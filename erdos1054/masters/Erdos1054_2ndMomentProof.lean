    linarith [hLHS1, hLHS2, hchain, h1.le, h1.ge, h2.le, h2.ge]
  -- bound the log: log(7NѕГ/(ѕГвИТ1)) вЙ§ log(7N) + log(1/x)
  have hlogb : Real.log ((N:вДЭ)*7*ѕГ/(ѕГ-1))
