      rw [hc, Complex.exp_eq_one_iff]; exact вЯ®k, by ringвЯ©
    have hderiv : вИА ќ± вИИ Set.uIcc (0:вДЭ) 1,
        HasDerivAt (fun ќ± : вДЭ => Complex.exp (c * вЖСќ±) / c) (e ((k : вДЭ) * ќ±)) ќ± := by
      intro ќ± _
      have h1 : HasDerivAt (fun ќ± : вДЭ => c * (вЖСќ± : вДВ)) c ќ± := by
        simpa using (Complex.ofRealCLM.hasDerivAt).const_mul c
      have h2 : HasDerivAt (fun ќ± : вДЭ => Complex.exp (c * вЖСќ±))
          (Complex.exp (c * вЖСќ±) * c) ќ± := h1.cexp
      have h3 := h2.div_const c
      rw [mul_div_assoc, div_self hcne, mul_one] at h3
      have hval : e ((k : вДЭ) * ќ±) = Complex.exp (c * вЖСќ±) := by
        rw [e, hc]; push_cast; ring_nf
      rw [hval]; exact h3
    have hcont : IntervalIntegrable (fun ќ± : вДЭ => e ((k : вДЭ) * ќ±)) MeasureTheory.volume 0 1 := by
      apply Continuous.intervalIntegrable; unfold e; fun_prop
    rw [intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv hcont]
    rw [Complex.ofReal_one, Complex.ofReal_zero, mul_one, mul_zero, Complex.exp_zero, hexpc]
    ring

/-- Orthogonality with natural indices: `вИЂвВА¬є e((mвИТn)ќ±) dќ± = [m = n]`. -/
lemma integral_e_nat (m n : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1, e (((m : вДЭ) - n) * ќ±) = if m = n then 1 else 0 := by
  have h := integral_e ((m : вД§) - n)
  have hcast : (((m : вД§) - (n : вД§) : вД§) : вДЭ) = (m : вДЭ) - n := by push_cast; ring
  rw [hcast] at h
  simpa only [sub_eq_zero, Int.natCast_inj] using h

/-- **Fourier extraction of the representation count**: the `n`-th Fourier coefficient of
    `S(ќ±)¬≤` is the twofold representation sum `R(n) = вИС_{m+k=n} aвВШaвВЦ` вАФ the bridge from
    the circle integral to Goldbach counts. -/
lemma fourier_coeff_sq (a : вДХ вЖТ вДВ) (N n : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1,
        (вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2 * e (-((n : вДЭ) * ќ±))
      = вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
