    calc 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1))
        вЙ§ 1 / 16 * (X : вДЭ) / 2 := h
      _ вЙ§ ((X : вДЭ) + 1) / 16 / 2 := by linarith
  ¬Ј exact hvar_of_arc_error_ax repWeight (fun X n => (cmodel (X + 1) n).re) mainTerm
      (fun ќµ hќµ => core_variance_repWeight cmodel core_variance_ax ќµ hќµ) harc

end PhaseF

end GoldbachReduction

