/-- Shim 1: `perron_kernel_gtOne` вАФ unfold `VerticalIntegral' = (1/(2ѕАi))вАҐ(iвАҐвИЂ)` and cancel `I`. -/
theorem perron_kernel_gtOne (y : вДЭ) (hy : 1 < y) (ѕГ : вДЭ) (hѕГ : 0 < ѕГ) :
    (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
        ((y : вДВ) ^ ((ѕГ : вДВ) + t * I)) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1))
      = 1 - 1 / (y : вДВ) := by
  have h := Perron.formulaGtOne (x := y) (ѕГ := ѕГ) hy hѕГ
  unfold VerticalIntegral' VerticalIntegral at h
  rw [smul_smul, smul_eq_mul] at h
  have hI : (1 / (2 * (Real.pi : вДВ) * I)) * I = 1 / (2 * (Real.pi : вДВ)) := by
    have hpi : (Real.pi : вДВ) вЙ† 0 := ofReal_ne_zero.mpr Real.pi_ne_zero
    field_simp
  rw [hI] at h
  exact h

/-- Shim 2: `perron_kernel_ltOne` вАФ `VerticalIntegral (f y) ѕГ = 0`, cancel the `IвАҐ`. -/
theorem perron_kernel_ltOne (y : вДЭ) (hy0 : 0 < y) (hy : y < 1) (ѕГ : вДЭ) (hѕГ : 0 < ѕГ) :
    (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
        ((y : вДВ) ^ ((ѕГ : вДВ) + t * I)) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1))
      = 0 := by
  have h := Perron.formulaLtOne (x := y) (ѕГ := ѕГ) hy0 hy hѕГ
  unfold VerticalIntegral at h
  rw [smul_eq_mul] at h
  rcases mul_eq_zero.mp h with hI | hint
  ¬Ј exact absurd hI I_ne_zero
  ¬Ј rw [hint, mul_zero]

/-- Shim 3: `medium_PNT` вАФ the isBigO form of `MediumPNT` made explicit for all `x вЙ• 2`,
    with the compact window `[2, XвВА]` absorbed into the constant (ѕИ is monotone, and the
    comparator is bounded below by `2¬Јexp(вИТc¬Ј(log M)^{1/10})` there). -/
theorem medium_PNT : вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИА x : вДЭ, 2 вЙ§ x вЖТ
    |(вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n) - x|
      вЙ§ C * x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by
  obtain вЯ®c, hc, hOвЯ© := MediumPNT
  rw [Asymptotics.isBigO_iff] at hO
  obtain вЯ®C, hCвЯ© := hO
  rw [Filter.eventually_atTop] at hC
  obtain вЯ®XвВА, hXвВАвЯ© := hC
  set M : вДЭ := max 2 XвВА with hMdef
  have hM2 : (2:вДЭ) вЙ§ M := le_max_left _ _
  have hM0 : (0:вДЭ) < M := by linarith
  -- comparator lower bound on [2, M]
  set m : вДЭ := 2 * Real.exp (-c * Real.log M ^ ((1:вДЭ)/10)) with hmdef
  have hm0 : 0 < m := by positivity
  -- ѕИ is monotone in x (sum of nonnegatives over a growing range)
  have hpsi_mono : вИА x : вДЭ, x вЙ§ M вЖТ
      (вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n) вЙ§ вИС n вИИ Finset.range (вМКMвМЛвВК + 1), ќЫ n := by
    intro x hx
    apply Finset.sum_le_sum_of_subset_of_nonneg
    ¬Ј intro k hk
      rw [Finset.mem_range] at hk вКҐ
      have := Nat.floor_le_floor hx
      omega
    ¬Ј intro n _ _
      exact vonMangoldt_nonneg
  set K : вДЭ := (вИС n вИИ Finset.range (вМКMвМЛвВК + 1), ќЫ n) + M with hKdef
  have hK0 : 0 < K := by
    have h1 : (0:вДЭ) вЙ§ вИС n вИИ Finset.range (вМКMвМЛвВК + 1), ќЫ n :=
      Finset.sum_nonneg (fun n _ => vonMangoldt_nonneg)
    linarith
  refine вЯ®c, max C 1 + K / m, hc, by positivity, ?_вЯ©
  intro x hx
  have hx0 : (0:вДЭ) < x := by linarith
  have hcomp0 : 0 < x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by positivity
  rcases le_total x M with hxM | hxM
  ¬Ј -- compact window: |ѕИ вИТ x| вЙ§ K and the comparator вЙ• m¬Ј(x/x)вА¶ use m вЙ§ x¬Јexp(вИТc logx^{1/10})
    have hѕИx : |(вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n) - x| вЙ§ K := by
      have h1 : (0:вДЭ) вЙ§ вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n :=
        Finset.sum_nonneg (fun n _ => vonMangoldt_nonneg)
      have h2 := hpsi_mono x hxM
      rw [abs_le]
      constructor
      ¬Ј have : x вЙ§ M := hxM
        nlinarith
      ¬Ј nlinarith
    have hcomp_ge : m вЙ§ x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by
      have hlog_le : Real.log x вЙ§ Real.log M := Real.log_le_log hx0 hxM
      have hlx0 : (0:вДЭ) вЙ§ Real.log x := Real.log_nonneg (by linarith)
      have hrpow_le : Real.log x ^ ((1:вДЭ)/10) вЙ§ Real.log M ^ ((1:вДЭ)/10) :=
        Real.rpow_le_rpow hlx0 hlog_le (by norm_num)
      have hexp_le : Real.exp (-c * Real.log M ^ ((1:вДЭ)/10))
          вЙ§ Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by
        apply Real.exp_le_exp.mpr
        nlinarith
      calc m = 2 * Real.exp (-c * Real.log M ^ ((1:вДЭ)/10)) := hmdef
        _ вЙ§ 2 * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by
            apply mul_le_mul_of_nonneg_left hexp_le (by norm_num)
        _ вЙ§ x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by
            apply mul_le_mul_of_nonneg_right hx (Real.exp_pos _).le
    calc |(вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n) - x| вЙ§ K := hѕИx
      _ = (K / m) * m := by field_simp
      _ вЙ§ (K / m) * (x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))) := by
          apply mul_le_mul_of_nonneg_left hcomp_ge (by positivity)
      _ вЙ§ (max C 1 + K / m) * (x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))) := by
          apply mul_le_mul_of_nonneg_right _ hcomp0.le
          have : (0:вДЭ) вЙ§ max C 1 := le_trans zero_le_one (le_max_right _ _)
          linarith
      _ = (max C 1 + K / m) * x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by ring
  ¬Ј -- asymptotic window: cite the isBigO bound
    have h := hXвВА x (by linarith [le_max_right (2:вДЭ) XвВА])
    have hѕИ : ChebyshevPsi x = вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n :=
      Chebyshev.psi_eq_sum_range x
    rw [Real.norm_eq_abs, Real.norm_eq_abs] at h
    have hxexp : |x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))|
        = x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := abs_of_pos hcomp0
    calc |(вИС n вИИ Finset.range (вМКxвМЛвВК + 1), ќЫ n) - x|
        = |(ChebyshevPsi x - x)| := by rw [hѕИ]
      _ вЙ§ C * |x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))| := by
          have := h
          simpa using this
      _ = C * (x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))) := by rw [hxexp]
      _ вЙ§ (max C 1 + K / m) * (x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10))) := by
          apply mul_le_mul_of_nonneg_right _ hcomp0.le
          have h1 : C вЙ§ max C 1 := le_max_left _ _
          have h2 : (0:вДЭ) вЙ§ K / m := by positivity
          linarith
      _ = (max C 1 + K / m) * x * Real.exp (-c * Real.log x ^ ((1:вДЭ)/10)) := by ring

end SWShims

