            congr 1
            ring
        _ вЙ§ |(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
              - ((t:вДЭ) - 1) / (q.totient : вДЭ)|
            + |((t:вДЭ) - 1) / (q.totient : вДЭ) - (t:вДЭ) * (1 / (q.totient : вДЭ))| :=
            abs_add_le _ _
        _ вЙ§ |(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
