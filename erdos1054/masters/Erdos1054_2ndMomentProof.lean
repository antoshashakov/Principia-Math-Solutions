      linarith
    have hzero' : (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * I)).re вЙ§ M - 1 / (ѕГ - ќ≤) := by
      linarith [hzb, hKA, hKU5]
    have hgb := growth_bound_uniform N (ѕЗ ^ 2) hѕЗ2 (2 * ќ≥) ѕГ hѕГ1 hѕГ2
    have hpt2 : ((ѕГ : вДВ) + ((2 * ќ≥ : вДЭ) : вДВ) * I) = ((ѕГ : вДВ) + 2 * (ќ≥ : вДВ) * I) := by
      push_cast
      ring
    rw [hpt2] at hgb
    have habs2 : (2:вДЭ) * |2 * ќ≥| + 7 = 4 * |ќ≥| + 7 := by
      rw [abs_mul, abs_two]
      ring
    rw [habs2] at hgb
    have hgrowth : (LSeries (вЖЧ(ѕЗ ^ 2) * вЖЧќЫ) ((ѕГ : вДВ) + 2 * ќ≥ * I)).re вЙ§ M := by
      linarith [hKA]
    have hcb := combined_bound_from_ingredients ќ≤ ѕГ M _ _ _ hcombo hpole hzero' hgrowth
    have h34 : 3 / (4 * (ѕГ - 1)) = 75 * M := by
      rw [hѕГ1']
      rw [div_eq_iff (by
        have : (0:вДЭ) < 4 * (1 / (100 * M)) := by linarith
        exact ne_of_gt this)]
      field_simp
      ring
    rw [h34] at hcb
    have h77 : 1 / (ѕГ - ќ≤) вЙ§ 77 * M := by linarith
    have hgap : 1 / (77 * M) вЙ§ ѕГ - ќ≤ := by
