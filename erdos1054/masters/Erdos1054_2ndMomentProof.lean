  -- Step 2: the finite Abel identity at w(n) = n^{вИТќ≤}
  have hiden : вИС n вИИ Icc 1 x, a n * ((n:вДЭ)) ^ (-ќ≤)
      = lam * (вИС n вИИ Icc 1 x, ((n:вДЭ)) ^ (-ќ≤)) + E x * ((x:вДЭ)) ^ (-ќ≤)
        + вИС n вИИ Icc 1 (x - 1), E n * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤)) :=
    abel_master_identity a lam E hAE (fun n => ((n:вДЭ)) ^ (-ќ≤)) x hx1
  -- Step 3: the E-part vs the full E-series
  have hbridgeE : SF = ((( вИС n вИИ Icc 1 (x - 1),
      E n * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤)) : вДЭ)) : вДВ) := by
    rw [hSF, Finset.sum_congr rfl (fun n _ => eabel_term_real E n ќ≤),
      вЖР Complex.ofReal_sum]
  have hSFre : (вИС n вИИ Icc 1 (x - 1),
      E n * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤))) = SF.re := by
    rw [hbridgeE, Complex.ofReal_re]
  have hEtail := eabel_tail_bound E C hC0 hE0 hE hќ≤1 hќ≤2 x hx
  have hSEle : вИС n вИИ Icc 1 (x - 1), E n * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤))
