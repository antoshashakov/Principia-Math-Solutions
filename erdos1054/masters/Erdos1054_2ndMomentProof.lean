  have hLcne : DirichletCharacter.LFunctionTrivChar N c вЙ† 0 := by
    intro h
    have h' : DirichletCharacter.LFunction (1 : DirichletCharacter вДВ N) c = 0 := h
    rw [h', norm_zero] at hLne
    nlinarith [hLpos]
  have hld : logDeriv (DirichletCharacter.LFunctionTrivCharвВБ N) c
      = 1/(c-1) + logDeriv (DirichletCharacter.LFunctionTrivChar N) c := by
    rw [logDeriv_apply, logDeriv_apply,
