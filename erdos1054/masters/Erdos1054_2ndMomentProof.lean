      exact hpoint n h
  -- assemble
  calc вАЦвИС' n : вДХ, (if n < x then (0:вДВ) else ((((ќ≤:вДВ)) - 1) * ((n:вДВ)) ^ (-(ќ≤:вДВ))
        - (((n:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ)))))вАЦ
      вЙ§ вИС' n : вДХ, вАЦif n < x then (0:вДВ) else ((((ќ≤:вДВ)) - 1) * ((n:вДВ)) ^ (-(ќ≤:вДВ))
        - (((n:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ))))вАЦ :=
        norm_tsum_le_tsum_norm hnorm_sum
    _ вЙ§ 11 * ((x:вДЭ)) ^ (-ќ≤) :=
        hnorm_sum.tsum_le_of_sum_range_le hpartial

/-- Real Abel initial-value summation (A2h-iv-a1): the вДЭ twin of `abel_initial`. -/
lemma abel_initial_r (a w : вДХ вЖТ вДЭ) : вИА x : вДХ, 1 вЙ§ x вЖТ
    вИС n вИИ Icc 1 x, a n * w n
      = (вИС n вИИ Icc 1 x, a n) * w x
        + вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1)) := by
  intro x
  induction x with
  | zero =>
    intro h0
    omega
  | succ p ih =>
    intro _
    rcases Nat.eq_zero_or_pos p with rfl | hp
    ¬Ј simp
    ¬Ј have hp1 : (p + 1 : вДХ) - 1 = p := by omega
      have hnotmem : (p + 1) вИЙ Icc 1 p := by
        simp only [Finset.mem_Icc]
        omega
      have hnotmem2 : p вИЙ Icc 1 (p - 1) := by
        simp only [Finset.mem_Icc]
        omega
      have hins : Icc 1 (p + 1) = insert (p + 1) (Icc 1 p) := by
        ext m
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      have hins2 : Icc 1 p = insert p (Icc 1 (p - 1)) := by
        ext m
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      have hLHS : вИС n вИИ Icc 1 (p + 1), a n * w n
          = a (p + 1) * w (p + 1) + вИС n вИИ Icc 1 p, a n * w n := by
        rw [hins, Finset.sum_insert hnotmem]
      have hRHS2 : вИС n вИИ Icc 1 ((p + 1) - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1))
          = (вИС m вИИ Icc 1 p, a m) * (w p - w (p + 1))
            + вИС n вИИ Icc 1 (p - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1)) := by
        rw [hp1]
        conv_lhs => rw [hins2]
        rw [Finset.sum_insert hnotmem2]
      have hA : вИС m вИИ Icc 1 (p + 1), a m = a (p + 1) + вИС m вИИ Icc 1 p, a m := by
        rw [hins, Finset.sum_insert hnotmem]
      rw [hLHS, ih hp, hRHS2, hA]
      ring

/-- **The finite Abel master identity** (Siegel brick A2h-iv-a): for partial sums
    `A(y) = ќїy + E(y)`, against ANY weight `w`:
    `ќ£_{nвЙ§x} a(n)w(n) = ќї¬Јќ£_{nвЙ§x}w(n) + E(x)w(x) + ќ£_{n<x}E(n)(w(n)вИТw(n+1))` вАФ
    the ќї-part telescopes exactly; no continuation enters. -/
theorem abel_master_identity (a : вДХ вЖТ вДЭ) (lam : вДЭ) (E : вДХ вЖТ вДЭ)
    (hAE : вИА n : вДХ, вИС m вИИ Icc 1 n, a m = lam * n + E n)
    (w : вДХ вЖТ вДЭ) (x : вДХ) (hx : 1 вЙ§ x) :
    вИС n вИИ Icc 1 x, a n * w n
    = lam * (вИС n вИИ Icc 1 x, w n) + E x * w x
      + вИС n вИИ Icc 1 (x - 1), E n * (w n - w (n + 1)) := by
  rw [abel_initial_r a w x hx, hAE x]
  have hterm : вИА n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1))
      = (n : вДЭ) * (w n - w (n + 1)) * lam + E n * (w n - w (n + 1)) := by
    intro n _
    rw [hAE n]
    ring
  rw [Finset.sum_congr rfl hterm, Finset.sum_add_distrib, вЖР Finset.sum_mul,
    weighted_telescope w (x - 1)]
  have hxx : (x - 1 : вДХ) + 1 = x := by omega
  rw [hxx]
  have hsplit : вИС n вИИ Icc 1 x, w n = w x + вИС n вИИ Icc 1 (x - 1), w n := by
    rw [show Icc 1 x = insert x (Icc 1 (x - 1)) from by
      ext m
      simp only [Finset.mem_insert, Finset.mem_Icc]
      omega, Finset.sum_insert (by
        simp only [Finset.mem_Icc]
        omega)]
  rw [hsplit]
  have hcast : ((x - 1 : вДХ) : вДЭ) = (x : вДЭ) - 1 := by
    push_cast [Nat.cast_sub hx]
    ring
  rw [hcast]
  ring

/-- Real-cast bridge for cpow at real exponents (A2h-iv-b0). -/
lemma cpow_real_cast (n : вДХ) (ќ≤ : вДЭ) :
    ((n:вДВ)) ^ (-(ќ≤:вДВ)) = ((((n:вДЭ)) ^ (-ќ≤) : вДЭ) : вДВ) := by
  rw [show -(ќ≤:вДВ) = (((-ќ≤ : вДЭ)):вДВ) from by push_cast; ring,
    show ((n:вДВ)) = (((n:вДЭ)):вДВ) from by push_cast; ring]
  exact (Complex.ofReal_cpow (Nat.cast_nonneg n) (-ќ≤)).symm

/-- The E-Abel term is real at real exponents (A2h-iv-b0'). -/
lemma eabel_term_real (E : вДХ вЖТ вДЭ) (n : вДХ) (ќ≤ : вДЭ) :
    ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))
    = (((E n * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤)) : вДЭ)) : вДВ) := by
  rw [cpow_real_cast n ќ≤, cpow_real_cast (n + 1) ќ≤]
  push_cast
  ring

/-- **The E-Abel tail bound** (Siegel brick A2h-iv-b): with `|E(n)| вЙ§ C¬Јn^{3/4}(1+log n)`,
    at real `ќ≤ вИИ (9/10, 1)` the series tail beyond `x` is `вЙ§ 400C¬Јx^{7/8вИТќ≤}` вАФ the error
    that the choice `9/10 > 7/8` makes vanish. -/
theorem eabel_tail_bound (E : вДХ вЖТ вДЭ) (C : вДЭ) (hC0 : 0 вЙ§ C) (hE0 : E 0 = 0)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)))
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1) (x : вДХ) (hx : 2 вЙ§ x) :
    вАЦ(вИС' n : вДХ, ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))
      - вИС n вИИ Icc 1 (x - 1), ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
    вЙ§ 400 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) := by
  have hx1 : 1 вЙ§ x := by omega
  have hx0 : (0:вДЭ) < (x:вДЭ) := by
    have : (0:вДХ) < x := by omega
    exact_mod_cast this
  have hќ≤0 : (0:вДЭ) < ќ≤ := by linarith
  have hp1 : (1:вДЭ) < ќ≤ + 1/8 := by linarith
  -- the pointwise majorant: вАЦE(n)ќФnвАЦ вЙ§ 9C¬Јn^{вИТ(ќ≤+1/8)} for n вЙ• 1
  have hpoint : вИА n : вДХ, 1 вЙ§ n вЖТ
      вАЦ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
      вЙ§ 9 * C * ((n:вДЭ)) ^ (-(ќ≤ + 1/8)) := by
    intro n hn
    have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
    have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
    rw [eabel_term_real, Complex.norm_real, Real.norm_eq_abs, abs_mul]
    have hќФ0 : (0:вДЭ) вЙ§ ((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤) := by
      have hmono : (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤) вЙ§ ((n:вДЭ)) ^ (-ќ≤) := by
        apply Real.rpow_le_rpow_of_nonpos hn0 (by push_cast; linarith)
        linarith
      linarith
    have hќФle : ((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤) вЙ§ ((n:вДЭ)) ^ (-ќ≤ - 1) := by
      calc ((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤)
          вЙ§ ќ≤ * ((n:вДЭ)) ^ (-ќ≤ - 1) := rpow_diff_le n hn ќ≤ hќ≤0.le
        _ вЙ§ 1 * ((n:вДЭ)) ^ (-ќ≤ - 1) := by
            apply mul_le_mul_of_nonneg_right (by linarith)
            exact Real.rpow_nonneg hn0.le _
        _ = ((n:вДЭ)) ^ (-ќ≤ - 1) := one_mul _
    have hlogbound : 1 + Real.log n вЙ§ 9 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
      have h1 : Real.log n вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) :=
        Real.log_le_rpow_div hn0.le (by norm_num)
      have h2 : ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) = 8 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by ring
      have h3 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) :=
        Real.one_le_rpow hn1r (by norm_num)
      linarith [h1, h2.le, h2.ge, h3]
    have hlog0 : (0:вДЭ) вЙ§ 1 + Real.log n := by
      have := Real.log_nonneg hn1r
      linarith
    have hEn := hE n hn
    have habs : |((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤)|
        = ((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤) := abs_of_nonneg hќФ0
    rw [habs]
    have hcollect : ((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) * ((n:вДЭ)) ^ (-ќ≤ - 1)
        = ((n:вДЭ)) ^ (-(ќ≤ + 1/8)) := by
      rw [вЖР Real.rpow_add hn0, вЖР Real.rpow_add hn0]
      congr 1
      ring
    calc |E n| * (((n:вДЭ)) ^ (-ќ≤) - (((n + 1 : вДХ)):вДЭ) ^ (-ќ≤))
        вЙ§ (C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n))) * (((n:вДЭ)) ^ (-ќ≤ - 1)) := by
          exact mul_le_mul hEn hќФle hќФ0 (by positivity)
      _ вЙ§ (C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (9 * ((n:вДЭ)) ^ ((1:вДЭ)/8)))) * (((n:вДЭ)) ^ (-ќ≤ - 1)) := by
          apply mul_le_mul_of_nonneg_right _ (Real.rpow_nonneg hn0.le _)
          apply mul_le_mul_of_nonneg_left _ hC0
          apply mul_le_mul_of_nonneg_left hlogbound (Real.rpow_nonneg hn0.le _)
      _ = 9 * C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) * ((n:вДЭ)) ^ (-ќ≤ - 1)) := by
          ring
      _ = 9 * C * ((n:вДЭ)) ^ (-(ќ≤ + 1/8)) := by rw [hcollect]
  -- summability of the terms
  have hsummable : Summable (fun n : вДХ => ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))) := by
    have hmaj : Summable (fun n : вДХ => (9 * C) * (1 / ((n:вДЭ)) ^ (ќ≤ + 1/8))) :=
      Summable.mul_left _ (Real.summable_one_div_nat_rpow.mpr hp1)
    apply Summable.of_norm_bounded
      (g := fun n : вДХ => (9 * C) * (1 / ((n:вДЭ)) ^ (ќ≤ + 1/8))) hmaj
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј rw [hE0]
      simp only [Complex.ofReal_zero, zero_mul, norm_zero]
      positivity
    ¬Ј have hn0 : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast hn
      have heq : (9 * C) * (1 / ((n:вДЭ)) ^ (ќ≤ + 1/8))
          = 9 * C * ((n:вДЭ)) ^ (-(ќ≤ + 1/8)) := by
        rw [one_div, вЖР Real.rpow_neg hn0.le]
      rw [heq]
      exact hpoint n hn
  -- the finite sum is the range-x head (the n = 0 term vanishes)
  have hhead : вИС n вИИ Icc 1 (x - 1), ((E n : вДЭ) : вДВ)
        * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))
      = вИС n вИИ range x, ((E n : вДЭ) : вДВ)
        * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) := by
    rw [show range x = insert 0 (Icc 1 (x - 1)) from by
      ext m
      simp only [Finset.mem_insert, Finset.mem_range, Finset.mem_Icc]
      omega, Finset.sum_insert (by
        simp only [Finset.mem_Icc]
        omega)]
    rw [hE0]
    simp
  rw [hhead]
  -- head/tail split of the tsum
  have hsplit : вИА n : вДХ, ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))
      = (if n < x then ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) else 0)
        + (if n < x then 0 else ((E n : вДЭ) : вДВ)
            * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))) := by
    intro n
    rcases Nat.lt_or_ge n x with h | h
    ¬Ј rw [if_pos h, if_pos h, add_zero]
    ¬Ј rw [if_neg (not_lt.mpr h), if_neg (not_lt.mpr h), zero_add]
  have hheadsum : Summable (fun n : вДХ => (if n < x then ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) else 0)) :=
    summable_of_ne_finset_zero (s := range x) (by
      intro n hn
      rw [Finset.mem_range] at hn
      rw [if_neg hn])
  have htailsum : Summable (fun n : вДХ => (if n < x then 0 else ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))) := by
    apply Summable.of_norm_bounded (g := fun n : вДХ =>
      вАЦ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ)
      hsummable.norm
    intro n
    rcases Nat.lt_or_ge n x with h | h
    ¬Ј rw [if_pos h, norm_zero]
      exact norm_nonneg _
    ¬Ј rw [if_neg (not_lt.mpr h)]
  have htsum_split : (вИС' n : вДХ, ((E n : вДЭ) : вДВ)
        * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))
      = (вИС n вИИ range x, ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))
        + вИС' n : вДХ, (if n < x then 0 else ((E n : вДЭ) : вДВ)
            * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))) := by
    calc вИС' n : вДХ, ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))
        = вИС' n : вДХ, ((if n < x then ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) else 0)
            + (if n < x then 0 else ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))) := tsum_congr hsplit
      _ = (вИС' n : вДХ, (if n < x then ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) else 0))
            + вИС' n : вДХ, (if n < x then 0 else ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))) :=
          hheadsum.tsum_add htailsum
      _ = (вИС n вИИ range x, ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))
            + вИС' n : вДХ, (if n < x then 0 else ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))) := by
          congr 1
          rw [tsum_eq_sum (s := range x) (by
            intro n hn
            rw [Finset.mem_range] at hn
            rw [if_neg hn])]
          apply Finset.sum_congr rfl
          intro n hn
          rw [Finset.mem_range] at hn
          rw [if_pos hn]
  rw [htsum_split]
  rw [show вИА (u v : вДВ), u + v - u = v from fun u v => by ring]
  -- bound the tail tsum by its norms
  have hxќ≤ : (0:вДЭ) вЙ§ ((x:вДЭ)) ^ (7/8 - ќ≤) := Real.rpow_nonneg hx0.le _
  have hnormsum : Summable (fun n : вДХ => вАЦif n < x then 0 else ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ) := htailsum.norm
  have hpartial : вИА z : вДХ, вИС n вИИ range z, вАЦif n < x then 0 else ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
      вЙ§ 400 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) := by
    intro z
    have hite : вИА n вИИ range z, вАЦif n < x then (0:вДВ) else ((E n : вДЭ) : вДВ)
        * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
        = (if x вЙ§ n then вАЦ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ else 0) := by
      intro n _
      rcases Nat.lt_or_ge n x with h | h
      ¬Ј rw [if_pos h, if_neg (by omega), norm_zero]
      ¬Ј rw [if_neg (not_lt.mpr h), if_pos h]
    rw [Finset.sum_congr rfl hite, вЖР Finset.sum_filter]
    have hset : (range z).filter (fun n => x вЙ§ n) = Icc x (z - 1) := by
      ext n
      simp only [Finset.mem_filter, Finset.mem_range, Finset.mem_Icc]
      omega
    rw [hset]
    rcases Nat.lt_or_ge (z - 1) x with hm | hm
    ¬Ј rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty]
      positivity
    ¬Ј rw [show Icc x (z - 1) = insert x (Icc (x + 1) (z - 1)) from by
        ext n
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega, Finset.sum_insert (by simp)]
      have h1 : вАЦ((E x : вДЭ) : вДВ) * (((x:вДВ)) ^ (-(ќ≤:вДВ)) - (((x + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
          вЙ§ 9 * C * ((x:вДЭ)) ^ (-(ќ≤ + 1/8)) := hpoint x hx1
      have h2 : вИС n вИИ Icc (x + 1) (z - 1), вАЦ((E n : вДЭ) : вДВ)
            * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ
          вЙ§ вИС n вИИ Icc (x + 1) (z - 1), 9 * C * ((n:вДЭ)) ^ (-(ќ≤ + 1/8)) := by
        apply Finset.sum_le_sum
