noncomputable def arc (Q : вДХ) (pq : вДХ √Ч вД§) : Set вДЭ :=
  Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1))) вИ© Set.Ioc (0:вДЭ) 1

noncomputable def redRes (q : вДХ) : Finset вДХ := (Finset.range q).filter (fun a => Nat.gcd a q = 1)

noncomputable def PsiIdeal (N P : вДХ) (ќ± : вДЭ) : вДВ :=
  вИС q вИИ Finset.Icc 1 P, ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
    * вИС a вИИ redRes q, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2

noncomputable def PhiArc (N P Q : вДХ) (ќ± : вДЭ) : вДВ :=
  вИС pq вИИ anchors P, (arc Q pq).indicator
    (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
      * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±

