              * gвВГ d.2.2.2.2.2.1 * gвВГ d.2.2.2.2.2.2) := by
          simp only [hb]; rw [вЖР ENNReal.tsum_mul_left]
    _ = ENNReal.ofReal ((E : вДЭ) ^ (-(3 / 2 : вДЭ)))
          * (Sp (3 / 2) * Sp (4 / 3) * Sp (4 / 3) * Sp (4 / 3)
              * Sp (7 / 6) * Sp (7 / 6) * Sp (7 / 6)) := by
          rw [tsum7 gвВБ gвВВ gвВГ, hS1, hS2, hS3]; ring

/-- `U(E)` is finite (corollary вАФ the crude bound diverges; finiteness comes THROUGH
    the extraction). -/
theorem U_lt_top (E : вДХ) (hE : 1 вЙ§ E) : U E < вК§ := by
  refine lt_of_le_of_lt (U_le_ennreal E hE) ?_
  rw [lt_top_iff_ne_top]
  refine ENNReal.mul_ne_top ENNReal.ofReal_ne_top ?_
  refine ENNReal.mul_ne_top (ENNReal.mul_ne_top (ENNReal.mul_ne_top
    (ENNReal.mul_ne_top (ENNReal.mul_ne_top (ENNReal.mul_ne_top ?_ ?_) ?_) ?_) ?_) ?_) ?_
  all_goals exact Sp_ne_top (by norm_num)

/-- **Power-saving second-moment tail, `вДЭ` form** (paper Lemma 6.2):
    `(U E).toReal вЙ§ CвВВ¬ЈE^{вИТ3/2}` with `CвВВ = (ќґ(3/2)ќґ(4/3)¬≥ќґ(7/6)¬≥).toReal > 0`. -/
theorem U_power_saving :
    вИГ CвВВ : вДЭ, 0 < CвВВ вИІ вИА E : вДХ, 1 вЙ§ E вЖТ (U E).toReal вЙ§ CвВВ * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) := by
  set Cen : вДЭвЙ•0вИЮ := Sp (3 / 2) * Sp (4 / 3) * Sp (4 / 3) * Sp (4 / 3)
      * Sp (7 / 6) * Sp (7 / 6) * Sp (7 / 6) with hCen
  have hCtop : Cen вЙ† вК§ := by
    rw [hCen]
    refine ENNReal.mul_ne_top (ENNReal.mul_ne_top (ENNReal.mul_ne_top
      (ENNReal.mul_ne_top (ENNReal.mul_ne_top (ENNReal.mul_ne_top ?_ ?_) ?_) ?_) ?_) ?_) ?_
    all_goals exact Sp_ne_top (by norm_num)
  have hCpos : 0 < Cen := by
    rw [hCen, pos_iff_ne_zero]
    refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_)
      ?_) ?_) ?_) ?_
    all_goals exact Sp_pos.ne'
  refine вЯ®Cen.toReal, ENNReal.toReal_pos hCpos.ne' hCtop, fun E hE => ?_вЯ©
  have hchain := U_le_ennreal E hE
  rw [вЖР hCen] at hchain
  refine le_trans (ENNReal.toReal_mono (ENNReal.mul_ne_top ENNReal.ofReal_ne_top hCtop) hchain) ?_
  rw [ENNReal.toReal_mul, ENNReal.toReal_ofReal (by positivity)]
  exact le_of_eq (mul_comm _ _)

