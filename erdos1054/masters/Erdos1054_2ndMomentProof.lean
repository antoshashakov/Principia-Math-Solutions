/-! ## The WEIGHTED reduction вАФ consuming the circle method directly -/

open ArithmeticFunction
open scoped ArithmeticFunction

/-- **Proper prime powers are rare**: the count of `m вЙ§ n` with `ќЫ(m) вЙ† 0` but `m` not
    prime is at most `вИЪn ¬Ј (logвВВn + 1)` вАФ the elementary input for converting the
    ќЫ-weighted Goldbach count into the prime-pair count. -/
lemma card_properPrimePow_le (n : вДХ) :
    (((Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0)).card : вДЭ)
      вЙ§ (Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1) := by
  set s := (Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0) with hs
  have hcard : s.card вЙ§ (Nat.log 2 n + 1) * (Finset.Ioc 0 (Nat.sqrt n)).card := by
    apply Finset.card_le_mul_card_image_of_maps_to (f := Nat.minFac)
    ¬Ј intro m hm
      rw [hs, Finset.mem_filter, Finset.mem_Ioc] at hm
      obtain вЯ®вЯ®hm0, hmnвЯ©, hnp, hќЫвЯ© := hm
      rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ
      obtain вЯ®p, k, hp, hk, rflвЯ© := hќЫ
      have hp' := hp.nat_prime
      have hmf : (p ^ k).minFac = p := Nat.Prime.pow_minFac hp' hk.ne'
      rw [hmf, Finset.mem_Ioc]
      have hk2 : 2 вЙ§ k := by
        by_contra hcon
        interval_cases k
        exact hnp (by simpa using hp')
      refine вЯ®hp'.pos, ?_вЯ©
      rw [Nat.le_sqrt]
      calc p * p = p ^ 2 := by ring
        _ вЙ§ p ^ k := Nat.pow_le_pow_right hp'.pos hk2
        _ вЙ§ n := hmn
    ¬Ј intro p _
      have hsubfiber : (s.filter (fun m => m.minFac = p)).card
          вЙ§ (Finset.Icc 2 (Nat.log 2 n)).card := by
        apply Finset.card_le_card_of_injOn (fun m => Nat.log p m)
        ¬Ј intro m hm
          simp only [Finset.mem_coe, Finset.mem_filter] at hm
          obtain вЯ®hms, hmfвЯ© := hm
          rw [hs, Finset.mem_filter, Finset.mem_Ioc] at hms
          obtain вЯ®вЯ®hm0, hmnвЯ©, hnp, hќЫвЯ© := hms
          rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ
          obtain вЯ®q, k, hq, hk, rflвЯ© := hќЫ
          have hq' := hq.nat_prime
          have hqf : (q ^ k).minFac = q := Nat.Prime.pow_minFac hq' hk.ne'
          have hqp : q = p := by rw [вЖР hqf, hmf]
          subst hqp
          have hk2 : 2 вЙ§ k := by
            by_contra hcon
            interval_cases k
            exact hnp (by simpa using hq')
          simp only [Finset.mem_coe, Finset.mem_Icc, Nat.log_pow hq'.one_lt]
          refine вЯ®hk2, ?_вЯ©
          have h2k : 2 ^ k вЙ§ n := le_trans (Nat.pow_le_pow_left hq'.two_le k) hmn
          exact Nat.le_log_of_pow_le (by norm_num) h2k
        ¬Ј intro m1 hm1 m2 hm2 heq
          simp only [Finset.mem_coe, Finset.mem_filter] at hm1 hm2
          obtain вЯ®hms1, hmf1вЯ© := hm1
          obtain вЯ®hms2, hmf2вЯ© := hm2
          rw [hs, Finset.mem_filter] at hms1 hms2
          obtain вЯ®-, -, hќЫ1вЯ© := hms1
          obtain вЯ®-, -, hќЫ2вЯ© := hms2
          rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ1 hќЫ2
          obtain вЯ®q1, k1, hq1, hk1, rflвЯ© := hќЫ1
          obtain вЯ®q2, k2, hq2, hk2, rflвЯ© := hќЫ2
          have hq1' := hq1.nat_prime
          have hq2' := hq2.nat_prime
          have hf1 : (q1 ^ k1).minFac = q1 := Nat.Prime.pow_minFac hq1' hk1.ne'
          have hf2 : (q2 ^ k2).minFac = q2 := Nat.Prime.pow_minFac hq2' hk2.ne'
          have hq1p : q1 = p := by rw [вЖР hf1, hmf1]
          have hq2p : q2 = p := by rw [вЖР hf2, hmf2]
          subst hq1p
          subst hq2p
          simp only [Nat.log_pow hq1'.one_lt] at heq
          rw [heq]
      calc (s.filter (fun m => m.minFac = p)).card
          вЙ§ (Finset.Icc 2 (Nat.log 2 n)).card := hsubfiber
        _ вЙ§ Nat.log 2 n + 1 := by rw [Nat.card_Icc]; omega
  have hIoc : (Finset.Ioc 0 (Nat.sqrt n)).card = Nat.sqrt n := by
    rw [Nat.card_Ioc, Nat.sub_zero]
  rw [hIoc] at hcard
  calc (s.card : вДЭ) вЙ§ ((Nat.log 2 n + 1) * Nat.sqrt n : вДХ) := by exact_mod_cast hcard
    _ = (Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1) := by push_cast; ring

/-- **The bad-n bound**: if `n` is NOT a sum of two primes, the ќЫ-weighted representation
    count is supported on pairs containing a proper prime power, hence
    `вЙ§ 2¬Јlog¬≤n¬ЈвИЪn¬Ј(logвВВn+1)` вАФ negligible against the main term `вЙН n`. -/
lemma badRep_le (N n : вДХ) (hn : 1 вЙ§ n)
    (hbad : ¬ђ вИГ p q, Nat.Prime p вИІ Nat.Prime q вИІ n = p + q) :
    вИС pr вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun pr => pr.1 + pr.2 = n),
        ќЫ pr.1 * ќЫ pr.2
      вЙ§ 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) := by
  classical
  set F := (Finset.range N √ЧЋҐ Finset.range N).filter (fun pr => pr.1 + pr.2 = n) with hF
  set F' := F.filter (fun pr => ќЫ pr.1 * ќЫ pr.2 вЙ† 0) with hF'
  set PP := (Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0) with hPP
  have hlogn : 0 вЙ§ Real.log n := Real.log_nonneg (by exact_mod_cast hn)
  have hmem : вИА pr вИИ F', pr.1 + pr.2 = n вИІ ќЫ pr.1 вЙ† 0 вИІ ќЫ pr.2 вЙ† 0 := by
    intro pr hpr
    rw [hF', Finset.mem_filter] at hpr
    obtain вЯ®hprF, hneвЯ© := hpr
    rw [hF, Finset.mem_filter] at hprF
    exact вЯ®hprF.2, fun h => hne (by rw [h, zero_mul]),
      fun h => hne (by rw [h, mul_zero])вЯ©
  have hterm : вИА pr вИИ F', ќЫ pr.1 * ќЫ pr.2 вЙ§ Real.log n ^ 2 := by
    intro pr hpr
    obtain вЯ®hsum, h1, h2вЯ© := hmem pr hpr
    have h1le : 2 вЙ§ pr.1 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h1).two_le
    have h2le : 2 вЙ§ pr.2 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h2).two_le
    have hb1 : ќЫ pr.1 вЙ§ Real.log n :=
      le_trans ArithmeticFunction.vonMangoldt_le_log
        (Real.log_le_log (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_two h1le)
          (by exact_mod_cast Nat.le.intro hsum))
    have hb2 : ќЫ pr.2 вЙ§ Real.log n :=
      le_trans ArithmeticFunction.vonMangoldt_le_log
        (Real.log_le_log (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_two h2le)
          (by exact_mod_cast Nat.le.intro (by omega : pr.2 + pr.1 = n)))
    calc ќЫ pr.1 * ќЫ pr.2 вЙ§ Real.log n * Real.log n :=
          mul_le_mul hb1 hb2 ArithmeticFunction.vonMangoldt_nonneg hlogn
      _ = Real.log n ^ 2 := (sq (Real.log n)).symm
  have hsplit : вИС pr вИИ F', ќЫ pr.1 * ќЫ pr.2
      = (вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2)
        + вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2 :=
    (Finset.sum_filter_add_sum_filter_not F' _ _).symm
  -- the ¬ђprime-first-coordinate class injects into PP via pr вЖ¶ pr.1
  have hcardA : (F'.filter (fun pr => ¬ђ pr.1.Prime)).card вЙ§ PP.card := by
    apply Finset.card_le_card_of_injOn (fun pr => pr.1)
    ¬Ј intro pr hpr
      simp only [Finset.mem_coe, Finset.mem_filter] at hpr
      obtain вЯ®hprF', hnpвЯ© := hpr
      obtain вЯ®hsum, h1, _вЯ© := hmem pr hprF'
      have h1le : 2 вЙ§ pr.1 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h1).two_le
      simp only [Finset.mem_coe, hPP, Finset.mem_filter, Finset.mem_Ioc]
      exact вЯ®вЯ®by omega, Nat.le.intro hsumвЯ©, hnp, h1вЯ©
    ¬Ј intro p1 hp1 p2 hp2 heq
      simp only [Finset.mem_coe, Finset.mem_filter] at hp1 hp2
      have hs1 := (hmem p1 hp1.1).1
      have hs2 := (hmem p2 hp2.1).1
      dsimp only at heq
      have : p1.2 = p2.2 := by omega
      exact Prod.ext heq this
  -- the prime-first-coordinate class: second coordinate is a proper prime power
  have hcardB : (F'.filter (fun pr => pr.1.Prime)).card вЙ§ PP.card := by
    apply Finset.card_le_card_of_injOn (fun pr => pr.2)
    ¬Ј intro pr hpr
      simp only [Finset.mem_coe, Finset.mem_filter] at hpr
      obtain вЯ®hprF', hp1вЯ© := hpr
      obtain вЯ®hsum, h1, h2вЯ© := hmem pr hprF'
      have h2le : 2 вЙ§ pr.2 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h2).two_le
      have hnp2 : ¬ђ pr.2.Prime := by
        intro hp2
        exact hbad вЯ®pr.1, pr.2, hp1, hp2, hsum.symmвЯ©
      simp only [Finset.mem_coe, hPP, Finset.mem_filter, Finset.mem_Ioc]
      exact вЯ®вЯ®by omega, Nat.le.intro (by omega : pr.2 + pr.1 = n)вЯ©, hnp2, h2вЯ©
    ¬Ј intro p1 hp1 p2 hp2 heq
      simp only [Finset.mem_coe, Finset.mem_filter] at hp1 hp2
      have hs1 := (hmem p1 hp1.1).1
      have hs2 := (hmem p2 hp2.1).1
      dsimp only at heq
      have : p1.1 = p2.1 := by omega
      exact Prod.ext this heq
  have hboundA : вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
      вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
    calc вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
        вЙ§ вИС _pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), Real.log n ^ 2 :=
          Finset.sum_le_sum (fun pr hpr => hterm pr (Finset.mem_of_mem_filter pr hpr))
      _ = ((F'.filter (fun pr => ¬ђ pr.1.Prime)).card : вДЭ) * Real.log n ^ 2 := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ (by positivity)
          exact_mod_cast hcardA
  have hboundB : вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
      вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
    calc вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
        вЙ§ вИС _pr вИИ F'.filter (fun pr => pr.1.Prime), Real.log n ^ 2 :=
          Finset.sum_le_sum (fun pr hpr => hterm pr (Finset.mem_of_mem_filter pr hpr))
      _ = ((F'.filter (fun pr => pr.1.Prime)).card : вДЭ) * Real.log n ^ 2 := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ (by positivity)
          exact_mod_cast hcardB
  have hPPbound := card_properPrimePow_le n
  rw [вЖР hPP] at hPPbound
  calc вИС pr вИИ F, ќЫ pr.1 * ќЫ pr.2
      = вИС pr вИИ F', ќЫ pr.1 * ќЫ pr.2 := (Finset.sum_filter_ne_zero F).symm
    _ = (вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2)
        + вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2 := hsplit
    _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 + (PP.card : вДЭ) * Real.log n ^ 2 :=
        add_le_add hboundB hboundA
    _ = 2 * Real.log n ^ 2 * (PP.card : вДЭ) := by ring
    _ вЙ§ 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) := by
        apply mul_le_mul_of_nonneg_left hPPbound (by positivity)

/-- The ќЫ-weighted Goldbach representation sum over the window `{0,вА¶,X}` вАФ the object the
    circle method controls (`= R(n)` of `MinorArc.fourier_coeff_sq` with `N = X+1`). -/
noncomputable def repWeight (X n : вДХ) : вДЭ :=
  вИС pr вИИ (Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun pr => pr.1 + pr.2 = n),
    ќЫ pr.1 * ќЫ pr.2

/-- **Almost-all Goldbach from the WEIGHTED variance bound** вАФ the form the circle method
    actually produces. Requires: the main-term lower bound `ќі` on the upper block, the
    elementary negligibility of prime-power contributions against `ќі` (satisfied when
    `ќі X вЙЂ вИЪX log¬≥X`, true for the HL main term `вЙН X`), and the weighted variance bound. -/
theorem almost_all_goldbach_of_weighted_variance
    (m : вДХ вЖТ вДЭ) (ќі : вДХ вЖТ вДЭ) (hќіpos : вИА X, 0 < ќі X)
    (hmain : вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ Even n вЖТ ќі X вЙ§ m n)
    (hnegl : вИГ XвВБ : вДХ, вИА X : вДХ, XвВБ вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ
        2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) вЙ§ ќі X / 2)
    (hvar : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
        вИС n вИИ Ioc (X / 2) X, (repWeight X n - m n) ^ 2 вЙ§ ќµ * X * ќі X ^ 2) :
    DensityZero notSumOfTwoPrimes := by
  classical
  have hRform : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА, вИА X, XвВА вЙ§ X вЖТ
      (((range (X + 1)).filter notSumOfTwoPrimes).card : вДЭ) вЙ§ ќµ * X := by
    apply densityZero_of_block notSumOfTwoPrimes
    intro ќµ hќµ
    obtain вЯ®Xm, hXmвЯ© := hmain
    obtain вЯ®Xn, hXnвЯ© := hnegl
    obtain вЯ®Xv, hXvвЯ© := hvar (ќµ / 4) (by linarith)
    refine вЯ®max Xm (max Xn Xv), fun X hX => ?_вЯ©
    have hXmX : Xm вЙ§ X := le_trans (le_max_left _ _) hX
    have hXnX : Xn вЙ§ X := le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hX
    have hXvX : Xv вЙ§ X := le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) hX
    have hBbound : вИА n вИИ (Ioc (X / 2) X).filter notSumOfTwoPrimes,
        ќі X / 2 вЙ§ |repWeight X n - m n| := by
      intro n hn
      rw [mem_filter, mem_Ioc] at hn
      obtain вЯ®вЯ®hn1, hn2вЯ©, hbadвЯ© := hn
      have hRle : repWeight X n вЙ§ ќі X / 2 := by
        unfold repWeight
        exact le_trans (badRep_le (X + 1) n (by omega) hbad.2) (hXn X hXnX n hn1 hn2)
      have hќіm : ќі X вЙ§ m n := hXm X hXmX n hn1 hn2 hbad.1
      calc ќі X / 2 вЙ§ m n - repWeight X n := by linarith
        _ вЙ§ |m n - repWeight X n| := le_abs_self _
        _ = |repWeight X n - m n| := abs_sub_comm _ _
    have hcard := card_bad_le_of_sq_sum (Ioc (X / 2) X)
        (fun n => repWeight X n - m n) (ќі X / 2)
        ((ќµ / 4) * X * ќі X ^ 2) (by have := hќіpos X; linarith)
        ((Ioc (X / 2) X).filter notSumOfTwoPrimes)
        (filter_subset _ _) hBbound (hXv X hXvX)
    have hќі2 : (0 : вДЭ) < ќі X ^ 2 := pow_pos (hќіpos X) 2
    have hcard2 : ((((Ioc (X / 2) X).filter notSumOfTwoPrimes).card : вДЭ)) * ќі X ^ 2
        вЙ§ ќµ * X * ќі X ^ 2 := by nlinarith [hcard]
    exact le_of_mul_le_mul_right hcard2 hќі2
  intro ќµ hќµ
  obtain вЯ®XвВА, hXвВАвЯ© := hRform (ќµ : вДЭ) (by exact_mod_cast hќµ)
  refine вЯ®XвВА, fun X hX => ?_вЯ©
  have hb := hXвВА X hX
  rw [countUpTo]
  have hcast : ((((range (X + 1)).filter notSumOfTwoPrimes).card : вДЪ) : вДЭ) вЙ§ (ќµ : вДЭ) * X := by
    push_cast
    exact hb
  have hq : (((range (X + 1)).filter notSumOfTwoPrimes).card : вДЪ) вЙ§ ќµ * X := by
    exact_mod_cast hcast
  simpa using hq

/-- **Phase D brick (d): the variance bound in `repWeight` / `Ioc(X/2,X]` form.**
    Repackages the abstract circle-method variance bound `hcv` (discharged by
    `RatedWindow.core_variance`, `N = X+1`) into the real-valued, upper-block form the
    reduction consumes: with `m_X n := Re (cmodel (X+1) n)`, eventually
    `вИС_{nвИИ(X/2,X]} (repWeight X n вИТ m_X n)¬≤ вЙ§ ќµ X¬≥`. Bridges the complex weighted count
    `R_{X+1}(n) = (repWeight X n : вДВ)`, drops `(rвИТz.re)¬≤ вЙ§ вАЦ(r:вДВ)вИТzвАЦ¬≤`, and restricts
    `Ioc(X/2,X] вКЖ range(2(X+1))`; the `(X+1)¬≥ вЙ§ 8X¬≥` slack is absorbed by taking `ќµ/8`. -/
lemma core_variance_repWeight
    (cmodel : вДХ вЖТ вДХ вЖТ вДВ)
    (hcv : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
      вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ)) - cmodel N nвАЦ ^ 2 вЙ§ ќµ * (N : вДЭ) ^ 3)
    (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (repWeight X n - (cmodel (X + 1) n).re) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3 := by
  obtain вЯ®NвВА, hbвЯ© := hcv (ќµ / 8) (by linarith)
  refine вЯ®max 1 NвВА, fun X hX => ?_вЯ©
  have hX1 : 1 вЙ§ X := le_trans (le_max_left _ _) hX
  have hXN0 : NвВА вЙ§ X := le_trans (le_max_right _ _) hX
  have hXR : (1:вДЭ) вЙ§ (X:вДЭ) := by exact_mod_cast hX1
  have hRcast : вИА n : вДХ,
      (вИС p вИИ (Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun p => p.1 + p.2 = n),
          ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ)) = ((repWeight X n : вДЭ) : вДВ) := by
    intro n
    rw [repWeight, Complex.ofReal_sum]
    apply Finset.sum_congr rfl
    intro p _
    push_cast; ring
  have hpt : вИА (r : вДЭ) (z : вДВ), (r - z.re) ^ 2 вЙ§ вАЦ(r : вДВ) - zвАЦ ^ 2 := by
    intro r z
    have h1 : |((r : вДВ) - z).re| вЙ§ вАЦ(r : вДВ) - zвАЦ := Complex.abs_re_le_norm _
    rw [Complex.sub_re, Complex.ofReal_re] at h1
    calc (r - z.re) ^ 2 = |r - z.re| ^ 2 := (sq_abs _).symm
      _ вЙ§ вАЦ(r : вДВ) - zвАЦ ^ 2 := pow_le_pow_leftвВА (abs_nonneg _) h1 2
  have hbX := hb (X + 1) (by omega)
  have hsub : Finset.Ioc (X / 2) X вКЖ Finset.range (2 * (X + 1)) := by
    intro n hn
    rw [Finset.mem_Ioc] at hn
    rw [Finset.mem_range]; omega
  calc вИС n вИИ Finset.Ioc (X / 2) X, (repWeight X n - (cmodel (X + 1) n).re) ^ 2
      вЙ§ вИС n вИИ Finset.Ioc (X / 2) X,
          вАЦ(вИС p вИИ (Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun p => p.1 + p.2 = n),
              ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ)) - cmodel (X + 1) nвАЦ ^ 2 := by
        apply Finset.sum_le_sum
        intro n _
        rw [hRcast n]
        exact hpt (repWeight X n) (cmodel (X + 1) n)
    _ вЙ§ вИС n вИИ Finset.range (2 * (X + 1)),
          вАЦ(вИС p вИИ (Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun p => p.1 + p.2 = n),
              ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ)) - cmodel (X + 1) nвАЦ ^ 2 := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsub
        intro n _ _; positivity
    _ вЙ§ ќµ / 8 * ((X : вДЭ) + 1) ^ 3 := by
        have h := hbX
        rw [show ((X + 1 : вДХ) : вДЭ) = (X : вДЭ) + 1 by push_cast; ring] at h
        exact h
    _ вЙ§ ќµ * (X : вДЭ) ^ 3 := by
        have hcube : ((X : вДЭ) + 1) ^ 3 вЙ§ 8 * (X : вДЭ) ^ 3 := by
          nlinarith [hXR, mul_nonneg (mul_nonneg (show (0:вДЭ) вЙ§ (X:вДЭ) by linarith)
            (show (0:вДЭ) вЙ§ (X:вДЭ) by linarith)) (show (0:вДЭ) вЙ§ (X:вДЭ) - 1 by linarith), sq_nonneg (X:вДЭ)]
        nlinarith [mul_le_mul_of_nonneg_left hcube (show (0:вДЭ) вЙ§ ќµ / 8 by linarith)]

/-- **Phase E brick (E0): the X-INDEXED weighted reduction.**
    Identical to `almost_all_goldbach_of_weighted_variance` except the main term is an
    X-indexed family `m : вДХ вЖТ вДХ вЖТ вДЭ` (`m X n`) rather than a single `m : вДХ вЖТ вДЭ`. The
    reduction processes one dyadic block `(X/2, X]` at a time, so `m` only ever appears as
    `m X n` at a fixed `X`; an X-indexed family therefore composes identically. This is what
    lets the circle method's *truncated* model `(cmodel (X+1) n).re` (whose truncation level
    `P = (log X)^9` is inherently X-dependent) serve as the main term вАФ no globally
    X-independent singular-series main term is needed. -/
theorem almost_all_goldbach_of_weighted_variance_indexed
    (m : вДХ вЖТ вДХ вЖТ вДЭ) (ќі : вДХ вЖТ вДЭ) (hќіpos : вИА X, 0 < ќі X)
    (hmain : вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ Even n вЖТ ќі X вЙ§ m X n)
    (hnegl : вИГ XвВБ : вДХ, вИА X : вДХ, XвВБ вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ
        2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) вЙ§ ќі X / 2)
    (hvar : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
        вИС n вИИ Ioc (X / 2) X, (repWeight X n - m X n) ^ 2 вЙ§ ќµ * X * ќі X ^ 2) :
    DensityZero notSumOfTwoPrimes := by
  classical
  have hRform : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА, вИА X, XвВА вЙ§ X вЖТ
      (((range (X + 1)).filter notSumOfTwoPrimes).card : вДЭ) вЙ§ ќµ * X := by
    apply densityZero_of_block notSumOfTwoPrimes
    intro ќµ hќµ
    obtain вЯ®Xm, hXmвЯ© := hmain
    obtain вЯ®Xn, hXnвЯ© := hnegl
    obtain вЯ®Xv, hXvвЯ© := hvar (ќµ / 4) (by linarith)
    refine вЯ®max Xm (max Xn Xv), fun X hX => ?_вЯ©
    have hXmX : Xm вЙ§ X := le_trans (le_max_left _ _) hX
    have hXnX : Xn вЙ§ X := le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hX
    have hXvX : Xv вЙ§ X := le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) hX
    have hBbound : вИА n вИИ (Ioc (X / 2) X).filter notSumOfTwoPrimes,
        ќі X / 2 вЙ§ |repWeight X n - m X n| := by
      intro n hn
      rw [mem_filter, mem_Ioc] at hn
      obtain вЯ®вЯ®hn1, hn2вЯ©, hbadвЯ© := hn
      have hRle : repWeight X n вЙ§ ќі X / 2 := by
        unfold repWeight
        exact le_trans (badRep_le (X + 1) n (by omega) hbad.2) (hXn X hXnX n hn1 hn2)
      have hќіm : ќі X вЙ§ m X n := hXm X hXmX n hn1 hn2 hbad.1
      calc ќі X / 2 вЙ§ m X n - repWeight X n := by linarith
        _ вЙ§ |m X n - repWeight X n| := le_abs_self _
        _ = |repWeight X n - m X n| := abs_sub_comm _ _
    have hcard := card_bad_le_of_sq_sum (Ioc (X / 2) X)
        (fun n => repWeight X n - m X n) (ќі X / 2)
        ((ќµ / 4) * X * ќі X ^ 2) (by have := hќіpos X; linarith)
        ((Ioc (X / 2) X).filter notSumOfTwoPrimes)
        (filter_subset _ _) hBbound (hXv X hXvX)
    have hќі2 : (0 : вДЭ) < ќі X ^ 2 := pow_pos (hќіpos X) 2
    have hcard2 : ((((Ioc (X / 2) X).filter notSumOfTwoPrimes).card : вДЭ)) * ќі X ^ 2
        вЙ§ ќµ * X * ќі X ^ 2 := by nlinarith [hcard]
    exact le_of_mul_le_mul_right hcard2 hќі2
  intro ќµ hќµ
  obtain вЯ®XвВА, hXвВАвЯ© := hRform (ќµ : вДЭ) (by exact_mod_cast hќµ)
  refine вЯ®XвВА, fun X hX => ?_вЯ©
  have hb := hXвВА X hX
  rw [countUpTo]
  have hcast : ((((range (X + 1)).filter notSumOfTwoPrimes).card : вДЪ) : вДЭ) вЙ§ (ќµ : вДЭ) * X := by
    push_cast
    exact hb
  have hq : (((range (X + 1)).filter notSumOfTwoPrimes).card : вДЪ) вЙ§ ќµ * X := by
    exact_mod_cast hcast
  simpa using hq

/-! ## Phase F вАФ final composition

Assemble almost-all binary Goldbach from the pieces proven across the LeanSandbox files. The
