          hnsum.tsum_le_tsum (fun k => hterm k w hw) (hmaj.mul_left ((R+1)*R))
      _ = (R+1)*R*S := by
          rw [hSdef, tsum_mul_left]
  have hTdiff : DifferentiableOn вДВ T U := by
    rw [hTdef]
    apply differentiableOn_tsum_of_summable_norm (hmaj.mul_left ((R+1)*R)) _ hUopen
      (fun k w hw => hterm k w hw)
    intro k
    apply Differentiable.differentiableOn
    have hb1 : ((((k+1 : вДХ)):вДВ)) вЙ† 0 := Nat.cast_ne_zero.mpr (by omega)
    have hb2 : ((((k+1+1 : вДХ)):вДВ)) вЙ† 0 := Nat.cast_ne_zero.mpr (by omega)
