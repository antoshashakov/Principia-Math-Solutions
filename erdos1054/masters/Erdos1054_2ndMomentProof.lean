lemma csup_g4 (a t1 t2 t3 t4 Z L : вДЭ)
    (ha : a вЙ§ L) (ha0 : 0 вЙ§ a) (h1 : t1 вЙ§ 16 * Z) (h2 : t2 вЙ§ 12 * (Z * L))
