    have h2 : вАЦSF - ESвАЦ = вАЦES - SFвАЦ := norm_sub_rev _ _
    have h3 : (SF - ES).re = SF.re - ES.re := Complex.sub_re _ _
    rw [hSFre]
    have h4 : вАЦES - SFвАЦ вЙ§ 400 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) := hEtail
    linarith [h1, h2.le, h2.ge, h3.le, h3.ge, h4]
  -- Step 4: the ќґ-part
  have hztr := zeta_truncation x hx hќ≤1 hќ≤2
  have hxc : ((x:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ)) = ((((x:вДЭ)) ^ (1 - ќ≤) : вДЭ) : вДВ) := by
    rw [show (1:вДВ) - (ќ≤:вДВ) = (((1 - ќ≤ : вДЭ)):вДВ) from by push_cast; ring,
      show ((x:вДВ)) = (((x:вДЭ)):вДВ) from by push_cast; ring]
    exact (Complex.ofReal_cpow hx0.le (1 - ќ≤)).symm
  have hre_expr : ((((ќ≤:вДВ)) - 1) * (Z - SC) - ((x:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ))).re
      = (ќ≤ - 1) * (Z.re - SC.re) - ((x:вДЭ)) ^ (1 - ќ≤) := by
    rw [hxc, show (((ќ≤:вДВ)) - 1) = (((ќ≤ - 1 : вДЭ)):вДВ) from by push_cast; ring,
      Complex.sub_re, Complex.re_ofReal_mul, Complex.sub_re, Complex.ofReal_re]
  have habs : |(ќ≤ - 1) * (Z.re - SC.re) - ((x:вДЭ)) ^ (1 - ќ≤)| вЙ§ 11 * ((x:вДЭ)) ^ (-ќ≤) := by
    rw [вЖР hre_expr]
    calc |((((ќ≤:вДВ)) - 1) * (Z - SC) - ((x:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ))).re|
        вЙ§ вАЦ(((ќ≤:вДВ)) - 1) * (Z - SC) - ((x:вДВ)) ^ ((1:вДВ) - (ќ≤:вДВ))вАЦ :=
          Complex.abs_re_le_norm _
      _ вЙ§ 11 * ((x:вДЭ)) ^ (-ќ≤) := hztr
  -- SC is the real partial sum
  have hSCre : SC = ((( вИС n вИИ Icc 1 (x - 1), ((n:вДЭ)) ^ (-ќ≤) : вДЭ)) : вДВ) := by
    rw [hSC, show range x = insert 0 (Icc 1 (x - 1)) from by
      ext m
      simp only [Finset.mem_insert, Finset.mem_range, Finset.mem_Icc]
      omega, Finset.sum_insert (by
        simp only [Finset.mem_Icc]
        omega)]
    have h0 : (((0:вДХ)):вДВ) ^ (-(ќ≤:вДВ)) = 0 := by
      rw [Nat.cast_zero, Complex.zero_cpow]
      simp only [ne_eq, neg_eq_zero, Complex.ofReal_eq_zero]
      linarith
    rw [h0, zero_add, Finset.sum_congr rfl (fun n _ => cpow_real_cast n ќ≤),
      вЖР Complex.ofReal_sum]
  have hSx : вИС n вИИ Icc 1 x, ((n:вДЭ)) ^ (-ќ≤) = SC.re + ((x:вДЭ)) ^ (-ќ≤) := by
    rw [hSCre, Complex.ofReal_re, show Icc 1 x = insert x (Icc 1 (x - 1)) from by
      ext m
      simp only [Finset.mem_insert, Finset.mem_Icc]
      omega, Finset.sum_insert (by
        simp only [Finset.mem_Icc]
        omega)]
    ring
  -- S.re вЙ§ Z.re + (x^{1вИТќ≤} + 11x^{вИТќ≤})/(1вИТќ≤)
  have hSCbound : SC.re вЙ§ Z.re + (((x:вДЭ)) ^ (1 - ќ≤) + 11 * ((x:вДЭ)) ^ (-ќ≤)) / (1 - ќ≤) := by
    obtain вЯ®hlo, hhiвЯ© := abs_le.mp habs
