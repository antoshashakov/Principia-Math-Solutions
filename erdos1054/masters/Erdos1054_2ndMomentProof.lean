open scoped LSeries.notation ArithmeticFunction in
/-- **The 1-1 positivity combo at the real point** (SW brick S4a-3a): for any `ѕЗ`,
    `0 вЙ§ Re(L(ѕЗвБ∞ќЫ, ѕГ) + L(ѕЗќЫ, ѕГ))` for real `ѕГ > 1` вАФ termwise `ќЫ(n)(1 + Re ѕЗ(n)) вЙ• 0`.
    The lower comparison feeding the conjugate-pair repulsion. -/
lemma pair_combo_re_nonneg {N : вДХ} (ѕЗ : DirichletCharacter вДВ N) (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    0 вЙ§ (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) ((ѕГ : вДВ))
       + LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ))).re := by
  have hs0 : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ
  have S0 := DirichletCharacter.LSeriesSummable_twist_vonMangoldt
    (1 : DirichletCharacter вДВ N) hs0
  have S1 := DirichletCharacter.LSeriesSummable_twist_vonMangoldt ѕЗ hs0
  simp only [LSeries]
  have H := S0.hasSum.add S1.hasSum
  rw [вЖР H.tsum_eq, re_tsum H.summable]
  apply tsum_nonneg
  intro n
  rcases eq_or_ne n 0 with rfl | hn
  ¬Ј simp [LSeries.term]
  ¬Ј rw [LSeries.term_of_ne_zero hn, LSeries.term_of_ne_zero hn]
    simp only [Pi.mul_apply]
    by_cases h : IsUnit ((n : ZMod N))
    ¬Ј have h0 : (1 : DirichletCharacter вДВ N) ((n : ZMod N)) = 1 := MulChar.one_apply h
      have h1 : вАЦѕЗ ((n : ZMod N))вАЦ = 1 := by
        obtain вЯ®u, huвЯ© := h
        rw [вЖР hu]
        exact ѕЗ.unit_norm_eq_one u
      have hn0 : (n : вДВ) вЙ† 0 := by exact_mod_cast hn
      have hPreal : (n : вДВ) ^ ((ѕГ:вДЭ) : вДВ) = (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ) := by
        rw [вЖР Complex.ofReal_natCast n,
          вЖР Complex.ofReal_cpow (by positivity : (0:вДЭ) вЙ§ (n:вДЭ))]
      have hPpos : (0:вДЭ) < (n:вДЭ) ^ ѕГ := by
        have hn1 : (0:вДЭ) < (n:вДЭ) := by
          exact_mod_cast Nat.pos_of_ne_zero hn
        positivity
      have key : ((1 : DirichletCharacter вДВ N) ((n : ZMod N)))
            * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) / (n:вДВ) ^ ((ѕГ:вДЭ) : вДВ)
          + (ѕЗ ((n : ZMod N))) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)
            / (n:вДВ) ^ ((ѕГ:вДЭ) : вДВ)
          = (((ArithmeticFunction.vonMangoldt n / (n:вДЭ)^ѕГ : вДЭ)) : вДВ)
            * (1 + ѕЗ ((n : ZMod N))) := by
        rw [h0, hPreal]
        push_cast
        ring
      rw [key, Complex.re_ofReal_mul]
      apply mul_nonneg (div_nonneg ArithmeticFunction.vonMangoldt_nonneg hPpos.le)
      have habs := Complex.abs_re_le_norm (ѕЗ ((n : ZMod N)))
      rw [h1] at habs
      have h2 := (abs_le.mp habs).1
      rw [Complex.add_re, Complex.one_re]
      linarith
    ¬Ј rw [MulChar.map_nonunit _ h, MulChar.map_nonunit _ h]
      simp

open scoped LSeries.notation ArithmeticFunction in
/-- **The quadratic small-height zero-free region** (SW brick S4a-3b): there is an
    absolute `C` such that every zero `ќ≤ + iќ≥` (ќ≥ вЙ† 0) of every quadratic nontrivial
    `L(¬Ј,ѕЗ)` mod `N` with `|ќ≥| вЙ§ 1/(C¬ЈLвВА)` (`LвВА = log(N(4|ќ≥|+7))+20`) satisfies
    `ќ≤ вЙ§ 1 вИТ 1/(C¬ЈLвВА)` вАФ the conjugate-pair Landau repulsion at `ѕГ = 1+2(1вИТќ≤+|ќ≥|)`,
    with the `log(1/x) вЙ§ 2/вИЪx` a-priori trick closing the self-reference. -/
theorem quad_pair_gap :
    вИГ C : вДЭ, 1 вЙ§ C вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N),
      ѕЗ вЙ† 1 вЖТ ѕЗ ^ 2 = 1 вЖТ вИА ќ≤ ќ≥ : вДЭ, ќ≥ вЙ† 0 вЖТ
      DirichletCharacter.LFunction ѕЗ ((ќ≤ : вДВ) + ќ≥ * Complex.I) = 0 вЖТ
      |ќ≥| * (C * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20)) вЙ§ 1 вЖТ
      ќ≤ вЙ§ 1 - 1 / (C * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20)) := by
  obtain вЯ®K, hKвЯ© := twist_re_le_uniform
  obtain вЯ®K', hK'defвЯ© : вИГ K' : вДЭ, K' = max K 0 := вЯ®_, rflвЯ©
  have hK'0 : 0 вЙ§ K' := by rw [hK'def]; exact le_max_right _ _
  have hKK' : K вЙ§ K' := by rw [hK'def]; exact le_max_left _ _
  obtain вЯ®C, hCdefвЯ© : вИГ C : вДЭ, C = 2 * (576060 * (K'/20 + 40)) + 40 := вЯ®_, rflвЯ©
  have hC40 : 40 вЙ§ C := by
    rw [hCdef]
    nlinarith [hK'0]
  refine вЯ®C, by linarith, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 hѕЗ2 ќ≤ ќ≥ hќ≥ hzero hsmall
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hg0 : (0:вДЭ) < |ќ≥| := abs_pos.mpr hќ≥
  have harg1 : (1:вДЭ) вЙ§ (N:вДЭ) * (4*|ќ≥|+7) := by nlinarith
  have hL0 : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*|ќ≥|+7)) := Real.log_nonneg harg1
  obtain вЯ®LвВА, hLвВАdefвЯ© : вИГ Lv : вДЭ, Lv = Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLвВАdef] at hsmall вКҐ
  have hL20 : 20 вЙ§ LвВА := by rw [hLвВАdef]; linarith
  have hCL : 800 вЙ§ C * LвВА := by nlinarith
  have hCL0 : 0 < C * LвВА := by linarith
  have hќ≤1 : ќ≤ < 1 := by
    by_contra hќ≤'
    push_neg at hќ≤'
    have hre : (1:вДЭ) вЙ§ ((ќ≤:вДВ) + ќ≥*Complex.I).re := by
      simp
      linarith
    exact DirichletCharacter.LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ1) hre hzero
  by_cases hb40 : 1/40 вЙ§ 1 - ќ≤
  ¬Ј have h1 : 1/(C*LвВА) вЙ§ 1/40 := by
      rw [div_le_div_iffвВА hCL0 (by norm_num : (0:вДЭ) < 40)]
      linarith
    linarith
  push_neg at hb40
  have hb0 : (0:вДЭ) < 1 - ќ≤ := by linarith
  have hgC : |ќ≥| вЙ§ 1/(C*LвВА) := by
    rw [le_div_iffвВА hCL0]
    exact hsmall
  have hg800 : |ќ≥| вЙ§ 1/800 := by
    refine le_trans hgC ?_
    rw [div_le_div_iffвВА hCL0 (by norm_num : (0:вДЭ) < 800)]
    linarith
  obtain вЯ®ѕГ, hѕГdefвЯ© : вИГ s : вДЭ, s = 1 + 2*((1-ќ≤) + |ќ≥|) := вЯ®_, rflвЯ©
  have hx0 : (0:вДЭ) < (1-ќ≤) + |ќ≥| := by linarith
  have hѕГ1 : 1 < ѕГ := by rw [hѕГdef]; linarith
  have hѕГ2 : ѕГ вЙ§ 2 := by rw [hѕГdef]; linarith [hb40, hg800]
  have hѕГќ≤ : ѕГ - ќ≤ = 3*(1-ќ≤) + 2*|ќ≥| := by rw [hѕГdef]; ring
  have hѕГ1x : ѕГ - 1 = 2*((1-ќ≤)+|ќ≥|) := by rw [hѕГdef]; ring
  -- the conjugate zero
  have hconjpt : (starRingEnd вДВ) ((ќ≤:вДВ) + ќ≥*Complex.I) = (ќ≤:вДВ) - ќ≥*Complex.I := by
    rw [map_add, map_mul, Complex.conj_ofReal, Complex.conj_ofReal, Complex.conj_I]
