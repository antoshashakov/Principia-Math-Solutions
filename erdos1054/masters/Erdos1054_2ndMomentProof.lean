      вЙ§ Real.log 2 + Real.log CвВА + 2 * Real.log ((N:вДЭ)*(|t|+3)/(ѕГ-1)) := by
    calc Real.log ((N:вДЭ) * (CвВА * (|t|+3)^2) / ((ѕГ-1)^2/2))
        вЙ§ Real.log (2*CвВА * ((N:вДЭ)*(|t|+3)/(ѕГ-1))^2) := by
          apply Real.log_le_log _ hMbml
          have hN0 : (0:вДЭ) < (N:вДЭ) := by linarith
