        + 2 * ((6 / g^2) * X ^ (1 + g : вДЭ)) / T
        вЙ§ 24*C * u ^ ((5:вДЭ)/2) * (X * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2))))
          + 6*C * u ^ (3:вДЭ) * (X * Real.exp (-(u/2)))
          + (48/c^2) * u ^ (3:вДЭ) * (X * Real.exp (-(u/2))) := by
