            (Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (N + 1)))
              вИ© Set.Ioc (0:вДЭ) 1),
          (вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
            * e (-((n : вДЭ) * ќ±)))
        - (вИС pq вИИ anchors P,
            вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (N + 1)))
              вИ© Set.Ioc (0:вДЭ) 1,
            ((вИС r вИИ Finset.range pq.1,
                e ((r : вДЭ) * (pq.2 : вДЭ) / (pq.1 : вДЭ)) * lambdaModel pq.1 r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
