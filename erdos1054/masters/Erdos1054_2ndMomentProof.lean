  have hA1 : (3:вДЭ) вЙ§ (N:вДЭ)*(|t|+3)/(ѕГ-1) := by
    rw [le_div_iffвВА (by linarith : (0:вДЭ) < ѕГ-1)]
    have := abs_nonneg t
