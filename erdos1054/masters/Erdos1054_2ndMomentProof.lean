/-- The вДВ-cast of a packaged real function. -/
noncomputable def castFn (g : вДХ вЖТ вДЭ) : вДХ вЖТ вДВ := fun n => ((toArith g n : вДЭ) : вДВ)

lemma castFn_zero (g : вДХ вЖТ вДЭ) : castFn g 0 = 0 := by
  simp [castFn, toArith]

lemma castFn_bound (g : вДХ вЖТ вДЭ) (hg : вИА n, |g n| вЙ§ 1) (n : вДХ) : вАЦcastFn g nвАЦ вЙ§ 1 := by
  rw [castFn, Complex.norm_real, Real.norm_eq_abs]
  rcases Nat.eq_zero_or_pos n with rfl | h0
  ¬Ј simp [toArith]
  ¬Ј rw [show toArith g n = g n from by simp [toArith, h0.ne']]
    exact hg n

open scoped LSeries.notation in
/-- **Casting commutes with Dirichlet convolution** (Siegel brick A2f-i):
    the вДВ-cast of the `ArithmeticFunction` product is the `вНЯ`-convolution of the casts. -/
lemma castFn_conv (u v : вДХ вЖТ вДЭ) (n : вДХ) :
    (((toArith u * toArith v) n : вДЭ) : вДВ) = (castFn u вНЯ castFn v) n := by
  rw [ArithmeticFunction.mul_apply, LSeries.convolution_def]
  push_cast
  apply Finset.sum_congr rfl
  intro p hp
  rw [Nat.mem_divisorsAntidiagonal] at hp
  have h1 : p.1 вЙ† 0 := by
    intro h0
    rw [h0, zero_mul] at hp
    exact hp.2 hp.1.symm
  have h2 : p.2 вЙ† 0 := by
    intro h0
    rw [h0, mul_zero] at hp
    exact hp.2 hp.1.symm
  rw [castFn, castFn]

/-- **Summability of bounded packaged series** (Siegel brick A2f-ii): `Re s > 1`. -/
lemma castFn_summable (g : вДХ вЖТ вДЭ) (hg : вИА n, |g n| вЙ§ 1) {s : вДВ} (hs : 1 < s.re) :
    LSeriesSummable (castFn g) s :=
  LSeriesSummable_of_bounded_of_one_lt_re (m := 1) (fun n _ => castFn_bound g hg n) hs

open scoped LSeries.notation in
/-- **The Goldfeld product identity** (Siegel brick A2f-iii): on `Re s > 1`, the
    L-series of the quadruple coefficient sequence factors as the product of the four
    L-series вАФ the series side of `F(s) = ќґ(s)L(s,ѕЗвВБ)L(s,ѕЗвВВ)L(s,ѕЗвВБѕЗвВВ)`. -/
theorem quad_LSeries_eq (gвВБ gвВВ : вДХ вЖТ вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1) {s : вДВ} (hs : 1 < s.re) :
    LSeries (fun n => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ)) s
      = LSeries (castFn (fun _ => (1:вДЭ))) s * LSeries (castFn gвВБ) s
        * LSeries (castFn gвВВ) s * LSeries (castFn (fun m => gвВБ m * gвВВ m)) s := by
  have honeb : вИА n : вДХ, |(fun _ : вДХ => (1:вДЭ)) n| вЙ§ 1 := fun n => by norm_num
  have hg12b : вИА n, |gвВБ n * gвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |gвВБ n| * |gвВВ n| вЙ§ 1 * 1 := mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have hS0 := castFn_summable (fun _ => (1:вДЭ)) honeb hs
  have hS1 := castFn_summable gвВБ h1b hs
  have hS2 := castFn_summable gвВВ h2b hs
  have hS12 := castFn_summable (fun m => gвВБ m * gвВВ m) hg12b hs
  -- rewrite the coefficient function through the cast bridge, twice-nested
  have hbridge : (fun n => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
      * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ))
      = ((castFn (fun _ => (1:вДЭ)) вНЯ castFn gвВБ) вНЯ castFn gвВВ)
        вНЯ castFn (fun m => gвВБ m * gвВВ m) := by
    funext n
    -- peel the outermost product
    have step1 : (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ)
        = ((fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ) m : вДЭ) : вДВ))
          вНЯ castFn (fun m => gвВБ m * gвВВ m)) n := by
      rw [ArithmeticFunction.mul_apply, LSeries.convolution_def]
      push_cast
      apply Finset.sum_congr rfl
      intro p hp
      rw [Nat.mem_divisorsAntidiagonal] at hp
      have h2 : p.2 вЙ† 0 := by
        intro h0
        rw [h0, mul_zero] at hp
        exact hp.2 hp.1.symm
      rw [castFn]
    rw [step1]
    -- peel the middle product inside the left slot
    have step2 : (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ) m : вДЭ) : вДВ))
        = (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ) m : вДЭ) : вДВ)) вНЯ castFn gвВВ := by
      funext m
      rw [ArithmeticFunction.mul_apply, LSeries.convolution_def]
      push_cast
      apply Finset.sum_congr rfl
      intro p hp
      rw [Nat.mem_divisorsAntidiagonal] at hp
      have h2 : p.2 вЙ† 0 := by
        intro h0
        rw [h0, mul_zero] at hp
        exact hp.2 hp.1.symm
      rw [castFn]
    rw [step2]
    -- peel the innermost product
    have step3 : (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ) m : вДЭ) : вДВ))
        = castFn (fun _ => (1:вДЭ)) вНЯ castFn gвВБ := by
      funext m
      exact castFn_conv (fun _ => (1:вДЭ)) gвВБ m
    rw [step3]
  rw [hbridge]
  -- three applications of the convolution identity
  rw [LSeries_convolution' ((hS0.convolution hS1).convolution hS2) hS12,
    LSeries_convolution' (hS0.convolution hS1) hS2,
    LSeries_convolution' hS0 hS1]

/-- **вДВ-weighted Abel summation over an initial window** (Siegel brick A2g-i):
    `ќ£_{nвЙ§x} a(n)w(n) = A(x)w(x) + ќ£_{n<x} A(n)(w(n) вИТ w(n+1))` with
    `A(t) = ќ£_{nвЙ§t} a(n)` вАФ the discrete engine of the integral representation,
    for arbitrary complex weights `w`. -/
lemma abel_initial (a : вДХ вЖТ вДВ) (w : вДХ вЖТ вДВ) :
    вИА x : вДХ, 1 вЙ§ x вЖТ
    вИС n вИИ Icc 1 x, a n * w n
      = (вИС n вИИ Icc 1 x, a n) * w x
        + вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1)) := by
  intro x
  induction x with
  | zero =>
    intro h0
    omega
  | succ p ih =>
    intro _
    rcases Nat.eq_zero_or_pos p with rfl | hp
    ¬Ј -- x = 1
      simp
    ¬Ј -- step p вЖТ p+1
      have hstepL : Icc 1 (p + 1) = insert (p + 1) (Icc 1 p) := by
        ext m
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      have hp1 : p + 1 - 1 = p := by omega
      rw [hstepL, Finset.sum_insert (by simp), Finset.sum_insert (by simp), ih hp, hp1]
      have hstepW : Icc 1 p = insert p (Icc 1 (p - 1)) := by
        ext m
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      rw [show вИС n вИИ Icc 1 p, (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1))
          = (вИС m вИИ Icc 1 p, a m) * (w p - w (p + 1))
            + вИС n вИИ Icc 1 (p - 1), (вИС m вИИ Icc 1 n, a m) * (w n - w (n + 1)) from by
        rw [hstepW, Finset.sum_insert (by
          simp only [Finset.mem_Icc]
          omega), вЖР hstepW]]
      ring

/-! ### Duplicated verbatim from DirichletLPoleBound.lean (verified there) -/

/-- The weighted telescope: `ќ£_{nвЙ§x} n(wвВЩ вИТ wвВЩвВКвВБ) = ќ£_{nвЙ§x} wвВЩ вИТ x¬Јw_{x+1}` (real). -/
lemma weighted_telescope (w : вДХ вЖТ вДЭ) : вИА x : вДХ,
    вИС n вИИ Icc 1 x, (n : вДЭ) * (w n - w (n + 1))
      = вИС n вИИ Icc 1 x, w n - (x : вДЭ) * w (x + 1) := by
  intro x
  induction x with
  | zero => simp
  | succ p ih =>
    have hstep : Icc 1 (p + 1) = insert (p + 1) (Icc 1 p) := by
      ext m
      simp only [Finset.mem_insert, Finset.mem_Icc]
      omega
    rw [hstep, Finset.sum_insert (by simp), Finset.sum_insert (by simp), ih]
    push_cast
    ring

/-- **The partial-sum series representation** (Siegel brick A2g-ii): for linearly
    bounded partial sums `вАЦA(x)вАЦ вЙ§ Cx` and `Re s > 1`,
    `ќ£' n, a(n)n^{вИТs} = ќ£' n, A(n)(n^{вИТs} вИТ (n+1)^{вИТs})` вАФ the boundary term
    `A(x)x^{вИТs}` dies and the Abel-rearranged series converges to the L-series. -/
theorem lseries_eq_tsum_abel (a : вДХ вЖТ вДВ) (C : вДЭ)
    (hC : вИА x : вДХ, вАЦвИС n вИИ Icc 1 x, a nвАЦ вЙ§ C * x)
    {s : вДВ} (hs : 1 < s.re) (hsum : LSeriesSummable a s) :
    LSeries a s
      = вИС' n : вДХ, (вИС m вИИ Icc 1 n, a m) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) := by
  -- the partial sums of the L-series along Icc 1 x
  have hterm_eq : вИА n : вДХ, 1 вЙ§ n вЖТ LSeries.term a s n = a n * ((n:вДВ)) ^ (-s) := by
    intro n hn
    rw [LSeries.term_of_ne_zero (by omega), Complex.cpow_neg, div_eq_mul_inv]
  have hpartial : Tendsto (fun x : вДХ => вИС n вИИ Icc 1 x, a n * ((n:вДВ)) ^ (-s))
      atTop (nhds (LSeries a s)) := by
    have h1 : Tendsto (fun x : вДХ => вИС n вИИ range (x + 1), LSeries.term a s n)
        atTop (nhds (LSeries a s)) := by
      have := hsum.hasSum.tendsto_sum_nat
      exact this.comp (tendsto_add_atTop_nat 1)
    have h2 : вИА x : вДХ, вИС n вИИ range (x + 1), LSeries.term a s n
        = вИС n вИИ Icc 1 x, a n * ((n:вДВ)) ^ (-s) := by
      intro x
      rw [show range (x + 1) = insert 0 (Icc 1 x) from by
        ext m
        simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]
        omega]
      rw [Finset.sum_insert (by simp)]
      rw [LSeries.term_zero, zero_add]
      exact Finset.sum_congr rfl (fun n hn => hterm_eq n (Finset.mem_Icc.mp hn).1)
    rw [show (fun x : вДХ => вИС n вИИ Icc 1 x, a n * ((n:вДВ)) ^ (-s))
        = (fun x : вДХ => вИС n вИИ range (x + 1), LSeries.term a s n) from
      funext (fun x => (h2 x).symm)]
    exact h1
  -- boundary decay: A(x)¬Јx^{вИТs} вЖТ 0
  have hboundary : Tendsto (fun x : вДХ => (вИС n вИИ Icc 1 x, a n) * ((x:вДВ)) ^ (-s))
      atTop (nhds 0) := by
    have hC0 : 0 вЙ§ C := by
      have h0 := hC 1
      have h1 : (0:вДЭ) вЙ§ вАЦвИС n вИИ Icc 1 1, a nвАЦ := norm_nonneg _
      have h2 : C * ((1:вДХ):вДЭ) = C := by norm_num
      linarith [h0, h1, h2.le, h2.ge]
    have hbnd : вИА x : вДХ, вАЦ(вИС n вИИ Icc 1 x, a n) * ((x:вДВ)) ^ (-s)вАЦ
        вЙ§ C * ((x:вДЭ)) ^ (1 - s.re) := by
      intro x
      rcases Nat.eq_zero_or_pos x with rfl | hx0
      ¬Ј rw [show (Icc 1 0 : Finset вДХ) = вИЕ from Finset.Icc_eq_empty (by omega),
          Finset.sum_empty, zero_mul, norm_zero, Nat.cast_zero,
          Real.zero_rpow (by linarith : (1:вДЭ) - s.re вЙ† 0), mul_zero]
      ¬Ј rw [norm_mul, Complex.norm_natCast_cpow_of_pos hx0, Complex.neg_re]
        have hxr : (0:вДЭ) < (x:вДЭ) := by exact_mod_cast hx0
        calc вАЦвИС n вИИ Icc 1 x, a nвАЦ * ((x:вДЭ)) ^ (-s.re)
            вЙ§ (C * x) * ((x:вДЭ)) ^ (-s.re) := by
              apply mul_le_mul_of_nonneg_right (hC x) (Real.rpow_nonneg hxr.le _)
          _ = C * ((x:вДЭ)) ^ (1 - s.re) := by
              rw [show (1:вДЭ) - s.re = 1 + (-s.re) by ring, Real.rpow_add hxr,
                Real.rpow_one]
              ring
    have hg0 : Tendsto (fun x : вДХ => C * ((x:вДЭ)) ^ (1 - s.re)) atTop (nhds 0) := by
      have h1 : Tendsto (fun x : вДХ => ((x:вДЭ)) ^ (1 - s.re)) atTop (nhds 0) := by
        have := tendsto_rpow_neg_atTop (show (0:вДЭ) < s.re - 1 by linarith)
        have hcomp := this.comp tendsto_natCast_atTop_atTop
        simpa [Function.comp_def, neg_sub] using hcomp
      simpa using h1.const_mul C
    exact squeeze_zero_norm hbnd hg0
  -- Abel + limits
  have hAbel : вИА x : вДХ, 1 вЙ§ x вЖТ
      вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))
      = вИС n вИИ Icc 1 x, a n * ((n:вДВ)) ^ (-s)
        - (вИС n вИИ Icc 1 x, a n) * ((x:вДВ)) ^ (-s) := by
    intro x hx
    have := abel_initial a (fun n => ((n:вДВ)) ^ (-s)) x hx
    push_cast at this вКҐ
    linear_combination -this
  have hlim : Tendsto (fun x : вДХ => вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
      * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) atTop (nhds (LSeries a s)) := by
    have heq : вИАбґ† x : вДХ in atTop, вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))
        = вИС n вИИ Icc 1 x, a n * ((n:вДВ)) ^ (-s)
          - (вИС n вИИ Icc 1 x, a n) * ((x:вДВ)) ^ (-s) := by
      filter_upwards [eventually_ge_atTop 1] with x hx
      exact hAbel x hx
    rw [Filter.tendsto_congr' heq]
    have := hpartial.sub hboundary
    simpa using this
  -- absolute convergence via the real difference kernel
  have hC0' : 0 вЙ§ C := by
    have h0 := hC 1
    have h1 : (0:вДЭ) вЙ§ вАЦвИС n вИИ Icc 1 1, a nвАЦ := norm_nonneg _
    have h2 : C * ((1:вДХ):вДЭ) = C := by norm_num
    linarith [h0, h1, h2.le, h2.ge]
  have hѕГ0 : (0:вДЭ) < s.re := by linarith
  have hsummable : Summable (fun n : вДХ => (вИС m вИИ Icc 1 n, a m)
      * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) := by
    set w : вДХ вЖТ вДЭ := fun n => ((n:вДЭ)) ^ (-s.re) with hw
    have hwanti : вИА n : вДХ, 1 вЙ§ n вЖТ w (n + 1) вЙ§ w n := by
      intro n hn
      rw [hw]
      simp only
      apply Real.rpow_le_rpow_of_nonpos (by exact_mod_cast hn) (by push_cast; linarith)
      linarith
    apply Summable.of_norm_bounded
      (g := fun n : вДХ => (C * (вАЦsвАЦ / s.re)) * ((n:вДЭ) * (w n - w (n + 1))))
    ¬Ј apply summable_of_sum_range_le (c := (C * (вАЦsвАЦ / s.re)) * (s.re / (s.re - 1)))
      ¬Ј intro n
        rcases Nat.eq_zero_or_pos n with rfl | hn0
        ¬Ј simp
        ¬Ј apply mul_nonneg (by positivity)
          apply mul_nonneg (Nat.cast_nonneg n)
          linarith [hwanti n hn0]
      ¬Ј intro x
        have hIcc : вИС i вИИ range x, (C * (вАЦsвАЦ / s.re)) * ((i:вДЭ) * (w i - w (i + 1)))
            = (C * (вАЦsвАЦ / s.re)) * вИС i вИИ Icc 1 (x - 1), ((i:вДЭ) * (w i - w (i + 1))) := by
          rw [Finset.mul_sum]
          rcases Nat.eq_zero_or_pos x with rfl | hx0
          ¬Ј simp
          ¬Ј rw [show range x = insert 0 (Icc 1 (x - 1)) from by
              ext m
              simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]
              omega]
            rw [Finset.sum_insert (by simp)]
            simp
        rw [hIcc, weighted_telescope w (x - 1)]
        have htail : (0:вДЭ) вЙ§ ((x - 1 : вДХ):вДЭ) * w ((x - 1) + 1) := by
          apply mul_nonneg (Nat.cast_nonneg _)
          rw [hw]
          simp only
          positivity
        have hsums : вИС n вИИ Icc 1 (x - 1), w n вЙ§ s.re / (s.re - 1) := by
          have hterm : вИА n вИИ Icc 1 (x - 1), w n = 1 / ((n:вДЭ)) ^ s.re := by
            intro n hn
            obtain вЯ®hn1, _вЯ© := Finset.mem_Icc.mp hn
            rw [hw]
            simp only
            rw [Real.rpow_neg (Nat.cast_nonneg n), one_div]
          rw [Finset.sum_congr rfl hterm]
          calc вИС n вИИ Icc 1 (x - 1), 1 / ((n:вДЭ)) ^ s.re
              вЙ§ вИС' n : вДХ, (1:вДЭ) / ((n:вДЭ)) ^ s.re :=
                Summable.sum_le_tsum _ (fun n _ => by positivity)
                  (Real.summable_one_div_nat_rpow.mpr hs)
            _ вЙ§ s.re / (s.re - 1) := tsum_one_div_nat_rpow_le s.re hs
        have hfac : (0:вДЭ) вЙ§ C * (вАЦsвАЦ / s.re) := by positivity
        apply mul_le_mul_of_nonneg_left _ hfac
        linarith [hsums, htail]
    ¬Ј intro n
      rcases Nat.eq_zero_or_pos n with rfl | hn0
      ¬Ј simp
      ¬Ј rw [norm_mul]
        have h1 := hC n
        have h2 := cpow_diff_kernel_bound n hn0 s hѕГ0
        calc вАЦвИС m вИИ Icc 1 n, a mвАЦ * вАЦ((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)вАЦ
            вЙ§ (C * n) * ((вАЦsвАЦ / s.re) * ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re))) := by
              apply mul_le_mul h1 h2 (norm_nonneg _)
              positivity
          _ = (C * (вАЦsвАЦ / s.re)) * ((n:вДЭ) * (w n - w (n + 1))) := by
              rw [hw]
              simp only
              push_cast
              ring
  have hrange := hsummable.hasSum.tendsto_sum_nat
  have hIccrange : вИА x : вДХ, вИС n вИИ range x, (вИС m вИИ Icc 1 n, a m)
      * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))
      = вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) := by
    intro x
    rcases Nat.eq_zero_or_pos x with rfl | hx0
    ¬Ј simp
    ¬Ј rw [show range x = insert 0 (Icc 1 (x - 1)) from by
        ext m
        simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]
        omega]
      rw [Finset.sum_insert (by simp)]
      rw [show (Icc 1 0 : Finset вДХ) = вИЕ from Finset.Icc_eq_empty (by omega),
        Finset.sum_empty, zero_mul, zero_add]
  have hrange' : Tendsto (fun x : вДХ => вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
      * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) atTop
      (nhds (вИС' n : вДХ, (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)))) := by
    rw [show (fun x : вДХ => вИС n вИИ Icc 1 (x - 1), (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)))
        = (fun x : вДХ => вИС n вИИ range x, (вИС m вИИ Icc 1 n, a m)
        * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) from
      funext (fun x => (hIccrange x).symm)]
    exact hrange
  exact (tendsto_nhds_unique hrange' hlim).symm

/-- **The Abel identity sums to ќґ** (Siegel brick A2g-iii-b):
    `ќ£' n¬Ј(n^{вИТs} вИТ (n+1)^{вИТs}) = ќґ(s)` on `Re s > 1` вАФ the ќї-part of the
    continuation `G` is Mathlib's `riemannZeta`, pole included. -/
theorem tsum_abel_id_eq_zeta {s : вДВ} (hs : 1 < s.re) :
    вИС' n : вДХ, ((n:вДВ)) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) = riemannZeta s := by
  set a : вДХ вЖТ вДВ := fun n => if n = 0 then 0 else 1 with ha
  have hs0 : s вЙ† 0 := by
    intro h0
    rw [h0] at hs
    simp only [Complex.zero_re] at hs
    linarith
  have hA : вИА x : вДХ, вИС n вИИ Icc 1 x, a n = (x : вДВ) := by
    intro x
    have hterm : вИА n вИИ Icc 1 x, a n = 1 := by
      intro n hn
      obtain вЯ®hn1, _вЯ© := Finset.mem_Icc.mp hn
      rw [ha]
      simp only [if_neg (by omega : ¬ђ n = 0)]
    rw [Finset.sum_congr rfl hterm, Finset.sum_const, Nat.card_Icc, Nat.add_sub_cancel,
      nsmul_eq_mul, mul_one]
  have hC : вИА x : вДХ, вАЦвИС n вИИ Icc 1 x, a nвАЦ вЙ§ 1 * x := by
    intro x
    rw [hA x, one_mul, Complex.norm_natCast]
  have hsummable : LSeriesSummable a s := by
    apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ hs
    intro n _
    rw [ha]
    rcases eq_or_ne n 0 with rfl | hn
    ¬Ј simp
    ¬Ј simp [if_neg hn]
  have hLS : LSeries a s = riemannZeta s := by
    rw [zeta_eq_tsum_one_div_nat_cpow hs, LSeries]
    apply tsum_congr
    intro n
    rcases eq_or_ne n 0 with rfl | hn
    ¬Ј rw [LSeries.term_zero]
      rw [Nat.cast_zero, Complex.zero_cpow hs0, div_zero]
    ¬Ј rw [LSeries.term_of_ne_zero hn, ha]
      simp only [if_neg hn]
  have habel := lseries_eq_tsum_abel a 1 hC hs hsummable
  rw [hLS] at habel
  rw [habel]
  apply tsum_congr
  intro n
  rw [hA n]

/-- Bernoulli for negative real exponents (Siegel brick A2g-a1-i):
    `(1+u)^{вИТѕГ} вЙ• 1 вИТ ѕГu` for `u, ѕГ вЙ• 0` вАФ from `(1вИТx)eЋ£ вЙ§ 1` and `log(1+u) вЙ§ u`. -/
lemma rpow_neg_ge_one_sub (u ѕГ : вДЭ) (hu : 0 вЙ§ u) (hѕГ : 0 вЙ§ ѕГ) :
    1 - ѕГ * u вЙ§ (1 + u) ^ (-ѕГ) := by
  by_cases hbig : 1 вЙ§ ѕГ * u
  ¬Ј -- trivial: LHS вЙ§ 0 вЙ§ RHS
    have h1 : (0:вДЭ) < 1 + u := by linarith
    have h2 : (0:вДЭ) вЙ§ (1 + u) ^ (-ѕГ) := Real.rpow_nonneg h1.le _
    linarith
  ¬Ј -- (1+u)^ѕГ вЙ§ e^{ѕГu} вЙ§ 1/(1вИТѕГu)
    push_neg at hbig
    have hsmall : ѕГ * u < 1 := hbig
    have h1 : (0:вДЭ) < 1 + u := by linarith
    have hlog : Real.log (1 + u) вЙ§ u := by
      have := Real.log_le_sub_one_of_pos h1
      linarith
    have hpow : (1 + u) ^ ѕГ вЙ§ Real.exp (ѕГ * u) := by
      rw [Real.rpow_def_of_pos h1]
      apply Real.exp_le_exp.mpr
      calc Real.log (1 + u) * ѕГ вЙ§ u * ѕГ := mul_le_mul_of_nonneg_right hlog hѕГ
        _ = ѕГ * u := mul_comm _ _
    have hexp : Real.exp (ѕГ * u) * (1 - ѕГ * u) вЙ§ 1 := by
      have h2 := Real.add_one_le_exp (-(ѕГ * u))
      have h3 : (0:вДЭ) < Real.exp (ѕГ * u) := Real.exp_pos _
      have h4 : Real.exp (-(ѕГ * u)) = 1 / Real.exp (ѕГ * u) := by
        rw [Real.exp_neg, one_div]
      rw [h4, le_div_iffвВА h3] at h2
      nlinarith [h2]
    have hposѕГu : (0:вДЭ) < 1 - ѕГ * u := by linarith
    have hpow0 : (0:вДЭ) < (1 + u) ^ ѕГ := Real.rpow_pos_of_pos h1 _
    rw [Real.rpow_neg h1.le, le_inv_commвВА hposѕГu hpow0]
    calc (1 + u) ^ ѕГ вЙ§ Real.exp (ѕГ * u) := hpow
      _ вЙ§ 1 / (1 - ѕГ * u) := by
          rw [le_div_iffвВА hposѕГu]
          exact hexp
      _ = (1 - ѕГ * u)вБї¬є := one_div _

/-- **The kernel decay bound** (Siegel brick A2g-a1): for `ѕГ вЙ• 0` and `n вЙ• 1`,
    `n^{вИТѕГ} вИТ (n+1)^{вИТѕГ} вЙ§ ѕГ¬Јn^{вИТѕГвИТ1}` вАФ the uniform-in-window majorant. -/
lemma rpow_diff_le (n : вДХ) (hn : 1 вЙ§ n) (ѕГ : вДЭ) (hѕГ : 0 вЙ§ ѕГ) :
    (n : вДЭ) ^ (-ѕГ) - ((n + 1 : вДХ) : вДЭ) ^ (-ѕГ) вЙ§ ѕГ * (n : вДЭ) ^ (-ѕГ - 1) := by
  have hn0 : (0:вДЭ) < n := by exact_mod_cast hn
  have hu : (0:вДЭ) вЙ§ 1 / n := by positivity
  have hb := rpow_neg_ge_one_sub (1 / n) ѕГ hu hѕГ
  have hsplit : ((n + 1 : вДХ) : вДЭ) = (n : вДЭ) * (1 + 1 / n) := by
    push_cast
    field_simp
  have hmul : ((n + 1 : вДХ) : вДЭ) ^ (-ѕГ) = (n : вДЭ) ^ (-ѕГ) * (1 + 1 / n) ^ (-ѕГ) := by
    rw [hsplit, Real.mul_rpow hn0.le (by positivity)]
  rw [hmul]
  have hnѕГ : (0:вДЭ) < (n : вДЭ) ^ (-ѕГ) := Real.rpow_pos_of_pos hn0 _
  have hkey : (n : вДЭ) ^ (-ѕГ) - (n : вДЭ) ^ (-ѕГ) * (1 + 1 / n) ^ (-ѕГ)
      вЙ§ (n : вДЭ) ^ (-ѕГ) * (ѕГ * (1 / n)) := by
    have h1 : (n : вДЭ) ^ (-ѕГ) * (1 - ѕГ * (1 / n)) вЙ§ (n : вДЭ) ^ (-ѕГ) * (1 + 1 / n) ^ (-ѕГ) :=
      mul_le_mul_of_nonneg_left hb hnѕГ.le
    nlinarith [h1]
  calc (n : вДЭ) ^ (-ѕГ) - (n : вДЭ) ^ (-ѕГ) * (1 + 1 / n) ^ (-ѕГ)
      вЙ§ (n : вДЭ) ^ (-ѕГ) * (ѕГ * (1 / n)) := hkey
    _ = ѕГ * ((n : вДЭ) ^ (-ѕГ) * (n : вДЭ) ^ (-(1:вДЭ))) := by
        rw [Real.rpow_neg_one]
        field_simp
    _ = ѕГ * (n : вДЭ) ^ (-ѕГ - 1) := by
        rw [вЖР Real.rpow_add hn0]
        ring_nf

/-- **The E-series is differentiable on `Re s > 9/10`** (Siegel brick A2g-a2): with
    `|E(n)| вЙ§ C¬Јn^{3/4}(1+log n)` and `E(0) = 0`, the series
    `s вЖ¶ ќ£' E(n)(n^{вИТs} вИТ (n+1)^{вИТs})` is differentiable at every point of the
    half-plane вАФ the analytic error part of the continuation `G`, via Mathlib's
    Weierstrass M-test `differentiableOn_tsum_of_summable_norm` on windows. -/
theorem eseries_differentiableAt (E : вДХ вЖТ вДЭ) (C : вДЭ) (hC0 : 0 вЙ§ C) (hE0 : E 0 = 0)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)))
    (sвВА : вДВ) (hsвВА : 9/10 < sвВА.re) :
    DifferentiableAt вДВ (fun s => вИС' n : вДХ,
      ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) sвВА := by
  set ѕГвВА : вДЭ := (9/10 + sвВА.re) / 2 with hѕГвВА
  have hѕГвВА1 : 9/10 < ѕГвВА := by rw [hѕГвВА]; linarith
  have hѕГвВА2 : ѕГвВА < sвВА.re := by rw [hѕГвВА]; linarith
  set R : вДЭ := вАЦsвВАвАЦ + 1 with hR
  have hR0 : 0 < R := by
    rw [hR]
    have := norm_nonneg sвВА
    linarith
  set U : Set вДВ := {s : вДВ | ѕГвВА < s.re} вИ© Metric.ball 0 R with hU
  have hUopen : IsOpen U := by
    apply IsOpen.inter
    ¬Ј exact isOpen_lt continuous_const Complex.continuous_re
    ¬Ј exact Metric.isOpen_ball
  have hsвВАU : sвВА вИИ U := by
    rw [hU]
    constructor
    ¬Ј exact hѕГвВА2
    ¬Ј rw [Metric.mem_ball, dist_zero_right, hR]
      linarith
  -- the majorant
  set u : вДХ вЖТ вДЭ := fun n => if n = 0 then 0 else
    C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1)) with hu
  have hmajsum : Summable (fun n : вДХ => (9 * C * R) * (1 / ((n:вДЭ)) ^ (ѕГвВА + 1/8))) :=
    Summable.mul_left _ (Real.summable_one_div_nat_rpow.mpr (by linarith))
  have husum : Summable u := by
    apply Summable.of_nonneg_of_le _ _ hmajsum
    ¬Ј intro n
      rw [hu]
      rcases eq_or_ne n 0 with rfl | hn
      ¬Ј simp
      ¬Ј simp only [if_neg hn]
        have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by
          have : 1 вЙ§ n := Nat.one_le_iff_ne_zero.mpr hn
          exact_mod_cast this
        have hlog0 : (0:вДЭ) вЙ§ 1 + Real.log n := by
          have := Real.log_nonneg hn1
          linarith
        positivity
    ¬Ј intro n
      rcases eq_or_ne n 0 with rfl | hn
      ¬Ј rw [hu]
        simp only [if_pos rfl]
        positivity
      ¬Ј rw [hu]
        simp only [if_neg hn]
        have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by
          have : 1 вЙ§ n := Nat.one_le_iff_ne_zero.mpr hn
          exact_mod_cast this
        have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
        -- (1 + log n) вЙ§ 9 n^{1/8}
        have hlogbound : 1 + Real.log n вЙ§ 9 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
          have h1 : Real.log n вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) :=
            Real.log_le_rpow_div hn0.le (by norm_num)
          have h2 : ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) = 8 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by ring
          have h3 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) :=
            Real.one_le_rpow hn1 (by norm_num)
          linarith [h1, h2.le, h2.ge, h3]
        -- collect exponents: 3/4 + 1/8 вИТ ѕГвВА вИТ 1 = вИТ(ѕГвВА + 1/8)
        have hcollect : ((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) * ((n:вДЭ)) ^ (-ѕГвВА - 1)
            = ((n:вДЭ)) ^ (-(ѕГвВА + 1/8)) := by
          rw [вЖР Real.rpow_add hn0, вЖР Real.rpow_add hn0]
          ring_nf
        have hfinal : C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1))
            вЙ§ (9 * C * R) * ((n:вДЭ)) ^ (-(ѕГвВА + 1/8)) := by
          calc C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1))
              вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (9 * ((n:вДЭ)) ^ ((1:вДЭ)/8))) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1)) := by
                apply mul_le_mul_of_nonneg_right _ (by positivity)
                apply mul_le_mul_of_nonneg_left _ hC0
                apply mul_le_mul_of_nonneg_left hlogbound (by positivity)
            _ = (9 * C * R) * (((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) * ((n:вДЭ)) ^ (-ѕГвВА - 1)) := by
                ring
            _ = (9 * C * R) * ((n:вДЭ)) ^ (-(ѕГвВА + 1/8)) := by rw [hcollect]
        calc C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1))
            вЙ§ (9 * C * R) * ((n:вДЭ)) ^ (-(ѕГвВА + 1/8)) := hfinal
          _ = (9 * C * R) * (1 / ((n:вДЭ)) ^ (ѕГвВА + 1/8)) := by
              rw [Real.rpow_neg hn0.le]
              ring
  -- pointwise bounds on U
  have hbound : вИА (n : вДХ) (w : вДВ), w вИИ U вЖТ
      вАЦ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-w) - (((n + 1 : вДХ):вДВ)) ^ (-w))вАЦ вЙ§ u n := by
    intro n w hw
    obtain вЯ®hwre, hwballвЯ© := hw
    have hwre' : ѕГвВА < w.re := hwre
    have hwѕГ : (0:вДЭ) < w.re := by linarith
    have hwnorm : вАЦwвАЦ вЙ§ R := by
      rw [Metric.mem_ball, dist_zero_right] at hwball
      linarith
    rcases eq_or_ne n 0 with rfl | hn
    ¬Ј rw [hE0]
      simp only [Complex.ofReal_zero, zero_mul, norm_zero, hu, if_pos rfl]
      exact le_refl 0
    ¬Ј have hn1 : 1 вЙ§ n := Nat.one_le_iff_ne_zero.mpr hn
      have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn1
      have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
      rw [hu]
      simp only [if_neg hn]
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs]
      have h1 := hE n hn1
      have h2 := cpow_diff_kernel_bound n hn1 w hwѕГ
      have h3 := rpow_diff_le n hn1 w.re hwѕГ.le
      have hker : вАЦ((n:вДВ)) ^ (-w) - (((n + 1 : вДХ):вДВ)) ^ (-w)вАЦ вЙ§ R * ((n:вДЭ)) ^ (-ѕГвВА - 1) := by
        have hstep : (вАЦwвАЦ / w.re) * ((n : вДЭ) ^ (-w.re) - ((n + 1 : вДХ) : вДЭ) ^ (-w.re))
            вЙ§ (вАЦwвАЦ / w.re) * (w.re * (n : вДЭ) ^ (-w.re - 1)) := by
          apply mul_le_mul_of_nonneg_left h3 (by positivity)
        have hsimp : (вАЦwвАЦ / w.re) * (w.re * (n : вДЭ) ^ (-w.re - 1))
            = вАЦwвАЦ * (n : вДЭ) ^ (-w.re - 1) := by
          field_simp
        have hmono : ((n:вДЭ)) ^ (-w.re - 1) вЙ§ ((n:вДЭ)) ^ (-ѕГвВА - 1) := by
          apply Real.rpow_le_rpow_of_exponent_le hn1r
          linarith
        calc вАЦ((n:вДВ)) ^ (-w) - (((n + 1 : вДХ):вДВ)) ^ (-w)вАЦ
            вЙ§ (вАЦwвАЦ / w.re) * ((n : вДЭ) ^ (-w.re) - ((n + 1 : вДХ) : вДЭ) ^ (-w.re)) := h2
          _ вЙ§ вАЦwвАЦ * ((n:вДЭ)) ^ (-w.re - 1) := by
              rw [вЖР hsimp]
              exact hstep
          _ вЙ§ R * ((n:вДЭ)) ^ (-ѕГвВА - 1) := by
              apply mul_le_mul hwnorm hmono (by positivity) hR0.le
      have hEnn : (0:вДЭ) вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
        have hlog0 : (0:вДЭ) вЙ§ 1 + Real.log n := by
          have := Real.log_nonneg hn1r
          linarith
        positivity
      calc |E n| * вАЦ((n:вДВ)) ^ (-w) - (((n + 1 : вДХ):вДВ)) ^ (-w)вАЦ
          вЙ§ (C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n))) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1)) :=
            mul_le_mul h1 hker (norm_nonneg _) hEnn
        _ = C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) * (R * ((n:вДЭ)) ^ (-ѕГвВА - 1)) := by
            ring
  -- termwise differentiability on U
  have hdiff : вИА n : вДХ, DifferentiableOn вДВ
      (fun s => ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) U := by
    intro n
    rcases eq_or_ne n 0 with rfl | hn
    ¬Ј rw [hE0]
      simp only [Complex.ofReal_zero, zero_mul]
      exact differentiableOn_const 0
    ¬Ј have hn0 : ((n:вДВ)) вЙ† 0 := by exact_mod_cast hn
      have hn10 : (((n + 1 : вДХ):вДВ)) вЙ† 0 := by exact_mod_cast Nat.succ_ne_zero n
      apply DifferentiableOn.const_mul
      apply DifferentiableOn.sub
      ¬Ј exact ((Differentiable.neg differentiable_id).const_cpow
          (Or.inl hn0)).differentiableOn
      ¬Ј exact ((Differentiable.neg differentiable_id).const_cpow
          (Or.inl hn10)).differentiableOn
  -- assemble
  have hDon := Complex.differentiableOn_tsum_of_summable_norm husum hdiff hUopen hbound
  exact (hDon.differentiableAt (hUopen.mem_nhds hsвВАU))

/-- Linear-growth sequences give absolutely convergent Abel series (A2g-c-i):
    the summability half of `lseries_eq_tsum_abel`, exposed standalone. -/
lemma abel_tsum_summable (b : вДХ вЖТ вДВ) (C : вДЭ)
    (hb : вИА n : вДХ, вАЦb nвАЦ вЙ§ C * n)
    {s : вДВ} (hs : 1 < s.re) :
    Summable (fun n : вДХ => b n * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) := by
  have hC0 : 0 вЙ§ C := by
    have h0 := hb 1
    have h1 : (0:вДЭ) вЙ§ вАЦb 1вАЦ := norm_nonneg _
    have h2 : C * ((1:вДХ):вДЭ) = C := by norm_num
    linarith [h0, h1, h2.le, h2.ge]
  have hѕГ0 : (0:вДЭ) < s.re := by linarith
  set w : вДХ вЖТ вДЭ := fun n => ((n:вДЭ)) ^ (-s.re) with hw
  have hwanti : вИА n : вДХ, 1 вЙ§ n вЖТ w (n + 1) вЙ§ w n := by
    intro n hn
    rw [hw]
    simp only
    apply Real.rpow_le_rpow_of_nonpos (by exact_mod_cast hn) (by push_cast; linarith)
    linarith
  apply Summable.of_norm_bounded
    (g := fun n : вДХ => (C * (вАЦsвАЦ / s.re)) * ((n:вДЭ) * (w n - w (n + 1))))
  ¬Ј apply summable_of_sum_range_le (c := (C * (вАЦsвАЦ / s.re)) * (s.re / (s.re - 1)))
    ¬Ј intro n
      rcases Nat.eq_zero_or_pos n with rfl | hn0
      ¬Ј simp
      ¬Ј apply mul_nonneg (by positivity)
        apply mul_nonneg (Nat.cast_nonneg n)
        linarith [hwanti n hn0]
    ¬Ј intro x
      have hIcc : вИС i вИИ range x, (C * (вАЦsвАЦ / s.re)) * ((i:вДЭ) * (w i - w (i + 1)))
          = (C * (вАЦsвАЦ / s.re)) * вИС i вИИ Icc 1 (x - 1), ((i:вДЭ) * (w i - w (i + 1))) := by
        rw [Finset.mul_sum]
        rcases Nat.eq_zero_or_pos x with rfl | hx0
        ¬Ј simp
        ¬Ј rw [show range x = insert 0 (Icc 1 (x - 1)) from by
            ext m
            simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]
            omega]
          rw [Finset.sum_insert (by simp)]
          simp
      rw [hIcc, weighted_telescope w (x - 1)]
      have htail : (0:вДЭ) вЙ§ ((x - 1 : вДХ):вДЭ) * w ((x - 1) + 1) := by
        apply mul_nonneg (Nat.cast_nonneg _)
        rw [hw]
        simp only
        positivity
      have hsums : вИС n вИИ Icc 1 (x - 1), w n вЙ§ s.re / (s.re - 1) := by
        have hterm : вИА n вИИ Icc 1 (x - 1), w n = 1 / ((n:вДЭ)) ^ s.re := by
          intro n hn
          obtain вЯ®hn1, _вЯ© := Finset.mem_Icc.mp hn
          rw [hw]
          simp only
          rw [Real.rpow_neg (Nat.cast_nonneg n), one_div]
        rw [Finset.sum_congr rfl hterm]
        calc вИС n вИИ Icc 1 (x - 1), 1 / ((n:вДЭ)) ^ s.re
            вЙ§ вИС' n : вДХ, (1:вДЭ) / ((n:вДЭ)) ^ s.re :=
              Summable.sum_le_tsum _ (fun n _ => by positivity)
                (Real.summable_one_div_nat_rpow.mpr hs)
          _ вЙ§ s.re / (s.re - 1) := tsum_one_div_nat_rpow_le s.re hs
      have hfac : (0:вДЭ) вЙ§ C * (вАЦsвАЦ / s.re) := by positivity
      apply mul_le_mul_of_nonneg_left _ hfac
      linarith [hsums, htail]
  ¬Ј intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј have hb0 : вАЦb 0вАЦ = 0 := by
        have h := hb 0
        have h2 : C * ((0:вДХ):вДЭ) = 0 := by norm_num
        have := norm_nonneg (b 0)
        linarith [h, h2.le, h2.ge]
      rw [norm_mul, hb0, zero_mul]
      have hrhs : (C * (вАЦsвАЦ / s.re)) * (((0:вДХ):вДЭ) * (w 0 - w (0 + 1))) = 0 := by
        norm_num
      rw [hrhs]
    ¬Ј rw [norm_mul]
      have h1 := hb n
      have h2 := cpow_diff_kernel_bound n hn0 s hѕГ0
      calc вАЦb nвАЦ * вАЦ((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)вАЦ
          вЙ§ (C * n) * ((вАЦsвАЦ / s.re) * ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re))) := by
            apply mul_le_mul h1 h2 (norm_nonneg _)
            positivity
        _ = (C * (вАЦsвАЦ / s.re)) * ((n:вДЭ) * (w n - w (n + 1))) := by
            rw [hw]
            simp only
            push_cast
            ring

/-- **The continuation identity on `Re s > 1`** (Siegel brick A2g-c): with
    `A(n) = ќїn + E(n)` (linear main term + controlled error), the L-series equals
    `ќї¬Јќґ(s) + ќ£' E(n)ќФвВЩ(s)` вАФ the function `G` that continues it to `Re > 9/10`. -/
theorem lseries_eq_G (a : вДХ вЖТ вДВ) (lam : вДЭ) (E : вДХ вЖТ вДЭ) (C : вДЭ)
    (hAE : вИА n : вДХ, вИС m вИИ Icc 1 n, a m = (lam * n : вДЭ) + E n)
    (hEb : вИА n : вДХ, |E n| вЙ§ C * n)
    {s : вДВ} (hs : 1 < s.re) (hsum : LSeriesSummable a s) :
    LSeries a s = (lam : вДВ) * riemannZeta s
      + вИС' n : вДХ, ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) := by
  have hC0 : 0 вЙ§ C := by
    have h0 := hEb 1
    have h1 : (0:вДЭ) вЙ§ |E 1| := abs_nonneg _
    have h2 : C * ((1:вДХ):вДЭ) = C := by norm_num
    linarith [h0, h1, h2.le, h2.ge]
  -- the A-partial sums are linearly bounded
  have hA : вИА x : вДХ, вАЦвИС n вИИ Icc 1 x, a nвАЦ вЙ§ (|lam| + C) * x := by
    intro x
    rw [hAE x]
    calc вАЦ((lam * x : вДЭ) : вДВ) + ((E x : вДЭ) : вДВ)вАЦ
        вЙ§ вАЦ((lam * x : вДЭ) : вДВ)вАЦ + вАЦ((E x : вДЭ) : вДВ)вАЦ := norm_add_le _ _
      _ = |lam * x| + |E x| := by
          rw [Complex.norm_real, Complex.norm_real, Real.norm_eq_abs, Real.norm_eq_abs]
      _ вЙ§ |lam| * x + C * x := by
          apply add_le_add
          ¬Ј rw [abs_mul, Nat.abs_cast]
          ¬Ј exact hEb x
      _ = (|lam| + C) * x := by ring
  rw [lseries_eq_tsum_abel a (|lam| + C) hA hs hsum]
  -- split the tsum
  have hsplit : вИА n : вДХ, (вИС m вИИ Icc 1 n, a m) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))
      = (lam : вДВ) * (((n:вДВ)) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)))
        + ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) := by
    intro n
    rw [hAE n]
    push_cast
    ring
  rw [tsum_congr hsplit]
  -- summabilities for tsum_add
  have hid : Summable (fun n : вДХ =>
      ((n:вДВ)) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) := by
    apply abel_tsum_summable (fun n : вДХ => ((n:вДВ))) 1 _ hs
    intro n
    rw [Complex.norm_natCast, one_mul]
  have hsum1 : Summable (fun n : вДХ => (lam : вДВ)
      * (((n:вДВ)) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)))) :=
    hid.mul_left ((lam : вДЭ) : вДВ)
  have hsum2 : Summable (fun n : вДХ =>
      ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s))) := by
    apply abel_tsum_summable (fun n : вДХ => ((E n : вДЭ) : вДВ)) C _ hs
    intro n
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact hEb n
  rw [hsum1.tsum_add hsum2, tsum_mul_left, tsum_abel_id_eq_zeta hs]

/-- Identity-theorem step on a convex open piece: agreement near one interior point
    propagates to the whole piece. -/
lemma eqOn_of_convex_piece (f g : вДВ вЖТ вДВ) (V : Set вДВ) (hVo : IsOpen V)
    (hVc : Convex вДЭ V)
    (hf : DifferentiableOn вДВ f V) (hg : DifferentiableOn вДВ g V)
    (zвВА : вДВ) (hzвВА : zвВА вИИ V) (hseed : f =бґ†[nhds zвВА] g) :
    Set.EqOn f g V := by
  have hfa : AnalyticOnNhd вДВ f V := hf.analyticOnNhd hVo
  have hga : AnalyticOnNhd вДВ g V := hg.analyticOnNhd hVo
  exact hfa.eqOn_of_preconnected_of_eventuallyEq hga hVc.isPreconnected hzвВА hseed

/-- **The identity theorem on the slit half-plane** (Siegel brick A2h-iii): two
    functions differentiable on `{Re > 9/10} вИЦ {1}` that agree on `{Re > 1}` agree
    everywhere on the slit half-plane вАФ by chaining through overlapping convex pieces
    (no slit-plane connectivity needed). -/
theorem eqOn_slit_halfplane (f g : вДВ вЖТ вДВ)
    (hf : вИА s : вДВ, 9/10 < s.re вЖТ s вЙ† 1 вЖТ DifferentiableAt вДВ f s)
    (hg : вИА s : вДВ, 9/10 < s.re вЖТ s вЙ† 1 вЖТ DifferentiableAt вДВ g s)
    (heq : вИА s : вДВ, 1 < s.re вЖТ f s = g s)
    (sвВА : вДВ) (hвВАre : 9/10 < sвВА.re) (hвВАne : sвВА вЙ† 1) : f sвВА = g sвВА := by
  -- the convex pieces
  set VвВБ : Set вДВ := {s : вДВ | 9/10 < s.re вИІ 0 < s.im} with hVвВБ
  set VвВВ : Set вДВ := {s : вДВ | 9/10 < s.re вИІ s.im < 0} with hVвВВ
  set VвВГ : Set вДВ := {s : вДВ | 1 < s.re} with hVвВГ
  set VвВД : Set вДВ := {s : вДВ | 9/10 < s.re вИІ s.re < 1} with hVвВД
  -- openness
  have hVвВБo : IsOpen VвВБ :=
    (isOpen_lt continuous_const Complex.continuous_re).inter
      (isOpen_lt continuous_const Complex.continuous_im)
  have hVвВВo : IsOpen VвВВ :=
    (isOpen_lt continuous_const Complex.continuous_re).inter
      (isOpen_lt Complex.continuous_im continuous_const)
  have hVвВГo : IsOpen VвВГ := isOpen_lt continuous_const Complex.continuous_re
  have hVвВДo : IsOpen VвВД :=
    (isOpen_lt continuous_const Complex.continuous_re).inter
      (isOpen_lt Complex.continuous_re continuous_const)
  -- convexity: intersections of re/im half-spaces
  have hVвВБc : Convex вДЭ VвВБ :=
    (convex_halfSpace_re_gt (9/10)).inter (convex_halfSpace_im_gt 0)
  have hVвВВc : Convex вДЭ VвВВ :=
    (convex_halfSpace_re_gt (9/10)).inter (convex_halfSpace_im_lt 0)
  have hVвВГc : Convex вДЭ VвВГ := convex_halfSpace_re_gt 1
  have hVвВДc : Convex вДЭ VвВД :=
    (convex_halfSpace_re_gt (9/10)).inter (convex_halfSpace_re_lt 1)
  -- every piece avoids 1 and sits in the domain
  have hne1 : вИА {V : Set вДВ}, (вИА s вИИ V, 9/10 < s.re вИІ s вЙ† 1) вЖТ
      DifferentiableOn вДВ f V вИІ DifferentiableOn вДВ g V := by
    intro V hV
    constructor
    ¬Ј intro s hs
      exact ((hf s (hV s hs).1 (hV s hs).2).differentiableWithinAt)
    ¬Ј intro s hs
      exact ((hg s (hV s hs).1 (hV s hs).2).differentiableWithinAt)
  have hdomвВБ : вИА s вИИ VвВБ, 9/10 < s.re вИІ s вЙ† 1 := by
    rintro s вЯ®h1, h2вЯ©
    refine вЯ®h1, ?_вЯ©
    intro hc
    rw [hc] at h2
    simp at h2
  have hdomвВВ : вИА s вИИ VвВВ, 9/10 < s.re вИІ s вЙ† 1 := by
    rintro s вЯ®h1, h2вЯ©
    refine вЯ®h1, ?_вЯ©
    intro hc
    rw [hc] at h2
    simp at h2
  have hdomвВГ : вИА s вИИ VвВГ, 9/10 < s.re вИІ s вЙ† 1 := by
    intro s hs
    have h1 : 1 < s.re := hs
    refine вЯ®by linarith, ?_вЯ©
    intro hc
    rw [hc] at h1
    simp at h1
  have hdomвВД : вИА s вИИ VвВД, 9/10 < s.re вИІ s вЙ† 1 := by
    rintro s вЯ®h1, h2вЯ©
    refine вЯ®h1, ?_вЯ©
    intro hc
    rw [hc] at h2
    simp at h2
  obtain вЯ®hfвВБ, hgвВБвЯ© := hne1 hdomвВБ
  obtain вЯ®hfвВВ, hgвВВвЯ© := hne1 hdomвВВ
  obtain вЯ®hfвВД, hgвВДвЯ© := hne1 hdomвВД
  -- seed on VвВГ overlaps: 2 + i вИИ VвВБ вИ© VвВГ, 2 вИТ i вИИ VвВВ вИ© VвВГ
  have hseedвВБ : f =бґ†[nhds (2 + Complex.I)] g := by
    have hmem : (2 + Complex.I) вИИ VвВГ := by
      show (1:вДЭ) < (2 + Complex.I).re
      simp
    filter_upwards [hVвВГo.mem_nhds hmem] with w hw
    exact heq w hw
  have hseedвВВ : f =бґ†[nhds (2 - Complex.I)] g := by
    have hmem : (2 - Complex.I) вИИ VвВГ := by
      show (1:вДЭ) < (2 - Complex.I).re
      simp
    filter_upwards [hVвВГo.mem_nhds hmem] with w hw
    exact heq w hw
  -- VвВБ, VвВВ agreement
  have hEqвВБ : Set.EqOn f g VвВБ := by
    apply eqOn_of_convex_piece f g VвВБ hVвВБo hVвВБc hfвВБ hgвВБ (2 + Complex.I) _ hseedвВБ
    constructor
    ¬Ј show (9:вДЭ)/10 < (2 + Complex.I).re
      simp
      norm_num
    ¬Ј show (0:вДЭ) < (2 + Complex.I).im
      simp
  have hEqвВВ : Set.EqOn f g VвВВ := by
    apply eqOn_of_convex_piece f g VвВВ hVвВВo hVвВВc hfвВВ hgвВВ (2 - Complex.I) _ hseedвВВ
    constructor
    ¬Ј show (9:вДЭ)/10 < (2 - Complex.I).re
      simp
      norm_num
    ¬Ј show (2 - Complex.I).im < 0
      simp
  -- VвВД agreement, seeded from VвВБ at 19/20 + i/2
  have hmid : ((19:вДЭ)/20 + Complex.I * (1/2)) вИИ VвВБ вИ© VвВД := by
    constructor
    ¬Ј constructor
      ¬Ј show (9:вДЭ)/10 < ((19:вДЭ)/20 + Complex.I * (1/2)).re
        simp
        norm_num
      ¬Ј show (0:вДЭ) < ((19:вДЭ)/20 + Complex.I * (1/2)).im
        simp
    ¬Ј constructor
      ¬Ј show (9:вДЭ)/10 < ((19:вДЭ)/20 + Complex.I * (1/2)).re
        simp
        norm_num
      ¬Ј show ((19:вДЭ)/20 + Complex.I * (1/2)).re < 1
        simp
        norm_num
  have hseedвВД : f =бґ†[nhds ((19:вДЭ)/20 + Complex.I * (1/2))] g := by
    filter_upwards [hVвВБo.mem_nhds hmid.1] with w hw
    exact hEqвВБ hw
  have hEqвВД : Set.EqOn f g VвВД := by
    apply eqOn_of_convex_piece f g VвВД hVвВДo hVвВДc hfвВД hgвВД _ hmid.2 hseedвВД
  -- conclude by cases on sвВА
  rcases lt_trichotomy sвВА.re 1 with hlt | heq1 | hgt
  ¬Ј exact hEqвВД вЯ®hвВАre, hltвЯ©
  ¬Ј -- re = 1: im вЙ† 0
    have him : sвВА.im вЙ† 0 := by
      intro hc
      apply hвВАne
      apply Complex.ext
      ¬Ј rw [heq1]
        simp
      ¬Ј rw [hc]
        simp
    rcases lt_or_gt_of_ne him with hneg | hpos
    ¬Ј exact hEqвВВ вЯ®hвВАre, hnegвЯ©
    ¬Ј exact hEqвВБ вЯ®hвВАre, hposвЯ©
  ¬Ј exact heq sвВА hgt

/-- Complex log-Taylor remainder (A2h-i-a): for real `0 вЙ§ z вЙ§ 1/2`,
    `|log(1+z) вИТ z| вЙ§ z¬≤`. -/
lemma log_taylor_remainder (z : вДЭ) (h0 : 0 вЙ§ z) (h1 : z вЙ§ 1/2) :
    |Real.log (1 + z) - z| вЙ§ z ^ 2 := by
  have h1z : (0:вДЭ) < 1 + z := by linarith
  -- upper: log(1+z) вЙ§ z
  have hup : Real.log (1 + z) вЙ§ z := by
    have := Real.log_le_sub_one_of_pos h1z
    linarith
  -- lower: log(1+z) вЙ• z вИТ z¬≤ via log(1+z) = вИТlog(1/(1+z)) and log(1/(1+z)) вЙ§ 1/(1+z) вИТ 1
  have hlow : z - z ^ 2 вЙ§ Real.log (1 + z) := by
    have hinv : Real.log (1 / (1 + z)) вЙ§ 1 / (1 + z) - 1 := by
      have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < 1 / (1 + z) by positivity)
      linarith
    have hneg : Real.log (1 / (1 + z)) = -Real.log (1 + z) := by
      rw [one_div, Real.log_inv]
    rw [hneg] at hinv
    have halg : 1 / (1 + z) - 1 = -z / (1 + z) := by
      field_simp
      ring
    rw [halg] at hinv
    -- вИТlog(1+z) вЙ§ вИТz/(1+z) вЯє log(1+z) вЙ• z/(1+z) вЙ• z вИТ z¬≤
    have hfrac : z - z ^ 2 вЙ§ z / (1 + z) := by
      rw [le_div_iffвВА h1z]
      nlinarith [h0, h1]
    have : z / (1 + z) вЙ§ Real.log (1 + z) := by
      have := neg_le_neg hinv
      simp only [neg_neg] at this
      calc z / (1 + z) = -(-z / (1 + z)) := by ring
        _ вЙ§ Real.log (1 + z) := by linarith [hinv]
    linarith
  rw [abs_le]
  constructor
  ¬Ј linarith
  ¬Ј nlinarith [hup, h0]

/-- **Second-order cpow Taylor bound** (Siegel brick A2h-i): for `w : вДВ` and real
    `0 вЙ§ z вЙ§ 1/2` with `вАЦwвАЦ вЙ§ W` and `W*z вЙ§ 1`,
    `вАЦ(1+z)^w вИТ 1 вИТ wzвАЦ вЙ§ 4(W+1)¬≤z¬≤` вАФ the engine of the ќґ-truncation defect. -/
lemma cpow_taylor_two (w : вДВ) (z : вДЭ) (h0 : 0 вЙ§ z) (h1 : z вЙ§ 1/2)
    (W : вДЭ) (hW : вАЦwвАЦ вЙ§ W) (hWz : W * z вЙ§ 1) :
    вАЦ((1 + z : вДЭ) : вДВ) ^ w - 1 - w * zвАЦ вЙ§ 4 * (W + 1) ^ 2 * z ^ 2 := by
  have hW0 : 0 вЙ§ W := le_trans (norm_nonneg w) hW
  have h1z : (0:вДЭ) < 1 + z := by linarith
  -- (1+z)^w = exp(w log(1+z))
  have hcpow : ((1 + z : вДЭ) : вДВ) ^ w = Complex.exp (w * Real.log (1 + z)) := by
    rw [Complex.cpow_def_of_ne_zero (by exact_mod_cast ne_of_gt h1z)]
    congr 1
    rw [Complex.ofReal_log h1z.le]
    ring
  rw [hcpow]
  -- split: exp(wL) вИТ 1 вИТ wz = [exp(wL) вИТ 1 вИТ wL] + w(L вИТ z)
  set L : вДЭ := Real.log (1 + z) with hL
  have hLz : |L - z| вЙ§ z ^ 2 := log_taylor_remainder z h0 h1
  have hLb : |L| вЙ§ z := by
    have h2 : 0 вЙ§ L := Real.log_nonneg (by linarith)
    have h3 : L вЙ§ z := by
      have := Real.log_le_sub_one_of_pos h1z
      rw [hL]
      linarith
    rw [abs_of_nonneg h2]
    exact h3
  have hwL : вАЦw * (L : вДВ)вАЦ вЙ§ W * z := by
    rw [norm_mul, Complex.norm_real, Real.norm_eq_abs]
    apply mul_le_mul hW hLb (abs_nonneg _) hW0
  -- вАЦexp(u) вИТ 1 вИТ uвАЦ вЙ§ вАЦuвАЦ¬≤ for вАЦuвАЦ вЙ§ 1
  have hexp2 : вАЦComplex.exp (w * L) - 1 - w * LвАЦ вЙ§ вАЦw * (L : вДВ)вАЦ ^ 2 := by
    have := Complex.norm_exp_sub_one_sub_id_le (x := w * (L : вДВ)) (by
      calc вАЦw * (L : вДВ)вАЦ вЙ§ W * z := hwL
        _ вЙ§ 1 := hWz)
    exact this
  have hsplit : Complex.exp (w * L) - 1 - w * z
      = (Complex.exp (w * L) - 1 - w * L) + w * ((L : вДВ) - z) := by
    ring
  rw [hsplit]
  have hterm2 : вАЦw * ((L : вДВ) - z)вАЦ вЙ§ W * z ^ 2 := by
    rw [norm_mul, show ((L : вДВ) - (z : вДЭ)) = (((L - z : вДЭ)) : вДВ) from by push_cast; ring,
      Complex.norm_real, Real.norm_eq_abs]
    exact mul_le_mul hW hLz (abs_nonneg _) hW0
  have hsq : вАЦw * (L : вДВ)вАЦ ^ 2 вЙ§ (W * z) ^ 2 := by
    have h := norm_nonneg (w * (L : вДВ))
    nlinarith [hwL, h]
  calc вАЦ(Complex.exp (w * L) - 1 - w * L) + w * ((L : вДВ) - z)вАЦ
      вЙ§ вАЦComplex.exp (w * L) - 1 - w * LвАЦ + вАЦw * ((L : вДВ) - z)вАЦ := norm_add_le _ _
    _ вЙ§ вАЦw * (L : вДВ)вАЦ ^ 2 + W * z ^ 2 := add_le_add hexp2 hterm2
    _ вЙ§ (W * z) ^ 2 + W * z ^ 2 := by linarith [hsq]
    _ вЙ§ 4 * (W + 1) ^ 2 * z ^ 2 := by
        nlinarith [hW0, sq_nonneg z, sq_nonneg W, mul_nonneg hW0 (sq_nonneg z)]

/-- **The second-order EulerвАУMaclaurin kernel bound** (Siegel brick A2h-ii-ќ±), in the
    `(sвИТ1)`-cleared form: for `n вЙ• 2`, `вАЦ1вИТsвАЦ вЙ§ W`, `W/n вЙ§ 1`:
    `вАЦ(sвИТ1)n^{вИТs} вИТ (n^{1вИТs} вИТ (n+1)^{1вИТs})вАЦ вЙ§ 4(W+1)¬≤¬Јn^{вИТ2}¬Јn^{1вИТRe s}`. -/
lemma euler_maclaurin_kernel (s : вДВ) (n : вДХ) (hn2 : 2 вЙ§ n)
    (W : вДЭ) (hW : вАЦ1 - sвАЦ вЙ§ W) (hWn : W * (1 / n) вЙ§ 1) :
    вАЦ(s - 1) * ((n:вДВ)) ^ (-s) - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))вАЦ
      вЙ§ 4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - s.re) := by
  have hn0 : (0:вДЭ) < (n:вДЭ) := by
    have : (0:вДХ) < n := by omega
    exact_mod_cast this
  have hnc0 : ((n:вДВ)) вЙ† 0 := by
    exact_mod_cast (by omega : n вЙ† 0)
  have hz1 : (1:вДЭ) / n вЙ§ 1/2 := by
    rw [div_le_div_iffвВА hn0 (by norm_num)]
    push_cast
    linarith [show (2:вДЭ) вЙ§ (n:вДЭ) from by exact_mod_cast hn2]
  have hz0 : (0:вДЭ) вЙ§ 1 / n := by positivity
  -- (n+1)^{1вИТs} = n^{1вИТs}¬Ј(1+1/n)^{1вИТs}
  have hsplit : (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)
      = ((n:вДВ)) ^ ((1:вДВ) - s) * (((1 + 1/(n:вДЭ) : вДЭ)) : вДВ) ^ ((1:вДВ) - s) := by
    have hy0 : (0:вДЭ) вЙ§ 1 + 1/(n:вДЭ) := by positivity
    have hb : (((n + 1 : вДХ):вДВ)) = (((n:вДЭ) : вДВ)) * (((1 + 1/(n:вДЭ) : вДЭ)) : вДВ) := by
      push_cast
      field_simp
    rw [hb, Complex.mul_cpow_ofReal_nonneg hn0.le hy0]
    norm_cast
  rw [hsplit]
  -- factor: LHS = n^{1вИТs}¬Ј[(1+1/n)^{1вИТs} вИТ 1 вИТ (1вИТs)(1/n)]
  have hpow : ((n:вДВ)) ^ ((1:вДВ) - s) = ((n:вДВ)) * ((n:вДВ)) ^ (-s) := by
    rw [show (1:вДВ) - s = 1 + (-s) by ring, Complex.cpow_add _ _ hnc0, Complex.cpow_one]
  have hnz : ((n:вДВ)) * ((1/(n:вДЭ) : вДЭ) : вДВ) = 1 := by
    have hc : ((1/(n:вДЭ) : вДЭ) : вДВ) = 1 / ((n:вДВ)) := by push_cast; ring
    rw [hc, mul_one_div, div_self hnc0]
  have hfactor : (s - 1) * ((n:вДВ)) ^ (-s)
      - (((n:вДВ)) ^ ((1:вДВ) - s) - ((n:вДВ)) ^ ((1:вДВ) - s) * (((1 + 1/(n:вДЭ) : вДЭ)) : вДВ) ^ ((1:вДВ) - s))
      = ((n:вДВ)) ^ ((1:вДВ) - s)
        * ((((1 + 1/(n:вДЭ) : вДЭ)) : вДВ) ^ ((1:вДВ) - s) - 1 - ((1:вДВ) - s) * ((1/(n:вДЭ) : вДЭ) : вДВ)) := by
    rw [hpow]
    linear_combination (((1:вДВ) - s) * ((n:вДВ)) ^ (-s)) * hnz
  rw [hfactor, norm_mul]
  have hnorm1 : вАЦ((n:вДВ)) ^ ((1:вДВ) - s)вАЦ = ((n:вДЭ)) ^ (1 - s.re) := by
    rw [Complex.norm_natCast_cpow_of_pos (by omega)]
    simp [Complex.sub_re]
  rw [hnorm1]
  have hbr := cpow_taylor_two ((1:вДВ) - s) (1/(n:вДЭ)) hz0 hz1 W hW hWn
  calc ((n:вДЭ)) ^ (1 - s.re)
        * вАЦ(((1 + 1/(n:вДЭ) : вДЭ)) : вДВ) ^ ((1:вДВ) - s) - 1 - ((1:вДВ) - s) * ((1/(n:вДЭ) : вДЭ) : вДВ)вАЦ
      вЙ§ ((n:вДЭ)) ^ (1 - s.re) * (4 * (W + 1) ^ 2 * (1/(n:вДЭ)) ^ 2) := by
        apply mul_le_mul_of_nonneg_left _ (Real.rpow_nonneg hn0.le _)
        have hcast : ((1:вДВ) - s) * ((1/(n:вДЭ) : вДЭ) : вДВ)
            = ((1:вДВ) - s) * (1/(n:вДЭ) : вДЭ) := by norm_num
        rw [hcast]
        exact hbr
    _ = 4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - s.re) := by ring

/-- Reverse Bernoulli (A2h-ii-ќ≤1): `(1+ќЄu)(1вИТu)^ќЄ вЙ§ 1` for `ќЄ вЙ• 0`, `0 вЙ§ u < 1` вАФ
    hence `(nвИТ1)^{1вИТp} вИТ n^{1вИТp} вЙ• (pвИТ1)n^{вИТp}`. -/
lemma one_add_mul_rpow_one_sub_le (ќЄ u : вДЭ) (hќЄ : 0 вЙ§ ќЄ) (h0 : 0 вЙ§ u) (h1 : u < 1) :
    (1 + ќЄ * u) * (1 - u) ^ ќЄ вЙ§ 1 := by
  have h1u : (0:вДЭ) < 1 - u := by linarith
  -- (1вИТu)^ќЄ вЙ§ e^{вИТќЄu}
  have hlog : Real.log (1 - u) вЙ§ -u := by
    have := Real.log_le_sub_one_of_pos h1u
    linarith
  have hpow : (1 - u) ^ ќЄ вЙ§ Real.exp (-(ќЄ * u)) := by
    rw [Real.rpow_def_of_pos h1u]
    apply Real.exp_le_exp.mpr
    calc Real.log (1 - u) * ќЄ вЙ§ (-u) * ќЄ := mul_le_mul_of_nonneg_right hlog hќЄ
      _ = -(ќЄ * u) := by ring
  -- (1+w)e^{вИТw} вЙ§ 1 for w := ќЄu вЙ• 0
  have hw0 : 0 вЙ§ ќЄ * u := mul_nonneg hќЄ h0
  have hexp : (1 + ќЄ * u) * Real.exp (-(ќЄ * u)) вЙ§ 1 := by
    have h2 := Real.add_one_le_exp (ќЄ * u)
    have h3 : (0:вДЭ) < Real.exp (ќЄ * u) := Real.exp_pos _
    have h4 : Real.exp (-(ќЄ * u)) = 1 / Real.exp (ќЄ * u) := by
      rw [Real.exp_neg, one_div]
    rw [h4, mul_one_div, div_le_one h3]
    linarith
  calc (1 + ќЄ * u) * (1 - u) ^ ќЄ вЙ§ (1 + ќЄ * u) * Real.exp (-(ќЄ * u)) := by
        apply mul_le_mul_of_nonneg_left hpow (by linarith)
    _ вЙ§ 1 := hexp

/-- The decreasing-power telescoping comparison (A2h-ii-ќ≤2): for `p > 1`, `n вЙ• 2`:
    `(pвИТ1)¬Јn^{вИТp} вЙ§ (nвИТ1)^{1вИТp} вИТ n^{1вИТp}` вАФ each tail term is dominated by the
    telescoping antiderivative decrement. -/
lemma rpow_tail_term_le (p : вДЭ) (hp : 1 < p) (n : вДХ) (hn : 2 вЙ§ n) :
    (p - 1) * ((n:вДЭ)) ^ (-p) вЙ§ (((n - 1 : вДХ)):вДЭ) ^ (1 - p) - ((n:вДЭ)) ^ (1 - p) := by
  have hn0 : (0:вДЭ) < (n:вДЭ) := by
    have : (0:вДХ) < n := by omega
    exact_mod_cast this
  have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by
    have : (1:вДХ) вЙ§ n := by omega
    exact_mod_cast this
  set u : вДЭ := 1 / n with hu
  have hu0 : 0 вЙ§ u := by positivity
  have hu1 : u < 1 := by
    rw [hu, div_lt_one hn0]
    linarith [show (2:вДЭ) вЙ§ (n:вДЭ) from by exact_mod_cast hn]
  have hcast : (((n - 1 : вДХ)):вДЭ) = (n:вДЭ) * (1 - u) := by
    rw [hu]
    push_cast [Nat.cast_sub (by omega : 1 вЙ§ n)]
    field_simp
  have hber := one_add_mul_rpow_one_sub_le (p - 1) u (by linarith) hu0 hu1
  -- (nвИТ1)^{1вИТp} = n^{1вИТp}¬Ј(1вИТu)^{1вИТp}; want n^{1вИТp}[(1вИТu)^{1вИТp} вИТ 1] вЙ• (pвИТ1)n^{вИТp}
  have hsplit : (((n - 1 : вДХ)):вДЭ) ^ (1 - p) = ((n:вДЭ)) ^ (1 - p) * (1 - u) ^ (1 - p) := by
    rw [hcast, Real.mul_rpow hn0.le (by linarith)]
  rw [hsplit]
  have hnp : ((n:вДЭ)) ^ (1 - p) = (n:вДЭ) * ((n:вДЭ)) ^ (-p) := by
    rw [show (1:вДЭ) - p = 1 + (-p) by ring, Real.rpow_add hn0, Real.rpow_one]
  have hkey : 1 + (p - 1) * u вЙ§ (1 - u) ^ (1 - p) := by
    have hpow0 : (0:вДЭ) < (1 - u) ^ (p - 1) := Real.rpow_pos_of_pos (by linarith) _
    have hinv : (1 - u) ^ (1 - p) = ((1 - u) ^ (p - 1))вБї¬є := by
      rw [вЖР Real.rpow_neg (by linarith : (0:вДЭ) вЙ§ 1 - u)]
      congr 1
      ring
    rw [hinv, le_inv_commвВА (by positivity) hpow0]
    calc (1 - u) ^ (p - 1) вЙ§ 1 / (1 + (p - 1) * u) := by
          rw [le_div_iffвВА (by nlinarith [mul_nonneg (show (0:вДЭ) вЙ§ p - 1 by linarith) hu0])]
          calc (1 - u) ^ (p - 1) * (1 + (p - 1) * u)
              = (1 + (p - 1) * u) * (1 - u) ^ (p - 1) := by ring
            _ вЙ§ 1 := hber
      _ = (1 + (p - 1) * u)вБї¬є := one_div _
  -- assemble: n^{1вИТp}(1вИТu)^{1вИТp} вИТ n^{1вИТp} вЙ• n^{1вИТp}¬Ј(pвИТ1)u = (pвИТ1)n^{вИТp}
  have hnu : (n:вДЭ) * u = 1 := by
    rw [hu]
    field_simp
  have hmul := mul_le_mul_of_nonneg_left hkey
    (Real.rpow_nonneg hn0.le (1 - p))
  have hfin : ((n:вДЭ)) ^ (1 - p) * ((p - 1) * u) = (p - 1) * ((n:вДЭ)) ^ (-p) := by
    rw [hnp]
    calc (n:вДЭ) * ((n:вДЭ)) ^ (-p) * ((p - 1) * u)
        = (p - 1) * ((n:вДЭ)) ^ (-p) * ((n:вДЭ) * u) := by ring
      _ = (p - 1) * ((n:вДЭ)) ^ (-p) := by rw [hnu, mul_one]
  nlinarith [hmul, hfin.le, hfin.ge]

/-- **The p-tail bound** (Siegel brick A2h-ii-ќ≤): for `p > 1`, `1 вЙ§ x`:
    `ќ£_{x<nвЙ§z} n^{вИТp} вЙ§ x^{1вИТp}/(pвИТ1)` вАФ sharp telescoping, uniform in `z`. -/
lemma rpow_tail_sum_le (p : вДЭ) (hp : 1 < p) (x : вДХ) (hx : 1 вЙ§ x) : вИА z : вДХ, x вЙ§ z вЖТ
    вИС n вИИ Icc (x + 1) z, ((n:вДЭ)) ^ (-p) вЙ§ ((x:вДЭ)) ^ (1 - p) / (p - 1) := by
  have hp0 : (0:вДЭ) < p - 1 := by linarith
  -- sharp form by induction: ќ£ вЙ§ (x^{1вИТp} вИТ z^{1вИТp})/(pвИТ1)
  have hsharp : вИА z : вДХ, x вЙ§ z вЖТ
      вИС n вИИ Icc (x + 1) z, ((n:вДЭ)) ^ (-p)
        вЙ§ (((x:вДЭ)) ^ (1 - p) - ((z:вДЭ)) ^ (1 - p)) / (p - 1) := by
    intro z
    induction z with
    | zero =>
      intro hx0
      omega
    | succ m ihm =>
      intro hxm
      rcases Nat.lt_or_ge m x with hlt | hge
      ¬Ј have hx' : x = m + 1 := by omega
        subst hx'
        simp
      ¬Ј have hstep : Icc (x + 1) (m + 1) = insert (m + 1) (Icc (x + 1) m) := by
          ext k
          simp only [Finset.mem_insert, Finset.mem_Icc]
          omega
        rw [hstep, Finset.sum_insert (by simp)]
        have hterm := rpow_tail_term_le p hp (m + 1) (by omega)
        have hm1 : (m + 1 : вДХ) - 1 = m := by omega
        rw [hm1] at hterm
        have hih := ihm hge
        have hd : ((m + 1 : вДХ):вДЭ) ^ (-p)
            вЙ§ (((m:вДЭ)) ^ (1 - p) - ((m + 1 : вДХ):вДЭ) ^ (1 - p)) / (p - 1) := by
          rw [le_div_iffвВА hp0]
          calc ((m + 1 : вДХ):вДЭ) ^ (-p) * (p - 1) = (p - 1) * ((m + 1 : вДХ):вДЭ) ^ (-p) := by ring
            _ вЙ§ ((m:вДЭ)) ^ (1 - p) - ((m + 1 : вДХ):вДЭ) ^ (1 - p) := hterm
        calc ((m + 1 : вДХ):вДЭ) ^ (-p) + вИС n вИИ Icc (x + 1) m, ((n:вДЭ)) ^ (-p)
            вЙ§ (((m:вДЭ)) ^ (1 - p) - ((m + 1 : вДХ):вДЭ) ^ (1 - p)) / (p - 1)
              + (((x:вДЭ)) ^ (1 - p) - ((m:вДЭ)) ^ (1 - p)) / (p - 1) := add_le_add hd hih
          _ = (((x:вДЭ)) ^ (1 - p) - ((m + 1 : вДХ):вДЭ) ^ (1 - p)) / (p - 1) := by ring
  intro z hz
  have hzp : (0:вДЭ) вЙ§ ((z:вДЭ)) ^ (1 - p) := Real.rpow_nonneg (Nat.cast_nonneg z) _
  calc вИС n вИИ Icc (x + 1) z, ((n:вДЭ)) ^ (-p)
      вЙ§ (((x:вДЭ)) ^ (1 - p) - ((z:вДЭ)) ^ (1 - p)) / (p - 1) := hsharp z hz
    _ вЙ§ ((x:вДЭ)) ^ (1 - p) / (p - 1) := by
        apply div_le_div_of_nonneg_right _ hp0.le
        linarith

/-- **The EulerвАУMaclaurin tail series is differentiable on `Re s > 9/10`**
    (Siegel brick A2h-ii-ќ≥): `Wtail_x(s) := ќ£'_n [nвЙ•x]¬Ј((sвИТ1)n^{вИТs} вИТ (n^{1вИТs}вИТ(n+1)^{1вИТs}))`
    is differentiable at every point of the half-plane вАФ the continuation vehicle of the
    ќґ-truncation. M-test on windows, head split off as a finite entire sum. -/
theorem wtail_differentiableAt (x : вДХ) (hx : 1 вЙ§ x) (sвВА : вДВ) (hsвВА : 9/10 < sвВА.re) :
    DifferentiableAt вДВ (fun s : вДВ => вИС' n : вДХ, (if n < x then 0 else
      ((s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) sвВА := by
  set ѕГвВА : вДЭ := (9/10 + sвВА.re) / 2 with hѕГвВА
  have hѕГвВА1 : 9/10 < ѕГвВА := by rw [hѕГвВА]; linarith
  have hѕГвВА2 : ѕГвВА < sвВА.re := by rw [hѕГвВА]; linarith
  set R : вДЭ := вАЦsвВАвАЦ + 1 with hR
  have hR0 : 0 < R := by
    rw [hR]
    have := norm_nonneg sвВА
    linarith
  set U : Set вДВ := {s : вДВ | ѕГвВА < s.re} вИ© Metric.ball 0 R with hU
  have hUopen : IsOpen U := by
    apply IsOpen.inter
    ¬Ј exact isOpen_lt continuous_const Complex.continuous_re
    ¬Ј exact Metric.isOpen_ball
  have hsвВАU : sвВА вИИ U := by
    rw [hU]
    constructor
    ¬Ј exact hѕГвВА2
    ¬Ј rw [Metric.mem_ball, dist_zero_right, hR]
      linarith
  set W : вДЭ := R + 2 with hW
  set NвВА : вДХ := max x (Nat.ceil R + 4) with hNвВА
  have hNвВАx : x вЙ§ NвВА := le_max_left _ _
  have hNвВА2 : 2 вЙ§ NвВА := le_trans (by omega) (le_max_right x (Nat.ceil R + 4))
  have hNвВАW : вИА n : вДХ, NвВА вЙ§ n вЖТ W вЙ§ (n:вДЭ) := by
    intro n hn
    have h1 : Nat.ceil R + 4 вЙ§ n := le_trans (le_max_right x _) hn
    have h2 : ((Nat.ceil R + 4 : вДХ):вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast h1
    have h3 : R вЙ§ (Nat.ceil R : вДЭ) := Nat.le_ceil R
    push_cast at h2
    rw [hW]
    linarith
  -- the pointwise kernel bound on U, for n вЙ• NвВА
  have hVbound : вИА n : вДХ, NвВА вЙ§ n вЖТ вИА w : вДВ, w вИИ U вЖТ
      вАЦ(w - 1) * ((n:вДВ)) ^ (-w)
        - (((n:вДВ)) ^ ((1:вДВ) - w) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - w))вАЦ
      вЙ§ 4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА) := by
    intro n hn w hwU
    obtain вЯ®hwre, hwballвЯ© := hwU
    have hwre' : ѕГвВА < w.re := hwre
    have hwnorm : вАЦwвАЦ < R := by
      rw [Metric.mem_ball, dist_zero_right] at hwball
      exact hwball
    have hn2 : 2 вЙ§ n := le_trans hNвВА2 hn
    have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by
      have : (1:вДХ) вЙ§ n := by omega
      exact_mod_cast this
    have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
    have hWb : вАЦ1 - wвАЦ вЙ§ W := by
      calc вАЦ1 - wвАЦ вЙ§ вАЦ(1:вДВ)вАЦ + вАЦwвАЦ := norm_sub_le _ _
        _ = 1 + вАЦwвАЦ := by rw [norm_one]
        _ вЙ§ W := by rw [hW]; linarith
    have hWn : W * (1 / (n:вДЭ)) вЙ§ 1 := by
      rw [mul_one_div, div_le_one hn0]
      exact hNвВАW n hn
    have hker := euler_maclaurin_kernel w n hn2 W hWb hWn
    have hexp : ((n:вДЭ)) ^ (1 - w.re) вЙ§ ((n:вДЭ)) ^ (1 - ѕГвВА) := by
      apply Real.rpow_le_rpow_of_exponent_le hn1r
      linarith
    calc вАЦ(w - 1) * ((n:вДВ)) ^ (-w)
          - (((n:вДВ)) ^ ((1:вДВ) - w) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - w))вАЦ
        вЙ§ 4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - w.re) := hker
      _ вЙ§ 4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА) := by
          apply mul_le_mul_of_nonneg_left hexp
          positivity
  -- the majorant is summable
  have husum : Summable (fun n : вДХ => if n < NвВА then (0:вДЭ) else
      4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА)) := by
    have hmajsum : Summable (fun n : вДХ => (4 * (W + 1) ^ 2) * (1 / ((n:вДЭ)) ^ (ѕГвВА + 1))) :=
      Summable.mul_left _ (Real.summable_one_div_nat_rpow.mpr (by linarith))
    apply Summable.of_nonneg_of_le _ _ hmajsum
    ¬Ј intro n
      rcases Nat.lt_or_ge n NвВА with h | h
      ¬Ј rw [if_pos h]
      ¬Ј rw [if_neg (not_lt.mpr h)]
        have hn0 : (0:вДЭ) < (n:вДЭ) := by
          have h1 : (1:вДХ) вЙ§ n := le_trans (le_trans hx hNвВАx) h
          have : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast h1
          linarith
        positivity
    ¬Ј intro n
      rcases Nat.lt_or_ge n NвВА with h | h
      ¬Ј rw [if_pos h]
        positivity
      ¬Ј rw [if_neg (not_lt.mpr h)]
        have hn0 : (0:вДЭ) < (n:вДЭ) := by
          have h1 : (1:вДХ) вЙ§ n := le_trans (le_trans hx hNвВАx) h
          have : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast h1
          linarith
        have hpow2 : (1/(n:вДЭ)) ^ 2 = ((n:вДЭ)) ^ (-((2:вДХ):вДЭ)) := by
          rw [div_pow, one_pow, one_div, вЖР Real.rpow_natCast (n:вДЭ) 2,
            вЖР Real.rpow_neg hn0.le]
        have hcollect : (1/(n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА) = 1 / ((n:вДЭ)) ^ (ѕГвВА + 1) := by
          rw [hpow2, вЖР Real.rpow_add hn0,
            show -((2:вДХ):вДЭ) + (1 - ѕГвВА) = -(ѕГвВА + 1) by push_cast; ring,
            Real.rpow_neg hn0.le, one_div]
        apply le_of_eq
        rw [вЖР hcollect]
        ring
  -- entire terms
  have hterm : вИА n : вДХ, 1 вЙ§ n вЖТ Differentiable вДВ (fun s : вДВ =>
      (s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))) := by
    intro n hn
    have hn0 : ((n:вДВ)) вЙ† 0 := by
      have : n вЙ† 0 := by omega
      exact_mod_cast this
    have hn10 : (((n + 1 : вДХ):вДВ)) вЙ† 0 := by exact_mod_cast Nat.succ_ne_zero n
    apply Differentiable.sub
    ¬Ј apply Differentiable.mul
      ¬Ј exact differentiable_id.sub (differentiable_const 1)
      ¬Ј exact (Differentiable.neg differentiable_id).const_cpow (Or.inl hn0)
    ¬Ј apply Differentiable.sub
      ¬Ј exact ((differentiable_const 1).sub differentiable_id).const_cpow (Or.inl hn0)
      ¬Ј exact ((differentiable_const 1).sub differentiable_id).const_cpow (Or.inl hn10)
  -- the tail: M-test on U
  have hgdiff : вИА n : вДХ, DifferentiableOn вДВ (fun s : вДВ => if n < NвВА then 0 else
      ((s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))) U := by
    intro n
    rcases Nat.lt_or_ge n NвВА with h | h
    ¬Ј simp only [if_pos h]
      exact differentiableOn_const 0
    ¬Ј simp only [if_neg (not_lt.mpr h)]
      exact (hterm n (le_trans (le_trans hx hNвВАx) h)).differentiableOn
  have hgbound : вИА (n : вДХ) (w : вДВ), w вИИ U вЖТ
      вАЦif n < NвВА then 0 else
        ((w - 1) * ((n:вДВ)) ^ (-w)
          - (((n:вДВ)) ^ ((1:вДВ) - w) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - w)))вАЦ
      вЙ§ (if n < NвВА then (0:вДЭ) else
          4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА)) := by
    intro n w hwU
    rcases Nat.lt_or_ge n NвВА with h | h
    ¬Ј rw [if_pos h, if_pos h, norm_zero]
    ¬Ј rw [if_neg (not_lt.mpr h), if_neg (not_lt.mpr h)]
      exact hVbound n h w hwU
  have hTail : DifferentiableOn вДВ (fun s : вДВ => вИС' n : вДХ, (if n < NвВА then 0 else
      ((s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) U :=
    Complex.differentiableOn_tsum_of_summable_norm husum hgdiff hUopen hgbound
  -- the head: a finite sum of entire functions
  have hHead : DifferentiableOn вДВ (fun s : вДВ => вИС n вИИ range NвВА, (if n < x then 0 else
      ((s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) U := by
    have hsum : DifferentiableOn вДВ (вИС n вИИ range NвВА, fun s : вДВ => (if n < x then 0 else
        ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) U := by
      apply DifferentiableOn.sum
      intro n _
      rcases Nat.lt_or_ge n x with h | h
      ¬Ј simp only [if_pos h]
        exact differentiableOn_const 0
      ¬Ј simp only [if_neg (not_lt.mpr h)]
        exact (hterm n (le_trans hx h)).differentiableOn
    have hfn : (fun s : вДВ => вИС n вИИ range NвВА, (if n < x then 0 else
        ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))))
        = (вИС n вИИ range NвВА, fun s : вДВ => (if n < x then 0 else
        ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) := by
      funext s
      rw [Finset.sum_apply]
    rw [hfn]
    exact hsum
  -- on U the full series splits as head + tail
  have hEqOn : вИА s вИИ U, (вИС' n : вДХ, (if n < x then 0 else
      ((s - 1) * ((n:вДВ)) ^ (-s)
        - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))))
      = (вИС n вИИ range NвВА, (if n < x then 0 else
          ((s - 1) * ((n:вДВ)) ^ (-s)
            - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))))
        + (вИС' n : вДХ, (if n < NвВА then 0 else
          ((s - 1) * ((n:вДВ)) ^ (-s)
            - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) := by
    intro s hsU
    set V : вДХ вЖТ вДВ := fun n => (s - 1) * ((n:вДВ)) ^ (-s)
      - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)) with hV
    have hgsum : Summable (fun n : вДХ => if n < NвВА then 0 else V n) := by
      apply Summable.of_norm_bounded (g := fun n : вДХ => if n < NвВА then (0:вДЭ) else
        4 * (W + 1) ^ 2 * (1 / (n:вДЭ)) ^ 2 * ((n:вДЭ)) ^ (1 - ѕГвВА)) husum
      intro n
      exact hgbound n s hsU
    have hhsum : Summable (fun n : вДХ => if n < NвВА then (if n < x then 0 else V n) else 0) :=
      summable_of_ne_finset_zero (s := range NвВА) (by
        intro n hn
        rw [Finset.mem_range] at hn
        rw [if_neg hn])
    have hsplit : вИА n : вДХ, (if n < x then 0 else V n)
        = (if n < NвВА then (if n < x then 0 else V n) else 0)
          + (if n < NвВА then 0 else V n) := by
      intro n
      rcases Nat.lt_or_ge n NвВА with h | h
      ¬Ј rw [if_pos h, if_pos h, add_zero]
      ¬Ј have hnx : ¬ђ n < x := not_lt.mpr (le_trans hNвВАx h)
        have hnN : ¬ђ n < NвВА := not_lt.mpr h
        rw [if_neg hnx, if_neg hnN, if_neg hnN, zero_add]
