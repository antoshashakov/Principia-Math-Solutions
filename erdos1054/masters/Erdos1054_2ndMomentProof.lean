    rw [Complex.ofReal_sum]
    apply Finset.sum_congr rfl
    intro n _
    by_cases h : a = ((n : ZMod q))
    ¬Ј rw [if_pos h, if_pos h]
    ¬Ј rw [if_neg h, if_neg h, Complex.ofReal_zero]
