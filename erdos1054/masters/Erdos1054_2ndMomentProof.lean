/- ================ ERDOS 1054 (pure second-moment), AXIOM-FREE ================ -/

section Section8Development
open Finset Filter Asymptotics
open scoped Topology ENNReal ArithmeticFunction

open scoped BigOperators

namespace Represented


/-! ## Section 3 -- Reflection identity (paper Lemma 3.1): F e d = e*d * g e (e*d). -/


/-- The divisor-prefix sum of `e*d` whose final divisor is `d`:
    the sum of all divisors of `e*d` that are `вЙ§ d`. -/
def F (e d : вДХ) : вДХ := вИС q вИИ (e * d).divisors.filter (¬Ј вЙ§ d), q

/-- `g e n = вИС_{r вИ£ n, r вЙ• e} 1/r` (as a real number). -/
noncomputable def g (e n : вДХ) : вДЭ := вИС r вИИ n.divisors.filter (e вЙ§ ¬Ј), (1 : вДЭ) / r

/-- Reflection identity: `F e d = (e*d) * g e (e*d)`. -/
theorem reflection (e d : вДХ) (he : 1 вЙ§ e) (hd : 1 вЙ§ d) :
    (F e d : вДЭ) = (e * d : вДЭ) * g e (e * d) := by
  set m := e * d with hm
  have hmpos : 0 < m := by rw [hm]; exact Nat.mul_pos he hd
  -- F as a sum over all divisors with an indicator
  have hF : (F e d : вДЭ) = вИС r вИИ m.divisors, (if r вЙ§ d then (r : вДЭ) else 0) := by
    rw [F, вЖР hm, Nat.cast_sum, Finset.sum_filter]
  -- (m) * g as a sum over all divisors with an indicator
  have hg : (m : вДЭ) * g e m = вИС r вИИ m.divisors, (if e вЙ§ r then (m : вДЭ) / r else 0) := by
    simp only [g, Finset.mul_sum, Finset.sum_filter]
    apply Finset.sum_congr rfl
    intro r _
    split_ifs with h
    ¬Ј rw [mul_one_div]
    ¬Ј rw [mul_zero]
  -- the reflection of the indicator sum
  have hrefl :
      (вИС r вИИ m.divisors, (if (m / r) вЙ§ d then ((m / r : вДХ) : вДЭ) else 0))
        = вИС r вИИ m.divisors, (if r вЙ§ d then (r : вДЭ) else 0) :=
    Nat.sum_div_divisors m (fun r => if r вЙ§ d then (r : вДЭ) else 0)
  -- termwise: reflected F-indicator = g-indicator
  have hterm : (вИС r вИИ m.divisors, (if (m / r) вЙ§ d then ((m / r : вДХ) : вДЭ) else 0))
        = вИС r вИИ m.divisors, (if e вЙ§ r then (m : вДЭ) / r else 0) := by
    apply Finset.sum_congr rfl
    intro r hr
    rw [Nat.mem_divisors] at hr
    obtain вЯ®hdvd, _вЯ© := hr
    have hrpos : 0 < r := Nat.pos_of_dvd_of_pos hdvd hmpos
    have hrne : (r : вДЭ) вЙ† 0 := by exact_mod_cast hrpos.ne'
    have hval : ((m / r : вДХ) : вДЭ) = (m : вДЭ) / r := Nat.cast_div hdvd hrne
    have hmul : m / r * r = m := Nat.div_mul_cancel hdvd
    have hcond : (m / r вЙ§ d) вЖФ (e вЙ§ r) := by
      constructor
      ¬Ј intro h
        have h1 : m / r * r вЙ§ d * r := by gcongr
        rw [hmul] at h1
        have h2 : e * d вЙ§ r * d := by rw [hm, mul_comm d r] at h1; exact h1
        exact le_of_mul_le_mul_right h2 (by omega)
      ¬Ј intro h
        have h1 : e * d вЙ§ r * d := by gcongr
        have h2 : m / r * r вЙ§ d * r := by rw [hmul, hm, mul_comm d r]; exact h1
        exact le_of_mul_le_mul_right h2 hrpos
    by_cases h : e вЙ§ r
    ¬Ј rw [if_pos (hcond.mpr h), if_pos h, hval]
    ¬Ј rw [if_neg (fun hc => h (hcond.mp hc)), if_neg h]
  rw [hF, вЖР hrefl, hterm, вЖР hg, hm]
  push_cast
  ring



/-! ## Section 1 -- Represented integers: R, f, prefix-sum divisors; N in R iff exists e d, N = F e d. -/


/-- Sum of the `k` smallest divisors of `m`. -/
noncomputable def prefixSumDivisors (m k : вДХ) : вДХ :=
  ((m.divisors.sort (¬Ј вЙ§ ¬Ј)).take k).sum

/-- `N` is a divisor-prefix sum of `m`: the sum of the first `k` divisors, `1 вЙ§ k вЙ§ ѕД(m)`. -/
def IsRep (N m : вДХ) : Prop :=
  вИГ k, 1 вЙ§ k вИІ k вЙ§ m.divisors.card вИІ N = prefixSumDivisors m k

/-- The set of represented integers. -/
def R : Set вДХ := {N | вИГ m, 1 вЙ§ m вИІ IsRep N m}

/-- `f N` = least `m` representing `N` (`0` if none; finiteness is recovered from `N вИИ R`). -/
noncomputable def f (N : вДХ) : вДХ := sInf {m | 1 вЙ§ m вИІ IsRep N m}

/-- Sum of divisors of `m` that are `вЙ§ d`. -/
def Fdiv (m d : вДХ) : вДХ := вИС q вИИ m.divisors.filter (¬Ј вЙ§ d), q

lemma F_eq_Fdiv {m d : вДХ} (hd : d вИ£ m) : F (m / d) d = Fdiv m d := by
  unfold F Fdiv
  rw [Nat.div_mul_cancel hd]

/-- The `toFinset` of the first `k` sorted divisors is exactly the divisors `вЙ§` the `k`-th one. -/
lemma take_sort_toFinset (m k : вДХ) (hidx : k - 1 < (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length) (hk1 : 1 вЙ§ k) :
    ((m.divisors.sort (¬Ј вЙ§ ¬Ј)).take k).toFinset
      = m.divisors.filter (¬Ј вЙ§ (m.divisors.sort (¬Ј вЙ§ ¬Ј))[k - 1]) := by
  classical
  have hslt : (m.divisors.sort (¬Ј вЙ§ ¬Ј)).SortedLT := Finset.sortedLT_sort m.divisors
  ext a
  simp only [List.mem_toFinset, Finset.mem_filter, List.mem_take_iff_getElem]
  constructor
  ¬Ј rintro вЯ®i, hi, rflвЯ©
    have hiL : i < (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length := lt_of_lt_of_le hi (min_le_right _ _)
    have hik : i вЙ§ k - 1 := by have := lt_of_lt_of_le hi (min_le_left _ _); omega
    refine вЯ®by rw [вЖР Finset.mem_sort (¬Ј вЙ§ ¬Ј)]; exact List.getElem_mem hiL, ?_вЯ©
    rw [hslt.getElem_le_getElem_iff]; exact hik
  ¬Ј rintro вЯ®haD, haleвЯ©
    have haL : a вИИ m.divisors.sort (¬Ј вЙ§ ¬Ј) := by rw [Finset.mem_sort]; exact haD
    obtain вЯ®i, hiL, rflвЯ© := List.getElem_of_mem haL
    have hik : i вЙ§ k - 1 := by rw [вЖР hslt.getElem_le_getElem_iff (hi := hiL) (hj := hidx)]; exact hale
    refine вЯ®i, lt_of_le_of_lt hik (by omega), ?_вЯ©
    simp

/-- For a nodup list, the list sum equals the `Finset` sum over its `toFinset`. -/
lemma list_sum_eq_toFinset_sum : вИА {l : List вДХ}, l.Nodup вЖТ l.sum = вИС q вИИ l.toFinset, q := by
  classical
  intro l
  induction l with
  | nil => intro _; simp
  | cons a t ih =>
    intro h
    rw [List.sum_cons, List.toFinset_cons,
      Finset.sum_insert (by simpa using (List.nodup_cons.1 h).1), ih (List.nodup_cons.1 h).2]

/-- **Sorted-prefix bridge (forward).** -/
lemma prefixSumDivisors_eq_Fdiv (m k : вДХ) (hk1 : 1 вЙ§ k) (hk2 : k вЙ§ m.divisors.card) :
    вИГ d, d вИИ m.divisors вИІ prefixSumDivisors m k = Fdiv m d := by
  classical
  have hlen : (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length = m.divisors.card := Finset.length_sort _
  have hidx : k - 1 < (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length := by rw [hlen]; omega
  refine вЯ®(m.divisors.sort (¬Ј вЙ§ ¬Ј))[k - 1], ?_, ?_вЯ©
  ¬Ј rw [вЖР Finset.mem_sort (¬Ј вЙ§ ¬Ј)]; exact List.getElem_mem hidx
  ¬Ј rw [prefixSumDivisors, Fdiv, вЖР take_sort_toFinset m k hidx hk1,
      list_sum_eq_toFinset_sum ((m.divisors.sort_nodup (¬Ј вЙ§ ¬Ј)).take)]

/-- **Sorted-prefix bridge (backward).** -/
lemma Fdiv_eq_prefixSumDivisors (m d : вДХ) (hd : d вИИ m.divisors) :
    вИГ k, 1 вЙ§ k вИІ k вЙ§ m.divisors.card вИІ Fdiv m d = prefixSumDivisors m k := by
  classical
  have hdL : d вИИ m.divisors.sort (¬Ј вЙ§ ¬Ј) := by rw [Finset.mem_sort]; exact hd
  obtain вЯ®i, hiL, hdiвЯ© := List.getElem_of_mem hdL
  have hlen : (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length = m.divisors.card := Finset.length_sort _
  refine вЯ®i + 1, by omega, by rw [вЖР hlen]; omega, ?_вЯ©
  have hidx : (i + 1) - 1 < (m.divisors.sort (¬Ј вЙ§ ¬Ј)).length := by omega
  have hdeq : (m.divisors.sort (¬Ј вЙ§ ¬Ј))[(i + 1) - 1] = d := by simp [hdi]
  rw [prefixSumDivisors, Fdiv, вЖР hdeq, вЖР take_sort_toFinset m (i + 1) hidx (by omega),
    list_sum_eq_toFinset_sum ((m.divisors.sort_nodup (¬Ј вЙ§ ¬Ј)).take)]

/-- A prefix representation of `N` by `m` is exactly `N = F (m/d) d` for a divisor `d вИ£ m`. -/
lemma isRep_iff_exists_divisor (N m : вДХ) (hm : 1 вЙ§ m) :
    IsRep N m вЖФ вИГ d, d вИИ m.divisors вИІ N = F (m / d) d := by
  constructor
  ¬Ј rintro вЯ®k, hk1, hk2, hNвЯ©
    obtain вЯ®d, hd, hpdвЯ© := prefixSumDivisors_eq_Fdiv m k hk1 hk2
    exact вЯ®d, hd, by rw [hN, hpd, F_eq_Fdiv (Nat.dvd_of_mem_divisors hd)]вЯ©
  ¬Ј rintro вЯ®d, hd, hNвЯ©
    obtain вЯ®k, hk1, hk2, hpdвЯ© := Fdiv_eq_prefixSumDivisors m d hd
    exact вЯ®k, hk1, hk2, by rw [hN, F_eq_Fdiv (Nat.dvd_of_mem_divisors hd), hpd]вЯ©

/-- The `f`-minimisation set, re-expressed via the `F e d` parametrisation. -/
lemma f_set_eq (N : вДХ) :
    {m | 1 вЙ§ m вИІ IsRep N m}
      = {m | вИГ e d, 1 вЙ§ e вИІ 1 вЙ§ d вИІ m = e * d вИІ N = F e d} := by
  ext m
  simp only [Set.mem_setOf_eq]
  constructor
  ¬Ј rintro вЯ®hm, hrepвЯ©
    rw [isRep_iff_exists_divisor N m hm] at hrep
    obtain вЯ®d, hd, hNвЯ© := hrep
    have hdvd := Nat.dvd_of_mem_divisors hd
    have hdpos := Nat.pos_of_mem_divisors hd
    refine вЯ®m / d, d, ?_, hdpos, (Nat.div_mul_cancel hdvd).symm, hNвЯ©
    exact Nat.div_pos (Nat.le_of_dvd (by omega) hdvd) hdpos
  ¬Ј rintro вЯ®e, d, he, hd, hme, hNвЯ©
    subst hme
    have hpos : 0 < e * d := Nat.mul_pos he hd
    have hed : (e * d) / d = e := by
      rw [Nat.mul_div_assoc e (dvd_refl d), Nat.div_self (by omega), mul_one]
    refine вЯ®hpos, ?_вЯ©
    rw [isRep_iff_exists_divisor N (e * d) hpos]
    refine вЯ®d, ?_, ?_вЯ©
    ¬Ј rw [Nat.mem_divisors]; exact вЯ®dvd_mul_left d e, hpos.ne'вЯ©
    ¬Ј rw [hed, hN]

/-- Membership in `R` is exactly the `F e d` parametrisation. -/
theorem mem_R_iff_exists_F (N : вДХ) :
    N вИИ R вЖФ вИГ e d, 1 вЙ§ e вИІ 1 вЙ§ d вИІ N = F e d := by
  constructor
  ¬Ј rintro вЯ®m, hm, hrepвЯ©
    have hmem : m вИИ {m | 1 вЙ§ m вИІ IsRep N m} := вЯ®hm, hrepвЯ©
    rw [f_set_eq] at hmem
    obtain вЯ®e, d, he, hd, _, hNвЯ© := hmem
    exact вЯ®e, d, he, hd, hNвЯ©
  ¬Ј rintro вЯ®e, d, he, hd, hNвЯ©
    have hpos : 0 < e * d := Nat.mul_pos he hd
    have hmem : (e * d) вИИ {m | 1 вЙ§ m вИІ IsRep N m} := by
      rw [f_set_eq]; exact вЯ®e, d, he, hd, rfl, hNвЯ©
    exact вЯ®e * d, hpos, hmem.2вЯ©

/-- For represented `N`, the minimiser `f N` is realised by a concrete pair `(e, d)`. -/
lemma f_mem_Fform (N : вДХ) (hN : N вИИ R) :
    вИГ e d, 1 вЙ§ e вИІ 1 вЙ§ d вИІ f N = e * d вИІ N = F e d := by
  have hne : {m | 1 вЙ§ m вИІ IsRep N m}.Nonempty := hN
  have hmem : f N вИИ {m | 1 вЙ§ m вИІ IsRep N m} := Nat.sInf_mem hne
  rw [f_set_eq] at hmem
  exact hmem



/-! ## Density infrastructure: countUpTo, CountIsLittleO (density zero), lowerDensity, union-bound combinator. -/


/-- The set of `n вЙ§ X` satisfying `P`. -/
def setUpTo (P : вДХ вЖТ Prop) (X : вДХ) : Set вДХ := {n | n вЙ§ X вИІ P n}

/-- The number of `n вЙ§ X` satisfying `P`. -/
noncomputable def countUpTo (P : вДХ вЖТ Prop) (X : вДХ) : вДХ := (setUpTo P X).ncard

/-- A predicate that holds only on a density-zero set: `#{n вЙ§ X : P n} = o(X)`. -/
def CountIsLittleO (P : вДХ вЖТ Prop) : Prop :=
  (fun X : вДХ => (countUpTo P X : вДЭ)) =o[atTop] (fun X : вДХ => (X : вДЭ))

/-- Lower asymptotic density `liminf_{XвЖТвИЮ} #{n вЙ§ X : P n} / X`. -/
noncomputable def lowerDensity (P : вДХ вЖТ Prop) : вДЭ :=
  liminf (fun X : вДХ => (countUpTo P X : вДЭ) / (X : вДЭ)) atTop

lemma setUpTo_finite (P : вДХ вЖТ Prop) (X : вДХ) : (setUpTo P X).Finite :=
  (Set.finite_Iic X).subset (fun _ hn => hn.1)

@[simp] lemma countUpTo_nonneg (P : вДХ вЖТ Prop) (X : вДХ) : 0 вЙ§ (countUpTo P X : вДЭ) := by
  positivity

/-- `#{n вЙ§ X : P n} вЙ§ X + 1`. -/
lemma countUpTo_le (P : вДХ вЖТ Prop) (X : вДХ) : countUpTo P X вЙ§ X + 1 := by
  unfold countUpTo setUpTo
  calc ({n | n вЙ§ X вИІ P n}).ncard
      вЙ§ (Set.Iic X).ncard :=
        Set.ncard_le_ncard (fun n hn => hn.1) (Set.finite_Iic X)
    _ = X + 1 := Set.ncard_Iic_nat X

/-- `#{n вЙ§ X : P n}/X вЙ§ 2`. -/
lemma countUpTo_div_le_two (P : вДХ вЖТ Prop) (X : вДХ) : (countUpTo P X : вДЭ) / X вЙ§ 2 := by
  rcases Nat.eq_zero_or_pos X with hX | hX
  ¬Ј subst hX; rw [Nat.cast_zero, div_zero]; norm_num
  ¬Ј have hXpos : (0 : вДЭ) < X := by exact_mod_cast hX
    have hle : (countUpTo P X : вДЭ) вЙ§ (X : вДЭ) + 1 := by exact_mod_cast countUpTo_le P X
    have h1 : (1 : вДЭ) вЙ§ X := by exact_mod_cast hX
    rw [div_le_iffвВА hXpos]
    nlinarith [hle, h1]

/-- Monotonicity of `countUpTo` in the predicate. -/
lemma countUpTo_mono {P Q : вДХ вЖТ Prop} (h : вИА n, P n вЖТ Q n) (X : вДХ) :
    countUpTo P X вЙ§ countUpTo Q X :=
  Set.ncard_le_ncard (fun n hn => вЯ®hn.1, h n hn.2вЯ©) (setUpTo_finite Q X)

/-- The "or" of two predicates is counted by at most the sum of counts. -/
lemma countUpTo_or_le (P Q : вДХ вЖТ Prop) (X : вДХ) :
    countUpTo (fun n => P n вИ® Q n) X вЙ§ countUpTo P X + countUpTo Q X := by
  unfold countUpTo setUpTo
  have heq : {n | n вЙ§ X вИІ (P n вИ® Q n)} = {n | n вЙ§ X вИІ P n} вИ™ {n | n вЙ§ X вИІ Q n} := by
    ext n; constructor
    ¬Ј rintro вЯ®hle, hP | hQвЯ©
      ¬Ј exact Or.inl вЯ®hle, hPвЯ©
      ¬Ј exact Or.inr вЯ®hle, hQвЯ©
    ¬Ј rintro (вЯ®hle, hPвЯ© | вЯ®hle, hQвЯ©)
      ¬Ј exact вЯ®hle, Or.inl hPвЯ©
      ¬Ј exact вЯ®hle, Or.inr hQвЯ©
  rw [heq]
  exact Set.ncard_union_le _ _

/-- Filtering by `G вИІ ¬ђB` removes at most the `B`-count from the `G`-count. -/
lemma countUpTo_and_not_ge (G B : вДХ вЖТ Prop) (X : вДХ) :
    countUpTo G X вЙ§ countUpTo (fun n => G n вИІ ¬ђ B n) X + countUpTo B X := by
  unfold countUpTo setUpTo
  have hsub : {n | n вЙ§ X вИІ G n} вКЖ
      {n | n вЙ§ X вИІ (G n вИІ ¬ђ B n)} вИ™ {n | n вЙ§ X вИІ B n} := by
    intro n hn
    by_cases hB : B n
    ¬Ј exact Or.inr вЯ®hn.1, hBвЯ©
    ¬Ј exact Or.inl вЯ®hn.1, hn.2, hBвЯ©
  calc ({n | n вЙ§ X вИІ G n}).ncard
      вЙ§ ({n | n вЙ§ X вИІ (G n вИІ ¬ђ B n)} вИ™ {n | n вЙ§ X вИІ B n}).ncard :=
        Set.ncard_le_ncard hsub ((setUpTo_finite _ X).union (setUpTo_finite _ X))
    _ вЙ§ _ := Set.ncard_union_le _ _

/-- A predicate implied by an `o(X)` predicate is itself `o(X)`. -/
lemma CountIsLittleO.mono {P Q : вДХ вЖТ Prop} (h : вИА n, P n вЖТ Q n) (hQ : CountIsLittleO Q) :
    CountIsLittleO P := by
  have hbound : (fun X : вДХ => (countUpTo P X : вДЭ)) =O[atTop]
      (fun X : вДХ => (countUpTo Q X : вДЭ)) := by
    refine Asymptotics.isBigO_of_le atTop (fun X => ?_)
    rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
    exact_mod_cast countUpTo_mono h X
  exact hbound.trans_isLittleO hQ

/-- Union bound for `o(X)` predicates. -/
lemma CountIsLittleO.or {P Q : вДХ вЖТ Prop}
    (hP : CountIsLittleO P) (hQ : CountIsLittleO Q) :
    CountIsLittleO (fun n => P n вИ® Q n) := by
  have hbound : (fun X : вДХ => (countUpTo (fun n => P n вИ® Q n) X : вДЭ)) =O[atTop]
      (fun X : вДХ => (countUpTo P X : вДЭ) + (countUpTo Q X : вДЭ)) := by
    refine Asymptotics.isBigO_of_le atTop (fun X => ?_)
    rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
    exact_mod_cast countUpTo_or_le P Q X
  exact hbound.trans_isLittleO (hP.add hQ)

/-- A `CountIsLittleO` predicate implies its count divided by `X` tends to `0`. -/
lemma CountIsLittleO.tendsto_div {B : вДХ вЖТ Prop} (hB : CountIsLittleO B) :
    Tendsto (fun X : вДХ => (countUpTo B X : вДЭ) / (X : вДЭ)) atTop (nhds 0) :=
  hB.tendsto_div_nhds_zero

/-- **Union-bound combinator.** Removing a density-zero set from a set of lower
density `вЙ• d` leaves a set of lower density `вЙ• d`. -/
lemma lowerDensity_and_not {G B : вДХ вЖТ Prop} {d : вДЭ}
    (hG : d вЙ§ lowerDensity G) (hB : CountIsLittleO B) :
    d вЙ§ lowerDensity (fun n => G n вИІ ¬ђ B n) := by
  have hbtend : Tendsto (fun X : вДХ => (countUpTo B X : вДЭ) / X) atTop (nhds 0) := hB.tendsto_div
  -- the `G`-density is bounded above (needed for `eventually_lt_of_lt_liminf`)
  have hcbdd : IsBoundedUnder (¬Ј вЙ• ¬Ј) atTop (fun X : вДХ => (countUpTo G X : вДЭ) / X) := by
    refine вЯ®0, ?_вЯ©
    rw [eventually_map]
    filter_upwards with X
    positivity
  rw [lowerDensity]
  apply le_of_forall_pos_le_add
  intro ќµ hќµ
  have hc : вИАбґ† X : вДХ in atTop, d - ќµ / 2 < (countUpTo G X : вДЭ) / X :=
    eventually_lt_of_lt_liminf (lt_of_lt_of_le (by linarith) hG) hcbdd
  have hbb : вИАбґ† X : вДХ in atTop, (countUpTo B X : вДЭ) / X < ќµ / 2 :=
    hbtend (Iio_mem_nhds (by linarith : (0 : вДЭ) < ќµ / 2))
  have hcnt : вИАбґ† X : вДХ in atTop,
      d - ќµ вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X := by
    filter_upwards [hc, hbb, eventually_gt_atTop 0] with X hcX hbX hX
    have hXpos : (0 : вДЭ) < X := by exact_mod_cast hX
    have hcount : (countUpTo G X : вДЭ)
        вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) + (countUpTo B X : вДЭ) := by
      exact_mod_cast countUpTo_and_not_ge G B X
    have hc_le : (countUpTo G X : вДЭ) / X
        вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X + (countUpTo B X : вДЭ) / X := by
      rw [вЖР add_div]
      exact (div_le_div_iff_of_pos_right hXpos).2 hcount
    linarith [hcX, hbX, hc_le]
  have hacobdd : IsCoboundedUnder (¬Ј вЙ• ¬Ј) atTop
      (fun X : вДХ => (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X) := by
    refine вЯ®2, fun z hz => ?_вЯ©
    rw [eventually_map] at hz
    obtain вЯ®X, hXвЯ© := hz.exists
    exact le_trans hX (countUpTo_div_le_two _ X)
  have hfin : d - ќµ вЙ§
      liminf (fun X : вДХ => (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X) atTop :=
    le_liminf_of_le hacobdd hcnt
  linarith [hfin]

/-- Removing a set of upper density `вЙ§ ќ≤` lowers the lower density by at most `ќ≤`. -/
lemma lowerDensity_and_not_le {G B : вДХ вЖТ Prop} {d ќ≤ : вДЭ}
    (hB : вИА X : вДХ, (countUpTo B X : вДЭ) вЙ§ ќ≤ * X) (hG : d вЙ§ lowerDensity G) :
    d - ќ≤ вЙ§ lowerDensity (fun n => G n вИІ ¬ђ B n) := by
  have hcbdd : IsBoundedUnder (¬Ј вЙ• ¬Ј) atTop (fun X : вДХ => (countUpTo G X : вДЭ) / X) := by
    refine вЯ®0, ?_вЯ©
    rw [eventually_map]
    filter_upwards with X
    positivity
  rw [lowerDensity]
  apply le_of_forall_pos_le_add
  intro ќµ hќµ
  have hc : вИАбґ† X : вДХ in atTop, d - ќµ < (countUpTo G X : вДЭ) / X :=
    eventually_lt_of_lt_liminf (lt_of_lt_of_le (by linarith) hG) hcbdd
  have hcnt : вИАбґ† X : вДХ in atTop,
      d - ќ≤ - ќµ вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X := by
    filter_upwards [hc, eventually_gt_atTop 0] with X hcX hX
    have hXpos : (0 : вДЭ) < X := by exact_mod_cast hX
    have hcount : (countUpTo G X : вДЭ)
        вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) + (countUpTo B X : вДЭ) := by
      exact_mod_cast countUpTo_and_not_ge G B X
    have hbќ≤ : (countUpTo B X : вДЭ) / X вЙ§ ќ≤ := by
      rw [div_le_iffвВА hXpos]; exact hB X
    have hc_le : (countUpTo G X : вДЭ) / X
        вЙ§ (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X + (countUpTo B X : вДЭ) / X := by
      rw [вЖР add_div]; exact (div_le_div_iff_of_pos_right hXpos).2 hcount
    linarith [hcX, hbќ≤, hc_le]
  have hacobdd : IsCoboundedUnder (¬Ј вЙ• ¬Ј) atTop
      (fun X : вДХ => (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X) := by
    refine вЯ®2, fun z hz => ?_вЯ©
    rw [eventually_map] at hz
    obtain вЯ®X, hXвЯ© := hz.exists
    exact le_trans hX (countUpTo_div_le_two _ X)
  have hfin : d - ќ≤ - ќµ вЙ§
      liminf (fun X : вДХ => (countUpTo (fun n => G n вИІ ¬ђ B n) X : вДЭ) / X) atTop :=
    le_liminf_of_le hacobdd hcnt
  linarith [hfin]

/-- Lower density is monotone in the predicate. -/
lemma lowerDensity_mono {G H : вДХ вЖТ Prop} (h : вИА n, G n вЖТ H n) :
    lowerDensity G вЙ§ lowerDensity H := by
  have hHcobdd : IsCoboundedUnder (¬Ј вЙ• ¬Ј) atTop (fun X : вДХ => (countUpTo H X : вДЭ) / X) := by
    refine вЯ®2, fun z hz => ?_вЯ©
    rw [eventually_map] at hz
    obtain вЯ®X, hXвЯ© := hz.exists
    exact le_trans hX (countUpTo_div_le_two _ X)
  have hGbdd : IsBoundedUnder (¬Ј вЙ• ¬Ј) atTop (fun X : вДХ => (countUpTo G X : вДЭ) / X) := by
    refine вЯ®0, ?_вЯ©
    rw [eventually_map]
    filter_upwards with X
    positivity
  apply liminf_le_liminf _ hGbdd hHcobdd
  filter_upwards [eventually_gt_atTop 0] with X hX
  have hXpos : (0 : вДЭ) < X := by exact_mod_cast hX
  exact (div_le_div_iff_of_pos_right hXpos).2 (by exact_mod_cast countUpTo_mono h X)



/-! ## The two ASSUMPTIONS (A2 Mertens, A3 Goldbach) -- see the Assumptions block at the top of this file. -/


/-- The two deep analytic inputs not available in Mathlib. -/
structure DeepInputs : Prop where
  /-- (A2) Mertens' lower bound for the product over primes `вЙ§ y`. -/
  mertens_lb : вИГ cвВА : вДЭ, 0 < cвВА вИІ вИА y : вДХ, 2 вЙ§ y вЖТ
      cвВА / Real.log (2 * y) вЙ§
        вИП p вИИ (Finset.range (y + 1)).filter Nat.Prime, (1 - (1 : вДЭ) / p)
  /-- (A3) Almost every even integer is a sum of two primes. -/
  goldbach_ae :
      CountIsLittleO
        (fun n => Even n вИІ ¬ђ вИГ p q : вДХ, p.Prime вИІ q.Prime вИІ n = p + q)



/-! ## Section 4.2 + (A1) -- sigma-avoidance: (A1) sum over primes p == -1 (mod q) of 1/p diverges (from Mathlib); then the set of n with q not dividing sigma(n) has density 0. -/


/-- `Bq q n` holds when `q вИ§ ѕГ(n)`. -/
def Bq (q n : вДХ) : Prop := ¬ђ (q вИ£ ArithmeticFunction.sigma 1 n)

open ArithmeticFunction ArithmeticFunction.vonMangoldt LSeries in
/-- **Foundation for (A1)**: the prime-restricted residue-class logвАУDirichlet series
`Q(x) = вИС_{pвЙ°-1} log p / pЋ£` exceeds the L-function pole `(1/ѕЖ(q))/(x-1) вИТ C` on `(1,2]`.
Obtained from Mathlib's `LSeries_residueClass_lower_bound` after discarding the (bounded)
prime-power `k вЙ• 2` contribution. -/
lemma Q_ge_pole (q : вДХ) [NeZero q] (ha : IsUnit (-1 : ZMod q)) :
    вИГ C : вДЭ, вИА x : вДЭ, x вИИ Set.Ioc 1 2 вЖТ
      (q.totient : вДЭ)вБї¬є / (x - 1) - C вЙ§
        вИС' n : вДХ, (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ x := by
  obtain вЯ®C', hC'вЯ© := LSeries_residueClass_lower_bound (a := (-1 : ZMod q)) ha
  refine вЯ®C' + вИС' n : вДХ, (if n.Prime then 0 else residueClass (-1 : ZMod q) n) / (n : вДЭ),
    fun x hx => ?_вЯ©
  have hx1 : (1 : вДЭ) < x := hx.1
  have hrcnn : вИА n : вДХ, 0 вЙ§ residueClass (-1 : ZMod q) n := residueClass_nonneg _
  have hxnn : вИА n : вДХ, (0 : вДЭ) вЙ§ (n : вДЭ) ^ x := fun n => Real.rpow_nonneg (by positivity) x
  have hD : Summable (fun n : вДХ => residueClass (-1 : ZMod q) n / (n : вДЭ) ^ x) :=
    summable_real_of_abscissaOfAbsConv_lt
      ((abscissaOfAbsConv_residueClass_le_one _).trans_lt (by exact_mod_cast hx1))
  have hQ : Summable (fun n : вДХ =>
      (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ x) := by
    refine Summable.of_nonneg_of_le (fun n => ?_) (fun n => ?_) hD
    ¬Ј split_ifs with h
      ¬Ј exact div_nonneg (hrcnn n) (hxnn n)
      ¬Ј simp
    ¬Ј gcongr
      split_ifs with h
      ¬Ј exact le_rfl
      ¬Ј exact hrcnn n
  have hNP : Summable (fun n : вДХ =>
      (if n.Prime then 0 else residueClass (-1 : ZMod q) n) / (n : вДЭ) ^ x) := by
    refine Summable.of_nonneg_of_le (fun n => ?_) (fun n => ?_) hD
    ¬Ј split_ifs with h
      ¬Ј simp
      ¬Ј exact div_nonneg (hrcnn n) (hxnn n)
    ¬Ј gcongr
      split_ifs with h
      ¬Ј exact hrcnn n
      ¬Ј exact le_rfl
  have hsplit : (вИС' n : вДХ, residueClass (-1 : ZMod q) n / (n : вДЭ) ^ x)
      = (вИС' n : вДХ, (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ x)
        + вИС' n : вДХ, (if n.Prime then 0 else residueClass (-1 : ZMod q) n) / (n : вДЭ) ^ x := by
    rw [вЖР Summable.tsum_add hQ hNP]
    exact tsum_congr (fun n => by split_ifs <;> ring)
  have hNPle : (вИС' n : вДХ, (if n.Prime then 0 else residueClass (-1 : ZMod q) n) / (n : вДЭ) ^ x)
      вЙ§ вИС' n : вДХ, (if n.Prime then 0 else residueClass (-1 : ZMod q) n) / (n : вДЭ) := by
    refine Summable.tsum_le_tsum (fun n => ?_) hNP (summable_residueClass_non_primes_div _)
    rcases n.eq_zero_or_pos with rfl | hn
    ¬Ј simp
    ¬Ј have hnum : (0 : вДЭ) вЙ§ (if n.Prime then 0 else residueClass (-1 : ZMod q) n) := by
        split_ifs with h
        ¬Ј exact le_rfl
        ¬Ј exact hrcnn n
      have hn1 : (1 : вДЭ) вЙ§ (n : вДЭ) := by exact_mod_cast hn
      have hnx : (n : вДЭ) вЙ§ (n : вДЭ) ^ x := by
        calc (n : вДЭ) = (n : вДЭ) ^ (1 : вДЭ) := (Real.rpow_one _).symm
          _ вЙ§ (n : вДЭ) ^ x := Real.rpow_le_rpow_of_exponent_le hn1 hx1.le
      exact div_le_div_of_nonneg_left hnum (by exact_mod_cast hn) hnx
  have hpoleD := hC' hx
  rw [hsplit] at hpoleD
  linarith [hpoleD, hNPle]

/-- `P(x) = вИС_{p вЙ° -1 (q)} 1/pЋ£`, the prime-restricted residue-class zeta-type series. -/
noncomputable def Pfun (q : вДХ) (x : вДЭ) : вДЭ :=
  вИС' n : вДХ, (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x

/-- Termwise integral: `вИЂвВУ¬≤ nвБїбµЧ dt = (nвБїЋ£ вИТ nвБї¬≤)/log n` for `n вЙ• 2`. -/
lemma rpow_neg_intervalIntegral (n : вДХ) (hn : 2 вЙ§ n) (x : вДЭ) :
    вИЂ t in x..2, (n : вДЭ) ^ (-t)
      = ((n : вДЭ) ^ (-x) - (n : вДЭ) ^ (-(2 : вДЭ))) / Real.log n := by
  have hn0 : (0 : вДЭ) < (n : вДЭ) := by positivity
  have hlog : Real.log (n : вДЭ) вЙ† 0 := ne_of_gt (Real.log_pos (by exact_mod_cast hn))
  have hderiv : вИА t вИИ Set.uIcc x (2 : вДЭ),
      HasDerivAt (fun s => (-(Real.log n)вБї¬є) * (n : вДЭ) ^ (-s)) ((n : вДЭ) ^ (-t)) t := by
    intro t _
    have hb : HasDerivAt (fun s : вДЭ => (n : вДЭ) ^ (-s)) (-(Real.log n) * (n : вДЭ) ^ (-t)) t := by
      simpa [mul_comm] using HasDerivAt.rpow (hasDerivAt_const t (n : вДЭ)) (hasDerivAt_id t).neg hn0
    have hd : (-(Real.log n)вБї¬є) * (-(Real.log n) * (n : вДЭ) ^ (-t)) = (n : вДЭ) ^ (-t) := by
      rw [вЖР mul_assoc, neg_mul_neg, inv_mul_cancelвВА hlog, one_mul]
    exact hd вЦЄ hb.const_mul (-(Real.log n)вБї¬є)
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv
    (Continuous.intervalIntegrable
      (Continuous.rpow continuous_const continuous_id.neg (fun _ => Or.inl hn0.ne')) x 2)]
  field_simp
  ring

open ArithmeticFunction ArithmeticFunction.vonMangoldt MeasureTheory in
/-- Per-term integral: `вИЂвВУ¬≤ qвВЩ = (Pfun-summand x) вИТ (Pfun-summand 2)` (the `ќЫ(p)=log p` weight
cancels the `1/log n` from the exponential integral). -/
lemma Q_term_integral (q : вДХ) [NeZero q] {x : вДЭ} (hx2 : x вЙ§ 2) (n : вДХ) :
    (вИЂ t in Set.Ioc x 2, (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t)
      = (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
        - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ) := by
  by_cases hp : n.Prime
  ¬Ј by_cases hr : (n : ZMod q) = -1
    ¬Ј have hn2 : 2 вЙ§ n := hp.two_le
      have hn0 : (0 : вДЭ) < (n : вДЭ) := by positivity
      have hlog : Real.log (n : вДЭ) вЙ† 0 := ne_of_gt (Real.log_pos (by exact_mod_cast hn2))
      have hrc : residueClass (-1 : ZMod q) n = Real.log n := by
        rw [residueClass, Set.indicator_of_mem (show n вИИ {m : вДХ | (m : ZMod q) = -1} from hr),
          vonMangoldt_apply_prime hp]
      rw [if_pos hp, if_pos вЯ®hp, hrвЯ©, hrc, вЖР intervalIntegral.integral_of_le hx2]
      have hcalc : (вИЂ t in x..2, Real.log (n : вДЭ) / (n : вДЭ) ^ t)
          = Real.log (n : вДЭ) * вИЂ t in x..2, (n : вДЭ) ^ (-t) := by
        rw [вЖР intervalIntegral.integral_const_mul]
        refine intervalIntegral.integral_congr (fun t _ => ?_)
        rw [Real.rpow_neg hn0.le, div_eq_mul_inv]
      rw [hcalc, rpow_neg_intervalIntegral n hn2, Real.rpow_neg hn0.le, Real.rpow_neg hn0.le]
      field_simp
    ¬Ј have hrc : residueClass (-1 : ZMod q) n = 0 := by
        rw [residueClass, Set.indicator_of_notMem (show n вИЙ {m : вДХ | (m : ZMod q) = -1} from hr)]
      simp [hp, hr, hrc]
  ¬Ј simp [hp]

/-- `Pfun q x` is summable for `x > 1` (sub-series of the zeta `p`-series). -/
lemma Pfun_summable (q : вДХ) {x : вДЭ} (hx : 1 < x) :
    Summable (fun n : вДХ => (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x) := by
  refine Summable.of_nonneg_of_le (fun n => by split_ifs <;> positivity) (fun n => ?_)
    (Real.summable_one_div_nat_rpow.mpr hx)
  split_ifs with h
  ¬Ј exact le_rfl
  ¬Ј rw [zero_div]; positivity

open ArithmeticFunction ArithmeticFunction.vonMangoldt MeasureTheory in
/-- **Integral identity**: `вИЂвВУ¬≤ Q = Pfun x вИТ Pfun 2` (Tonelli via `integral_tsum`). -/
lemma integral_Q_eq (q : вДХ) [NeZero q] {x : вДЭ} (hx1 : 1 < x) (hx2 : x вЙ§ 2) :
    (вИЂ t in Set.Ioc x 2,
        (вИС' n : вДХ, (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t))
      = Pfun q x - Pfun q 2 := by
  have hcont : вИА n : вДХ, Continuous
      (fun t : вДЭ => (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t) := by
    intro n
    rcases eq_or_ne n 0 with rfl | hne
    ¬Ј simpa [Nat.not_prime_zero] using continuous_const
    ¬Ј exact continuous_const.div
        (Continuous.rpow continuous_const continuous_id (fun _ => Or.inl (by exact_mod_cast hne)))
        (fun t => (Real.rpow_pos_of_pos (by positivity) t).ne')
  have hnn : вИА (n : вДХ) (t : вДЭ),
      0 вЙ§ (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t := by
    intro n t; split_ifs with h
    ¬Ј exact div_nonneg (residueClass_nonneg _ _) (by positivity)
    ¬Ј simp
  have hint : вИА n : вДХ, IntegrableOn
      (fun t : вДЭ => (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t)
      (Set.Ioc x 2) := fun n => (hcont n).integrableOn_Ioc
  have hpnn : вИА n : вДХ, 0 вЙ§ (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
      - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ) := by
    intro n; rw [вЖР Q_term_integral q hx2 n]; exact setIntegral_nonneg measurableSet_Ioc (fun t _ => hnn n t)
  have hsummdiff : Summable (fun n : вДХ =>
      (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
        - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ)) :=
    (Pfun_summable q hx1).sub (Pfun_summable q (by norm_num))
  have hfin : (вИС' n : вДХ, вИЂвБї t in Set.Ioc x 2,
      вАЦ(if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ tвАЦвВК) вЙ† вК§ := by
    have hterm : вИА n : вДХ, (вИЂвБї t in Set.Ioc x 2,
        вАЦ(if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ tвАЦвВК)
        = ENNReal.ofReal ((if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
          - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ)) := by
      intro n
      rw [вЖР Q_term_integral q hx2 n, lintegral_coe_eq_integral _ (hint n).norm]
      congr 1
      refine setIntegral_congr_fun measurableSet_Ioc (fun t _ => ?_)
      rw [coe_nnnorm, Real.norm_of_nonneg (hnn n t)]
    rw [tsum_congr hterm, вЖР ENNReal.ofReal_tsum_of_nonneg hpnn hsummdiff]
    exact ENNReal.ofReal_ne_top
  rw [integral_tsum (fun n => (hcont n).aestronglyMeasurable) hfin, tsum_congr (Q_term_integral q hx2)]
  exact Summable.tsum_sub (Pfun_summable q hx1) (Pfun_summable q (by norm_num))

open ArithmeticFunction ArithmeticFunction.vonMangoldt MeasureTheory LSeries in
/-- `Q` is integrable on `(x,2]` for `x > 1` (the difference series is summable). -/
lemma Q_integrableOn (q : вДХ) [NeZero q] {x : вДЭ} (hx1 : 1 < x) (hx2 : x вЙ§ 2) :
    IntegrableOn
      (fun t => вИС' n : вДХ, (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t)
      (Set.Ioc x 2) := by
  have hcont : вИА n : вДХ, Continuous
      (fun t : вДЭ => (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t) := by
    intro n
    rcases eq_or_ne n 0 with rfl | hne
    ¬Ј simpa [Nat.not_prime_zero] using continuous_const
    ¬Ј exact continuous_const.div
        (Continuous.rpow continuous_const continuous_id (fun _ => Or.inl (by exact_mod_cast hne)))
        (fun t => (Real.rpow_pos_of_pos (by positivity) t).ne')
  have hnn : вИА (n : вДХ) (t : вДЭ),
      0 вЙ§ (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t := by
    intro n t; split_ifs with h
    ¬Ј exact div_nonneg (residueClass_nonneg _ _) (by positivity)
    ¬Ј simp
  have hint : вИА n : вДХ, IntegrableOn
      (fun t : вДЭ => (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ t)
      (Set.Ioc x 2) := fun n => (hcont n).integrableOn_Ioc
  have hpnn : вИА n : вДХ, 0 вЙ§ (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
      - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ) := by
    intro n; rw [вЖР Q_term_integral q hx2 n]
    exact setIntegral_nonneg measurableSet_Ioc (fun t _ => hnn n t)
  have hsummdiff : Summable (fun n : вДХ =>
      (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
        - (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (2 : вДЭ)) :=
    (Pfun_summable q hx1).sub (Pfun_summable q (by norm_num))
  have hu : Summable (fun n : вДХ =>
      (if n.Prime then residueClass (-1 : ZMod q) n else 0) / (n : вДЭ) ^ x) := by
    refine Summable.of_nonneg_of_le (fun n => hnn n x) (fun n => ?_)
      (summable_real_of_abscissaOfAbsConv_lt
        ((abscissaOfAbsConv_residueClass_le_one (-1 : ZMod q)).trans_lt (by exact_mod_cast hx1)))
    gcongr
    split_ifs with h
    ¬Ј exact le_rfl
    ¬Ј exact residueClass_nonneg _ _
  refine (ContinuousOn.integrableOn_Icc ?_).mono_set Set.Ioc_subset_Icc_self
  refine continuousOn_tsum (fun n => (hcont n).continuousOn) hu (fun n t ht => ?_)
  rw [Real.norm_of_nonneg (hnn n t)]
  rcases eq_or_ne n 0 with rfl | hne
  ¬Ј simp [Nat.not_prime_zero]
  ¬Ј rw [Set.mem_Icc] at ht
    refine div_le_div_of_nonneg_left ?_ (Real.rpow_pos_of_pos (by positivity) x)
      (Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast Nat.one_le_iff_ne_zero.mpr hne) ht.1)
    split_ifs with h
    ¬Ј exact residueClass_nonneg _ _
    ¬Ј exact le_rfl

open ArithmeticFunction ArithmeticFunction.vonMangoldt MeasureTheory in
/-- `Pfun q x вЖТ вИЮ` as `x вЖТ 1вБЇ`: it exceeds any bound on `(1,2]`. -/
lemma P_unbounded (q : вДХ) [NeZero q] (ha : IsUnit (-1 : ZMod q)) (B : вДЭ) :
    вИГ x : вДЭ, x вИИ Set.Ioc 1 2 вИІ B < Pfun q x := by
  obtain вЯ®C, hCвЯ© := Q_ge_pole q ha
  have hѕЖ : (0 : вДЭ) < (q.totient : вДЭ)вБї¬є :=
    inv_pos.mpr (by exact_mod_cast Nat.totient_pos.mpr (Nat.pos_of_ne_zero (NeZero.ne q)))
  have hlb : вИА x : вДЭ, x вИИ Set.Ioc 1 2 вЖТ
      Pfun q 2 + ((q.totient : вДЭ)вБї¬є * (-(Real.log (x - 1))) - C * (2 - x)) вЙ§ Pfun q x := by
    intro x hx
    obtain вЯ®hx1, hx2вЯ© := hx
    have hpoleII : IntervalIntegrable (fun t => (q.totient : вДЭ)вБї¬є / (t - 1) - C) volume x 2 := by
      apply ContinuousOn.intervalIntegrable
      refine (ContinuousOn.div continuousOn_const (continuousOn_id.sub continuousOn_const)
        (fun t ht => ?_)).sub continuousOn_const
      rw [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
      simp only [id_eq]; have : (1 : вДЭ) < t := lt_of_lt_of_le hx1 ht.1; linarith
    have hpoleint : (вИЂ t in Set.Ioc x 2, ((q.totient : вДЭ)вБї¬є / (t - 1) - C))
        = (q.totient : вДЭ)вБї¬є * (-(Real.log (x - 1))) - C * (2 - x) := by
      rw [вЖР intervalIntegral.integral_of_le hx2,
        intervalIntegral.integral_eq_sub_of_hasDerivAt
          (f := (fun t => (q.totient : вДЭ)вБї¬є * Real.log (t - 1)) - (fun t => C * t))
          (fun t ht => ?_) hpoleII]
      ¬Ј simp only [Pi.sub_apply]
        rw [show (2 : вДЭ) - 1 = 1 by norm_num, Real.log_one]; ring
      ¬Ј rw [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
        have h1 : (t : вДЭ) - 1 вЙ† 0 := by
          have : (1 : вДЭ) < t := lt_of_lt_of_le hx1 ht.1; linarith
        have hd := (((Real.hasDerivAt_log h1).comp t ((hasDerivAt_id t).sub_const 1)).const_mul
          ((q.totient : вДЭ)вБї¬є)).sub ((hasDerivAt_id t).const_mul C)
        simpa [div_eq_mul_inv] using hd
    have hmono := setIntegral_mono_on
      ((intervalIntegrable_iff_integrableOn_Ioc_of_le hx2).mp hpoleII)
      (Q_integrableOn q hx1 hx2) measurableSet_Ioc
      (fun t ht => hC t вЯ®lt_trans hx1 ht.1, ht.2вЯ©)
    rw [hpoleint, integral_Q_eq q hx1 hx2] at hmono
    linarith [hmono]
  -- pick `x = 1 + ќµ` with `ќµ` small enough; abstract `|C|` as `Cb` so `linarith` sees only atoms
  obtain вЯ®Cb, -, hCbвЯ© : вИГ Cb : вДЭ, 0 вЙ§ Cb вИІ вИА ќі : вДЭ, 0 вЙ§ ќі вЖТ ќі вЙ§ 1 вЖТ C * (1 - ќі) вЙ§ Cb :=
    вЯ®|C|, abs_nonneg C, fun ќі hќі0 hќі1 => by
      calc C * (1 - ќі) вЙ§ |C * (1 - ќі)| := le_abs_self _
        _ = |C| * (1 - ќі) := by rw [abs_mul, abs_of_nonneg (sub_nonneg.mpr hќі1)]
        _ вЙ§ |C| := mul_le_of_le_one_right (abs_nonneg C) (sub_le_self 1 hќі0)вЯ©
  set ќµ : вДЭ := min 1 (Real.exp (-((B - Pfun q 2 + Cb + 1) / (q.totient : вДЭ)вБї¬є))) with hќµ
  have hќµ0 : 0 < ќµ := lt_min one_pos (Real.exp_pos _)
  have hќµ1 : ќµ вЙ§ 1 := min_le_left _ _
  have hxmem : 1 + ќµ вИИ Set.Ioc 1 2 := вЯ®by linarith, by linarithвЯ©
  refine вЯ®1 + ќµ, hxmem, ?_вЯ©
  have hlbx := hlb (1 + ќµ) hxmem
  rw [show (1 + ќµ) - 1 = ќµ by ring, show (2 : вДЭ) - (1 + ќµ) = 1 - ќµ by ring] at hlbx
  have hloge : (B - Pfun q 2 + Cb + 1) / (q.totient : вДЭ)вБї¬є вЙ§ -(Real.log ќµ) := by
    have hle : ќµ вЙ§ Real.exp (-((B - Pfun q 2 + Cb + 1) / (q.totient : вДЭ)вБї¬є)) := min_le_right _ _
    have := Real.log_le_log hќµ0 hle
    rw [Real.log_exp] at this; linarith
  have hѕЖloge : B - Pfun q 2 + Cb + 1 вЙ§ (q.totient : вДЭ)вБї¬є * (-(Real.log ќµ)) := by
    rw [mul_comm]; exact (div_le_iffвВА hѕЖ).mp hloge
  linarith [hlbx, hѕЖloge, hCb ќµ hќµ0.le hќµ1]

/-- **(A1)** Divergence of `вИС_{p вЙ° -1 (q)} 1/p`. -/
theorem primes_neg_one_div_diverges (q : вДХ) (hq : q.Prime) (hq2 : 2 вЙ§ q) :
    ¬ђ Summable (fun p : {p : вДХ // p.Prime вИІ (p : ZMod q) = -1} => (1 : вДЭ) / (p : вДХ)) := by
  haveI : NeZero q := вЯ®by omegaвЯ©
  intro hsum
  have hind : Summable ((Set.indicator {n : вДХ | n.Prime вИІ (n : ZMod q) = -1}
      (fun n : вДХ => (1 : вДЭ) / (n : вДЭ)))) :=
    (summable_subtype_iff_indicator (s := {n : вДХ | n.Prime вИІ (n : ZMod q) = -1})
      (f := fun n : вДХ => (1 : вДЭ) / (n : вДЭ))).mp hsum
  have hP1eq : (fun n : вДХ => (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (1 : вДЭ))
      = Set.indicator {n : вДХ | n.Prime вИІ (n : ZMod q) = -1} (fun n : вДХ => (1 : вДЭ) / (n : вДЭ)) := by
    funext n
    rw [Real.rpow_one, Set.indicator_apply]
    by_cases h : n.Prime вИІ (n : ZMod q) = -1 <;> simp [Set.mem_setOf_eq, h]
  have hP1summ : Summable (fun n : вДХ =>
      (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (1 : вДЭ)) := by
    rw [hP1eq]; exact hind
  have hterm : вИА (n : вДХ) (x : вДЭ), 1 вЙ§ x вЖТ
      (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x
        вЙ§ (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ (1 : вДЭ) := by
    intro n x hx1
    rcases n.eq_zero_or_pos with rfl | hn
    ¬Ј simp [Nat.not_prime_zero]
    ¬Ј by_cases h : n.Prime вИІ (n : ZMod q) = -1
      ¬Ј simp only [h]
        exact one_div_le_one_div_of_le (Real.rpow_pos_of_pos (by exact_mod_cast hn) 1)
          (Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast hn) hx1)
      ¬Ј simp [h]
  obtain вЯ®x, hx, hxBвЯ© := P_unbounded q isUnit_one.neg (Pfun q 1)
  have hxsumm : Summable (fun n : вДХ =>
      (if n.Prime вИІ (n : ZMod q) = -1 then (1 : вДЭ) else 0) / (n : вДЭ) ^ x) :=
    Summable.of_nonneg_of_le (fun n => by split_ifs <;> positivity)
      (fun n => hterm n x hx.1.le) hP1summ
  have hmono : Pfun q x вЙ§ Pfun q 1 :=
    Summable.tsum_le_tsum (fun n => hterm n x hx.1.le) hxsumm hP1summ
  exact absurd hxB (not_lt.mpr hmono)

/-- **Forced ѕГ-factor** (paper Lemma 4.2 key step): if `p вЙ° -1 (mod q)` is a prime exactly
dividing `n` (i.e. `p вИ£ n` but `p¬≤ вИ§ n`), then `q вИ£ ѕГ(n)`. -/
lemma forced_sigma_factor (q p n : вДХ) (hq2 : 2 вЙ§ q) (hp : p.Prime) (hpq : (p : ZMod q) = -1)
    (hpn : p вИ£ n) (hp2n : ¬ђ p ^ 2 вИ£ n) : q вИ£ ArithmeticFunction.sigma 1 n := by
  haveI : NeZero q := вЯ®by omegaвЯ©
  obtain вЯ®m, rflвЯ© := hpn
  have hpm : ¬ђ p вИ£ m := fun h => by
    obtain вЯ®k, rflвЯ© := h; exact hp2n вЯ®k, by ringвЯ©
  have hcop : Nat.Coprime p m := (Nat.Prime.coprime_iff_not_dvd hp).mpr hpm
  have hqp1 : q вИ£ (p + 1) := by
    rw [вЖР CharP.cast_eq_zero_iff (ZMod q) q]; push_cast; rw [hpq]; ring
  have hsp : ArithmeticFunction.sigma 1 p = p + 1 := by
    rw [ArithmeticFunction.sigma_one_apply, Nat.Prime.divisors hp, Finset.sum_pair hp.one_lt.ne]
    omega
  rw [ArithmeticFunction.isMultiplicative_sigma.map_mul_of_coprime hcop, hsp]
  exact Dvd.dvd.mul_right hqp1 _

/-- Divergence of `вИС_{p вЙ° -1 (q)} (1/p вИТ 1/p¬≤)` (drives the sieve product to `0`):
from A1 (`вИС 1/p = вИЮ`) and `вИС 1/p¬≤ < вИЮ`. -/
lemma recip_sub_sq_diverges (q : вДХ) (hq : q.Prime) (hq2 : 2 вЙ§ q) :
    ¬ђ Summable (fun p : {p : вДХ // p.Prime вИІ (p : ZMod q) = -1} =>
      (1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2) := by
  intro h
  have hsq : Summable (fun p : {p : вДХ // p.Prime вИІ (p : ZMod q) = -1} => (1 : вДЭ) / (p : вДХ) ^ 2) :=
    (Real.summable_one_div_nat_pow.mpr one_lt_two).subtype _
  exact primes_neg_one_div_diverges q hq hq2 ((h.add hsq).congr (fun p => by ring))

/-- The sieve density product `вИП_{pвИИs}(1 вИТ 1/p + 1/p¬≤)` can be made smaller than any `ќµ > 0`
by choosing a large enough finite set `s` of primes `вЙ° -1 (mod q)`. -/
lemma sieve_prod_small (q : вДХ) (hq : q.Prime) (hq2 : 2 вЙ§ q) {ќµ : вДЭ} (hќµ : 0 < ќµ) :
    вИГ s : Finset {p : вДХ // p.Prime вИІ (p : ZMod q) = -1},
      вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) вЙ§ ќµ := by
  have hann : вИА p : {p : вДХ // p.Prime вИІ (p : ZMod q) = -1},
      (0 : вДЭ) вЙ§ (1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2 := by
    intro p
    have hp2 : (2 : вДЭ) вЙ§ (p : вДХ) := by exact_mod_cast p.2.1.two_le
    rw [sub_nonneg]
    apply one_div_le_one_div_of_le (by linarith)
    nlinarith
  obtain вЯ®s, hsвЯ© : вИГ s : Finset {p : вДХ // p.Prime вИІ (p : ZMod q) = -1},
      -Real.log ќµ вЙ§ вИС p вИИ s, ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2) := by
    by_contra hcon
    push_neg at hcon
    exact recip_sub_sq_diverges q hq hq2 (summable_of_sum_le hann (fun s => (hcon s).le))
  refine вЯ®s, ?_вЯ©
  calc вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2))
      вЙ§ вИП p вИИ s, Real.exp (-((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) :=
        Finset.prod_le_prod (fun p _ => by
          have hp2 : (2 : вДЭ) вЙ§ (p : вДХ) := by exact_mod_cast p.2.1.two_le
          have h1p : (1 : вДЭ) / (p : вДХ) вЙ§ 1 := by rw [div_le_one (by linarith)]; linarith
          have h2p : (0 : вДЭ) вЙ§ 1 / (p : вДХ) ^ 2 := by positivity
          linarith) (fun p _ => Real.one_sub_le_exp_neg _)
    _ = Real.exp (-вИС p вИИ s, ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) := by
        rw [вЖР Real.exp_sum, вЖР Finset.sum_neg_distrib]
    _ вЙ§ Real.exp (Real.log ќµ) := Real.exp_le_exp.mpr (by linarith [hs])
    _ = ќµ := Real.exp_log hќµ

/-- **CRT count is multiplicative over coprime moduli.**  If `Pa` is periodic mod `a` and `Pb`
periodic mod `b` (with `a, b` coprime), the count of `n < a¬Јb` with `Pa n вИІ Pb n` is the product
of the per-modulus counts.  Proof: the map `n вЖ¶ (n % a, n % b)` is a bijection from
`range (a¬Јb)` to `range a √ЧЋҐ range b` (Chinese remainder), carrying good residues to good
residues. -/
private lemma crt_count_mul {a b : вДХ} (ha : a вЙ† 0) (hb : b вЙ† 0) (hab : a.Coprime b)
    (Pa Pb : вДХ вЖТ Prop) [DecidablePred Pa] [DecidablePred Pb]
    (hPa : Function.Periodic Pa a) (hPb : Function.Periodic Pb b) :
    (a * b).count (fun n => Pa n вИІ Pb n) = a.count Pa * b.count Pb := by
  rw [Nat.count_eq_card_filter_range, Nat.count_eq_card_filter_range,
    Nat.count_eq_card_filter_range, вЖР Finset.card_product, вЖР Finset.filter_product]
  refine Finset.card_nbij' (fun n => (n % a, n % b))
    (fun x => (Nat.chineseRemainder hab x.1 x.2 : вДХ)) ?_ ?_ ?_ ?_
  ¬Ј intro n hn
    simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_range] at hn
    obtain вЯ®hnlt, hPan, hPbnвЯ© := hn
    simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_product, Finset.mem_range]
    refine вЯ®вЯ®Nat.mod_lt _ (Nat.pos_of_ne_zero ha), Nat.mod_lt _ (Nat.pos_of_ne_zero hb)вЯ©, ?_, ?_вЯ©
    ¬Ј rw [hPa.map_mod_nat]; exact hPan
    ¬Ј rw [hPb.map_mod_nat]; exact hPbn
  ¬Ј intro x hx
    simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_product, Finset.mem_range] at hx
    obtain вЯ®вЯ®hx1, hx2вЯ©, hPax, hPbxвЯ© := hx
    have hka : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % a = x.1 := by
      have h2 : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % a = x.1 % a :=
        (Nat.chineseRemainder hab x.1 x.2).prop.1
      rwa [Nat.mod_eq_of_lt hx1] at h2
    have hkb : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % b = x.2 := by
      have h2 : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % b = x.2 % b :=
        (Nat.chineseRemainder hab x.1 x.2).prop.2
      rwa [Nat.mod_eq_of_lt hx2] at h2
    simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_range]
    refine вЯ®Nat.chineseRemainder_lt_mul hab x.1 x.2 ha hb, ?_, ?_вЯ©
    ¬Ј rw [вЖР hPa.map_mod_nat, hka]; exact hPax
    ¬Ј rw [вЖР hPb.map_mod_nat, hkb]; exact hPbx
  ¬Ј intro n hn
    simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_range] at hn
    obtain вЯ®hnlt, -, -вЯ© := hn
    show (Nat.chineseRemainder hab (n % a) (n % b) : вДХ) = n
    have hca : (Nat.chineseRemainder hab (n % a) (n % b) : вДХ) вЙ° n [MOD a] :=
      (Nat.chineseRemainder hab (n % a) (n % b)).prop.1.trans (Nat.mod_modEq n a)
    have hcb : (Nat.chineseRemainder hab (n % a) (n % b) : вДХ) вЙ° n [MOD b] :=
      (Nat.chineseRemainder hab (n % a) (n % b)).prop.2.trans (Nat.mod_modEq n b)
    have hcab : (Nat.chineseRemainder hab (n % a) (n % b) : вДХ) вЙ° n [MOD a * b] :=
      (Nat.modEq_and_modEq_iff_modEq_mul hab).mp вЯ®hca, hcbвЯ©
    have hclt : (Nat.chineseRemainder hab (n % a) (n % b) : вДХ) < a * b :=
      Nat.chineseRemainder_lt_mul hab (n % a) (n % b) ha hb
    have hmod := Nat.mod_eq_of_modEq hcab hnlt
    rwa [Nat.mod_eq_of_lt hclt] at hmod
  ¬Ј intro x hx
    rw [Finset.mem_coe, Finset.mem_filter, Finset.mem_product, Finset.mem_range,
      Finset.mem_range] at hx
    obtain вЯ®вЯ®hx1, hx2вЯ©, -, -вЯ© := hx
    have hka : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % a = x.1 := by
      have h2 : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % a = x.1 % a :=
        (Nat.chineseRemainder hab x.1 x.2).prop.1
      rwa [Nat.mod_eq_of_lt hx1] at h2
    have hkb : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % b = x.2 := by
      have h2 : (Nat.chineseRemainder hab x.1 x.2 : вДХ) % b = x.2 % b :=
        (Nat.chineseRemainder hab x.1 x.2).prop.2
      rwa [Nat.mod_eq_of_lt hx2] at h2
    show ((Nat.chineseRemainder hab x.1 x.2 : вДХ) % a, (Nat.chineseRemainder hab x.1 x.2 : вДХ) % b) = x
    rw [hka, hkb]

/-- The "exactly divides" predicate `¬ђ (p вИ£ n вИІ ¬ђ p¬≤ вИ£ n)` is periodic with period `p¬≤`. -/
private lemma single_prime_periodic (p : вДХ) :
    Function.Periodic (fun n => ¬ђ (p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n)) (p ^ 2) := by
  intro n
  have e1 : p вИ£ n + p ^ 2 вЖФ p вИ£ n := by
    rw [add_comm]; exact Nat.dvd_add_right (dvd_pow_self p two_ne_zero)
  have e2 : p ^ 2 вИ£ n + p ^ 2 вЖФ p ^ 2 вИ£ n := Nat.dvd_add_self_right
  simp only [e1, e2]

/-- The conjunction over `s` of "exactly divides" predicates is periodic mod `вИП p¬≤`. -/
private lemma good_periodic {q : вДХ} (s : Finset {p : вДХ // p.Prime вИІ (p : ZMod q) = -1}) :
    Function.Periodic (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
      (вИП p вИИ s, ((p : вДХ)) ^ 2) := by
  intro n
  simp only [eq_iff_iff]
  refine forall_congr' fun p => imp_congr_right fun hp => ?_
  have hpdvd : ((p : вДХ)) ^ 2 вИ£ вИП p вИИ s, ((p : вДХ)) ^ 2 := Finset.dvd_prod_of_mem _ hp
  have e1 : (p : вДХ) вИ£ n + вИП p вИИ s, ((p : вДХ)) ^ 2 вЖФ (p : вДХ) вИ£ n := by
    rw [add_comm]
    exact Nat.dvd_add_right (dvd_trans (dvd_pow_self (p : вДХ) two_ne_zero) hpdvd)
  have e2 : ((p : вДХ)) ^ 2 вИ£ n + вИП p вИИ s, ((p : вДХ)) ^ 2 вЖФ ((p : вДХ)) ^ 2 вИ£ n := by
    rw [add_comm]; exact Nat.dvd_add_right hpdvd
  simp only [e1, e2]

/-- **Single-prime good-residue count**: among `0 вЙ§ r < p¬≤` there are exactly `p¬≤ вИТ (pвИТ1)`
residues not exactly divisible by the prime `p` (the `pвИТ1` bad ones are `p, 2p, вА¶, (pвИТ1)p`). -/
private lemma single_prime_count (p : вДХ) (hp : p.Prime) :
    (p ^ 2).count (fun n => ¬ђ (p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n)) = p ^ 2 - (p - 1) := by
  have hp0 : 0 < p := hp.pos
  -- count the *bad* residues, then complement
  have hbad : (p ^ 2).count (fun n => p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n) = p - 1 := by
    rw [Nat.count_eq_card_filter_range]
    have hset : (Finset.range (p ^ 2)).filter (fun n => p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n)
        = (Finset.Ico 1 p).image (fun k => k * p) := by
      ext n
      simp only [Finset.mem_filter, Finset.mem_range, Finset.mem_image, Finset.mem_Ico]
      constructor
      ¬Ј rintro вЯ®hnlt, вЯ®k, rflвЯ©, hnsвЯ©
        refine вЯ®k, вЯ®?_, ?_вЯ©, by ringвЯ©
        ¬Ј rcases Nat.eq_zero_or_pos k with rfl | hkpos
          ¬Ј exact absurd (show p ^ 2 вИ£ p * 0 from вЯ®0, by ringвЯ©) hns
          ¬Ј exact hkpos
        ¬Ј by_contra hge
          push_neg at hge
          have hmul : p * p вЙ§ p * k := Nat.mul_le_mul (le_refl p) hge
          rw [pow_two] at hnlt
          omega
      ¬Ј rintro вЯ®k, вЯ®hk1, hkpвЯ©, rflвЯ©
        refine вЯ®?_, вЯ®k, by ringвЯ©, ?_вЯ©
        ¬Ј rw [pow_two]; exact mul_lt_mul_of_pos_right hkp hp0
        ¬Ј intro hdvd
          rw [pow_two] at hdvd
          have hpk : p вИ£ k := (mul_dvd_mul_iff_right hp0.ne').mp hdvd
          have := Nat.le_of_dvd (by omega) hpk
          omega
    rw [hset, Finset.card_image_of_injective _
      (fun x y h => Nat.eq_of_mul_eq_mul_right hp0 h), Nat.card_Ico]
  have hcompl : (p ^ 2).count (fun n => ¬ђ (p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n))
      + (p ^ 2).count (fun n => p вИ£ n вИІ ¬ђ p ^ 2 вИ£ n) = p ^ 2 := by
    rw [Nat.count_eq_card_filter_range, Nat.count_eq_card_filter_range, add_comm,
      Finset.card_filter_add_card_filter_not, Finset.card_range]
  omega

/-- **Good-residue count factorizes (CRT).**  The number of residues `0 вЙ§ r < вИП p¬≤` exactly
avoiding every `p вИИ s` is `вИП (p¬≤ вИТ (pвИТ1))`.  Induction on `s`, with the insert step handled by
`crt_count_mul` (the new prime's modulus `p¬≤` is coprime to `вИП` over the rest). -/
private lemma good_count_eq {q : вДХ} (s : Finset {p : вДХ // p.Prime вИІ (p : ZMod q) = -1}) :
    (вИП p вИИ s, ((p : вДХ)) ^ 2).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
      = вИП p вИИ s, (((p : вДХ)) ^ 2 - ((p : вДХ) - 1)) := by
  induction s using Finset.induction_on with
  | empty =>
    rw [Finset.prod_empty, Finset.prod_empty, Nat.count_eq_card_filter_range,
      Finset.filter_true_of_mem (fun x _ => by simp), Finset.card_range]
  | @insert pвВА s hpвВА ih =>
    have ha : ((pвВА : вДХ)) ^ 2 вЙ† 0 := pow_ne_zero _ pвВА.2.1.pos.ne'
    have hb : (вИП p вИИ s, ((p : вДХ)) ^ 2) вЙ† 0 :=
      Finset.prod_ne_zero_iff.mpr fun p _ => pow_ne_zero _ p.2.1.pos.ne'
    have hcop : ((pвВА : вДХ)) ^ 2 |>.Coprime (вИП p вИИ s, ((p : вДХ)) ^ 2) := by
      refine Nat.Coprime.prod_right fun p hp => ?_
      have hne : (pвВА : вДХ) вЙ† (p : вДХ) := by
        intro h
        exact hpвВА (by rw [Subtype.ext h]; exact hp)
      exact ((Nat.coprime_primes pвВА.2.1 p.2.1).mpr hne).pow 2 2
    rw [Finset.prod_insert hpвВА, Finset.prod_insert hpвВА]
    have hbridge2 :
        ((pвВА : вДХ) ^ 2 * вИП p вИИ s, ((p : вДХ)) ^ 2).count
            (fun n => вИА p вИИ insert pвВА s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
          = ((pвВА : вДХ) ^ 2 * вИП p вИИ s, ((p : вДХ)) ^ 2).count
              (fun n => (fun n => ¬ђ ((pвВА : вДХ) вИ£ n вИІ ¬ђ (pвВА : вДХ) ^ 2 вИ£ n)) n
                вИІ (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) n) := by
      rw [Nat.count_eq_card_filter_range, Nat.count_eq_card_filter_range]
      exact congrArg Finset.card (Finset.filter_congr (fun n _ => by
        simp only [Finset.forall_mem_insert]))
    rw [hbridge2, crt_count_mul ha hb hcop
        (fun n => ¬ђ ((pвВА : вДХ) вИ£ n вИІ ¬ђ (pвВА : вДХ) ^ 2 вИ£ n))
        (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
        (single_prime_periodic (pвВА : вДХ)) (good_periodic s),
      single_prime_count (pвВА : вДХ) pвВА.2.1, ih]

/-- **CRT periodic-density bound**: the count of `n вЙ§ X` with no `p вИИ s` exactly dividing `n`
(`p вИ• n` means `p вИ£ n вИІ ¬ђ p¬≤ вИ£ n`) is at most `X ¬Ј вИП(1 вИТ 1/p + 1/p¬≤) + вИП p¬≤`, the `+вИПp¬≤`
being the single-period error.  (Periodic mod `вИП p¬≤`; per-prime good residues `p¬≤вИТ(pвИТ1)`.) -/
lemma density_S_le (q : вДХ) (s : Finset {p : вДХ // p.Prime вИІ (p : ZMod q) = -1}) (X : вДХ) :
    (countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X : вДЭ)
      вЙ§ (X : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2))
        + вИП p вИИ s, ((p : вДХ) : вДЭ) ^ 2 := by
  -- abbreviations (kept defeq, written out so external lemmas match syntactically)
  have hM0 : 0 < вИП p вИИ s, ((p : вДХ)) ^ 2 := Finset.prod_pos fun p _ => pow_pos p.2.1.pos 2
  set M : вДХ := вИП p вИИ s, ((p : вДХ)) ^ 2 with hMdef
  -- (a) bridge: `countUpTo P X = (X+1).count P`
  have hbridge : countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X
      = (X + 1).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) := by
    rw [Nat.count_eq_card_filter_range]
    unfold countUpTo setUpTo
    rw [вЖР Set.ncard_coe_finset]
    congr 1
    ext n
    simp
  -- (c1) periodic count: `(B*M).count P = B*K`
  have hperiodM : Function.Periodic
      (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) M := by
    rw [hMdef]; exact good_periodic s
  have hblock : вИА B : вДХ, (B * M).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
      = B * M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) := by
    intro B
    induction B with
    | zero => simp
    | succ B ihB =>
      have hcongr :
          M.count (fun k => (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) (B * M + k))
            = M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) := by
        rw [Nat.count_eq_card_filter_range, Nat.count_eq_card_filter_range]
        refine congrArg Finset.card (Finset.filter_congr (fun k _ => ?_))
        have hh := (hperiodM.nat_mul B) k
        simp only [Nat.cast_id] at hh
        rw [add_comm k (B * M)] at hh
        exact hh.to_iff
      rw [add_mul, one_mul, Nat.count_add, hcongr, ihB]
      ring
  -- (c2) bound `X+1 вЙ§ (X/M + 1)*M`, then monotone count
  have hXle : X + 1 вЙ§ (X / M + 1) * M := by
    have h1 : M * (X / M) + X % M = X := Nat.div_add_mod X M
    have h2 : X % M < M := Nat.mod_lt _ hM0
    calc X + 1 вЙ§ M * (X / M) + M := by omega
      _ = (X / M + 1) * M := by ring
  have hcountle : (X + 1).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
      вЙ§ (X / M + 1) * M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) := by
    calc (X + 1).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n))
        вЙ§ ((X / M + 1) * M).count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) :=
          Nat.count_monotone _ hXle
      _ = (X / M + 1) * M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) :=
          hblock _
  -- (b) `K вЙ§ M`
  have hKM : M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) вЙ§ M :=
    Nat.count_le _
  -- (d) the CRT product identity in вДЭ: `(K:вДЭ) = M * вИП(1 - (1/p - 1/p¬≤))`
  have hKreal : (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ)
      = (M : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) := by
    rw [hMdef, good_count_eq, Nat.cast_prod, Nat.cast_prod, вЖР Finset.prod_mul_distrib]
    refine Finset.prod_congr rfl fun p _ => ?_
    have hp2 : (2 : вДЭ) вЙ§ (p : вДХ) := by exact_mod_cast p.2.1.two_le
    have hp0 : (0 : вДЭ) < (p : вДХ) := by linarith
    have hpne : ((p : вДХ) : вДЭ) вЙ† 0 := ne_of_gt hp0
    have hcastsub : (((p : вДХ)) ^ 2 - ((p : вДХ) - 1) : вДХ)
        = ((p : вДХ) : вДЭ) ^ 2 - (((p : вДХ) : вДЭ) - 1) := by
      have hle1 : 1 вЙ§ (p : вДХ) := p.2.1.one_lt.le
      have hle2 : (p : вДХ) - 1 вЙ§ ((p : вДХ)) ^ 2 :=
        le_trans (Nat.sub_le _ _) (Nat.le_self_pow (by norm_num) _)
      rw [Nat.cast_sub hle2, Nat.cast_pow, Nat.cast_sub hle1, Nat.cast_one]
    rw [hcastsub]
    push_cast
    field_simp
    try ring
  -- assemble in вДЭ
  have hMR0 : (0 : вДЭ) < (M : вДЭ) := by exact_mod_cast hM0
  have hMcast : (M : вДЭ) = вИП p вИИ s, ((p : вДХ) : вДЭ) ^ 2 := by
    rw [hMdef, Nat.cast_prod]; exact Finset.prod_congr rfl fun p _ => by push_cast; ring
  have hcountleR :
      ((countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X : вДХ) : вДЭ)
        вЙ§ ((X / M + 1) * M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДХ) := by
    rw [hbridge]; exact_mod_cast hcountle
  have hdivle : ((X / M : вДХ) : вДЭ) вЙ§ (X : вДЭ) / (M : вДЭ) := Nat.cast_div_le
  calc ((countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X : вДХ) : вДЭ)
      вЙ§ ((X / M + 1) * M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДХ) :=
        hcountleR
    _ = ((X / M : вДХ) : вДЭ) * (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ)
          + (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) := by
        push_cast; ring
    _ вЙ§ (X : вДЭ) / (M : вДЭ)
            * (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) + (M : вДЭ) := by
        have hKnn : (0 : вДЭ) вЙ§ (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) :=
          Nat.cast_nonneg _
        have hk : ((X / M : вДХ) : вДЭ)
              * (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ)
            вЙ§ (X : вДЭ) / (M : вДЭ)
              * (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) :=
          mul_le_mul_of_nonneg_right hdivle hKnn
        have hm : (M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) вЙ§ (M : вДЭ) := by
          exact_mod_cast hKM
        linarith
    _ = (X : вДЭ)
          * ((M.count (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) : вДЭ) / (M : вДЭ))
          + (M : вДЭ) := by ring
    _ = (X : вДЭ) * (((M : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2))) / (M : вДЭ))
          + (M : вДЭ) := by rw [hKreal]
    _ = (X : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) + (M : вДЭ) := by
        rw [mul_div_cancel_leftвВА _ (ne_of_gt hMR0)]
    _ = (X : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2))
          + вИП p вИИ s, ((p : вДХ) : вДЭ) ^ 2 := by rw [hMcast]

/-- **ѕГ density-zero** (paper Lemma 4.2): for prime `q`, `{n : q вИ§ ѕГ(n)}` has density `0`. -/
theorem sigma_avoid (q : вДХ) (hq : q.Prime) : CountIsLittleO (Bq q) := by
  have hq2 : 2 вЙ§ q := hq.two_le
  refine Asymptotics.isLittleO_iff.mpr ?_
  intro c hc
  obtain вЯ®s, hsвЯ© := sieve_prod_small q hq hq2 (half_pos hc)
  set M : вДЭ := вИП p вИИ s, ((p : вДХ) : вДЭ) ^ 2 with hM
  filter_upwards [eventually_ge_atTop вМИ2 * M / cвМЙвВК] with X hX
  rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
  have hXR : 2 * M / c вЙ§ (X : вДЭ) := le_trans (Nat.le_ceil _) (by exact_mod_cast hX)
  have hMX : M вЙ§ c / 2 * (X : вДЭ) := by
    have h2 : 2 * M вЙ§ (X : вДЭ) * c := by rwa [div_le_iffвВА hc] at hXR
    nlinarith [h2]
  have hred : countUpTo (Bq q) X вЙ§
      countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X := by
    apply Set.ncard_le_ncard _ (setUpTo_finite _ _)
    rintro n вЯ®hnX, hBqвЯ©
    exact вЯ®hnX, fun p _ h => hBq (forced_sigma_factor q (p : вДХ) n hq2 p.2.1 p.2.2 h.1 h.2)вЯ©
  calc (вЖС(countUpTo (Bq q) X) : вДЭ)
      вЙ§ (вЖС(countUpTo (fun n => вИА p вИИ s, ¬ђ ((p : вДХ) вИ£ n вИІ ¬ђ (p : вДХ) ^ 2 вИ£ n)) X) : вДЭ) := by
        exact_mod_cast hred
    _ вЙ§ (X : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2)) + M :=
        density_S_le q s X
    _ вЙ§ (X : вДЭ) * (c / 2) + M := by
        have : (X : вДЭ) * вИП p вИИ s, (1 - ((1 : вДЭ) / (p : вДХ) - 1 / (p : вДХ) ^ 2))
            вЙ§ (X : вДЭ) * (c / 2) := mul_le_mul_of_nonneg_left hs (by positivity)
        linarith
    _ вЙ§ (X : вДЭ) * (c / 2) + c / 2 * (X : вДЭ) := by linarith [hMX]
    _ = c * (X : вДЭ) := by ring



/-! ## Section 4.3 -- Thin-set transfer lemma. -/


/-- **Thin-set transfer** (paper Lemma 4.3). -/
theorem thinSet_transfer (Aset : вДХ вЖТ Prop) [DecidablePred Aset] (B : вДХ вЖТ вДЭ)
    (hBpos : вИА n, 0 вЙ§ B n) (hBle : вИА n, B n вЙ§ n)
    (hBo : (fun n : вДХ => B n) =o[atTop] (fun n : вДХ => (n : вДЭ)))
    (hAsum : Summable (fun a : {a : вДХ // Aset a} => (1 : вДЭ) / a)) :
    (fun X : вДХ => вИС a вИИ (Finset.range (X + 1)).filter Aset, B (X / a))
      =o[atTop] (fun X : вДХ => (X : вДЭ)) := by
  classical
  -- indicator form of the reciprocal sum, and its summability
  set g : вДХ вЖТ вДЭ := Set.indicator {a | Aset a} (fun n => (1 : вДЭ) / n) with hgdef
  have hg : Summable g := summable_subtype_iff_indicator.mp hAsum
  have hgnn : вИА n, 0 вЙ§ g n := fun n => by
    rw [hgdef]; exact Set.indicator_nonneg (fun i _ => by positivity) n
  have hgval : вИА n, Aset n вЖТ g n = (1 : вДЭ) / n := fun n hn => by
    rw [hgdef, Set.indicator_of_mem (show n вИИ {x | Aset x} from hn)]
  -- elementary bound `вЖС(X/a) вЙ§ вЖСX/вЖСa`
  have hcastdiv : вИА X a : вДХ, ((X / a : вДХ) : вДЭ) вЙ§ (X : вДЭ) / a := by
    intro X a
    rcases Nat.eq_zero_or_pos a with rfl | ha'
    ¬Ј simp
    ¬Ј rw [le_div_iffвВА (by exact_mod_cast ha')]
      exact_mod_cast Nat.div_mul_le_self X a
  rw [Asymptotics.isLittleO_iff]
  intro c hc
  -- pick a cutoff `T` so the tail of `g` beyond `range T` is `< c/2`
  have h0 : Tendsto (fun N => вИС' n, g n - вИС n вИИ Finset.range N, g n) atTop (рЭУЭ 0) := by
    have h1 := hg.hasSum.tendsto_sum_nat
    simpa using (tendsto_const_nhds (x := вИС' n, g n)).sub h1
  obtain вЯ®T, hTвЯ© := (h0.eventually (Iio_mem_nhds (show (0 : вДЭ) < c / 2 by linarith))).exists
  -- the head is `o(X)`: a finite sum of per-divisor `o(X)` terms
  have hhead : (fun X : вДХ => вИС a вИИ (Finset.range T).filter Aset, B (X / a))
      =o[atTop] (fun X : вДХ => (X : вДЭ)) := by
    apply IsLittleO.sum
    intro a _
    rcases Nat.eq_zero_or_pos a with rfl | ha
    ¬Ј have hB0 : B 0 = 0 := le_antisymm (by simpa using hBle 0) (hBpos 0)
      simp only [Nat.div_zero, hB0]
      exact isLittleO_zero _ _
    ¬Ј have hk : Tendsto (fun X => X / a) atTop atTop := by
        rw [tendsto_atTop_atTop]
        exact fun b => вЯ®b * a, fun X hX => by rw [Nat.le_div_iff_mul_le ha]; exact hXвЯ©
      refine (hBo.comp_tendsto hk).trans_isBigO ?_
      refine Asymptotics.isBigO_of_le atTop (fun X => ?_)
      show вАЦ((X / a : вДХ) : вДЭ)вАЦ вЙ§ вАЦ(X : вДЭ)вАЦ
      rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
      exact_mod_cast Nat.div_le_self X a
  rw [Asymptotics.isLittleO_iff] at hhead
  filter_upwards [hhead (show (0 : вДЭ) < c / 2 by linarith), eventually_ge_atTop T] with X hXhead hXT
  have hXnn : (0 : вДЭ) вЙ§ X := by positivity
  -- split the index set at `T`
  have hsplit : (Finset.range (X + 1)).filter Aset
      = (Finset.range T).filter Aset вИ™ (Finset.Ico T (X + 1)).filter Aset := by
    rw [вЖР Finset.filter_union]
    congr 1
    rw [Finset.range_eq_Ico, Finset.range_eq_Ico,
      Finset.Ico_union_Ico_eq_Ico (Nat.zero_le T) (by omega)]
  have hdisj : Disjoint ((Finset.range T).filter Aset) ((Finset.Ico T (X + 1)).filter Aset) := by
    rw [Finset.disjoint_left]
    intro a ha hb
    rw [Finset.mem_filter, Finset.mem_range] at ha
    rw [Finset.mem_filter, Finset.mem_Ico] at hb
    omega
  -- head bound
  have hheadbound : вИС a вИИ (Finset.range T).filter Aset, B (X / a) вЙ§ c / 2 * X := by
    rwa [Real.norm_of_nonneg (Finset.sum_nonneg fun a _ => hBpos _),
      Real.norm_of_nonneg hXnn] at hXhead
  -- tail bound
  have htailbound : вИС a вИИ (Finset.Ico T (X + 1)).filter Aset, B (X / a) вЙ§ c / 2 * X := by
    have hstep : вИС a вИИ (Finset.Ico T (X + 1)).filter Aset, B (X / a)
        вЙ§ (X : вДЭ) * вИС a вИИ Finset.Ico T (X + 1), g a := by
      calc вИС a вИИ (Finset.Ico T (X + 1)).filter Aset, B (X / a)
          вЙ§ вИС a вИИ (Finset.Ico T (X + 1)).filter Aset, (X : вДЭ) * g a := by
            apply Finset.sum_le_sum
            intro a ha
            rw [Finset.mem_filter] at ha
            rw [hgval a ha.2, mul_one_div]
            exact le_trans (hBle _) (hcastdiv X a)
        _ вЙ§ вИС a вИИ Finset.Ico T (X + 1), (X : вДЭ) * g a :=
            Finset.sum_le_sum_of_subset_of_nonneg (Finset.filter_subset _ _)
              (fun i _ _ => mul_nonneg hXnn (hgnn i))
        _ = (X : вДЭ) * вИС a вИИ Finset.Ico T (X + 1), g a := by rw [Finset.mul_sum]
    have htg : вИС a вИИ Finset.Ico T (X + 1), g a вЙ§ c / 2 := by
      have hadd : вИС n вИИ Finset.range T, g n + вИС a вИИ Finset.Ico T (X + 1), g a
          = вИС n вИИ Finset.range (X + 1), g n := by
        rw [Finset.range_eq_Ico, Finset.range_eq_Ico,
          вЖР Finset.sum_union (Finset.Ico_disjoint_Ico_consecutive 0 T (X + 1)),
          Finset.Ico_union_Ico_eq_Ico (Nat.zero_le T) (by omega)]
      have hub : вИС n вИИ Finset.range (X + 1), g n вЙ§ вИС' n, g n :=
        Summable.sum_le_tsum _ (fun i _ => hgnn i) hg
      linarith [hadd, hub, hT]
    calc вИС a вИИ (Finset.Ico T (X + 1)).filter Aset, B (X / a)
        вЙ§ (X : вДЭ) * вИС a вИИ Finset.Ico T (X + 1), g a := hstep
      _ вЙ§ (X : вДЭ) * (c / 2) := by
          apply mul_le_mul_of_nonneg_left htg hXnn
      _ = c / 2 * X := by ring
  -- combine
  rw [Real.norm_of_nonneg (Finset.sum_nonneg fun a _ => hBpos _), Real.norm_of_nonneg hXnn,
    hsplit, Finset.sum_union hdisj]
  linarith [hheadbound, htailbound]



/-! ## Section 5.1-5.2 -- Smooth-rough identity (Lem 5.1) and forced prime divisor (Lem 5.2). -/


/-- `H_e(a) = ѕГ(e*a) - F_e(a)`. -/
def Hfun (e a : вДХ) : вДХ := ArithmeticFunction.sigma 1 (e * a) - F e a

/-- The active set `{r : 1 вЙ§ r < e, r вИ£ e*a}`. -/
def activeSet (e a : вДХ) : Finset вДХ := (e * a).divisors.filter (¬Ј < e)

/-- **SmoothвАУrough identity** (paper Lemma 5.1, eq. 5.1). -/
theorem smooth_rough (e a b : вДХ) (he : 2 вЙ§ e)
    (hsmooth : вИА p, p вИ£ a вЖТ p.Prime вЖТ p вЙ§ e)
    (hrough : вИА p, p вИ£ b вЖТ p.Prime вЖТ e < p) :
    F e (a * b)
      = ArithmeticFunction.sigma 1 (e * a) * ArithmeticFunction.sigma 1 b - Hfun e a * b := by
  rcases Nat.eq_zero_or_pos a with rfl | ha
  ¬Ј simp [F, Hfun]
  rcases Nat.eq_zero_or_pos b with rfl | hb
  ¬Ј simp [F, Hfun]
  have hea : 0 < e * a := Nat.mul_pos (by omega) ha
  -- coprimality of `e*a` and `b`
  have hcop : (e * a).Coprime b := by
    apply Nat.coprime_of_dvd
    intro k hk hkea hkb
    have hke : k вЙ§ e := by
      rcases (Nat.Prime.dvd_mul hk).1 hkea with h | h
      ¬Ј exact Nat.le_of_dvd (by omega) h
      ¬Ј exact hsmooth k h hk
    exact absurd (hrough k hkb hk) (by omega)
  -- `b вЙ§ ѕГ b` and `F e a вЙ§ ѕГ(ea)`
  have hbѕГ : b вЙ§ ArithmeticFunction.sigma 1 b := by
    rw [ArithmeticFunction.sigma_one_apply]
    exact Finset.single_le_sum (fun i _ => Nat.zero_le i) (Nat.mem_divisors_self b (by omega))
  have hFle : F e a вЙ§ ArithmeticFunction.sigma 1 (e * a) := by
    rw [F, ArithmeticFunction.sigma_one_apply]
    exact Finset.sum_le_sum_of_subset (Finset.filter_subset _ _)
  -- reindexing over the coprime product
  have key : вИА f : вДХ вЖТ вДХ, вИС d вИИ (e * a * b).divisors, f d
      = вИС x вИИ (e * a).divisors, вИС y вИИ b.divisors, f (x * y) := by
    intro f
    rw [Nat.divisors_mul, Finset.mul_def,
      Finset.sum_image (fun p hp q hq h =>
        hcop.mul_injOn_divisors (Finset.mem_coe.2 hp) (Finset.mem_coe.2 hq) h),
      Finset.sum_product]
  -- the additive form, proved per `x` by splitting `y = b` off
  have hadd : F e (a * b) + ArithmeticFunction.sigma 1 (e * a) * b
      = F e a * b + ArithmeticFunction.sigma 1 (e * a) * ArithmeticFunction.sigma 1 b := by
    have hFab : F e (a * b)
        = вИС x вИИ (e * a).divisors, вИС y вИИ b.divisors, (if x * y вЙ§ a * b then x * y else 0) := by
      rw [F, вЖР mul_assoc, Finset.sum_filter, key]
    have hѕГѕГ : ArithmeticFunction.sigma 1 (e * a) * ArithmeticFunction.sigma 1 b
        = вИС x вИИ (e * a).divisors, вИС y вИИ b.divisors, x * y := by
      rw [ArithmeticFunction.sigma_one_apply, ArithmeticFunction.sigma_one_apply,
        Finset.sum_mul_sum]
    have hѕГb : ArithmeticFunction.sigma 1 (e * a) * b
        = вИС x вИИ (e * a).divisors, x * b := by
      rw [ArithmeticFunction.sigma_one_apply, Finset.sum_mul]
    have hFeab : F e a * b = вИС x вИИ (e * a).divisors, (if x вЙ§ a then x * b else 0) := by
      rw [F, Finset.sum_filter, Finset.sum_mul]
      apply Finset.sum_congr rfl
      intro x _
      by_cases hx : x вЙ§ a <;> simp [hx]
    rw [hFab, hѕГb, hFeab, hѕГѕГ, вЖР Finset.sum_add_distrib, вЖР Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro x hx
    rw [Nat.mem_divisors] at hx
    have hxea : x вЙ§ e * a := Nat.le_of_dvd hea hx.1
    -- the per-`x` identity, splitting `y = b`
    have hbmem : b вИИ b.divisors := Nat.mem_divisors_self b (by omega)
    have hyb : (if x * b вЙ§ a * b then x * b else 0) = (if x вЙ§ a then x * b else 0) := by
      have hiff : x * b вЙ§ a * b вЖФ x вЙ§ a := by
        constructor
        ¬Ј intro h; exact le_of_mul_le_mul_right h hb
        ¬Ј intro h; gcongr
      simp only [hiff]
    -- for `y вИИ erase b`, the product is `вЙ§ a*b`
    have hsmall : вИА y вИИ (b.divisors).erase b, (if x * y вЙ§ a * b then x * y else 0) = x * y := by
      intro y hy
      rw [Finset.mem_erase, Nat.mem_divisors] at hy
      obtain вЯ®hyne, hydvd, _вЯ© := hy
      have hypos : 0 < y := Nat.pos_of_dvd_of_pos hydvd hb
      have hyltb : y < b := lt_of_le_of_ne (Nat.le_of_dvd hb hydvd) hyne
      set c := b / y with hc
      have hcy : c * y = b := Nat.div_mul_cancel hydvd
      have hc1 : 1 < c := by
        rcases Nat.lt_or_ge c 2 with h | h
        ¬Ј interval_cases c <;> omega
        ¬Ј omega
      have hce : e < c := by
        have hcpos : 0 < c := by omega
        have hmf : c.minFac вИ£ b := dvd_trans (Nat.minFac_dvd c) (by rw [вЖР hcy]; exact Dvd.intro y rfl)
        have := hrough c.minFac hmf (Nat.minFac_prime (by omega))
        have hle : c.minFac вЙ§ c := Nat.minFac_le hcpos
        omega
      have hxyle : x * y вЙ§ a * b := by
        have h1 : x * y вЙ§ e * a * y := by gcongr
        have h2 : e * a * y * c = a * b * e := by rw [mul_assoc, mul_comm y c, hcy]; ring
        nlinarith [h1, h2, mul_le_mul_of_nonneg_left hce.le (Nat.zero_le (e * a * y)), he, ha, hb]
      rw [if_pos hxyle]
    rw [вЖР Finset.add_sum_erase _ _ hbmem, вЖР Finset.add_sum_erase _ (fun y => x * y) hbmem,
      Finset.sum_congr rfl hsmall, hyb]
    ring
  -- derive the subtractive statement
  have hHb : Hfun e a * b
      = ArithmeticFunction.sigma 1 (e * a) * b - F e a * b := by
    rw [Hfun, Nat.sub_mul]
  have h1 : F e a * b вЙ§ ArithmeticFunction.sigma 1 (e * a) * b := by gcongr
  have h2 : ArithmeticFunction.sigma 1 (e * a) * b
      вЙ§ ArithmeticFunction.sigma 1 (e * a) * ArithmeticFunction.sigma 1 b := by gcongr
  omega

/-- **Forced prime divisor** (paper Lemma 5.2, eq. 5.2): rational form of `H_e(a)/a`. -/
theorem H_rational (e a : вДХ) (he : 2 вЙ§ e) :
    (Hfun e a : вДЭ) / a = e * вИС r вИИ activeSet e a, (1 : вДЭ) / r := by
  simp only [activeSet]
  rcases Nat.eq_zero_or_pos a with ha | ha
  ¬Ј subst ha; simp [Hfun, F, Nat.divisors_zero]
  ¬Ј set m := e * a with hm
    have hmpos : 0 < m := by rw [hm]; positivity
    have hsig : (ArithmeticFunction.sigma 1 m : вДЭ) = вИС x вИИ m.divisors, (x : вДЭ) := by
      rw [ArithmeticFunction.sigma_one_apply]; push_cast; rfl
    have hFr : (F e a : вДЭ) = вИС x вИИ m.divisors.filter (¬Ј вЙ§ a), (x : вДЭ) := by
      rw [F, вЖР hm]; push_cast; rfl
    have hFle : F e a вЙ§ ArithmeticFunction.sigma 1 m := by
      rw [F, ArithmeticFunction.sigma_one_apply, вЖР hm]
      exact Finset.sum_le_sum_of_subset (Finset.filter_subset _ _)
    -- (H : вДЭ) = вИС_{x вИ£ m, a < x} x
    have hHr : (Hfun e a : вДЭ) = вИС x вИИ m.divisors.filter (a < ¬Ј), (x : вДЭ) := by
      rw [Hfun, вЖР hm, Nat.cast_sub hFle, hsig, hFr,
        вЖР Finset.sum_filter_add_sum_filter_not m.divisors (¬Ј вЙ§ a) (fun x => (x : вДЭ)),
        add_sub_cancel_left]
      simp only [not_le]
    -- reflection `x вЖ¶ m/x`: вИС_{a < x} x = вИС_{r < e} (m/r)
    have hrefl : (вИС x вИИ m.divisors.filter (a < ¬Ј), (x : вДЭ))
        = вИС r вИИ m.divisors.filter (¬Ј < e), ((m / r : вДХ) : вДЭ) := by
      rw [Finset.sum_filter, Finset.sum_filter,
        вЖР Nat.sum_div_divisors m (fun x => if a < x then (x : вДЭ) else 0)]
      apply Finset.sum_congr rfl
      intro r hr
      rw [Nat.mem_divisors] at hr
      obtain вЯ®hdvd, _вЯ© := hr
      have hrpos : 0 < r := Nat.pos_of_dvd_of_pos hdvd hmpos
      have hmul : m / r * r = m := Nat.div_mul_cancel hdvd
      have hcond0 : (m / r вЙ§ a) вЖФ (e вЙ§ r) := by
        constructor
        ¬Ј intro h
          have h1 : m / r * r вЙ§ a * r := by gcongr
          rw [hmul] at h1
          have h2 : e * a вЙ§ r * a := by rw [hm, mul_comm a r] at h1; exact h1
          exact le_of_mul_le_mul_right h2 ha
        ¬Ј intro h
          have h1 : e * a вЙ§ r * a := by gcongr
          have h2 : m / r * r вЙ§ a * r := by rw [hmul, hm, mul_comm a r]; exact h1
          exact le_of_mul_le_mul_right h2 hrpos
      have hcond : (a < m / r) вЖФ (r < e) := by
        rw [вЖР not_le, вЖР not_le]; exact not_congr hcond0
      show (if a < m / r then ((m / r : вДХ) : вДЭ) else 0)
          = (if r < e then ((m / r : вДХ) : вДЭ) else 0)
      by_cases h : a < m / r
      ¬Ј rw [if_pos h, if_pos (hcond.mp h)]
      ¬Ј rw [if_neg h, if_neg (fun hc => h (hcond.mpr hc))]
    -- (H : вДЭ) = m * вИС_{r < e} 1/r
    have hH2 : (Hfun e a : вДЭ)
        = (m : вДЭ) * вИС r вИИ m.divisors.filter (¬Ј < e), (1 : вДЭ) / r := by
      rw [hHr, hrefl, Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro r hr
      rw [Finset.mem_filter, Nat.mem_divisors] at hr
      obtain вЯ®вЯ®hdvd, _вЯ©, _вЯ© := hr
      have hrpos : 0 < r := Nat.pos_of_dvd_of_pos hdvd hmpos
      rw [Nat.cast_div hdvd (by exact_mod_cast hrpos.ne'), mul_one_div]
    -- divide by a, using m = e*a
    have hme : (m : вДЭ) = (e : вДЭ) * a := by rw [hm]; push_cast; ring
    have ha' : (a : вДЭ) вЙ† 0 := by exact_mod_cast ha.ne'
    rw [hH2]
    set S := вИС r вИИ m.divisors.filter (¬Ј < e), (1 : вДЭ) / r with hS
    rw [hme, show (e : вДЭ) * a * S = e * S * a by ring, mul_div_assoc, div_self ha', mul_one]



/-! ## Section 5.3-5.4 -- Sieve modulus Q_E; density lower bound (Lem 5.4); bounded-cofactor exclusion (Prop 5.3). -/


/-- Reduced numerator of `e * вИС_{r вИИ R} 1/r`. -/
def Aval (e : вДХ) (R : Finset вДХ) : вДХ := ((e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r).num.natAbs

/-- Chosen prime divisor of `Aval e R`. -/
def qER (e : вДХ) (R : Finset вДХ) : вДХ := (Aval e R).minFac

/-- The sieve prime set `S_E` (over `e вЙ§ E` and all candidate active sets `R вКЖ [1,e)`). -/
def S (E : вДХ) : Finset вДХ :=
  insert 2 ((Finset.Icc 2 E).biUnion (fun e =>
    ((Finset.Ico 1 e).powerset).image (fun R => qER e R)))

/-- The squarefree sieve modulus `Q_E = вИП_{q вИИ S_E} q`. -/
def Qpr (E : вДХ) : вДХ := вИП q вИИ S E, q

/-- `ќі_E = ѕЖ(Q_E)/Q_E`. -/
noncomputable def ќі (E : вДХ) : вДЭ := (Nat.totient (Qpr E) : вДЭ) / (Qpr E : вДЭ)

/-- **Forced prime divisor** (paper Lemma 5.2, second part): the chosen prime `qER` for the
active set divides `H_e(a)`. -/
lemma forced_prime (e a : вДХ) (he : 2 вЙ§ e) (ha : 1 вЙ§ a) :
    qER e (activeSet e a) вИ£ Hfun e a := by
  set R := activeSet e a with hR
  set V : вДЪ := (e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r with hV
  have haR : (a : вДЭ) вЙ† 0 := by exact_mod_cast (by omega : a вЙ† 0)
  -- the rational identity `(Hfun : вДЪ) = a * V` (cast of `H_rational`)
  have hr : (Hfun e a : вДЭ) / a = (e : вДЭ) * вИС r вИИ R, (1 : вДЭ) / r := H_rational e a he
  have hQ : (Hfun e a : вДЪ) = a * V := by
    have hcast : ((a : вДЪ) * V : вДЭ) = (Hfun e a : вДЭ) := by
      push_cast [hV]
      rw [вЖР hr]
      field_simp
    exact_mod_cast hcast.symm
  -- cross-multiplication `a * V.num = Hfun * V.den`
  have hden : (V.den : вДЪ) вЙ† 0 := by exact_mod_cast V.den_nz
  have hcross : (a : вД§) * V.num = (V.den : вД§) * Hfun e a := by
    have h1 : (a : вДЪ) * ((V.num : вДЪ) / (V.den : вДЪ)) = (Hfun e a : вДЪ) := by
      rw [Rat.num_div_den]; exact hQ.symm
    field_simp at h1
    exact_mod_cast h1
  -- coprimality of numerator and denominator gives `V.num вИ£ Hfun`
  have hcop : IsCoprime V.num (V.den : вД§) := by
    rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd]
    simpa using V.reduced
  have hdvd : V.num вИ£ (Hfun e a : вД§) :=
    hcop.dvd_of_dvd_mul_left вЯ®a, hcross.symm.trans (mul_comm (a : вД§) V.num)вЯ©
  -- conclude `qER вИ£ Aval вИ£ Hfun`
  have hAvaldvd : Aval e R вИ£ Hfun e a := by
    rw [Aval, вЖР hV, вЖР Int.natAbs_natCast (Hfun e a)]
    exact Int.natAbs_dvd_natAbs.mpr hdvd
  rw [qER]
  exact dvd_trans (Nat.minFac_dvd _) hAvaldvd

/-- **SmoothвАУrough factorization.** Every `d вЙ• 1` splits as `d = a * b` with `a` the `e`-smooth
part (prime factors `вЙ§ e`) and `b` the `e`-rough part (prime factors `> e`), coprime. -/
lemma smooth_rough_factor (e d : вДХ) (hd : 1 вЙ§ d) :
    вИГ a b : вДХ, d = a * b вИІ a.Coprime b вИІ 1 вЙ§ a вИІ 1 вЙ§ b вИІ
      (вИА p, p вИ£ a вЖТ p.Prime вЖТ p вЙ§ e) вИІ (вИА p, p вИ£ b вЖТ p.Prime вЖТ e < p) := by
  classical
  have hd0 : d вЙ† 0 := by omega
  set a := вИП p вИИ d.primeFactors.filter (¬Ј вЙ§ e), p ^ d.factorization p with ha
  set b := вИП p вИИ d.primeFactors.filter (fun p => ¬ђ p вЙ§ e), p ^ d.factorization p with hb
  have hsplit : d = вИП p вИИ d.primeFactors, p ^ d.factorization p := by
    conv_lhs => rw [вЖР Nat.prod_factorization_pow_eq_self hd0]
    rw [Finsupp.prod, Nat.support_factorization]
  have hab : d = a * b := by
    rw [ha, hb, Finset.prod_filter_mul_prod_filter_not, вЖР hsplit]
  have hapos : 0 < a := by
    rw [ha]; exact Finset.prod_pos (fun p hp => by
      rw [Finset.mem_filter, Nat.mem_primeFactors] at hp
      exact pow_pos hp.1.1.pos _)
  have hbpos : 0 < b := by
    rw [hb]; exact Finset.prod_pos (fun p hp => by
      rw [Finset.mem_filter, Nat.mem_primeFactors] at hp
      exact pow_pos hp.1.1.pos _)
  have hprimea : вИА p, p вИ£ a вЖТ p.Prime вЖТ p вЙ§ e := by
    intro p hpa hp
    obtain вЯ®q, hq, hpqвЯ© := (hp.prime).exists_mem_finset_dvd (by rw [вЖР ha]; exact hpa)
    rw [Finset.mem_filter] at hq
    have : p = q := (Nat.prime_dvd_prime_iff_eq hp (Nat.prime_of_mem_primeFactors hq.1)).mp
      (hp.dvd_of_dvd_pow hpq)
    rw [this]; exact hq.2
  have hprimeb : вИА p, p вИ£ b вЖТ p.Prime вЖТ e < p := by
    intro p hpb hp
    obtain вЯ®q, hq, hpqвЯ© := (hp.prime).exists_mem_finset_dvd (by rw [вЖР hb]; exact hpb)
    rw [Finset.mem_filter] at hq
    have : p = q := (Nat.prime_dvd_prime_iff_eq hp (Nat.prime_of_mem_primeFactors hq.1)).mp
      (hp.dvd_of_dvd_pow hpq)
    rw [this]; omega
  refine вЯ®a, b, hab, ?_, hapos, hbpos, hprimea, hprimebвЯ©
  rw [Nat.coprime_iff_gcd_eq_one]
  by_contra hgcd
  obtain вЯ®p, hp, hpabвЯ© := Nat.exists_prime_and_dvd hgcd
  have hpa : p вИ£ a := hpab.trans (Nat.gcd_dvd_left a b)
  have hpb : p вИ£ b := hpab.trans (Nat.gcd_dvd_right a b)
  exact absurd (hprimea p hpa hp) (by have := hprimeb p hpb hp; omega)

/-- `Nat.sqrt X = o(X)`. -/
lemma nat_sqrt_isLittleO :
    (fun X : вДХ => (Nat.sqrt X : вДЭ)) =o[atTop] (fun X : вДХ => (X : вДЭ)) := by
  rw [Asymptotics.isLittleO_iff]
  intro ќµ hќµ
  filter_upwards [eventually_gt_atTop (Nat.ceil (1 / ќµ ^ 2))] with X hX
  have hXr : (1 : вДЭ) / ќµ ^ 2 < X := lt_of_le_of_lt (Nat.le_ceil _) (by exact_mod_cast hX)
  have hsqrt : (Nat.sqrt X : вДЭ) вЙ§ Real.sqrt X := by
    rw [show (Nat.sqrt X : вДЭ) = Real.sqrt ((Nat.sqrt X : вДЭ) ^ 2) from
      (Real.sqrt_sq (by positivity)).symm]
    exact Real.sqrt_le_sqrt (by exact_mod_cast Nat.sqrt_le' X)
  have hќµ2 : 1 < ќµ ^ 2 * X := by rw [mul_comm]; exact (div_lt_iffвВА (by positivity)).mp hXr
  have h2 : Real.sqrt X вЙ§ ќµ * X := by
    rw [show ќµ * (X : вДЭ) = Real.sqrt ((ќµ * X) ^ 2) from (Real.sqrt_sq (by positivity)).symm]
    exact Real.sqrt_le_sqrt (by nlinarith [hќµ2, (Nat.cast_nonneg X : (0:вДЭ) вЙ§ X)])
  rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
  linarith [hsqrt, h2]

/-- The squares and twice-squares form a density-zero set (`O(вИЪX)`). -/
lemma sq_or_twosq_littleO :
    CountIsLittleO (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) := by
  have hcard : вИА X : вДХ, countUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X
      вЙ§ 2 * (Nat.sqrt X + 1) := by
    intro X
    unfold countUpTo
    have hsub : setUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X вКЖ
        вЖС((Finset.range (Nat.sqrt X + 1)).image (¬Ј ^ 2) вИ™
          (Finset.range (Nat.sqrt X + 1)).image (fun s => 2 * s ^ 2)) := by
      intro n hn
      unfold setUpTo at hn
      rw [Set.mem_setOf_eq] at hn
      obtain вЯ®hnX, s, hsвЯ© := hn
      simp only [Finset.coe_union, Finset.coe_image, Finset.coe_range, Set.mem_union,
        Set.mem_image, Set.mem_Iio]
      rcases hs with hs | hs
      ¬Ј exact Or.inl вЯ®s, Nat.lt_succ_iff.mpr (Nat.le_sqrt'.mpr (hs вЦЄ hnX)), hs.symmвЯ©
      ¬Ј exact Or.inr вЯ®s, Nat.lt_succ_iff.mpr (Nat.le_sqrt'.mpr
          (le_trans (Nat.le_mul_of_pos_left (s ^ 2) (by norm_num)) (hs вЦЄ hnX))), hs.symmвЯ©
    calc (setUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X).ncard
        вЙ§ _ := Set.ncard_le_ncard hsub (Finset.finite_toSet _)
      _ = _ := Set.ncard_coe_finset _
      _ вЙ§ 2 * (Nat.sqrt X + 1) := by
          refine (Finset.card_union_le _ _).trans ?_
          have h1 := Finset.card_image_le (s := Finset.range (Nat.sqrt X + 1)) (f := (¬Ј ^ 2))
          have h2 := Finset.card_image_le (s := Finset.range (Nat.sqrt X + 1))
            (f := fun s => 2 * s ^ 2)
          simp only [Finset.card_range] at h1 h2
          omega
  have hg : (fun X : вДХ => 4 * (Nat.sqrt X : вДЭ)) =o[atTop] (fun X : вДХ => (X : вДЭ)) :=
    nat_sqrt_isLittleO.const_mul_left 4
  refine Asymptotics.IsBigO.trans_isLittleO ?_ hg
  rw [Asymptotics.isBigO_iff]
  refine вЯ®1, ?_вЯ©
  filter_upwards [eventually_ge_atTop 1] with X hX1
  have hsqrt1 : (1 : вДЭ) вЙ§ (Nat.sqrt X : вДЭ) := by
    have : 1 вЙ§ Nat.sqrt X := Nat.le_sqrt'.mpr (by simpa using hX1)
    exact_mod_cast this
  have hcd : (countUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X : вДЭ)
      вЙ§ 2 * ((Nat.sqrt X : вДЭ) + 1) := by exact_mod_cast hcard X
  rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
  nlinarith [hcd, hsqrt1]

open ArithmeticFunction in
/-- **ѕГ-parity (forward).** If `ѕГ(d)` is odd then `d` is a square or twice a square. -/
lemma sigma_odd_imp_sq_or_twosq (d : вДХ) (hd : 1 вЙ§ d) (hodd : Odd (sigma 1 d)) :
    вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2 := by
  classical
  have hd0 : d вЙ† 0 := by omega
  -- (1) every odd prime factor has even valuation
  have hev : вИА p вИИ d.primeFactors, p вЙ† 2 вЖТ Even (d.factorization p) := by
    intro p hp hp2
    have hpp : p.Prime := Nat.prime_of_mem_primeFactors hp
    have hpodd : p % 2 = 1 := Nat.odd_iff.mp (hpp.odd_of_ne_two hp2)
    have hdvd : sigma 1 (p ^ d.factorization p) вИ£ sigma 1 d := by
      conv_rhs => rw [isMultiplicative_sigma.multiplicative_factorization _ hd0, Finsupp.prod]
      exact Finset.dvd_prod_of_mem (fun q => sigma 1 (q ^ d.factorization q))
        (by rw [Nat.support_factorization]; exact hp)
    have hfac : Odd (sigma 1 (p ^ d.factorization p)) := by
      obtain вЯ®c, hcвЯ© := hdvd
      have h := hodd
      rw [hc, Nat.odd_mul] at h
      exact h.1
    rw [sigma_one_apply_prime_pow hpp] at hfac
    have hsum : (вИС j вИИ Finset.range (d.factorization p + 1), p ^ j) % 2
        = (d.factorization p + 1) % 2 := by
      rw [Finset.sum_nat_mod,
        Finset.sum_congr rfl (fun j _ => by rw [Nat.pow_mod, hpodd, one_pow])]
      simp
    rw [Nat.odd_iff, hsum] at hfac
    rw [Nat.even_iff]; omega
  -- (2) split off the 2-part: `d = 2 ^ a * o` with `o` odd
  set a := d.factorization 2 with ha
  have hdvd2 : 2 ^ a вИ£ d := Nat.ordProj_dvd d 2
  set o := d / 2 ^ a with ho
  have hdeq : d = 2 ^ a * o := (Nat.mul_div_cancel' hdvd2).symm
  have ho0 : o вЙ† 0 := by rintro h; rw [h, mul_zero] at hdeq; exact hd0 hdeq
  have h2a0 : (2 : вДХ) ^ a вЙ† 0 := by positivity
  have hod : o вИ£ d := вЯ®2 ^ a, by rw [hdeq, mul_comm]вЯ©
  have hoodd : ¬ђ (2 вИ£ o) := Nat.not_dvd_ordCompl Nat.prime_two hd0
  have hfacto : вИА p, p вЙ† 2 вЖТ o.factorization p = d.factorization p := by
    intro p hp2
    rw [hdeq, Nat.factorization_mul h2a0 ho0, Finsupp.add_apply, Nat.factorization_pow,
      Finsupp.smul_apply, Nat.Prime.factorization Nat.prime_two, Finsupp.single_apply,
      if_neg (Ne.symm hp2), smul_zero, zero_add]
  -- (3) `o` is a perfect square
  have hosq : вИГ s, o = s ^ 2 := by
    refine вЯ®вИП p вИИ o.primeFactors, p ^ (o.factorization p / 2), ?_вЯ©
    rw [вЖР Finset.prod_pow]
    conv_lhs => rw [вЖР Nat.prod_factorization_pow_eq_self ho0, Finsupp.prod,
      Nat.support_factorization]
    refine Finset.prod_congr rfl (fun p hp => ?_)
    have hp2 : p вЙ† 2 := fun h => hoodd (h вЦЄ Nat.dvd_of_mem_primeFactors hp)
    have hpd : p вИИ d.primeFactors := Nat.primeFactors_mono hod hd0 hp
    have heven : Even (o.factorization p) := by rw [hfacto p hp2]; exact hev p hpd hp2
    rw [вЖР pow_mul, Nat.div_mul_cancel heven.two_dvd]
  -- (4) assemble
  obtain вЯ®s, hsвЯ© := hosq
  rcases Nat.even_or_odd a with вЯ®b, hbвЯ© | вЯ®b, hbвЯ©
  ¬Ј exact вЯ®2 ^ b * s, Or.inl (by rw [hdeq, hs, hb]; ring)вЯ©
  ¬Ј exact вЯ®2 ^ b * s, Or.inr (by rw [hdeq, hs, hb]; ring)вЯ©

/-- `2 вИ£ Q_E`, so every integer coprime to `Q_E` is odd. -/
theorem two_dvd_Qpr (E : вДХ) (_hE : 2 вЙ§ E) : 2 вИ£ Qpr E := by
  unfold Qpr S
  exact Finset.dvd_prod_of_mem _ (Finset.mem_insert_self 2 _)

open ArithmeticFunction in
/-- `F 1 d = ѕГ d` (with `e = 1`, every divisor of `d` is `вЙ§ d`). -/
lemma F_one_eq_sigma (d : вДХ) : F 1 d = sigma 1 d := by
  rw [F, one_mul, sigma_one_apply]
  refine Finset.sum_congr (Finset.filter_true_of_mem (fun q hq => ?_)) (fun _ _ => rfl)
  exact Nat.le_of_dvd (Nat.pos_of_ne_zero (Nat.mem_divisors.mp hq).2) (Nat.mem_divisors.mp hq).1

open ArithmeticFunction in
/-- **`e = 1` case of Prop 5.3.** Coprime-to-`Q_E` values `ѕГ(d)` are odd, hence `d` is a square
or twice a square, a density-zero set. -/
lemma small_e_one_littleO (E : вДХ) (hE : 2 вЙ§ E) :
    CountIsLittleO (fun N => Nat.Coprime N (Qpr E) вИІ вИГ d, N = F 1 d) := by
  have hfin : вИА X, (setUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X).Finite :=
    fun X => Set.Finite.subset (Set.finite_Iic X) (fun n hn => hn.1)
  have hbound : вИА X, countUpTo (fun N => Nat.Coprime N (Qpr E) вИІ вИГ d, N = F 1 d) X
      вЙ§ countUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X := by
    intro X
    have hsub : setUpTo (fun N => Nat.Coprime N (Qpr E) вИІ вИГ d, N = F 1 d) X вКЖ
        sigma 1 '' setUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X := by
      intro N hN
      obtain вЯ®hNX, hcop, d, hdвЯ© := hN
      rw [F_one_eq_sigma] at hd
      have hN0 : N вЙ† 0 := by
        rintro rfl
        rw [Nat.coprime_zero_left] at hcop
        exact absurd (two_dvd_Qpr E hE) (by rw [hcop]; decide)
      have hd0 : d вЙ† 0 := by rintro rfl; rw [hd] at hN0; simp at hN0
      have hNodd : Odd N :=
        (Nat.Coprime.coprime_dvd_right (two_dvd_Qpr E hE) hcop).odd_of_right
      have hdle : d вЙ§ X := by
        have : d вЙ§ sigma 1 d := by
          rw [sigma_one_apply]
          exact Finset.single_le_sum (fun i _ => Nat.zero_le i)
            (Nat.mem_divisors_self d hd0)
        omega
      refine вЯ®d, вЯ®hdle, sigma_odd_imp_sq_or_twosq d (by omega) (hd вЦЄ hNodd)вЯ©, hd.symmвЯ©
    calc (setUpTo (fun N => Nat.Coprime N (Qpr E) вИІ вИГ d, N = F 1 d) X).ncard
        вЙ§ (sigma 1 '' setUpTo (fun d => вИГ s, d = s ^ 2 вИ® d = 2 * s ^ 2) X).ncard :=
          Set.ncard_le_ncard hsub ((hfin X).image _)
      _ вЙ§ _ := Set.ncard_image_le (hfin X)
  refine Asymptotics.IsBigO.trans_isLittleO ?_ sq_or_twosq_littleO
  rw [Asymptotics.isBigO_iff]
  refine вЯ®1, Filter.Eventually.of_forall (fun X => ?_)вЯ©
  rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity), one_mul]
  exact_mod_cast hbound X

/-- The reciprocals of `k`-smooth numbers are summable (Euler product over primes `< k`). -/
lemma smooth_recip_summable (k : вДХ) :
    Summable (fun a : Nat.smoothNumbers k => (1 : вДЭ) / (a : вДХ)) := by
  induction k with
  | zero =>
    have hfin : (Nat.smoothNumbers 0).Finite := by
      rw [Nat.smoothNumbers_zero]; exact Set.finite_singleton 1
    exact hfin.summable (fun n : вДХ => (1 : вДЭ) / (n : вДЭ))
  | succ p ih =>
    by_cases hp : p.Prime
    ¬Ј rw [вЖР (Nat.equivProdNatSmoothNumbers hp).summable_iff]
      have heq : (fun a : Nat.smoothNumbers (p + 1) => (1 : вДЭ) / (a : вДХ)) вИШ
          (Nat.equivProdNatSmoothNumbers hp)
          = fun x : вДХ √Ч Nat.smoothNumbers p => (1 / (p : вДЭ)) ^ x.1 * (1 / (x.2 : вДХ)) := by
        funext x
        simp only [Function.comp_apply, Nat.equivProdNatSmoothNumbers_apply', Nat.cast_mul,
          Nat.cast_pow, one_div, mul_inv, inv_pow]
      rw [heq]
      have hgeo : Summable (fun e : вДХ => (1 / (p : вДЭ)) ^ e) := by
        apply summable_geometric_of_lt_one (by positivity)
        rw [div_lt_one (by exact_mod_cast hp.pos)]
        exact_mod_cast hp.one_lt
      exact hgeo.mul_of_nonneg ih (fun _ => by positivity) (fun _ => by positivity)
    ¬Ј rw [Nat.smoothNumbers_succ hp]
      exact ih

/-- The always-false predicate has count `o(X)`. -/
lemma CountIsLittleO_false : CountIsLittleO (fun _ : вДХ => False) := by
  have hz : вИА X, countUpTo (fun _ : вДХ => False) X = 0 := by
    intro X
    simp only [countUpTo]
    convert Set.ncard_empty вДХ
    ext n; simp [setUpTo]
  unfold CountIsLittleO
  simp only [hz, Nat.cast_zero]
  exact Asymptotics.isLittleO_zero _ _

/-- A finite union of density-zero sets is density-zero. -/
lemma CountIsLittleO_biUnion {ќє : Type*} (s : Finset ќє) (P : ќє вЖТ вДХ вЖТ Prop)
    (h : вИА i вИИ s, CountIsLittleO (P i)) :
    CountIsLittleO (fun N => вИГ i вИИ s, P i N) := by
  classical
  induction s using Finset.induction with
  | empty =>
    exact CountIsLittleO.mono (fun n hn => by simpa using hn) CountIsLittleO_false
  | @insert a t ha ih =>
    have hcong : (fun N => вИГ i вИИ insert a t, P i N) = (fun N => P a N вИ® вИГ i вИИ t, P i N) := by
      funext N; simp only [Finset.exists_mem_insert]
    rw [hcong]
    exact (h a (Finset.mem_insert_self a t)).or
      (ih (fun i hi => h i (Finset.mem_insert_of_mem hi)))

/-- The chosen prime `qER e (activeSet e a)` is genuinely prime (`Aval вЙ• 2` since `1 вИИ activeSet`). -/
lemma qER_prime (e a : вДХ) (he : 2 вЙ§ e) (ha : 1 вЙ§ a) :
    (qER e (activeSet e a)).Prime := by
  rw [qER]
  apply Nat.minFac_prime
  set R := activeSet e a with hR
  have hea : e * a вЙ† 0 := by positivity
  have h1R : (1 : вДХ) вИИ R := by
    rw [hR, activeSet, Finset.mem_filter, Nat.mem_divisors]
    exact вЯ®вЯ®one_dvd _, heaвЯ©, by omegaвЯ©
  have hsum1 : (1 : вДЪ) вЙ§ вИС r вИИ R, (1 : вДЪ) / r :=
    le_trans (by norm_num) (Finset.single_le_sum (fun i _ => by positivity) h1R)
  have hge2 : (2 : вДЪ) вЙ§ (e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r := by
    calc (2 : вДЪ) вЙ§ (e : вДЪ) := by exact_mod_cast he
      _ = (e : вДЪ) * 1 := (mul_one _).symm
      _ вЙ§ (e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r := mul_le_mul_of_nonneg_left hsum1 (by positivity)
  intro h1
  rw [Aval] at h1
  set q : вДЪ := (e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r with hq
  have hqpos : 0 < q := lt_of_lt_of_le (by norm_num) hge2
  have hnum1 : q.num = 1 := by
    have hnpos : 0 < q.num := Rat.num_pos.mpr hqpos
    omega
  have hle1 : q вЙ§ 1 := by
    rw [вЖР Rat.num_div_den q, hnum1, div_le_one (by exact_mod_cast q.den_pos)]
    exact_mod_cast q.den_pos
  linarith [hge2]

open ArithmeticFunction in
/-- **Mod-`q` deduction (`e вЙ• 2`).** If `N = F e (a*b)` (smoothвАУrough split) is coprime to `Q_E`,
then the rough part `b` lies in `B_q` for `q = qER e (activeSet e a)`. -/
lemma e_ge_two_forces_Bq (e a b E : вДХ) (he : 2 вЙ§ e) (ha : 1 вЙ§ a) (hb : 1 вЙ§ b)
    (hsmooth : вИА p, p вИ£ a вЖТ p.Prime вЖТ p вЙ§ e) (hrough : вИА p, p вИ£ b вЖТ p.Prime вЖТ e < p)
    (hqS : qER e (activeSet e a) вИИ S E)
    (hcop : Nat.Coprime (F e (a * b)) (Qpr E)) :
    Bq (qER e (activeSet e a)) b := by
  set q := qER e (activeSet e a) with hq
  have hqp : q.Prime := qER_prime e a he ha
  have hqHfun : q вИ£ Hfun e a := forced_prime e a he ha
  have hqQ : q вИ£ Qpr E := Finset.dvd_prod_of_mem _ hqS
  have hqN : ¬ђ q вИ£ F e (a * b) := by
    intro hqd
    exact hqp.ne_one (Nat.dvd_one.mp (hcop вЦЄ Nat.dvd_gcd hqd hqQ))
  have hsr := smooth_rough e a b he hsmooth hrough
  have hble : b вЙ§ sigma 1 b := by
    rw [sigma_one_apply]
    exact Finset.single_le_sum (fun i _ => Nat.zero_le i) (Nat.mem_divisors_self b (by omega))
  have hmul : Hfun e a * b вЙ§ sigma 1 (e * a) * sigma 1 b :=
    Nat.mul_le_mul (by rw [Hfun]; exact Nat.sub_le _ _) hble
  have hadd : sigma 1 (e * a) * sigma 1 b = F e (a * b) + Hfun e a * b := by rw [hsr]; omega
  intro hqb
  have hqss : q вИ£ sigma 1 (e * a) * sigma 1 b := hqb.mul_left _
  rw [hadd] at hqss
  exact hqN ((Nat.dvd_add_right (hqHfun.mul_right b)).mp (by rwa [add_comm] at hqss))

/-- `d вЙ§ F e d` (the divisor `d` itself is one of the summands). -/
lemma F_ge (e d : вДХ) (he : 1 вЙ§ e) (hd : 1 вЙ§ d) : d вЙ§ F e d := by
  rw [F]
  refine Finset.single_le_sum (fun i _ => Nat.zero_le i) ?_
  rw [Finset.mem_filter, Nat.mem_divisors]
  exact вЯ®вЯ®dvd_mul_left d e, by positivityвЯ©, le_refl dвЯ©

/-- `countUpTo` as a `Finset.card`. -/
lemma countUpTo_eq_card (P : вДХ вЖТ Prop) [DecidablePred P] (X : вДХ) :
    countUpTo P X = ((Finset.range (X + 1)).filter P).card := by
  unfold countUpTo setUpTo
  rw [вЖР Set.ncard_coe_finset]
  congr 1
  ext n
  simp [Nat.lt_succ_iff]

open Classical in
/-- Count bound feeding `thinSet_transfer`: values `F e (a*b)` with `a` smooth, `b вИИ B_q`,
counted by smooth part `a`. -/
lemma count_Fe_le_sum (e q X : вДХ) (he : 1 вЙ§ e) :
    countUpTo (fun N => вИГ a b, a вИИ Nat.smoothNumbers (e + 1) вИІ 1 вЙ§ b вИІ Bq q b вИІ N = F e (a * b)) X
      вЙ§ вИС a вИИ (Finset.range (X + 1)).filter (¬Ј вИИ Nat.smoothNumbers (e + 1)),
          countUpTo (Bq q) (X / a) := by
  rw [countUpTo_eq_card]
  simp_rw [countUpTo_eq_card]
  calc ((Finset.range (X + 1)).filter
          (fun N => вИГ a b, a вИИ Nat.smoothNumbers (e + 1) вИІ 1 вЙ§ b вИІ Bq q b вИІ N = F e (a * b))).card
      вЙ§ (((Finset.range (X + 1)).filter (¬Ј вИИ Nat.smoothNumbers (e + 1))).biUnion (fun a =>
          ((Finset.range (X / a + 1)).filter (Bq q)).image (fun b => F e (a * b)))).card :=
        Finset.card_le_card (by
          intro N hN
          rw [Finset.mem_filter, Finset.mem_range] at hN
          obtain вЯ®hNX, a, b, hsm, hb1, hbq, hNeqвЯ© := hN
          have ha1 : 1 вЙ§ a := Nat.one_le_iff_ne_zero.mpr hsm.1
          have hab1 : 1 вЙ§ a * b :=
            Nat.one_le_iff_ne_zero.mpr (Nat.mul_ne_zero (by omega) (by omega))
          have habX : a * b вЙ§ X :=
            le_trans (le_trans (F_ge e (a * b) he hab1) hNeq.ge) (by omega)
          rw [Finset.mem_biUnion]
          refine вЯ®a, ?_, ?_вЯ©
          ¬Ј rw [Finset.mem_filter, Finset.mem_range]
            exact вЯ®lt_of_le_of_lt (le_trans (Nat.le_mul_of_pos_right a (by omega)) habX)
              (by omega), hsmвЯ©
          ¬Ј rw [Finset.mem_image]
            refine вЯ®b, ?_, hNeq.symmвЯ©
            rw [Finset.mem_filter, Finset.mem_range, Nat.lt_succ_iff, Nat.le_div_iff_mul_le ha1]
            exact вЯ®by rwa [mul_comm] at habX, hbqвЯ©)
    _ вЙ§ вИС a вИИ (Finset.range (X + 1)).filter (¬Ј вИИ Nat.smoothNumbers (e + 1)),
          (((Finset.range (X / a + 1)).filter (Bq q)).image (fun b => F e (a * b))).card :=
        Finset.card_biUnion_le
    _ вЙ§ вИС a вИИ (Finset.range (X + 1)).filter (¬Ј вИИ Nat.smoothNumbers (e + 1)),
          ((Finset.range (X / a + 1)).filter (Bq q)).card :=
        Finset.sum_le_sum (fun a _ => Finset.card_image_le)

open Classical in
/-- For fixed `e вЙ• 1` and prime `q`, the set of `F e (a*b)` (`a` smooth, `b вИИ B_q`) is density-zero. -/
lemma per_q_littleO (e q : вДХ) (he : 1 вЙ§ e) (hq : q.Prime) :
    CountIsLittleO (fun N => вИГ a b,
      a вИИ Nat.smoothNumbers (e + 1) вИІ 1 вЙ§ b вИІ Bq q b вИІ N = F e (a * b)) := by
  have hBle0 : вИА n, countUpTo (Bq q) n вЙ§ n := by
    intro n
    have h0 : (0 : вДХ) вИЙ setUpTo (Bq q) n := fun h0 => h0.2 (by simp)
    calc countUpTo (Bq q) n
        вЙ§ (вЖС(Finset.Icc 1 n) : Set вДХ).ncard :=
          Set.ncard_le_ncard (fun m hm => by
            rw [Finset.coe_Icc, Set.mem_Icc]
            exact вЯ®Nat.one_le_iff_ne_zero.mpr (fun h => h0 (h вЦЄ hm)), hm.1вЯ©)
            (Finset.finite_toSet _)
      _ = (Finset.Icc 1 n).card := Set.ncard_coe_finset _
      _ = n := by rw [Nat.card_Icc]; omega
  have hthin := thinSet_transfer (fun a => a вИИ Nat.smoothNumbers (e + 1))
    (fun n => (countUpTo (Bq q) n : вДЭ)) (fun n => countUpTo_nonneg _ n)
    (fun n => by exact_mod_cast hBle0 n) (sigma_avoid q hq) (smooth_recip_summable (e + 1))
  refine Asymptotics.IsBigO.trans_isLittleO ?_ hthin
  rw [Asymptotics.isBigO_iff]
  refine вЯ®1, Filter.Eventually.of_forall (fun X => ?_)вЯ©
  rw [Real.norm_of_nonneg (by positivity),
    Real.norm_of_nonneg (Finset.sum_nonneg (fun a _ => countUpTo_nonneg _ _)), one_mul]
  exact_mod_cast count_Fe_le_sum e q X he

open Classical in
/-- The `e вЙ• 2` case of Prop 5.3 (density-zero via the mod-`q` deduction + `thinSet_transfer`). -/
lemma e_ge_two_littleO (E e : вДХ) (he2 : 2 вЙ§ e) (heE : e вЙ§ E) :
    CountIsLittleO (fun N => Nat.Coprime N (Qpr E) вИІ вИГ d, N = F e d) := by
  refine CountIsLittleO.mono (Q := fun N => вИГ q вИИ (S E).filter Nat.Prime, вИГ a b,
    a вИИ Nat.smoothNumbers (e + 1) вИІ 1 вЙ§ b вИІ Bq q b вИІ N = F e (a * b)) ?_ ?_
  ¬Ј rintro N вЯ®hcop, d, hdвЯ©
    have hN0 : N вЙ† 0 := by
      rintro rfl
      rw [Nat.coprime_zero_left] at hcop
      exact absurd (two_dvd_Qpr E (by omega)) (by rw [hcop]; decide)
    have hd1 : 1 вЙ§ d := by
      rcases Nat.eq_zero_or_pos d with rfl | h
      ¬Ј exact absurd (show N = 0 by rw [hd]; simp [F]) hN0
      ¬Ј exact h
    obtain вЯ®a, b, hdab, _, ha1, hb1, hsm, hroвЯ© := smooth_rough_factor e d hd1
    have hqS : qER e (activeSet e a) вИИ S E := by
      rw [S, Finset.mem_insert]
      refine Or.inr (Finset.mem_biUnion.mpr вЯ®e, Finset.mem_Icc.mpr вЯ®he2, heEвЯ©,
        Finset.mem_image.mpr вЯ®activeSet e a, Finset.mem_powerset.mpr (fun r hr => ?_), rflвЯ©вЯ©)
      rw [activeSet, Finset.mem_filter, Nat.mem_divisors] at hr
      rw [Finset.mem_Ico]
      exact вЯ®Nat.one_le_iff_ne_zero.mpr (fun h => hr.1.2 (zero_dvd_iff.mp (h вЦЄ hr.1.1))), hr.2вЯ©
    have hcopab : Nat.Coprime (F e (a * b)) (Qpr E) := by rw [hd, hdab] at hcop; exact hcop
    refine вЯ®qER e (activeSet e a), Finset.mem_filter.mpr вЯ®hqS, qER_prime e a he2 ha1вЯ©,
      a, b, ?_, hb1, e_ge_two_forces_Bq e a b E he2 ha1 hb1 hsm hro hqS hcopab, by rw [hd, hdab]вЯ©
    rw [Nat.mem_smoothNumbers]
    refine вЯ®by omega, fun p hp => ?_вЯ©
    have := hsm p (Nat.dvd_of_mem_primeFactorsList hp) (Nat.prime_of_mem_primeFactorsList hp)
    omega
  ¬Ј exact CountIsLittleO_biUnion _ _ (fun q hq => per_q_littleO e q (by omega)
      (Finset.mem_filter.mp hq).2)

/-- **Bounded-cofactor exclusion** (paper Prop 5.3). -/
theorem small_e_exclusion (E : вДХ) (hE : 2 вЙ§ E) :
    CountIsLittleO
      (fun N => Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d) := by
  refine CountIsLittleO.mono (Q := fun N => (Nat.Coprime N (Qpr E) вИІ вИГ d, N = F 1 d) вИ®
    (вИГ e вИИ Finset.Icc 2 E, Nat.Coprime N (Qpr E) вИІ вИГ d, N = F e d)) ?_ ?_
  ¬Ј rintro N вЯ®hcop, e, d, h1e, heE, hdвЯ©
    rcases Nat.lt_or_ge e 2 with he1 | he2
    ¬Ј exact Or.inl вЯ®hcop, d, by rwa [show e = 1 by omega] at hdвЯ©
    ¬Ј exact Or.inr вЯ®e, Finset.mem_Icc.mpr вЯ®he2, heEвЯ©, hcop, d, hdвЯ©
  ¬Ј exact (small_e_one_littleO E hE).or (CountIsLittleO_biUnion _ _ (fun e he =>
      e_ge_two_littleO E e (Finset.mem_Icc.mp he).1 (Finset.mem_Icc.mp he).2))

/-- All elements of `S E` are positive. -/
lemma S_pos (E : вДХ) : вИА q вИИ S E, 0 < q := by
  intro q hq
  rw [S, Finset.mem_insert] at hq
  rcases hq with rfl | hq
  ¬Ј norm_num
  ¬Ј simp only [Finset.mem_biUnion, Finset.mem_image] at hq
    obtain вЯ®e, _, R, _, rflвЯ© := hq
    rw [qER]; exact Nat.minFac_pos _

lemma Qpr_pos (E : вДХ) : 0 < Qpr E := Finset.prod_pos (S_pos E)

/-- `ќі_E = вИП_{p вИ£ Q_E} (1 - 1/p)` (Euler product form of the totient density). -/
lemma delta_eq_prod (E : вДХ) :
    ќі E = вИП p вИИ (Qpr E).primeFactors, (1 - 1 / (p : вДЭ)) := by
  have hQ0 : (Qpr E : вДЭ) вЙ† 0 := by have := Qpr_pos E; positivity
  rw [ќі]
  have hr : (Nat.totient (Qpr E) : вДЭ)
      = (Qpr E : вДЭ) * вИП p вИИ (Qpr E).primeFactors, (1 - (p : вДЭ)вБї¬є) := by
    have hcast := congrArg (fun x : вДЪ => (x : вДЭ)) (Nat.totient_eq_mul_prod_factors (Qpr E))
    push_cast at hcast
    exact hcast
  rw [hr, mul_comm (Qpr E : вДЭ), mul_div_assoc, div_self hQ0, mul_one]
  apply Finset.prod_congr rfl
  intro p _
  rw [one_div]

/-- The reduced numerator `Aval e R` is bounded by `E^(E+2)` (the lowest-terms numerator
divides the common-denominator numerator `e¬ЈвИС (E-1)!/r`). -/
lemma Aval_le (E e : вДХ) (R : Finset вДХ) (he : e вЙ§ E) (hR : R вКЖ Finset.Ico 1 e) :
    Aval e R вЙ§ E ^ (E + 2) := by
  rcases Nat.eq_zero_or_pos e with rfl | hepos
  ¬Ј simp [Aval]
  set Dn : вДХ := Nat.factorial (E - 1) with hDn
  have hDnpos : 0 < Dn := Nat.factorial_pos (E - 1)
  have hrdvd : вИА r вИИ R, r вИ£ Dn := fun r hr => by
    have hmem := hR hr; rw [Finset.mem_Ico] at hmem
    exact Nat.dvd_factorial (by omega) (by omega)
  set An : вДХ := e * вИС r вИИ R, Dn / r with hAn
  have hDn0 : (Dn : вДЪ) вЙ† 0 := by exact_mod_cast hDnpos.ne'
  have hVeq : (e : вДЪ) * вИС r вИИ R, (1 : вДЪ) / r = Rat.divInt (An : вД§) (Dn : вД§) := by
    rw [Rat.divInt_eq_div, Int.cast_natCast, Int.cast_natCast,
      eq_div_iff (by exact_mod_cast hDnpos.ne' : (Dn : вДЪ) вЙ† 0), hAn]
    push_cast
    rw [mul_assoc, Finset.sum_mul]
    congr 1
    refine Finset.sum_congr rfl (fun r hr => ?_)
    have hr0 : (r : вДЪ) вЙ† 0 := by
      have hmem := hR hr; rw [Finset.mem_Ico] at hmem
      exact Nat.cast_ne_zero.mpr (by omega)
    rw [Nat.cast_div (hrdvd r hr) hr0, one_div, inv_mul_eq_div]
  have hAval_le_An : Aval e R вЙ§ An := by
    rcases Nat.eq_zero_or_pos An with hA0 | hApos
    ¬Ј rw [Aval, hVeq, hA0]; simp
    ¬Ј have hdvd : (Aval e R : вД§) вИ£ (An : вД§) := by
        rw [Aval]
        have hnd := Rat.num_dvd (An : вД§) (b := (Dn : вД§)) (by exact_mod_cast hDnpos.ne')
        rw [вЖР hVeq] at hnd
        rwa [Int.natAbs_dvd]
      exact Nat.le_of_dvd hApos (by exact_mod_cast hdvd)
  have hAn_le : An вЙ§ E ^ (E + 2) := by
    rw [hAn]
    calc e * вИС r вИИ R, Dn / r
        вЙ§ E * (R.card * Dn) := by
          refine Nat.mul_le_mul he ?_
          calc вИС r вИИ R, Dn / r вЙ§ вИС _r вИИ R, Dn := Finset.sum_le_sum (fun r _ => Nat.div_le_self _ _)
            _ = R.card * Dn := by rw [Finset.sum_const, smul_eq_mul]
      _ вЙ§ E * (E * E ^ E) := by
          refine Nat.mul_le_mul_left _ (Nat.mul_le_mul ?_ ?_)
          ¬Ј calc R.card вЙ§ (Finset.Ico 1 e).card := Finset.card_le_card hR
              _ = e - 1 := by rw [Nat.card_Ico]
              _ вЙ§ E := by omega
          ¬Ј calc Dn вЙ§ (E - 1) ^ (E - 1) := Nat.factorial_le_pow _
              _ вЙ§ E ^ E := le_trans (Nat.pow_le_pow_left (by omega) (E - 1))
                  (Nat.pow_le_pow_right (by omega) (by omega))
      _ = E ^ (E + 2) := by ring
  omega

/-- The chosen prime `qER e R` is bounded by `E^(E+2)`. -/
lemma qER_le (E e : вДХ) (R : Finset вДХ) (hE : 2 вЙ§ E) (he : e вЙ§ E) (hR : R вКЖ Finset.Ico 1 e) :
    qER e R вЙ§ E ^ (E + 2) := by
  rw [qER]
  rcases Nat.eq_zero_or_pos (Aval e R) with h0 | hpos
  ¬Ј rw [h0, Nat.minFac_zero]
    calc 2 вЙ§ E := hE
      _ вЙ§ E ^ (E + 2) := Nat.le_self_pow (by omega) E
  ¬Ј exact le_trans (Nat.minFac_le hpos) (Aval_le E e R he hR)

/-- Every prime factor of `Q_E` is at most `E^(E+2)`. -/
lemma primeFactors_Qpr_le (E : вДХ) (hE : 2 вЙ§ E) :
    вИА p вИИ (Qpr E).primeFactors, p вЙ§ E ^ (E + 2) := by
  intro p hp
  obtain вЯ®hpp, hpdvd, _вЯ© := Nat.mem_primeFactors.1 hp
  rw [Qpr] at hpdvd
  obtain вЯ®q, hqS, hpqвЯ© := hpp.prime.exists_mem_finset_dvd hpdvd
  have hqle : q вЙ§ E ^ (E + 2) := by
    rw [S, Finset.mem_insert] at hqS
    rcases hqS with rfl | hqS
    ¬Ј calc 2 вЙ§ E := hE
        _ вЙ§ E ^ (E + 2) := Nat.le_self_pow (by omega) E
    ¬Ј simp only [Finset.mem_biUnion, Finset.mem_image] at hqS
      obtain вЯ®e, hemem, R, hRmem, rflвЯ© := hqS
      rw [Finset.mem_Icc] at hemem
      rw [Finset.mem_powerset] at hRmem
      exact qER_le E e R hE hemem.2 hRmem
  exact le_trans (Nat.le_of_dvd (S_pos E q hqS) hpq) hqle

/-- **Density of the sifted set, lower bound** (paper Lemma 5.4). -/
theorem sift_density_lb (hDeep : DeepInputs) :
    вИГ cвВБ : вДЭ, 0 < cвВБ вИІ вИА E : вДХ, 2 вЙ§ E вЖТ
      cвВБ / ((E : вДЭ) * Real.log (2 * E)) вЙ§ ќі E := by
  obtain вЯ®cвВА, hcвВА, hmertensвЯ© := hDeep.mertens_lb
  refine вЯ®cвВА / 3, by positivity, fun E hE => ?_вЯ©
  have hE2R : (2 : вДЭ) вЙ§ E := by exact_mod_cast hE
  have hY2 : 2 вЙ§ E ^ (E + 2) := by
    calc 2 вЙ§ E := hE
      _ вЙ§ E ^ (E + 2) := Nat.le_self_pow (by omega) E
  have hYR : (2 : вДЭ) вЙ§ (E ^ (E + 2) : вДХ) := by exact_mod_cast hY2
  have hsub : (Qpr E).primeFactors вКЖ (Finset.range (E ^ (E + 2) + 1)).filter Nat.Prime := by
    intro p hp
    rw [Finset.mem_filter, Finset.mem_range]
    exact вЯ®by have := primeFactors_Qpr_le E hE p hp; omega, (Nat.mem_primeFactors.1 hp).1вЯ©
  have hmono : вИП p вИИ (Finset.range (E ^ (E + 2) + 1)).filter Nat.Prime, (1 - 1 / (p : вДЭ))
      вЙ§ вИП p вИИ (Qpr E).primeFactors, (1 - 1 / (p : вДЭ)) := by
    rw [вЖР Finset.prod_sdiff hsub]
    apply mul_le_of_le_one_left
    ¬Ј apply Finset.prod_nonneg
      intro p hp
      have hpp := (Nat.mem_primeFactors.1 hp).1
      have hp1 : (1 : вДЭ) вЙ§ p := by have := hpp.two_le; exact_mod_cast (show 1 вЙ§ p by omega)
      have : 1 / (p : вДЭ) вЙ§ 1 := by rw [div_le_one (by linarith)]; exact hp1
      linarith
    ¬Ј apply Finset.prod_le_one
      ¬Ј intro p hp
        have hpp : p.Prime := (Finset.mem_filter.1 (Finset.mem_sdiff.1 hp).1).2
        have hp1 : (1 : вДЭ) вЙ§ p := by have := hpp.two_le; exact_mod_cast (show 1 вЙ§ p by omega)
        have : 1 / (p : вДЭ) вЙ§ 1 := by rw [div_le_one (by linarith)]; exact hp1
        linarith
      ¬Ј intro p hp
        have hpp : p.Prime := (Finset.mem_filter.1 (Finset.mem_sdiff.1 hp).1).2
        have hppos : (0 : вДЭ) < p := by have := hpp.pos; exact_mod_cast this
        have : 0 вЙ§ 1 / (p : вДЭ) := by positivity
        linarith
  have hA2 := hmertens (E ^ (E + 2)) hY2
  have hElogpos : 0 < (E : вДЭ) * Real.log (2 * E) := by
    apply mul_pos (by linarith)
    exact Real.log_pos (by nlinarith [hE2R])
  have hlogYpos : 0 < Real.log (2 * (E ^ (E + 2) : вДХ)) :=
    Real.log_pos (by nlinarith [hYR])
  have hlog : Real.log (2 * (E ^ (E + 2) : вДХ)) вЙ§ 3 * ((E : вДЭ) * Real.log (2 * E)) := by
    have hElog : Real.log (2 * (E : вДЭ)) = Real.log 2 + Real.log E :=
      Real.log_mul (by norm_num) (by positivity)
    have hYlog : Real.log (2 * (E ^ (E + 2) : вДХ)) = Real.log 2 + (E + 2 : вДЭ) * Real.log E := by
      push_cast
      rw [Real.log_mul (by norm_num) (by positivity), Real.log_pow]
      push_cast; ring
    rw [hYlog, hElog]
    have hlogE : 0 вЙ§ Real.log (E : вДЭ) := Real.log_nonneg (by exact_mod_cast (show 1 вЙ§ E by omega))
    have hlog2 : 0 вЙ§ Real.log 2 := Real.log_nonneg (by norm_num)
    nlinarith [hlogE, hlog2, hE2R]
  rw [delta_eq_prod]
  calc cвВА / 3 / ((E : вДЭ) * Real.log (2 * E))
      = cвВА / (3 * ((E : вДЭ) * Real.log (2 * E))) := by rw [div_div]
    _ вЙ§ cвВА / Real.log (2 * (E ^ (E + 2) : вДХ)) := by
        rw [div_le_div_iffвВА (by linarith) hlogYpos]
        exact mul_le_mul_of_nonneg_left hlog hcвВА.le
    _ вЙ§ вИП p вИИ (Finset.range (E ^ (E + 2) + 1)).filter Nat.Prime, (1 - 1 / (p : вДЭ)) := hA2
    _ вЙ§ вИП p вИИ (Qpr E).primeFactors, (1 - 1 / (p : вДЭ)) := hmono

/-- The sifted set has lower density at least `ќі_E` (paper Lemma 5.4, counting). -/
theorem sift_lowerDensity (E : вДХ) (hE : 2 вЙ§ E) :
    ќі E вЙ§ lowerDensity (fun N => Nat.Coprime N (Qpr E)) := by
  have hSpos : вИА q вИИ S E, 0 < q := by
    intro q hq
    rw [S, Finset.mem_insert] at hq
    rcases hq with rfl | hq
    ¬Ј norm_num
    ¬Ј simp only [Finset.mem_biUnion, Finset.mem_image] at hq
      obtain вЯ®e, _, R, _, rflвЯ© := hq
      rw [qER]; exact Nat.minFac_pos _
  have hQpos : 0 < Qpr E := Finset.prod_pos hSpos
  have hQR : (0 : вДЭ) < Qpr E := by exact_mod_cast hQpos
  have hѕЖpos : 0 < Nat.totient (Qpr E) := Nat.totient_pos.2 hQpos
  -- counting via finsets
  have hcard : вИА X, countUpTo (fun n => Nat.Coprime n (Qpr E)) X
      = ((Finset.range (X + 1)).filter (fun n => Nat.Coprime n (Qpr E))).card := by
    intro X
    have hset : setUpTo (fun n => Nat.Coprime n (Qpr E)) X
        = вЖС((Finset.range (X + 1)).filter (fun n => Nat.Coprime n (Qpr E))) := by
      ext n
      simp only [setUpTo, Set.mem_setOf_eq, Finset.coe_filter, Finset.mem_range, Nat.lt_succ_iff]
    unfold countUpTo
    rw [hset, Set.ncard_coe_finset]
  -- per-block count: each block of length `Q` has exactly `ѕЖ Q` coprimes
  have hblock : вИА B : вДХ,
      ((Finset.range (Qpr E * B)).filter (fun n => Nat.Coprime n (Qpr E))).card
        = B * Nat.totient (Qpr E) := by
    intro B
    induction B with
    | zero => simp
    | succ b ih =>
      have hu : Finset.range (Qpr E * (b + 1))
          = Finset.range (Qpr E * b) вИ™ Finset.Ico (Qpr E * b) (Qpr E * b + Qpr E) := by
        rw [Finset.range_eq_Ico, Finset.range_eq_Ico,
          Finset.Ico_union_Ico_eq_Ico (Nat.zero_le _) (by omega), Nat.mul_succ]
      have hdisj : Disjoint (Finset.range (Qpr E * b))
          (Finset.Ico (Qpr E * b) (Qpr E * b + Qpr E)) := by
        rw [Finset.range_eq_Ico]
        exact Finset.Ico_disjoint_Ico_consecutive 0 (Qpr E * b) (Qpr E * b + Qpr E)
      have hbk : ((Finset.Ico (Qpr E * b) (Qpr E * b + Qpr E)).filter
          (fun n => Nat.Coprime n (Qpr E))).card = Nat.totient (Qpr E) := by
        rw [вЖР Nat.filter_coprime_Ico_eq_totient (Qpr E) (Qpr E * b)]
        congr 1
        apply Finset.filter_congr
        intro x _
        exact вЯ®fun h => Nat.coprime_comm.1 h, fun h => Nat.coprime_comm.1 hвЯ©
      rw [hu, Finset.filter_union,
        Finset.card_union_of_disjoint (Finset.disjoint_filter_filter hdisj), ih, hbk]
      ring
  -- lower bound on the count, for `X вЙ• 1`
  have hlb : вИА X : вДХ, 1 вЙ§ X вЖТ
      ќі E - (Nat.totient (Qpr E) : вДЭ) / X
        вЙ§ (countUpTo (fun n => Nat.Coprime n (Qpr E)) X : вДЭ) / X := by
    intro X hX1
    have hXpos : (0 : вДЭ) < X := by exact_mod_cast hX1
    have hdm := Nat.div_add_mod (X + 1) (Qpr E)
    have hmod : (X + 1) % Qpr E < Qpr E := Nat.mod_lt _ hQpos
    have hQBle : Qpr E * ((X + 1) / Qpr E) вЙ§ X + 1 := by
      rw [mul_comm]; exact Nat.div_mul_le_self _ _
    have hcountlb : (X + 1) / Qpr E * Nat.totient (Qpr E)
        вЙ§ countUpTo (fun n => Nat.Coprime n (Qpr E)) X := by
      rw [hcard, вЖР hblock ((X + 1) / Qpr E)]
      apply Finset.card_le_card
      intro n hn
      rw [Finset.mem_filter, Finset.mem_range] at hn вКҐ
      exact вЯ®lt_of_lt_of_le hn.1 hQBle, hn.2вЯ©
    have hcountlb' : ((X + 1) / Qpr E : вДХ) * (Nat.totient (Qpr E) : вДЭ)
        вЙ§ (countUpTo (fun n => Nat.Coprime n (Qpr E)) X : вДЭ) := by exact_mod_cast hcountlb
    have hXle : (X : вДЭ) вЙ§ (Qpr E : вДЭ) * (((X + 1) / Qpr E : вДХ) + 1) := by
      have : X + 1 < Qpr E * ((X + 1) / Qpr E + 1) := by rw [Nat.mul_succ]; omega
      have h2 : (X : вДЭ) + 1 < (Qpr E : вДЭ) * (((X + 1) / Qpr E : вДХ) + 1) := by exact_mod_cast this
      linarith
    rw [ќі]
    rw [div_sub_div _ _ (ne_of_gt hQR) (ne_of_gt hXpos), div_le_div_iffвВА (by positivity) hXpos]
    have hѕЖR : (0 : вДЭ) вЙ§ (Nat.totient (Qpr E) : вДЭ) := by positivity
    nlinarith [mul_le_mul_of_nonneg_left hXle (mul_nonneg hѕЖR hXpos.le),
      mul_le_mul_of_nonneg_left hcountlb' (mul_nonneg hQR.le hXpos.le), hXpos, hQR, hѕЖR]
  -- conclude `ќі E вЙ§ liminf (count / X)`
  rw [lowerDensity]
  apply le_of_forall_pos_le_add
  intro ќµ hќµ
  have hѕЖtend : Tendsto (fun X : вДХ => (Nat.totient (Qpr E) : вДЭ) / X) atTop (nhds 0) := by
    simpa using (tendsto_const_nhds (x := (Nat.totient (Qpr E) : вДЭ))).div_atTop
      tendsto_natCast_atTop_atTop
  have hcobdd : IsCoboundedUnder (¬Ј вЙ• ¬Ј) atTop
      (fun X : вДХ => (countUpTo (fun n => Nat.Coprime n (Qpr E)) X : вДЭ) / X) := by
    refine вЯ®2, fun z hz => ?_вЯ©
    rw [eventually_map] at hz
    obtain вЯ®X, hXвЯ© := hz.exists
    exact le_trans hX (countUpTo_div_le_two _ X)
  have hev : вИАбґ† X : вДХ in atTop,
      ќі E - ќµ вЙ§ (countUpTo (fun n => Nat.Coprime n (Qpr E)) X : вДЭ) / X := by
    filter_upwards [hѕЖtend (Iio_mem_nhds hќµ), eventually_ge_atTop 1] with X hѕЖX hX1
    have hh := hlb X hX1
    simp only [Set.mem_preimage, Set.mem_Iio] at hѕЖX
    linarith [hh, hѕЖX]
  have hfin : ќі E - ќµ вЙ§
      liminf (fun X : вДХ => (countUpTo (fun n => Nat.Coprime n (Qpr E)) X : вДЭ) / X) atTop :=
    le_liminf_of_le hcobdd hev
  linarith [hfin]



/-! ## Section 6 -- Second moment with the cofactor retained (Lem 6.1) and large-cofactor bound (Prop 6.3; counts PAIRS, not values). -/








/-- Single-variable `p`-series in `вДЭвЙ•0вИЮ`: `Sp p = вИС' n, ofReal (n^{-p})`. -/
noncomputable def Sp (p : вДЭ) : вДЭвЙ•0вИЮ := вИС' n : вДХ, ENNReal.ofReal ((n : вДЭ) ^ (-p))

/-- For `1 < p`, the `p`-series is finite. -/
lemma Sp_ne_top {p : вДЭ} (hp : 1 < p) : Sp p вЙ† вК§ := by
  have hf : вИА r : вДХ, (0 : вДЭ) вЙ§ (r : вДЭ) ^ (-p) := fun r => Real.rpow_nonneg (by positivity) _
  have hsum : Summable (fun r : вДХ => (r : вДЭ) ^ (-p)) := by
    have heq : (fun r : вДХ => (r : вДЭ) ^ (-p)) = (fun r : вДХ => 1 / (r : вДЭ) ^ p) := by
      funext r; rw [Real.rpow_neg (by positivity), one_div]
    rw [heq]; exact (Real.summable_one_div_nat_rpow).mpr hp
  rw [Sp, вЖР ENNReal.ofReal_tsum_of_nonneg hf hsum]
  exact ENNReal.ofReal_ne_top

/-- The `p`-series is strictly positive (the `n = 1` term is `1`). -/
lemma Sp_pos {p : вДЭ} : 0 < Sp p := by
  rw [Sp]
  refine lt_of_lt_of_le ?_ (ENNReal.le_tsum 1)
  rw [Nat.cast_one, Real.one_rpow]
  simp

/-- Two-factor product `tsum` factorization. -/
lemma tsum_mul_prod {ќ± ќ≤ : Type*} (f : ќ± вЖТ вДЭвЙ•0вИЮ) (g : ќ≤ вЖТ вДЭвЙ•0вИЮ) :
    (вИС' p : ќ± √Ч ќ≤, f p.1 * g p.2) = (вИС' a, f a) * (вИС' b, g b) := by
  rw [ENNReal.tsum_prod']
  rw [show (вИС' (a : ќ±) (b : ќ≤), f a * g b) = вИС' (a : ќ±), f a * (вИС' b, g b) from
    tsum_congr (fun a => ENNReal.tsum_mul_left)]
  rw [ENNReal.tsum_mul_right]

/-- Factorization of a seven-fold `tsum` into a product of single-variable sums
(right-associated). -/
lemma tsum7 (fвВБ fвВВ fвВГ : вДХ вЖТ вДЭвЙ•0вИЮ) :
    (вИС' p : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ,
      fвВБ p.1 * fвВВ p.2.1 * fвВВ p.2.2.1 * fвВВ p.2.2.2.1 * fвВГ p.2.2.2.2.1
        * fвВГ p.2.2.2.2.2.1 * fвВГ p.2.2.2.2.2.2)
      = (вИС' a, fвВБ a) * ((вИС' a, fвВВ a) * ((вИС' a, fвВВ a) * ((вИС' a, fвВВ a)
          * ((вИС' a, fвВГ a) * ((вИС' a, fвВГ a) * (вИС' a, fвВГ a)))))) := by
  have e1 : (вИС' p : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ,
      fвВБ p.1 * fвВВ p.2.1 * fвВВ p.2.2.1 * fвВВ p.2.2.2.1 * fвВГ p.2.2.2.2.1
        * fвВГ p.2.2.2.2.2.1 * fвВГ p.2.2.2.2.2.2)
      = вИС' p : вДХ √Ч (вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ),
        fвВБ p.1 * (fвВВ p.2.1 * fвВВ p.2.2.1 * fвВВ p.2.2.2.1 * fвВГ p.2.2.2.2.1
          * fвВГ p.2.2.2.2.2.1 * fвВГ p.2.2.2.2.2.2) := tsum_congr (fun p => by ring)
  have e2 : (вИС' q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ,
      fвВВ q.1 * fвВВ q.2.1 * fвВВ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2.1 * fвВГ q.2.2.2.2.2)
      = вИС' q : вДХ √Ч (вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ),
        fвВВ q.1 * (fвВВ q.2.1 * fвВВ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2.1 * fвВГ q.2.2.2.2.2) :=
    tsum_congr (fun q => by ring)
  have e3 : (вИС' q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ,
      fвВВ q.1 * fвВВ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2)
      = вИС' q : вДХ √Ч (вДХ √Ч вДХ √Ч вДХ √Ч вДХ),
        fвВВ q.1 * (fвВВ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2) :=
    tsum_congr (fun q => by ring)
  have e4 : (вИС' q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ, fвВВ q.1 * fвВГ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2)
      = вИС' q : вДХ √Ч (вДХ √Ч вДХ √Ч вДХ),
        fвВВ q.1 * (fвВГ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2) :=
    tsum_congr (fun q => by ring)
  have e5 : (вИС' q : вДХ √Ч вДХ √Ч вДХ, fвВГ q.1 * fвВГ q.2.1 * fвВГ q.2.2)
      = вИС' q : вДХ √Ч (вДХ √Ч вДХ), fвВГ q.1 * (fвВГ q.2.1 * fвВГ q.2.2) :=
    tsum_congr (fun q => by ring)
  rw [e1, tsum_mul_prod fвВБ (fun q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ =>
        fвВВ q.1 * fвВВ q.2.1 * fвВВ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2.1 * fвВГ q.2.2.2.2.2)]
  rw [e2, tsum_mul_prod fвВВ (fun q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ =>
        fвВВ q.1 * fвВВ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2.1 * fвВГ q.2.2.2.2)]
  rw [e3, tsum_mul_prod fвВВ (fun q : вДХ √Ч вДХ √Ч вДХ √Ч вДХ =>
        fвВВ q.1 * fвВГ q.2.1 * fвВГ q.2.2.1 * fвВГ q.2.2.2)]
  rw [e4, tsum_mul_prod fвВВ (fun q : вДХ √Ч вДХ √Ч вДХ => fвВГ q.1 * fвВГ q.2.1 * fвВГ q.2.2)]
  rw [e5, tsum_mul_prod fвВГ (fun q : вДХ √Ч вДХ => fвВГ q.1 * fвВГ q.2)]
  rw [tsum_mul_prod fвВГ fвВГ]

/-- The gcd-decomposition map `(r,s,t) вЖ¶ (h,u,v,w,R,S,T)` recovering the seven-variable
gcd/lcm structure: `h = gcd(r,s,t)`, `u,v,w` the pairwise extra-gcd parts, `R,S,T` the
coprime remainders. -/
noncomputable def decomp (r s t : вДХ) : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ :=
  let h := Nat.gcd r (Nat.gcd s t)
  let u := Nat.gcd r s / h
  let v := Nat.gcd r t / h
  let w := Nat.gcd s t / h
  (h, u, v, w, r / (h * u * v), s / (h * u * w), t / (h * v * w))

/-- **The seven-variable gcd/lcm decomposition** (paper ¬І6.2, the `7 вЖТ 3` injection).
For positive `(r,s,t)`, the components `(h,u,v,w,R,S,T) = decomp r s t` satisfy the
multiplicative identities `r = huvR`, `s = huwS`, `t = hvwT`, are all positive, and
recombine to the lcm: `h¬Јu¬Јv¬Јw¬ЈR¬ЈS¬ЈT = lcm r (lcm s t)`.

This is the prime-by-prime/factorization identity at the heart of the bound, proved by
comparing `p`-adic valuations (`min`/`max` of exponents) via `Nat.eq_of_factorization_eq`. -/
lemma decomp_spec {r s t : вДХ} (hr : 1 вЙ§ r) (hs : 1 вЙ§ s) (ht : 1 вЙ§ t) :
    let d := decomp r s t
    1 вЙ§ d.1 вИІ 1 вЙ§ d.2.1 вИІ 1 вЙ§ d.2.2.1 вИІ 1 вЙ§ d.2.2.2.1 вИІ
      1 вЙ§ d.2.2.2.2.1 вИІ 1 вЙ§ d.2.2.2.2.2.1 вИІ 1 вЙ§ d.2.2.2.2.2.2 вИІ
      r = d.1 * d.2.1 * d.2.2.1 * d.2.2.2.2.1 вИІ
      s = d.1 * d.2.1 * d.2.2.2.1 * d.2.2.2.2.2.1 вИІ
      t = d.1 * d.2.2.1 * d.2.2.2.1 * d.2.2.2.2.2.2 вИІ
      d.1 * d.2.1 * d.2.2.1 * d.2.2.2.1 * d.2.2.2.2.1 * d.2.2.2.2.2.1 * d.2.2.2.2.2.2
        = Nat.lcm r (Nat.lcm s t) := by
  simp only [decomp]
  have hr0 : r вЙ† 0 := by omega
  have hs0 : s вЙ† 0 := by omega
  have ht0 : t вЙ† 0 := by omega
  have hgw0 : Nat.gcd s t вЙ† 0 := by simp only [ne_eq, Nat.gcd_eq_zero_iff]; omega
  have hgu0 : Nat.gcd r s вЙ† 0 := by simp only [ne_eq, Nat.gcd_eq_zero_iff]; omega
  have hgv0 : Nat.gcd r t вЙ† 0 := by simp only [ne_eq, Nat.gcd_eq_zero_iff]; omega
  set h := Nat.gcd r (Nat.gcd s t) with hh_def
  have hh0 : h вЙ† 0 := by rw [hh_def]; simp only [ne_eq, Nat.gcd_eq_zero_iff]; omega
  have hdh_r : h вИ£ r := Nat.gcd_dvd_left _ _
  have hdh_gst : h вИ£ Nat.gcd s t := Nat.gcd_dvd_right _ _
  have hdh_s : h вИ£ s := hdh_gst.trans (Nat.gcd_dvd_left _ _)
  have hdh_t : h вИ£ t := hdh_gst.trans (Nat.gcd_dvd_right _ _)
  have hdh_gu : h вИ£ Nat.gcd r s := Nat.dvd_gcd hdh_r hdh_s
  have hdh_gv : h вИ£ Nat.gcd r t := Nat.dvd_gcd hdh_r hdh_t
  set u := Nat.gcd r s / h with hu_def
  set v := Nat.gcd r t / h with hv_def
  set w := Nat.gcd s t / h with hw_def
  have hu0 : u вЙ† 0 := by
    rw [hu_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero hgu0) hdh_gu)
      (Nat.pos_of_ne_zero hh0)).ne'
  have hv0 : v вЙ† 0 := by
    rw [hv_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero hgv0) hdh_gv)
      (Nat.pos_of_ne_zero hh0)).ne'
  have hw0 : w вЙ† 0 := by
    rw [hw_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero hgw0) hdh_gst)
      (Nat.pos_of_ne_zero hh0)).ne'
  -- per-prime factorizations
  have hfh : вИА p, h.factorization p
      = min (r.factorization p) (min (s.factorization p) (t.factorization p)) := by
    intro p
    rw [hh_def, Nat.factorization_gcd hr0 hgw0, Finsupp.inf_apply,
      Nat.factorization_gcd hs0 ht0, Finsupp.inf_apply]
  have hfu : вИА p, u.factorization p = (Nat.gcd r s).factorization p - h.factorization p := by
    intro p; rw [hu_def, Nat.factorization_div hdh_gu, Finsupp.tsub_apply]
  have hfv : вИА p, v.factorization p = (Nat.gcd r t).factorization p - h.factorization p := by
    intro p; rw [hv_def, Nat.factorization_div hdh_gv, Finsupp.tsub_apply]
  have hfw : вИА p, w.factorization p = (Nat.gcd s t).factorization p - h.factorization p := by
    intro p; rw [hw_def, Nat.factorization_div hdh_gst, Finsupp.tsub_apply]
  have hfgu : вИА p, (Nat.gcd r s).factorization p
      = min (r.factorization p) (s.factorization p) := by
    intro p; rw [Nat.factorization_gcd hr0 hs0, Finsupp.inf_apply]
  have hfgv : вИА p, (Nat.gcd r t).factorization p
      = min (r.factorization p) (t.factorization p) := by
    intro p; rw [Nat.factorization_gcd hr0 ht0, Finsupp.inf_apply]
  have hfgw : вИА p, (Nat.gcd s t).factorization p
      = min (s.factorization p) (t.factorization p) := by
    intro p; rw [Nat.factorization_gcd hs0 ht0, Finsupp.inf_apply]
  -- the three key divisibilities
  have key_huv : h * u * v вИ£ r := by
    rw [вЖР Nat.factorization_le_iff_dvd (mul_ne_zero (mul_ne_zero hh0 hu0) hv0) hr0, Finsupp.le_def]
    intro p
    rw [Nat.factorization_mul (mul_ne_zero hh0 hu0) hv0,
      Nat.factorization_mul hh0 hu0, Finsupp.add_apply, Finsupp.add_apply,
      hfu p, hfv p, hfh p, hfgu p, hfgv p]
    omega
  have key_huw : h * u * w вИ£ s := by
    rw [вЖР Nat.factorization_le_iff_dvd (mul_ne_zero (mul_ne_zero hh0 hu0) hw0) hs0, Finsupp.le_def]
    intro p
    rw [Nat.factorization_mul (mul_ne_zero hh0 hu0) hw0,
      Nat.factorization_mul hh0 hu0, Finsupp.add_apply, Finsupp.add_apply,
      hfu p, hfw p, hfh p, hfgu p, hfgw p]
    omega
  have key_hvw : h * v * w вИ£ t := by
    rw [вЖР Nat.factorization_le_iff_dvd (mul_ne_zero (mul_ne_zero hh0 hv0) hw0) ht0, Finsupp.le_def]
    intro p
    rw [Nat.factorization_mul (mul_ne_zero hh0 hv0) hw0,
      Nat.factorization_mul hh0 hv0, Finsupp.add_apply, Finsupp.add_apply,
      hfv p, hfw p, hfh p, hfgv p, hfgw p]
    omega
  set R := r / (h * u * v) with hR_def
  set S := s / (h * u * w) with hS_def
  set T := t / (h * v * w) with hT_def
  have hR0 : R вЙ† 0 := by
    rw [hR_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero hr0) key_huv)
      (Nat.pos_of_ne_zero (mul_ne_zero (mul_ne_zero hh0 hu0) hv0))).ne'
  have hS0 : S вЙ† 0 := by
    rw [hS_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero hs0) key_huw)
      (Nat.pos_of_ne_zero (mul_ne_zero (mul_ne_zero hh0 hu0) hw0))).ne'
  have hT0 : T вЙ† 0 := by
    rw [hT_def]
    exact (Nat.div_pos (Nat.le_of_dvd (Nat.pos_of_ne_zero ht0) key_hvw)
      (Nat.pos_of_ne_zero (mul_ne_zero (mul_ne_zero hh0 hv0) hw0))).ne'
  -- identities
  have hrid : r = h * u * v * R := by rw [hR_def, Nat.mul_div_cancel' key_huv]
  have hsid : s = h * u * w * S := by rw [hS_def, Nat.mul_div_cancel' key_huw]
  have htid : t = h * v * w * T := by rw [hT_def, Nat.mul_div_cancel' key_hvw]
  -- factorizations of R, S, T
  have hfR : вИА p, R.factorization p
      = r.factorization p - (h.factorization p + u.factorization p + v.factorization p) := by
    intro p
    rw [hR_def, Nat.factorization_div key_huv, Finsupp.tsub_apply,
      Nat.factorization_mul (mul_ne_zero hh0 hu0) hv0, Nat.factorization_mul hh0 hu0,
      Finsupp.add_apply, Finsupp.add_apply]
  have hfS : вИА p, S.factorization p
      = s.factorization p - (h.factorization p + u.factorization p + w.factorization p) := by
    intro p
    rw [hS_def, Nat.factorization_div key_huw, Finsupp.tsub_apply,
      Nat.factorization_mul (mul_ne_zero hh0 hu0) hw0, Nat.factorization_mul hh0 hu0,
      Finsupp.add_apply, Finsupp.add_apply]
  have hfT : вИА p, T.factorization p
      = t.factorization p - (h.factorization p + v.factorization p + w.factorization p) := by
    intro p
    rw [hT_def, Nat.factorization_div key_hvw, Finsupp.tsub_apply,
      Nat.factorization_mul (mul_ne_zero hh0 hv0) hw0, Nat.factorization_mul hh0 hv0,
      Finsupp.add_apply, Finsupp.add_apply]
  -- the lcm identity
  have hlcm : h * u * v * w * R * S * T = Nat.lcm r (Nat.lcm s t) := by
    apply Nat.eq_of_factorization_eq
      (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero
        hh0 hu0) hv0) hw0) hR0) hS0) hT0)
      (by simp only [ne_eq, Nat.lcm_eq_zero_iff]; omega)
    intro p
    rw [Nat.factorization_mul (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero
        hh0 hu0) hv0) hw0) hR0) hS0) hT0,
      Nat.factorization_mul (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero
        hh0 hu0) hv0) hw0) hR0) hS0,
      Nat.factorization_mul (mul_ne_zero (mul_ne_zero (mul_ne_zero
        hh0 hu0) hv0) hw0) hR0,
      Nat.factorization_mul (mul_ne_zero (mul_ne_zero hh0 hu0) hv0) hw0,
      Nat.factorization_mul (mul_ne_zero hh0 hu0) hv0,
      Nat.factorization_mul hh0 hu0]
    simp only [Finsupp.add_apply]
    rw [hfR p, hfS p, hfT p, hfu p, hfv p, hfw p, hfh p, hfgu p, hfgv p, hfgw p,
      Nat.factorization_lcm hr0 (by simp only [ne_eq, Nat.lcm_eq_zero_iff]; omega),
      Finsupp.sup_apply, Nat.factorization_lcm hs0 ht0, Finsupp.sup_apply]
    omega
  -- positivity in the final shape
  refine вЯ®Nat.one_le_iff_ne_zero.mpr hh0, Nat.one_le_iff_ne_zero.mpr hu0,
    Nat.one_le_iff_ne_zero.mpr hv0, Nat.one_le_iff_ne_zero.mpr hw0,
    Nat.one_le_iff_ne_zero.mpr hR0, Nat.one_le_iff_ne_zero.mpr hS0,
    Nat.one_le_iff_ne_zero.mpr hT0, hrid, hsid, htid, hlcmвЯ©

/-- The pointwise power-saving estimate, given the seven-variable decomposition data. -/
lemma decomp_pointwise {e r s t h u v w R S T : вДХ}
    (he : 1 вЙ§ e) (hre : e вЙ§ r) (hse : e вЙ§ s) (hte : e вЙ§ t)
    (hh : 1 вЙ§ h) (hu : 1 вЙ§ u) (hv : 1 вЙ§ v) (hw : 1 вЙ§ w)
    (hR : 1 вЙ§ R) (hS : 1 вЙ§ S) (hT : 1 вЙ§ T)
    (hrid : r = h * u * v * R) (hsid : s = h * u * w * S) (htid : t = h * v * w * T)
    (hlcm : h * u * v * w * R * S * T = Nat.lcm r (Nat.lcm s t)) :
    (1 : вДЭ) / ((r * s * t * Nat.lcm r (Nat.lcm s t) : вДХ) : вДЭ)
      вЙ§ (e : вДЭ) ^ (-(5 / 2 : вДЭ)) *
          ((h : вДЭ) ^ (-(3 / 2 : вДЭ)) * (u : вДЭ) ^ (-(4 / 3 : вДЭ)) * (v : вДЭ) ^ (-(4 / 3 : вДЭ))
            * (w : вДЭ) ^ (-(4 / 3 : вДЭ)) * (R : вДЭ) ^ (-(7 / 6 : вДЭ)) * (S : вДЭ) ^ (-(7 / 6 : вДЭ))
            * (T : вДЭ) ^ (-(7 / 6 : вДЭ))) := by
  -- real positivity facts
  have heR : (1 : вДЭ) вЙ§ (e : вДЭ) := by exact_mod_cast he
  have hhR : (1 : вДЭ) вЙ§ (h : вДЭ) := by exact_mod_cast hh
  have huR : (1 : вДЭ) вЙ§ (u : вДЭ) := by exact_mod_cast hu
  have hvR : (1 : вДЭ) вЙ§ (v : вДЭ) := by exact_mod_cast hv
  have hwR : (1 : вДЭ) вЙ§ (w : вДЭ) := by exact_mod_cast hw
  have hRR : (1 : вДЭ) вЙ§ (R : вДЭ) := by exact_mod_cast hR
  have hSR : (1 : вДЭ) вЙ§ (S : вДЭ) := by exact_mod_cast hS
  have hTR : (1 : вДЭ) вЙ§ (T : вДЭ) := by exact_mod_cast hT
  have he0 : (0 : вДЭ) < (e : вДЭ) := by linarith
  have hh0 : (0 : вДЭ) < (h : вДЭ) := by linarith
  have hu0 : (0 : вДЭ) < (u : вДЭ) := by linarith
  have hv0 : (0 : вДЭ) < (v : вДЭ) := by linarith
  have hw0 : (0 : вДЭ) < (w : вДЭ) := by linarith
  have hR0 : (0 : вДЭ) < (R : вДЭ) := by linarith
  have hS0 : (0 : вДЭ) < (S : вДЭ) := by linarith
  have hT0 : (0 : вДЭ) < (T : вДЭ) := by linarith
  -- the lcm is positive
  have hLpos : 0 < Nat.lcm r (Nat.lcm s t) :=
    Nat.pos_of_ne_zero (by simp only [ne_eq, Nat.lcm_eq_zero_iff]; omega)
  have hL0 : (0 : вДЭ) < (Nat.lcm r (Nat.lcm s t) : вДЭ) := by exact_mod_cast hLpos
  -- `r*s*t = Q := h^3 u^2 v^2 w^2 R S T`
  set Q : вДЭ := (h : вДЭ) ^ 3 * (u : вДЭ) ^ 2 * (v : вДЭ) ^ 2 * (w : вДЭ) ^ 2 * R * S * T with hQdef
  have hrstQ : (r : вДЭ) * s * t = Q := by
    have : (r : вДЭ) = (h : вДЭ) * u * v * R := by exact_mod_cast hrid
    have hs' : (s : вДЭ) = (h : вДЭ) * u * w * S := by exact_mod_cast hsid
    have ht' : (t : вДЭ) = (h : вДЭ) * v * w * T := by exact_mod_cast htid
    rw [this, hs', ht', hQdef]; ring
  -- `e^3 вЙ§ r*s*t = Q`
  have hrste3 : (e : вДЭ) ^ 3 вЙ§ Q := by
    rw [вЖР hrstQ]
    have : (e : вДЭ) ^ 3 = (e : вДЭ) * e * e := by ring
    rw [this]
    have h1 : (e : вДЭ) * e вЙ§ (r : вДЭ) * s := by
      apply mul_le_mul (by exact_mod_cast hre) (by exact_mod_cast hse) he0.le
      linarith [(by exact_mod_cast hre : (e:вДЭ) вЙ§ r)]
    apply mul_le_mul h1 (by exact_mod_cast hte) he0.le
    nlinarith [(by exact_mod_cast hre : (e:вДЭ) вЙ§ r), (by exact_mod_cast hse : (e:вДЭ) вЙ§ s)]
  -- `G := h^4 u^3 v^3 w^3 R^2 S^2 T^2 вЙ§ r*s*t*lcm`
  set G : вДЭ := (h : вДЭ) ^ 4 * (u : вДЭ) ^ 3 * (v : вДЭ) ^ 3 * (w : вДЭ) ^ 3
      * (R : вДЭ) ^ 2 * (S : вДЭ) ^ 2 * (T : вДЭ) ^ 2 with hGdef
  have hLeq : (Nat.lcm r (Nat.lcm s t) : вДЭ)
      = (h : вДЭ) * u * v * w * R * S * T := by
    have : ((h * u * v * w * R * S * T : вДХ) : вДЭ) = (Nat.lcm r (Nat.lcm s t) : вДЭ) := by
      exact_mod_cast hlcm
    rw [вЖР this]; push_cast; ring
  have hGle : G вЙ§ (r : вДЭ) * s * t * (Nat.lcm r (Nat.lcm s t) : вДЭ) := by
    rw [hrstQ, hLeq, hGdef, hQdef]; apply le_of_eq; ring
  -- `B := e^{5/2}¬ЈP_pos`, the denominator we compare against; `B вЙ§ G`
  set Ppos : вДЭ := (h : вДЭ) ^ (3 / 2 : вДЭ) * (u : вДЭ) ^ (4 / 3 : вДЭ) * (v : вДЭ) ^ (4 / 3 : вДЭ)
      * (w : вДЭ) ^ (4 / 3 : вДЭ) * (R : вДЭ) ^ (7 / 6 : вДЭ) * (S : вДЭ) ^ (7 / 6 : вДЭ)
      * (T : вДЭ) ^ (7 / 6 : вДЭ) with hPposdef
  set B : вДЭ := (e : вДЭ) ^ (5 / 2 : вДЭ) * Ppos with hBdef
  have hBpos : 0 < B := by
    rw [hBdef, hPposdef]; positivity
  -- `M := e^15 h^9 u^8 v^8 w^8 R^7 S^7 T^7` (all natural powers), and `B = M^{1/6}`
  set M : вДЭ := (e : вДЭ) ^ 15 * (h : вДЭ) ^ 9 * (u : вДЭ) ^ 8 * (v : вДЭ) ^ 8 * (w : вДЭ) ^ 8
      * (R : вДЭ) ^ 7 * (S : вДЭ) ^ 7 * (T : вДЭ) ^ 7 with hMdef
  have hsixth : вИА (x : вДЭ) (k : вДХ) (c : вДЭ), 0 вЙ§ x вЖТ (k : вДЭ) * (1 / 6) = c вЖТ
      (x ^ k) ^ (1 / 6 : вДЭ) = x ^ c := by
    intro x k c hx hc
    rw [вЖР Real.rpow_natCast x k, вЖР Real.rpow_mul hx, hc]
  have hBM : B = M ^ (1 / 6 : вДЭ) := by
    rw [hMdef]
    rw [Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity),
        Real.mul_rpow (by positivity) (by positivity)]
    rw [hsixth _ 15 (5 / 2) he0.le (by norm_num), hsixth _ 9 (3 / 2) hh0.le (by norm_num),
        hsixth _ 8 (4 / 3) hu0.le (by norm_num), hsixth _ 8 (4 / 3) hv0.le (by norm_num),
        hsixth _ 8 (4 / 3) hw0.le (by norm_num), hsixth _ 7 (7 / 6) hR0.le (by norm_num),
        hsixth _ 7 (7 / 6) hS0.le (by norm_num), hsixth _ 7 (7 / 6) hT0.le (by norm_num)]
    rw [hBdef, hPposdef]; ring
  -- `M вЙ§ G^6`, hence `B = M^{1/6} вЙ§ (G^6)^{1/6} = G`
  have hMG : M вЙ§ G ^ 6 := by
    have hK : (0 : вДЭ) вЙ§ (h : вДЭ) ^ 9 * (u : вДЭ) ^ 8 * (v : вДЭ) ^ 8 * (w : вДЭ) ^ 8
        * (R : вДЭ) ^ 7 * (S : вДЭ) ^ 7 * (T : вДЭ) ^ 7 := by positivity
    have hMK : M = (e : вДЭ) ^ 15 * ((h : вДЭ) ^ 9 * (u : вДЭ) ^ 8 * (v : вДЭ) ^ 8 * (w : вДЭ) ^ 8
        * (R : вДЭ) ^ 7 * (S : вДЭ) ^ 7 * (T : вДЭ) ^ 7) := by rw [hMdef]; ring
    have hG6K : G ^ 6 = Q ^ 5 * ((h : вДЭ) ^ 9 * (u : вДЭ) ^ 8 * (v : вДЭ) ^ 8 * (w : вДЭ) ^ 8
        * (R : вДЭ) ^ 7 * (S : вДЭ) ^ 7 * (T : вДЭ) ^ 7) := by rw [hGdef, hQdef]; ring
    rw [hMK, hG6K]
    refine mul_le_mul_of_nonneg_right ?_ hK
    calc (e : вДЭ) ^ 15 = ((e : вДЭ) ^ 3) ^ 5 := by ring
      _ вЙ§ Q ^ 5 := pow_le_pow_leftвВА (by positivity) hrste3 5
  have hG0 : (0 : вДЭ) вЙ§ G := by rw [hGdef]; positivity
  have hBG : B вЙ§ G := by
    rw [hBM]
    calc M ^ (1 / 6 : вДЭ) вЙ§ (G ^ 6) ^ (1 / 6 : вДЭ) :=
          Real.rpow_le_rpow (by rw [hMdef]; positivity) hMG (by norm_num)
      _ = G := by rw [hsixth _ 6 (1 : вДЭ) hG0 (by norm_num), Real.rpow_one]
  -- chain: `B вЙ§ G вЙ§ r*s*t*lcm`, so `1/(r*s*t*lcm) вЙ§ 1/B`
  have hBD : B вЙ§ (r : вДЭ) * s * t * (Nat.lcm r (Nat.lcm s t) : вДЭ) := le_trans hBG hGle
  have hDpos : (0 : вДЭ) < (r : вДЭ) * s * t * (Nat.lcm r (Nat.lcm s t) : вДЭ) := by
    have hr0 : (0:вДЭ) < r := by exact_mod_cast (by omega : 0 < r)
    have hs0 : (0:вДЭ) < s := by exact_mod_cast (by omega : 0 < s)
    have ht0 : (0:вДЭ) < t := by exact_mod_cast (by omega : 0 < t)
    positivity
  -- the target RHS equals `1/B`
  have hRHS : (e : вДЭ) ^ (-(5 / 2 : вДЭ)) *
      ((h : вДЭ) ^ (-(3 / 2 : вДЭ)) * (u : вДЭ) ^ (-(4 / 3 : вДЭ)) * (v : вДЭ) ^ (-(4 / 3 : вДЭ))
        * (w : вДЭ) ^ (-(4 / 3 : вДЭ)) * (R : вДЭ) ^ (-(7 / 6 : вДЭ)) * (S : вДЭ) ^ (-(7 / 6 : вДЭ))
        * (T : вДЭ) ^ (-(7 / 6 : вДЭ))) = 1 / B := by
    rw [hBdef, hPposdef]
    rw [Real.rpow_neg he0.le, Real.rpow_neg hh0.le, Real.rpow_neg hu0.le, Real.rpow_neg hv0.le,
        Real.rpow_neg hw0.le, Real.rpow_neg hR0.le, Real.rpow_neg hS0.le, Real.rpow_neg hT0.le]
    ring
  rw [hRHS]
  -- finally compare reciprocals
  have hcast : ((r * s * t * Nat.lcm r (Nat.lcm s t) : вДХ) : вДЭ)
      = (r : вДЭ) * s * t * (Nat.lcm r (Nat.lcm s t) : вДЭ) := by push_cast; ring
  rw [hcast]
  exact one_div_le_one_div_of_le hBpos hBD

-- ==== PURE SECOND-MOMENT CHAIN (paper Lemmas 6.1/6.2; replaces the T3 route; verified in Erdos1054SecondMoment.lean) ====

noncomputable def U (E : вДХ) : вДЭвЙ•0вИЮ :=
  вИС' t : вДХ √Ч вДХ √Ч вДХ,
    (if E < t.1 вИІ t.1 вЙ§ t.2.1 вИІ t.1 вЙ§ t.2.2 then
      ENNReal.ofReal
        (1 / ((t.2.1 * t.2.2 * Nat.lcm t.1 (Nat.lcm t.2.1 t.2.2) : вДХ) : вДЭ))
    else 0)

-- ==== SM brick 2: the paper's Lemma 6.2, U(E) вЙ§ Cen¬ЈE^{вИТ3/2} ====

/-- **Power-saving second-moment tail, `вДЭвЙ•0вИЮ` form** (paper Lemma 6.2):
    `U(E) вЙ§ E^{вИТ3/2}¬Јќґ(3/2)ќґ(4/3)¬≥ќґ(7/6)¬≥`, via the reused 7-variable decomposition вАФ
    the extraction `1/(rs[e,r,s]) = e¬Ј(1/(ers[e,r,s])) вЙ§ e¬Јe^{вИТ5/2}¬Ј(...) вЙ§ E^{вИТ3/2}¬Ј(...)`. -/
theorem U_le_ennreal (E : вДХ) (hE : 1 вЙ§ E) :
    U E вЙ§ ENNReal.ofReal ((E : вДЭ) ^ (-(3 / 2 : вДЭ)))
      * (Sp (3 / 2) * Sp (4 / 3) * Sp (4 / 3) * Sp (4 / 3)
          * Sp (7 / 6) * Sp (7 / 6) * Sp (7 / 6)) := by
  classical
  set gвВБ : вДХ вЖТ вДЭвЙ•0вИЮ := fun n => ENNReal.ofReal ((n : вДЭ) ^ (-(3 / 2 : вДЭ))) with hg1
  set gвВВ : вДХ вЖТ вДЭвЙ•0вИЮ := fun n => ENNReal.ofReal ((n : вДЭ) ^ (-(4 / 3 : вДЭ))) with hg2
  set gвВГ : вДХ вЖТ вДЭвЙ•0вИЮ := fun n => ENNReal.ofReal ((n : вДЭ) ^ (-(7 / 6 : вДЭ))) with hg3
  have hS1 : (вИС' n, gвВБ n) = Sp (3 / 2) := rfl
  have hS2 : (вИС' n, gвВВ n) = Sp (4 / 3) := rfl
  have hS3 : (вИС' n, gвВГ n) = Sp (7 / 6) := rfl
  -- the bound function on seven-tuples, with the E-prefactor
  set b : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ вЖТ вДЭвЙ•0вИЮ := fun d =>
    ENNReal.ofReal ((E : вДЭ) ^ (-(3 / 2 : вДЭ))) *
      (gвВБ d.1 * gвВВ d.2.1 * gвВВ d.2.2.1 * gвВВ d.2.2.2.1 * gвВГ d.2.2.2.2.1
        * gвВГ d.2.2.2.2.2.1 * gвВГ d.2.2.2.2.2.2) with hb
  set Sset : Set (вДХ √Ч вДХ √Ч вДХ) := {p | E < p.1 вИІ p.1 вЙ§ p.2.1 вИІ p.1 вЙ§ p.2.2} with hSset
  set fS : вДХ √Ч вДХ √Ч вДХ вЖТ вДЭвЙ•0вИЮ := fun p =>
    ENNReal.ofReal (1 / ((p.2.1 * p.2.2 * Nat.lcm p.1 (Nat.lcm p.2.1 p.2.2) : вДХ) : вДЭ))
    with hfS
  have hUeq : U E = вИС' p : Sset, fS p := by
    have h1 : U E = вИС' x : вДХ √Ч вДХ √Ч вДХ, Sset.indicator fS x := by
      rw [U]
      refine tsum_congr (fun p => ?_)
      rw [Set.indicator_apply]
      simp only [hSset, hfS, Set.mem_setOf_eq]
    rw [h1]; exact (tsum_subtype Sset fS).symm
  -- the injection into seven-tuples
  set F : Sset вЖТ вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ := fun p => decomp p.1.1 p.1.2.1 p.1.2.2 with hF
  have hone : вИА p : Sset, 1 вЙ§ p.1.1 вИІ 1 вЙ§ p.1.2.1 вИІ 1 вЙ§ p.1.2.2 := by
    rintro p
    have hp := p.2
    simp only [hSset, Set.mem_setOf_eq] at hp
    omega
  have hFinj : Function.Injective F := by
    intro a c hac
    obtain вЯ®har, has, hatвЯ© := hone a
    obtain вЯ®hcr, hcs, hctвЯ© := hone c
    have spa := decomp_spec (r := a.1.1) (s := a.1.2.1) (t := a.1.2.2) har has hat
    have spc := decomp_spec (r := c.1.1) (s := c.1.2.1) (t := c.1.2.2) hcr hcs hct
    simp only at spa spc
    obtain вЯ®_, _, _, _, _, _, _, hra, hsa, hta, _вЯ© := spa
    obtain вЯ®_, _, _, _, _, _, _, hrc, hsc, htc, _вЯ© := spc
    simp only [hF] at hac
    apply Subtype.ext
    apply Prod.ext
    ¬Ј rw [hra, hrc, hac]
    apply Prod.ext
    ¬Ј rw [hsa, hsc, hac]
    ¬Ј rw [hta, htc, hac]
  -- pointwise bound with the √Чe extraction
  have hpt : вИА p : Sset, fS p вЙ§ b (F p) := by
    rintro p
    have hp := p.2
    simp only [hSset, Set.mem_setOf_eq] at hp
    obtain вЯ®hpE, hps, hpt'вЯ© := hp
    have hpe1 : 1 вЙ§ p.1.1 := by omega
    have sp := decomp_spec (r := p.1.1) (s := p.1.2.1) (t := p.1.2.2)
      hpe1 (by omega) (by omega)
    simp only at sp
    obtain вЯ®hh, hu, hv, hw, hRR, hSS, hTT, hrid, hsid, htid, hlcmвЯ© := sp
    have hpw := decomp_pointwise (e := p.1.1) (r := p.1.1) (s := p.1.2.1) (t := p.1.2.2)
      (h := (decomp p.1.1 p.1.2.1 p.1.2.2).1)
      (u := (decomp p.1.1 p.1.2.1 p.1.2.2).2.1)
      (v := (decomp p.1.1 p.1.2.1 p.1.2.2).2.2.1)
      (w := (decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.1)
      (R := (decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.1)
      (S := (decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.1)
      (T := (decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.2)
      hpe1 le_rfl hps hpt' hh hu hv hw hRR hSS hTT hrid hsid htid hlcm
    -- multiply by e and absorb: 1/(rsL) = e¬Ј(1/(ersL)) вЙ§ e¬Јe^{вИТ5/2}¬Јprod = e^{вИТ3/2}¬Јprod вЙ§ E^{вИТ3/2}¬Јprod
    have he0R : (0 : вДЭ) < (p.1.1 : вДЭ) := by exact_mod_cast hpe1
    have hE0R : (0 : вДЭ) < (E : вДЭ) := by exact_mod_cast hE
    have hEe : (E : вДЭ) вЙ§ (p.1.1 : вДЭ) := by exact_mod_cast hpE.le
    have hLpos : 0 < Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) :=
      Nat.pos_of_ne_zero (by
        simp only [ne_eq, Nat.lcm_eq_zero_iff]
        push_neg
        omega)
    have hrsL0 : (0 : вДЭ) < ((p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ) := by
      have h1 : 0 < p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) := by
        have h2 : 0 < p.1.2.1 := by omega
        have h3 : 0 < p.1.2.2 := by omega
        positivity
      exact_mod_cast h1
    have hsplit : (1 : вДЭ) / ((p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ)
        = (p.1.1 : вДЭ) * ((1 : вДЭ)
            / ((p.1.1 * p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ)) := by
      have h1 : (0:вДЭ) < (p.1.2.1 : вДЭ) := by exact_mod_cast (by omega : 0 < p.1.2.1)
      have h2 : (0:вДЭ) < (p.1.2.2 : вДЭ) := by exact_mod_cast (by omega : 0 < p.1.2.2)
      have h3 : (0:вДЭ) < ((Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ) := by
        exact_mod_cast hLpos
      push_cast
      rw [mul_one_div, eq_comm,
        div_eq_div_iff (mul_pos (mul_pos (mul_pos he0R h1) h2) h3).ne'
          (mul_pos (mul_pos h1 h2) h3).ne']
      ring
    have hexp : (p.1.1 : вДЭ) * (p.1.1 : вДЭ) ^ (-(5 / 2 : вДЭ)) = (p.1.1 : вДЭ) ^ (-(3 / 2 : вДЭ)) := by
      nth_rewrite 1 [show (p.1.1 : вДЭ) = (p.1.1 : вДЭ) ^ (1 : вДЭ) from (Real.rpow_one _).symm]
      rw [вЖР Real.rpow_add he0R]
      norm_num
    have hmono : (p.1.1 : вДЭ) ^ (-(3 / 2 : вДЭ)) вЙ§ (E : вДЭ) ^ (-(3 / 2 : вДЭ)) :=
      Real.rpow_le_rpow_of_nonpos hE0R hEe (by norm_num)
    have hreal : (1 : вДЭ) / ((p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ)
        вЙ§ (E : вДЭ) ^ (-(3 / 2 : вДЭ)) *
            (((decomp p.1.1 p.1.2.1 p.1.2.2).1 : вДЭ) ^ (-(3 / 2 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.1 : вДЭ) ^ (-(7 / 6 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.1 : вДЭ) ^ (-(7 / 6 : вДЭ))
              * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.2 : вДЭ) ^ (-(7 / 6 : вДЭ))) := by
      set prod7 : вДЭ := ((decomp p.1.1 p.1.2.1 p.1.2.2).1 : вДЭ) ^ (-(3 / 2 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.1 : вДЭ) ^ (-(4 / 3 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.1 : вДЭ) ^ (-(7 / 6 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.1 : вДЭ) ^ (-(7 / 6 : вДЭ))
          * ((decomp p.1.1 p.1.2.1 p.1.2.2).2.2.2.2.2.2 : вДЭ) ^ (-(7 / 6 : вДЭ)) with hprod7
      have hprod70 : 0 вЙ§ prod7 := by
        rw [hprod7]
        positivity
      calc (1 : вДЭ) / ((p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ)
          = (p.1.1 : вДЭ) * ((1 : вДЭ)
              / ((p.1.1 * p.1.2.1 * p.1.2.2 * Nat.lcm p.1.1 (Nat.lcm p.1.2.1 p.1.2.2) : вДХ) : вДЭ)) :=
            hsplit
        _ вЙ§ (p.1.1 : вДЭ) * ((p.1.1 : вДЭ) ^ (-(5 / 2 : вДЭ)) * prod7) := by
            apply mul_le_mul_of_nonneg_left _ he0R.le
            rw [hprod7]
            exact hpw
        _ = (p.1.1 : вДЭ) ^ (-(3 / 2 : вДЭ)) * prod7 := by
            rw [вЖР mul_assoc, hexp]
        _ вЙ§ (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * prod7 :=
            mul_le_mul_of_nonneg_right hmono hprod70
    simp only [hfS, hF, hb, hg1, hg2, hg3]
    refine le_trans (ENNReal.ofReal_le_ofReal hreal) (le_of_eq ?_)
    rw [ENNReal.ofReal_mul (by positivity), ENNReal.ofReal_mul (by positivity),
        ENNReal.ofReal_mul (by positivity), ENNReal.ofReal_mul (by positivity),
        ENNReal.ofReal_mul (by positivity), ENNReal.ofReal_mul (by positivity),
        ENNReal.ofReal_mul (by positivity)]
  -- assemble
  rw [hUeq]
  calc (вИС' p : Sset, fS p) вЙ§ вИС' p : Sset, b (F p) := ENNReal.tsum_le_tsum hpt
    _ вЙ§ вИС' d, b d := ENNReal.tsum_comp_le_tsum_of_injective hFinj b
    _ = ENNReal.ofReal ((E : вДЭ) ^ (-(3 / 2 : вДЭ))) *
          (вИС' d : вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ √Ч вДХ,
