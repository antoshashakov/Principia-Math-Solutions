end Quad341

/-- **THE UNIFORM ZERO-FREE REGION FOR QUADRATIC CHARACTERS OFF THE REAL AXIS**
    (SW brick S4a-6): one absolute `C` with: every zero `ќ≤ + iќ≥`, `ќ≥ вЙ† 0`, of every
    quadratic nontrivial `ѕЗ` mod `N` satisfies
    `ќ≤ вЙ§ 1 вИТ 1/(C(log(N(4|ќ≥|+7)) + 20))` вАФ the conjugate-pair repulsion for small
    `|ќ≥|`, the damped 3-4-1 for the rest. Only REAL zeros (Siegel) remain. -/
theorem dvp_zero_free_uniform_quadratic :
    вИГ C : вДЭ, 1 вЙ§ C вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N),
      ѕЗ вЙ† 1 вЖТ ѕЗ ^ 2 = 1 вЖТ вИА ќ≤ ќ≥ : вДЭ, ќ≥ вЙ† 0 вЖТ
      DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ) + ќ≥*Complex.I) = 0 вЖТ
      ќ≤ вЙ§ 1 - 1/(C * (Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20)) := by
  obtain вЯ®Cp, hCp1, hCpвЯ© := quad_pair_gap
  obtain вЯ®Cq, hCq1, hCqвЯ© := quad_341_gap Cp hCp1
  refine вЯ®max Cp Cq, le_trans hCp1 (le_max_left _ _), ?_вЯ©
  intro N _ ѕЗ hѕЗ1 hѕЗ2 ќ≤ ќ≥ hќ≥ hzero
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hg0 : (0:вДЭ) вЙ§ |ќ≥| := abs_nonneg ќ≥
  have harg1 : (1:вДЭ) вЙ§ (N:вДЭ) * (4*|ќ≥|+7) := by nlinarith
  have hL0 : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*|ќ≥|+7)) := Real.log_nonneg harg1
  obtain вЯ®LвВА, hLвВАdefвЯ© : вИГ Lv : вДЭ, Lv = Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLвВАdef] at вКҐ
  have hL20 : 20 вЙ§ LвВА := by rw [hLвВАdef]; linarith
  have hmono : вИА Cbr : вДЭ, 1 вЙ§ Cbr вЖТ Cbr вЙ§ max Cp Cq вЖТ
      1/(max Cp Cq * LвВА) вЙ§ 1/(Cbr * LвВА) := by
    intro Cbr hCbr1 hCbrle
    apply div_le_div_of_nonneg_left (by norm_num) (by nlinarith [hL20])
    nlinarith [hL20, hCbr1]
  by_cases hsmall : |ќ≥| * (Cp * LвВА) вЙ§ 1
  ¬Ј have h1 := hCp N ѕЗ hѕЗ1 hѕЗ2 ќ≤ ќ≥ hќ≥ hzero (by rw [hLвВАdef] at hsmall; exact hsmall)
    rw [вЖР hLвВАdef] at h1
    have h2 := hmono Cp hCp1 (le_max_left _ _)
    linarith [h1, h2]
  ¬Ј push_neg at hsmall
    have h1 := hCq N ѕЗ hѕЗ1 hѕЗ2 ќ≤ ќ≥ hzero
      (by rw [hLвВАdef] at hsmall; linarith [hsmall])
    rw [вЖР hLвВАdef] at h1
    have h2 := hmono Cq hCq1 (le_max_right _ _)
    linarith [h1, h2]

