  have hLHS1 : 8/(5*(ѕГ-ќ≤)) вЙ§ 2*(ѕГ-ќ≤)/((ѕГ-ќ≤)^2+ќ≥^2) := by
    rw [div_le_div_iffвВА (by linarith : (0:вДЭ) < 5*(ѕГ-ќ≤)) hden0]
    nlinarith [hden]
  have hLHS2 : 8/(15*((1-ќ≤)+|ќ≥|)) вЙ§ 8/(5*(ѕГ-ќ≤)) := by
    apply div_le_div_of_nonneg_left (by norm_num : (0:вДЭ) вЙ§ 8) (by linarith : (0:вДЭ) < 5*(ѕГ-ќ≤))
    linarith [hu3x]
  have hkey : 1/(30*((1-ќ≤)+|ќ≥|)) вЙ§ K' + 40 + 40*Real.log ((N:вДЭ)*7*ѕГ/(ѕГ-1)) := by
    have h1 : 8/(15*((1-ќ≤)+|ќ≥|)) - 1/(2*((1-ќ≤)+|ќ≥|)) = 1/(30*((1-ќ≤)+|ќ≥|)) := by
      field_simp
