    have hu11pos : (0:вДЭ) < u ^ (11:вДЭ) := Real.rpow_pos_of_pos hu0 _
    have h11 : Real.log (60 * B * u ^ (11:вДЭ)) вЙ§ Real.log X - (1:вДЭ)/2 * u := by
