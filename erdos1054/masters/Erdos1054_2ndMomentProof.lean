    have h2 : 12 * u ^ ((1:вДЭ)/4) вЙ§ u/4 := by
      have h3 : 48 * u ^ ((1:вДЭ)/4) вЙ§ u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) := by
        calc 48 * u ^ ((1:вДЭ)/4) вЙ§ (16 * u ^ ((1:вДЭ)/4)) * 4 := by ring_nf; nlinarith [hq0]
          _ вЙ§ (u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/4)) * u ^ ((1:вДЭ)/4) := by
              apply mul_le_mul _ h4q (by norm_num) (by positivity)
              apply mul_le_mul_of_nonneg_right h16 hq0.le
          _ = u ^ ((1:вДЭ)/2) * (u ^ ((1:вДЭ)/4) * u ^ ((1:вДЭ)/4)) := by ring
          _ = u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) := by rw [hqq]
      rw [hss] at h3
      linarith
    -- u/2 вИТ (c/8)вИЪu вЙ• u/4: (c/8)вИЪu вЙ§ вИЪu/16 вЙ§ u/4
    have h5 : (c/8) * u ^ ((1:вДЭ)/2) вЙ§ u/4 := by
      have h6 : (c/8) * u ^ ((1:вДЭ)/2) вЙ§ (1/16) * u ^ ((1:вДЭ)/2) := by
        apply mul_le_mul_of_nonneg_right (by linarith) hs0.le
      have h7 : u ^ ((1:вДЭ)/2) вЙ§ u := by
        calc u ^ ((1:вДЭ)/2) = 1 * u ^ ((1:вДЭ)/2) := (one_mul _).symm
          _ вЙ§ u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) := by
              apply mul_le_mul_of_nonneg_right _ hs0.le
              nlinarith [h16]
          _ = u := hss
      linarith
    linarith
  -- assemble
  calc C * u ^ ((5:вДЭ)/2) * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))
        + K * u ^ (3:вДЭ) * Real.exp (-(u/2))
      = C * (u ^ ((5:вДЭ)/2) * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2))))
        + K * (u ^ (3:вДЭ) * Real.exp (-(u/2))) := by ring
    _ вЙ§ C * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) + K * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) :=
        add_le_add (mul_le_mul_of_nonneg_left hterm1 hC0) (mul_le_mul_of_nonneg_left hterm2 hK0)
    _ = (C + K) * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) := by ring

/-- **R4b-pre: modulus-power bounds at `ќµ = 1/(4B)`** вАФ for `1 вЙ§ Nr вЙ§ u^{2B}`, `u вЙ• 1`:
    `Nr^{1/(4B)} вЙ§ u^{1/2}` and `u^{вИТ1/2} вЙ§ Nr^{вИТ1/(4B)} вЙ§ 1` (the `Ne`-window `rate_g_bounds`
    and the `M`-bound need). -/
lemma N_eps_bounds (B : вДЭ) (hB : 1 вЙ§ B) (u Nr : вДЭ) (hu1 : 1 вЙ§ u) (hNr1 : 1 вЙ§ Nr)
    (hNru : Nr вЙ§ u ^ (2*B : вДЭ)) :
    Nr ^ ((1:вДЭ)/(4*B)) вЙ§ u ^ ((1:вДЭ)/2) вИІ
    u ^ (-(1:вДЭ)/2) вЙ§ Nr ^ (-((1:вДЭ)/(4*B))) вИІ Nr ^ (-((1:вДЭ)/(4*B))) вЙ§ 1 := by
  have hu0 : (0:вДЭ) < u := by linarith
  have hNr0 : (0:вДЭ) < Nr := by linarith
  have hB0 : (0:вДЭ) < B := by linarith
  have hќµ0 : (0:вДЭ) < (1:вДЭ)/(4*B) := by positivity
  have hup : Nr ^ ((1:вДЭ)/(4*B)) вЙ§ u ^ ((1:вДЭ)/2) := by
    have h1 : Nr ^ ((1:вДЭ)/(4*B)) вЙ§ (u ^ (2*B : вДЭ)) ^ ((1:вДЭ)/(4*B)) :=
      Real.rpow_le_rpow hNr0.le hNru hќµ0.le
    rwa [вЖР Real.rpow_mul hu0.le, show (2*B) * ((1:вДЭ)/(4*B)) = 1/2 from by
      field_simp
      ring] at h1
  have hpos : (0:вДЭ) < Nr ^ ((1:вДЭ)/(4*B)) := Real.rpow_pos_of_pos hNr0 _
  refine вЯ®hup, ?_, ?_вЯ©
  ¬Ј rw [show (-(1:вДЭ)/2) = -((1:вДЭ)/2) by ring, Real.rpow_neg hu0.le,
      Real.rpow_neg hNr0.le]
    rw [вЖР one_div, вЖР one_div]
    exact one_div_le_one_div_of_le hpos hup
  ¬Ј exact Real.rpow_le_one_of_one_le_of_nonpos hNr1 (neg_nonpos.mpr hќµ0.le)

