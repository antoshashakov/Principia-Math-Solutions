    rw [le_div_iffвВА hd0]
    linarith [hd20]
  have hdW : 1/d = W*LвВА := by
    rw [hddef]
    field_simp
  have hlogd : Real.log (1/d) вЙ§ Real.log W + LвВА := by
    rw [hdW, Real.log_mul (by linarith) (by linarith)]
    have h1 : Real.log LвВА вЙ§ LвВА - 1 := Real.log_le_sub_one_of_pos (by linarith)
    linarith
  -- log(N(2|ќ≥|+7)(1+d)/d) вЙ§ LвВА + log(1/d)
  have hlog1 : Real.log ((N:вДЭ)*(2*|ќ≥|+7)*(1+d)/d) вЙ§ LвВА + Real.log (1/d) := by
    have h1 : (N:вДЭ)*(2*|ќ≥|+7)*(1+d)/d вЙ§ ((N:вДЭ)*(4*|ќ≥|+7)) * (1/d) := by
      rw [div_le_iffвВА hd0]
