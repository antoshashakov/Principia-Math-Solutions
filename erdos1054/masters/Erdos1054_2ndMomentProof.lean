    Route: with `L = (log N)^{1/10}` (so `log N = L^10`), show `L вЙ§ exp(sL)`
    (`s = c/(20k+20)`, via `add_one_le_exp` squared), raise to `10k` to get
    `L^{10k} вЙ§ exp((c/2)L)`, then `exp((c/2)L)¬Јexp(-cL) = exp(-(c/2)L) вЙ§ ќі`. -/
lemma exp_dominates_polylog (c : вДЭ) (hc : 0 < c) (k : вДХ) (ќі : вДЭ) (hќі : 0 < ќі) :
    вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
      (Real.log N) ^ k * Real.exp (-c * (Real.log N) ^ ((1:вДЭ)/10)) вЙ§ ќі := by
  set s : вДЭ := c / (20 * k + 20) with hsdef
  have hs : 0 < s := by rw [hsdef]; positivity
  have hs2 : 0 < s ^ 2 := by positivity
  have hcne : c вЙ† 0 := ne_of_gt hc
  have h10ks : (10 * (k:вДЭ)) * s вЙ§ c / 2 := by
    have hden : (0:вДЭ) < 20 * (k:вДЭ) + 20 := by positivity
    have key : (10 * (k:вДЭ)) * s = (10 * (k:вДЭ) * c) / (20 * (k:вДЭ) + 20) := by rw [hsdef]; ring
    rw [key, div_le_iffвВА hden]
    have hk0 : (0:вДЭ) вЙ§ (k:вДЭ) := by positivity
    nlinarith [hc, hk0, mul_nonneg hk0 hc.le]
  set D : вДЭ := 4 / s ^ 2 + (2 / c) * |Real.log ќі| + 1 with hDdef
  have hD4 : 4 / s ^ 2 вЙ§ D := by
    rw [hDdef]; linarith [mul_nonneg (show (0:вДЭ) вЙ§ 2 / c by positivity) (abs_nonneg (Real.log ќі))]
  have hDlog : (2 / c) * |Real.log ќі| вЙ§ D := by
    rw [hDdef]; linarith [show (0:вДЭ) вЙ§ 4 / s ^ 2 by positivity]
  have hD0 : 0 < D := by rw [hDdef]; positivity
  refine вЯ®Nat.ceil (Real.exp (D ^ 10)) + 1, fun N hN => ?_вЯ©
  have hNexp : Real.exp (D ^ 10) вЙ§ (N:вДЭ) := by
    have h1 : (вМИReal.exp (D ^ 10)вМЙвВК : вДЭ) вЙ§ (N:вДЭ) := by
      have : вМИReal.exp (D ^ 10)вМЙвВК вЙ§ N := by omega
      exact_mod_cast this
    linarith [Nat.le_ceil (Real.exp (D ^ 10))]
  have hexp1 : (1:вДЭ) вЙ§ Real.exp (D ^ 10) := by
    rw [вЖР Real.exp_zero]; exact Real.exp_le_exp.mpr (by positivity)
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := le_trans hexp1 hNexp
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := Real.log_nonneg hN1
  have hlogND : D ^ 10 вЙ§ Real.log N := by
    calc D ^ 10 = Real.log (Real.exp (D ^ 10)) := (Real.log_exp _).symm
      _ вЙ§ Real.log N := Real.log_le_log (Real.exp_pos _) hNexp
  have hlogNpos : (0:вДЭ) < Real.log N := lt_of_lt_of_le (by positivity) hlogND
  set L : вДЭ := Real.log N ^ ((1:вДЭ)/10) with hLdef
  have hL0 : 0 < L := by rw [hLdef]; exact Real.rpow_pos_of_pos hlogNpos _
  have hLpow : L ^ (10 * k) = (Real.log N) ^ k := by
    rw [hLdef, вЖР Real.rpow_natCast (Real.log N ^ ((1:вДЭ)/10)) (10 * k),
        вЖР Real.rpow_mul hlogN0, вЖР Real.rpow_natCast (Real.log N) k]
    congr 1; push_cast; ring
  have hLD : D вЙ§ L := by
    rw [hLdef]
    have hDrw : D = (D ^ 10 : вДЭ) ^ ((1:вДЭ)/10) := by
      rw [вЖР Real.rpow_natCast D 10, вЖР Real.rpow_mul hD0.le]; norm_num
    rw [hDrw]
    exact Real.rpow_le_rpow (by positivity) hlogND (by norm_num)
  have hLexp : L вЙ§ Real.exp (s * L) := by
    have hq := Real.add_one_le_exp (s * L / 2)
    have hsq : Real.exp (s * L) = Real.exp (s * L / 2) * Real.exp (s * L / 2) := by
      rw [вЖР Real.exp_add]; congr 1; ring
    have hpos : (0:вДЭ) вЙ§ s * L / 2 + 1 := by positivity
    have hquad : (s * L / 2 + 1) ^ 2 вЙ§ Real.exp (s * L) := by
      rw [hsq]; nlinarith [mul_le_mul hq hq hpos (Real.exp_pos (s * L / 2)).le]
    have hge : 4 / s ^ 2 вЙ§ L := le_trans hD4 hLD
    have hs2L : (4:вДЭ) вЙ§ L * s ^ 2 := (div_le_iffвВА hs2).mp hge
    have hLs2 : L вЙ§ s ^ 2 * L ^ 2 / 4 := by nlinarith [hs2L, hL0]
    nlinarith [hquad, hLs2, mul_nonneg hs.le hL0.le]
  have hLk : L ^ (10 * k) вЙ§ Real.exp ((10 * (k:вДЭ)) * s * L) := by
    calc L ^ (10 * k) вЙ§ (Real.exp (s * L)) ^ (10 * k) := pow_le_pow_leftвВА hL0.le hLexp (10 * k)
      _ = Real.exp ((10 * (k:вДЭ)) * (s * L)) := by
          rw [вЖР Real.exp_nat_mul]; congr 1; push_cast; ring
      _ = Real.exp ((10 * (k:вДЭ)) * s * L) := by congr 1; ring
  have hexp_neg : Real.exp ((10 * (k:вДЭ)) * s * L) * Real.exp (-c * L) вЙ§ Real.exp (-(c/2) * L) := by
    rw [вЖР Real.exp_add]
    apply Real.exp_le_exp.mpr
    nlinarith [h10ks, hL0.le]
  have hfin : Real.exp (-(c/2) * L) вЙ§ ќі := by
    rw [вЖР Real.le_log_iff_exp_le hќі]
    have h1 : -(c/2) * L вЙ§ -(c/2) * D := by
      nlinarith [mul_nonneg (show (0:вДЭ) вЙ§ c/2 by positivity) (show (0:вДЭ) вЙ§ L - D by linarith [hLD])]
    have hcancel : |Real.log ќі| вЙ§ (c/2) * D := by
      calc |Real.log ќі| = (c/2) * ((2/c) * |Real.log ќі|) := by field_simp
        _ вЙ§ (c/2) * D := mul_le_mul_of_nonneg_left hDlog (by positivity)
    have h2 : -(c/2) * D вЙ§ Real.log ќі := by
      have hneg : -|Real.log ќі| вЙ§ Real.log ќі := neg_abs_le _
      linarith [hcancel, hneg]
    linarith
  calc (Real.log N) ^ k * Real.exp (-c * L)
      = L ^ (10 * k) * Real.exp (-c * L) := by rw [hLpow]
    _ вЙ§ Real.exp ((10 * (k:вДЭ)) * s * L) * Real.exp (-c * L) :=
        mul_le_mul_of_nonneg_right hLk (Real.exp_pos _).le
    _ вЙ§ Real.exp (-(c/2) * L) := hexp_neg
    _ вЙ§ ќі := hfin

