          rw [Real.log_mul (by nlinarith) (by positivity),
            Real.log_mul (by norm_num) (by nlinarith)]
      _ вЙ§ 1 + (LT - 20) + ((1+ќµ)*LT + Real.log (1/c)) := by
          have hlog2le : Real.log 2 вЙ§ 1 := by
            rw [show (1:вДЭ) = Real.log (Real.exp 1) by rw [Real.log_exp]]
            apply Real.log_le_log (by norm_num)
            have := Real.exp_one_gt_d9
            linarith
          have h19 : Real.log ((N:вДЭ)*(4*(T+1)+7)) = LT - 20 := by
            rw [hLTdef]
            ring
          linarith [hlog2le, h19.le, h19.ge, hlog1g]
      _ вЙ§ Kc * LT := by
          rw [hKcdef]
          have h20 : Real.log (1/c) * 1 вЙ§ Real.log (1/c) * LT :=
            mul_le_mul_of_nonneg_left (by linarith) hlogc0
          nlinarith [hLT20, hќµ0, h20]
  have hA0 : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(2*|s.im|+7)*(1+g)/g) := by
    apply Real.log_nonneg
    rw [le_div_iffвВА hg0]
    have p1 : (7:вДЭ) вЙ§ (2*|s.im|+7) := by linarith [abs_nonneg s.im]
    have p2 : (1:вДЭ) вЙ§ 1+g := by linarith
    have p3 : (7:вДЭ) вЙ§ (N:вДЭ)*(2*|s.im|+7) := by nlinarith [hN1r, p1]
    have p4 : (7:вДЭ) вЙ§ (N:вДЭ)*(2*|s.im|+7)*(1+g) := by nlinarith [p3, p2]
