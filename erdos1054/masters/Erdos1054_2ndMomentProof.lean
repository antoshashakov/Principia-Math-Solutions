  have hPlb : C - 1 вЙ§ (P : вДЭ) := by linarith
  have hP1R : (1:вДЭ) вЙ§ (P : вДЭ) := by linarith
  have hP0R : (0:вДЭ) < (P : вДЭ) := by linarith
  have hPsq : (128 / ќµ) ^ 2 вЙ§ (P : вДЭ) := by
    have h1 : (128 / ќµ) ^ 2 + 1 вЙ§ C := le_max_right _ _
    linarith
  have hPleL9 : (P : вДЭ) вЙ§ L ^ 9 := Nat.floor_le (by positivity)
  have hPleN : (P : вДЭ) вЙ§ (N : вДЭ) := by
    have := hNвВБ N hN1'
    rw [one_mul] at this
    exact hPleL9.trans this
  have hPleNnat : P вЙ§ N := by exact_mod_cast hPleN
  set Q : вДХ := N / P with hQdef
  have hQP : (Q + 1) * P вЙ§ 2 * N := by
    have h1 : Q * P вЙ§ N := Nat.div_mul_le_self N P
    have h2 : (Q + 1) * P = Q * P + P := by ring
    omega
  have hQPR : ((Q : вДЭ) + 1) * (P : вДЭ) вЙ§ 2 * (N : вДЭ) := by exact_mod_cast hQP
  have hQ0R : (0:вДЭ) вЙ§ (Q : вДЭ) + 1 := by positivity
  have hsqrtP0 : 0 < Real.sqrt (P : вДЭ) := Real.sqrt_pos.mpr hP0R
  have hsqrtP : 128 / ќµ вЙ§ Real.sqrt (P : вДЭ) := by
    rw [show (128 / ќµ) = Real.sqrt ((128 / ќµ) ^ 2) from (Real.sqrt_sq (by positivity)).symm]
