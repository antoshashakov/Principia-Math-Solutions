          linarith [h3]

/-- **SIEGEL'S THEOREM** (Siegel brick S3c-h, final form): for every `ќµ > 0` there
    is `c(ќµ) > 0` (ineffective) with: every real zero `ќ≤ < 1` of every quadratic
    nontrivial Dirichlet character mod `q вЙ• 3` satisfies `ќ≤ вЙ§ 1 вИТ c¬Јq^{вИТќµ}`. -/
theorem siegel_zero_free (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c : вДЭ, 0 < c вИІ вИА (q : вДХ) [NeZero q], 3 вЙ§ q вЖТ
      вИА ѕЗ : DirichletCharacter вДВ q, ѕЗ ^ 2 = 1 вЖТ ѕЗ вЙ† 1 вЖТ
      вИА ќ≤ : вДЭ, ќ≤ < 1 вЖТ DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ)) = 0 вЖТ
      ќ≤ вЙ§ 1 - c * ((q:вДЭ)) ^ (-ќµ) := by
  rcases le_or_gt ќµ (1/100) with hќµ1 | hќµ1
  ¬Ј exact siegel_zero_free_aux ќµ hќµ0 hќµ1
  ¬Ј obtain вЯ®c, hc0, hcвЯ© := siegel_zero_free_aux (1/100) (by norm_num) (le_refl _)
    refine вЯ®c, hc0, ?_вЯ©
    intro q _ hq3 ѕЗ hѕЗ2 hѕЗ1 ќ≤ hќ≤2 hzero
    have h1 := hc q hq3 ѕЗ hѕЗ2 hѕЗ1 ќ≤ hќ≤2 hzero
    have hq1r : (1:вДЭ) вЙ§ (q:вДЭ) := by
      have : (1:вДХ) вЙ§ q := by omega
      exact_mod_cast this
    have h2 : ((q:вДЭ)) ^ (-ќµ) вЙ§ ((q:вДЭ)) ^ (-(1/100:вДЭ)) :=
      Real.rpow_le_rpow_of_exponent_le hq1r (by linarith)
    have h3 : c * ((q:вДЭ)) ^ (-ќµ) вЙ§ c * ((q:вДЭ)) ^ (-(1/100:вДЭ)) :=
      mul_le_mul_of_nonneg_left h2 hc0.le
    linarith [h1, h3]

/-! ### ================= THE FINAL MERGE (S4b) ================= -/

/-- **THE FINAL ZERO-FREE REGION** (SW brick S4b): for every `ќµ > 0` there is
    `c(ќµ) > 0` (ineffective, via Siegel) with: EVERY zero `ќ≤ + iќ≥` of EVERY
    nontrivial Dirichlet L-function mod `N` satisfies
    `ќ≤ вЙ§ 1 вИТ c¬ЈN^{вИТќµ}/(log(N(4|ќ≥|+7)) + 20)`.
    Non-quadratic: de la Vall√©e-Poussin uniform. Quadratic off-axis: the
    conjugate-pair/damped-3-4-1 region. Quadratic real zeros: Siegel. -/
theorem zero_free_region_final (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c : вДЭ, 0 < c вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
      вИА ќ≤ ќ≥ : вДЭ, DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ) + ќ≥*Complex.I) = 0 вЖТ
      ќ≤ вЙ§ 1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20) := by
  obtain вЯ®CвВБ, hCвВБ1, hCвВБвЯ© := dvp_zero_free_uniform
  obtain вЯ®CвВВ, hCвВВ1, hCвВВвЯ© := dvp_zero_free_uniform_quadratic
  obtain вЯ®cвВГ, hcвВГ0, hcвВГвЯ© := siegel_zero_free ќµ hќµ0
  obtain вЯ®c, hcdefвЯ© : вИГ x : вДЭ,
      x = min (min (1/(335*(1360+CвВБ))) (1/CвВВ)) (min (20*cвВГ) 1) := вЯ®_, rflвЯ©
  have hA0 : (0:вДЭ) < 1/(335*(1360+CвВБ)) := by
    apply div_pos one_pos
    nlinarith [hCвВБ1]
  have hB0 : (0:вДЭ) < 1/CвВВ := by
    apply div_pos one_pos
    linarith
  have hc0 : 0 < c := by
    rw [hcdef]
    apply lt_min (lt_min hA0 hB0)
    apply lt_min (by linarith) one_pos
  refine вЯ®c, hc0, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 ќ≤ ќ≥ hzero
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hg0 : (0:вДЭ) вЙ§ |ќ≥| := abs_nonneg ќ≥
  have harg1 : (1:вДЭ) вЙ§ (N:вДЭ) * (4*|ќ≥|+7) := by nlinarith
  have hL0 : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*|ќ≥|+7)) := Real.log_nonneg harg1
  obtain вЯ®LвВА, hLвВАdefвЯ© : вИГ Lv : вДЭ, Lv = Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLвВАdef]
  have hL20 : 20 вЙ§ LвВА := by rw [hLвВАdef]; linarith
  have hNe1 : ((N:вДЭ))^(-ќµ) вЙ§ 1 :=
    Real.rpow_le_one_of_one_le_of_nonpos hN1r (by linarith)
  have hNe0 : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hclose : вИА K : вДЭ, c * ((N:вДЭ))^(-ќµ) вЙ§ K*LвВА вЖТ ќ≤ вЙ§ 1 - K вЖТ
      ќ≤ вЙ§ 1 - c*((N:вДЭ))^(-ќµ)/LвВА := by
    intro K hK hќ≤
    have h1 : c*((N:вДЭ))^(-ќµ)/LвВА вЙ§ K := by
      rw [div_le_iffвВА (by linarith : (0:вДЭ) < LвВА)]
      linarith [hK]
    linarith [h1, hќ≤]
  by_cases hquad : ѕЗ^2 = 1
  ¬Ј by_cases hќ≥ : ќ≥ = 0
    ¬Ј -- Siegel: the real zero of a quadratic character
      subst hќ≥
      simp only [Complex.ofReal_zero, zero_mul, add_zero] at hzero
      by_cases hN3 : 3 вЙ§ N
      ¬Ј have hќ≤1 : ќ≤ < 1 := by
          by_contra hќ≤'
          push_neg at hќ≤'
          have hre : (1:вДЭ) вЙ§ (((ќ≤:вДЭ):вДВ)).re := by
            rw [Complex.ofReal_re]
            linarith
          exact DirichletCharacter.LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ1) hre hzero
        have h1 := hcвВГ N hN3 ѕЗ hquad hѕЗ1 ќ≤ hќ≤1 hzero
        apply hclose (cвВГ * ((N:вДЭ))^(-ќµ)) _ h1
        have h2 : c вЙ§ 20*cвВГ := by
          rw [hcdef]
          exact le_trans (min_le_right _ _) (min_le_left _ _)
        have h3 : 20*cвВГ вЙ§ cвВГ*LвВА := by nlinarith [hcвВГ0, hL20]
        have h4 := mul_le_mul_of_nonneg_right (le_trans h2 h3) hNe0.le
        have h5 : (cвВГ*LвВА)*((N:вДЭ))^(-ќµ) = (cвВГ*((N:вДЭ))^(-ќµ))*LвВА := by ring
        linarith [h4, h5.le, h5.ge]
      ¬Ј -- no nontrivial character below modulus 3
        push_neg at hN3
        exfalso
        apply hѕЗ1
        have hN1 : 1 вЙ§ N := Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
        interval_cases N
        ¬Ј -- N = 1
          apply MulChar.ext
          intro a
          have ha : вИА b : (ZMod 1)Ћ£, b = 1 := by decide
          rw [ha a]
          simp
        ¬Ј -- N = 2
          apply MulChar.ext
          intro a
          have ha : вИА b : (ZMod 2)Ћ£, b = 1 := by decide
          rw [ha a]
          simp
    ¬Ј -- quadratic, off the real axis
      have h1 := hCвВВ N ѕЗ hѕЗ1 hquad ќ≤ ќ≥ hќ≥ hzero
      rw [вЖР hLвВАdef] at h1
      apply hclose (1/(CвВВ*LвВА)) _ h1
      have h2 : c вЙ§ 1/CвВВ := by
        rw [hcdef]
        exact le_trans (min_le_left _ _) (min_le_right _ _)
      have h3 : c*((N:вДЭ))^(-ќµ) вЙ§ c := by nlinarith [hNe1, hNe0.le, hc0]
      have hCвВВ0 : CвВВ вЙ† 0 := by linarith
      have hLвВАne : LвВА вЙ† 0 := by linarith
      have h4 : (1/(CвВВ*LвВА))*LвВА = 1/CвВВ := by
        field_simp
      linarith [h2, h3, h4.le, h4.ge]
  ¬Ј -- non-quadratic: de la Vall√©e-Poussin
    have h1 := hCвВБ N ѕЗ hѕЗ1 hquad ќ≤ ќ≥ hzero
    rw [вЖР hLвВАdef] at h1
    apply hclose (1/(335*(1360+CвВБ)*LвВА)) _ h1
    have h2 : c вЙ§ 1/(335*(1360+CвВБ)) := by
      rw [hcdef]
      exact le_trans (min_le_left _ _) (min_le_left _ _)
    have h3 : c*((N:вДЭ))^(-ќµ) вЙ§ c := by nlinarith [hNe1, hNe0.le, hc0]
    have hden : (335:вДЭ)*(1360+CвВБ) вЙ† 0 := by nlinarith [hCвВБ1]
    have hLвВАne : LвВА вЙ† 0 := by linarith
    have h4 : (1/(335*(1360+CвВБ)*LвВА))*LвВА = 1/(335*(1360+CвВБ)) := by
      field_simp
    linarith [h2, h3, h4.le, h4.ge]

section LandauCount
open Metric

/-- **Landau with the Jensen zero count** (SW brick B1b): the `landau_LFunction`
    package plus `вИС m вЙ§ 2¬Јlog(N(2|t|+7)ѕГвВА/(ѕГвВАвИТ1))` вАФ everything the contour
    `LвА≤/L` bound consumes about one center. -/
theorem landau_LFunction_count (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ѕГвВА t : вДЭ) (hѕГвВА : 1 < ѕГвВА) (hѕГвВА2 : ѕГвВА вЙ§ 2) :
    вИГ (S : Finset вДВ) (m : вДВ вЖТ вДХ),
      (вИА ѕБ вИИ S, ѕБ вИИ closedBall ((ѕГвВА : вДВ) + t * Complex.I) (1/5) вИІ
        DirichletCharacter.LFunction ѕЗ ѕБ = 0) вИІ
      (вИА ѕБ вИИ S, m ѕБ = analyticOrderNatAt (DirichletCharacter.LFunction ѕЗ) ѕБ) вИІ
      (вИА ѕБ вИИ closedBall ((ѕГвВА : вДВ) + t * Complex.I) (1/5),
        DirichletCharacter.LFunction ѕЗ ѕБ = 0 вЖТ ѕБ вИИ S) вИІ
      (вИА ѕБ вИИ S, 1 вЙ§ m ѕБ) вИІ
      ((вИС ѕБ вИИ S, (m ѕБ : вДЭ)) вЙ§ 2 * Real.log ((N : вДЭ) * (2 * |t| + 7) * ѕГвВА / (ѕГвВА - 1))) вИІ
      вИА z вИИ ball ((ѕГвВА : вДВ) + t * Complex.I) (1/20), (вИА ѕБ вИИ S, z вЙ† ѕБ) вЖТ
        вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) z - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ)вАЦ
          вЙ§ 40 * (Real.log ((N : вДЭ) * (2 * |t| + 7) * ѕГвВА / (ѕГвВА - 1)) + 1) := by
  obtain вЯ®S, m, hSz, hm, hcomp, hmpos, hboundвЯ© := landau_LFunction N ѕЗ hѕЗ ѕГвВА t hѕГвВА hѕГвВА2
  refine вЯ®S, m, hSz, hm, hcomp, hmpos, ?_, hboundвЯ©
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  set c : вДВ := (ѕГвВА : вДВ) + t * Complex.I with hc
  have hcre : c.re = ѕГвВА := by rw [hc]; simp
  have hcnorm : вАЦcвАЦ вЙ§ ѕГвВА + |t| := by
    rw [hc]
    calc вАЦ(ѕГвВА:вДВ) + t*Complex.IвАЦ вЙ§ вАЦ(ѕГвВА:вДВ)вАЦ + вАЦ(t:вДВ)*Complex.IвАЦ := norm_add_le _ _
      _ = |ѕГвВА| + |t| := by
          rw [Complex.norm_real, norm_mul, Complex.norm_I, mul_one, Complex.norm_real]
          simp [Real.norm_eq_abs]
      _ = ѕГвВА + |t| := by rw [abs_of_pos (by linarith)]
  -- the anchor: f c вЙ† 0 with a quantitative lower bound
  have hanchor := LFunction_anchor_quantitative N ѕЗ c (by rw [hcre]; exact hѕГвВА)
  rw [hcre] at hanchor
  have hml0 : (0:вДЭ) < (ѕГвВА-1)/ѕГвВА := by
    apply div_pos <;> linarith
  have hfc0 : DirichletCharacter.LFunction ѕЗ c вЙ† 0 := by
    intro h
    rw [h, norm_zero] at hanchor
    linarith
  -- the sphere bound at radius 2/5
  have hM1 : (1:вДЭ) вЙ§ (N:вДЭ) * (2*|t|+7) := by nlinarith [abs_nonneg t]
  have hfbound : вИА z вИИ sphere c (2/5),
      вАЦDirichletCharacter.LFunction ѕЗ zвАЦ вЙ§ (N:вДЭ) * (2*|t|+7) := by
    intro z hz
    rw [mem_sphere, dist_eq_norm] at hz
    have hzre : (3:вДЭ)/5 вЙ§ z.re := by
      have h1 : |(z - c).re| вЙ§ вАЦz - cвАЦ := Complex.abs_re_le_norm _
      rw [hz] at h1
      have h2 := (abs_le.mp h1).1
      rw [Complex.sub_re, hcre] at h2
      linarith
    have hznorm : вАЦzвАЦ вЙ§ |t| + 12/5 := by
      calc вАЦzвАЦ = вАЦc + (z - c)вАЦ := by ring_nf
        _ вЙ§ вАЦcвАЦ + вАЦz - cвАЦ := norm_add_le _ _
        _ = вАЦcвАЦ + 2/5 := by rw [hz]
        _ вЙ§ (ѕГвВА + |t|) + 2/5 := by linarith [hcnorm]
        _ вЙ§ |t| + 12/5 := by linarith
    have h3 := LFunction_window_bound N ѕЗ hѕЗ (3/5) (|t| + 12/5) (by norm_num)
      (by positivity) z hzre hznorm
    calc вАЦDirichletCharacter.LFunction ѕЗ zвАЦ вЙ§ (N:вДЭ) * (2 + (|t| + 12/5)/(3/5)) := h3
      _ вЙ§ (N:вДЭ) * (2*|t|+7) := by
          apply mul_le_mul_of_nonneg_left _ (by linarith)
          have h6 : (|t| + 12/5)/((3:вДЭ)/5) = (5/3)*|t| + 4 := by ring
          linarith [abs_nonneg t, h6.le, h6.ge]
  -- Jensen
  have hanal : AnalyticOnNhd вДВ (DirichletCharacter.LFunction ѕЗ) (closedBall c (2/5)) :=
    fun z _ => (DirichletCharacter.differentiable_LFunction hѕЗ).analyticAt z
  have hjensen := sum_m_le_jensen (DirichletCharacter.LFunction ѕЗ) c (1/5) (2/5)
    ((N:вДЭ) * (2*|t|+7)) (by norm_num) (by norm_num) hM1 hanal hfc0 hfbound S m hSz hm
  -- massage the bound
  have hlog2 : Real.log ((2:вДЭ)/5 / (1/5)) = Real.log 2 := by norm_num
  rw [hlog2] at hjensen
  have hl2 : (1:вДЭ)/2 вЙ§ Real.log 2 := by
    have := Real.log_two_gt_d9
    linarith
  have hfcpos : (0:вДЭ) < вАЦDirichletCharacter.LFunction ѕЗ cвАЦ := by
    have := norm_nonneg (DirichletCharacter.LFunction ѕЗ c)
    rcases lt_or_eq_of_le this with h | h
    ¬Ј exact h
    ¬Ј exact absurd (norm_eq_zero.mp h.symm) hfc0
  have hargpos : (0:вДЭ) < (N:вДЭ) * (2*|t|+7) * ѕГвВА / (ѕГвВА-1) := by
    apply div_pos (by nlinarith [abs_nonneg t]) (by linarith)
  have hlogmono : Real.log ((N:вДЭ) * (2*|t|+7) / вАЦDirichletCharacter.LFunction ѕЗ cвАЦ)
      вЙ§ Real.log ((N:вДЭ) * (2*|t|+7) * ѕГвВА / (ѕГвВА-1)) := by
    apply Real.log_le_log (by positivity)
    rw [div_le_div_iffвВА hfcpos (by linarith : (0:вДЭ) < ѕГвВА-1)]
    have h4 : (ѕГвВА-1)/ѕГвВА * ѕГвВА = ѕГвВА - 1 := by
      field_simp
    have h5 := mul_le_mul_of_nonneg_left hanchor
      (by nlinarith [abs_nonneg t] : (0:вДЭ) вЙ§ (N:вДЭ) * (2*|t|+7) * ѕГвВА)
    nlinarith [h5, h4.le, h4.ge, hfcpos, hanchor, hml0]
  have hlogpos : (0:вДЭ) вЙ§ Real.log ((N:вДЭ) * (2*|t|+7) * ѕГвВА / (ѕГвВА-1)) := by
    apply Real.log_nonneg
    rw [le_div_iffвВА (by linarith : (0:вДЭ) < ѕГвВА-1)]
    nlinarith [abs_nonneg t]
  calc (вИС ѕБ вИИ S, (m ѕБ : вДЭ))
      вЙ§ Real.log ((N:вДЭ) * (2*|t|+7) / вАЦDirichletCharacter.LFunction ѕЗ cвАЦ) / Real.log 2 :=
        hjensen
    _ вЙ§ Real.log ((N:вДЭ) * (2*|t|+7) * ѕГвВА / (ѕГвВА-1)) / Real.log 2 := by
        rw [div_le_div_iffвВА (by linarith : (0:вДЭ) < Real.log 2)
          (by linarith : (0:вДЭ) < Real.log 2)]
        nlinarith [hlogmono, hl2]
    _ вЙ§ 2 * Real.log ((N:вДЭ) * (2*|t|+7) * ѕГвВА / (ѕГвВА-1)) := by
        rw [div_le_iffвВА (by linarith : (0:вДЭ) < Real.log 2)]
        nlinarith [hlogpos, hl2]

end LandauCount

set_option maxHeartbeats 1000000
open DirichletCharacter Complex Metric

section CrossFileInputs



/-- **Contour-to-zero distance** (SW brick B1a): with the final zero-free region's
    `c(ќµ)`, write `g := c¬ЈN^{вИТќµ}/(log(N(4(T+1)+7))+20)` for the height-`T` window gap.
    Every point `s` with `|Im s| вЙ§ T` and `Re s вЙ• 1 вИТ g/2` keeps distance `вЙ• g/2`
    from every zero of `L(¬Ј,ѕЗ)` within `вАЦs вИТ ѕБвАЦ вЙ§ 1` вАФ the input to the contour
    `LвА≤/L` bound. -/
theorem contour_zero_distance (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c : вДЭ, 0 < c вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА T : вДЭ, 0 вЙ§ T вЖТ вИА s : вДВ, |s.im| вЙ§ T вЖТ
    1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ s.re вЖТ
    вИА ѕБ : вДВ, DirichletCharacter.LFunction ѕЗ ѕБ = 0 вЖТ вАЦs - ѕБвАЦ вЙ§ 1 вЖТ
    c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ вАЦs - ѕБвАЦ := by
  obtain вЯ®c, hc0, hcвЯ© := zero_free_region_final ќµ hќµ0
  refine вЯ®c, hc0, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 T hT0 s hsim hsre ѕБ hѕБz hѕБnear
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hѕБform : ((ѕБ.re : вДЭ) : вДВ) + (ѕБ.im : вДЭ) * Complex.I = ѕБ := Complex.re_add_im ѕБ
  have hzero' : DirichletCharacter.LFunction ѕЗ (((ѕБ.re : вДЭ) : вДВ)
      + (ѕБ.im : вДЭ) * Complex.I) = 0 := by
    rw [hѕБform]
    exact hѕБz
  have h1 := hc N ѕЗ hѕЗ1 ѕБ.re ѕБ.im hzero'
  have him : |ѕБ.im| вЙ§ T + 1 := by
    have h2 : |ѕБ.im - s.im| вЙ§ вАЦѕБ - sвАЦ := by
      have h3 : (ѕБ - s).im = ѕБ.im - s.im := by rw [Complex.sub_im]
      rw [вЖР h3]
      exact Complex.abs_im_le_norm _
    have h4 : вАЦѕБ - sвАЦ = вАЦs - ѕБвАЦ := by
      rw [вЖР norm_neg]
      congr 1
      ring
    have h5 := abs_sub_abs_le_abs_sub ѕБ.im s.im
    linarith [h2, h4.le, h4.ge, hsim, hѕБnear, h5]
  obtain вЯ®LT, hLTdefвЯ© : вИГ x : вДЭ, x = Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 := вЯ®_, rflвЯ©
  obtain вЯ®LѕБ, hLѕБdefвЯ© : вИГ x : вДЭ, x = Real.log ((N:вДЭ)*(4*|ѕБ.im|+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLTdef] at hsre вКҐ
  rw [вЖР hLѕБdef] at h1
  have hg0' : (0:вДЭ) вЙ§ |ѕБ.im| := abs_nonneg _
  have hLѕБ20 : 20 вЙ§ LѕБ := by
    rw [hLѕБdef]
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*|ѕБ.im|+7)) :=
      Real.log_nonneg (by nlinarith)
    linarith
  have hLT20 : 20 вЙ§ LT := by
    rw [hLTdef]
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*(T+1)+7)) :=
