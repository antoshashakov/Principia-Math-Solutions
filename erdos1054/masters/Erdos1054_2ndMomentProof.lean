  ¬Ј -- TAIL: siegel_walfisz at X := t вИТ 1
    have ht1 : 1 вЙ§ t := by
      by_contra hcon
      push_neg at hcon
      have h1 : t = 0 := by omega
      rw [h1] at htail
      simp only [Nat.cast_zero, zero_sub] at htail
