      ¬Ј exact Nat.pos_of_mem_divisors hr.1
      ¬Ј exact (Nat.mem_divisors.mp hr.1).1

theorem activeSet_sum_le_card_mul_e (e a : Nat) :
    (ActiveSet e a).sum (fun r => r) вЙ§ (ActiveSet e a).card * e := by
  calc
    (ActiveSet e a).sum (fun r => r) вЙ§ (ActiveSet e a).sum (fun _ => e) := by
