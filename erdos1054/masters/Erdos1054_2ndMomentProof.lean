    rw [heq]
    calc (ѕГ - ќ≤) / ((ѕГ - ќ≤)^2 + ќ≥^2) = 1 * ((ѕГ - ќ≤) / ((ѕГ - ќ≤)^2 + ќ≥^2)) := (one_mul _).symm
      _ вЙ§ (m ѕБ : вДЭ) * ((ѕГ - ќ≤) / ((ѕГ - ќ≤)^2 + ќ≥^2)) := by
