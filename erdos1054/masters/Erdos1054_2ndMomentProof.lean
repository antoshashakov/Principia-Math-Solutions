/-- **The bounded character quad system** (Siegel brick S3-pre-b):
    `quad_system_for_chars` with the constant polynomially controlled:
    `C вЙ§ 1000(1+qвВБ)¬≤(1+qвВВ)¬≤` вАФ the shape the dichotomy's `x`-choice requires. -/
theorem quad_system_for_chars_bounded {qвВБ qвВВ : вДХ} (hqвВБ : 1 вЙ§ qвВБ) (hqвВВ : 1 вЙ§ qвВВ)
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1) :
    вИГ LвВБ Lk C : вДЭ,
      (вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn qвВБ ѕЗвВБ d / d| вЙ§ 2 * (qвВБ:вДЭ) / (y + 1))
      вИІ (вИА y : вДХ, 1 вЙ§ y вЖТ
          |Lk - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
              * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d / d|
            вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y)
      вИІ 0 вЙ§ C
      вИІ C вЙ§ 1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2
      вИІ вИА n : вДХ, 1 вЙ§ n вЖТ
        |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
            * toArith (charFn qвВВ ѕЗвВВ)
            * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m - LвВБ * Lk * n|
          вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
  have h1b := fun n => charFn_bound ѕЗвВБ hѕЗвВБ2 n
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  have hGвВБ := charFn_partial_sum_bound hqвВБ ѕЗвВБ hѕЗвВБ2 hѕЗвВБ1
  have hGвВВ := charFn_partial_sum_bound hqвВВ ѕЗвВВ hѕЗвВВ2 hѕЗвВВ1
  obtain вЯ®LвВБ, hLвВБвЯ© := log_mean_exists (charFn qвВБ ѕЗвВБ) ((qвВБ:вДЭ)) hGвВБ
  have hH : вИА M : вДХ, 1 вЙ§ M вЖТ
      |вИС n вИИ Icc 1 M, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)) n - LвВБ * M|
        вЙ§ (1 + 4 * (qвВБ:вДЭ)) * (Real.sqrt M + 1) := by
    intro M hM
    have hcomm : toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
        = toArith (charFn qвВБ ѕЗвВБ) * toArith (fun _ => (1:вДЭ)) := mul_comm _ _
    rw [hcomm]
    exact divisor_char_asymptotic (charFn qвВБ ѕЗвВБ) ((qвВБ:вДЭ)) LвВБ h1b hGвВБ hLвВБ M hM
  have hѕЗвВГ2 : ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
      * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ^ 2 = 1 := by
    rw [mul_pow, вЖР map_pow, вЖР map_pow, hѕЗвВБ2, hѕЗвВВ2, map_one, map_one, mul_one]
  have hqвВБвВВ : 1 вЙ§ qвВБ * qвВВ :=
    Nat.one_le_iff_ne_zero.mpr (Nat.mul_ne_zero (by omega) (by omega))
  have hGвВГ := charFn_partial_sum_bound hqвВБвВВ _ hѕЗвВГ2 hѕЗвВГ1
  have h12b : вИА n, |charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |charFn qвВБ ѕЗвВБ n| * |charFn qвВВ ѕЗвВВ n| вЙ§ 1 * 1 :=
        mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have hK2 : вИА t : вДХ, |вИС n вИИ Icc 1 t, (charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n)|
      вЙ§ (qвВБ:вДЭ) * (qвВВ:вДЭ) := by
    intro t
    have heq : вИС n вИИ Icc 1 t, (charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n)
        = вИС n вИИ Icc 1 t, charFn (qвВБ * qвВВ)
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) n :=
      Finset.sum_congr rfl (fun n _ => (charFn_mul_char ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 n).symm)
    rw [heq]
    have h := hGвВГ t
    push_cast at h
    exact h
  have hKb : вИА t : вДХ, |вИС n вИИ Icc 1 t, (toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) n|
      вЙ§ (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) * (Real.sqrt t + 1) :=
    fun t => bounded_conv_sqrt_bound (charFn qвВВ ѕЗвВВ)
      (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m) ((qвВВ:вДЭ)) ((qвВБ:вДЭ) * (qвВВ:вДЭ))
      h2b h12b hGвВВ hK2 t
  obtain вЯ®Lk, hLkвЯ© := sqrt_mean_exists
    (fun d => (toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d)
    (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) hKb
  have hE := quad_E_package_explicit (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ)
    ((qвВБ:вДЭ)) (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) LвВБ Lk h1b h2b hLвВБ
    (by positivity) hH hKb hLk
  refine вЯ®LвВБ, Lk, 30 * (1 + (qвВБ:вДЭ)) * (1 + (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ))) + 36
    + 3 * |LвВБ * Lk|, hLвВБ, hLk, by positivity, ?_, hEвЯ©
  -- the polynomial bound
  have ha1 : (1:вДЭ) вЙ§ (qвВБ:вДЭ) := by exact_mod_cast hqвВБ
  have hb1 : (1:вДЭ) вЙ§ (qвВВ:вДЭ) := by exact_mod_cast hqвВВ
  have hL1u : |LвВБ| вЙ§ 3 + Real.log qвВБ :=
    rate_limit_upper_log (charFn qвВБ ѕЗвВБ) qвВБ hqвВБ LвВБ h1b hLвВБ
  have hLku : |Lk| вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) + 1 :=
    sqrt_rate_limit_upper (charFn qвВВ ѕЗвВВ)
      (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)
      (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) Lk h2b h12b hLk
  have hlogq : Real.log qвВБ вЙ§ (qвВБ:вДЭ) := by
    have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < (qвВБ:вДЭ) by linarith)
    linarith
  have hprod : |LвВБ * Lk| вЙ§ (3 + (qвВБ:вДЭ)) * (7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) + 1) := by
    rw [abs_mul]
    apply mul_le_mul _ hLku (abs_nonneg _) (by linarith)
    calc |LвВБ| вЙ§ 3 + Real.log qвВБ := hL1u
      _ вЙ§ 3 + (qвВБ:вДЭ) := by linarith
  set a : вДЭ := (qвВБ:вДЭ) with hadef
  set b : вДЭ := (qвВВ:вДЭ) with hbdef
  have hab : (1:вДЭ) вЙ§ a * b := by nlinarith
  nlinarith [hprod, ha1, hb1, hab, sq_nonneg (a - b), sq_nonneg (a + b),
    sq_nonneg ((a + 1) * (b + 1)), mul_pos (show (0:вДЭ) < a + 1 by linarith)
      (show (0:вДЭ) < b + 1 by linarith),
    mul_nonneg (mul_nonneg (show (0:вДЭ) вЙ§ a by linarith) (show (0:вДЭ) вЙ§ b by linarith))
      (show (0:вДЭ) вЙ§ a by linarith),
    mul_nonneg (mul_nonneg (show (0:вДЭ) вЙ§ a by linarith) (show (0:вДЭ) вЙ§ b by linarith))
      (show (0:вДЭ) вЙ§ b by linarith),
    sq_nonneg (a * b - 1), sq_nonneg (a * b + 1)]

/-- **The bounded ќї lower bound at characters** (Siegel brick S3a):
    `siegel_lambda_lower_for_chars` with `C вЙ§ 1000(1+qвВБ)¬≤(1+qвВВ)¬≤` carried along. -/
theorem siegel_lambda_lower_for_chars_bounded {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1)
    (hzero : DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ)) = 0) :
    вИГ LвВБ Lk C : вДЭ, 0 вЙ§ LвВБ * Lk вИІ 0 вЙ§ C
      вИІ C вЙ§ 1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2
      вИІ (вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn qвВБ ѕЗвВБ d / d| вЙ§ 2 * (qвВБ:вДЭ) / (y + 1))
      вИІ (вИА y : вДХ, 1 вЙ§ y вЖТ
          |Lk - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
              * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d / d|
            вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y)
      вИІ вИА x : вДХ, 2 вЙ§ x вЖТ ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) вЙ§ (x:вДЭ) вЖТ
          1 - ќ≤ вЙ§ 26 * (LвВБ * Lk) * ((x:вДЭ)) ^ (1 - ќ≤) := by
  have hqвВБ : 1 вЙ§ qвВБ := Nat.one_le_iff_ne_zero.mpr (NeZero.ne qвВБ)
  have hqвВВ : 1 вЙ§ qвВВ := Nat.one_le_iff_ne_zero.mpr (NeZero.ne qвВВ)
  obtain вЯ®LвВБ, Lk, C, hr1, hr2, hC0, hCB, hEsysвЯ© :=
    quad_system_for_chars_bounded hqвВБ hqвВВ ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 hѕЗвВБ1 hѕЗвВВ1 hѕЗвВГ1
  obtain вЯ®ha0, ha1вЯ© := quad_conv_nonneg (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ)
    (charFn_mul ѕЗвВБ hѕЗвВБ2) (charFn_mul ѕЗвВВ hѕЗвВВ2)
    (charFn_one ѕЗвВБ) (charFn_one ѕЗвВВ)
    (charFn_values ѕЗвВБ hѕЗвВБ2) (charFn_values ѕЗвВВ hѕЗвВВ2)
  have h1b := fun n => charFn_bound ѕЗвВБ hѕЗвВБ2 n
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  -- the E-function and its properties
  have hA0 : вИА n : вДХ, 0 вЙ§ вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ))
      * toArith (charFn qвВБ ѕЗвВБ) * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m :=
    fun n => Finset.sum_nonneg (fun m _ => ha0 m)
  have hlam : 0 вЙ§ LвВБ * Lk := by
    apply lam_nonneg (fun n => вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ))
        * toArith (charFn qвВБ ѕЗвВБ) * toArith (charFn qвВВ ѕЗвВВ)
        * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m)
      (LвВБ * Lk) C hC0 hA0
    intro n hn
    exact hEsys n hn
  refine вЯ®LвВБ, Lk, C, hlam, hC0, hCB, hr1, hr2, ?_вЯ©
  intro x hx hxC
  apply siegel_lambda_lower
    (fun n => (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
      * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) n)
    (LвВБ * Lk)
    (fun n => (вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
      * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m) - LвВБ * Lk * n)
    C ha0 ha1 hlam
    (fun n => by ring)
    hC0
    (by
      show (вИС m вИИ Icc 1 0, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
        * toArith (charFn qвВВ ѕЗвВВ)
        * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m) - LвВБ * Lk * (0:вДХ) = 0
      rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty, Nat.cast_zero, mul_zero,
        sub_zero])
    (fun n hn => hEsys n hn)
    (fun s hs => quad_LSeriesSummable (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ) h1b h2b hs)
    (fun w => riemannZeta w * DirichletCharacter.LFunction ѕЗвВБ w
      * DirichletCharacter.LFunction ѕЗвВВ w
      * DirichletCharacter.LFunction
          ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
            * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) w)
    (fun s _ hs1 => quad_P_differentiableAt ѕЗвВБ ѕЗвВВ hѕЗвВБ1 hѕЗвВВ1 hѕЗвВГ1 s hs1)
    (fun s hs => quad_P_identity ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 hs)
    hќ≤1 hќ≤2
    (by
      show riemannZeta ((ќ≤:вДВ)) * DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ))
        * DirichletCharacter.LFunction ѕЗвВВ ((ќ≤:вДВ))
        * DirichletCharacter.LFunction
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ((ќ≤:вДВ)) = 0
      rw [hzero, mul_zero, zero_mul, zero_mul])
    x hx hxC

/-- **The ќї lower bound with the concrete truncation** (Siegel brick S3b): with
    `M := 2(820(1000(1+qвВБ)¬≤(1+qвВВ)¬≤+1))^{40}`, a vanishing `L(ќ≤,ѕЗвВБ)` at real
    `ќ≤ вИИ (9/10,1)` forces `1вИТќ≤ вЙ§ 26¬Јќї¬ЈM^{1вИТќ≤}` вАФ every quantity closed-form in
    the moduli. -/
theorem siegel_lambda_lower_concrete {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1)
    (hzero : DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ)) = 0) :
    вИГ LвВБ Lk : вДЭ, 0 вЙ§ LвВБ * Lk
      вИІ (вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn qвВБ ѕЗвВБ d / d| вЙ§ 2 * (qвВБ:вДЭ) / (y + 1))
      вИІ (вИА y : вДХ, 1 вЙ§ y вЖТ
          |Lk - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
              * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d / d|
            вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y)
      вИІ 1 - ќ≤ вЙ§ 26 * (LвВБ * Lk)
          * ((2 * (820 * (1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2 + 1))
              ^ ((40:вДЭ)))) ^ (1 - ќ≤) := by
