theorem dirichlet_ap_reciprocal_diverges (q : Nat) (hq : 1 < q) :
    ¬ђ Summable (fun p : {p : Nat // p.Prime вИІ p % q = q - 1} => (1 / (p.1 : вДЭ))) := by
  haveI : NeZero q := вЯ®by omegaвЯ©
