    have hQle : (Q : вДЭ) вЙ§ N / P := by rw [le_div_iffвВА (by linarith)]; nlinarith [hPQR]
    calc (Q : вДЭ) * Real.sqrt P вЙ§ (N / P) * Real.sqrt P :=
