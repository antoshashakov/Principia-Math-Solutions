/-- **Round minimality**: `|w вИТ round w| вЙ§ |w вИТ m|` for every integer `m`. -/
lemma abs_sub_round_min (w : вДЭ) (m : вД§) : |w - round w| вЙ§ |w - (m : вДЭ)| := by
  by_cases hm : m = round w
  ¬Ј rw [hm]
  ¬Ј have h1 : |w - round w| вЙ§ 1/2 := abs_sub_round w
    have h2 : (1:вДЭ) вЙ§ |((m : вДЭ)) - (round w : вДЭ)| := by
      have hne : ((m : вДЭ)) - (round w : вДЭ) вЙ† 0 := by
        intro h0
        apply hm
        have : (m : вДЭ) = (round w : вДЭ) := by linarith
        exact_mod_cast this
      have h3 : (1 : вД§) вЙ§ |m - round w| := Int.one_le_abs (by
        intro h0
        apply hm
        omega)
      calc (1:вДЭ) = ((1:вД§) : вДЭ) := by norm_num
        _ вЙ§ ((|m - round w| : вД§) : вДЭ) := by exact_mod_cast h3
        _ = |((m - round w : вД§) : вДЭ)| := by rw [Int.cast_abs]
        _ = |((m : вДЭ)) - (round w : вДЭ)| := by push_cast; ring_nf
    have h4 : |((m : вДЭ)) - (round w : вДЭ)| вЙ§ |w - (m : вДЭ)| + |w - round w| := by
      calc |((m : вДЭ)) - (round w : вДЭ)| = |(w - (round w : вДЭ)) - (w - (m : вДЭ))| := by ring_nf
        _ вЙ§ |w - (round w : вДЭ)| + |w - (m : вДЭ)| := abs_sub _ _
        _ = |w - (m : вДЭ)| + |w - round w| := by ring
    linarith

/-- **Circle-distance triangle inequality**:
    `|y+z вИТ round(y+z)| вЙ§ |y вИТ round y| + |z вИТ round z|`. -/
lemma circle_dist_triangle (y z : вДЭ) :
    |y + z - round (y + z)| вЙ§ |y - round y| + |z - round z| := by
  calc |y + z - round (y + z)|
      вЙ§ |y + z - ((round y + round z : вД§) : вДЭ)| := abs_sub_round_min _ _
    _ = |(y - round y) + (z - round z)| := by push_cast; ring_nf
    _ вЙ§ |y - round y| + |z - round z| := abs_add_le _ _

/-- **harc brick B4b (skeleton): the per-pair cross-term bound.** For distinct canonical
    fractions, the product of tail-restricted kernel norms integrates to
    `вЙ§ (qq')¬≤¬Ј(Q+1)¬Ј(q+q')` вАФ the midline split: the far kernel is `вЙ§ (qq')¬≤` pointwise
    (separation вЙ• 1/(qq'), so the far distance is вЙ• 1/(2qq')), the near kernel's tail
    integral is `вЙ§ q(Q+1)` (resp. `q'(Q+1)`). -/
lemma cross_pair_bound (N P Q q q' aвВА aвВА' : вДХ)
    (hqP : q вИИ Finset.Icc 1 P) (hq'P : q' вИИ Finset.Icc 1 P)
    (haвВА : aвВА вИИ redRes q) (haвВА' : aвВА' вИИ redRes q') (hQ2 : 2 вЙ§ Q)
    (hne : (aвВА : вДЭ) / (q : вДЭ) вЙ† (aвВА' : вДЭ) / (q' : вДЭ)) :
    вИЂ ќ± in tailSet P Q q aвВА вИ© tailSet P Q q' aвВА',
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2вАЦ
        * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (aвВА' : вДЭ) / (q' : вДЭ)))) ^ 2вАЦ
      вЙ§ 6 * ((q : вДЭ) * (q' : вДЭ)) ^ 2 * (((Q : вДЭ) + 1) * ((q : вДЭ) + (q' : вДЭ))) := by
  classical
  obtain вЯ®hq1, hqP'вЯ© := Finset.mem_Icc.mp hqP
  obtain вЯ®hq'1, hq'P'вЯ© := Finset.mem_Icc.mp hq'P
  have ha_lt : aвВА < q := Finset.mem_range.mp (Finset.mem_filter.mp haвВА).1
  have ha'_lt : aвВА' < q' := Finset.mem_range.mp (Finset.mem_filter.mp haвВА').1
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
  have hq'0R : (0:вДЭ) < (q' : вДЭ) := by exact_mod_cast hq'1
  set x : вДЭ := (aвВА : вДЭ) / (q : вДЭ) with hxdef
  set x' : вДЭ := (aвВА' : вДЭ) / (q' : вДЭ) with hx'def
  set s : вДЭ := 1 / ((q : вДЭ) * (q' : вДЭ)) with hsdef
  have hs0 : (0:вДЭ) < s := by positivity
  -- the two fractions lie in [0,1)
  have hx01 : 0 вЙ§ x вИІ x < 1 := by
    constructor
    ¬Ј rw [hxdef]; positivity
    ¬Ј rw [hxdef, div_lt_one hq0R]; exact_mod_cast ha_lt
  have hx'01 : 0 вЙ§ x' вИІ x' < 1 := by
    constructor
    ¬Ј rw [hx'def]; positivity
    ¬Ј rw [hx'def, div_lt_one hq'0R]; exact_mod_cast ha'_lt
  -- circle separation of the two fractions
  have hsep : s вЙ§ |(x - x') - round (x - x')| := by
    have hd_lb : (-1:вДЭ) < x - x' := by linarith [hx01.1, hx'01.2]
    have hd_ub : x - x' < 1 := by linarith [hx01.2, hx'01.1]
    set m : вД§ := round (x - x') with hmdef
    have hm_lb : -1 вЙ§ m := by
      rw [hmdef, round_eq]
      exact_mod_cast Int.le_floor.mpr (by push_cast; linarith)
    have hm_ub : m вЙ§ 1 := by
      rw [hmdef, round_eq]
      have h2 : вМК(x - x') + 1/2вМЛ < 2 := Int.floor_lt.mpr (by push_cast; linarith)
      omega
    have := redRes_sep_circle q q' aвВА aвВА' hq1 hq'1 ha_lt ha'_lt hne m (by omega)
    rw [hsdef, hxdef, hx'def]
    calc 1 / ((q : вДЭ) * (q' : вДЭ))
        вЙ§ |(aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ) - (m : вДЭ)| := this
      _ = |((aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ)) - (m : вДЭ)| := by ring_nf
  -- circle distance is symmetric under negation
  have hdC_neg : вИА w : вДЭ, |(-w) - round (-w)| = |w - round w| := by
    intro w
    apply le_antisymm
    ¬Ј calc |(-w) - round (-w)| вЙ§ |(-w) - ((-(round w) : вД§) : вДЭ)| := abs_sub_round_min _ _
        _ = |w - round w| := by push_cast; rw [вЖР abs_neg]; ring_nf
    ¬Ј calc |w - round w| вЙ§ |w - ((-(round (-w)) : вД§) : вДЭ)| := abs_sub_round_min _ _
        _ = |(-w) - round (-w)| := by push_cast; rw [вЖР abs_neg]; ring_nf
  -- pointwise either-or on the intersection: f¬Јg вЙ§ sвБї¬≤¬Ј(f + g)
  have hpt : вИА ќ± вИИ tailSet P Q q aвВА вИ© tailSet P Q q' aвВА',
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x))) ^ 2вАЦ
        * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x'))) ^ 2вАЦ
      вЙ§ (4 / s ^ 2) * (вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x))) ^ 2вАЦ
          + вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x'))) ^ 2вАЦ) := by
    intro ќ± hќ±
    obtain вЯ®hќ±T, hќ±T'вЯ© := hќ±
    have hd := tail_dist P Q q aвВА hqP haвВА hQ2 ќ± hќ±T
    have hd' := tail_dist P Q q' aвВА' hq'P haвВА' hQ2 ќ± hќ±T'
    rw [вЖР hxdef] at hd
    rw [вЖР hx'def] at hd'
    set d : вДЭ := |(ќ± - x) - round (ќ± - x)| with hddef
    set d' : вДЭ := |(ќ± - x') - round (ќ± - x')| with hd'def
    have hd0 : 0 < d := lt_of_le_of_lt (by positivity) hd
    have hd'0 : 0 < d' := lt_of_le_of_lt (by positivity) hd'
    -- the kernels are bounded by 1/(4¬Јdist¬≤)
    have hker : вИА (c : вДЭ), 0 < |(ќ± - c) - round (ќ± - c)| вЖТ
        вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ
          вЙ§ 1 / (4 * |(ќ± - c) - round (ќ± - c)| ^ 2) := by
      intro c hc0
      have hsin : Real.sin (Real.pi * (ќ± - c)) вЙ† 0 := by
        intro hzero
        obtain вЯ®n, hnвЯ© := Real.sin_eq_zero_iff.mp hzero
        have hxn : ќ± - c = (n : вДЭ) := by
          have h2 : Real.pi * ((ќ± - c) - (n : вДЭ)) = 0 := by ring_nf; linarith [hn]
          rcases mul_eq_zero.mp h2 with h | h
          ¬Ј exact absurd h Real.pi_ne_zero
          ¬Ј linarith
        rw [hxn, round_intCast] at hc0
        simp at hc0
      rw [norm_pow]
      have hb := exp_sum_bound (ќ± - c) hsin N
      calc вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))вАЦ ^ 2
          вЙ§ (1 / (2 * |(ќ± - c) - round (ќ± - c)|)) ^ 2 := by
            apply pow_le_pow_leftвВА (norm_nonneg _) hb
        _ = 1 / (4 * |(ќ± - c) - round (ќ± - c)| ^ 2) := by
            rw [div_pow, one_pow, mul_pow]
            norm_num
    -- the separation forces max(d, d') вЙ• s/2
    have hmax : s вЙ§ d + d' := by
      have htri : |(x - x') - round (x - x')| вЙ§ d' + d := by
        have h1 := circle_dist_triangle (ќ± - x') (x - ќ±)
        have h2 : (ќ± - x') + (x - ќ±) = x - x' := by ring
        rw [h2] at h1
        have h3 : |(x - ќ±) - round (x - ќ±)| = d := by
          have := hdC_neg (ќ± - x)
          rw [show -(ќ± - x) = x - ќ± by ring] at this
          rw [this, hddef]
        rw [h3, вЖР hd'def] at h1
        exact h1
      linarith [hsep, htri]
    have hf0 : 0 вЙ§ вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x))) ^ 2вАЦ := norm_nonneg _
    have hg0 : 0 вЙ§ вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x'))) ^ 2вАЦ := norm_nonneg _
    rcases le_or_gt (s / 2) d' with hfar | hnear
    ¬Ј -- x' is far: g вЙ§ 1/(4d'¬≤) вЙ§ 1/s¬≤
      have hg_bound : вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x'))) ^ 2вАЦ вЙ§ 1 / s ^ 2 := by
        calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - x'))) ^ 2вАЦ
            вЙ§ 1 / (4 * d' ^ 2) := hker x' hd'0
