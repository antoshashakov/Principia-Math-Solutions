        positivity
    _ = C * q * N ^ 2 * (Real.log N + 1) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
        * (1 + 2 * Real.pi * N * |ќ≤|) := by ring
    _ вЙ§ 3 * C * q * N ^ 2 * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi * N * |ќ≤|) := by
        have h1 : (0:вДЭ) вЙ§ (q:вДЭ) * N ^ 2 * (Real.log N + 1)
            * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
            * (1 + 2 * Real.pi * N * |ќ≤|) := by
