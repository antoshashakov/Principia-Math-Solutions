open Finset in
set_option maxHeartbeats 4000000 in
/-- **Anchor-sum error** (brick D2b): summing the per-anchor integral errors over
    all reduced Farey anchors of level `P вЙ§ (log N)^B`:
    `вАЦвИС_pq вИЂ_window (S¬≤ вИТ model_pq¬≤)e(вИТnќ±)вАЦ вЙ§ C¬ЈP¬≤¬ЈN¬Ј(log N+1)¬Јexp(вИТc(log N)^{1/10})`,
    uniform in `n` вАФ `#anchors вЙ§ P(3P+1) вЙ§ 4P¬≤`. -/
theorem anchor_sum_error (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИА P : вДХ, 0 < P вЖТ (P : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) вЖТ
    вИА n : вДХ,
    вАЦвИС pq вИИ anchors P,
        вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (N + 1)))
          вИ© Set.Ioc (0:вДЭ) 1,
        ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
          - ((вИС r вИИ Finset.range pq.1,
                e ((r : вДЭ) * (pq.2 : вДЭ) / (pq.1 : вДЭ)) * lambdaModel pq.1 r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
      вЙ§ C * P ^ 2 * N * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
  obtain вЯ®c, C, hc0, hC0, NвВА, hD2aвЯ© := anchor_integral_error B hB
  refine вЯ®c, 4 * C, hc0, by positivity, NвВА, ?_вЯ©
  intro N hNвВА P hP0 hPB n
  have hP0R : (0:вДЭ) < (P:вДЭ) := by exact_mod_cast hP0
  have hterm : вИА pq вИИ anchors P,
      вАЦвИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (N + 1)))
          вИ© Set.Ioc (0:вДЭ) 1,
        ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
          - ((вИС r вИИ Finset.range pq.1,
                e ((r : вДЭ) * (pq.2 : вДЭ) / (pq.1 : вДЭ)) * lambdaModel pq.1 r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
      вЙ§ C * N * (Real.log N + 1) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
    intro pq hpq
    rw [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc] at hpq
    obtain вЯ®вЯ®вЯ®hq1, hqPвЯ©, -вЯ©, -вЯ© := hpq
    have hq0 : 0 < pq.1 := hq1
    have hqB : (pq.1 : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) := by
      have h1 : (pq.1 : вДЭ) вЙ§ (P : вДЭ) := by exact_mod_cast hqP
      linarith
    exact hD2a N hNвВА pq.1 hq0 hqB pq.2 n
  have hcard : ((anchors P).card : вДЭ) вЙ§ 4 * P ^ 2 := by
    have h1 : (anchors P).card вЙ§ P * (3 * P + 1) := by
      calc (anchors P).card
          вЙ§ (Finset.Icc 1 P √ЧЋҐ Finset.Icc (-(P : вД§)) (2 * P)).card :=
            Finset.card_le_card (Finset.filter_subset _ _)
        _ = (Finset.Icc 1 P).card * (Finset.Icc (-(P : вД§)) (2 * P)).card :=
            Finset.card_product _ _
        _ = P * (3 * P + 1) := by
            rw [Nat.card_Icc, Int.card_Icc]
            congr 1
            omega
    have h3 : P * (3 * P + 1) вЙ§ 4 * P ^ 2 := by nlinarith
    calc ((anchors P).card : вДЭ) вЙ§ ((P * (3 * P + 1) : вДХ) : вДЭ) := by exact_mod_cast h1
      _ вЙ§ ((4 * P ^ 2 : вДХ) : вДЭ) := by exact_mod_cast h3
      _ = 4 * (P:вДЭ) ^ 2 := by push_cast; ring
  have hK0 : (0:вДЭ) вЙ§ C * N * (Real.log N + 1)
      * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
    have hN0 : (0:вДЭ) вЙ§ (N:вДЭ) := by positivity
    have hlogN0 : (0:вДЭ) вЙ§ Real.log N := by
      rcases Nat.eq_zero_or_pos N with rfl | hN1
      ¬Ј simp
      ¬Ј apply Real.log_nonneg
        exact_mod_cast hN1
    positivity
  calc вАЦвИС pq вИИ anchors P,
      вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (N + 1)))
          вИ© Set.Ioc (0:вДЭ) 1,
