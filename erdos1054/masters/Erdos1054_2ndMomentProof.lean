open DirichletCharacter Complex Metric MeasureTheory

/-- The smoothed-Perron integrand (duplicated def, identical to DirichletPsiExplicit/Frontier). -/
noncomputable def G' {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X : вДЭ) : вДВ вЖТ вДВ :=
  fun s => (-deriv (DirichletCharacter.LFunction ѕЗ) s / DirichletCharacter.LFunction ѕЗ s)
    * ((X : вДВ) ^ s / (s * (s + 1)))




/-- **W2d: cpow ratio of positive reals** вАФ `(X:вДВ)^s/(n:вДВ)^s = ((X/n:вДЭ):вДВ)^s` for positive real
    `X, n`: reduces the per-`n` summand `X^s¬Јn^{вИТs}¬Јkernel` to the Perron-kernel shape at
    `y = X/n`. Via `Complex.mul_cpow_ofReal_nonneg` on `X = (X/n)¬Јn`. -/
lemma cpow_ratio (X n : вДЭ) (hX : 0 < X) (hn : 0 < n) (s : вДВ) :
    (X : вДВ) ^ s / (n : вДВ) ^ s = (((X / n : вДЭ)) : вДВ) ^ s := by
  have hXn : X = (X / n) * n := by field_simp
  have h1 : ((X : вДЭ) : вДВ) ^ s = (((X / n : вДЭ)) : вДВ) ^ s * ((n : вДЭ) : вДВ) ^ s := by
    calc ((X : вДЭ) : вДВ) ^ s = ((((X / n : вДЭ)) : вДВ) * ((n : вДЭ) : вДВ)) ^ s := by
          rw [вЖР Complex.ofReal_mul, вЖР hXn]
      _ = (((X / n : вДЭ)) : вДВ) ^ s * ((n : вДЭ) : вДВ) ^ s :=
          Complex.mul_cpow_ofReal_nonneg (by positivity) hn.le s
  have hn0 : ((n : вДЭ) : вДВ) ^ s вЙ† 0 := by
    rw [Complex.cpow_def_of_ne_zero (Complex.ofReal_ne_zero.mpr hn.ne')]
    exact Complex.exp_ne_zero _
  rw [h1]
  field_simp

open ArithmeticFunction in
/-- **W2b: the smoothed integrand as a tsum of Perron-kernel summands** вАФ for `Re s > 1`, `X > 0`:
    `G'(s) = вИС'_n ѕЗ(n)ќЫ(n) ¬Ј (X/n)^s/(s(s+1))` (the `n`-th summand in exactly the
    `perron_kernel_*` shape at `y = X/n`). Via `neg_logDeriv_LFunction_eq` + `tsum_mul_right` +
    per-`n` `cpow_ratio` (`n = 0` term vanishes since `ќЫ(0) = 0`). -/
lemma G_tsum_form {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X : вДЭ) (hX : 0 < X)
    {s : вДВ} (hs : 1 < s.re) :
    G' ѕЗ X s = вИС' n : вДХ,
      (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) * ((((X / n : вДЭ)) : вДВ) ^ s / (s * (s + 1))) := by
  rw [G', neg_logDeriv_LFunction_eq ѕЗ hs, LSeries, вЖР tsum_mul_right]
  apply tsum_congr
  intro n
  rcases Nat.eq_zero_or_pos n with rfl | hn
  ¬Ј simp [LSeries.term_zero]
  ¬Ј have hn0 : ((n:вДХ):вДВ) вЙ† 0 := by exact_mod_cast hn.ne'
    rw [LSeries.term_of_ne_zero hn.ne']
    have hnR : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast hn
    have hratio := cpow_ratio X (n:вДЭ) hX hnR s
    push_cast at hratio вКҐ
    rw [вЖР hratio]
    ring

open ArithmeticFunction in
/-- **W2c: the sum/integral interchange** вАФ `вИЂ_вДЭ G'(ѕГ+it) dt = вИС'_n вИЂ_вДЭ h_n(t) dt` for `X>0`, `ѕГ>1`:
    dominated by `ќЫ(n)(X/n)^ѕГ¬Ј(1+t¬≤)вБї¬є` (integrable in `t`, summable in `n`). -/
lemma integral_G_tsum {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X ѕГ : вДЭ)
    (hX : 0 < X) (hѕГ : 1 < ѕГ) :
    (вИЂ t : вДЭ, G' ѕЗ X ((ѕГ:вДВ) + t * I))
      = вИС' n : вДХ, вИЂ t : вДЭ,
        (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
          * ((((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1))) := by
  have hre : вИА t : вДЭ, ((ѕГ:вДВ) + (t:вДВ) * I).re = ѕГ := fun t => by simp
  have hs1 : вИА t : вДЭ, 1 < ((ѕГ:вДВ) + (t:вДВ) * I).re := fun t => by rw [hre]; exact hѕГ
  set h : вДХ вЖТ вДЭ вЖТ вДВ := fun n t =>
    (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
      * ((((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I) / (((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)))
    with hdef
  have hden : вИА t : вДЭ, (1:вДЭ) + t^2 вЙ§ вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ := by
    intro t
    have e1 : вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ = Real.sqrt (ѕГ^2 + t^2) := Complex.norm_add_mul_I ѕГ t
    have e2 : (ѕГ:вДВ) + (t:вДВ) * I + 1 = ((ѕГ + 1 : вДЭ) : вДВ) + (t:вДВ) * I := by push_cast; ring
    have e3 : вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ = Real.sqrt ((ѕГ+1)^2 + t^2) := by
      rw [e2]; exact Complex.norm_add_mul_I _ _
    rw [e1, e3]
    have h1 : Real.sqrt (ѕГ^2 + t^2) * Real.sqrt (ѕГ^2 + t^2)
        вЙ§ Real.sqrt (ѕГ^2 + t^2) * Real.sqrt ((ѕГ+1)^2 + t^2) := by
      apply mul_le_mul_of_nonneg_left (Real.sqrt_le_sqrt (by nlinarith)) (Real.sqrt_nonneg _)
    rw [Real.mul_self_sqrt (by positivity)] at h1
    nlinarith [h1, sq_nonneg t]
  have hdenpos : вИА t : вДЭ, (0:вДЭ) < вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ := by
    intro t
    have := hden t
    nlinarith [sq_nonneg t]
  have hdenne : вИА t : вДЭ, ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1) вЙ† 0 := by
    intro t hzero
    have h2 : вАЦ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)вАЦ = 0 := by rw [hzero, norm_zero]
    rw [norm_mul] at h2
    nlinarith [hdenpos t]
  have hzero0 : h 0 = fun _ => 0 := by
    funext t
    simp [hdef, ArithmeticFunction.map_zero]
  have hnorm : вИА n : вДХ, 0 < n вЖТ вИА t : вДЭ,
      вАЦh n tвАЦ вЙ§ (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * (1 + t^2)вБї¬є := by
    intro n hn t
    have hy0 : (0:вДЭ) < X / n := by positivity
    have h1 : вАЦ(((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)вАЦ = (X/n) ^ (ѕГ:вДЭ) := by
      rw [Complex.norm_cpow_eq_rpow_re_of_pos hy0, hre]
    have h2 : вАЦѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)вАЦ вЙ§ vonMangoldt n := by
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg vonMangoldt_nonneg]
      calc вАЦѕЗ (n : ZMod N)вАЦ * vonMangoldt n вЙ§ 1 * vonMangoldt n :=
            mul_le_mul_of_nonneg_right (DirichletCharacter.norm_le_one ѕЗ _) vonMangoldt_nonneg
        _ = vonMangoldt n := one_mul _
    have h4 : (0:вДЭ) < 1 + t^2 := by positivity
    rw [hdef]
    simp only []
    rw [norm_mul, norm_mul, norm_div, h1]
    have h3 : (1:вДЭ) + t^2 вЙ§ вАЦ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)вАЦ := by
      rw [norm_mul]; exact hden t
    have hќЫ : вАЦ((vonMangoldt n : вДЭ) : вДВ)вАЦ = vonMangoldt n := by
      rw [Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg vonMangoldt_nonneg]
    calc вАЦѕЗ (n : ZMod N)вАЦ * вАЦ((vonMangoldt n : вДЭ) : вДВ)вАЦ
          * ((X/n) ^ (ѕГ:вДЭ) / вАЦ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)вАЦ)
        вЙ§ 1 * vonMangoldt n * ((X/n) ^ (ѕГ:вДЭ) / (1 + t^2)) := by
          apply mul_le_mul
          ¬Ј exact mul_le_mul (DirichletCharacter.norm_le_one ѕЗ _) (le_of_eq hќЫ)
              (norm_nonneg _) zero_le_one
          ¬Ј exact div_le_div_of_nonneg_left (by positivity) h4 h3
          ¬Ј positivity
          ¬Ј exact mul_nonneg zero_le_one vonMangoldt_nonneg
      _ = (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * (1 + t^2)вБї¬є := by
          rw [div_eq_mul_inv]; ring
  have hInt : вИА n : вДХ, Integrable (h n) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј rw [hzero0]
      exact integrable_zero _ _ _
    ¬Ј have hy0 : (0:вДЭ) < X / n := by positivity
      have hyC : (((X / n : вДЭ)) : вДВ) вЙ† 0 := Complex.ofReal_ne_zero.mpr hy0.ne'
      have hcpow : Continuous (fun t : вДЭ => (((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)) := by
        have he : (fun t : вДЭ => (((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I))
            = fun t : вДЭ => Complex.exp (Complex.log (((X / n : вДЭ)) : вДВ) * ((ѕГ:вДВ) + (t:вДВ) * I)) := by
          funext t
          rw [Complex.cpow_def_of_ne_zero hyC]
        rw [he]
        fun_prop
      have hcont : Continuous (h n) := by
        rw [hdef]
        simp only []
        apply Continuous.mul continuous_const
        exact Continuous.div hcpow (by fun_prop) hdenne
      apply Integrable.mono' (g := fun t : вДЭ => (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * (1 + t^2)вБї¬є)
        (integrable_inv_one_add_sq.const_mul _) hcont.aestronglyMeasurable
      exact Filter.Eventually.of_forall (hnorm n hn)
  have hIntNorm : вИА n : вДХ, 0 < n вЖТ
      (вИЂ t : вДЭ, вАЦh n tвАЦ) вЙ§ (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * Real.pi := by
    intro n hn
    calc (вИЂ t : вДЭ, вАЦh n tвАЦ)
        вЙ§ вИЂ t : вДЭ, (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * (1 + t^2)вБї¬є := by
          apply integral_mono_of_nonneg (Filter.Eventually.of_forall fun t => norm_nonneg _)
            (integrable_inv_one_add_sq.const_mul _)
            (Filter.Eventually.of_forall (hnorm n hn))
      _ = (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * вИЂ t : вДЭ, (1 + t^2)вБї¬є :=
          integral_const_mul _ _
      _ = (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * Real.pi := by
          rw [integral_univ_inv_one_add_sq]
  have hSummable : Summable (fun n : вДХ => вИЂ t : вДЭ, вАЦh n tвАЦ) := by
    have hmaj : Summable (fun n : вДХ =>
        (Real.pi * X ^ (ѕГ:вДЭ)) * вАЦLSeries.term (fun m : вДХ => ((vonMangoldt m : вДЭ) : вДВ)) (ѕГ:вДВ) nвАЦ) := by
      apply Summable.mul_left
      apply summable_norm_iff.mpr
      exact LSeriesSummable_vonMangoldt (s := (ѕГ:вДВ)) (by simpa using hѕГ)
    apply Summable.of_nonneg_of_le
      (fun n => integral_nonneg fun t => norm_nonneg _)
      _ hmaj
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј rw [hzero0]
      simp
    ¬Ј have hy0 : (0:вДЭ) < X / n := by positivity
      have hnR : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast hn
      calc (вИЂ t : вДЭ, вАЦh n tвАЦ) вЙ§ (vonMangoldt n * (X/n) ^ (ѕГ:вДЭ)) * Real.pi := hIntNorm n hn
        _ = (Real.pi * X ^ (ѕГ:вДЭ)) * (vonMangoldt n / (n:вДЭ) ^ (ѕГ:вДЭ)) := by
            rw [Real.div_rpow hX.le hnR.le]
            field_simp
        _ = (Real.pi * X ^ (ѕГ:вДЭ)) * вАЦLSeries.term (fun m : вДХ => ((vonMangoldt m : вДЭ) : вДВ)) (ѕГ:вДВ) nвАЦ := by
            rw [LSeries.norm_term_eq]
            rw [if_neg hn.ne']
            congr 1
            rw [Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg vonMangoldt_nonneg,
              Complex.ofReal_re]
  calc (вИЂ t : вДЭ, G' ѕЗ X ((ѕГ:вДВ) + t * I))
      = вИЂ t : вДЭ, вИС' n : вДХ, h n t := by
        apply integral_congr_ae
        apply Filter.Eventually.of_forall
        intro t
        exact G_tsum_form ѕЗ X hX (hs1 t)
    _ = вИС' n : вДХ, вИЂ t : вДЭ, h n t :=
        (integral_tsum_of_summable_integral_norm hInt hSummable).symm

open Filter Topology in
/-- **W2-y1: the Perron kernel at `y = 1` vanishes** вАФ `(1/2ѕА)¬ЈвИЂ 1^{ѕГ+it}/((ѕГ+it)(ѕГ+it+1)) dt = 0`
    for `ѕГ > 0`: dominated-convergence limit of `perron_kernel_gtOne` along `y_k = 1 + 1/(k+1) вЖУ 1`
    (`1 вИТ 1/y_k вЖТ 0`; domination `2^ѕГ¬Ј(1+t¬≤)вБї¬є`-grade uniform for `y вЙ§ 2`). -/
lemma perron_kernel_one (ѕГ : вДЭ) (hѕГ : 0 < ѕГ) :
    (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
        (((1:вДЭ) : вДВ) ^ ((ѕГ : вДВ) + t * I)) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1))
      = 0 := by
  -- the kernel and its denominator bounds
  have hre : вИА t : вДЭ, ((ѕГ:вДВ) + (t:вДВ) * I).re = ѕГ := fun t => by simp
  have hden : вИА t : вДЭ, min 1 (ѕГ^2) + t^2 вЙ§ вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ := by
    intro t
    have e1 : вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ = Real.sqrt (ѕГ^2 + t^2) := Complex.norm_add_mul_I ѕГ t
    have e2 : (ѕГ:вДВ) + (t:вДВ) * I + 1 = ((ѕГ + 1 : вДЭ) : вДВ) + (t:вДВ) * I := by push_cast; ring
    have e3 : вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ = Real.sqrt ((ѕГ+1)^2 + t^2) := by
      rw [e2]; exact Complex.norm_add_mul_I _ _
    rw [e1, e3]
    have h1 : Real.sqrt (ѕГ^2 + t^2) * Real.sqrt (ѕГ^2 + t^2)
        вЙ§ Real.sqrt (ѕГ^2 + t^2) * Real.sqrt ((ѕГ+1)^2 + t^2) := by
      apply mul_le_mul_of_nonneg_left (Real.sqrt_le_sqrt (by nlinarith)) (Real.sqrt_nonneg _)
    rw [Real.mul_self_sqrt (by positivity)] at h1
    have h2 : min 1 (ѕГ^2) вЙ§ ѕГ^2 := min_le_right _ _
    nlinarith [h1]
  have hm0 : (0:вДЭ) < min 1 (ѕГ^2) := lt_min one_pos (pow_pos hѕГ 2)
  have hdenpos : вИА t : вДЭ, (0:вДЭ) < вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ := by
    intro t
    have := hden t
    nlinarith [sq_nonneg t]
  -- the y-parameterized integrand family and its uniform bound (1 вЙ§ y вЙ§ 2)
  set F : вДХ вЖТ вДЭ вЖТ вДВ := fun k t =>
    (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)
      / (((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)) with hFdef
  set f : вДЭ вЖТ вДВ := fun t =>
    (((1:вДЭ) : вДВ)) ^ ((ѕГ:вДВ) + (t:вДВ) * I)
      / (((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)) with hfdef
  have hyk : вИА k : вДХ, (1:вДЭ) < 1 + 1/((k:вДЭ)+1) := by
    intro k
    have : (0:вДЭ) < 1/((k:вДЭ)+1) := by positivity
    linarith
  have hyk2 : вИА k : вДХ, (1:вДЭ) + 1/((k:вДЭ)+1) вЙ§ 2 := by
    intro k
    have h1 : (1:вДЭ) вЙ§ (k:вДЭ)+1 := by linarith [Nat.cast_nonneg (ќ± := вДЭ) k]
    have : 1/((k:вДЭ)+1) вЙ§ 1 := by
      rw [div_le_one (by positivity)]
      exact h1
    linarith
  have hbound : вИА k : вДХ, вИА t : вДЭ,
      вАЦF k tвАЦ вЙ§ (2 ^ (ѕГ:вДЭ)) * ((min 1 (ѕГ^2) + t^2)вБї¬є) := by
    intro k t
    rw [hFdef]
    simp only []
    rw [norm_div, norm_mul]
    have h1 : вАЦ(((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)вАЦ
        = (1 + 1/((k:вДЭ)+1)) ^ (ѕГ:вДЭ) := by
      rw [Complex.norm_cpow_eq_rpow_re_of_pos (by linarith [hyk k]), hre]
    rw [h1]
    have h2 : (1 + 1/((k:вДЭ)+1)) ^ (ѕГ:вДЭ) вЙ§ 2 ^ (ѕГ:вДЭ) :=
      Real.rpow_le_rpow (by linarith [hyk k]) (hyk2 k) hѕГ.le
    have h3 := hden t
    have h4 : (0:вДЭ) < min 1 (ѕГ^2) + t^2 := by nlinarith [sq_nonneg t]
    calc (1 + 1/((k:вДЭ)+1)) ^ (ѕГ:вДЭ) / (вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ)
        вЙ§ 2 ^ (ѕГ:вДЭ) / (min 1 (ѕГ^2) + t^2) := by
          have ha := div_le_div_of_nonneg_right h2 (hdenpos t).le
          have hb : (2:вДЭ) ^ (ѕГ:вДЭ) / (вАЦ(ѕГ:вДВ) + (t:вДВ) * IвАЦ * вАЦ(ѕГ:вДВ) + (t:вДВ) * I + 1вАЦ)
              вЙ§ 2 ^ (ѕГ:вДЭ) / (min 1 (ѕГ^2) + t^2) :=
            div_le_div_of_nonneg_left (by positivity) h4 h3
          linarith
      _ = (2 ^ (ѕГ:вДЭ)) * ((min 1 (ѕГ^2) + t^2)вБї¬є) := by rw [div_eq_mul_inv]
  -- integrability of the bound
  have hbound_int : Integrable (fun t : вДЭ => (2 ^ (ѕГ:вДЭ)) * ((min 1 (ѕГ^2) + t^2)вБї¬є)) := by
    apply Integrable.const_mul
    apply Integrable.mono' (g := fun t : вДЭ => (min 1 (ѕГ^2))вБї¬є * (1 + t^2)вБї¬є)
      (integrable_inv_one_add_sq.const_mul _)
    ¬Ј apply Continuous.aestronglyMeasurable
      apply Continuous.invвВА (by fun_prop)
      intro t
      nlinarith [sq_nonneg t]
    ¬Ј apply Filter.Eventually.of_forall
      intro t
      have h4 : (0:вДЭ) < min 1 (ѕГ^2) + t^2 := by nlinarith [sq_nonneg t]
      rw [Real.norm_of_nonneg (by positivity)]
      rw [inv_le_iff_one_le_mulвВА h4]
      have hmin1 : min 1 (ѕГ^2) вЙ§ 1 := min_le_left _ _
      have h5 : (min 1 (ѕГ^2))вБї¬є * (1 + t^2)вБї¬є * (min 1 (ѕГ^2) + t^2)
          = ((min 1 (ѕГ^2) + t^2) / (min 1 (ѕГ^2) * (1 + t^2))) := by
        field_simp
      rw [h5, le_div_iffвВА (by positivity)]
      nlinarith [sq_nonneg t, hm0]
  -- measurability of each F k
  have hdenne : вИА t : вДЭ, ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1) вЙ† 0 := by
    intro t hzero
    have h2 : вАЦ((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)вАЦ = 0 := by rw [hzero, norm_zero]
    rw [norm_mul] at h2
    nlinarith [hdenpos t]
  have hFmeas : вИА k : вДХ, AEStronglyMeasurable (F k) (volume : Measure вДЭ) := by
    intro k
    have hyC : (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) вЙ† 0 :=
      Complex.ofReal_ne_zero.mpr (by linarith [hyk k])
    have hcont : Continuous (F k) := by
      rw [hFdef]
      simp only []
      apply Continuous.div _ (by fun_prop) hdenne
      have he : (fun t : вДЭ => (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I))
          = fun t : вДЭ => Complex.exp (Complex.log (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) * ((ѕГ:вДВ) + (t:вДВ) * I)) := by
        funext t
        rw [Complex.cpow_def_of_ne_zero hyC]
      rw [he]
      fun_prop
    exact hcont.aestronglyMeasurable
  -- pointwise convergence F k t вЖТ f t
  have hlim : вИА t : вДЭ, Tendsto (fun k : вДХ => F k t) atTop (рЭУЭ (f t)) := by
    intro t
    have hbase : Tendsto (fun k : вДХ => (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) atTop (рЭУЭ (((1:вДЭ):вДВ))) := by
      apply Tendsto.comp (Complex.continuous_ofReal.tendsto _)
      have h1 : Tendsto (fun k : вДХ => 1/((k:вДЭ)+1)) atTop (рЭУЭ 0) :=
        tendsto_one_div_add_atTop_nhds_zero_nat
      have := h1.const_add 1
      simpa using this
    have hcpowC : ContinuousAt (fun z : вДВ => z ^ ((ѕГ:вДВ) + (t:вДВ) * I)) (((1:вДЭ):вДВ)) := by
      apply continuousAt_cpow_const
      norm_num [Complex.mem_slitPlane_iff]
    have hnum : Tendsto (fun k : вДХ => (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I))
        atTop (рЭУЭ ((((1:вДЭ):вДВ)) ^ ((ѕГ:вДВ) + (t:вДВ) * I))) :=
      (hcpowC.tendsto).comp hbase
    rw [hFdef, hfdef]
    simp only []
    exact hnum.div_const _
  -- dominated convergence
  have hDCT := MeasureTheory.tendsto_integral_of_dominated_convergence
    (fun t : вДЭ => (2 ^ (ѕГ:вДЭ)) * ((min 1 (ѕГ^2) + t^2)вБї¬є)) hFmeas hbound_int
    (fun k => Filter.Eventually.of_forall (hbound k))
    (Filter.Eventually.of_forall hlim)
  -- values from the gtOne axiom
  have h2ѕАne : (2 * (Real.pi : вДВ)) вЙ† 0 := by
    simp [Complex.ofReal_ne_zero, Real.pi_ne_zero]
  have hvals : вИА k : вДХ, (вИЂ t : вДЭ, F k t)
      = (2 * (Real.pi : вДВ)) * (1 - 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) := by
    intro k
    have hax := perron_kernel_gtOne (1 + 1/((k:вДЭ)+1)) (hyk k) ѕГ hѕГ
    rw [hFdef]
    simp only []
    calc (вИЂ t : вДЭ, (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)
            / (((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1)))
        = (2 * (Real.pi : вДВ)) * ((1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
            (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + (t:вДВ) * I)
              / (((ѕГ:вДВ) + (t:вДВ) * I) * ((ѕГ:вДВ) + (t:вДВ) * I + 1))) := by
          rw [вЖР mul_assoc, mul_one_div, div_self h2ѕАne, one_mul]
      _ = (2 * (Real.pi : вДВ)) * (1 - 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) := by rw [hax]
  have hvals_lim : Tendsto (fun k : вДХ => (2 * (Real.pi : вДВ)) * (1 - 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)))
      atTop (рЭУЭ 0) := by
    have hbase : Tendsto (fun k : вДХ => (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) atTop (рЭУЭ 1) := by
      apply Tendsto.comp (Complex.continuous_ofReal.tendsto _)
      have h1 : Tendsto (fun k : вДХ => 1/((k:вДЭ)+1)) atTop (рЭУЭ 0) :=
        tendsto_one_div_add_atTop_nhds_zero_nat
      have h2 := h1.const_add 1
      simpa using h2
    have hinv : Tendsto (fun k : вДХ => 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) atTop (рЭУЭ 1) := by
      have := hbase.invвВА (by norm_num : (1:вДВ) вЙ† 0)
      simpa using this
    have h3 : Tendsto (fun k : вДХ => (1:вДВ) - 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) atTop (рЭУЭ 0) := by
      have := (tendsto_const_nhds (x := (1:вДВ))).sub hinv
      simpa using this
    have h4 := h3.const_mul (2 * (Real.pi : вДВ))
    simpa using h4
  -- conclude
  have hint_f : (вИЂ t : вДЭ, f t) = 0 := by
    apply tendsto_nhds_unique hDCT
    have : (fun k : вДХ => вИЂ t : вДЭ, F k t)
        = fun k : вДХ => (2 * (Real.pi : вДВ)) * (1 - 1 / (((1 + 1/((k:вДЭ)+1) : вДЭ)) : вДВ)) := by
      funext k
      exact hvals k
    rw [this]
    exact hvals_lim
  rw [hfdef] at hint_f
  simp only [] at hint_f
  rw [hint_f, mul_zero]

open ArithmeticFunction in
/-- **W2e: per-`n` Perron evaluation** вАФ for `X > 1`, `ѕГ > 0`, every `n`:
    `(1/2ѕА)¬ЈвИЂ ѕЗ(n)ќЫ(n)¬Ј(X/n)^{ѕГ+it}/((ѕГ+it)(ѕГ+it+1)) dt
       = ѕЗ(n)ќЫ(n)¬Ј(if n вЙ§ X then 1 вИТ n/X else 0)`.
    Trichotomy `n < X` (`gtOne`), `n = X` (`perron_kernel_one`, both sides `0` via `1вИТn/X = 0`),
    `n > X` (`ltOne`); `n = 0` degenerates via `ќЫ(0) = 0`. -/
lemma perron_summand_eval {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X ѕГ : вДЭ) (hX : 1 < X) (hѕГ : 0 < ѕГ) (n : вДХ) :
    (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
        (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
          * ((((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      = (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
          * (if (n:вДЭ) вЙ§ X then 1 - ((n:вДЭ) : вДВ) / ((X:вДЭ) : вДВ) else 0) := by
  rcases Nat.eq_zero_or_pos n with rfl | hn
  ¬Ј simp [ArithmeticFunction.map_zero]
  ¬Ј have hnR : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast hn
    have hXne : (X:вДЭ) вЙ† 0 := by linarith
    -- pull the constant out
    rw [MeasureTheory.integral_const_mul, show
      (1 / (2 * (Real.pi : вДВ))) * ((ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) * вИЂ t : вДЭ,
        (((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      = (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) * ((1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
        (((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      from by ring]
    congr 1
    rcases lt_trichotomy ((n:вДЭ)) X with hlt | heq | hgt
    ¬Ј -- n < X: y = X/n > 1
      have hy : 1 < X / (n:вДЭ) := by
        rw [lt_div_iffвВА hnR]
        linarith
      rw [perron_kernel_gtOne (X / (n:вДЭ)) hy ѕГ hѕГ, if_pos hlt.le]
      congr 1
      rw [show ((X / (n:вДЭ) : вДЭ) : вДВ) = ((X:вДЭ):вДВ) / ((n:вДЭ):вДВ) from by push_cast; ring]
      rw [one_div_div]
    ¬Ј -- n = X: y = 1
      have hy1 : (X / (n:вДЭ) : вДЭ) = 1 := by
        rw [heq]
        field_simp
      rw [hy1, perron_kernel_one ѕГ hѕГ, if_pos heq.le]
      have hcast : ((n:вДЭ) : вДВ) = ((X:вДЭ) : вДВ) := by
        exact_mod_cast congrArg Complex.ofReal heq
      rw [hcast, div_self (Complex.ofReal_ne_zero.mpr hXne)]
      ring
    ¬Ј -- n > X: 0 < y < 1
      have hy0 : (0:вДЭ) < X / (n:вДЭ) := by positivity
      have hy1 : X / (n:вДЭ) < 1 := by
        rw [div_lt_one hnR]
        exact hgt
      rw [perron_kernel_ltOne (X / (n:вДЭ)) hy0 hy1 ѕГ hѕГ, if_neg (by linarith)]


open ArithmeticFunction in
/-- **W2f: THE SMOOTHED-PERRON REPRESENTATION, PROVEN** вАФ the exact statement of the
    `smoothed_perron_LFunction` axiom, now a theorem (modulo the two PNT kernel inputs):
    reshape вЖТ interchange (W2c) вЖТ per-`n` evaluation (W2e) вЖТ tsum collapse to the finite sum. -/
theorem smoothed_perron_LFunction {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X : вДЭ) (hX : 1 < X) (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X)
      = (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
          (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + t * I)
              / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + t * I))
            * (X : вДВ) ^ ((ѕГ : вДВ) + t * I)
            / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1)) := by
  have hX0 : (0:вДЭ) < X := by linarith
  -- reshape to the G'-form and interchange
  have h1 : (вИЂ t : вДЭ, (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I)
          / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I))
        * (X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      = вИС' n : вДХ, вИЂ t : вДЭ,
        (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
          * ((((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1))) := by
    rw [perron_integrand_reshape]
    exact integral_G_tsum ѕЗ X ѕГ hX0 hѕГ
  rw [h1, вЖР tsum_mul_left]
  -- evaluate each summand and collapse
  have h2 : вИА n : вДХ, (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ,
      (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
        * ((((X / n : вДЭ)) : вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      = (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
        * (if (n:вДЭ) вЙ§ X then 1 - ((n:вДЭ) : вДВ) / ((X:вДЭ) : вДВ) else 0) :=
    perron_summand_eval ѕЗ X ѕГ hX (by linarith)
  rw [tsum_congr h2]
  -- tsum вЖТ finite sum over range(вМКXвМЛ+1)
  have hvanish : вИА n вИЙ Finset.range (вМКXвМЛвВК + 1),
      (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
        * (if (n:вДЭ) вЙ§ X then 1 - ((n:вДЭ) : вДВ) / ((X:вДЭ) : вДВ) else 0) = 0 := by
    intro n hn
    rw [Finset.mem_range, not_lt] at hn
    have hnX : X < (n:вДЭ) := by
      have h3 : X < (вМКXвМЛвВК : вДЭ) + 1 := Nat.lt_floor_add_one X
      have h4 : ((вМКXвМЛвВК + 1 : вДХ) : вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
      push_cast at h4
      linarith
    rw [if_neg (by linarith)]
    ring
  rw [tsum_eq_sum hvanish]
  apply Finset.sum_congr rfl
  intro n hn
  rw [Finset.mem_range] at hn
  have hnX : (n:вДЭ) вЙ§ X := by
    have h3 : n вЙ§ вМКXвМЛвВК := by omega
    have h4 : ((n:вДХ):вДЭ) вЙ§ (вМКXвМЛвВК : вДЭ) := by exact_mod_cast h3
    have h5 : (вМКXвМЛвВК : вДЭ) вЙ§ X := Nat.floor_le hX0.le
    linarith
  rw [if_pos hnX]

/-- **Sharp вЖФ smoothed bridge** (SW brick B2b): the sharp partial sum equals the smoothed one plus
    the linear-weight correction `(1/X)вИС n¬Јa_n`. Pure algebra (regroup `a_n¬Ј(n/X)`); the correction
    is then handled at two scales `X`, `X(1+ќі)` to recover the sharp sum with the smoothed rate. -/
lemma sharp_eq_smoothed_add {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X : вДЭ) (M : вДХ) :
    вИС n вИИ Finset.range M, ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)
      = (вИС n вИИ Finset.range M,
          ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X))
        + (1 / (X : вДВ)) * вИС n вИИ Finset.range M,
            (n : вДВ) * (ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) := by
  rw [Finset.mul_sum, вЖР Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro n _
  push_cast
  ring

/-- **Perron-kernel holomorphy** (SW brick B3 input): the smoothed kernel `X^s/(s(s+1))` is
    holomorphic on `Re s > 0` (`s вЙ† 0`, `s+1 вЙ† 0`; `X^s` entire for `X > 0`). Combined with the
    zero-free-region holomorphy of `вИТLвА≤/L` (`LFunction_ne_zero_re_ge_one` / the contour gap), the
    smoothed-Perron integrand is holomorphic in the shift strip, so the B3 rectangle contour picks up
    only the kernel pole at `s = 0` and (for `ѕЗвВА`) the `L`-pole at `s = 1`. -/
lemma perron_kernel_differentiableOn (X : вДЭ) (hX : 0 < X) :
    DifferentiableOn вДВ (fun s : вДВ => (X : вДВ) ^ s / (s * (s + 1))) {s : вДВ | 0 < s.re} := by
  have hXne : (X : вДВ) вЙ† 0 := by exact_mod_cast hX.ne'
  apply DifferentiableOn.div
  ¬Ј have hcpow : Differentiable вДВ (fun s : вДВ => (X : вДВ) ^ s) :=
      fun s => (hasStrictDerivAt_const_cpow (Or.inl hXne)).hasDerivAt.differentiableAt
    exact hcpow.differentiableOn
  ¬Ј fun_prop
  ¬Ј intro s hs
    simp only [Set.mem_setOf_eq] at hs
    have h1 : s вЙ† 0 := by intro h; rw [h] at hs; simp at hs
    have h2 : s + 1 вЙ† 0 := by
      intro h
      have : s = -1 := by linear_combination h
      rw [this] at hs; norm_num at hs
    exact mul_ne_zero h1 h2

/-- **Smoothed-kernel magnitude** (SW brick B3 input): `вАЦX^s/(s(s+1))вАЦ = X^{Re s}/(вАЦsвАЦвАЦs+1вАЦ)`
    for `X > 0`. Via `norm_cpow_eq_rpow_re_of_pos`. -/
lemma perron_kernel_norm (X : вДЭ) (hX : 0 < X) (s : вДВ) :
    вАЦ(X : вДВ) ^ s / (s * (s + 1))вАЦ = X ^ s.re / (вАЦsвАЦ * вАЦs + 1вАЦ) := by
  rw [norm_div, norm_mul, norm_cpow_eq_rpow_re_of_pos hX]

/-- **Smoothed-kernel vertical decay** (SW brick B3 input): `вАЦX^s/(s(s+1))вАЦ вЙ§ X^{Re s}/(Im s)¬≤` off
    the real axis (`вАЦsвАЦ, вАЦs+1вАЦ вЙ• |Im s|`). The `1/t¬≤` decay makes the top/horizontal contour
    integrals `O(X^ѕГ/T)` in the B3 rectangle shift, and the vertical integral absolutely convergent. -/
lemma perron_kernel_decay (X : вДЭ) (hX : 0 < X) (s : вДВ) (hs : s.im вЙ† 0) :
    вАЦ(X : вДВ) ^ s / (s * (s + 1))вАЦ вЙ§ X ^ s.re / s.im ^ 2 := by
  rw [perron_kernel_norm X hX s]
  have him1 : |s.im| вЙ§ вАЦsвАЦ := Complex.abs_im_le_norm s
  have him2 : |s.im| вЙ§ вАЦs + 1вАЦ := by
    have h : (s + 1).im = s.im := by simp
    calc |s.im| = |(s + 1).im| := by rw [h]
      _ вЙ§ вАЦs + 1вАЦ := Complex.abs_im_le_norm _
  have hsq : s.im ^ 2 вЙ§ вАЦsвАЦ * вАЦs + 1вАЦ := by
    rw [вЖР sq_abs, sq]
    exact mul_le_mul him1 him2 (abs_nonneg _) (norm_nonneg _)
  have hX0 : (0 : вДЭ) вЙ§ X ^ s.re := Real.rpow_nonneg hX.le _
  have him0 : (0 : вДЭ) < s.im ^ 2 := (sq_nonneg s.im).lt_of_ne (Ne.symm (pow_ne_zero 2 hs))
  exact div_le_div_of_nonneg_left hX0 him0 hsq

/-- **Derivative of the entire L-function is entire** (SW brick B3 input): for `ѕЗ вЙ† 1`,
    `deriv (LFunction ѕЗ)` is differentiable everywhere (holomorphic вЗТ analytic вЗТ deriv analytic).
    Via `AnalyticOnNhd.deriv`. -/
lemma deriv_LFunction_differentiable {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1) :
    Differentiable вДВ (deriv (DirichletCharacter.LFunction ѕЗ)) := by
  have hana : AnalyticOnNhd вДВ (DirichletCharacter.LFunction ѕЗ) Set.univ :=
    (differentiable_LFunction hѕЗ).differentiableOn.analyticOnNhd isOpen_univ
  have hderiv : AnalyticOnNhd вДВ (deriv (DirichletCharacter.LFunction ѕЗ)) Set.univ := hana.deriv
  intro s
  exact (hderiv s (Set.mem_univ s)).differentiableAt

/-- **Smoothed-Perron integrand holomorphy** (SW brick B3): the integrand
    `(вИТLвА≤/L)¬ЈX^s/(s(s+1))` is holomorphic on `{Re s > 0 вИІ L(s,ѕЗ) вЙ† 0}`. So on the zero-free strip
    (`ѕЗ вЙ† 1`, `Re s > 1вИТg`) the B3 rectangle encloses no pole and Cauchy
    (`integral_boundary_rect_of_continuousOn_of_hasFDerivAt_real`) gives the vertical-integral shift
    `вИЂ_{(ѕГ)} = вИЂ_{(ѕГ')}` (horizontal connectors `вЖТ0` by `perron_kernel_decay`). -/
lemma smoothed_integrand_differentiableOn {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (X : вДЭ) (hX : 0 < X) :
    DifferentiableOn вДВ
      (fun s : вДВ => (-deriv (DirichletCharacter.LFunction ѕЗ) s / DirichletCharacter.LFunction ѕЗ s)
        * ((X : вДВ) ^ s / (s * (s + 1))))
      {s : вДВ | 0 < s.re вИІ DirichletCharacter.LFunction ѕЗ s вЙ† 0} := by
  have hSsub : {s : вДВ | 0 < s.re вИІ DirichletCharacter.LFunction ѕЗ s вЙ† 0} вКЖ {s : вДВ | 0 < s.re} :=
    fun s hs => hs.1
  apply DifferentiableOn.mul
  ¬Ј apply DifferentiableOn.div
    ¬Ј exact ((deriv_LFunction_differentiable ѕЗ hѕЗ).neg).differentiableOn
    ¬Ј exact (differentiable_LFunction hѕЗ).differentiableOn
    ¬Ј intro s hs; exact hs.2
  ¬Ј exact (perron_kernel_differentiableOn X hX).mono hSsub

/-- **B3 rectangle Cauchy-vanishing**: for a closed rectangle `[z,w]` inside the zero-free strip
    `{Re s > 0 вИІ L(s,ѕЗ) вЙ† 0}` (`ѕЗ вЙ† 1`), the smoothed-Perron integrand's boundary integral vanishes
    (CauchyвАУGoursat, `integral_boundary_rect_eq_zero_of_differentiableOn` +
    `smoothed_integrand_differentiableOn`). Equating the two vertical sides (as `T вЖТ вИЮ`, the
    horizontal sides `вЖТ0` by `perron_kernel_decay`) gives the contour shift `вИЂ_{(ѕГ)} = вИЂ_{(ѕГ')}`
    for `ѕЗ вЙ† 1` вАФ the heart of B3. -/
lemma smoothed_integrand_rect_zero {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (X : вДЭ) (hX : 0 < X) (z w : вДВ)
    (hrect : Complex.reProdIm (Set.uIcc z.re w.re) (Set.uIcc z.im w.im)
      вКЖ {s : вДВ | 0 < s.re вИІ DirichletCharacter.LFunction ѕЗ s вЙ† 0}) :
    (вИЂ x : вДЭ in z.re..w.re,
        (-deriv (DirichletCharacter.LFunction ѕЗ) (x + z.im * I) / DirichletCharacter.LFunction ѕЗ (x + z.im * I))
          * ((X : вДВ) ^ ((x : вДВ) + z.im * I) / (((x : вДВ) + z.im * I) * ((x : вДВ) + z.im * I + 1))))
      - (вИЂ x : вДЭ in z.re..w.re,
        (-deriv (DirichletCharacter.LFunction ѕЗ) (x + w.im * I) / DirichletCharacter.LFunction ѕЗ (x + w.im * I))
          * ((X : вДВ) ^ ((x : вДВ) + w.im * I) / (((x : вДВ) + w.im * I) * ((x : вДВ) + w.im * I + 1))))
      + I вАҐ (вИЂ y : вДЭ in z.im..w.im,
        (-deriv (DirichletCharacter.LFunction ѕЗ) (w.re + y * I) / DirichletCharacter.LFunction ѕЗ (w.re + y * I))
          * ((X : вДВ) ^ ((w.re : вДВ) + y * I) / (((w.re : вДВ) + y * I) * ((w.re : вДВ) + y * I + 1))))
      - I вАҐ (вИЂ y : вДЭ in z.im..w.im,
        (-deriv (DirichletCharacter.LFunction ѕЗ) (z.re + y * I) / DirichletCharacter.LFunction ѕЗ (z.re + y * I))
          * ((X : вДВ) ^ ((z.re : вДВ) + y * I) / (((z.re : вДВ) + y * I) * ((z.re : вДВ) + y * I + 1))))
      = 0 :=
  integral_boundary_rect_eq_zero_of_differentiableOn _ z w
    ((smoothed_integrand_differentiableOn ѕЗ hѕЗ X hX).mono hrect)

/-- **Integrand continuity on the vertical line `Re = ѕГ > 1`** (SW brick B3 input): `t вЖ¶ F(ѕГ+it)` is
    continuous (the integrand is holomorphic on `{Re>0 вИІ LвЙ†0}`; the line `Re=ѕГ>1` lies inside it by
    `LFunction_ne_zero_re_ge_one`). Prerequisite for the vertical Perron integral and its `TвЖТвИЮ` limit. -/
lemma integrand_continuous_on_line {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (X : вДЭ) (hX : 0 < X) (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    Continuous (fun t : вДЭ =>
      (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + t * I))
        * ((X : вДВ) ^ ((ѕГ : вДВ) + t * I) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1)))) := by
  apply (smoothed_integrand_differentiableOn ѕЗ hѕЗ X hX).continuousOn.comp_continuous
    (by fun_prop)
  intro t
  refine вЯ®?_, ?_вЯ©
  ¬Ј simp
    linarith
  ¬Ј exact LFunction_ne_zero_re_ge_one ѕЗ hѕЗ (by simp; linarith)

/-- **`вИТLвА≤/L` uniformly bounded on the line `Re = ѕГ > 1`** (SW brick B3 input): `вАЦвИТLвА≤/L(ѕГ+it,ѕЗ)вАЦ вЙ§
    вИС_n ќЫ(n)/n^ѕГ` for all `t` (a constant `B_ѕГ`). Via `neg_logDeriv_LFunction_eq` (= the ѕЗ¬ЈќЫ Dirichlet
    series) + `norm_tsum_le_tsum_norm` + `norm_term_eq` (the term norm depends only on `Re s = ѕГ`).
    With `perron_kernel_decay` (`1/t¬≤`) this makes the vertical integrand integrable on `Re = ѕГ`. -/
lemma neg_logDeriv_bounded_on_line {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    вИГ B : вДЭ, вИА t : вДЭ,
      вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + t * I)вАЦ вЙ§ B := by
  refine вЯ®вИС' n : вДХ, вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) (ѕГ : вДВ) nвАЦ, fun t => ?_вЯ©
  have hre : ((ѕГ : вДВ) + t * I).re = ѕГ := by simp
  have hs : 1 < ((ѕГ : вДВ) + t * I).re := by rw [hre]; exact hѕГ
  rw [neg_logDeriv_LFunction_eq ѕЗ hs]
  have hsummable : Summable (fun n : вДХ =>
      вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) ((ѕГ : вДВ) + t * I) nвАЦ) :=
    summable_norm_iff.mpr (LSeriesSummable_twist_vonMangoldt ѕЗ hs)
  calc вАЦLSeries (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) ((ѕГ : вДВ) + t * I)вАЦ
      вЙ§ вИС' n : вДХ, вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) ((ѕГ : вДВ) + t * I) nвАЦ :=
        norm_tsum_le_tsum_norm hsummable
    _ = вИС' n : вДХ, вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) (ѕГ : вДВ) nвАЦ := by
        apply tsum_congr; intro n
        rw [LSeries.norm_term_eq, LSeries.norm_term_eq, hre, Complex.ofReal_re]

open MeasureTheory in
/-- **Vertical-integrand integrability on `Re = ѕГ > 1`** (SW brick B3): the smoothed-Perron integrand
    `t вЖ¶ F(ѕГ+it)` is integrable over `вДЭ`. Domination: `вАЦFвАЦ = вАЦвИТLвА≤/LвАЦ¬ЈвАЦkernelвАЦ вЙ§ B¬ЈX^ѕГ/(ѕГ¬≤+t¬≤) вЙ§
    B¬ЈX^ѕГ/(1+t¬≤)` (`neg_logDeriv_bounded_on_line`, `perron_kernel_norm`, `вАЦsвАЦвАЦs+1вАЦ вЙ• ѕГ¬≤+t¬≤` via
    `norm_add_mul_I`, and `ѕГ¬≤вЙ•1`), dominated by the integrable `B¬ЈX^ѕГ¬Ј(1+t¬≤)вБї¬є`
    (`integrable_inv_one_add_sq`). So the vertical Perron integral is a well-defined Bochner integral. -/
lemma integrand_integrable_on_line {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (X : вДЭ) (hX : 0 < X) (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    Integrable (fun t : вДЭ =>
      (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + t * I))
        * ((X : вДВ) ^ ((ѕГ : вДВ) + t * I) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1)))) := by
  obtain вЯ®B, hBвЯ© := neg_logDeriv_bounded_on_line ѕЗ ѕГ hѕГ
  have hB0 : 0 вЙ§ B := le_trans (norm_nonneg _) (hB 0)
  have hXѕГ0 : 0 вЙ§ X ^ ѕГ := Real.rpow_nonneg hX.le _
  refine Integrable.mono' (g := fun t : вДЭ => B * X ^ ѕГ * (1 + t ^ 2)вБї¬є) ?_
    (integrand_continuous_on_line ѕЗ hѕЗ X hX ѕГ hѕГ).aestronglyMeasurable ?_
  ¬Ј exact integrable_inv_one_add_sq.const_mul (B * X ^ ѕГ)
  ¬Ј apply Filter.Eventually.of_forall
    intro t
    have hknorm : вАЦ(X : вДВ) ^ ((ѕГ : вДВ) + t * I) / (((ѕГ : вДВ) + t * I) * ((ѕГ : вДВ) + t * I + 1))вАЦ
        = X ^ ѕГ / (вАЦ(ѕГ : вДВ) + t * IвАЦ * вАЦ(ѕГ : вДВ) + t * I + 1вАЦ) := by
      rw [perron_kernel_norm X hX]; congr 1; simp
    have hden : ѕГ ^ 2 + t ^ 2 вЙ§ вАЦ(ѕГ : вДВ) + вЖСt * IвАЦ * вАЦ(ѕГ : вДВ) + вЖСt * I + 1вАЦ := by
      have e1 : вАЦ(ѕГ : вДВ) + вЖСt * IвАЦ = Real.sqrt (ѕГ ^ 2 + t ^ 2) := Complex.norm_add_mul_I ѕГ t
      have e2 : (ѕГ : вДВ) + вЖСt * I + 1 = ((ѕГ + 1 : вДЭ) : вДВ) + вЖСt * I := by push_cast; ring
      have e3 : вАЦ(ѕГ : вДВ) + вЖСt * I + 1вАЦ = Real.sqrt ((ѕГ + 1) ^ 2 + t ^ 2) := by
        rw [e2]; exact Complex.norm_add_mul_I _ _
      rw [e1, e3]
      have h4 : Real.sqrt (ѕГ ^ 2 + t ^ 2) вЙ§ Real.sqrt ((ѕГ + 1) ^ 2 + t ^ 2) :=
        Real.sqrt_le_sqrt (by nlinarith)
      calc ѕГ ^ 2 + t ^ 2 = Real.sqrt (ѕГ ^ 2 + t ^ 2) * Real.sqrt (ѕГ ^ 2 + t ^ 2) :=
            (Real.mul_self_sqrt (by positivity)).symm
        _ вЙ§ Real.sqrt (ѕГ ^ 2 + t ^ 2) * Real.sqrt ((ѕГ + 1) ^ 2 + t ^ 2) :=
            mul_le_mul_of_nonneg_left h4 (Real.sqrt_nonneg _)
    have hѕГ2 : (0 : вДЭ) < ѕГ ^ 2 + t ^ 2 := by nlinarith [hѕГ, sq_nonneg t]
    have hle1 : (1 : вДЭ) + t ^ 2 вЙ§ ѕГ ^ 2 + t ^ 2 := by nlinarith
    calc вАЦ(-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + вЖСt * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + вЖСt * I))
            * ((X : вДВ) ^ ((ѕГ : вДВ) + вЖСt * I) / (((ѕГ : вДВ) + вЖСt * I) * ((ѕГ : вДВ) + вЖСt * I + 1)))вАЦ
        = вАЦ(-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ : вДВ) + вЖСt * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ : вДВ) + вЖСt * I))вАЦ
            * вАЦ(X : вДВ) ^ ((ѕГ : вДВ) + вЖСt * I) / (((ѕГ : вДВ) + вЖСt * I) * ((ѕГ : вДВ) + вЖСt * I + 1))вАЦ := norm_mul _ _
      _ вЙ§ B * (X ^ ѕГ / (ѕГ ^ 2 + t ^ 2)) := by
          rw [hknorm]
          refine mul_le_mul (hB t) ?_ (by positivity) hB0
          exact div_le_div_of_nonneg_left hXѕГ0 hѕГ2 hden
      _ вЙ§ B * X ^ ѕГ * (1 + t ^ 2)вБї¬є := by
          rw [вЖР mul_div_assoc, вЖР div_eq_mul_inv]
          exact div_le_div_of_nonneg_left (mul_nonneg hB0 hXѕГ0) (by positivity) hle1

open MeasureTheory intervalIntegral in
/-- **Horizontal connector bound** (SW brick B3): the top/bottom sides of the B3 rectangle at height
    `T` are `O(X^ѕГ/T¬≤)`: `вАЦвИЂ_{ѕГ'}^{ѕГ} F(x+iT)вАЦ вЙ§ (ѕГвИТѕГ')¬ЈM¬ЈX^ѕГ/T¬≤`, given a uniform `вАЦвИТLвА≤/LвАЦ вЙ§ M`
    bound on the segment (from `contour_logDeriv_bound`, `M = C¬ЈN^ќµ¬ЈL_T¬≤` polylog). Via
    `perron_kernel_decay` (`вАЦkernelвАЦ вЙ§ X^x/T¬≤`) + `X^x вЙ§ X^ѕГ` (`XвЙ•1`, `xвЙ§ѕГ`) +
    `norm_integral_le_of_norm_le_const`. Drives the connectors `вЖТ0` as `TвЖТвИЮ` (polylog `M`, `1/T¬≤`). -/
lemma horizontal_connector_bound {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X : вДЭ) (hX1 : 1 вЙ§ X) (ѕГ' ѕГ T M : вДЭ) (hѕГ'ѕГ : ѕГ' вЙ§ ѕГ) (hT : T вЙ† 0) (hM0 : 0 вЙ§ M)
    (hM : вИА x вИИ Set.uIcc ѕГ' ѕГ,
      вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((x : вДВ) + T * I) / DirichletCharacter.LFunction ѕЗ ((x : вДВ) + T * I)вАЦ вЙ§ M) :
    вАЦвИЂ x : вДЭ in ѕГ'..ѕГ,
        (-deriv (DirichletCharacter.LFunction ѕЗ) ((x : вДВ) + T * I) / DirichletCharacter.LFunction ѕЗ ((x : вДВ) + T * I))
          * ((X : вДВ) ^ ((x : вДВ) + T * I) / (((x : вДВ) + T * I) * ((x : вДВ) + T * I + 1)))вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) := by
  have hX0 : (0 : вДЭ) < X := by linarith
  have hT2 : (0 : вДЭ) < T ^ 2 := (sq_nonneg T).lt_of_ne (Ne.symm (pow_ne_zero 2 hT))
  have hkey : вИА x вИИ Set.uIcc ѕГ' ѕГ,
      вАЦ(-deriv (DirichletCharacter.LFunction ѕЗ) ((x : вДВ) + T * I) / DirichletCharacter.LFunction ѕЗ ((x : вДВ) + T * I))
          * ((X : вДВ) ^ ((x : вДВ) + T * I) / (((x : вДВ) + T * I) * ((x : вДВ) + T * I + 1)))вАЦ
        вЙ§ M * X ^ ѕГ / T ^ 2 := by
    intro x hx
    have hxѕГ : x вЙ§ ѕГ := (Set.uIcc_of_le hѕГ'ѕГ вЦЄ hx : x вИИ Set.Icc ѕГ' ѕГ).2
    have him : ((x : вДВ) + T * I).im = T := by simp
    have hre : ((x : вДВ) + T * I).re = x := by simp
    have hkd := perron_kernel_decay X hX0 ((x : вДВ) + T * I) (by rw [him]; exact hT)
    rw [hre, him] at hkd
    have h3 : X ^ x вЙ§ X ^ ѕГ := Real.rpow_le_rpow_of_exponent_le hX1 hxѕГ
    have hdiv : X ^ x / T ^ 2 вЙ§ X ^ ѕГ / T ^ 2 := by gcongr
    rw [norm_mul]
    calc вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((x : вДВ) + T * I) / DirichletCharacter.LFunction ѕЗ ((x : вДВ) + T * I)вАЦ
            * вАЦ(X : вДВ) ^ ((x : вДВ) + T * I) / (((x : вДВ) + T * I) * ((x : вДВ) + T * I + 1))вАЦ
        вЙ§ M * (X ^ x / T ^ 2) := mul_le_mul (hM x hx) hkd (norm_nonneg _) hM0
      _ вЙ§ M * (X ^ ѕГ / T ^ 2) := mul_le_mul_of_nonneg_left hdiv hM0
      _ = M * X ^ ѕГ / T ^ 2 := by ring
  calc вАЦвИЂ x : вДЭ in ѕГ'..ѕГ,
          (-deriv (DirichletCharacter.LFunction ѕЗ) ((x : вДВ) + T * I) / DirichletCharacter.LFunction ѕЗ ((x : вДВ) + T * I))
            * ((X : вДВ) ^ ((x : вДВ) + T * I) / (((x : вДВ) + T * I) * ((x : вДВ) + T * I + 1)))вАЦ
      вЙ§ (M * X ^ ѕГ / T ^ 2) * |ѕГ - ѕГ'| :=
        intervalIntegral.norm_integral_le_of_norm_le_const
          (fun x hx => hkey x (Set.uIoc_subset_uIcc hx))
    _ = (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) := by
        rw [abs_of_nonneg (by linarith)]; ring

open MeasureTheory Filter Topology in
/-- **Truncated вЖТ full vertical integral** (SW brick B3): `вИЂ_{-T}^{T} g вЖТ вИЂ_вДЭ g` as `T вЖТ вИЮ` for
    integrable `g` вАФ the right/left sides of the B3 rectangle converge to the full vertical Perron
    integrals. Via `tendsto_setIntegral_of_monotone` over `Ioc(-T,T) вЖЧ univ`. Applied with
    `g = F(ѕГ+¬Јi)` (`integrand_integrable_on_line`) and `g = F(ѕГ'+¬Јi)`, plus the horizontal connectors
    `вЖТ0` (`horizontal_connector_bound`), the rectangle identity `smoothed_integrand_rect_zero` yields
    the contour shift `вИЂ_{(ѕГ)} = вИЂ_{(ѕГ')}` in the limit. -/
lemma vertical_integral_tendsto (g : вДЭ вЖТ вДВ) (hg : Integrable g) :
    Tendsto (fun T : вДЭ => вИЂ y in (-T)..T, g y) atTop (рЭУЭ (вИЂ y, g y)) := by
  have hunion : (вЛГ T : вДЭ, Set.Ioc (-T) T) = Set.univ := by
    ext x
    simp only [Set.mem_iUnion, Set.mem_Ioc, Set.mem_univ, iff_true]
    exact вЯ®|x| + 1, by have := neg_abs_le x; linarith, by have := le_abs_self x; linarithвЯ©
  have hmono : Monotone (fun T : вДЭ => Set.Ioc (-T) T) := by
    intro a b hab; apply Set.Ioc_subset_Ioc <;> linarith
  have hint : IntegrableOn g (вЛГ T : вДЭ, Set.Ioc (-T) T) := by rw [hunion]; exact hg.integrableOn
  have key := tendsto_setIntegral_of_monotone (fun T : вДЭ => measurableSet_Ioc) hmono hint
  rw [hunion, MeasureTheory.setIntegral_univ] at key
  refine key.congr' ?_
  filter_upwards [Filter.eventually_ge_atTop (0 : вДЭ)] with T hT
  exact (intervalIntegral.integral_of_le (by linarith : -T вЙ§ T)).symm

/-- **Orthogonality character-sum bound** (SW brick B5): `вАЦвИС_ѕЗ ѕЗ(a)¬Јf(ѕЗ)вАЦ вЙ§ вИС_ѕЗ вАЦf(ѕЗ)вАЦ` вАФ Dirichlet
    character values have norm вЙ§ 1 (`norm_le_one`). Applied to `psi_ap_orthogonality` with
    `f ѕЗ = ѕИ(X,ѕЗ)`, this reduces the AP prime-count error `ѕЖ(q)¬ЈвИС_{nвЙ°a}ќЫ вИТ вЛѓ` to the sum of
    per-character `ѕИ(X,ѕЗ)` bounds (the ѕЗвВА main term `X` + the ѕЗвЙ†1 SW rate), completing the B5 assembly
    skeleton for `siegel_walfisz`. -/
lemma char_sum_norm_le {q : вДХ} [NeZero q] (a : ZMod q) (f : DirichletCharacter вДВ q вЖТ вДВ) :
    вАЦвИС ѕЗ : DirichletCharacter вДВ q, ѕЗ a * f ѕЗвАЦ вЙ§ вИС ѕЗ : DirichletCharacter вДВ q, вАЦf ѕЗвАЦ := by
  calc вАЦвИС ѕЗ : DirichletCharacter вДВ q, ѕЗ a * f ѕЗвАЦ
      вЙ§ вИС ѕЗ : DirichletCharacter вДВ q, вАЦѕЗ a * f ѕЗвАЦ := norm_sum_le _ _
    _ вЙ§ вИС ѕЗ : DirichletCharacter вДВ q, вАЦf ѕЗвАЦ := by
        apply Finset.sum_le_sum
        intro ѕЗ _
        rw [norm_mul]
        calc вАЦѕЗ aвАЦ * вАЦf ѕЗвАЦ вЙ§ 1 * вАЦf ѕЗвАЦ :=
              mul_le_mul_of_nonneg_right (norm_le_one ѕЗ a) (norm_nonneg _)
          _ = вАЦf ѕЗвАЦ := one_mul _

/-- **B5 principal-character separation**: `вАЦвИС_ѕЗ ѕЗ(a)¬Јf(ѕЗ)вАЦ вЙ§ вАЦf(1)вАЦ + вИС_{ѕЗвЙ†1} вАЦf(ѕЗ)вАЦ`. Isolates the
    principal character `ѕЗвВА=1` (whose `ѕИ(X,ѕЗвВА)` carries the main term `X`) from the nontrivial
    characters (whose `ѕИ(X,ѕЗ)` is `O(SW rate)`). The B5 reduction shape for `siegel_walfisz`:
    `вАЦѕЖ(q)¬Ј(AP count) вИТ XвАЦ вЙ§ вАЦѕИ(X,ѕЗвВА)вИТXвАЦ + вИС_{ѕЗвЙ†1}вАЦѕИ(X,ѕЗ)вАЦ`. -/
lemma char_sum_norm_le_split {q : вДХ} [NeZero q] (a : ZMod q) (f : DirichletCharacter вДВ q вЖТ вДВ) :
    вАЦвИС ѕЗ : DirichletCharacter вДВ q, ѕЗ a * f ѕЗвАЦ
      вЙ§ вАЦf 1вАЦ + вИС ѕЗ вИИ (Finset.univ.erase (1 : DirichletCharacter вДВ q)), вАЦf ѕЗвАЦ := by
  refine le_trans (char_sum_norm_le a f) ?_
  rw [вЖР Finset.add_sum_erase Finset.univ (fun ѕЗ => вАЦf ѕЗвАЦ) (Finset.mem_univ 1)]

/-- **B5 reduction** (SW brick B5c): `вАЦвИС_ѕЗ ѕЗ(a)¬Јf(ѕЗ)вАЦ вЙ§ вАЦf(1)вАЦ + (#ѕЗ вИТ 1)¬ЈR` given a uniform bound
    `R` on the nontrivial characters. With `f ѕЗ = ѕИ(X,ѕЗ)` and `psi_ap_orthogonality`, this reduces
    the AP prime-count error to the ѕЗвВА main-term error `вАЦѕИ(X,ѕЗвВА)вИТXвАЦ` plus `(ѕЖ(q)вИТ1)√Ч` the SW rate вАФ
    dividing by `ѕЖ(q)` then gives the `siegel_walfisz` statement shape. -/
lemma char_sum_reduction {q : вДХ} [NeZero q] (a : ZMod q) (R : вДЭ) (hR : 0 вЙ§ R)
    (f : DirichletCharacter вДВ q вЖТ вДВ) (hf : вИА ѕЗ : DirichletCharacter вДВ q, ѕЗ вЙ† 1 вЖТ вАЦf ѕЗвАЦ вЙ§ R) :
    вАЦвИС ѕЗ : DirichletCharacter вДВ q, ѕЗ a * f ѕЗвАЦ
      вЙ§ вАЦf 1вАЦ + (Fintype.card (DirichletCharacter вДВ q) - 1 : вДХ) * R := by
  have hcard : (Finset.univ.erase (1 : DirichletCharacter вДВ q)).card
      = Fintype.card (DirichletCharacter вДВ q) - 1 := by
    rw [Finset.card_erase_of_mem (Finset.mem_univ _), Finset.card_univ]
  have hbound : вИС ѕЗ вИИ (Finset.univ.erase (1 : DirichletCharacter вДВ q)), вАЦf ѕЗвАЦ
      вЙ§ (Fintype.card (DirichletCharacter вДВ q) - 1 : вДХ) * R := by
    calc вИС ѕЗ вИИ (Finset.univ.erase (1 : DirichletCharacter вДВ q)), вАЦf ѕЗвАЦ
        вЙ§ (Finset.univ.erase (1 : DirichletCharacter вДВ q)).card вАҐ R :=
          Finset.sum_le_card_nsmul _ _ _ (fun ѕЗ hѕЗ => hf ѕЗ (Finset.ne_of_mem_erase hѕЗ))
      _ = (Fintype.card (DirichletCharacter вДВ q) - 1 : вДХ) * R := by rw [hcard, nsmul_eq_mul]
  linarith [char_sum_norm_le_split a f, hbound]

open MeasureTheory in
/-- **Truncation tail bound** (SW brick W1a): for integrable `g` with `вАЦg(t)вАЦ вЙ§ C/t¬≤` off `0`,
    `вАЦвИЂ_вДЭ g вИТ вИЂ_{-T}^{T} gвАЦ вЙ§ 2C/T`. The quantitative ѕГ-line truncation error for the B3 finite-T
    rectangle assembly (`g = F(ѕГ+it)`, `C = B_ѕГ¬ЈX^ѕГ` via `neg_logDeriv_bounded_on_line` +
    `perron_kernel_decay`) вАФ ties `smoothed_perron_LFunction`'s full vertical integral to the
    truncated one appearing in `smoothed_integrand_rect_zero`. -/
lemma truncation_tail_bound (g : вДЭ вЖТ вДВ) (hg : Integrable g) (C T : вДЭ) (hT : 0 < T)
    (hbound : вИА t : вДЭ, t вЙ† 0 вЖТ вАЦg tвАЦ вЙ§ C / t ^ 2) :
    вАЦ(вИЂ t, g t) - вИЂ t in (-T)..T, g tвАЦ вЙ§ 2 * C / T := by
  have hC : 0 вЙ§ C := by
    have h1 := hbound 1 one_ne_zero
    have h2 : (0:вДЭ) вЙ§ вАЦg 1вАЦ := norm_nonneg _
    have h3 : C / (1:вДЭ) ^ 2 = C := by norm_num
    linarith [h3 вЦЄ h1]
  have tailR : вИА h : вДЭ вЖТ вДВ, (вИА x вИИ Set.Ioi T, вАЦh xвАЦ вЙ§ C / x ^ 2) вЖТ
      вАЦвИЂ x in Set.Ioi T, h xвАЦ вЙ§ C / T := by
    intro h hh
    have h1 := MeasureTheory.norm_integral_le_integral_norm (ќЉ := volume.restrict (Set.Ioi T)) h
    have hgi : Integrable (fun x : вДЭ => C * x ^ (-2:вДЭ)) (volume.restrict (Set.Ioi T)) :=
      (integrableOn_Ioi_rpow_of_lt (by norm_num) hT).const_mul C
    have h2 : (вИЂ x in Set.Ioi T, вАЦh xвАЦ) вЙ§ вИЂ x in Set.Ioi T, C * x ^ (-2:вДЭ) := by
      apply MeasureTheory.integral_mono_of_nonneg
      ¬Ј exact Filter.Eventually.of_forall fun x => norm_nonneg _
      ¬Ј exact hgi
      ¬Ј filter_upwards [MeasureTheory.ae_restrict_mem measurableSet_Ioi] with x hx
        have hx0 : 0 < x := lt_trans hT hx
        have e : x ^ (-2:вДЭ) = ((x : вДЭ) ^ (2:вДХ))вБї¬є := by
          rw [Real.rpow_neg hx0.le, show (2:вДЭ) = ((2:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
        rw [e, вЖР div_eq_mul_inv]
        exact hh x hx
    have h3 : вИЂ x in Set.Ioi T, C * x ^ (-2:вДЭ) = C / T := by
      rw [MeasureTheory.integral_const_mul, integral_Ioi_rpow_of_lt (by norm_num) hT,
        show (-2:вДЭ) + 1 = -1 by norm_num, Real.rpow_neg_one]
      ring
    linarith
  have hadd := MeasureTheory.integral_add_compl
    (measurableSet_Ioc : MeasurableSet (Set.Ioc (-T) T)) hg
  have hdiff : (вИЂ t, g t) - (вИЂ t in Set.Ioc (-T) T, g t) = вИЂ t in (Set.Ioc (-T) T)бґЬ, g t := by
    rw [вЖР hadd]; ring
  have hcompl : (Set.Ioc (-T) T)бґЬ = Set.Iic (-T) вИ™ Set.Ioi T := by
    ext x
    simp only [Set.mem_compl_iff, Set.mem_Ioc, Set.mem_union, Set.mem_Iic, Set.mem_Ioi]
    push_neg
    constructor
    ¬Ј intro hx
      by_cases h : -T < x
      ¬Ј exact Or.inr (hx h)
      ¬Ј exact Or.inl (by linarith [not_lt.mp h])
    ¬Ј intro hx h1
      rcases hx with h | h
      ¬Ј linarith
      ¬Ј linarith
  have hdisj : Disjoint (Set.Iic (-T)) (Set.Ioi T) := Set.Iic_disjoint_Ioi (by linarith)
  rw [intervalIntegral.integral_of_le (by linarith : -T вЙ§ T), hdiff, hcompl,
    MeasureTheory.setIntegral_union hdisj measurableSet_Ioi hg.integrableOn hg.integrableOn]
  have hleft : вАЦвИЂ t in Set.Iic (-T), g tвАЦ вЙ§ C / T := by
    rw [вЖР integral_comp_neg_Ioi]
    apply tailR
    intro x hx
    have hx0 : 0 < x := lt_trans hT hx
    have hb := hbound (-x) (by simpa using hx0.ne')
    rwa [show (-x) ^ 2 = x ^ 2 by ring] at hb
  have hright : вАЦвИЂ t in Set.Ioi T, g tвАЦ вЙ§ C / T := by
    apply tailR
    intro x hx
    exact hbound x (ne_of_gt (lt_trans hT hx))
  calc вАЦ(вИЂ t in Set.Iic (-T), g t) + вИЂ t in Set.Ioi T, g tвАЦ
      вЙ§ вАЦвИЂ t in Set.Iic (-T), g tвАЦ + вАЦвИЂ t in Set.Ioi T, g tвАЦ := norm_add_le _ _
    _ вЙ§ C / T + C / T := add_le_add hleft hright
    _ = 2 * C / T := by ring

open MeasureTheory in
/-- **Shifted-line integral bound** (SW brick W1b): if `вАЦF(t)вАЦ вЙ§ M¬ЈXѕГ/(ѕГ'¬≤+t¬≤)` on `(-T,T]` with
    `ѕГ' вЙ• 3/4`, then `вАЦвИЂ_{-T}^{T} FвАЦ вЙ§ 6¬ЈM¬ЈXѕГ`. -/
lemma shifted_line_integral_bound (F : вДЭ вЖТ вДВ) (M XѕГ ѕГ' T : вДЭ)
    (hM : 0 вЙ§ M) (hXѕГ : 0 вЙ§ XѕГ) (hѕГ' : 3/4 вЙ§ ѕГ') (hT : 0 вЙ§ T)
    (hpt : вИА t : вДЭ, t вИИ Set.Ioc (-T) T вЖТ вАЦF tвАЦ вЙ§ M * XѕГ / (ѕГ' ^ 2 + t ^ 2)) :
    вАЦвИЂ t in (-T)..T, F tвАЦ вЙ§ 6 * M * XѕГ := by
  have hd1 : вИА t : вДЭ, (0:вДЭ) < ѕГ' ^ 2 + t ^ 2 := fun t => by nlinarith [sq_nonneg t]
  have hd2 : вИА t : вДЭ, (0:вДЭ) < 1 + t ^ 2 := fun t => by nlinarith [sq_nonneg t]
  have hgcont : Continuous (fun t : вДЭ => M * XѕГ / (ѕГ' ^ 2 + t ^ 2)) :=
    continuous_const.div (by fun_prop) (fun t => (hd1 t).ne')
  have hhcont : Continuous (fun t : вДЭ => 16/9 * (M * XѕГ) * (1 + t ^ 2)вБї¬є) :=
    continuous_const.mul (Continuous.invвВА (by fun_prop) (fun t => (hd2 t).ne'))
  have step1 := intervalIntegral.norm_integral_le_of_norm_le (by linarith : -T вЙ§ T)
    (Filter.Eventually.of_forall hpt) (hgcont.intervalIntegrable (ќЉ := volume) (-T) T)
  have step2 : (вИЂ t in (-T)..T, M * XѕГ / (ѕГ' ^ 2 + t ^ 2))
      вЙ§ вИЂ t in (-T)..T, 16/9 * (M * XѕГ) * (1 + t ^ 2)вБї¬є := by
    apply intervalIntegral.integral_mono_on (by linarith)
      (hgcont.intervalIntegrable (ќЉ := volume) (-T) T) (hhcont.intervalIntegrable (ќЉ := volume) (-T) T)
    intro t _
    have h9 : 9/16 * (1 + t ^ 2) вЙ§ ѕГ' ^ 2 + t ^ 2 := by nlinarith [sq_nonneg t]
    calc M * XѕГ / (ѕГ' ^ 2 + t ^ 2) вЙ§ M * XѕГ / (9/16 * (1 + t ^ 2)) :=
          div_le_div_of_nonneg_left (mul_nonneg hM hXѕГ) (by nlinarith [hd2 t]) h9
      _ = 16/9 * (M * XѕГ) * (1 + t ^ 2)вБї¬є := by
          field_simp
  have step3 : (вИЂ t in (-T)..T, 16/9 * (M * XѕГ) * (1 + t ^ 2)вБї¬є)
      = 16/9 * (M * XѕГ) * вИЂ t in (-T)..T, (1 + t ^ 2)вБї¬є := by
    rw [вЖР intervalIntegral.integral_const_mul]
  have step4 : (вИЂ t in (-T)..T, (1 + t ^ 2)вБї¬є) вЙ§ Real.pi := by
    rw [intervalIntegral.integral_of_le (by linarith : -T вЙ§ T)]
    calc (вИЂ t in Set.Ioc (-T) T, (1 + t ^ 2)вБї¬є)
        вЙ§ вИЂ t : вДЭ, (1 + t ^ 2)вБї¬є := by
          apply MeasureTheory.setIntegral_le_integral integrable_inv_one_add_sq
          exact Filter.Eventually.of_forall (fun t => by positivity)
      _ = Real.pi := integral_univ_inv_one_add_sq
  have h0 : 0 вЙ§ M * XѕГ := mul_nonneg hM hXѕГ
  have hInn : (0:вДЭ) вЙ§ вИЂ t in (-T)..T, (1 + t ^ 2)вБї¬є := by
    apply intervalIntegral.integral_nonneg (by linarith)
    intro t _
    positivity
  have step5 : 16/9 * (M * XѕГ) * (вИЂ t in (-T)..T, (1 + t ^ 2)вБї¬є) вЙ§ 6 * M * XѕГ := by
    have hѕА : Real.pi < 3.15 := Real.pi_lt_d2
    calc 16/9 * (M * XѕГ) * (вИЂ t in (-T)..T, (1 + t ^ 2)вБї¬є)
        вЙ§ 16/9 * (M * XѕГ) * Real.pi := by
          apply mul_le_mul_of_nonneg_left step4 (by positivity)
      _ вЙ§ 6 * M * XѕГ := by nlinarith [Real.pi_pos]
  linarith [step1, step2, step3.le, step3.ge, step5]

/-- **Integrand pointwise bound on a shifted line** (SW brick W1c): given `вАЦвИТLвА≤/L(ѕГ'+it)вАЦ вЙ§ M`,
    the smoothed integrand satisfies `вАЦF(ѕГ'+it)вАЦ вЙ§ M¬ЈX^{ѕГ'}/(ѕГ'¬≤+t¬≤)` вАФ exactly the input to
    `shifted_line_integral_bound`. -/
lemma integrand_pointwise_bound {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X ѕГ' t M : вДЭ) (hX : 0 < X) (hѕГ'0 : 0 < ѕГ') (hM : 0 вЙ§ M)
    (hLL : вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ' : вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ' : вДВ) + t * I)вАЦ вЙ§ M) :
    вАЦ(-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ' : вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ' : вДВ) + t * I))
        * ((X : вДВ) ^ ((ѕГ' : вДВ) + t * I) / (((ѕГ' : вДВ) + t * I) * ((ѕГ' : вДВ) + t * I + 1)))вАЦ
      вЙ§ M * X ^ ѕГ' / (ѕГ' ^ 2 + t ^ 2) := by
  have hknorm : вАЦ(X : вДВ) ^ ((ѕГ' : вДВ) + t * I) / (((ѕГ' : вДВ) + t * I) * ((ѕГ' : вДВ) + t * I + 1))вАЦ
      = X ^ ѕГ' / (вАЦ(ѕГ' : вДВ) + t * IвАЦ * вАЦ(ѕГ' : вДВ) + t * I + 1вАЦ) := by
    rw [perron_kernel_norm X hX]; congr 1; simp
  have hden : ѕГ' ^ 2 + t ^ 2 вЙ§ вАЦ(ѕГ' : вДВ) + вЖСt * IвАЦ * вАЦ(ѕГ' : вДВ) + вЖСt * I + 1вАЦ := by
    have e1 : вАЦ(ѕГ' : вДВ) + вЖСt * IвАЦ = Real.sqrt (ѕГ' ^ 2 + t ^ 2) := Complex.norm_add_mul_I ѕГ' t
    have e2 : (ѕГ' : вДВ) + вЖСt * I + 1 = ((ѕГ' + 1 : вДЭ) : вДВ) + вЖСt * I := by push_cast; ring
    have e3 : вАЦ(ѕГ' : вДВ) + вЖСt * I + 1вАЦ = Real.sqrt ((ѕГ' + 1) ^ 2 + t ^ 2) := by
      rw [e2]; exact Complex.norm_add_mul_I _ _
    rw [e1, e3]
    have h4 : Real.sqrt (ѕГ' ^ 2 + t ^ 2) вЙ§ Real.sqrt ((ѕГ' + 1) ^ 2 + t ^ 2) :=
      Real.sqrt_le_sqrt (by nlinarith)
    calc ѕГ' ^ 2 + t ^ 2 = Real.sqrt (ѕГ' ^ 2 + t ^ 2) * Real.sqrt (ѕГ' ^ 2 + t ^ 2) :=
          (Real.mul_self_sqrt (by positivity)).symm
      _ вЙ§ Real.sqrt (ѕГ' ^ 2 + t ^ 2) * Real.sqrt ((ѕГ' + 1) ^ 2 + t ^ 2) :=
          mul_le_mul_of_nonneg_left h4 (Real.sqrt_nonneg _)
  have hѕГt : (0:вДЭ) < ѕГ' ^ 2 + t ^ 2 := by nlinarith [sq_nonneg t]
  rw [norm_mul, hknorm]
  calc вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ' : вДВ) + вЖСt * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ' : вДВ) + вЖСt * I)вАЦ
        * (X ^ ѕГ' / (вАЦ(ѕГ' : вДВ) + вЖСt * IвАЦ * вАЦ(ѕГ' : вДВ) + вЖСt * I + 1вАЦ))
      вЙ§ M * (X ^ ѕГ' / (ѕГ' ^ 2 + t ^ 2)) := by
        apply mul_le_mul hLL ?_ (by positivity) hM
        exact div_le_div_of_nonneg_left (Real.rpow_nonneg hX.le _) hѕГt hden
    _ = M * X ^ ѕГ' / (ѕГ' ^ 2 + t ^ 2) := by ring

open MeasureTheory in
/-- **W1 capstone (abstract rectangle assembly)**: given the smoothed-Perron representation
    `S = (1/2ѕА)¬ЈвИЂ_вДЭ G(ѕГ+it)`, the ѕГ-line truncation error `Ct`, the rectangle identity, connector
    bounds `Cc`, and the shifted-line bound `Cs`, conclude `вАЦSвАЦ вЙ§ (Cs + 2Cc + Ct)/(2ѕА)`. -/
lemma rectangle_assembly (S : вДВ) (G : вДВ вЖТ вДВ) (ѕГ' ѕГ T Ct Cc Cs : вДЭ)
    (h1 : S = (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ, G ((ѕГ : вДВ) + t * Complex.I))
    (h2 : вАЦ(вИЂ t : вДЭ, G ((ѕГ : вДВ) + t * Complex.I))
        - вИЂ t in (-T)..T, G ((ѕГ : вДВ) + t * Complex.I)вАЦ вЙ§ Ct)
    (h3 : (вИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((-T : вДЭ) : вДВ) * Complex.I))
        - (вИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((T:вДЭ) : вДВ) * Complex.I))
        + Complex.I вАҐ (вИЂ y in (-T)..T, G ((ѕГ:вДВ) + (y:вДВ) * Complex.I))
        - Complex.I вАҐ (вИЂ y in (-T)..T, G ((ѕГ':вДВ) + (y:вДВ) * Complex.I)) = 0)
    (h4 : вАЦвИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((T:вДЭ) : вДВ) * Complex.I)вАЦ вЙ§ Cc)
    (h5 : вАЦвИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((-T:вДЭ) : вДВ) * Complex.I)вАЦ вЙ§ Cc)
    (h6 : вАЦвИЂ y in (-T)..T, G ((ѕГ':вДВ) + (y:вДВ) * Complex.I)вАЦ вЙ§ Cs) :
    вАЦSвАЦ вЙ§ (Cs + 2 * Cc + Ct) / (2 * Real.pi) := by
  set Full := вИЂ t : вДЭ, G ((ѕГ : вДВ) + t * Complex.I) with hFull
  set R := вИЂ y in (-T)..T, G ((ѕГ:вДВ) + (y:вДВ) * Complex.I) with hRdef
  set L := вИЂ y in (-T)..T, G ((ѕГ':вДВ) + (y:вДВ) * Complex.I) with hLdef
  set Btm := вИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((-T:вДЭ) : вДВ) * Complex.I) with hBdef
  set Top := вИЂ x in ѕГ'..ѕГ, G ((x:вДВ) + ((T:вДЭ) : вДВ) * Complex.I) with hTdef
  rw [smul_eq_mul, smul_eq_mul] at h3
  have h7 : Complex.I * R = Complex.I * L + (Top - Btm) := by linear_combination h3
  have hR : вАЦRвАЦ вЙ§ Cs + 2 * Cc := by
    have h8 : вАЦComplex.I * RвАЦ = вАЦRвАЦ := by rw [norm_mul, Complex.norm_I, one_mul]
    have h9 : вАЦComplex.I * LвАЦ = вАЦLвАЦ := by rw [norm_mul, Complex.norm_I, one_mul]
    calc вАЦRвАЦ = вАЦComplex.I * RвАЦ := h8.symm
      _ = вАЦComplex.I * L + (Top - Btm)вАЦ := by rw [h7]
      _ вЙ§ вАЦComplex.I * LвАЦ + вАЦTop - BtmвАЦ := norm_add_le (Complex.I * L) (Top - Btm)
      _ вЙ§ вАЦLвАЦ + (вАЦTopвАЦ + вАЦBtmвАЦ) := by
          rw [h9]
          exact add_le_add le_rfl (norm_sub_le Top Btm)
      _ вЙ§ Cs + (Cc + Cc) := add_le_add h6 (add_le_add h4 h5)
      _ = Cs + 2 * Cc := by ring
  have hfull : вАЦFullвАЦ вЙ§ Cs + 2 * Cc + Ct := by
    have hsplit : Full = (Full - R) + R := by ring
    calc вАЦFullвАЦ = вАЦ(Full - R) + RвАЦ := by rw [вЖР hsplit]
      _ вЙ§ вАЦFull - RвАЦ + вАЦRвАЦ := norm_add_le (Full - R) R
      _ вЙ§ Ct + (Cs + 2 * Cc) := add_le_add h2 hR
      _ = Cs + 2 * Cc + Ct := by ring
  have hnrm : вАЦ(1 : вДВ) / (2 * (Real.pi : вДВ))вАЦ = 1 / (2 * Real.pi) := by
    rw [norm_div, norm_one, norm_mul, Complex.norm_real,
      Real.norm_eq_abs, abs_of_pos Real.pi_pos]
    norm_num
  have h2ѕА : (0:вДЭ) < 2 * Real.pi := by positivity
  rw [h1, norm_mul, hnrm]
  calc 1 / (2 * Real.pi) * вАЦFullвАЦ = вАЦFullвАЦ / (2 * Real.pi) := by ring
    _ вЙ§ (Cs + 2 * Cc + Ct) / (2 * Real.pi) := by gcongr

/-- **Zero-free strip** (SW brick W1d): `L(s,ѕЗ) вЙ† 0` on the contour strip
    `Re s вЙ• 1 вИТ g/2`, `|Im s| вЙ§ T` вАФ a zero there would contradict its own distance bound
    (`contour_zero_distance` at `ѕБ = s`: `0 = вАЦsвИТsвАЦ вЙ• g/2 > 0`). Gives the non-vanishing half of
    the `smoothed_integrand_rect_zero` rectangle hypothesis. -/
lemma LFunction_ne_zero_in_strip (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c : вДЭ, 0 < c вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА T : вДЭ, 0 вЙ§ T вЖТ вИА s : вДВ, |s.im| вЙ§ T вЖТ
    1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ s.re вЖТ
    DirichletCharacter.LFunction ѕЗ s вЙ† 0 := by
  obtain вЯ®c, hc0, hcвЯ© := contour_zero_distance ќµ hќµ0
  refine вЯ®c, hc0, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 T hT0 s hsim hsre hzero
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hkey := hc N ѕЗ hѕЗ1 T hT0 s hsim hsre s hzero (by simp)
  have hLT : (0:вДЭ) < Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 := by
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*(T+1)+7)) := Real.log_nonneg (by nlinarith)
    linarith
  have hg0 : (0:вДЭ) < c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 := by
    have hNe : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
    positivity
  simp only [sub_self, norm_zero] at hkey
  linarith

/-- **Combined contour data** (SW brick W1e): ONE constant `c` under which the strip
    `1 вИТ g/2 вЙ§ Re s вЙ§ 1 + g`, `|Im s| вЙ§ T` (`g = c¬ЈN^{вИТќµ}/L_T`) is simultaneously zero-free and
    carries the `вАЦLвА≤/LвАЦ вЙ§ C¬ЈN^ќµ¬ЈL_T¬≤` bound. `c := min cвВБ cвВВ` + strip monotonicity (a narrower strip
    inherits both properties). Resolves the two independent existentials for the W1 instantiation. -/
lemma contour_combined (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c C : вДЭ, 0 < c вИІ c вЙ§ 1/2 вИІ 1 вЙ§ C вИІ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА T : вДЭ, 0 вЙ§ T вЖТ вИА s : вДВ, |s.im| вЙ§ T вЖТ
    1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ s.re вЖТ
    DirichletCharacter.LFunction ѕЗ s вЙ† 0 вИІ
    (s.re вЙ§ 1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) вЖТ
      вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ
        вЙ§ C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2) := by
  obtain вЯ®cвВБ, hcвВБ0, hzfвЯ© := LFunction_ne_zero_in_strip ќµ hќµ0
  obtain вЯ®cвВВ, C, hcвВВ0, hcвВВ12, hC1, hLLвЯ© := contour_logDeriv_bound ќµ hќµ0
  refine вЯ®min cвВБ cвВВ, C, lt_min hcвВБ0 hcвВВ0, le_trans (min_le_right _ _) hcвВВ12, hC1, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 T hT0 s hsim hsre
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hNe : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hLT : (0:вДЭ) < Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 := by
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*(T+1)+7)) := Real.log_nonneg (by nlinarith)
    linarith
  have hfac : (0:вДЭ) < ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) := by positivity
  have hmono1 : min cвВБ cвВВ * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)
      вЙ§ cвВБ * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) := by
    apply div_le_div_of_nonneg_right (mul_le_mul_of_nonneg_right (min_le_left _ _) hNe.le) hLT.le
  have hmono2 : min cвВБ cвВВ * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)
      вЙ§ cвВВ * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) := by
    apply div_le_div_of_nonneg_right (mul_le_mul_of_nonneg_right (min_le_right _ _) hNe.le) hLT.le
  constructor
  ¬Ј exact hzf N ѕЗ hѕЗ1 T hT0 s hsim (by linarith)
  ¬Ј intro hsre2
    exact hLL N ѕЗ hѕЗ1 T hT0 s hsim (by linarith) (by linarith)

/-- **`вИТLвА≤/L` вЖФ `logDeriv` norm bridge** (SW brick W1f): `вАЦвИТderiv L/LвАЦ = вАЦlogDeriv LвАЦ`, so
    `contour_combined`'s `logDeriv` bound transfers to the smoothed-integrand form. -/
lemma neg_logDeriv_norm_eq {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (s : вДВ) :
    вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) s / DirichletCharacter.LFunction ѕЗ sвАЦ
      = вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ := by
  rw [logDeriv_apply, neg_div, norm_neg]

/-- **Strip numerics** (SW brick W1g): with `0 < c вЙ§ 1/2`, `0 < Ne вЙ§ 1`, `20 вЙ§ LT`, the gap
    `g = c¬ЈNe/LT` satisfies `0 < g вЙ§ 1/40`, so `ѕГ' = 1вИТg/2 вЙ• 3/4` (`shifted_line_integral_bound`'s
    hypothesis), `ѕГ = 1+g вИИ (1,2]`, and `ѕГ' вЙ§ ѕГ`. The arithmetic inputs of the W1 instantiation. -/
lemma strip_numerics (c Ne LT : вДЭ) (hc0 : 0 < c) (hc12 : c вЙ§ 1/2)
    (hNe0 : 0 < Ne) (hNe1 : Ne вЙ§ 1) (hLT : 20 вЙ§ LT) :
    0 < c * Ne / LT вИІ c * Ne / LT вЙ§ 1/40 вИІ 3/4 вЙ§ 1 - c * Ne / LT / 2 вИІ
      1 < 1 + c * Ne / LT вИІ 1 - c * Ne / LT / 2 вЙ§ 1 + c * Ne / LT вИІ 1 + c * Ne / LT вЙ§ 2 := by
  have hLT0 : (0:вДЭ) < LT := by linarith
  have hg0 : 0 < c * Ne / LT := by positivity
  have hgle : c * Ne / LT вЙ§ 1/40 := by
    rw [div_le_iffвВА hLT0]
    nlinarith
  refine вЯ®hg0, hgle, by linarith, by linarith, by linarith, by linarithвЯ©

/-- **ѕГ-line tail constant** (SW brick W1h): the smoothed integrand on `Re = ѕГ > 1` is dominated by
    `(B¬ЈX^ѕГ)/t¬≤` off `t = 0` вАФ the exact `hbound` input of `truncation_tail_bound`. -/
lemma sigma_line_tail_bound {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X ѕГ : вДЭ) (hX : 0 < X) (hѕГ : 1 < ѕГ) :
    вИГ B : вДЭ, 0 вЙ§ B вИІ вИА t : вДЭ, t вЙ† 0 вЖТ
      вАЦ(-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I))
          * ((X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))вАЦ
        вЙ§ (B * X ^ ѕГ) / t ^ 2 := by
  obtain вЯ®B, hBвЯ© := neg_logDeriv_bounded_on_line ѕЗ ѕГ hѕГ
  have hB0 : 0 вЙ§ B := le_trans (norm_nonneg _) (hB 0)
  refine вЯ®B, hB0, fun t ht => ?_вЯ©
  have him : ((ѕГ:вДВ) + t * I).im = t := by simp
  have hre : ((ѕГ:вДВ) + t * I).re = ѕГ := by simp
  have hkd := perron_kernel_decay X hX ((ѕГ:вДВ) + t * I) (by rw [him]; exact ht)
  rw [hre, him] at hkd
  rw [norm_mul]
  calc вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I)вАЦ
        * вАЦ(X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1))вАЦ
      вЙ§ B * (X ^ ѕГ / t ^ 2) := mul_le_mul (hB t) hkd (norm_nonneg _) hB0
    _ = (B * X ^ ѕГ) / t ^ 2 := by ring

/-- **Strip-point `M`-bound in integrand form** (SW brick W1i): given `contour_combined`'s
    `logDeriv` bound as a hypothesis (fixed constants; `T` = height, `[rlo, rhi]` = Re-range),
    every strip point `x + t¬ЈI` (`|t| вЙ§ T`, `rlo вЙ§ x вЙ§ rhi`) has `вАЦвИТLвА≤/L(x+t¬ЈI)вАЦ вЙ§ M`. One
