end TrivCharHeight

section Quad341
open Metric
set_option maxHeartbeats 2000000

open scoped LSeries.notation ArithmeticFunction in
/-- **The quadratic 3-4-1 gap away from the real axis** (SW brick S4a-5): for any
    height-threshold parameter `D вЙ• 1` there is `C вЙ• 1` with: every zero `ќ≤+iќ≥` of
    every quadratic nontrivial `ѕЗ` mod `N` with `1 вЙ§ |ќ≥|¬ЈD¬ЈLвВА` satisfies
    `ќ≤ вЙ§ 1 вИТ 1/(C¬ЈLвВА)` вАФ the classical de la Vall√©e-Poussin argument, with the
    trivial-character term DAMPED by the height (`trivchar_height_bound`). -/
theorem quad_341_gap (D : вДЭ) (hD : 1 вЙ§ D) :
    вИГ C : вДЭ, 1 вЙ§ C вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N),
      ѕЗ вЙ† 1 вЖТ ѕЗ ^ 2 = 1 вЖТ вИА ќ≤ ќ≥ : вДЭ,
      DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ) + ќ≥*Complex.I) = 0 вЖТ
      1 вЙ§ |ќ≥| * (D * (Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20)) вЖТ
      ќ≤ вЙ§ 1 - 1/(C * (Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20)) := by
  obtain вЯ®KP, hKPвЯ© := twist_re_le_uniform
  obtain вЯ®KP', hKP'defвЯ© : вИГ K' : вДЭ, K' = max KP 0 := вЯ®_, rflвЯ©
  have hKP'0 : 0 вЙ§ KP' := by rw [hKP'def]; exact le_max_right _ _
  have hKPle : KP вЙ§ KP' := by rw [hKP'def]; exact le_max_left _ _
  obtain вЯ®CвВД, hCвВД1, hCвВДвЯ© := trivchar_height_bound
  obtain вЯ®CвВЙ, hCвВЙdefвЯ© : вИГ c : вДЭ, c = 3*KP' + 320 + 2*CвВД := вЯ®_, rflвЯ©
  have hCвВЙ1 : 1 вЙ§ CвВЙ := by rw [hCвВЙdef]; linarith
  obtain вЯ®W, hWdefвЯ© : вИГ w : вДЭ, w = 4*D*(6400*CвВЙ^2 + 1600*CвВЙ + 4) := вЯ®_, rflвЯ©
  have hW16D : 16*D вЙ§ W := by rw [hWdef]; nlinarith [hCвВЙ1, hD]
  have hW6400 : 6400*CвВЙ^2 вЙ§ W := by rw [hWdef]; nlinarith [hCвВЙ1, hD]
  have hW2400 : 2400*CвВЙ вЙ§ W := by rw [hWdef]; nlinarith [hCвВЙ1, hD]
  have hW1 : 1 вЙ§ W := by nlinarith [hW2400, hCвВЙ1]
  have hW0 : (0:вДЭ) < W := by linarith
  refine вЯ®4*W, by linarith, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 hѕЗ2 ќ≤ ќ≥ hzero hbig
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hg0 : (0:вДЭ) вЙ§ |ќ≥| := abs_nonneg ќ≥
  have harg1 : (1:вДЭ) вЙ§ (N:вДЭ) * (4*|ќ≥|+7) := by nlinarith
  have hL0 : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*|ќ≥|+7)) := Real.log_nonneg harg1
  obtain вЯ®LвВА, hLвВАdefвЯ© : вИГ Lv : вДЭ, Lv = Real.log ((N:вДЭ)*(4*|ќ≥|+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLвВАdef] at hbig вКҐ
  have hL20 : 20 вЙ§ LвВА := by rw [hLвВАdef]; linarith
  have hCL : 4*W*LвВА вЙ• 80 := by nlinarith [hW1, hL20]
  have hCL0 : (0:вДЭ) < 4*W*LвВА := by linarith
