    rw [div_eq_iff (ne_of_gt hg0)]
    linarith [h9]
  have hlog1g : Real.log (1/g) вЙ§ (1+ќµ)*LT + Real.log (1/c) := by
    rw [hg1]
    have hNlog : Real.log ((N:вДЭ)) вЙ§ LT - 20 := by
      rw [hLTdef]
      have h11 : (N:вДЭ) вЙ§ (N:вДЭ)*(4*(T+1)+7) := by nlinarith
      have h12 := Real.log_le_log (by linarith : (0:вДЭ) < (N:вДЭ)) h11
      linarith
    have hLTlog : Real.log LT вЙ§ LT - 1 :=
      Real.log_le_sub_one_of_pos (by linarith)
    calc Real.log (LT * ((N:вДЭ))^ќµ / c)
        = Real.log (LT * ((N:вДЭ))^ќµ) - Real.log c := by
          rw [Real.log_div (by positivity) (ne_of_gt hc0)]
      _ = Real.log LT + ќµ * Real.log ((N:вДЭ)) - Real.log c := by
          rw [Real.log_mul (by linarith : LT вЙ† 0) (by positivity),
            Real.log_rpow (by linarith : (0:вДЭ) < (N:вДЭ))]
      _ вЙ§ (LT - 1) + ќµ * (LT - 20) - Real.log c := by
          have h13 := mul_le_mul_of_nonneg_left hNlog (le_of_lt hќµ0)
          linarith [hLTlog, h13]
      _ вЙ§ (1+ќµ)*LT + Real.log (1/c) := by
          have h14 : Real.log (1/c) = - Real.log c := by
            rw [one_div, Real.log_inv]
          nlinarith [hќµ0, h14.le, h14.ge, hLT20]
  have hA : Real.log ((N:вДЭ)*(2*|s.im|+7)*(1+g)/g) вЙ§ Kc * LT := by
    have h15 : (N:вДЭ)*(2*|s.im|+7)*(1+g)/g вЙ§ (2*((N:вДЭ)*(4*(T+1)+7))) * (1/g) := by
      rw [div_le_iffвВА hg0]
      have h16 : (2*|s.im|+7)*(1+g) вЙ§ 2*(4*(T+1)+7) := by
        nlinarith [hsim, hg40, hg0, abs_nonneg s.im, hT0]
      have h17 : (N:вДЭ)*(2*|s.im|+7)*(1+g) вЙ§ 2*((N:вДЭ)*(4*(T+1)+7)) := by
        nlinarith [h16, hN1r, abs_nonneg s.im, hg0]
      have h18 : (1:вДЭ)/g * g = 1 := by field_simp
      nlinarith [h17, h18, hg0]
    calc Real.log ((N:вДЭ)*(2*|s.im|+7)*(1+g)/g)
        вЙ§ Real.log ((2*((N:вДЭ)*(4*(T+1)+7))) * (1/g)) := by
          apply Real.log_le_log _ h15
          apply div_pos _ hg0
          exact mul_pos (mul_pos (by linarith : (0:вДЭ) < (N:вДЭ))
            (by nlinarith [abs_nonneg s.im] : (0:вДЭ) < 2*|s.im|+7))
            (by linarith [hg0] : (0:вДЭ) < 1+g)
