    intro a
    rw [Real.rpow_add hX0, Real.rpow_one, Real.rpow_def_of_pos hX0, mul_comm L a]
  have hT2 : T^2 = Real.exp (2*u) := by
    rw [hTdef, sq, вЖР Real.exp_add]
    ring_nf
  -- t1
  have ht1 : 6 * M * X ^ (1 - g/2 : вДЭ)
      вЙ§ 24*C * u ^ ((5:вДЭ)/2) * (X * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))) := by
    rw [rpow_shift_as_exp X g hX0]
    have h1 : Real.exp (-(g/2) * L) вЙ§ Real.exp (-((c/4) * u ^ ((1:вДЭ)/2))) := by
      apply Real.exp_le_exp.mpr
      nlinarith [hgL2]
    calc 6 * M * (X * Real.exp (-(g/2) * L))
