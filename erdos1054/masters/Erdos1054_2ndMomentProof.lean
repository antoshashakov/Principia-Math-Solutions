-- ===== Phase D brick (c): core_variance =====

/-- **Any power of log is eventually beaten by N**: for `K>0`, `k`, eventually
    `K¬Ј(log N)^k вЙ§ N`. (The nat/log bookkeeping for `P = вМК(log N)^9вМЛвВК`: gives
    `P¬≥ вЙ§ N`, `2P¬≥ вЙ§ N`, etc.) Route: `u = log N`, `N = exp u`; `u вЙ§ exp(su)`
    (`s=1/(2k+2)`) вЯє `u^k вЙ§ exp(u/2)` вЯє `K u^k вЙ§ K exp(u/2) вЙ§ exp u = N`. -/
lemma polylog_le_self (k : вДХ) (K : вДЭ) (hK : 0 < K) :
    вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ K * (Real.log N) ^ k вЙ§ (N : вДЭ) := by
  set s : вДЭ := 1 / (2 * k + 2) with hsdef
  have hs : 0 < s := by rw [hsdef]; positivity
  have hs2 : 0 < s ^ 2 := by positivity
  have hks : (k:вДЭ) * s вЙ§ 1 / 2 := by
    rw [hsdef]
    rw [show (k:вДЭ) * (1 / (2 * k + 2)) = (k:вДЭ) / (2 * k + 2) from by ring,
        div_le_div_iffвВА (by positivity) (by norm_num)]
    have hk0 : (0:вДЭ) вЙ§ (k:вДЭ) := by positivity
    nlinarith [hk0]
  set D : вДЭ := 4 / s ^ 2 + 2 * |Real.log K| + 1 with hDdef
  have hD4 : 4 / s ^ 2 вЙ§ D := by
    rw [hDdef]; linarith [abs_nonneg (Real.log K)]
  have hDK : 2 * |Real.log K| вЙ§ D := by
    rw [hDdef]; linarith [show (0:вДЭ) вЙ§ 4 / s ^ 2 by positivity]
  have hD0 : 0 < D := by rw [hDdef]; positivity
  refine вЯ®Nat.ceil (Real.exp D) + 1, fun N hN => ?_вЯ©
  have hNexp : Real.exp D вЙ§ (N:вДЭ) := by
    have h1 : (вМИReal.exp DвМЙвВК : вДЭ) вЙ§ (N:вДЭ) := by
      have : вМИReal.exp DвМЙвВК вЙ§ N := by omega
      exact_mod_cast this
    linarith [Nat.le_ceil (Real.exp D)]
  have hexp1 : (1:вДЭ) вЙ§ Real.exp D := by
    rw [вЖР Real.exp_zero]; exact Real.exp_le_exp.mpr (by positivity)
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := le_trans hexp1 hNexp
  have hlogND : D вЙ§ Real.log N := by
    calc D = Real.log (Real.exp D) := (Real.log_exp _).symm
      _ вЙ§ Real.log N := Real.log_le_log (Real.exp_pos _) hNexp
  set u : вДЭ := Real.log N with hudef
  have hu0 : 0 < u := lt_of_lt_of_le hD0 hlogND
  have huD : D вЙ§ u := hlogND
  have hNeq : (N:вДЭ) = Real.exp u := (Real.exp_log (by linarith)).symm
  -- u вЙ§ exp(su)
  have hLexp : u вЙ§ Real.exp (s * u) := by
    have hq := Real.add_one_le_exp (s * u / 2)
    have hsq : Real.exp (s * u) = Real.exp (s * u / 2) * Real.exp (s * u / 2) := by
      rw [вЖР Real.exp_add]; congr 1; ring
    have hpos : (0:вДЭ) вЙ§ s * u / 2 + 1 := by positivity
    have hquad : (s * u / 2 + 1) ^ 2 вЙ§ Real.exp (s * u) := by
      rw [hsq]; nlinarith [mul_le_mul hq hq hpos (Real.exp_pos (s * u / 2)).le]
    have hge : 4 / s ^ 2 вЙ§ u := le_trans hD4 huD
    have hs2u : (4:вДЭ) вЙ§ u * s ^ 2 := (div_le_iffвВА hs2).mp hge
    have hus2 : u вЙ§ s ^ 2 * u ^ 2 / 4 := by nlinarith [hs2u, hu0]
    nlinarith [hquad, hus2, mul_nonneg hs.le hu0.le]
  -- u^k вЙ§ exp(u/2)
  have huk : u ^ k вЙ§ Real.exp (u / 2) := by
    calc u ^ k вЙ§ (Real.exp (s * u)) ^ k := pow_le_pow_leftвВА hu0.le hLexp k
      _ = Real.exp ((k:вДЭ) * (s * u)) := by rw [вЖР Real.exp_nat_mul]
      _ вЙ§ Real.exp (u / 2) := by
          apply Real.exp_le_exp.mpr; nlinarith [hks, hu0.le]
  -- K вЙ§ exp(u/2)
  have hKexp : K вЙ§ Real.exp (u / 2) := by
    rw [вЖР Real.log_le_iff_le_exp hK]
    have hneg : Real.log K вЙ§ |Real.log K| := le_abs_self _
    linarith [hDK, huD, hneg]
  -- assemble: K u^k вЙ§ exp(u/2)*exp(u/2) = exp(u) = N
  calc K * u ^ k вЙ§ Real.exp (u / 2) * Real.exp (u / 2) :=
        mul_le_mul hKexp huk (by positivity) (Real.exp_pos _).le
    _ = Real.exp u := by rw [вЖР Real.exp_add]; congr 1; ring
    _ = (N:вДЭ) := hNeq.symm

/-- The truncated singular-series / anchor-window model coefficient (the `c(n)` fed to
    `variance_le_bessel`; matches `major_bessel_error_q`'s model sum). -/
noncomputable def coeffModel (N P Q : вДХ) : вДХ вЖТ вДВ := fun n =>
  вИС pq вИИ anchors P,
    вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
      вИ© Set.Ioc (0:вДЭ) 1,
    ((вИС r вИИ Finset.range pq.1, e ((r : вДЭ) * (pq.2 : вДЭ) / (pq.1 : вДЭ)) * lambdaModel pq.1 r)
      * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
    * e (-((n : вДЭ) * ќ±))

/-- **Phase D brick (c): the circle-method variance bound (X-dependent form).**
    With `P = вМК(log N)^9вМЛвВК`, `Q = N/P`, the weighted Goldbach count `R(n)` is close in
    вДУ¬≤ to the truncated singular-series model: `вИС_{n<2N} вАЦR(n) вИТ c(n)вАЦ¬≤ вЙ§ ќµ N¬≥` eventually. -/
theorem core_variance (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
      вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ))
          - coeffModel N (Nat.floor ((Real.log N) ^ 9)) (N / Nat.floor ((Real.log N) ^ 9)) nвАЦ ^ 2
      вЙ§ ќµ * (N : вДЭ) ^ 3 := by
  obtain вЯ®cM, CM, hcM, hCM, Nmaj, hmajвЯ© := major_bessel_error_q 9 (by norm_num)
  obtain вЯ®Nmin, hminвЯ© := minor_limit (ќµ / 2) (by linarith)
  obtain вЯ®Nexp, hexpвЯ© := exp_dominates_polylog (2 * cM) (by linarith) 74 (ќµ / (128 * CM)) (by positivity)
  obtain вЯ®Npoly, hpolyвЯ© := polylog_le_self 27 2 (by norm_num)
  refine вЯ®max 8 (max Nmaj (max Nmin (max Nexp Npoly))), fun N hN => ?_вЯ©
  have hN8 : 8 вЙ§ N := le_trans (le_max_left _ _) hN
  have hNmaj : Nmaj вЙ§ N := le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hN
  have hNmin : Nmin вЙ§ N := le_trans (le_trans (le_max_left _ _) (le_trans (le_max_right _ _) (le_max_right _ _))) hN
  have hNexp : Nexp вЙ§ N := le_trans (le_trans (le_max_left _ _) (le_trans (le_max_right _ _) (le_trans (le_max_right _ _) (le_max_right _ _)))) hN
  have hNpoly : Npoly вЙ§ N := le_trans (le_trans (le_max_right _ _) (le_trans (le_max_right _ _) (le_trans (le_max_right _ _) (le_max_right _ _)))) hN
  -- scale facts
  have hN1 : 1 вЙ§ N := by omega
  have hNR : (8:вДЭ) вЙ§ (N:вДЭ) := by exact_mod_cast hN8
  have hNpos : (0:вДЭ) < (N:вДЭ) := by linarith
  have hlogN2 : (2:вДЭ) вЙ§ Real.log N := by
    calc (2:вДЭ) вЙ§ Real.log 8 := by
          rw [show (8:вДЭ) = 2^3 by norm_num, Real.log_pow]
          have := Real.log_two_gt_d9; push_cast; linarith
      _ вЙ§ Real.log N := Real.log_le_log (by norm_num) hNR
  have hlogNpos : (0:вДЭ) < Real.log N := by linarith
  set P : вДХ := Nat.floor ((Real.log N) ^ 9) with hPdef
  set Q : вДХ := N / P with hQdef
  -- bookkeeping
  have hL9nn : (0:вДЭ) вЙ§ (Real.log N) ^ 9 := by positivity
  have hPleL9 : (P:вДЭ) вЙ§ (Real.log N) ^ 9 := by rw [hPdef]; exact Nat.floor_le hL9nn
  have hP2 : 2 вЙ§ P := by
    rw [hPdef]; apply Nat.le_floor
    have h := pow_le_pow_leftвВА (by norm_num : (0:вДЭ) вЙ§ 2) hlogN2 9
    calc ((2:вДХ):вДЭ) = 2 := by norm_num
      _ вЙ§ (2:вДЭ)^9 := by norm_num
      _ вЙ§ (Real.log N)^9 := h
  have hP0 : 0 < P := by omega
  have hP1 : 1 вЙ§ P := by omega
  have hPR1 : (1:вДЭ) вЙ§ (P:вДЭ) := by exact_mod_cast hP1
  have h2poly : (2:вДЭ) * (Real.log N)^27 вЙ§ (N:вДЭ) := hpoly N hNpoly
  have hL27nn : (0:вДЭ) вЙ§ (Real.log N)^27 := by positivity
  -- P^3 вЙ§ N
  have hP3R : (P:вДЭ)^3 вЙ§ (Real.log N)^27 := by
    calc (P:вДЭ)^3 вЙ§ ((Real.log N)^9)^3 := by apply pow_le_pow_leftвВА (by positivity) hPleL9
      _ = (Real.log N)^27 := by ring
  have hP3 : P ^ 3 вЙ§ N := by
    have : (P:вДЭ)^3 вЙ§ (N:вДЭ) := by nlinarith [hP3R, h2poly, hL27nn]
    have h2 : ((P^3 : вДХ):вДЭ) вЙ§ ((N:вДХ):вДЭ) := by push_cast; linarith
    exact_mod_cast h2
  have hP2le : P ^ 2 вЙ§ N := le_trans (Nat.pow_le_pow_right hP1 (by norm_num)) hP3
  have hPN : P вЙ§ N := le_trans (Nat.le_self_pow (by norm_num) P) hP3
  have hQ1 : 1 вЙ§ Q := by rw [hQdef]; exact Nat.one_le_div_iff hP0 |>.mpr hPN
  have hPQcut : P вЙ§ Q := by
    rw [hQdef]; exact Nat.le_div_iff_mul_le hP0 |>.mpr (by rw [вЖР pow_two]; exact hP2le)
  have hPmulQ : P * Q вЙ§ N := by rw [hQdef]; exact Nat.mul_div_le N P
  have h2P3 : 2 * P ^ 3 вЙ§ N := by
    have : ((2 * P^3 : вДХ):вДЭ) вЙ§ ((N:вДХ):вДЭ) := by push_cast; nlinarith [hP3R, h2poly, hL27nn]
    exact_mod_cast this
  have h2P2Q : 2 * P ^ 2 < Q + 1 := by
    have h2P2 : 2 * P ^ 2 вЙ§ Q := by
      rw [hQdef]; apply Nat.le_div_iff_mul_le hP0 |>.mpr
      calc 2 * P ^ 2 * P = 2 * P ^ 3 := by ring
        _ вЙ§ N := h2P3
    omega
  have hPB : (P:вДЭ) вЙ§ Real.log N ^ (9:вДЭ) := by
    have hbridge : Real.log N ^ (9:вДЭ) = (Real.log N) ^ (9:вДХ) := by
      rw [show (9:вДЭ) = ((9:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
    rw [hbridge]; exact hPleL9
  -- apply variance_le_bessel
  have hbessel := variance_le_bessel (fun k => ((ќЫ k : вДЭ) : вДВ)) N
    (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q)
    (measurableSet_Ioc.diff (measurableSet_majorArcs P Q)) Set.diff_subset
    (coeffModel N P Q)
  -- set equality for the major integral domain
  have hset : Set.Ioc (0:вДЭ) 1 \ (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q)
      = вЛГ pq вИИ anchors P,
          (Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
            вИ© Set.Ioc (0:вДЭ) 1) := by
    rw [Set.diff_diff_right, Set.diff_self, Set.empty_union, Set.inter_comm,
        majorArcs_inter_eq_anchors P Q hP0, Set.iUnionвВВ_inter]
  -- term1 вЙ§ ќµ/2 N¬≥  and  term2 вЙ§ ќµ/2 N¬≥
  have hterm1 : 2 * (вИЂ ќ± in (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q),
        вАЦвИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)вАЦ ^ 4) вЙ§ ќµ / 2 * (N:вДЭ)^3 := by
    have hms : MeasurableSet (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q) :=
      measurableSet_Ioc.diff (measurableSet_majorArcs P Q)
    have heq : (вИЂ ќ± in (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q),
          вАЦвИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)вАЦ ^ 4)
        = вИЂ ќ± in (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q),
          вАЦ(вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2вАЦ ^ 2 := by
      apply MeasureTheory.setIntegral_congr_fun hms
      intro ќ± _
      dsimp only
      rw [norm_pow]; ring
    rw [heq]
    have hL4 := minor_L4_le_explicit N P Q hP2 hP3 hPQcut hPmulQ hN1 hQ1
    have hml := hmin N hNmin
    rw [вЖР hPdef] at hml
    linarith [hL4, hml]
  have hterm2 : 2 * вИС n вИИ Finset.range (2 * N),
        вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ (Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q),
            (вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2 * e (-((n : вДЭ) * ќ±)))
          - coeffModel N P Q nвАЦ ^ 2 вЙ§ ќµ / 2 * (N:вДЭ)^3 := by
    have hsum := hmaj N hNmaj P hP0 hPB Q h2P2Q
    simp only [coeffModel]
    simp_rw [hset]
    refine le_trans (mul_le_mul_of_nonneg_left hsum (by norm_num)) ?_
    -- goal: 2 * majorRHS вЙ§ ќµ/2 * N¬≥
    have hQ1pos : (0:вДЭ) < (Q:вДЭ) + 1 := by positivity
