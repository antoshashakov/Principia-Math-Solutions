  have hMbml : (N:вДЭ) * (CвВА * (|t|+3)^2) / ((ѕГ-1)^2/2)
      вЙ§ 2*CвВА * ((N:вДЭ)*(|t|+3)/(ѕГ-1))^2 := by
    rw [div_le_iffвВА (by positivity : (0:вДЭ) < (ѕГ-1)^2/2)]
