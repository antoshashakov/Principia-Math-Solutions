theorem F_le_sigma (e a : Nat) : F e a вЙ§ sigma (e * a) := by
  unfold F sigma
  exact Finset.sum_le_sum_of_subset_of_nonneg
    (by intro x hx; exact (Finset.mem_filter.mp hx).1)
    (by intro x hxt hxnot; exact Nat.zero_le x)

theorem activeSet_subset_divisors (e a : Nat) (he : 0 < e) (ha : 0 < a) :
    ActiveSet e a вКЖ (e * a).divisors := by
  intro r hr
  have hmem : r вИИ (Finset.range e).filter (fun r => 0 < r вИІ r вИ£ e * a) := by
    simpa [ActiveSet] using hr
  have hdvd : r вИ£ e * a := (Finset.mem_filter.mp hmem).2.2
  exact Nat.mem_divisors.mpr вЯ®hdvd, (Nat.mul_pos he ha).ne'вЯ©

theorem activeSet_sum_le_sigma (e a : Nat) (he : 0 < e) (ha : 0 < a) :
    (ActiveSet e a).sum (fun r => r) вЙ§ sigma (e * a) := by
  rw [activeSet_eq_divisors_filter_lt e a he ha]
  unfold sigma
  exact Finset.sum_le_sum_of_subset_of_nonneg
    (by intro x hx; exact (Finset.mem_filter.mp hx).1)
    (by intro x hxt hxnot; exact Nat.zero_le x)

theorem div_reflect_involutive (n q : Nat) (hn : 0 < n) (hq : q вИИ n.divisors) :
    n / (n / q) = q := by
  have hqd : q вИ£ n := (Nat.mem_divisors.mp hq).1
  exact Nat.div_div_self hqd hn.ne'

theorem prefix_reflect_involutive (e a q : Nat) (he : 0 < e) (ha : 0 < a)
    (hq : q вИИ (e * a).divisors.filter (fun q => q вЙ§ a)) :
    (e * a) / ((e * a) / q) = q := by
  have hn : 0 < e * a := Nat.mul_pos he ha
  have hqdivs : q вИИ (e * a).divisors := (Finset.mem_filter.mp hq).1
  simpa using div_reflect_involutive (e * a) q hn hqdivs

theorem suffix_reflect_involutive (e a r : Nat) (he : 0 < e) (ha : 0 < a)
    (hr : r вИИ (e * a).divisors.filter (fun r => e вЙ§ r)) :
    (e * a) / ((e * a) / r) = r := by
  have hn : 0 < e * a := Nat.mul_pos he ha
  have hrdivs : r вИИ (e * a).divisors := (Finset.mem_filter.mp hr).1
  simpa using div_reflect_involutive (e * a) r hn hrdivs

theorem mul_g_le_sigma_rat (e a : Nat) (_he : 0 < e) (_ha : 0 < a)
    (hFg : (F e a : Rat) = (e * a : Rat) * g e (e * a)) :
    (e * a : Rat) * g e (e * a) вЙ§ (sigma (e * a) : Rat) := by
  have hnat : F e a вЙ§ sigma (e * a) := F_le_sigma e a
  have hrat : (F e a : Rat) вЙ§ (sigma (e * a) : Rat) := by
    exact_mod_cast hnat
  rw [hFg] at hrat
  exact hrat


/- ================================================================
   PART II вАФ The divisor-prefix representation and f(N)
   ================================================================ -/



theorem represented_iff_isRep (N : Nat) : Represented N вЖФ вИГ m, IsRep m N := by
  constructor
  ¬Ј rintro вЯ®e, d, he, hd, hNвЯ©; exact вЯ®e * d, e, d, he, hd, rfl, hNвЯ©
  ¬Ј rintro вЯ®m, e, d, he, hd, _, hNвЯ©; exact вЯ®e, d, he, hd, hNвЯ©

