      _ вЙ§ ((m ѕБвВА : вДВ) / (c - ѕБвВА)).re + ((m ѕБвВБ : вДВ) / (c - ѕБвВБ)).re :=
          add_le_add (hterm ѕБвВА hѕБвВАS hѕБвВАre (by rw [hѕБвВАim]))
