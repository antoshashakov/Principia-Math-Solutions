/-- **The `LвВБ` upper bound** (Siegel brick S1a): any limit with the `2q/(y+1)` rate
    of `1`-bounded coefficient means satisfies `|LвВБ| вЙ§ 3 + log q` for `q вЙ• 1`. -/
lemma rate_limit_upper_log (g : вДХ вЖТ вДЭ) (q : вДХ) (hq : 1 вЙ§ q) (L : вДЭ)
    (hgb : вИА n, |g n| вЙ§ 1)
    (hr : вИА y : вДХ, |L - вИС d вИИ Icc 1 y, g d / d| вЙ§ 2 * (q:вДЭ) / (y + 1)) :
    |L| вЙ§ 3 + Real.log q := by
  have hq0 : (0:вДЭ) < (q:вДЭ) := by
    have : (0:вДХ) < q := hq
    exact_mod_cast this
  have h1 := hr q
  have h2 : |вИС d вИИ Icc 1 q, g d / d| вЙ§ 1 + Real.log q := by
    calc |вИС d вИИ Icc 1 q, g d / d| вЙ§ вИС d вИИ Icc 1 q, |g d / d| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc 1 q, (1:вДЭ) / d := by
          apply Finset.sum_le_sum
          intro d hd
          rw [Finset.mem_Icc] at hd
          have hd0 : (0:вДЭ) < (d:вДЭ) := by
            have : (0:вДХ) < d := by omega
            exact_mod_cast this
          rw [abs_div, Nat.abs_cast]
          apply div_le_div_of_nonneg_right (hgb d) hd0.le
      _ вЙ§ 1 + Real.log q := sum_one_div_le_log q hq
  have h3 : 2 * (q:вДЭ) / ((q:вДЭ) + 1) вЙ§ 2 := by
    rw [div_le_iffвВА (by linarith)]
    linarith
  calc |L| вЙ§ |L - вИС d вИИ Icc 1 q, g d / d| + |вИС d вИИ Icc 1 q, g d / d| := by
        have := abs_add_le (L - вИС d вИИ Icc 1 q, g d / d) (вИС d вИИ Icc 1 q, g d / d)
        simpa using this
    _ вЙ§ 2 * (q:вДЭ) / ((q:вДЭ) + 1) + (1 + Real.log q) := by
        push_cast at h1
        linarith [h1, h2]
    _ вЙ§ 3 + Real.log q := by linarith [h3]

/-- **The `Lk` upper bound** (Siegel brick S1b): any limit with the `7B/вИЪy` rate of
    a convolution of `1`-bounded functions satisfies `|Lk| вЙ§ 7B + 1`. -/
lemma sqrt_rate_limit_upper (u v : вДХ вЖТ вДЭ) (B : вДЭ) (Lk : вДЭ)
    (hub : вИА n, |u n| вЙ§ 1) (hvb : вИА n, |v n| вЙ§ 1)
    (hr : вИА y : вДХ, 1 вЙ§ y вЖТ
      |Lk - вИС d вИИ Icc 1 y, (toArith u * toArith v) d / d| вЙ§ 7 * B / Real.sqrt y) :
    |Lk| вЙ§ 7 * B + 1 := by
  have h1 := hr 1 (le_refl 1)
  have hs1 : Real.sqrt ((1:вДХ):вДЭ) = 1 := by
    rw [Nat.cast_one, Real.sqrt_one]
  rw [hs1, div_one] at h1
  have h2 : вИС d вИИ Icc 1 1, (toArith u * toArith v) d / d
      = (toArith u * toArith v) 1 := by
    rw [show (Icc 1 1 : Finset вДХ) = {1} from rfl, Finset.sum_singleton, Nat.cast_one,
      div_one]
  have h3 : |(toArith u * toArith v) 1| вЙ§ 1 := by
    rw [ArithmeticFunction.mul_apply, Nat.divisorsAntidiagonal_one,
      Finset.sum_singleton]
    have hu1 : |toArith u 1| вЙ§ 1 := by
      rw [show toArith u 1 = u 1 from by simp [toArith]]
      exact hub 1
    have hv1 : |toArith v 1| вЙ§ 1 := by
      rw [show toArith v 1 = v 1 from by simp [toArith]]
      exact hvb 1
    rw [abs_mul]
    calc |toArith u 1| * |toArith v 1| вЙ§ 1 * 1 :=
        mul_le_mul hu1 hv1 (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  calc |Lk| вЙ§ |Lk - вИС d вИИ Icc 1 1, (toArith u * toArith v) d / d|
        + |вИС d вИИ Icc 1 1, (toArith u * toArith v) d / d| := by
        have := abs_add_le (Lk - вИС d вИИ Icc 1 1, (toArith u * toArith v) d / d)
          (вИС d вИИ Icc 1 1, (toArith u * toArith v) d / d)
        simpa using this
    _ вЙ§ 7 * B + 1 := by
        rw [h2] at h1 вКҐ
        linarith [h1, h3]

/-- Character sums against `d^{вИТѕГ}` decay at the `(y+1)^{вИТѕГ}` rate for every
    `ѕГ вЙ• 0` (Siegel brick S2a) вАФ the sub-one extension of `char_rpow_tail_rate`. -/
lemma char_rpow_tail_rate_gen {q : вДХ} (hq : 1 вЙ§ q) (ѕЗ : DirichletCharacter вДВ q)
    (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1) {ѕГ : вДЭ} (hѕГ : 0 вЙ§ ѕГ) (y : вДХ) :
    вИА z : вДХ, y вЙ§ z вЖТ
    |вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ)|
      вЙ§ 2 * (q:вДЭ) * (((y + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
  intro z hz
  set w : вДХ вЖТ вДЭ := fun d => if d = 0 then 1 else ((d:вДЭ)) ^ (-ѕГ) with hw
  have hw0 : вИА d, 0 вЙ§ w d := by
    intro d
    rw [hw]
    rcases eq_or_ne d 0 with rfl | hd
    ¬Ј simp
    ¬Ј simp only [if_neg hd]
      exact Real.rpow_nonneg (Nat.cast_nonneg _) _
  have hwa : вИА d, w (d + 1) вЙ§ w d := by
    intro d
    rw [hw]
    rcases eq_or_ne d 0 with rfl | hd
    ¬Ј norm_num [Real.one_rpow]
    ¬Ј simp only [if_neg hd, if_neg (by omega : d + 1 вЙ† 0)]
      have hd0 : (0:вДЭ) < (d:вДЭ) := by
        have : (0:вДХ) < d := by omega
        exact_mod_cast this
      apply Real.rpow_le_rpow_of_nonpos hd0 (by push_cast; linarith)
      linarith
  have hG := charFn_partial_sum_bound hq ѕЗ hѕЗ2 hѕЗ1
  have h := abel_tail_general (charFn q ѕЗ) ((q:вДЭ)) w hG hw0 hwa y z hz
  have hcongr : вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * w d
      = вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ) := by
    apply Finset.sum_congr rfl
    intro d hd
    rw [Finset.mem_Icc] at hd
    rw [hw]
    simp only [if_neg (by omega : d вЙ† 0)]
  rw [hcongr] at h
  have hwy : w (y + 1) = (((y + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
    rw [hw]
    simp only [if_neg (by omega : y + 1 вЙ† 0)]
  rw [hwy] at h
  exact h

/-- **The below-one partial-sum rate for `L(ѕГ,ѕЗ)`** (Siegel brick S2b): at real
    `ѕГ вИИ (9/10, 1)`, the analytically-continued `L`-value is within
    `2q(y+1)^{вИТѕГ}` of every partial sum вАФ the representation the zero-gap
    bridge differences. -/
theorem LFunction_partial_rate_below_one {q : вДХ} [NeZero q] (hq : 1 вЙ§ q)
    (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1)
    {ѕГ : вДЭ} (hѕГ1 : 9/10 < ѕГ) (hѕГ2 : ѕГ < 1) (y : вДХ) :
    вАЦDirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ))
      - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ) : вДЭ) : вДВ)вАЦ
    вЙ§ 2 * (q:вДЭ) * (((y + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
  have hѕГ0 : (0:вДЭ) < ѕГ := by linarith
  -- the running character sum
  set SFn : вДХ вЖТ вДЭ := fun n => вИС m вИИ Icc 1 n, charFn q ѕЗ m with hSFn
  have hSFn0 : SFn 0 = 0 := by
    rw [hSFn]
    simp
  have hSb : вИА n : вДХ, |SFn n| вЙ§ (q:вДЭ) := fun n => charFn_partial_sum_bound hq ѕЗ hѕЗ2 hѕЗ1 n
  have hSE : вИА n : вДХ, 1 вЙ§ n вЖТ |SFn n| вЙ§ (q:вДЭ) * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
    intro n hn
    have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
    have h1 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) := Real.one_le_rpow hn1r (by norm_num)
    have h2 : (1:вДЭ) вЙ§ 1 + Real.log n := by
      have := Real.log_nonneg hn1r
      linarith
    calc |SFn n| вЙ§ (q:вДЭ) := hSb n
      _ = (q:вДЭ) * 1 := (mul_one _).symm
      _ вЙ§ (q:вДЭ) * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
          apply mul_le_mul_of_nonneg_left _ (Nat.cast_nonneg q)
          nlinarith [h1, h2]
  -- the Abel continuation W
  set W : вДВ вЖТ вДВ := fun s => вИС' n : вДХ,
      ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)) with hW
  -- LFunction = W at ѕГ via the identity theorem
  have hLW : DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ)) = W ((ѕГ:вДВ)) := by
    apply eqOn_slit_halfplane (DirichletCharacter.LFunction ѕЗ) W
      (fun s _ _ => (DirichletCharacter.differentiable_LFunction hѕЗ1).differentiableAt)
      (fun s hs _ => eseries_differentiableAt SFn ((q:вДЭ)) (Nat.cast_nonneg q) hSFn0 hSE s hs)
      ?_ ((ѕГ:вДВ)) (by rw [Complex.ofReal_re]; exact hѕГ1) (by
        intro h
        rw [Complex.ofReal_eq_one] at h
        linarith)
    intro s hs
    have hsum : LSeriesSummable (fun n => ((charFn q ѕЗ n : вДЭ) : вДВ)) s := by
      apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ hs
      intro n _
      rw [Complex.norm_real, Real.norm_eq_abs]
      exact charFn_bound ѕЗ hѕЗ2 n
    have hC : вИА x : вДХ, вАЦвИС n вИИ Icc 1 x, ((charFn q ѕЗ n : вДЭ) : вДВ)вАЦ вЙ§ (q:вДЭ) * x := by
      intro x
      rw [вЖР Complex.ofReal_sum, Complex.norm_real, Real.norm_eq_abs]
      rcases Nat.eq_zero_or_pos x with rfl | hx
      ¬Ј simp
      ¬Ј have hx1r : (1:вДЭ) вЙ§ (x:вДЭ) := by exact_mod_cast hx
        calc |вИС n вИИ Icc 1 x, charFn q ѕЗ n| вЙ§ (q:вДЭ) :=
              charFn_partial_sum_bound hq ѕЗ hѕЗ2 hѕЗ1 x
          _ вЙ§ (q:вДЭ) * x := by nlinarith [Nat.cast_nonneg (ќ± := вДЭ) q]
    have hL : DirichletCharacter.LFunction ѕЗ s
        = LSeries (fun n => ((charFn q ѕЗ n : вДЭ) : вДВ)) s := by
      rw [DirichletCharacter.LFunction_eq_LSeries ѕЗ hs]
      exact (LSeries_congr (fun {n} hn => charFn_repr ѕЗ hѕЗ2 n) s).symm
    rw [hL, lseries_eq_tsum_abel _ ((q:вДЭ)) hC hs hsum, hW]
    apply tsum_congr
    intro n
    rw [hSFn, Complex.ofReal_sum]
  -- the direct partial sums converge to W(ѕГ)
  set D : вДХ вЖТ вДЭ := fun z => вИС d вИИ Icc 1 z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ) with hD
  have hterm_cast : вИА d : вДХ, ((charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ) : вДЭ) : вДВ)
      = ((charFn q ѕЗ d : вДЭ) : вДВ) * ((d:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) := by
    intro d
    rw [cpow_real_cast d ѕГ]
    push_cast
    ring
  -- summability of the W-terms at ѕГ
  have hWsum : Summable (fun n : вДХ =>
      ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ)))) := by
    have hmaj : Summable (fun n : вДХ => (q:вДЭ) * (1 / ((n:вДЭ)) ^ ((19:вДЭ)/10))) :=
      Summable.mul_left _ (Real.summable_one_div_nat_rpow.mpr (by norm_num))
    have hg0 : вИА n : вДХ, 0 вЙ§ (if n = 0 then (0:вДЭ) else
        (q:вДЭ) * (1 / ((n:вДЭ)) ^ ((19:вДЭ)/10))) := by
      intro n
      rcases eq_or_ne n 0 with rfl | hn
      ¬Ј rw [if_pos rfl]
      ¬Ј rw [if_neg hn]
        positivity
    have hgle : вИА n : вДХ, (if n = 0 then (0:вДЭ) else
        (q:вДЭ) * (1 / ((n:вДЭ)) ^ ((19:вДЭ)/10)))
        вЙ§ (q:вДЭ) * (1 / ((n:вДЭ)) ^ ((19:вДЭ)/10)) := by
      intro n
      rcases eq_or_ne n 0 with rfl | hn
      ¬Ј rw [if_pos rfl]
        positivity
      ¬Ј rw [if_neg hn]
    apply Summable.of_norm_bounded (g := fun n : вДХ => if n = 0 then 0 else
      (q:вДЭ) * (1 / ((n:вДЭ)) ^ ((19:вДЭ)/10))) (Summable.of_nonneg_of_le hg0 hgle hmaj)
    intro n
    rcases eq_or_ne n 0 with rfl | hn
    ¬Ј rw [hSFn0]
      simp
    ¬Ј rw [if_neg hn]
      have hn1 : 1 вЙ§ n := Nat.one_le_iff_ne_zero.mpr hn
      have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn1
      have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
      have hќФ : ((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ))
          = (((((n:вДЭ)) ^ (-ѕГ) - (((n + 1 : вДХ)):вДЭ) ^ (-ѕГ)) : вДЭ) : вДВ) := by
        rw [cpow_real_cast n ѕГ, cpow_real_cast (n + 1) ѕГ]
        push_cast
        ring
      rw [hќФ, вЖР Complex.ofReal_mul, Complex.norm_real, Real.norm_eq_abs, abs_mul]
      have hќФ0 : (0:вДЭ) вЙ§ ((n:вДЭ)) ^ (-ѕГ) - (((n + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
        have : (((n + 1 : вДХ)):вДЭ) ^ (-ѕГ) вЙ§ ((n:вДЭ)) ^ (-ѕГ) := by
          apply Real.rpow_le_rpow_of_nonpos hn0 (by push_cast; linarith)
          linarith
        linarith
      have hќФle : ((n:вДЭ)) ^ (-ѕГ) - (((n + 1 : вДХ)):вДЭ) ^ (-ѕГ) вЙ§ ((n:вДЭ)) ^ (-((19:вДЭ)/10)) := by
        calc ((n:вДЭ)) ^ (-ѕГ) - (((n + 1 : вДХ)):вДЭ) ^ (-ѕГ)
            вЙ§ ѕГ * ((n:вДЭ)) ^ (-ѕГ - 1) := rpow_diff_le n hn1 ѕГ hѕГ0.le
          _ вЙ§ 1 * ((n:вДЭ)) ^ (-ѕГ - 1) := by
              apply mul_le_mul_of_nonneg_right (by linarith)
                (Real.rpow_nonneg hn0.le _)
          _ = ((n:вДЭ)) ^ (-ѕГ - 1) := one_mul _
          _ вЙ§ ((n:вДЭ)) ^ (-((19:вДЭ)/10)) := by
              apply Real.rpow_le_rpow_of_exponent_le hn1r
              linarith
      have hone : (1:вДЭ) / ((n:вДЭ)) ^ ((19:вДЭ)/10) = ((n:вДЭ)) ^ (-((19:вДЭ)/10)) := by
        rw [one_div, вЖР Real.rpow_neg hn0.le]
      rw [abs_of_nonneg hќФ0, hone]
      exact mul_le_mul (hSb n) hќФle hќФ0 (Nat.cast_nonneg q)
  -- boundary decay
  have hbdry : Tendsto (fun z : вДХ => ((SFn z : вДЭ) : вДВ) * ((z:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)))
      atTop (nhds 0) := by
    have hbound : вИА z : вДХ, вАЦ((SFn z : вДЭ) : вДВ) * ((z:вДВ)) ^ (-((ѕГ:вДЭ):вДВ))вАЦ
        вЙ§ (q:вДЭ) * ((z:вДЭ)) ^ (-ѕГ) := by
      intro z
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, cpow_real_cast z ѕГ,
        Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (Real.rpow_nonneg (Nat.cast_nonneg z) _)]
      exact mul_le_mul_of_nonneg_right (hSb z) (Real.rpow_nonneg (Nat.cast_nonneg z) _)
    have hg : Tendsto (fun z : вДХ => (q:вДЭ) * ((z:вДЭ)) ^ (-ѕГ)) atTop (nhds 0) := by
      have h := tendsto_rpow_neg_atTop hѕГ0
      have hcomp := h.comp tendsto_natCast_atTop_atTop
      have h2 := hcomp.const_mul ((q:вДЭ))
      simpa [Function.comp_def] using h2
    exact squeeze_zero_norm hbound hg
  -- the Icc-to-range recount of the W-partials
  have hIcc_range : вИА z : вДХ, вИС n вИИ Icc 1 (z - 1),
      ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ)))
      = вИС n вИИ range z,
      ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ))) := by
    intro z
    rcases Nat.eq_zero_or_pos z with rfl | hz
    ¬Ј rfl
    ¬Ј rw [show range z = insert 0 (Icc 1 (z - 1)) from by
        ext d
        simp only [Finset.mem_insert, Finset.mem_range, Finset.mem_Icc]
        omega, Finset.sum_insert (by
          simp only [Finset.mem_Icc]
          omega)]
      rw [hSFn0]
      simp
  have hsum_shift : Tendsto (fun z : вДХ => вИС n вИИ Icc 1 (z - 1),
      ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ))))
      atTop (nhds (W ((ѕГ:вДВ)))) := by
    have h := hWsum.hasSum.tendsto_sum_nat
    apply h.congr
    intro z
    exact (hIcc_range z).symm
  -- the Abel identity links D to the W-partials
  have habel : вИА z : вДХ, 1 вЙ§ z вЖТ ((D z : вДЭ) : вДВ)
      = ((SFn z : вДЭ) : вДВ) * ((z:вДВ)) ^ (-((ѕГ:вДЭ):вДВ))
        + вИС n вИИ Icc 1 (z - 1),
          ((SFn n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-((ѕГ:вДЭ):вДВ))) := by
    intro z hz
    have h := abel_initial (fun n => ((charFn q ѕЗ n : вДЭ) : вДВ))
      (fun n => ((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ))) z hz
    have hL : ((D z : вДЭ) : вДВ) = вИС n вИИ Icc 1 z,
        ((charFn q ѕЗ n : вДЭ) : вДВ) * ((n:вДВ)) ^ (-((ѕГ:вДЭ):вДВ)) := by
      rw [hD]
      push_cast [Complex.ofReal_sum]
      apply Finset.sum_congr rfl
      intro d _
      rw [вЖР hterm_cast d]
      push_cast
      ring
    have hA : вИА x : вДХ, вИС m вИИ Icc 1 x, ((charFn q ѕЗ m : вДЭ) : вДВ) = ((SFn x : вДЭ) : вДВ) := by
      intro x
      rw [hSFn, Complex.ofReal_sum]
    rw [hL, h, hA z]
    congr 1
    apply Finset.sum_congr rfl
    intro n _
    rw [hA n]
  -- D converges to W(ѕГ)
  have hDW : Tendsto (fun z : вДХ => ((D z : вДЭ) : вДВ)) atTop (nhds (W ((ѕГ:вДВ)))) := by
    have h := hbdry.add hsum_shift
    rw [zero_add] at h
    apply h.congr'
    filter_upwards [eventually_ge_atTop 1] with z hz
    exact (habel z hz).symm
  -- the tail rate transfers to the limit
  have hrate : вИА z : вДХ, y вЙ§ z вЖТ
      вАЦ((D z : вДЭ) : вДВ) - ((D y : вДЭ) : вДВ)вАЦ вЙ§ 2 * (q:вДЭ) * (((y + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
    intro z hz
    rw [вЖР Complex.ofReal_sub, Complex.norm_real, Real.norm_eq_abs]
    have hsplit : D z - D y = вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ѕГ) := by
      rw [hD]
      simp only
      rw [show Icc 1 z = Icc 1 y вИ™ Icc (y + 1) z from by
        ext d
        simp only [Finset.mem_union, Finset.mem_Icc]
        omega, Finset.sum_union (by
          rw [Finset.disjoint_left]
          intro d hd hd2
          rw [Finset.mem_Icc] at hd hd2
          omega)]
      ring
    rw [hsplit]
    exact char_rpow_tail_rate_gen hq ѕЗ hѕЗ2 hѕЗ1 hѕГ0.le y z hz
  have hfinal : вАЦW ((ѕГ:вДВ)) - ((D y : вДЭ) : вДВ)вАЦ вЙ§ 2 * (q:вДЭ) * (((y + 1 : вДХ)):вДЭ) ^ (-ѕГ) := by
    have h2 : Tendsto (fun z : вДХ => вАЦ((D z : вДЭ) : вДВ) - ((D y : вДЭ) : вДВ)вАЦ) atTop
        (nhds вАЦW ((ѕГ:вДВ)) - ((D y : вДЭ) : вДВ)вАЦ) := (hDW.sub tendsto_const_nhds).norm
    apply le_of_tendsto h2
    filter_upwards [eventually_ge_atTop y] with z hz
    exact hrate z hz
  rw [hLW]
  exact hfinal

/-- **The head difference across the window** (Siegel brick S2c): moving the
    exponent from `ќ≤` to `1` across a window with `N^{1вИТќ≤} вЙ§ 2` costs only
    `2(1вИТќ≤)(1+log N)¬≤` on partial sums of a quadratic character. -/
lemma char_head_diff_bound {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1)
    (N : вДХ) (hN : 1 вЙ§ N) {ќ≤ : вДЭ} (hќ≤1 : 0 < ќ≤) (hќ≤2 : ќ≤ < 1)
    (hN2 : ((N:вДЭ)) ^ (1 - ќ≤) вЙ§ 2) :
    |вИС d вИИ Icc 1 N, charFn q ѕЗ d / d - вИС d вИИ Icc 1 N, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤)|
    вЙ§ 2 * (1 - ќ≤) * (1 + Real.log N) ^ 2 := by
  have hNr : (1:вДЭ) вЙ§ (N:вДЭ) := by exact_mod_cast hN
  have hlogN : (0:вДЭ) вЙ§ Real.log N := Real.log_nonneg hNr
  -- per-term bound
  have hterm : вИА d : вДХ, d вИИ Icc 1 N вЖТ
      |charFn q ѕЗ d / d - charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤)|
      вЙ§ 2 * (1 - ќ≤) * (Real.log d / d) := by
    intro d hd
    rw [Finset.mem_Icc] at hd
    have hd1r : (1:вДЭ) вЙ§ (d:вДЭ) := by exact_mod_cast hd.1
    have hd0 : (0:вДЭ) < (d:вДЭ) := by linarith
    have hlogd : (0:вДЭ) вЙ§ Real.log d := Real.log_nonneg hd1r
    -- factor: 1/d вИТ d^{вИТќ≤} = вИТd^{вИТ1}(d^{1вИТќ≤} вИТ 1)
    have hfac : charFn q ѕЗ d / d - charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤)
        = -(charFn q ѕЗ d * (((d:вДЭ)) ^ (1 - ќ≤) - 1) / d) := by
      have hrw : ((d:вДЭ)) ^ (-ќ≤) = ((d:вДЭ)) ^ (1 - ќ≤) / d := by
        rw [eq_div_iff (ne_of_gt hd0)]
        calc ((d:вДЭ)) ^ (-ќ≤) * (d:вДЭ) = ((d:вДЭ)) ^ (-ќ≤) * ((d:вДЭ)) ^ (1:вДЭ) := by
              rw [Real.rpow_one]
          _ = ((d:вДЭ)) ^ (-ќ≤ + 1) := (Real.rpow_add hd0 _ _).symm
          _ = ((d:вДЭ)) ^ (1 - ќ≤) := by ring_nf
      rw [hrw]
      field_simp
      ring
    rw [hfac, abs_neg, abs_div, Nat.abs_cast, abs_mul]
    -- d^{1вИТќ≤} вИТ 1 вЙ§ 2(1вИТќ≤)log d
    have hexp : ((d:вДЭ)) ^ (1 - ќ≤) - 1 вЙ§ 2 * (1 - ќ≤) * Real.log d := by
      have h1ќ≤ : (0:вДЭ) вЙ§ 1 - ќ≤ := by linarith
      have hx0 : (0:вДЭ) вЙ§ (1 - ќ≤) * Real.log d := mul_nonneg h1ќ≤ hlogd
      have hrpow : ((d:вДЭ)) ^ (1 - ќ≤) = Real.exp ((1 - ќ≤) * Real.log d) := by
        rw [Real.rpow_def_of_pos hd0]
        ring_nf
      have hEM : Real.exp ((1 - ќ≤) * Real.log d) - 1
          вЙ§ ((1 - ќ≤) * Real.log d) * Real.exp ((1 - ќ≤) * Real.log d) := by
        set x : вДЭ := (1 - ќ≤) * Real.log d with hx
        have h1 := Real.add_one_le_exp (-x)
        have h2 : (0:вДЭ) < Real.exp x := Real.exp_pos _
        have h3 : Real.exp (-x) = (Real.exp x)вБї¬є := Real.exp_neg x
        rw [h3] at h1
        have h4 : (-x + 1) * Real.exp x вЙ§ 1 := by
          calc (-x + 1) * Real.exp x вЙ§ (Real.exp x)вБї¬є * Real.exp x := by
                apply mul_le_mul_of_nonneg_right h1 h2.le
            _ = 1 := inv_mul_cancelвВА (ne_of_gt h2)

        nlinarith [h4]
      have hd2 : ((d:вДЭ)) ^ (1 - ќ≤) вЙ§ 2 := by
        calc ((d:вДЭ)) ^ (1 - ќ≤) вЙ§ ((N:вДЭ)) ^ (1 - ќ≤) := by
              apply Real.rpow_le_rpow hd0.le _ h1ќ≤
              exact_mod_cast hd.2
          _ вЙ§ 2 := hN2
      calc ((d:вДЭ)) ^ (1 - ќ≤) - 1
          = Real.exp ((1 - ќ≤) * Real.log d) - 1 := by rw [hrpow]
        _ вЙ§ ((1 - ќ≤) * Real.log d) * Real.exp ((1 - ќ≤) * Real.log d) := hEM
        _ = ((1 - ќ≤) * Real.log d) * ((d:вДЭ)) ^ (1 - ќ≤) := by rw [hrpow]
        _ вЙ§ ((1 - ќ≤) * Real.log d) * 2 := by
            apply mul_le_mul_of_nonneg_left hd2 hx0
        _ = 2 * (1 - ќ≤) * Real.log d := by ring
    have hnn : (0:вДЭ) вЙ§ ((d:вДЭ)) ^ (1 - ќ≤) - 1 := by
      have : (1:вДЭ) вЙ§ ((d:вДЭ)) ^ (1 - ќ≤) := Real.one_le_rpow hd1r (by linarith)
      linarith
    calc |charFn q ѕЗ d| * |((d:вДЭ)) ^ (1 - ќ≤) - 1| / (d:вДЭ)
        вЙ§ 1 * (2 * (1 - ќ≤) * Real.log d) / (d:вДЭ) := by
          apply div_le_div_of_nonneg_right _ hd0.le
          apply mul_le_mul (charFn_bound ѕЗ hѕЗ2 d) _ (abs_nonneg _) zero_le_one
          rw [abs_of_nonneg hnn]
          exact hexp
      _ = 2 * (1 - ќ≤) * (Real.log d / d) := by ring
  -- sum the per-term bounds
  have hsum : вИС d вИИ Icc 1 N, Real.log d / d вЙ§ (1 + Real.log N) ^ 2 := by
    calc вИС d вИИ Icc 1 N, Real.log d / d
        вЙ§ вИС d вИИ Icc 1 N, Real.log N * (1 / d) := by
          apply Finset.sum_le_sum
          intro d hd
          rw [Finset.mem_Icc] at hd
          have hd0 : (0:вДЭ) < (d:вДЭ) := by
            have : (0:вДХ) < d := by omega
            exact_mod_cast this
          have hlog_le : Real.log d вЙ§ Real.log N := by
            apply Real.log_le_log hd0
            exact_mod_cast hd.2
          rw [mul_one_div]
          apply div_le_div_of_nonneg_right hlog_le hd0.le
      _ = Real.log N * вИС d вИИ Icc 1 N, (1:вДЭ) / d := by rw [Finset.mul_sum]
      _ вЙ§ Real.log N * (1 + Real.log N) := by
          apply mul_le_mul_of_nonneg_left (sum_one_div_le_log N hN) hlogN
      _ вЙ§ (1 + Real.log N) ^ 2 := by nlinarith [hlogN]
  calc |вИС d вИИ Icc 1 N, charFn q ѕЗ d / d - вИС d вИИ Icc 1 N, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤)|
      = |вИС d вИИ Icc 1 N, (charFn q ѕЗ d / d - charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤))| := by
        rw [Finset.sum_sub_distrib]
    _ вЙ§ вИС d вИИ Icc 1 N, |charFn q ѕЗ d / d - charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤)| :=
        Finset.abs_sum_le_sum_abs _ _
    _ вЙ§ вИС d вИИ Icc 1 N, 2 * (1 - ќ≤) * (Real.log d / d) := Finset.sum_le_sum hterm
    _ = 2 * (1 - ќ≤) * вИС d вИИ Icc 1 N, Real.log d / d := by rw [Finset.mul_sum]
    _ вЙ§ 2 * (1 - ќ≤) * (1 + Real.log N) ^ 2 := by
        apply mul_le_mul_of_nonneg_left hsum
        nlinarith [hќ≤2]

/-- **THE ZERO-GAP BRIDGE** (Siegel brick S2d): a real zero `ќ≤` of `L(¬Ј,ѕЗ)` inside
    the window `(1вИТќ≤)¬Јlog q вЙ§ 1/10` forces the `L(1,ѕЗ)`-limit small:
    `|LвВБ| вЙ§ 2(1вИТќ≤)(1+3log q)¬≤ + 4q^{вИТ17/10}` вАФ so a big `L(1,ѕЗ)` pushes zeros away. -/
theorem zero_gap_bridge {q : вДХ} [NeZero q] (hq : 3 вЙ§ q)
    (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1)
    (LвВБ : вДЭ)
    (hr : вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn q ѕЗ d / d| вЙ§ 2 * (q:вДЭ) / (y + 1))
    {ќ≤ : вДЭ} (hќ≤2 : ќ≤ < 1) (hќ≤w : (1 - ќ≤) * Real.log q вЙ§ 1/10)
    (hzero : DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ)) = 0) :
    |LвВБ| вЙ§ 2 * (1 - ќ≤) * (1 + 3 * Real.log q) ^ 2 + 4 * ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
  have hq1 : 1 вЙ§ q := by omega
  have hq0 : (0:вДЭ) < (q:вДЭ) := by
    have : (0:вДХ) < q := by omega
    exact_mod_cast this
  have hq3r : (3:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq
  -- log q > 1
  have hlogq1 : (1:вДЭ) < Real.log q := by
    have he : Real.exp 1 < 3 := by
      have := Real.exp_one_lt_d9
      linarith
    calc (1:вДЭ) = Real.log (Real.exp 1) := (Real.log_exp 1).symm
      _ < Real.log 3 := Real.log_lt_log (Real.exp_pos 1) he
      _ вЙ§ Real.log q := Real.log_le_log (by norm_num) hq3r
  have hќ≤910 : (9:вДЭ)/10 < ќ≤ := by
    have h1 : 1 - ќ≤ вЙ§ (1/10) / Real.log q := by
      rw [le_div_iffвВА (by linarith)]
      linarith [hќ≤w]
    have h2 : (1/10 : вДЭ) / Real.log q < 1/10 := by
      rw [div_lt_iffвВА (by linarith)]
      nlinarith [hlogq1]
    linarith
  have hќ≤0 : (0:вДЭ) < ќ≤ := by linarith
  set N : вДХ := q ^ 3 with hN
  have hN1 : 1 вЙ§ N := Nat.one_le_pow 3 q (by omega)
  have hNr : ((N:вДХ):вДЭ) = ((q:вДЭ)) ^ (3:вДХ) := by
    rw [hN]
    push_cast
    ring
  have hlogN : Real.log N = 3 * Real.log q := by
    rw [hNr, Real.log_pow]
    push_cast
    ring
  -- N^{1вИТќ≤} вЙ§ 2
  have hN2 : ((N:вДЭ)) ^ (1 - ќ≤) вЙ§ 2 := by
    have hN0 : (0:вДЭ) < (N:вДЭ) := by
      rw [hNr]
      positivity
    rw [Real.rpow_def_of_pos hN0]
    calc Real.exp (Real.log ((N:вДЭ)) * (1 - ќ≤)) вЙ§ Real.exp (3/10) := by
          apply Real.exp_le_exp.mpr
          rw [hlogN]
          nlinarith [hќ≤w]
      _ вЙ§ 2 := by
          have hlog2 : (0.6931471803 : вДЭ) < Real.log 2 := Real.log_two_gt_d9
          calc Real.exp (3/10) вЙ§ Real.exp (Real.log 2) := by
                apply Real.exp_le_exp.mpr
                linarith
            _ = 2 := Real.exp_log (by norm_num)
  set D1 : вДЭ := вИС d вИИ Icc 1 N, charFn q ѕЗ d / d with hD1
  set Dќ≤ : вДЭ := вИС d вИИ Icc 1 N, charFn q ѕЗ d * ((d:вДЭ)) ^ (-ќ≤) with hDќ≤
  -- piece (a): |LвВБ вИТ D_N(1)| вЙ§ 2q^{вИТ17/10}
  have ha : |LвВБ - D1| вЙ§ 2 * ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
    calc |LвВБ - D1| вЙ§ 2 * (q:вДЭ) / ((N:вДЭ) + 1) := hr N
      _ вЙ§ 2 * (q:вДЭ) / ((q:вДЭ)) ^ (3:вДХ) := by
          apply div_le_div_of_nonneg_left (by positivity) (by positivity)
          rw [hNr]
          linarith
      _ = 2 * ((q:вДЭ)) ^ (-(2:вДЭ)) := by
          rw [show (-(2:вДЭ)) = -(((2:вДХ)):вДЭ) from by norm_num, Real.rpow_neg hq0.le,
            Real.rpow_natCast]
          field_simp
      _ вЙ§ 2 * ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
          apply mul_le_mul_of_nonneg_left _ (by norm_num)
          apply Real.rpow_le_rpow_of_exponent_le (by linarith)
          norm_num
  -- piece (b): the head difference
  have hb : |D1 - Dќ≤| вЙ§ 2 * (1 - ќ≤) * (1 + 3 * Real.log q) ^ 2 := by
    have h := char_head_diff_bound ѕЗ hѕЗ2 N hN1 hќ≤0 hќ≤2 hN2
    rw [hlogN] at h
    exact h
  -- piece (c): |D_N(ќ≤)| вЙ§ 2q^{вИТ17/10} at the zero
  have hc : |Dќ≤| вЙ§ 2 * ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
    have h1 := LFunction_partial_rate_below_one hq1 ѕЗ hѕЗ2 hѕЗ1 hќ≤910 hќ≤2 N
    rw [hzero, zero_sub, norm_neg, Complex.norm_real, Real.norm_eq_abs] at h1
    have hN0 : (0:вДЭ) < (N:вДЭ) := by
      rw [hNr]
      positivity
    have h2 : (((N + 1 : вДХ)):вДЭ) ^ (-ќ≤) вЙ§ ((N:вДЭ)) ^ (-ќ≤) := by
      apply Real.rpow_le_rpow_of_nonpos hN0 (by push_cast; linarith)
      linarith
    have hq1r : (1:вДЭ) вЙ§ (q:вДЭ) := by linarith
    have h4 : ((N:вДЭ)) ^ (-ќ≤) = ((q:вДЭ)) ^ ((3:вДЭ) * (-ќ≤)) := by
      rw [hNr, вЖР Real.rpow_natCast (q:вДЭ) 3, вЖР Real.rpow_mul hq0.le]
      congr 1
    have h5 : (q:вДЭ) * ((q:вДЭ)) ^ ((3:вДЭ) * (-ќ≤)) = ((q:вДЭ)) ^ (1 + (3:вДЭ) * (-ќ≤)) := by
      rw [Real.rpow_add hq0, Real.rpow_one]
    have h6 : ((q:вДЭ)) ^ (1 + (3:вДЭ) * (-ќ≤)) вЙ§ ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
      apply Real.rpow_le_rpow_of_exponent_le hq1r
      nlinarith [hќ≤910]
    calc |Dќ≤| вЙ§ 2 * (q:вДЭ) * (((N + 1 : вДХ)):вДЭ) ^ (-ќ≤) := h1
      _ вЙ§ 2 * (q:вДЭ) * ((N:вДЭ)) ^ (-ќ≤) := by
          apply mul_le_mul_of_nonneg_left h2 (by positivity)
      _ = 2 * ((q:вДЭ) * ((q:вДЭ)) ^ ((3:вДЭ) * (-ќ≤))) := by
          rw [h4]
          ring
      _ = 2 * ((q:вДЭ)) ^ (1 + (3:вДЭ) * (-ќ≤)) := by rw [h5]
      _ вЙ§ 2 * ((q:вДЭ)) ^ (-(17:вДЭ)/10) := by
          apply mul_le_mul_of_nonneg_left h6 (by norm_num)
  -- triangle assembly
  have h1 := abs_add_le (LвВБ - D1) (D1 - Dќ≤)
  have e1 : (LвВБ - D1) + (D1 - Dќ≤) = LвВБ - Dќ≤ := by ring
  rw [e1] at h1
  have h2 := abs_add_le (LвВБ - Dќ≤) Dќ≤
  have e2 : (LвВБ - Dќ≤) + Dќ≤ = LвВБ := by ring
  rw [e2] at h2
  linarith [h1, h2, ha, hb, hc]

/-- **The explicit-C E-package** (Siegel brick S3-pre-a): `quad_E_package` with the
    constant exposed вАФ `C = 30(1+qвВБ)(1+B) + 36 + 3|LвВБLk|`, ready for the
    polynomial-in-`q` bound the dichotomy needs. -/
theorem quad_E_package_explicit (gвВБ gвВВ : вДХ вЖТ вДЭ) (qвВБ B LвВБ Lk : вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1)
    (hLвВБ : вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, gвВБ d / d| вЙ§ 2 * qвВБ / (y + 1))
    (hqвВБ : 0 вЙ§ qвВБ)
    (hH : вИА M : вДХ, 1 вЙ§ M вЖТ
      |вИС n вИИ Icc 1 M, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ) n - LвВБ * M|
        вЙ§ (1 + 4 * qвВБ) * (Real.sqrt M + 1))
    (hKb : вИА t : вДХ, |вИС n вИИ Icc 1 t, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) n|
        вЙ§ B * (Real.sqrt t + 1))
    (hLk : вИА y : вДХ, 1 вЙ§ y вЖТ
      |Lk - вИС d вИИ Icc 1 y, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) d / d|
        вЙ§ 7 * B / Real.sqrt y) :
    вИА n : вДХ, 1 вЙ§ n вЖТ
      |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
          * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ (30 * (1 + qвВБ) * (1 + B) + 36 + 3 * |LвВБ * Lk|)
          * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
  have hB0 : 0 вЙ§ B := by
    have h0 := hKb 0
    rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty, abs_zero,
      Nat.cast_zero, Real.sqrt_zero, zero_add, mul_one] at h0
    exact h0
  intro n hn
  have hn0 : (0:вДЭ) < (n:вДЭ) := by
    have : (0:вДХ) < n := hn
    exact_mod_cast this
  have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
  have htge1 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n) := by
    have h1 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) := Real.one_le_rpow hn1r (by norm_num)
    have h2 : (1:вДЭ) вЙ§ 1 + Real.log n := by
      have := Real.log_nonneg hn1r
      linarith
    nlinarith [h1, h2]
  have ht0 : (0:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n) := by linarith
  rcases Nat.lt_or_ge n 4 with h4 | h4
  ¬Ј -- n вИИ {1, 2, 3}: cube bound
    have hA : |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) m| вЙ§ 36 := by
      calc |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m|
          вЙ§ вИС m вИИ Icc 1 n, |(toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m| := Finset.abs_sum_le_sum_abs _ _
        _ вЙ§ вИС m вИИ Icc 1 n, ((m:вДЭ)) ^ (3:вДХ) :=
            Finset.sum_le_sum (fun m _ => quad_value_le_cube gвВБ gвВВ h1b h2b m)
        _ вЙ§ вИС m вИИ Icc (1:вДХ) 3, ((m:вДЭ)) ^ (3:вДХ) := by
            apply Finset.sum_le_sum_of_subset_of_nonneg
            ¬Ј intro m hm
              rw [Finset.mem_Icc] at hm вКҐ
              omega
            ¬Ј intro m _ _
              positivity
        _ = 36 := by
            rw [show (Icc (1:вДХ) 3 : Finset вДХ) = {1, 2, 3} by decide]
            norm_num [Finset.sum_insert, Finset.mem_insert, Finset.sum_singleton]
    have h3n : (n:вДЭ) вЙ§ 3 := by
      have : n вЙ§ 3 := by omega
      exact_mod_cast this
    have hlam : |LвВБ * Lk| * (n:вДЭ) вЙ§ 3 * |LвВБ * Lk| := by
      nlinarith [abs_nonneg (LвВБ * Lk), h3n]
    have htri : |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m| + |LвВБ * Lk * (n:вДЭ)| := by
      have h := abs_add_le (вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ
          * toArith gвВВ * toArith (fun k => gвВБ k * gвВВ k)) m) (-(LвВБ * Lk * (n:вДЭ)))
