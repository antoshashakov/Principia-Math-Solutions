        = Z.re + (((x:вДЭ)) ^ (1 - ќ≤) + 11 * ((x:вДЭ)) ^ (-ќ≤)) * (1 - ќ≤)вБї¬є from by ring]
    have hkey : (SC.re - Z.re) * (1 - ќ≤) вЙ§ ((x:вДЭ)) ^ (1 - ќ≤) + 11 * ((x:вДЭ)) ^ (-ќ≤) := by
      nlinarith [hlo, hx1ќ≤]
    have h2 : SC.re - Z.re вЙ§ (((x:вДЭ)) ^ (1 - ќ≤) + 11 * ((x:вДЭ)) ^ (-ќ≤)) * (1 - ќ≤)вБї¬є := by
      rw [вЖР div_eq_mul_inv, le_div_iffвВА h1ќ≤]
