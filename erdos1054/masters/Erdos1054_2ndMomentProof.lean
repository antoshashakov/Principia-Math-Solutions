section TrivCharHeight
open Metric

/-- Norm of a product over prime factors, each factor of norm вЙ§ 2, is at most `N`. -/
lemma primeFactors_prod_norm_le (N : вДХ) [NeZero N] (g : вДХ вЖТ вДВ)
    (hg : вИА p вИИ N.primeFactors, вАЦg pвАЦ вЙ§ 2) :
    вАЦвИП p вИИ N.primeFactors, g pвАЦ вЙ§ (N:вДЭ) := by
  calc вАЦвИП p вИИ N.primeFactors, g pвАЦ вЙ§ вИП p вИИ N.primeFactors, вАЦg pвАЦ :=
      (norm_prod _ _).le
    _ вЙ§ вИП p вИИ N.primeFactors, (2:вДЭ) := by
        apply Finset.prod_le_prod (fun p _ => norm_nonneg _) hg
    _ = (2:вДЭ) ^ N.primeFactors.card := by
        rw [Finset.prod_const]
    _ вЙ§ (N:вДЭ) := by
        have h1 : (2:вДХ) ^ N.primeFactors.card вЙ§ вИП p вИИ N.primeFactors, p :=
          Finset.pow_card_le_prod _ _ _ (fun p hp => (Nat.prime_of_mem_primeFactors hp).two_le)
        have h2 : вИП p вИИ N.primeFactors, p вЙ§ N :=
          Nat.le_of_dvd (Nat.pos_of_ne_zero (NeZero.ne N)) (Nat.prod_primeFactors_dvd N)
