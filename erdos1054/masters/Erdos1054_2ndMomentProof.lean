/-- The truncated circle-method model coefficient, instantiated exactly as
    `core_variance` produces it. -/
noncomputable def cmodel : вДХ вЖТ вДХ вЖТ вДВ := fun N =>
  coeffModel N (Nat.floor ((Real.log N) ^ 9)) (N / Nat.floor ((Real.log N) ^ 9))

theorem core_variance_ax : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИС n вИИ Finset.range (2 * N),
      вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
          ((ќЫ p.1 : вДЭ) : вДВ) * ((ќЫ p.2 : вДЭ) : вДВ)) - cmodel N nвАЦ ^ 2 вЙ§ ќµ * (N : вДЭ) ^ 3 := by
  intro ќµ hќµ
