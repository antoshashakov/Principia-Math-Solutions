/-- Two-variable square expansion of a finite sum. -/
lemma sum_sq_eq_prod {ќє : Type*} (s : Finset ќє) (a : ќє вЖТ вДЭ) :
    (вИС r вИИ s, a r) ^ 2 = вИС p вИИ s √ЧЋҐ s, a p.1 * a p.2 := by
  simp only [Finset.sum_product]
  rw [sq, Finset.sum_mul_sum]

/-- **SM3: Second moment with the cofactor retained** (paper Lemma 6.1):
    `вИС_{(n,e): n вЙ§ Z, e вИ£ n, e > E} g_e(n)¬≤ вЙ§ Z¬ЈU(E)`. The outer pairs-form matches the
    consumer (`large_e_bound` Step 2) exactly. -/
theorem moment2_le (E Z : вДХ) (hE : 1 вЙ§ E) :
    (вИС p вИИ (Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1)).filter
        (fun p => p.2 вИ£ p.1 вИІ E < p.2), (g p.2 p.1) ^ 2)
      вЙ§ (Z : вДЭ) * (U E).toReal := by
  classical
  set ind : вДХ вЖТ вДХ вЖТ вДЭ := fun r n => if r вИ£ n вИІ 1 вЙ§ n then (1 : вДЭ) / r else 0 with hind
  set inde : вДХ вЖТ вДХ вЖТ вДЭ := fun e r => if e вЙ§ r then (1 : вДЭ) else 0 with hinde
  set indd : вДХ вЖТ вДХ вЖТ вДЭ := fun e n => if e вИ£ n вИІ 1 вЙ§ n then (1 : вДЭ) else 0 with hindd
  -- (1) g e n squared, over the fixed range with divisor indicators carrying `e вЙ§ r`
  have hg : вИА e : вДХ, вИА n вИИ Finset.range (Z + 1), 1 вЙ§ n вЖТ
      g e n = вИС r вИИ Finset.range (Z + 1), inde e r * ind r n := by
    intro e n hn hn1
    rw [Finset.mem_range] at hn
    rw [g]
    rw [вЖР Finset.sum_filter_add_sum_filter_not (Finset.range (Z + 1)) (fun r => e вЙ§ r вИІ r вИ£ n вИІ 1 вЙ§ n)]
    have hz : вИС r вИИ (Finset.range (Z + 1)).filter
        (fun r => ¬ђ(e вЙ§ r вИІ r вИ£ n вИІ 1 вЙ§ n)), inde e r * ind r n = 0 := by
      apply Finset.sum_eq_zero
      intro r hr
      rw [Finset.mem_filter] at hr
      simp only [hinde, hind]
      by_cases h1 : e вЙ§ r
      ¬Ј by_cases h2 : r вИ£ n вИІ 1 вЙ§ n
        ¬Ј exact absurd вЯ®h1, h2.1, h2.2вЯ© hr.2
        ¬Ј rw [if_neg h2, mul_zero]
      ¬Ј rw [if_neg h1, zero_mul]
    rw [hz, add_zero]
    have hmatch : (Finset.range (Z + 1)).filter (fun r => e вЙ§ r вИІ r вИ£ n вИІ 1 вЙ§ n)
        = n.divisors.filter (e вЙ§ ¬Ј) := by
      ext r
      simp only [Finset.mem_filter, Nat.mem_divisors, Finset.mem_range]
      constructor
      ¬Ј rintro вЯ®_, her, hdvd, _вЯ©
        exact вЯ®вЯ®hdvd, by omegaвЯ©, herвЯ©
      ¬Ј rintro вЯ®вЯ®hdvd, hn0вЯ©, herвЯ©
        exact вЯ®lt_of_le_of_lt (Nat.le_of_dvd (by omega) hdvd) hn, her, hdvd, by omegaвЯ©
    rw [hmatch]
    apply Finset.sum_congr rfl
    intro r hr
    rw [Finset.mem_filter, Nat.mem_divisors] at hr
    simp only [hinde, hind]
    rw [if_pos hr.2, if_pos вЯ®hr.1.1, by omegaвЯ©, one_mul]
  -- (2) rewrite the pair sum with the outer filter as an indicator over the full product,
  --     expand the square, and swap so `n` is innermost over triples `(e, r, s)`
  set R2 := Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1) with hR2
  set R3 := Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1) with hR3
  have hswap : (вИС p вИИ R2.filter (fun p => p.2 вИ£ p.1 вИІ E < p.2), (g p.2 p.1) ^ 2)
      вЙ§ вИС q вИИ R3, вИС n вИИ Finset.range (Z + 1),
          (if E < q.1 then (1:вДЭ) else 0) * indd q.1 n
            * (inde q.1 q.2.1 * ind q.2.1 n) * (inde q.1 q.2.2 * ind q.2.2 n) := by
    have hpair : вИА p вИИ R2, (if p.2 вИ£ p.1 вИІ E < p.2 then (g p.2 p.1) ^ 2 else 0)
        = вИС rs вИИ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1),
            (if E < p.2 then (1:вДЭ) else 0) * indd p.2 p.1
              * (inde p.2 rs.1 * ind rs.1 p.1) * (inde p.2 rs.2 * ind rs.2 p.1) := by
      intro p hp
      rw [hR2, Finset.mem_product, Finset.mem_range, Finset.mem_range] at hp
      by_cases hc : p.2 вИ£ p.1 вИІ E < p.2
      ¬Ј rw [if_pos hc]
        by_cases hn1 : 1 вЙ§ p.1
        ¬Ј have hgp := hg p.2 p.1 (Finset.mem_range.mpr hp.1) hn1
          rw [hgp, sum_sq_eq_prod]
          apply Finset.sum_congr rfl
          intro rs _
          rw [if_pos hc.2]
          simp only [hindd]
          rw [if_pos вЯ®hc.1, hn1вЯ©]
          ring
        ¬Ј have hp10 : p.1 = 0 := by omega
          have hgz : g p.2 p.1 = 0 := by
            rw [hp10, g]
            simp
          rw [hgz]
          rw [show (0:вДЭ) ^ 2 = 0 by ring]
          symm
          apply Finset.sum_eq_zero
          intro rs _
          simp only [hindd]
          rw [hp10, if_neg (by omega : ¬ђ(p.2 вИ£ 0 вИІ 1 вЙ§ 0))]
          ring
      ¬Ј rw [if_neg hc]
        symm
        apply Finset.sum_eq_zero
        intro rs _
        rcases not_and_or.mp hc with hnd | hnE
        ¬Ј have h0 : indd p.2 p.1 = 0 := by
            simp only [hindd]
            exact if_neg (fun h => hnd h.1)
          rw [h0]
          ring
        ¬Ј have h0 : (if E < p.2 then (1:вДЭ) else 0) = 0 := if_neg hnE
          rw [h0]
          ring
    refine le_of_eq ?_
    calc (вИС p вИИ R2.filter (fun p => p.2 вИ£ p.1 вИІ E < p.2), (g p.2 p.1) ^ 2)
        = вИС p вИИ R2, (if p.2 вИ£ p.1 вИІ E < p.2 then (g p.2 p.1) ^ 2 else 0) :=
          Finset.sum_filter _ _
      _ = вИС p вИИ R2, вИС rs вИИ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1),
            (if E < p.2 then (1:вДЭ) else 0) * indd p.2 p.1
              * (inde p.2 rs.1 * ind rs.1 p.1) * (inde p.2 rs.2 * ind rs.2 p.1) :=
          Finset.sum_congr rfl hpair
      _ = вИС n вИИ Finset.range (Z + 1), вИС e вИИ Finset.range (Z + 1),
            вИС rs вИИ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1),
            (if E < e then (1:вДЭ) else 0) * indd e n
              * (inde e rs.1 * ind rs.1 n) * (inde e rs.2 * ind rs.2 n) := by
          rw [hR2, Finset.sum_product]
      _ = вИС e вИИ Finset.range (Z + 1), вИС n вИИ Finset.range (Z + 1),
            вИС rs вИИ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1),
            (if E < e then (1:вДЭ) else 0) * indd e n
              * (inde e rs.1 * ind rs.1 n) * (inde e rs.2 * ind rs.2 n) :=
          Finset.sum_comm
      _ = вИС e вИИ Finset.range (Z + 1),
            вИС rs вИИ Finset.range (Z + 1) √ЧЋҐ Finset.range (Z + 1),
            вИС n вИИ Finset.range (Z + 1),
            (if E < e then (1:вДЭ) else 0) * indd e n
              * (inde e rs.1 * ind rs.1 n) * (inde e rs.2 * ind rs.2 n) := by
          apply Finset.sum_congr rfl
          intro e _
          exact Finset.sum_comm
      _ = вИС q вИИ R3, вИС n вИИ Finset.range (Z + 1),
            (if E < q.1 then (1:вДЭ) else 0) * indd q.1 n
              * (inde q.1 q.2.1 * ind q.2.1 n) * (inde q.1 q.2.2 * ind q.2.2 n) := by
          rw [hR3, Finset.sum_product]
  refine le_trans hswap ?_
  -- (3) per-(e,r,s): the four divisibility indicators collapse to lcm вИ£ n; count вЙ§ Z/lcm
  have hpbound : вИА q вИИ R3,
      (вИС n вИИ Finset.range (Z + 1),
          (if E < q.1 then (1:вДЭ) else 0) * indd q.1 n
            * (inde q.1 q.2.1 * ind q.2.1 n) * (inde q.1 q.2.2 * ind q.2.2 n))
      вЙ§ (Z : вДЭ) * (if E < q.1 вИІ q.1 вЙ§ q.2.1 вИІ q.1 вЙ§ q.2.2 then
          (1 : вДЭ) / ((q.2.1 * q.2.2 * Nat.lcm q.1 (Nat.lcm q.2.1 q.2.2) : вДХ) : вДЭ) else 0) := by
    rintro вЯ®e, r, sвЯ© _
    by_cases hc : E < e вИІ e вЙ§ r вИІ e вЙ§ s
    ¬Ј have hterm : вИА n, (if E < e then (1:вДЭ) else 0) * indd e n
          * (inde e r * ind r n) * (inde e s * ind s n)
          = if Nat.lcm e (Nat.lcm r s) вИ£ n вИІ 1 вЙ§ n then (1 : вДЭ) / (r * s) else 0 := by
        intro n
        simp only [hind, hinde, hindd]
        rw [if_pos hc.1, if_pos hc.2.1, if_pos hc.2.2]
        by_cases hd : Nat.lcm e (Nat.lcm r s) вИ£ n вИІ 1 вЙ§ n
        ¬Ј have hd' := hd
          rw [Nat.lcm_dvd_iff, Nat.lcm_dvd_iff] at hd'
          rw [if_pos вЯ®hd'.1.1, hd.2вЯ©, if_pos вЯ®hd'.1.2.1, hd.2вЯ©, if_pos вЯ®hd'.1.2.2, hd.2вЯ©,
            if_pos hd]
          push_cast
          ring
        ¬Ј rw [if_neg hd]
          rw [Nat.lcm_dvd_iff, Nat.lcm_dvd_iff] at hd
          by_cases h1 : e вИ£ n вИІ 1 вЙ§ n
          ¬Ј by_cases h2 : r вИ£ n вИІ 1 вЙ§ n
            ¬Ј by_cases h3 : s вИ£ n вИІ 1 вЙ§ n
              ¬Ј exact absurd вЯ®вЯ®h1.1, h2.1, h3.1вЯ©, h1.2вЯ© hd
              ¬Ј rw [if_pos h1, if_pos h2, if_neg h3]
                ring
            ¬Ј rw [if_pos h1, if_neg h2]
              ring
          ¬Ј rw [if_neg h1]
            ring
      rw [Finset.sum_congr rfl (fun n _ => hterm n)]
      rw [Finset.sum_ite, Finset.sum_const_zero, add_zero, Finset.sum_const, nsmul_eq_mul]
      rw [if_pos hc]
      set L := Nat.lcm e (Nat.lcm r s) with hL
      have hcount : ((Finset.range (Z + 1)).filter (fun n => L вИ£ n вИІ 1 вЙ§ n)).card вЙ§ Z / L := by
        rw [вЖР Nat.card_multiples' Z L]
        apply Finset.card_le_card
        intro n hn
        rw [Finset.mem_filter] at hn вКҐ
        obtain вЯ®hr', hd', h1'вЯ© := hn
        exact вЯ®hr', by omega, hd'вЯ©
      have hcountR : (((Finset.range (Z + 1)).filter (fun n => L вИ£ n вИІ 1 вЙ§ n)).card : вДЭ)
          вЙ§ (Z : вДЭ) / (L : вДЭ) := by
        have h1 : (((Finset.range (Z + 1)).filter (fun n => L вИ£ n вИІ 1 вЙ§ n)).card : вДЭ)
            вЙ§ ((Z / L : вДХ) : вДЭ) := by exact_mod_cast hcount
        exact h1.trans Nat.cast_div_le
      refine le_trans (mul_le_mul_of_nonneg_right hcountR (by positivity)) (le_of_eq ?_)
      push_cast
      ring
    ¬Ј rw [if_neg hc, mul_zero]
      refine le_of_eq (Finset.sum_eq_zero (fun n _ => ?_))
      rcases not_and_or.mp hc with hnE | hnrs
      ¬Ј have h0 : (if E < e then (1:вДЭ) else 0) = 0 := if_neg hnE
        rw [h0]
        ring
      ¬Ј rcases not_and_or.mp hnrs with hnr | hns
        ¬Ј have h0 : inde e r = 0 := by
            simp only [hinde]
            exact if_neg hnr
          rw [h0]
          ring
        ¬Ј have h0 : inde e s = 0 := by
            simp only [hinde]
            exact if_neg hns
          rw [h0]
          ring
  -- (4) assemble and bridge to the tsum
  calc вИС q вИИ R3, вИС n вИИ Finset.range (Z + 1),
        (if E < q.1 then (1:вДЭ) else 0) * indd q.1 n
          * (inde q.1 q.2.1 * ind q.2.1 n) * (inde q.1 q.2.2 * ind q.2.2 n)
      вЙ§ вИС q вИИ R3, (Z : вДЭ) * (if E < q.1 вИІ q.1 вЙ§ q.2.1 вИІ q.1 вЙ§ q.2.2 then
          (1 : вДЭ) / ((q.2.1 * q.2.2 * Nat.lcm q.1 (Nat.lcm q.2.1 q.2.2) : вДХ) : вДЭ) else 0) :=
        Finset.sum_le_sum hpbound
    _ = (Z : вДЭ) * вИС q вИИ R3, (if E < q.1 вИІ q.1 вЙ§ q.2.1 вИІ q.1 вЙ§ q.2.2 then
          (1 : вДЭ) / ((q.2.1 * q.2.2 * Nat.lcm q.1 (Nat.lcm q.2.1 q.2.2) : вДХ) : вДЭ) else 0) := by
        rw [Finset.mul_sum]
    _ вЙ§ (Z : вДЭ) * (U E).toReal := by
        refine mul_le_mul_of_nonneg_left ?_ (by positivity)
        rw [вЖР ENNReal.toReal_ofReal (Finset.sum_nonneg (fun q _ => by positivity))]
        refine ENNReal.toReal_mono (U_lt_top E hE).ne ?_
        rw [ENNReal.ofReal_sum_of_nonneg (fun q _ => by positivity)]
        calc вИС q вИИ R3, ENNReal.ofReal (if E < q.1 вИІ q.1 вЙ§ q.2.1 вИІ q.1 вЙ§ q.2.2 then
                (1 : вДЭ) / ((q.2.1 * q.2.2 * Nat.lcm q.1 (Nat.lcm q.2.1 q.2.2) : вДХ) : вДЭ) else 0)
            = вИС q вИИ R3, (if E < q.1 вИІ q.1 вЙ§ q.2.1 вИІ q.1 вЙ§ q.2.2 then ENNReal.ofReal
                ((1 : вДЭ) / ((q.2.1 * q.2.2 * Nat.lcm q.1 (Nat.lcm q.2.1 q.2.2) : вДХ) : вДЭ))
                else 0) :=
              Finset.sum_congr rfl (fun q _ => by rw [apply_ite ENNReal.ofReal, ENNReal.ofReal_zero])
          _ вЙ§ U E := by
              rw [U]
              exact ENNReal.sum_le_tsum R3


-- ==== SM brick 4: interface L re-proven verbatim from the second moment ====


/-- `H_{A,E}` membership: a representation with cofactor `> E` and modulus `вЙ§ A¬ЈN`.
The `1 вЙ§ d` ensures `N = F e d вЙ• 1` (the degenerate `d = 0`, `N = 0` is excluded). -/
def Hset (A : вДЭ) (E : вДХ) (N : вДХ) : Prop :=
  вИГ e d, E < e вИІ 1 вЙ§ d вИІ N = F e d вИІ (e * d : вДЭ) вЙ§ A * N


/-- **The large-cofactor bound at the paper's strength** (Prop 6.3): `#H_{A,E}(X) вЙ§ C¬ЈA¬≥¬ЈE^{вИТ3/2}¬ЈX`. -/
theorem large_e_bound_cubed :
    вИГ CвВЕ : вДЭ, 0 < CвВЕ вИІ вИА (A : вДЭ), 1 вЙ§ A вЖТ вИА E : вДХ, 1 вЙ§ E вЖТ вИА X : вДХ,
      (countUpTo (Hset A E) X : вДЭ) вЙ§ CвВЕ * A ^ 3 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * X := by
  classical
  obtain вЯ®CвВВ, hCвВВpos, hCвВВвЯ© := U_power_saving
  refine вЯ®CвВВ, hCвВВpos, fun A hA E hE X => ?_вЯ©
  have hA0 : (0 : вДЭ) < A := by linarith
  set M := вМКA * (X : вДЭ)вМЛвВК with hMdef
  set pairs := (Finset.range (M + 1) √ЧЋҐ Finset.range (M + 1)).filter
    (fun p => p.2 вИ£ p.1 вИІ E < p.2 вИІ (1 : вДЭ) / A вЙ§ g p.2 p.1) with hpairs
  -- Step 1 (unchanged from the TвВГ version): countUpTo вЙ§ pairs.card via reflection
  have hstep1 : (countUpTo (Hset A E) X : вДЭ) вЙ§ (pairs.card : вДЭ) := by
    have hsub : setUpTo (Hset A E) X вКЖ вЖС(pairs.image (fun p => F p.2 (p.1 / p.2))) := by
      rintro N вЯ®hNX, e, d, hEe, hd1, hN, hleвЯ©
      have he1 : 1 вЙ§ e := by omega
      have hgN : (N : вДЭ) = ((e * d : вДХ) : вДЭ) * g e (e * d) := by
        rw [hN]; exact_mod_cast reflection e d he1 hd1
      have hgpos : (1 : вДЭ) / A вЙ§ g e (e * d) := by
        have hmpos : (0 : вДЭ) < ((e * d : вДХ) : вДЭ) := by positivity
        have hgnn : 0 вЙ§ g e (e * d) := by
          rw [g]; exact Finset.sum_nonneg (fun r _ => by positivity)
        have hcast : ((e * d : вДХ) : вДЭ) вЙ§ A * N := by exact_mod_cast hle
        rw [hgN] at hcast
        rw [div_le_iffвВА hA0]; nlinarith [hcast, hmpos, hgnn]
      have hmle : e * d вЙ§ M := by
        rw [hMdef]; apply Nat.le_floor
        calc ((e * d : вДХ) : вДЭ) вЙ§ A * N := by exact_mod_cast hle
          _ вЙ§ A * X := by
              apply mul_le_mul_of_nonneg_left _ hA0.le; exact_mod_cast hNX
      have hele : e вЙ§ M := le_trans (Nat.le_mul_of_pos_right e (by omega : 0 < d)) hmle
      rw [Finset.coe_image, Set.mem_image]
      refine вЯ®(e * d, e), ?_, ?_вЯ©
      ¬Ј rw [Finset.mem_coe, hpairs, Finset.mem_filter, Finset.mem_product, Finset.mem_range,
          Finset.mem_range]
        exact вЯ®вЯ®by omega, by omegaвЯ©, dvd_mul_right e d, hEe, hgposвЯ©
      ¬Ј simp only [Nat.mul_div_cancel_left d (by omega : 0 < e)]; exact hN.symm
    calc (countUpTo (Hset A E) X : вДЭ)
        вЙ§ ((pairs.image (fun p => F p.2 (p.1 / p.2))).card : вДЭ) := by
          rw [countUpTo]
          exact_mod_cast le_trans (Set.ncard_le_ncard hsub (Finset.finite_toSet _))
            (le_of_eq (Set.ncard_coe_finset _))
      _ вЙ§ (pairs.card : вДЭ) := by exact_mod_cast Finset.card_image_le
  -- Step 2 (NEW): Markov with the square, keep the divisibility, apply moment2_le
  have hstep2 : (pairs.card : вДЭ) вЙ§ A ^ 2 * ((M : вДЭ) * (U E).toReal) := by
    have hmarkov : (pairs.card : вДЭ) вЙ§ A ^ 2 * вИС p вИИ pairs, (g p.2 p.1) ^ 2 := by
      rw [Finset.mul_sum, Finset.card_eq_sum_ones, Nat.cast_sum]
      refine Finset.sum_le_sum (fun p hp => ?_)
      rw [hpairs, Finset.mem_filter] at hp
      have h1 : (1 : вДЭ) вЙ§ A * g p.2 p.1 := by
        have := (div_le_iffвВА hA0).mp hp.2.2.2; linarith [this]
      calc ((1 : вДХ) : вДЭ) = 1 := by norm_num
        _ вЙ§ (A * g p.2 p.1) ^ 2 := one_le_powвВА h1
        _ = A ^ 2 * (g p.2 p.1) ^ 2 := by rw [mul_pow]
    refine le_trans hmarkov (mul_le_mul_of_nonneg_left ?_ (by positivity))
    -- enlarge pairs, KEEPING the divisibility and E < e filters
    have henlarge : вИС p вИИ pairs, (g p.2 p.1) ^ 2
        вЙ§ вИС p вИИ (Finset.range (M + 1) √ЧЋҐ Finset.range (M + 1)).filter
            (fun p => p.2 вИ£ p.1 вИІ E < p.2), (g p.2 p.1) ^ 2 := by
      apply Finset.sum_le_sum_of_subset_of_nonneg
      ¬Ј intro p hp
        simp only [hpairs, Finset.mem_filter, Finset.mem_product] at hp вКҐ
        exact вЯ®hp.1, hp.2.1, hp.2.2.1вЯ©
      ¬Ј intro p _ _
        positivity
    exact le_trans henlarge (moment2_le E M hE)
  -- combine
  refine le_trans hstep1 (le_trans hstep2 ?_)
  have hMle : (M : вДЭ) вЙ§ A * X := by rw [hMdef]; exact Nat.floor_le (by positivity)
  have hU := hCвВВ E hE
  have hUnn : (0 : вДЭ) вЙ§ (U E).toReal := ENNReal.toReal_nonneg
  calc A ^ 2 * ((M : вДЭ) * (U E).toReal)
      вЙ§ A ^ 2 * ((A * X) * (CвВВ * (E : вДЭ) ^ (-(3 / 2 : вДЭ)))) := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        exact mul_le_mul hMle hU hUnn (by positivity)
    _ = CвВВ * A ^ 3 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * X := by ring

/-- The `AвБі` form consumed verbatim by the ¬І8 assembly (`main`), derived from the sharp
    `A¬≥` bound (`A вЙ• 1`). -/
theorem large_e_bound :
    вИГ CвВЕ : вДЭ, 0 < CвВЕ вИІ вИА (A : вДЭ), 1 вЙ§ A вЖТ вИА E : вДХ, 1 вЙ§ E вЖТ вИА X : вДХ,
      (countUpTo (Hset A E) X : вДЭ) вЙ§ CвВЕ * A ^ 4 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * X := by
  obtain вЯ®CвВЕ, hCвВЕ, hboundвЯ© := large_e_bound_cubed
  refine вЯ®CвВЕ, hCвВЕ, fun A hA E hE X => ?_вЯ©
  refine le_trans (hbound A hA E hE X) ?_
  apply mul_le_mul_of_nonneg_right _ (by exact_mod_cast Nat.zero_le X)
  apply mul_le_mul_of_nonneg_right _ (by positivity)
  have hA3 : A ^ 3 вЙ§ A ^ 4 := by nlinarith [pow_nonneg (by linarith : (0:вДЭ) вЙ§ A) 3]
  nlinarith [hCвВЕ.le, hA3]



/-! ## Section 7 -- Almost every odd integer is represented (Lem 7.1; uses A3 -- see the N \ {2,5} note at top). -/


/-- The divisors of a product of two distinct primes. -/
lemma divisors_two_primes {p q : вДХ} (hp : p.Prime) (hq : q.Prime) (hpq : p вЙ† q) :
    (p * q).divisors = {1, p, q, p * q} := by
  rw [Nat.divisors_mul, hp.divisors, hq.divisors]
  ext x
  simp only [Finset.mem_mul, Finset.mem_insert, Finset.mem_singleton]
  constructor
  ¬Ј rintro вЯ®a, ha, b, hb, rflвЯ©
    rcases ha with rfl | rfl <;> rcases hb with rfl | rfl <;> simp
  ¬Ј rintro (h | h | h | h)
    ¬Ј exact вЯ®1, by simp, 1, by simp, by simp [h]вЯ©
    ¬Ј exact вЯ®p, by simp, 1, by simp, by simp [h]вЯ©
    ¬Ј exact вЯ®1, by simp, q, by simp, by simp [h]вЯ©
    ¬Ј exact вЯ®p, by simp, q, by simp, by simp [h]вЯ©

/-- For distinct primes `p < q`, `F p q = 1 + p + q` (divisors of `pq` that are `вЙ§ q`
are `1, p, q`). -/
lemma F_two_primes {p q : вДХ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q) :
    F p q = 1 + p + q := by
  have hp2 : 2 вЙ§ p := hp.two_le
  have hq2 : 2 вЙ§ q := hq.two_le
  have hqlt : q < p * q := by
    calc q < 2 * q := by omega
      _ вЙ§ p * q := by gcongr
  have hfilter : ({1, p, q, p * q} : Finset вДХ).filter (¬Ј вЙ§ q) = {1, p, q} := by
    ext x
    simp only [Finset.mem_filter, Finset.mem_insert, Finset.mem_singleton]
    constructor
    ¬Ј rintro вЯ®h, hleвЯ©
      rcases h with rfl | rfl | rfl | rfl
      ¬Ј exact Or.inl rfl
      ¬Ј exact Or.inr (Or.inl rfl)
      ¬Ј exact Or.inr (Or.inr rfl)
      ¬Ј omega
    ¬Ј rintro (rfl | rfl | rfl)
      ¬Ј exact вЯ®Or.inl rfl, by omegaвЯ©
      ¬Ј exact вЯ®Or.inr (Or.inl rfl), by omegaвЯ©
      ¬Ј exact вЯ®Or.inr (Or.inr (Or.inl rfl)), le_rflвЯ©
  have h1 : (1 : вДХ) вИЙ ({p, q} : Finset вДХ) := by
    simp only [Finset.mem_insert, Finset.mem_singleton]; omega
  have h2 : p вИЙ ({q} : Finset вДХ) := by
    simp only [Finset.mem_singleton]; omega
  rw [F, divisors_two_primes hp hq (by omega), hfilter, Finset.sum_insert h1,
    Finset.sum_insert h2, Finset.sum_singleton]
  omega

open Topology in
/-- The prime counting function is `o(n)` (Chebyshev's upper bound). -/
lemma primeCounting_isLittleO :
    (fun n : вДХ => (Nat.primeCounting n : вДЭ)) =o[Filter.atTop] (fun n : вДХ => (n : вДЭ)) := by
  rw [Asymptotics.isLittleO_iff_tendsto']
  ¬Ј have hsqrt : Filter.Tendsto (fun n : вДХ => Real.sqrt n) Filter.atTop Filter.atTop :=
      Real.tendsto_sqrt_atTop.comp tendsto_natCast_atTop_atTop
    have hlogsqrt : Filter.Tendsto (fun n : вДХ => Real.log (Real.sqrt n))
        Filter.atTop Filter.atTop := Real.tendsto_log_atTop.comp hsqrt
    have hU : Filter.Tendsto
        (fun n : вДХ => Real.log 4 / Real.log (Real.sqrt n) + 1 / Real.sqrt n)
        Filter.atTop (рЭУЭ 0) := by
      have h1 := Filter.Tendsto.div_atTop (tendsto_const_nhds (x := Real.log 4)) hlogsqrt
      have h2 := Filter.Tendsto.div_atTop (tendsto_const_nhds (x := (1 : вДЭ))) hsqrt
      simpa using h1.add h2
    refine squeeze_zero' (Filter.Eventually.of_forall fun n => by positivity) ?_ hU
    filter_upwards [Filter.eventually_gt_atTop 1] with n hn
    have hn1 : (1 : вДЭ) < n := by exact_mod_cast hn
    have hnpos : (0 : вДЭ) < n := by positivity
    have hpi := Chebyshev.pi_le_log4_mul_div hn1
    rw [Nat.floor_natCast] at hpi
    rw [div_le_iffвВА hnpos]
    calc (Nat.primeCounting n : вДЭ)
        вЙ§ Real.log 4 * n / Real.log (Real.sqrt n) + Real.sqrt n := hpi
      _ = (Real.log 4 / Real.log (Real.sqrt n) + 1 / Real.sqrt n) * n := by
          rw [add_mul, div_mul_eq_mul_div, one_div, inv_mul_eq_div, Real.div_sqrt]
  ¬Ј filter_upwards [Filter.eventually_gt_atTop 0] with n hn h
    exact absurd h (Nat.cast_pos.mpr hn).ne'

/-- Shifting a predicate by `-1` changes the count by at most `1`. -/
lemma countUpTo_pred_le (Q : вДХ вЖТ Prop) (X : вДХ) :
    countUpTo (fun N => Q (N - 1)) X вЙ§ countUpTo Q X + 1 := by
  unfold countUpTo
  have hsub : setUpTo (fun N => Q (N - 1)) X вКЖ insert 0 (Nat.succ '' setUpTo Q X) := by
    rintro N вЯ®hNX, hQвЯ©
    rcases Nat.eq_zero_or_pos N with rfl | hN
    ¬Ј exact Set.mem_insert _ _
    ¬Ј exact Set.mem_insert_of_mem _ вЯ®N - 1, вЯ®by omega, hQвЯ©, by omegaвЯ©
  calc (setUpTo (fun N => Q (N - 1)) X).ncard
      вЙ§ (insert 0 (Nat.succ '' setUpTo Q X)).ncard :=
        Set.ncard_le_ncard hsub ((Set.Finite.image _ (setUpTo_finite Q X)).insert 0)
    _ вЙ§ (Nat.succ '' setUpTo Q X).ncard + 1 := Set.ncard_insert_le _ _
    _ = (setUpTo Q X).ncard + 1 := by
        rw [Set.ncard_image_of_injective _ Nat.succ_injective]

/-- A density-zero predicate stays density-zero after a `-1` shift. -/
lemma CountIsLittleO.pred {Q : вДХ вЖТ Prop} (hQ : CountIsLittleO Q) :
    CountIsLittleO (fun N => Q (N - 1)) := by
  have hconst : (fun (_ : вДХ) => (1 : вДЭ)) =o[Filter.atTop] (fun X : вДХ => (X : вДЭ)) := by
    apply Asymptotics.isLittleO_const_left.2
    right
    refine tendsto_atTop_mono (fun X => ?_) tendsto_natCast_atTop_atTop
    show (X : вДЭ) вЙ§ вАЦ(X : вДЭ)вАЦ
    rw [Real.norm_eq_abs]; exact le_abs_self _
  have hbound : (fun X : вДХ => (countUpTo (fun N => Q (N - 1)) X : вДЭ)) =O[Filter.atTop]
      (fun X : вДХ => (countUpTo Q X : вДЭ) + 1) := by
    refine Asymptotics.isBigO_of_le Filter.atTop (fun X => ?_)
    rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
    have hle : (countUpTo (fun N => Q (N - 1)) X : вДЭ) вЙ§ (countUpTo Q X : вДЭ) + 1 := by
      exact_mod_cast countUpTo_pred_le Q X
    linarith [hle]
  exact hbound.trans_isLittleO (hQ.add hconst)

/-- `#{n вЙ§ X : n prime}` is the prime counting function. -/
lemma countUpTo_prime_eq (X : вДХ) : countUpTo Nat.Prime X = Nat.primeCounting X := by
  rw [countUpTo, Nat.primeCounting, Nat.primeCounting', Nat.count_eq_card_filter_range,
    вЖР Set.ncard_coe_finset]
  congr 1
  ext n
  simp only [setUpTo, Set.mem_setOf_eq, Finset.coe_filter, Finset.mem_range, Nat.lt_succ_iff]

/-- The integers `2p+1` (`p` prime) up to `X` inject into the primes up to `X`. -/
lemma countTwoP1_le_prime (X : вДХ) :
    countUpTo (fun N => вИГ p, p.Prime вИІ N = 2 * p + 1) X вЙ§ countUpTo Nat.Prime X := by
  unfold countUpTo
  refine Set.ncard_le_ncard_of_injOn (fun N => (N - 1) / 2) ?_ ?_ (setUpTo_finite _ X)
  ¬Ј rintro N вЯ®hNX, p, hp, rflвЯ©
    simp only [setUpTo, Set.mem_setOf_eq]
    have hpe : (2 * p + 1 - 1) / 2 = p := by omega
    rw [hpe]
    exact вЯ®by omega, hpвЯ©
  ¬Ј rintro N вЯ®hNX, p, hp, rflвЯ© M вЯ®hMX, q, hq, rflвЯ© h
    simp only [] at h
    omega

/-- The set `{2p+1 : p prime}` has density zero. -/
lemma twoP1_littleO : CountIsLittleO (fun N => вИГ p, p.Prime вИІ N = 2 * p + 1) := by
  have hP : CountIsLittleO Nat.Prime := by
    have heq : (fun X : вДХ => (countUpTo Nat.Prime X : вДЭ))
        = (fun X => (Nat.primeCounting X : вДЭ)) := by
      funext X; rw [countUpTo_prime_eq]
    rw [CountIsLittleO, heq]; exact primeCounting_isLittleO
  have hbound : (fun X : вДХ => (countUpTo (fun N => вИГ p, p.Prime вИІ N = 2 * p + 1) X : вДЭ))
      =O[Filter.atTop] (fun X : вДХ => (countUpTo Nat.Prime X : вДЭ)) := by
    refine Asymptotics.isBigO_of_le Filter.atTop (fun X => ?_)
    rw [Real.norm_of_nonneg (by positivity), Real.norm_of_nonneg (by positivity)]
    exact_mod_cast countTwoP1_le_prime X
  exact hbound.trans_isLittleO hP

/-- **Almost every odd integer is represented** (paper Lemma 7.1). -/
theorem odd_represented (hDeep : DeepInputs) :
    CountIsLittleO (fun N => Odd N вИІ N вИЙ R) := by
  refine CountIsLittleO.mono ?_ ((hDeep.goldbach_ae.pred).or twoP1_littleO)
  rintro N вЯ®hodd, hNRвЯ©
  obtain вЯ®k, hkвЯ© := hodd
  by_cases hg : вИГ p q, p.Prime вИІ q.Prime вИІ N - 1 = p + q
  ¬Ј obtain вЯ®p, q, hp, hq, hpqвЯ© := hg
    rcases eq_or_ne p q with rfl | hne
    ¬Ј exact Or.inr вЯ®p, hp, by omegaвЯ©
    ¬Ј exfalso
      apply hNR
      rw [mem_R_iff_exists_F]
      rcases lt_or_gt_of_ne hne with hlt | hgt
      ¬Ј exact вЯ®p, q, hp.pos, hq.pos, by rw [F_two_primes hp hq hlt]; omegaвЯ©
      ¬Ј exact вЯ®q, p, hq.pos, hp.pos, by rw [F_two_primes hq hp hgt]; omegaвЯ©
  ¬Ј exact Or.inl вЯ®вЯ®k, by omegaвЯ©, hgвЯ©



/-! ## Section 8 -- Main theorem (Thm 1.1): positive lower density of N in R with f(N) > A*N; hence limsup f(N)/N is infinite. -/


/-- **Main theorem** (paper Theorem 1.1): for each `A вЙ• 1`, the set of represented `N`
with `f N > A¬ЈN` has positive lower density. -/
theorem main (hDeep : DeepInputs) (A : вДЭ) (hA : 1 вЙ§ A) :
    вИГ c : вДЭ, 0 < c вИІ
      c вЙ§ lowerDensity (fun N => N вИИ R вИІ (A * N : вДЭ) < (f N : вДЭ)) := by
  obtain вЯ®cвВБ, hcвВБpos, hsiftвЯ© := sift_density_lb hDeep
  obtain вЯ®CвВЕ, hCвВЕpos, hlargeвЯ© := large_e_bound
  obtain вЯ®E, hE2, hEchoiceвЯ© :
      вИГ E : вДХ, 2 вЙ§ E вИІ CвВЕ * A ^ 4 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) вЙ§ ќі E / 4 := by
    set K : вДЭ := 16 * (2 : вДЭ) ^ (1 / 4 : вДЭ) * (CвВЕ * A ^ 4) with hK
    have htend : Tendsto (fun E : вДХ => K * (E : вДЭ) ^ (-(1 / 4 : вДЭ))) atTop (рЭУЭ 0) := by
      have h2 : Tendsto (fun E : вДХ => (E : вДЭ) ^ (-(1 / 4 : вДЭ))) atTop (рЭУЭ 0) :=
        (tendsto_rpow_neg_atTop (by norm_num)).comp tendsto_natCast_atTop_atTop
      simpa using h2.const_mul K
    obtain вЯ®E, hKlt, hE2вЯ© :=
      ((htend.eventually (Iio_mem_nhds hcвВБpos)).and (eventually_ge_atTop 2)).exists
    refine вЯ®E, hE2, ?_вЯ©
    have hE0 : (0 : вДЭ) < E := by exact_mod_cast (by omega : 0 < E)
    have hlog0 : (0 : вДЭ) < Real.log (2 * E) := by
      apply Real.log_pos
      have h2E : (2 : вДЭ) вЙ§ E := by exact_mod_cast hE2
      linarith
    -- log(2E) вЙ§ 4 (2E)^{1/4}
    have hlog : Real.log (2 * E) вЙ§ 4 * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ) := by
      have h := Real.log_le_rpow_div (x := 2 * (E : вДЭ)) (by positivity) (show (0 : вДЭ) < 1 / 4 by norm_num)
      have h4 : (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ) / (1 / 4) = 4 * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ) := by ring
      rw [h4] at h; exact h
    -- the rpow identity `E^{-1/2} ¬Ј (2E)^{1/4} = 2^{1/4} ¬Ј E^{-1/4}`
    have hrpow : (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ)
        = (2 : вДЭ) ^ (1 / 4 : вДЭ) * (E : вДЭ) ^ (-(1 / 4 : вДЭ)) := by
      rw [Real.mul_rpow (by norm_num) hE0.le,
        show (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * ((2 : вДЭ) ^ (1 / 4 : вДЭ) * (E : вДЭ) ^ (1 / 4 : вДЭ))
          = (2 : вДЭ) ^ (1 / 4 : вДЭ) * ((E : вДЭ) ^ (-(1 / 2 : вДЭ)) * (E : вДЭ) ^ (1 / 4 : вДЭ)) by ring,
        вЖР Real.rpow_add hE0, show (-(1 / 2 : вДЭ) + 1 / 4) = -(1 / 4 : вДЭ) by norm_num]
    -- key bound: `4 CвВЕAвБі E^{-1/2} log(2E) вЙ§ K E^{-1/4} < cвВБ`
    have hkey : 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * Real.log (2 * E) вЙ§ cвВБ := by
      have hle : 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * Real.log (2 * E)
          вЙ§ K * (E : вДЭ) ^ (-(1 / 4 : вДЭ)) := by
        calc 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * Real.log (2 * E)
            вЙ§ 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * (4 * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ)) := by
              apply mul_le_mul_of_nonneg_left hlog (by positivity)
          _ = K * (E : вДЭ) ^ (-(1 / 4 : вДЭ)) := by
              have hcollect : 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) *
                    (4 * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ))
                  = 16 * (CвВЕ * A ^ 4) *
                    ((E : вДЭ) ^ (-(1 / 2 : вДЭ)) * (2 * (E : вДЭ)) ^ (1 / 4 : вДЭ)) := by ring
              rw [hcollect, hrpow, hK]; ring
      linarith [hle, hKlt]
    -- convert `hkey` into the modulus inequality, then use `hsift`
    have hElog2 : (0 : вДЭ) < 4 * (E : вДЭ) * Real.log (2 * E) := by positivity
    have hstep : CвВЕ * A ^ 4 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) вЙ§ cвВБ / (4 * (E : вДЭ) * Real.log (2 * E)) := by
      rw [le_div_iffвВА hElog2]
      calc CвВЕ * A ^ 4 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * (4 * (E : вДЭ) * Real.log (2 * E))
          = 4 * (CвВЕ * A ^ 4) * ((E : вДЭ) ^ (-(3 / 2 : вДЭ)) * (E : вДЭ)) * Real.log (2 * E) := by ring
        _ = 4 * (CвВЕ * A ^ 4) * (E : вДЭ) ^ (-(1 / 2 : вДЭ)) * Real.log (2 * E) := by
            have hEE : (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * (E : вДЭ) = (E : вДЭ) ^ (-(1 / 2 : вДЭ)) := by
              have h := (Real.rpow_add hE0 (-(3 / 2 : вДЭ)) 1).symm
              rw [Real.rpow_one] at h
              rw [h, show (-(3 / 2 : вДЭ) + 1) = -(1 / 2 : вДЭ) by norm_num]
            rw [hEE]
        _ вЙ§ cвВБ := hkey
    refine le_trans hstep ?_
    rw [show 4 * (E : вДЭ) * Real.log (2 * E) = ((E : вДЭ) * Real.log (2 * E)) * 4 by ring, вЖР div_div]
    exact (div_le_div_iff_of_pos_right (by norm_num)).2 (hsift E hE2)
  -- `ќі E > 0`
  have hElog : (0 : вДЭ) < (E : вДЭ) * Real.log (2 * E) := by
    have h1 : (0 : вДЭ) < (E : вДЭ) := by exact_mod_cast (by omega : 0 < E)
    have h2 : (0 : вДЭ) < Real.log (2 * E) := by
      apply Real.log_pos
      have : (2 : вДЭ) вЙ§ E := by exact_mod_cast hE2
      linarith
    positivity
  have hќіpos : 0 < ќі E := lt_of_lt_of_le (div_pos hcвВБpos hElog) (hsift E hE2)
  refine вЯ®ќі E / 2, by positivity, ?_вЯ©
  -- coprime to `Q_E` вЯє odd
  have hodd : вИА N, Nat.Coprime N (Qpr E) вЖТ Odd N := by
    intro N hN
    rcases Nat.even_or_odd N with he | ho
    ¬Ј have hgcd : Nat.gcd N (Qpr E) = 1 := hN
      have : (2 : вДХ) вИ£ 1 := hgcd вЦЄ Nat.dvd_gcd he.two_dvd (two_dvd_Qpr E hE2)
      exact absurd this (by decide)
    ¬Ј exact ho
  -- density chain: start at `ќі E`, remove the two `o(X)` sets, then the `вЙ§ ќі E/4` set
  have step0 : ќі E вЙ§ lowerDensity (fun N => Nat.Coprime N (Qpr E)) := sift_lowerDensity E hE2
  have step1 : ќі E вЙ§ lowerDensity
      (fun N => Nat.Coprime N (Qpr E) вИІ
        ¬ђ (Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d)) :=
    lowerDensity_and_not step0 (small_e_exclusion E hE2)
  have hB1 : CountIsLittleO (fun N => Nat.Coprime N (Qpr E) вИІ N вИЙ R) :=
    CountIsLittleO.mono (fun N hN => вЯ®hodd N hN.1, hN.2вЯ©) (odd_represented hDeep)
  have step2 : ќі E вЙ§ lowerDensity
      (fun N => (Nat.Coprime N (Qpr E) вИІ
          ¬ђ (Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d)) вИІ
        ¬ђ (Nat.Coprime N (Qpr E) вИІ N вИЙ R)) :=
    lowerDensity_and_not step1 hB1
  have hHbound : вИА X : вДХ, (countUpTo (Hset A E) X : вДЭ) вЙ§ ќі E / 4 * X := by
    intro X
    calc (countUpTo (Hset A E) X : вДЭ)
        вЙ§ CвВЕ * A ^ 4 * (E : вДЭ) ^ (-(3 / 2 : вДЭ)) * X := hlarge A hA E (by omega) X
      _ вЙ§ ќі E / 4 * X := mul_le_mul_of_nonneg_right hEchoice (by positivity)
  have step3 : ќі E - ќі E / 4 вЙ§ lowerDensity
      (fun N => ((Nat.Coprime N (Qpr E) вИІ
          ¬ђ (Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d)) вИІ
        ¬ђ (Nat.Coprime N (Qpr E) вИІ N вИЙ R)) вИІ ¬ђ Hset A E N) :=
    lowerDensity_and_not_le hHbound step2
  -- survivors satisfy `N вИИ R` and `f N > A¬ЈN`
  have hmono : вИА N, (((Nat.Coprime N (Qpr E) вИІ
          ¬ђ (Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d)) вИІ
        ¬ђ (Nat.Coprime N (Qpr E) вИІ N вИЙ R)) вИІ ¬ђ Hset A E N) вЖТ
      N вИИ R вИІ (A * N : вДЭ) < (f N : вДЭ) := by
    intro N hgood
    obtain вЯ®вЯ®вЯ®hQc, hnsmallвЯ©, hnunrepвЯ©, hnHsetвЯ© := hgood
    have hNR : N вИИ R := by
      by_contra hNR; exact hnunrep вЯ®hQc, hNRвЯ©
    refine вЯ®hNR, ?_вЯ©
    by_contra hle
    rw [not_lt] at hle
    obtain вЯ®e, d, he, hd, hfeq, hNFвЯ© := f_mem_Fform N hNR
    by_cases heE : e вЙ§ E
    ¬Ј exact hnsmall вЯ®hQc, e, d, he, heE, hNFвЯ©
    ¬Ј rw [not_le] at heE
      refine hnHset вЯ®e, d, heE, hd, hNF, ?_вЯ©
      have hcast : (e : вДЭ) * d = (f N : вДЭ) := by rw [вЖР Nat.cast_mul, вЖР hfeq]
      rw [hcast]; exact hle
  calc ќі E / 2
      вЙ§ ќі E - ќі E / 4 := by linarith
    _ вЙ§ lowerDensity
        (fun N => ((Nat.Coprime N (Qpr E) вИІ
            ¬ђ (Nat.Coprime N (Qpr E) вИІ вИГ e d, 1 вЙ§ e вИІ e вЙ§ E вИІ N = F e d)) вИІ
          ¬ђ (Nat.Coprime N (Qpr E) вИІ N вИЙ R)) вИІ ¬ђ Hset A E N) := step3
    _ вЙ§ lowerDensity (fun N => N вИИ R вИІ (A * N : вДЭ) < (f N : вДЭ)) := lowerDensity_mono hmono

/-- **Unbounded ratio** (paper Theorem 1.1, limsup form): for every `A` there is a
represented `N` with `f N / N > A`. -/
theorem ratio_unbounded (hDeep : DeepInputs) (A : вДЭ) :
    вИГ N : вДХ, N вИИ R вИІ A < (f N : вДЭ) / (N : вДЭ) := by
  obtain вЯ®c, hcpos, hcвЯ© := main hDeep (max A 1) (le_max_right A 1)
  -- positivity of the lower density forces the set to be nonempty
  have hne : вИГ N, N вИИ R вИІ (max A 1 * (N : вДЭ)) < (f N : вДЭ) := by
    by_contra h
    push_neg at h
    have hc0 : вИА X, countUpTo (fun N => N вИИ R вИІ (max A 1 * (N : вДЭ)) < (f N : вДЭ)) X = 0 := by
      intro X
      have hemp : setUpTo (fun N => N вИИ R вИІ (max A 1 * (N : вДЭ)) < (f N : вДЭ)) X = вИЕ :=
