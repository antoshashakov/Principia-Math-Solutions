open Finset







/-- `e` on an integer is `1`. -/
lemma e_int (a : вД§) : e ((a : вДЭ)) = 1 := (e_eq_one_iff _).mpr вЯ®a, rflвЯ©

/-- **Additive-character orthogonality**: `вИС_{n<q} e(an/q) = q` if `q вИ£ a`, else `0`.
    The backbone of Gauss/Ramanujan sums and the major-arc singular series. -/
lemma char_orthogonality (a : вД§) (q : вДХ) (hq : q вЙ† 0) :
    вИС n вИИ Finset.range q, e ((a : вДЭ) * n / q) = if (q : вД§) вИ£ a then (q : вДВ) else 0 := by
  have hqR : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq
  have hterm : вИА n : вДХ, e ((a : вДЭ) * n / q) = (e ((a : вДЭ) / q)) ^ n := by
    intro n
    rw [вЖР e_pow, show (n : вДЭ) * ((a : вДЭ) / q) = (a : вДЭ) * n / q by ring]
  rw [Finset.sum_congr rfl (fun n _ => hterm n)]
  have hzq : (e ((a : вДЭ) / q)) ^ q = 1 := by
    rw [вЖР e_pow, show (q : вДЭ) * ((a : вДЭ) / q) = (a : вДЭ) by field_simp]
    exact e_int a
  by_cases hdvd : (q : вД§) вИ£ a
  ¬Ј obtain вЯ®k, hkвЯ© := hdvd
    have hz : e ((a : вДЭ) / q) = 1 := by
      rw [show ((a : вДЭ) / q) = (k : вДЭ) by rw [hk]; push_cast; field_simp]
      exact e_int k
    rw [if_pos вЯ®k, hkвЯ©]
    simp [hz]
  ¬Ј have hzne : e ((a : вДЭ) / q) вЙ† 1 := by
      intro hz
      rw [e_eq_one_iff] at hz
      obtain вЯ®k, hkвЯ© := hz
      apply hdvd
      refine вЯ®k, ?_вЯ©
      have h1 : (a : вДЭ) = (k : вДЭ) * (q : вДЭ) := by rw [вЖР hk]; field_simp
      have h2 : (a : вДЭ) = (q : вДЭ) * (k : вДЭ) := by rw [h1]; ring
      exact_mod_cast h2
    rw [geom_sum_eq hzne, hzq, sub_self, zero_div, if_neg hdvd]

/-- **Integral character orthogonality**: `вИЂвВА¬є e(kќ±) dќ± = 1` if `k = 0`, else `0`.
    The circle-method main-term extractor and the seed of the Parseval/large-sieve chain. -/
lemma integral_e (k : вД§) :
    вИЂ ќ± in (0:вДЭ)..1, e ((k : вДЭ) * ќ±) = if k = 0 then 1 else 0 := by
  by_cases hk : k = 0
  ¬Ј subst hk
    rw [if_pos rfl]
    have hcong : вИА ќ± вИИ Set.uIcc (0:вДЭ) 1, e (((0 : вД§) : вДЭ) * ќ±) = 1 := by
      intro ќ± _; simp only [Int.cast_zero, zero_mul]; simp [e]
    rw [intervalIntegral.integral_congr hcong, intervalIntegral.integral_const]
    norm_num
  ¬Ј rw [if_neg hk]
    set c : вДВ := 2 * (Real.pi : вДВ) * Complex.I * (k : вДВ) with hc
    have hcne : c вЙ† 0 := by
      rw [hc]
      exact mul_ne_zero (mul_ne_zero (mul_ne_zero (by norm_num)
        (Complex.ofReal_ne_zero.mpr Real.pi_ne_zero)) Complex.I_ne_zero)
        (by exact_mod_cast hk)
