      _ = X * (24*C * u ^ ((5:вДЭ)/2) * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))
          + (6*C + 48/c^2) * u ^ (3:вДЭ) * Real.exp (-(u/2))) := by ring
      _ вЙ§ X * ((24*C + (6*C + 48/c^2)) * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2)))) := h2
      _ = (30*C + 48/c^2) * X * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) := by ring
