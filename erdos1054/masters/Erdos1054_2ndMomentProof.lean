    apply (continuousOn_const.div (by fun_prop) ?_).intervalIntegrable
    intro t ht; simp only [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
    exact ne_of_gt (by linarith [ht.1])
  rw [intervalIntegral.integral_sub hint (intervalIntegral.intervalIntegrable_const),
      h1, intervalIntegral.integral_const, smul_eq_mul]; ring

theorem int_pole_intble (c C : вДЭ) (x : вДЭ) (hx : 1 < x) (hx2 : x вЙ§ 2) :
    IntervalIntegrable (fun t => c / (t - 1) - C) MeasureTheory.volume x 2 := by
  apply IntervalIntegrable.sub _ (intervalIntegral.intervalIntegrable_const)
  apply (continuousOn_const.div (by fun_prop) ?_).intervalIntegrable
  intro t ht; simp only [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
  exact ne_of_gt (by linarith [ht.1])

variable [NeZero q]

theorem Vmono (ha : IsUnit a) {x : вДЭ} (hx : 1 вЙ§ x)
    (hsum : Summable (fun n : вДХ => prc a n / n)) : Vf a x вЙ§ Vf a 1 := by
  have hV1 : (fun n : вДХ => prc a n / n) = (fun n : вДХ => prc a n * (n:вДЭ)^(-(1:вДЭ))) := by
    funext n; rw [Real.rpow_neg_one]; ring
  have hle : вИА n : вДХ, prc a n * (n:вДЭ)^(-x) вЙ§ prc a n * (n:вДЭ)^(-(1:вДЭ)) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј simp [prc, Nat.not_prime_zero]
    ¬Ј refine mul_le_mul_of_nonneg_left ?_ (prc_nonneg a n)
      exact Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast hn) (by linarith)
  have hsum' : Summable (fun n : вДХ => prc a n * (n:вДЭ)^(-(1:вДЭ))) := hV1 вЦЄ hsum
  have hnn : вИА n : вДХ, 0 вЙ§ prc a n * (n:вДЭ)^(-x) :=
    fun n => mul_nonneg (prc_nonneg a n) (Real.rpow_nonneg (by positivity) _)
  unfold Vf
  exact Summable.tsum_le_tsum hle (hsum'.of_nonneg_of_le hnn hle) hsum'

theorem bridge (hq : 1 < q) (ha : a = ((q - 1 : вДХ) : ZMod q))
    (H : Summable (fun p : {p : Nat // p.Prime вИІ p % q = q - 1} => (1 / (p.1 : вДЭ)))) :
    Summable (fun n : вДХ => prc a n / n) := by
  have H2 : Summable ({p : вДХ | p.Prime вИІ p % q = q - 1}.indicator (fun p : вДХ => 1 / (p:вДЭ))) :=
    (summable_subtype_iff_indicator (s := {p : вДХ | p.Prime вИІ p % q = q - 1})
      (f := fun n : вДХ => 1 / (n:вДЭ))).mp H
  refine H2.congr (fun n => ?_)
  have hiff : ((n:ZMod q) = a) вЖФ (n % q = q - 1) := by
    rw [ha, ZMod.natCast_eq_natCast_iff]; unfold Nat.ModEq
    rw [Nat.mod_eq_of_lt (show q - 1 < q by omega)]
  unfold prc
  rw [Set.indicator_apply]; simp only [Set.mem_setOf_eq]
  by_cases hp : n.Prime вИІ n % q = q - 1
  ¬Ј rw [if_pos hp, if_pos вЯ®hp.1, hiff.mpr hp.2вЯ©]
  ¬Ј rw [if_neg hp, if_neg (fun h => hp вЯ®h.1, hiff.mp h.2вЯ©)]; simp

theorem Wpole (ha : IsUnit a) :
    вИГ C : вДЭ, вИА {x : вДЭ}, x вИИ Set.Ioc 1 2 вЖТ (q.totient : вДЭ)вБї¬є / (x - 1) - C вЙ§ Wf a x := by
  obtain вЯ®C, hCвЯ© := LSeries_residueClass_lower_bound ha
  have hBsum : Summable (fun n : вДХ => (if n.Prime then 0 else residueClass a n) / n) :=
    summable_residueClass_non_primes_div a
  set B : вДЭ := вИС' n : вДХ, (if n.Prime then 0 else residueClass a n) / (n:вДЭ) with hBdef
  refine вЯ®C + B, fun {x} hx => ?_вЯ©
  have hx1 : 1 < x := hx.1
  have hRs := Rsum (a := a) x hx1
  have hnp : вИА n : вДХ, 1 вЙ§ n вЖТ (n:вДЭ) вЙ§ (n:вДЭ)^x := by
    intro n hn
    have h1n : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
    calc (n:вДЭ) = (n:вДЭ)^(1:вДЭ) := (Real.rpow_one _).symm
    _ вЙ§ (n:вДЭ)^x := Real.rpow_le_rpow_of_exponent_le h1n hx1.le
  have hsplit : вИА n : вДХ, residueClass a n / (n:вДЭ)^x
      = (if n.Prime then residueClass a n else 0) / (n:вДЭ)^x
        + (if n.Prime then 0 else residueClass a n) / (n:вДЭ)^x := by
    intro n; by_cases hp : n.Prime <;> simp [hp]
  have hWs : Summable (fun n : вДХ => (if n.Prime then residueClass a n else 0) / (n:вДЭ)^x) := by
    apply hRs.of_nonneg_of_le
      (fun n => div_nonneg (by split_ifs; exacts [residueClass_nonneg a n, le_refl 0]) (Real.rpow_nonneg (Nat.cast_nonneg n) x))
      (fun n => ?_)
    gcongr
    split_ifs
    ¬Ј exact le_refl _
    ¬Ј exact residueClass_nonneg a n
  have htle : вИА n : вДХ, (if n.Prime then 0 else residueClass a n) / (n:вДЭ)^x
      вЙ§ (if n.Prime then 0 else residueClass a n) / (n:вДЭ) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј simp
    ¬Ј gcongr
      ¬Ј split_ifs; exacts [le_refl 0, residueClass_nonneg a n]
      ¬Ј exact hnp n hn
  have htails : Summable (fun n : вДХ => (if n.Prime then 0 else residueClass a n) / (n:вДЭ)^x) := by
    apply hBsum.of_nonneg_of_le
      (fun n => div_nonneg (by split_ifs; exacts [le_refl 0, residueClass_nonneg a n]) (Real.rpow_nonneg (Nat.cast_nonneg n) x)) htle
  have hWval : Wf a x = вИС' n : вДХ, (if n.Prime then residueClass a n else 0) / (n:вДЭ)^x := by
    unfold Wf; exact tsum_congr (fun n => Wf_summand x n)
  have hRsplit : (вИС' n : вДХ, residueClass a n / (n:вДЭ)^x)
      = Wf a x + вИС' n : вДХ, (if n.Prime then 0 else residueClass a n) / (n:вДЭ)^x := by
    rw [hWval, вЖР Summable.tsum_add hWs htails]; exact tsum_congr hsplit
  have hpole := hC hx
  have htaille : (вИС' n : вДХ, (if n.Prime then 0 else residueClass a n) / (n:вДЭ)^x) вЙ§ B :=
    Summable.tsum_le_tsum htle htails hBsum
  linarith [hpole, htaille, hRsplit]

theorem hunb (ha : IsUnit a)
    (hVW : вИА {x:вДЭ}, x вИИ Set.Ioc 1 2 вЖТ Vf a x = Vf a 2 + вИЂ t in x..2, Wf a t)
    (hWint : вИА {x:вДЭ}, x вИИ Set.Ioc 1 2 вЖТ IntervalIntegrable (Wf a) MeasureTheory.volume x 2)
    (C : вДЭ) (hC : вИА {x:вДЭ}, x вИИ Set.Ioc 1 2 вЖТ (q.totient:вДЭ)вБї¬є/(x-1) - C вЙ§ Wf a x) :
    вИА M : вДЭ, вИГ x : вДЭ, x вИИ Set.Ioc 1 2 вИІ M < Vf a x := by
  intro M
  have hcpos : (0:вДЭ) < (q.totient:вДЭ)вБї¬є := by
    have : 0 < q.totient := Nat.totient_pos.mpr (Nat.pos_of_ne_zero (NeZero.ne q)); positivity
  set c : вДЭ := (q.totient:вДЭ)вБї¬є with hc
  set K : вДЭ := (Vf a 2 - |C| - M) / c with hKd
  set ќµ : вДЭ := min 1 (Real.exp (K - 1)) with hќµ
  have hќµpos : 0 < ќµ := lt_min one_pos (Real.exp_pos _)
  have hќµle : ќµ вЙ§ 1 := min_le_left _ _
  set x : вДЭ := 1 + ќµ with hxd
  have hxmem : x вИИ Set.Ioc 1 2 := вЯ®by linarith, by linarithвЯ©
  have hxm1 : x - 1 = ќµ := by rw [hxd]; ring
  refine вЯ®x, hxmem, ?_вЯ©
  have hmono : (вИЂ t in x..2, (c/(t-1) - C)) вЙ§ вИЂ t in x..2, Wf a t := by
    apply intervalIntegral.integral_mono_on hxmem.2 (int_pole_intble c C x hxmem.1 hxmem.2) (hWint hxmem)
    intro t ht
    exact hC вЯ®by simp only [Set.mem_Icc] at ht; linarith [ht.1, hxmem.1], by
      simp only [Set.mem_Icc] at ht; linarith [ht.2]вЯ©
  have heval := int_pole c C x hxmem.1 hxmem.2
  rw [hxm1] at heval
  have hlog : Real.log ќµ вЙ§ K - 1 := by
    calc Real.log ќµ вЙ§ Real.log (Real.exp (K-1)) := Real.log_le_log hќµpos (min_le_right _ _)
    _ = K - 1 := Real.log_exp _
  have hcK : c * K = Vf a 2 - |C| - M := by rw [hKd]; field_simp
  have hCbound : -C * (2 - x) вЙ• -|C| := by
    have h2x : (0:вДЭ) вЙ§ 2 - x := by linarith [hxmem.2]
    have h2x1 : 2 - x вЙ§ 1 := by linarith [hxmem.1]
    nlinarith [abs_nonneg C, neg_abs_le C, le_abs_self C]
  rw [hVW hxmem]
  have h3 : Vf a 2 + (c * (-Real.log ќµ) - C * (2 - x)) вЙ§ Vf a 2 + вИЂ t in x..2, Wf a t := by
    rw [вЖР heval]; linarith [hmono]
  have h4 : M + c вЙ§ Vf a 2 + (c * (-Real.log ќµ) - C * (2 - x)) := by
    have hc2 : c * (-Real.log ќµ) вЙ• -(c * (K-1)) := by nlinarith [hlog, hcpos]
    nlinarith [hc2, hCbound, hcK]
  linarith [h3, h4, hcpos]

theorem main (hq : 1 < q) :
    ¬ђ Summable (fun p : {p : Nat // p.Prime вИІ p % q = q - 1} => (1 / (p.1 : вДЭ))) := by
  set a : ZMod q := ((q - 1 : вДХ) : ZMod q) with ha_def
  have ha : IsUnit a := by
    have h : a = -1 := by
      rw [ha_def]; push_cast [Nat.cast_sub (by omega : 1 вЙ§ q)]; simp [ZMod.natCast_self]
    rw [h]; exact isUnit_one.neg
  intro H
  have hsum : Summable (fun n : вДХ => prc a n / n) := bridge hq ha_def H
  obtain вЯ®C, hCвЯ© := Wpole ha
  have hunbd := hunb ha (fun {x} hx => VW ha hx) (fun {x} hx => Wint ha hx) C hC
  obtain вЯ®x, hx, hMвЯ© := hunbd (Vf a 1)
  exact absurd (Vmono ha hx.1.le hsum) (not_le.mpr hM)

end A1proof


namespace Erdos1054

noncomputable def sigma (n : Nat) : Nat := n.divisors.sum (fun d => d)


