open Finset in
set_option maxHeartbeats 4000000 in
/-- **The rated uniform window bound** (brick C1c = plan item C1, Phase C core):
    uniformly for `q вЙ§ (log N)^B`, every Farey-window evaluation of `вИСќЫ(n)e(nќ±)`
    against its `ќЉ/ѕЖ`-model window carries an `exp(вИТc(log N)^{1/10})` rate:
    `вАЦвИС_{n<N}ќЫ(n)e(n(a/q+ќ≤)) вИТ S_q(a)¬ЈвИС_{n<N}e(nќ≤)вАЦ вЙ§ C¬Јq¬ЈN¬Јexp(вИТc(log N)^{1/10})¬Ј(1+2ѕАN|ќ≤|)`.
    This is the input Phase D feeds to the major-arc L¬≤ computation. -/
theorem rated_window_eval (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИА q : вДХ, 0 < q вЖТ (q : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) вЖТ
    вИА a : вД§, вИА ќ≤ : вДЭ,
    вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
      - (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
        * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
    вЙ§ C * q * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
      * (1 + 2 * Real.pi * N * |ќ≤|) := by
  obtain вЯ®c, C, hc0, hC0, NвВБ, hC1aвЯ© := rated_progression_bound B hB
  refine вЯ®c, C + 1, hc0, by positivity, ?_вЯ©
  obtain вЯ®ќЫвВГ, hќЫвВГdefвЯ© : вИГ x : вДЭ, x = (30*B + c + 1)^(10:вДХ) + 4 := вЯ®_, rflвЯ©
  have hќЫвВГ0 : 0 < ќЫвВГ := by
    rw [hќЫвВГdef]
    positivity
  refine вЯ®max NвВБ (вМИReal.exp ќЫвВГвМЙвВК + 3), ?_вЯ©
  intro N hNвВА q hq0 hqB a ќ≤
  have hNNвВБ : NвВБ вЙ§ N := le_trans (le_max_left _ _) hNвВА
  have hNe : вМИReal.exp ќЫвВГвМЙвВК + 3 вЙ§ N := le_trans (le_max_right _ _) hNвВА
  have hN3 : 3 вЙ§ N := by omega
  have hN0 : (0:вДЭ) < (N:вДЭ) := by
    have h1 : 0 < N := by omega
    exact_mod_cast h1
  have hNR : Real.exp ќЫвВГ вЙ§ (N:вДЭ) := by
    have h1 : (вМИReal.exp ќЫвВГвМЙвВК : вДЭ) вЙ§ (N:вДЭ) := by
      have h2 : вМИReal.exp ќЫвВГвМЙвВК вЙ§ N := by omega
      exact_mod_cast h2
    linarith [Nat.le_ceil (Real.exp ќЫвВГ)]
  have hlogN : ќЫвВГ вЙ§ Real.log N := by
    calc ќЫвВГ = Real.log (Real.exp ќЫвВГ) := (Real.log_exp _).symm
      _ вЙ§ Real.log N := Real.log_le_log (Real.exp_pos _) hNR
  have hlogN4 : (4:вДЭ) вЙ§ Real.log N := by
    rw [hќЫвВГdef] at hlogN
    have h1 : (0:вДЭ) вЙ§ (30*B + c + 1)^(10:вДХ) := by positivity
    linarith
  have hlogN0 : (0:вДЭ) < Real.log N := by linarith
  obtain вЯ®L, hLdefвЯ© : вИГ x : вДЭ, x = Real.log N ^ ((1:вДЭ)/10) := вЯ®_, rflвЯ©
  have hL0 : 0 < L := by
    rw [hLdef]
    exact Real.rpow_pos_of_pos hlogN0 _
  have hLpow : L ^ (10:вДХ) = Real.log N := by
    rw [hLdef, вЖР Real.rpow_natCast (Real.log N ^ ((1:вДЭ)/10)) 10,
      вЖР Real.rpow_mul hlogN0.le]
    norm_num
  have hL30B : 30*B + c + 1 вЙ§ L := by
    by_contra hcon
    push_neg at hcon
    have h1 : L ^ (10:вДХ) < (30*B + c + 1) ^ (10:вДХ) :=
      pow_lt_pow_leftвВА hcon hL0.le (by norm_num)
    rw [hLpow] at h1
    rw [hќЫвВГdef] at hlogN
    linarith
  have hL1 : 1 вЙ§ L := by
    have h1 : (0:вДЭ) вЙ§ 30*B + c := by positivity
    linarith
  -- the non-unit trivial bound is dominated by the rated error
  have hnonunit_dom : (q:вДЭ) * Real.log N
      вЙ§ (N:вДЭ) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
    -- q¬ЈlogN вЙ§ (logN)^{B+1} вЙ§ exp(L^{10} вИТ cL) = N¬Јe^{вИТcL}
    have h1 : (q:вДЭ) * Real.log N вЙ§ Real.log N ^ ((B:вДЭ)) * Real.log N := by
      apply mul_le_mul_of_nonneg_right hqB hlogN0.le
    have h2 : Real.log N ^ ((B:вДЭ)) * Real.log N = Real.log N ^ ((B+1 : вДЭ)) := by
      rw [Real.rpow_add hlogN0, Real.rpow_one]
    have h3 : Real.log N ^ ((B+1 : вДЭ)) = Real.exp ((B+1) * Real.log (Real.log N)) := by
      rw [Real.rpow_def_of_pos hlogN0, mul_comm]
    have hloglog : Real.log (Real.log N) вЙ§ 10 * (L - 1) + 10 := by
      have h4 : Real.log (Real.log N) = 10 * Real.log L := by
        rw [вЖР hLpow, Real.log_pow]
        push_cast
        ring
      have h5 : Real.log L вЙ§ L - 1 := by
        have h6 := Real.log_le_sub_one_of_pos hL0
        linarith
      linarith [h4.le, h4.ge]
    have hexp_arg : (B+1) * Real.log (Real.log N) + c * L вЙ§ L ^ (10:вДХ) := by
      have h7 : (B+1) * Real.log (Real.log N) вЙ§ (B+1) * (10 * L) := by
        apply mul_le_mul_of_nonneg_left ?_ (by linarith)
        linarith [hloglog]
      have h8 : (B+1) * (10 * L) + c * L = (10*B + 10 + c) * L := by ring
      have h9 : (10*B + 10 + c) * L вЙ§ L ^ (9:вДХ) * L := by
        apply mul_le_mul_of_nonneg_right ?_ hL0.le
        have h10 : L вЙ§ L ^ (9:вДХ) := le_self_powвВА hL1 (by norm_num)
        linarith [hL30B]
      have h11 : L ^ (9:вДХ) * L = L ^ (10:вДХ) := by ring
      linarith
    calc (q:вДЭ) * Real.log N вЙ§ Real.log N ^ ((B+1 : вДЭ)) := by linarith [h2.le, h2.ge]
      _ = Real.exp ((B+1) * Real.log (Real.log N)) := h3
      _ вЙ§ Real.exp (L ^ (10:вДХ) - c * L) := by
          apply Real.exp_le_exp.mpr
          linarith [hexp_arg]
      _ = (N:вДЭ) * Real.exp (-(c * L)) := by
          rw [show L ^ (10:вДХ) - c * L = L ^ (10:вДХ) + -(c * L) from by ring,
            Real.exp_add, hLpow, Real.exp_log hN0]
      _ = (N:вДЭ) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
          rw [hLdef]
          congr 2
          ring
  -- per-residue input for ap_twisted_model, uniform over r < q
  have hper : вИА r вИИ Finset.range q,
      вИА t вЙ§ N, вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r),
        ((ќЫ n : вДЭ) : вДВ)) - (t : вДВ) * lambdaModel q rвАЦ
      вЙ§ (C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
    intro r hr t ht
    rw [Finset.mem_range] at hr
    by_cases hgcd : Nat.gcd r q = 1
    ¬Ј have h1 := hC1a N hNNвВБ q hq0 hqB r hr hgcd t ht
      rw [show lambdaModel q r = 1 / (q.totient : вДВ) from by
        rw [lambdaModel, if_pos hgcd]]
      calc вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ))
          - (t : вДВ) * (1 / (q.totient : вДВ))вАЦ
          вЙ§ C * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := h1
        _ вЙ§ (C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
            have h2 : (0:вДЭ) вЙ§ (N:вДЭ) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
              positivity
            nlinarith
    ¬Ј have h1 := nonunit_progression_bound q hq0 r hgcd N hN3 t ht
      rw [show lambdaModel q r = 0 from by rw [lambdaModel, if_neg hgcd]]
      rw [mul_zero, sub_zero]
      have h2 : вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r),
          ((ќЫ n : вДЭ) : вДВ))вАЦ
          = |вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n| := by
        rw [show (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ))
            = (((вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n : вДЭ)) : вДВ)
            from by push_cast; ring,
          Complex.norm_real, Real.norm_eq_abs]
      rw [h2, abs_of_nonneg (Finset.sum_nonneg
        (fun n _ => ArithmeticFunction.vonMangoldt_nonneg))]
      calc вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n
          вЙ§ (q:вДЭ) * Real.log N := h1
        _ вЙ§ (N:вДЭ) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := hnonunit_dom
        _ вЙ§ (C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
            have h3 : (0:вДЭ) вЙ§ (N:вДЭ) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
              positivity
            nlinarith
  -- assemble via the residue decomposition
  rw [major_arc_residue_decomp (fun n => ((ќЫ n : вДЭ) : вДВ)) N a q hq0 ќ≤,
    Finset.sum_mul, вЖР Finset.sum_sub_distrib]
  have hterm : вИА r вИИ Finset.range q,
      вАЦe ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
          * (вИС n вИИ (Finset.range N).filter (fun n => n % q = r),
              ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ≤))
        - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ (C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
        * (1 + 2 * Real.pi * N * |ќ≤|) := by
    intro r hr
    have h1 : e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
          * (вИС n вИИ (Finset.range N).filter (fun n => n % q = r),
              ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ≤))
        - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)
        = e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
          * ((вИС n вИИ (Finset.range N).filter (fun n => n % q = r),
              ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ≤))
            - lambdaModel q r * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)) := by
      ring
    rw [h1, norm_mul, e_norm, one_mul]
    exact ap_twisted_model (fun n => ((ќЫ n : вДЭ) : вДВ)) (lambdaModel q r) q r N ќ≤
      ((C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)))
      (hper r hr)
  calc вАЦвИС r вИИ Finset.range q,
      (e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
          * (вИС n вИИ (Finset.range N).filter (fun n => n % q = r),
              ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ≤))
        - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤))вАЦ
      вЙ§ вИС r вИИ Finset.range q,
        ((C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
          * (1 + 2 * Real.pi * N * |ќ≤|)) :=
        (norm_sum_le _ _).trans (Finset.sum_le_sum hterm)
    _ = (q:вДЭ) * ((C + 1) * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
          * (1 + 2 * Real.pi * N * |ќ≤|)) := by
        rw [Finset.sum_const, nsmul_eq_mul, Finset.card_range]
    _ = (C + 1) * q * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
        * (1 + 2 * Real.pi * N * |ќ≤|) := by ring

open Finset in
set_option maxHeartbeats 4000000 in
/-- **Rated per-arc S¬≤ model** (brick D1): squaring the rated window bound вАФ
    on the arc `ќ± = a/q + ќ≤` with `q вЙ§ (log N)^B`,
    `вАЦS(ќ±)¬≤ вИТ (W(a,q)¬ЈT(ќ≤))¬≤вАЦ вЙ§ C¬Јq¬ЈN¬≤¬Ј(log N + 1)¬Јexp(вИТc(log N)^{1/10})¬Ј(1+2ѕАN|ќ≤|)`
    where `S(ќ±) = вИС_{n<N}ќЫ(n)e(nќ±)`, `W(a,q) = вИС_r e(ra/q)¬ЈlambdaModel q r`,
    `T(ќ≤) = вИС_{n<N}e(nќ≤)`. Via `A¬≤вИТB¬≤ = (AвИТB)(A+B)`, `вАЦAвАЦ вЙ§ N¬Јlog N` and
    `вАЦWвАЦ вЙ§ 1` (the model window has total mass exactly 1). -/
theorem rated_arc_sq_model (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИА q : вДХ, 0 < q вЖТ (q : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) вЖТ
    вИА a : вД§, вИА ќ≤ : вДЭ,
    вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))) ^ 2
      - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)) ^ 2вАЦ
    вЙ§ C * q * N ^ 2 * (Real.log N + 1) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
      * (1 + 2 * Real.pi * N * |ќ≤|) := by
  obtain вЯ®c, C, hc0, hC0, NвВА, hC1вЯ© := rated_window_eval B hB
  refine вЯ®c, 3 * C, hc0, by positivity, max NвВА 3, ?_вЯ©
  intro N hNвВА q hq0 hqB a ќ≤
  have hNNвВА : NвВА вЙ§ N := le_trans (le_max_left _ _) hNвВА
  have hN3 : 3 вЙ§ N := le_trans (le_max_right _ _) hNвВА
  have hN0 : (0:вДЭ) < (N:вДЭ) := by
    have h1 : 0 < N := by omega
    exact_mod_cast h1
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := by
    apply Real.log_nonneg
    have h1 : 1 вЙ§ N := by omega
    exact_mod_cast h1
  have hwindow := hC1 N hNNвВА q hq0 hqB a ќ≤
  -- crude bound on S(ќ±)
  have hS : вАЦвИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
      * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))вАЦ вЙ§ (N:вДЭ) * Real.log N := by
    refine (norm_sum_le _ _).trans ?_
    calc вИС n вИИ Finset.range N, вАЦ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))вАЦ
        = вИС n вИИ Finset.range N, ќЫ n := by
          apply Finset.sum_congr rfl
          intro n _
          rw [norm_mul, e_norm, mul_one, Complex.norm_real, Real.norm_eq_abs,
            abs_of_nonneg ArithmeticFunction.vonMangoldt_nonneg]
      _ вЙ§ вИС _n вИИ Finset.range N, Real.log N := by
          apply Finset.sum_le_sum
          intro n hn
          rcases Nat.eq_zero_or_pos n with rfl | hn0
          ¬Ј rw [show ќЫ 0 = 0 from ArithmeticFunction.map_zero]
            linarith
          ¬Ј calc ќЫ n вЙ§ Real.log n := ArithmeticFunction.vonMangoldt_le_log
              _ вЙ§ Real.log N := by
                  apply Real.log_le_log (by exact_mod_cast hn0)
                  rw [Finset.mem_range] at hn
                  have h1 : n вЙ§ N := by omega
                  exact_mod_cast h1
      _ = (N:вДЭ) * Real.log N := by
          rw [Finset.sum_const, nsmul_eq_mul, Finset.card_range]
  -- the model window has mass вЙ§ 1
  have hѕЖ0 : (0:вДЭ) < (q.totient : вДЭ) := by
    exact_mod_cast Nat.totient_pos.mpr hq0
  have hW : вАЦвИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q rвАЦ
      вЙ§ 1 := by
    refine (norm_sum_le _ _).trans ?_
    have hterm : вИА r вИИ Finset.range q,
        вАЦe ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q rвАЦ
        = if Nat.gcd r q = 1 then 1 / (q.totient : вДЭ) else 0 := by
      intro r _
      rw [norm_mul, e_norm, one_mul, lambdaModel]
      by_cases h : Nat.gcd r q = 1
      ¬Ј rw [if_pos h, if_pos h,
          show (1 / (q.totient : вДВ)) = (((1 / (q.totient : вДЭ)) : вДЭ) : вДВ) from by
            push_cast; ring,
          Complex.norm_real, Real.norm_eq_abs, abs_of_pos (by positivity)]
      ¬Ј rw [if_neg h, if_neg h, norm_zero]
    rw [Finset.sum_congr rfl hterm, вЖР Finset.sum_filter, Finset.sum_const,
      nsmul_eq_mul]
    have hcard : (((Finset.range q).filter (fun r => Nat.gcd r q = 1)).card : вДЭ)
        = (q.totient : вДЭ) := by
      have h1 : ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).card
          = q.totient := by
        rw [Nat.totient]
        congr 1
        apply Finset.filter_congr
        intro r _
        simp [Nat.Coprime, Nat.gcd_comm]
      exact_mod_cast h1
    rw [hcard, mul_one_div, div_self hѕЖ0.ne']
  have hT : вАЦвИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ вЙ§ (N:вДЭ) := by
    refine (norm_sum_le _ _).trans (le_of_eq ?_)
    calc вИС n вИИ Finset.range N, вАЦe ((n : вДЭ) * ќ≤)вАЦ
        = вИС _n вИИ Finset.range N, (1:вДЭ) := by
          apply Finset.sum_congr rfl
          intro n _
          exact e_norm _
      _ = (N:вДЭ) := by
          rw [Finset.sum_const, nsmul_eq_mul, mul_one, Finset.card_range]
  have hB' : вАЦ(вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
      * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ вЙ§ (N:вДЭ) := by
    rw [norm_mul]
    calc вАЦвИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q rвАЦ
        * вАЦвИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
        вЙ§ 1 * (N:вДЭ) := mul_le_mul hW hT (norm_nonneg _) (by norm_num)
      _ = (N:вДЭ) := one_mul _
  -- A¬≤ вИТ B¬≤ = (AвИТB)(A+B)
  rw [show (вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
        * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))) ^ 2
      - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)) ^ 2
      = ((вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
            * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
          - (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
            * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤))
        * ((вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
            * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
          + (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
            * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)) from by ring,
    norm_mul]
  have hsum : вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
        * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
      + (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
        * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ (N:вДЭ) * (Real.log N + 1) := by
    calc вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
        + (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
        вЙ§ вАЦвИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
            * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))вАЦ
          + вАЦ(вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
              * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ := norm_add_le _ _
      _ вЙ§ (N:вДЭ) * Real.log N + (N:вДЭ) := by linarith [hS, hB']
      _ = (N:вДЭ) * (Real.log N + 1) := by ring
  have hEpos : (0:вДЭ) вЙ§ Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
      * (1 + 2 * Real.pi * N * |ќ≤|) := by
    have h1 : (0:вДЭ) вЙ§ 1 + 2 * Real.pi * N * |ќ≤| := by positivity
    positivity
  calc вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
        * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
      - (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
        * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      * вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
        + (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ (C * q * N * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))
          * (1 + 2 * Real.pi * N * |ќ≤|))
