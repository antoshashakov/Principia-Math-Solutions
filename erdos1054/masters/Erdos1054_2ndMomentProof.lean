open scoped Classical in
open ArithmeticFunction in
/-- **W3b-i: per-prime power-mass bound** вАФ for a prime `p` and `X вЙ• 2`, the von Mangoldt mass on
    powers of `p` up to `X` is at most `(log X / log 2 + 1)¬Јlog p`: there are at most
    `log X / log 2 + 1` exponents `k вЙ• 1` with `p^k вЙ§ X`, each contributing `ќЫ(p^k) = log p`. -/
lemma vonMangoldt_prime_powers_le (p : вДХ) (hp : p.Prime) (X : вДХ) (hX : 2 вЙ§ X) :
    вИС n вИИ (Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n),
      vonMangoldt n
    вЙ§ (Real.log X / Real.log 2 + 1) * Real.log p := by
  have hp2 : 2 вЙ§ p := hp.two_le
  have hlog2 : (0:вДЭ) < Real.log 2 := Real.log_pos (by norm_num)
  have hlogX : (0:вДЭ) вЙ§ Real.log X := Real.log_nonneg (by exact_mod_cast (by omega : 1 вЙ§ X))
  have hlogp : (0:вДЭ) вЙ§ Real.log p := Real.log_nonneg (by exact_mod_cast hp.one_lt.le)
  set K : вДХ := вМКReal.log X / Real.log 2вМЛвВК with hKdef
  -- the filter is the image of the exponents k вИИ Icc 1 K under k вЖ¶ p^k
  have hsub : (Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n)
      вКЖ (Finset.Icc 1 K).image (fun k => p ^ k) := by
    intro n hn
    rw [Finset.mem_filter, Finset.mem_range] at hn
    obtain вЯ®hnX, k, hk1, hknвЯ© := hn
    rw [Finset.mem_image]
    refine вЯ®k, ?_, hknвЯ©
    rw [Finset.mem_Icc]
    refine вЯ®hk1, ?_вЯ©
    -- p^k вЙ§ X вЗТ 2^k вЙ§ X вЗТ k¬Јlog2 вЙ§ logX вЗТ k вЙ§ K
    have h1 : p ^ k вЙ§ X := by omega
    have h2 : 2 ^ k вЙ§ X := le_trans (Nat.pow_le_pow_left hp2 k) h1
    have h3 : (k:вДЭ) * Real.log 2 вЙ§ Real.log X := by
      have h4 : ((2:вДХ):вДЭ) ^ k вЙ§ (X:вДЭ) := by exact_mod_cast h2
      have h5 := Real.log_le_log (by positivity) h4
      rwa [Real.log_pow, Nat.cast_ofNat] at h5
    apply Nat.le_floor
    rw [le_div_iffвВА hlog2]
    exact h3
  have hnonneg : вИА n вИИ (Finset.Icc 1 K).image (fun k => p ^ k), 0 вЙ§ vonMangoldt n :=
    fun n _ => vonMangoldt_nonneg
  calc вИС n вИИ (Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n), vonMangoldt n
      вЙ§ вИС n вИИ (Finset.Icc 1 K).image (fun k => p ^ k), vonMangoldt n :=
        Finset.sum_le_sum_of_subset_of_nonneg hsub (fun n hn _ => vonMangoldt_nonneg)
    _ = вИС k вИИ Finset.Icc 1 K, vonMangoldt (p ^ k) := by
        rw [Finset.sum_image]
        intro a _ b _ hab
        exact Nat.pow_right_injective hp2 hab
    _ = вИС k вИИ Finset.Icc 1 K, Real.log p := by
        apply Finset.sum_congr rfl
        intro k hk
        rw [Finset.mem_Icc] at hk
        rw [ArithmeticFunction.vonMangoldt_apply_pow (by omega : k вЙ† 0),
          ArithmeticFunction.vonMangoldt_apply_prime hp]
    _ = (K : вДЭ) * Real.log p := by
        rw [Finset.sum_const, Nat.card_Icc]
        simp [nsmul_eq_mul]
    _ вЙ§ (Real.log X / Real.log 2 + 1) * Real.log p := by
        apply mul_le_mul_of_nonneg_right _ hlogp
        have := Nat.floor_le (by positivity : (0:вДЭ) вЙ§ Real.log X / Real.log 2)
        rw [hKdef]
        linarith

open scoped Classical in
open ArithmeticFunction in
/-- **W3b-ii: the non-unit von Mangoldt mass is polylog** вАФ for `q вЙ• 1`, `X вЙ• 2`:
    `вИС_{nвЙ§X, ¬ђIsUnit(n mod q)} ќЫ(n) вЙ§ (log X/log 2 + 1)¬Јlog q`. Prime-power support: each
    contributing `n = p^k` has `p вИ£ q`; per-prime mass вЙ§ `(logX/log2+1)¬Јlog p` (W3b-i);
    `вИС_{pвИ£q} log p = log вИП p вЙ§ log q`. -/
lemma vonMangoldt_nonunit_sum_le (q : вДХ) [NeZero q] (X : вДХ) (hX : 2 вЙ§ X) :
    вИС n вИИ (Finset.range (X+1)).filter (fun n => ¬ђ IsUnit ((n : вДХ) : ZMod q)), vonMangoldt n
    вЙ§ (Real.log X / Real.log 2 + 1) * Real.log q := by
  have hq0 : q вЙ† 0 := NeZero.ne q
  have hlog2 : (0:вДЭ) < Real.log 2 := Real.log_pos (by norm_num)
  have hlogX : (0:вДЭ) вЙ§ Real.log X := Real.log_nonneg (by exact_mod_cast (by omega : 1 вЙ§ X))
  have hcoef : (0:вДЭ) вЙ§ Real.log X / Real.log 2 + 1 := by positivity
  -- drop the ќЫ = 0 terms
  rw [вЖР Finset.sum_filter_ne_zero]
  -- the surviving support embeds in the union of p-power filters, p вИИ q.primeFactors
  set T := ((Finset.range (X+1)).filter (fun n => ¬ђ IsUnit ((n : вДХ) : ZMod q))).filter
    (fun n => vonMangoldt n вЙ† 0) with hTdef
  have hsub : T вКЖ q.primeFactors.biUnion
      (fun p => (Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n)) := by
    intro n hn
    rw [hTdef, Finset.mem_filter, Finset.mem_filter, Finset.mem_range] at hn
    obtain вЯ®вЯ®hnX, hnuвЯ©, hќЫвЯ© := hn
    have hpp : IsPrimePow n := ArithmeticFunction.vonMangoldt_ne_zero_iff.mp hќЫ
    obtain вЯ®p, k, hp, hk, hpkвЯ© := hpp
    have hpN : p.Prime := Nat.prime_iff.mpr hp
    -- ¬ђIsUnit(p^k mod q) вЗТ ¬ђcoprime p q вЗТ p вИ£ q
    have hpq : p вИ£ q := by
      by_contra hnd
      apply hnu
      rw [ZMod.isUnit_iff_coprime]
      have h1 : Nat.Coprime p q := (Nat.Prime.coprime_iff_not_dvd hpN).mpr hnd
      have h2 : Nat.Coprime n q := by
        rw [вЖР hpk]
        exact Nat.Coprime.pow_left k h1
      exact h2
    rw [Finset.mem_biUnion]
    refine вЯ®p, ?_, ?_вЯ©
    ¬Ј rw [Nat.mem_primeFactors]
      exact вЯ®hpN, hpq, hq0вЯ©
    ¬Ј rw [Finset.mem_filter, Finset.mem_range]
      exact вЯ®hnX, k, hk, hpkвЯ©
  -- distinct primes give disjoint power filters
  have hdisj : вИА p вИИ q.primeFactors, вИА p' вИИ q.primeFactors, p вЙ† p' вЖТ
      Disjoint ((Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n))
        ((Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p' ^ k = n)) := by
    intro p hp p' hp' hne
    rw [Finset.disjoint_left]
    intro n hn hn'
    rw [Finset.mem_filter] at hn hn'
    obtain вЯ®-, k, hk1, hknвЯ© := hn
    obtain вЯ®-, k', hk1', hkn'вЯ© := hn'
    have hpN : p.Prime := (Nat.mem_primeFactors.mp hp).1
    have hpN' : p'.Prime := (Nat.mem_primeFactors.mp hp').1
    apply hne
    have h1 : p вИ£ p' ^ k' := by
      rw [hkn', вЖР hkn]
      exact dvd_pow_self p (by omega)
    have h2 : p вИ£ p' := hpN.dvd_of_dvd_pow h1
    exact (Nat.prime_dvd_prime_iff_eq hpN hpN').mp h2
  calc вИС n вИИ T, vonMangoldt n
      вЙ§ вИС n вИИ q.primeFactors.biUnion
          (fun p => (Finset.range (X+1)).filter (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n)),
          vonMangoldt n := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsub
        intro n _ _
        exact vonMangoldt_nonneg
    _ = вИС p вИИ q.primeFactors, вИС n вИИ (Finset.range (X+1)).filter
          (fun n => вИГ k, 1 вЙ§ k вИІ p ^ k = n), vonMangoldt n :=
        Finset.sum_biUnion hdisj
    _ вЙ§ вИС p вИИ q.primeFactors, (Real.log X / Real.log 2 + 1) * Real.log p := by
        apply Finset.sum_le_sum
        intro p hp
        exact vonMangoldt_prime_powers_le p (Nat.mem_primeFactors.mp hp).1 X hX
    _ = (Real.log X / Real.log 2 + 1) * вИС p вИИ q.primeFactors, Real.log p := by
        rw [Finset.mul_sum]
    _ вЙ§ (Real.log X / Real.log 2 + 1) * Real.log q := by
        apply mul_le_mul_of_nonneg_left _ hcoef
        have h1 : вИС p вИИ q.primeFactors, Real.log p
            = Real.log (вИП p вИИ q.primeFactors, (p:вДЭ)) := by
          rw [Real.log_prod]
          intro p hp
          exact_mod_cast (Nat.mem_primeFactors.mp hp).1.pos.ne'
        rw [h1]
        have h2 : (вИП p вИИ q.primeFactors, p) вИ£ q := Nat.prod_primeFactors_dvd q
        have h5 : 0 < вИП p вИИ q.primeFactors, p :=
          Finset.prod_pos (fun p hp => (Nat.mem_primeFactors.mp hp).1.pos)
        have h3 : (вИП p вИИ q.primeFactors, p) вЙ§ q := Nat.le_of_dvd (Nat.pos_of_ne_zero hq0) h2
        have h4 : (вИП p вИИ q.primeFactors, (p:вДЭ)) = ((вИП p вИИ q.primeFactors, p : вДХ) : вДЭ) := by
          push_cast
          rfl
        rw [h4]
        apply Real.log_le_log
        ¬Ј exact_mod_cast h5
        ¬Ј exact_mod_cast h3



open scoped Classical in
open ArithmeticFunction in
/-- **W3c: the unit-restricted ѕИ obeys PNT with a polylog correction** вАФ for every modulus
    `q вЙ• 1` and `X вЙ• 2`:
    `|вИС_{nвЙ§X, IsUnit(n mod q)} ќЫ(n) вИТ X| вЙ§ C¬ЈX¬Јexp(вИТc(log X)^{1/10}) + (logX/log2+1)¬Јlog q`.
    Split `ѕИ = unit-part + nonunit-part`; `medium_PNT` for the first, W3b-ii for the second.
    This is `ѕИ(X,ѕЗвВА)` (`MulChar.one_apply` gives the indicator), the ѕЗвВА input to the W5 wiring. -/
theorem psi_unit_sum_bound : вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ
    вИА (q : вДХ) [NeZero q], вИА X : вДЭ, 2 вЙ§ X вЖТ
    |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0) - X|
      вЙ§ C * X * Real.exp (-c * Real.log X ^ ((1:вДЭ)/10))
        + (Real.log X / Real.log 2 + 1) * Real.log q := by
  obtain вЯ®c, C, hc, hC, hpntвЯ© := medium_PNT
  refine вЯ®c, C, hc, hC, ?_вЯ©
  intro q _ X hX
  have hX0 : (0:вДЭ) < X := by linarith
  have hXn : 2 вЙ§ вМКXвМЛвВК := Nat.le_floor (by exact_mod_cast hX)
  have hfloor0 : (0:вДЭ) < (вМКXвМЛвВК : вДЭ) := by exact_mod_cast (by omega : 0 < вМКXвМЛвВК)
  have hfloorle : ((вМКXвМЛвВК : вДХ) : вДЭ) вЙ§ X := Nat.floor_le hX0.le
  have hlog2 : (0:вДЭ) < Real.log 2 := Real.log_pos (by norm_num)
  have hlogq : (0:вДЭ) вЙ§ Real.log q := by
    apply Real.log_nonneg
    have : 1 вЙ§ q := Nat.one_le_iff_ne_zero.mpr (NeZero.ne q)
    exact_mod_cast this
  -- ѕИ = unit + nonunit
  have hsplit : (вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n)
      = (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0)
        + вИС n вИИ (Finset.range (вМКXвМЛвВК + 1)).filter (fun n => ¬ђ IsUnit ((n : вДХ) : ZMod q)),
            vonMangoldt n := by
    rw [Finset.sum_filter, вЖР Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro n _
    by_cases h : IsUnit ((n : вДХ) : ZMod q) <;> simp [h]
  set U := вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
    if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0 with hUdef
  set V := вИС n вИИ (Finset.range (вМКXвМЛвВК + 1)).filter (fun n => ¬ђ IsUnit ((n : вДХ) : ZMod q)),
    vonMangoldt n with hVdef
  have hV0 : 0 вЙ§ V := Finset.sum_nonneg (fun n _ => vonMangoldt_nonneg)
  -- V вЙ§ (logвМКXвМЛ/log2 + 1)¬Јlog q вЙ§ (logX/log2 + 1)¬Јlog q
  have hVle : V вЙ§ (Real.log X / Real.log 2 + 1) * Real.log q := by
    have h1 := vonMangoldt_nonunit_sum_le q (X := вМКXвМЛвВК) hXn
    have h2 : Real.log (вМКXвМЛвВК : вДЭ) вЙ§ Real.log X := Real.log_le_log hfloor0 hfloorle
    have h3 : (Real.log (вМКXвМЛвВК : вДЭ) / Real.log 2 + 1) * Real.log q
        вЙ§ (Real.log X / Real.log 2 + 1) * Real.log q := by
      apply mul_le_mul_of_nonneg_right _ hlogq
      have := div_le_div_of_nonneg_right h2 hlog2.le
      linarith
    exact le_trans h1 h3
  have hpntX := hpnt X hX
  -- |U вИТ X| = |(ѕИ вИТ X) вИТ V| вЙ§ |ѕИ вИТ X| + V
  have habs : |U - X| вЙ§ |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X| + V := by
    have h4 : U - X = ((вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X) - V := by
      rw [hsplit]
      ring
    rw [h4]
    calc |((вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X) - V|
        вЙ§ |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X| + |V| := abs_sub _ _
      _ = |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X| + V := by
          rw [abs_of_nonneg hV0]
  calc |U - X| вЙ§ |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1), vonMangoldt n) - X| + V := habs
    _ вЙ§ C * X * Real.exp (-c * Real.log X ^ ((1:вДЭ)/10))
        + (Real.log X / Real.log 2 + 1) * Real.log q := add_le_add hpntX hVle

open ArithmeticFunction in
/-- **W4a: the two-scale identity** вАФ for `0 < X вЙ§ Y`:
    `Y¬ЈS(Y) вИТ X¬ЈS(X) = (YвИТX)¬ЈѕИ_c(X) + вИС_{вМКXвМЛ<nвЙ§вМКYвМЛ} ѕЗќЫ(n)(YвИТn)`, where `S` is the smoothed sum
    and `ѕИ_c` the sharp one. Pure algebra: `Y(1вИТn/Y) = YвИТn`, split `range(вМКYвМЛ+1)` at `вМКXвМЛ+1`. -/
lemma two_scale_identity {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X Y : вДЭ)
    (hX : 0 < X) (hXY : X вЙ§ Y) :
    ((Y:вДЭ) : вДВ) * (вИС n вИИ Finset.range (вМКYвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / Y))
      - ((X:вДЭ) : вДВ) * (вИС n вИИ Finset.range (вМКXвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X))
    = (((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * (вИС n вИИ Finset.range (вМКXвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
      + вИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)) := by
  have hY0 : (0:вДЭ) < Y := lt_of_lt_of_le hX hXY
  have hXC : ((X:вДЭ) : вДВ) вЙ† 0 := Complex.ofReal_ne_zero.mpr hX.ne'
  have hYC : ((Y:вДЭ) : вДВ) вЙ† 0 := Complex.ofReal_ne_zero.mpr hY0.ne'
  have hfloor : вМКXвМЛвВК + 1 вЙ§ вМКYвМЛвВК + 1 := by
    have := Nat.floor_le_floor hXY
    omega
  -- per-term unsmoothing
  have hterm : вИА (Z : вДЭ) (hZ : ((Z:вДЭ) : вДВ) вЙ† 0) (n : вДХ),
      ((Z:вДЭ) : вДВ) * (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / Z))
      = ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Z:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)) := by
    intro Z hZ n
    have h1 : ((Z:вДЭ) : вДВ) * (1 - ((n:вДЭ) : вДВ) / ((Z:вДЭ) : вДВ)) = ((Z:вДЭ) : вДВ) - ((n:вДЭ) : вДВ) := by
      field_simp
    calc ((Z:вДЭ) : вДВ) * (ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / Z))
        = ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)
            * (((Z:вДЭ) : вДВ) * (1 - ((n:вДЭ) : вДВ) / ((Z:вДЭ) : вДВ))) := by
          push_cast
          ring
      _ = ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Z:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)) := by
          rw [h1]
  -- unsmooth both scales
  rw [Finset.mul_sum, Finset.mul_sum]
  simp_rw [hterm Y hYC, hterm X hXC]
  -- split the Y-range at вМКXвМЛ+1
  have hsplit : вИС n вИИ Finset.range (вМКYвМЛвВК+1),
      ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ))
      = (вИС n вИИ Finset.range (вМКXвМЛвВК+1),
          ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)))
        + вИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
          ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)) := by
    rw [Finset.range_eq_Ico, Finset.range_eq_Ico,
      вЖР Finset.sum_Ico_consecutive _ (Nat.zero_le _) hfloor]
  rw [hsplit]
  have hAC : (вИС n вИИ Finset.range (вМКXвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)))
      - (вИС n вИИ Finset.range (вМКXвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((X:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)))
      = (((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * вИС n вИИ Finset.range (вМКXвМЛвВК+1),
          ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) := by
    rw [вЖР Finset.sum_sub_distrib, Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro n _
    ring
  linear_combination hAC

open ArithmeticFunction in
/-- **W4b: the boundary window is small** вАФ for `2 вЙ§ X вЙ§ Y`:
    `вАЦвИС_{вМКXвМЛ<nвЙ§вМКYвМЛ} ѕЗќЫ(n)(YвИТn)вАЦ вЙ§ (YвИТX+1)¬Ј((YвИТX)¬Јlog Y)`: each of the вЙ§ `YвИТX+1` terms has
    `ќЫ(n) вЙ§ log n вЙ§ log Y` and `0 вЙ§ YвИТn вЙ§ YвИТX`. -/
lemma boundary_sum_bound {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X Y : вДЭ)
    (hX : 2 вЙ§ X) (hXY : X вЙ§ Y) :
    вАЦвИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ))вАЦ
      вЙ§ (Y - X + 1) * ((Y - X) * Real.log Y) := by
  have hY2 : (2:вДЭ) вЙ§ Y := le_trans hX hXY
  have hYX0 : (0:вДЭ) вЙ§ Y - X := by linarith
  have hlogY : (0:вДЭ) вЙ§ Real.log Y := Real.log_nonneg (by linarith)
  have hfloorle : вМКXвМЛвВК вЙ§ вМКYвМЛвВК := Nat.floor_le_floor hXY
  -- per-term bound
  have hterm : вИА n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
      вАЦѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ))вАЦ
        вЙ§ (Y - X) * Real.log Y := by
    intro n hn
    rw [Finset.mem_Ico] at hn
    have hnX : X < (n:вДЭ) := by
      have h1 : X < (вМКXвМЛвВК : вДЭ) + 1 := Nat.lt_floor_add_one X
      have h2 : ((вМКXвМЛвВК + 1 : вДХ) : вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn.1
      push_cast at h2
      linarith
    have hnY : (n:вДЭ) вЙ§ Y := by
      have h1 : n вЙ§ вМКYвМЛвВК := by omega
      have h2 : ((n:вДХ):вДЭ) вЙ§ (вМКYвМЛвВК : вДЭ) := by exact_mod_cast h1
      have h3 : (вМКYвМЛвВК : вДЭ) вЙ§ Y := Nat.floor_le (by linarith)
      linarith
    have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by linarith
    rw [norm_mul, norm_mul]
    have h4 : вАЦ((vonMangoldt n : вДЭ) : вДВ)вАЦ вЙ§ Real.log Y := by
      rw [Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg vonMangoldt_nonneg]
      calc vonMangoldt n вЙ§ Real.log n := vonMangoldt_le_log
        _ вЙ§ Real.log Y := Real.log_le_log (by linarith) hnY
    have h5 : вАЦ((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)вАЦ вЙ§ Y - X := by
      rw [вЖР Complex.ofReal_sub, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (by linarith)]
      linarith
    calc вАЦѕЗ (n : ZMod N)вАЦ * вАЦ((vonMangoldt n : вДЭ) : вДВ)вАЦ * вАЦ((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)вАЦ
        вЙ§ 1 * Real.log Y * (Y - X) := by
          apply mul_le_mul _ h5 (norm_nonneg _) (by positivity)
          apply mul_le_mul (DirichletCharacter.norm_le_one ѕЗ _) h4 (norm_nonneg _) zero_le_one
      _ = (Y - X) * Real.log Y := by ring
  -- count bound
  have hcard : ((Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1)).card : вДЭ) вЙ§ Y - X + 1 := by
    rw [Nat.card_Ico]
    have h1 : (вМКYвМЛвВК + 1) - (вМКXвМЛвВК + 1) = вМКYвМЛвВК - вМКXвМЛвВК := by omega
    rw [h1, Nat.cast_sub hfloorle]
    have h2 : (вМКYвМЛвВК : вДЭ) вЙ§ Y := Nat.floor_le (by linarith)
    have h3 : X - 1 вЙ§ (вМКXвМЛвВК : вДЭ) := by
      have := Nat.lt_floor_add_one X
      linarith
    linarith
  calc вАЦвИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ))вАЦ
      вЙ§ вИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
          вАЦѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ))вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС _n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1), (Y - X) * Real.log Y :=
        Finset.sum_le_sum hterm
    _ = ((Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1)).card : вДЭ) * ((Y - X) * Real.log Y) := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ вЙ§ (Y - X + 1) * ((Y - X) * Real.log Y) := by
        apply mul_le_mul_of_nonneg_right hcard (by positivity)

/-- **W4c-i: solve the two-scale identity for the sharp sum** вАФ from
    `Y¬ЈSY вИТ X¬ЈSX = (YвИТX)¬ЈѕИc + R` with `X < Y` and norm bounds, conclude
    `вАЦѕИcвАЦ вЙ§ (Y¬ЈBY + X¬ЈBX + Bnd)/(YвИТX)`. -/
lemma sharp_recovery_norm (ѕИc SY SX R : вДВ) (X Y BY BX Bnd : вДЭ)
    (hX : 0 < X) (hXY : X < Y)
    (hid : ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SX = (((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * ѕИc + R)
    (hSY : вАЦSYвАЦ вЙ§ BY) (hSX : вАЦSXвАЦ вЙ§ BX) (hR : вАЦRвАЦ вЙ§ Bnd) :
    вАЦѕИcвАЦ вЙ§ (Y * BY + X * BX + Bnd) / (Y - X) := by
  have hYX0 : (0:вДЭ) < Y - X := by linarith
  have h1 : (((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * ѕИc = ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SX - R := by
    rw [hid]
    ring
  have h2 : вАЦ(((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * ѕИcвАЦ = (Y - X) * вАЦѕИcвАЦ := by
    rw [norm_mul, вЖР Complex.ofReal_sub, Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos hYX0]
  have h3 : вАЦ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SX - RвАЦ вЙ§ Y * BY + X * BX + Bnd := by
    have hnY : вАЦ((Y:вДЭ) : вДВ) * SYвАЦ вЙ§ Y * BY := by
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, abs_of_pos (by linarith)]
      exact mul_le_mul_of_nonneg_left hSY (by linarith)
    have hnX : вАЦ((X:вДЭ) : вДВ) * SXвАЦ вЙ§ X * BX := by
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, abs_of_pos hX]
      exact mul_le_mul_of_nonneg_left hSX hX.le
    calc вАЦ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SX - RвАЦ
        вЙ§ вАЦ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SXвАЦ + вАЦRвАЦ := norm_sub_le _ _
      _ вЙ§ (вАЦ((Y:вДЭ) : вДВ) * SYвАЦ + вАЦ((X:вДЭ) : вДВ) * SXвАЦ) + вАЦRвАЦ :=
          add_le_add (norm_sub_le _ _) le_rfl
      _ вЙ§ Y * BY + X * BX + Bnd := by
          have := add_le_add (add_le_add hnY hnX) hR
          linarith
  rw [le_div_iffвВА hYX0]
  calc вАЦѕИcвАЦ * (Y - X) = (Y - X) * вАЦѕИcвАЦ := by ring
    _ = вАЦ(((Y:вДЭ) : вДВ) - ((X:вДЭ) : вДВ)) * ѕИcвАЦ := h2.symm
    _ = вАЦ((Y:вДЭ) : вДВ) * SY - ((X:вДЭ) : вДВ) * SX - RвАЦ := by rw [h1]
    _ вЙ§ Y * BY + X * BX + Bnd := h3

/-- **W4c-ii: polynomial absorption at linear exponent** вАФ `u^m¬Јe^{вИТa¬Јu} вЙ§ e^{вИТ(a/2)¬Јu}` for
    `u вЙ• max 1 (4m/a)¬≤` (`m¬Јlog u вЙ§ 2m¬ЈвИЪu вЙ§ (a/2)¬Јu`). -/
lemma rpow_exp_absorb (a m : вДЭ) (ha : 0 < a) (hm : 0 вЙ§ m) :
    вИА u : вДЭ, max 1 ((4*m/a)^2) вЙ§ u вЖТ
    u ^ (m : вДЭ) * Real.exp (-(a * u)) вЙ§ Real.exp (-((a/2) * u)) := by
  intro u hu
  have hu1 : (1:вДЭ) вЙ§ u := le_trans (le_max_left _ _) hu
  have hu0 : (0:вДЭ) < u := by linarith
  have hum : (4*m/a)^2 вЙ§ u := le_trans (le_max_right _ _) hu
  have hsq : 4*m/a вЙ§ u ^ ((1:вДЭ)/2) := by
    have h1 : ((4*m/a)^2) ^ ((1:вДЭ)/2) вЙ§ u ^ ((1:вДЭ)/2) :=
      Real.rpow_le_rpow (by positivity) hum (by norm_num)
    rwa [show ((4*m/a):вДЭ)^2 = (4*m/a) * (4*m/a) by ring, вЖР Real.sqrt_eq_rpow,
      Real.sqrt_mul_self (by positivity)] at h1
  have hss : u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) = u := by
    rw [вЖР Real.rpow_add hu0]
    norm_num
  have hs0 : (0:вДЭ) вЙ§ u ^ ((1:вДЭ)/2) := Real.rpow_nonneg hu0.le _
  -- log(u^m) = m¬Јlog u вЙ§ 2m¬ЈвИЪu вЙ§ (a/2)¬Јu
  have hlog : Real.log (u ^ (m:вДЭ)) вЙ§ (a/2) * u := by
    rw [Real.log_rpow hu0]
    have h2 : Real.log u вЙ§ 2 * u ^ ((1:вДЭ)/2) := by
      have := Real.log_le_rpow_div hu0.le (by norm_num : (0:вДЭ) < 1/2)
      calc Real.log u вЙ§ u ^ ((1:вДЭ)/2) / (1/2) := this
        _ = 2 * u ^ ((1:вДЭ)/2) := by ring
    have h3 : m * Real.log u вЙ§ 2*m * u ^ ((1:вДЭ)/2) := by nlinarith [Real.log_nonneg hu1]
    have h4 : 2*m * u ^ ((1:вДЭ)/2) вЙ§ (a/2) * u := by
      have h5 : (4*m/a) * u ^ ((1:вДЭ)/2) вЙ§ u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) :=
        mul_le_mul_of_nonneg_right hsq hs0
      rw [hss] at h5
      have h6 : a * ((4*m/a) * u ^ ((1:вДЭ)/2)) = 4*m*u ^ ((1:вДЭ)/2) := by
        field_simp
      nlinarith [h5, ha]
    linarith
  have h7 : u ^ (m:вДЭ) вЙ§ Real.exp ((a/2) * u) :=
    (Real.log_le_iff_le_exp (Real.rpow_pos_of_pos hu0 _)).mp hlog
  calc u ^ (m:вДЭ) * Real.exp (-(a * u))
      вЙ§ Real.exp ((a/2) * u) * Real.exp (-(a * u)) :=
        mul_le_mul_of_nonneg_right h7 (Real.exp_pos _).le
    _ = Real.exp (-((a/2) * u)) := by
        rw [вЖР Real.exp_add]
        ring_nf

/-- **W4c-pre: the ќі-choice facts** вАФ with `ќі = e^{вИТ(a/2)u}` and `u вЙ• max 2 (80/a)¬≤`:
    (i) `e^{вИТau}/ќі = ќі`; (ii) `u^{10}¬Јќі вЙ§ e^{вИТ(a/4)u}`; (iii) `2u^{10} вЙ§ e^{u^{10}}¬Јe^{вИТ(a/4)u}`
    (the standalone-polylog absorption into `X = e^{u^{10}}`). -/
lemma delta_facts (a : вДЭ) (ha : 0 < a) (ha1 : a вЙ§ 1) :
    вИА u : вДЭ, max 2 ((80/a)^2) вЙ§ u вЖТ
    Real.exp (-(a * u)) / Real.exp (-((a/2) * u)) = Real.exp (-((a/2) * u)) вИІ
    u ^ (10:вДЭ) * Real.exp (-((a/2) * u)) вЙ§ Real.exp (-((a/4) * u)) вИІ
    2 * u ^ (10:вДЭ) вЙ§ Real.exp (u ^ (10:вДЭ)) * Real.exp (-((a/4) * u)) := by
  intro u hu
  have hu2 : (2:вДЭ) вЙ§ u := le_trans (le_max_left _ _) hu
  have hu1 : (1:вДЭ) вЙ§ u := by linarith
  have hu0 : (0:вДЭ) < u := by linarith
  refine вЯ®?_, ?_, ?_вЯ©
  ¬Ј -- (i) exp division
    rw [вЖР Real.exp_sub]
    congr 1
    ring
  ¬Ј -- (ii) via rpow_exp_absorb at a' := a/2
    have h1 := rpow_exp_absorb (a/2) 10 (by linarith) (by norm_num) u ?_
    ¬Ј have h2 : (a/2)/2 = a/4 := by ring
      rw [h2] at h1
      exact h1
    ¬Ј apply max_le
      ¬Ј linarith
      ¬Ј have h3 : (4*10/(a/2)) = 80/a := by
          field_simp
          ring
        rw [h3]
        exact le_trans (le_max_right _ _) hu
  ¬Ј -- (iii) log route: log 2 + 10¬Јlog u вЙ§ u^{10} вИТ (a/4)u
    have hu10pos : (0:вДЭ) < u ^ (10:вДЭ) := Real.rpow_pos_of_pos hu0 _
    have hlog : Real.log (2 * u ^ (10:вДЭ)) вЙ§ u ^ (10:вДЭ) - (a/4) * u := by
      rw [Real.log_mul (by norm_num) hu10pos.ne', Real.log_rpow hu0]
      have h4 : Real.log 2 вЙ§ 1 := by
        have := Real.log_two_lt_d9
        linarith
      have h5 : Real.log u вЙ§ 2 * u ^ ((1:вДЭ)/2) := by
        have := Real.log_le_rpow_div hu0.le (by norm_num : (0:вДЭ) < 1/2)
        calc Real.log u вЙ§ u ^ ((1:вДЭ)/2) / (1/2) := this
          _ = 2 * u ^ ((1:вДЭ)/2) := by ring
      have h6 : u ^ ((1:вДЭ)/2) вЙ§ u := by
        calc u ^ ((1:вДЭ)/2) вЙ§ u ^ (1:вДЭ) :=
              Real.rpow_le_rpow_of_exponent_le hu1 (by norm_num)
          _ = u := Real.rpow_one u
      have h7 : u ^ (9:вДЭ) вЙ• 512 := by
        calc (512:вДЭ) = 2 ^ (9:вДЭ) := by
              rw [show (9:вДЭ) = ((9:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
              norm_num
          _ вЙ§ u ^ (9:вДЭ) := Real.rpow_le_rpow (by norm_num) hu2 (by norm_num)
      have h8 : u ^ (10:вДЭ) = u ^ (9:вДЭ) * u := by
        rw [show (10:вДЭ) = 9 + 1 by norm_num, Real.rpow_add hu0, Real.rpow_one]
      have h9 : (a/4) * u вЙ§ u := by nlinarith
      have h56 : Real.log u вЙ§ 2*u := by nlinarith [h5, h6, Real.log_nonneg hu1]
      have hkey : u ^ (9:вДЭ) * u вЙ• 512 * u := by nlinarith [h7, hu0]
      have hA : u ^ (10:вДЭ) вЙ• 512 * u := by
        rw [h8]
        linarith
      have hC : Real.log 2 + 10 * Real.log u вЙ§ 1 + 20 * u := by linarith [h4, h56]
      calc Real.log 2 + 10 * Real.log u вЙ§ 1 + 20 * u := hC
        _ вЙ§ 511 * u := by linarith
        _ = 512 * u - u := by ring
        _ вЙ§ u ^ (10:вДЭ) - u := sub_le_sub_right hA u
        _ вЙ§ u ^ (10:вДЭ) - (a/4) * u := sub_le_sub_left h9 _
    have h10 : (0:вДЭ) < 2 * u ^ (10:вДЭ) := by positivity
    have h11 := (Real.log_le_iff_le_exp h10).mp hlog
    calc 2 * u ^ (10:вДЭ) вЙ§ Real.exp (u ^ (10:вДЭ) - (a/4) * u) := h11
      _ = Real.exp (u ^ (10:вДЭ)) * Real.exp (-((a/4) * u)) := by
          rw [вЖР Real.exp_add]
          ring_nf


open ArithmeticFunction in
/-- **W4c-MAIN: THE SHARP ѕЗвЙ†1 SIEGELвАУWALFISZ BOUND** вАФ for every `B вЙ• 1` there are
    `cвВЕ, CвВЕ, XвВА > 0` with: for all `X вЙ• XвВА`, `q вЙ§ (log X)^B`, `ѕЗ вЙ† 1 mod q`:
    `вАЦѕИ(X,ѕЗ)вАЦ = вАЦвИС_{nвЙ§X} ѕЗ(n)ќЫ(n)вАЦ вЙ§ CвВЕ¬ЈX¬Јexp(вИТcвВЕ(log X)^{1/10})`. Two-scale recovery at
    `Y = X(1+ќі)`, `ќі = e^{вИТ(cвВВ'/2)(log X)^{1/10}}`, from the smoothed bound at both scales. -/
theorem psi_sharp_SW_rate (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ cвВЕ CвВЕ XвВА : вДЭ, 0 < cвВЕ вИІ 0 < CвВЕ вИІ вИА X : вДЭ, XвВА вЙ§ X вЖТ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    (N:вДЭ) вЙ§ Real.log X ^ (B : вДЭ) вЖТ
    вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1), ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)вАЦ
      вЙ§ CвВЕ * X * Real.exp (-(cвВЕ * Real.log X ^ ((1:вДЭ)/10))) := by
  obtain вЯ®cвВВ, CвВВ, XвВА', hcвВВ0, hCвВВ0, hrateвЯ© := psi_smooth_SW_rate B hB
  set a := min cвВВ 1 with hadef
  have ha0 : 0 < a := lt_min hcвВВ0 one_pos
  have ha1 : a вЙ§ 1 := min_le_right _ _
  have hacвВВ : a вЙ§ cвВВ := min_le_left _ _
  set M := max 2 ((80/a)^2) with hMdef
  have hM2 : (2:вДЭ) вЙ§ M := le_max_left _ _
  have hM0 : (0:вДЭ) вЙ§ M := by linarith
  refine вЯ®a/4, 5*CвВВ + 3, max XвВА' (Real.exp (M^10)), by positivity, by positivity, ?_вЯ©
  intro X hX N _ ѕЗ hѕЗ hNB
  have hXXвВА : XвВА' вЙ§ X := le_trans (le_max_left _ _) hX
  -- scales
  have hLM : M^10 вЙ§ Real.log X := by
    have h1 : Real.exp (M^10) вЙ§ X := le_trans (le_max_right _ _) hX
    have h2 := Real.log_le_log (Real.exp_pos _) h1
    rwa [Real.log_exp] at h2
  have hM10 : (1024:вДЭ) вЙ§ M^10 := by
    calc (1024:вДЭ) = 2^10 := by norm_num
      _ вЙ§ M^10 := by
          apply pow_le_pow_leftвВА (by norm_num) hM2
  have hL1 : (1:вДЭ) вЙ§ Real.log X := by linarith
  have hL0 : (0:вДЭ) < Real.log X := by linarith
  have hX2 : (2:вДЭ) вЙ§ X := by
    have h1 : Real.exp (M^10) вЙ§ X := le_trans (le_max_right _ _) hX
    have h2 : (2:вДЭ) вЙ§ Real.exp (M^10) := by
      have h3 := Real.add_one_le_exp (M^10)
      linarith
    linarith
  have hX1 : (1:вДЭ) < X := by linarith
  have hX0 : (0:вДЭ) < X := by linarith
  set u := Real.log X ^ ((1:вДЭ)/10) with hudef
  have hu0 : (0:вДЭ) < u := Real.rpow_pos_of_pos hL0 _
  have huM : M вЙ§ u := by
    have h1 : (M^10) ^ ((1:вДЭ)/10) вЙ§ (Real.log X) ^ ((1:вДЭ)/10) :=
      Real.rpow_le_rpow (by positivity) hLM (by norm_num)
    rwa [show (M:вДЭ)^10 = M^((10:вДХ):вДЭ) from by rw [Real.rpow_natCast],
      вЖР Real.rpow_mul hM0, show ((10:вДХ):вДЭ) * ((1:вДЭ)/10) = 1 by norm_num,
      Real.rpow_one] at h1
  have hu1 : (1:вДЭ) вЙ§ u := by linarith
  have hu10 : u ^ (10:вДЭ) = Real.log X := by
    rw [hudef, вЖР Real.rpow_mul hL0.le]
    norm_num
  -- ќі and Y
  set ќі := Real.exp (-((a/2) * u)) with hќіdef
  have hќі0 : (0:вДЭ) < ќі := Real.exp_pos _
  have hќі1 : ќі вЙ§ 1 := by
    rw [hќіdef]
    apply Real.exp_le_one_iff.mpr
    nlinarith
  set Y := X * (1 + ќі) with hYdef
  have hXY : X < Y := by
    rw [hYdef]
    nlinarith
  have hY2X : Y вЙ§ 2*X := by
    rw [hYdef]
    nlinarith
  have hYXвВА : XвВА' вЙ§ Y := by linarith
  have hlogXY : Real.log X вЙ§ Real.log Y := Real.log_le_log hX0 hXY.le
  have hNB_Y : (N:вДЭ) вЙ§ Real.log Y ^ (B : вДЭ) := by
    calc (N:вДЭ) вЙ§ Real.log X ^ (B:вДЭ) := hNB
      _ вЙ§ Real.log Y ^ (B:вДЭ) := Real.rpow_le_rpow hL0.le hlogXY (by linarith)
  -- smoothed bounds at both scales, weakened to the a-rate at X
  have hrX : Real.exp (-(cвВВ * Real.log Y ^ ((1:вДЭ)/10))) вЙ§ Real.exp (-(a * u)) := by
    apply Real.exp_le_exp.mpr
    have h1 : u вЙ§ Real.log Y ^ ((1:вДЭ)/10) :=
      Real.rpow_le_rpow hL0.le hlogXY (by norm_num)
    nlinarith [Real.rpow_nonneg (Real.log_nonneg (by linarith : (1:вДЭ) вЙ§ Y)) ((1:вДЭ)/10), hu0]
  have hrXX : Real.exp (-(cвВВ * Real.log X ^ ((1:вДЭ)/10))) вЙ§ Real.exp (-(a * u)) := by
    apply Real.exp_le_exp.mpr
    rw [вЖР hudef]
    nlinarith [hu0]
  have hSX := hrate X hXXвВА N ѕЗ hѕЗ hNB
  have hSY := hrate Y hYXвВА N ѕЗ hѕЗ hNB_Y
  have hSX' : вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1),
      ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X)вАЦ
      вЙ§ CвВВ * X * Real.exp (-(a * u)) := by
    calc вАЦ_вАЦ вЙ§ CвВВ * X * Real.exp (-(cвВВ * Real.log X ^ ((1:вДЭ)/10))) := hSX
      _ вЙ§ CвВВ * X * Real.exp (-(a * u)) := by
          apply mul_le_mul_of_nonneg_left hrXX (by positivity)
  have hSY' : вАЦвИС n вИИ Finset.range (вМКYвМЛвВК + 1),
      ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / Y)вАЦ
      вЙ§ CвВВ * (2*X) * Real.exp (-(a * u)) := by
    calc вАЦ_вАЦ вЙ§ CвВВ * Y * Real.exp (-(cвВВ * Real.log Y ^ ((1:вДЭ)/10))) := hSY
      _ вЙ§ CвВВ * (2*X) * Real.exp (-(a * u)) := by
          apply mul_le_mul (by nlinarith) hrX (Real.exp_pos _).le (by positivity)
  -- the identity, boundary bound, and recovery
  have hid := two_scale_identity ѕЗ X Y hX0 hXY.le
  have hR := boundary_sum_bound ѕЗ X Y hX2 hXY.le
  have hrec := sharp_recovery_norm
    (вИС n вИИ Finset.range (вМКXвМЛвВК + 1), ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ))
    (вИС n вИИ Finset.range (вМКYвМЛвВК + 1), ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / Y))
    (вИС n вИИ Finset.range (вМКXвМЛвВК + 1), ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X))
    (вИС n вИИ Finset.Ico (вМКXвМЛвВК+1) (вМКYвМЛвВК+1),
      ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (((Y:вДЭ) : вДВ) - ((n:вДЭ) : вДВ)))
    X Y (CвВВ * (2*X) * Real.exp (-(a * u))) (CвВВ * X * Real.exp (-(a * u)))
    ((Y - X + 1) * ((Y - X) * Real.log Y))
    hX0 hXY hid hSY' hSX' hR
  -- the ќі-facts
  obtain вЯ®hdf1, hdf2, hdf3вЯ© := delta_facts a ha0 ha1 u (hMdef вЦЄ huM)
  -- numeric collapse
  have hYX : Y - X = ќі * X := by rw [hYdef]; ring
  have hlog2X : Real.log Y вЙ§ 2 * u ^ (10:вДЭ) := by
    have h1 : Real.log Y вЙ§ Real.log (2*X) := Real.log_le_log (by linarith) hY2X
    have h2 : Real.log (2*X) = Real.log 2 + Real.log X := Real.log_mul (by norm_num) hX0.ne'
