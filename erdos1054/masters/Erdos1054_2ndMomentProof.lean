    rw [hddef]
    field_simp
  have hd20 : d вЙ§ 1/400 := by
    rw [hddef]
    rw [div_le_div_iffвВА (by positivity) (by norm_num : (0:вДЭ) < 400)]
    nlinarith [hW1, hL20]
