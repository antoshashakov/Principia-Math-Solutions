    have hxx : (1/((1-ќ≤)+|ќ≥|)) * (2*((1-ќ≤)+|ќ≥|)) = 2 := by
      field_simp
    have hle : (N:вДЭ)*7*ѕГ/(ѕГ-1) вЙ§ 7*(N:вДЭ) * (1/((1-ќ≤)+|ќ≥|)) := by
      rw [hѕГ1x, div_le_iffвВА (by linarith : (0:вДЭ) < 2*((1-ќ≤)+|ќ≥|))]
      nlinarith [hѕГ2, hN1, hxx, hx0]
    calc Real.log ((N:вДЭ)*7*ѕГ/(ѕГ-1))
        вЙ§ Real.log (7*(N:вДЭ) * (1/((1-ќ≤)+|ќ≥|))) := Real.log_le_log harg0 hle
      _ = Real.log (7*(N:вДЭ)) + Real.log (1/((1-ќ≤)+|ќ≥|)) :=
          Real.log_mul (by nlinarith [hN1]) (by positivity)
  -- the вИЪ-trick
  have hsqrt : Real.log (1/((1-ќ≤)+|ќ≥|)) вЙ§ 2*(1/((1-ќ≤)+|ќ≥|))^((1:вДЭ)/2) := by
    have h1 := Real.log_le_rpow_div
      (le_of_lt (by positivity : (0:вДЭ) < 1/((1-ќ≤)+|ќ≥|)))
      (by norm_num : (0:вДЭ) < 1/2)
    calc Real.log (1/((1-ќ≤)+|ќ≥|)) вЙ§ (1/((1-ќ≤)+|ќ≥|))^((1:вДЭ)/2) / (1/2) := h1
      _ = 2*(1/((1-ќ≤)+|ќ≥|))^((1:вДЭ)/2) := by ring
  obtain вЯ®t, htdefвЯ© : вИГ t : вДЭ, t = (1/((1-ќ≤)+|ќ≥|))^((1:вДЭ)/2) := вЯ®_, rflвЯ©
  have ht0 : 0 вЙ§ t := by rw [htdef]; positivity
  have ht2 : t^2 = 1/((1-ќ≤)+|ќ≥|) := by
    rw [htdef, вЖР Real.rpow_natCast ((1/((1-ќ≤)+|ќ≥|))^((1:вДЭ)/2)) 2,
      вЖР Real.rpow_mul (by positivity : (0:вДЭ) вЙ§ 1/((1-ќ≤)+|ќ≥|))]
    norm_num
  obtain вЯ®D, hDdefвЯ© : вИГ D : вДЭ, D = K' + 40 + 40*Real.log (7*(N:вДЭ)) := вЯ®_, rflвЯ©
  have hD40 : 40 вЙ§ D := by
    rw [hDdef]
    have h1 : (0:вДЭ) вЙ§ Real.log (7*(N:вДЭ)) := Real.log_nonneg (by nlinarith [hN1])
    linarith [hK'0]
  have hquad : t^2 вЙ§ 30*D + 2400*t := by
    have h1 : 1/(30*((1-ќ≤)+|ќ≥|)) = t^2/30 := by
      rw [ht2, div_div]
      ring
    rw [h1] at hkey
    have h3 : Real.log ((N:вДЭ)*7*ѕГ/(ѕГ-1)) вЙ§ Real.log (7*(N:вДЭ)) + 2*t := by
      rw [htdef]
      linarith [hlogb, hsqrt]
    have h4 : K' + 40 + 40*Real.log ((N:вДЭ)*7*ѕГ/(ѕГ-1)) вЙ§ D + 80*t := by
      rw [hDdef]
      linarith [h3]
    linarith [hkey, h4]
  have hres : t^2 вЙ§ 576060*D := by
    by_cases ht48 : t вЙ§ 4800
    ¬Ј have h8 : 2400*t вЙ§ 11520000 := by linarith
      have h9 : (11520000:вДЭ) вЙ§ 288000*D := by linarith [hD40]
      have h10 : (0:вДЭ) вЙ§ D := by linarith [hD40]
      linarith [hquad, h8, h9, h10]
    ¬Ј push_neg at ht48
      have h8 : 2400*t вЙ§ t^2/2 := by nlinarith [ht48, ht0]
      have h10 : (0:вДЭ) вЙ§ D := by linarith [hD40]
      linarith [hquad, h8, h10]
  have hDL : D вЙ§ (K'/20 + 40)*LвВА := by
    rw [hDdef]
    have h1 : Real.log (7*(N:вДЭ)) вЙ§ LвВА - 20 := by
      rw [hLвВАdef]
      have h2 : 7*(N:вДЭ) вЙ§ (N:вДЭ)*(4*|ќ≥|+7) := by nlinarith [hN1, hg0.le]
      have h3 := Real.log_le_log (by nlinarith [hN1] : (0:вДЭ) < 7*(N:вДЭ)) h2
      linarith
    have h4 : K' вЙ§ (K'/20)*LвВА := by nlinarith [hK'0, hL20]
    have hexp : (K'/20 + 40)*LвВА = (K'/20)*LвВА + 40*LвВА := by ring
    linarith [h1, h4, hexp.le, hexp.ge, hL20]
  have hxfinal : t^2 вЙ§ (C/2)*LвВА := by
    have hCC : 576060*(K'/20+40) = (C-40)/2 := by
      rw [hCdef]
      ring
    have h5 : 576060*D вЙ§ ((C-40)/2)*LвВА := by
      have h9 : 576060*((K'/20+40)*LвВА) = ((C-40)/2)*LвВА := by
        rw [вЖР mul_assoc, hCC]
      have h11 := mul_le_mul_of_nonneg_left hDL (by norm_num : (0:вДЭ) вЙ§ 576060)
      linarith [h11, h9.le, h9.ge]
    have h7 : (C/2)*LвВА = ((C-40)/2)*LвВА + 20*LвВА := by ring
    linarith [hres, h5, h7.le, h7.ge, hL20]
  have hxfinal' : 1/((1-ќ≤)+|ќ≥|) вЙ§ (C/2)*LвВА := by
    rw [вЖР ht2]
    exact hxfinal
  have h6 : 1 вЙ§ ((C/2)*LвВА) * ((1-ќ≤)+|ќ≥|) := by
    rw [div_le_iffвВА hx0] at hxfinal'
    linarith [hxfinal']
  have h2CL : 2/(C*LвВА) вЙ§ (1-ќ≤)+|ќ≥| := by
    rw [div_le_iffвВА hCL0]
    have h10 : (((C/2)*LвВА))*((1-ќ≤)+|ќ≥|)*2 = ((1-ќ≤)+|ќ≥|)*(C*LвВА) := by ring
    linarith [h6, h10.le, h10.ge]
  have hsplit : 2/(C*LвВА) - 1/(C*LвВА) = 1/(C*LвВА) := by
    ring
  linarith [h2CL, hgC, hsplit.le, hsplit.ge]

/-- Derivative of `u вЖ¶ (u:вДВ)^c` at positive real `u`. -/
lemma hasDerivAt_real_cpow_const {u : вДЭ} (hu : 0 < u) (c : вДВ) :
    HasDerivAt (fun v : вДЭ => ((v:вДВ)) ^ c) (c * ((u:вДВ)) ^ (c - 1)) u := by
  have h1 : HasDerivAt (fun z : вДВ => z ^ c) (c * ((u:вДВ)) ^ (c - 1) * 1) ((u:вДВ)) := by
    apply HasDerivAt.cpow_const (hasDerivAt_id ((u:вДВ)))
    exact Complex.ofReal_mem_slitPlane.mpr hu
  rw [mul_one] at h1
  exact h1.comp_ofReal

/-- Inner MVT step: `вАЦn^{вИТs} вИТ u^{вИТs}вАЦ вЙ§ вАЦsвАЦ¬Јn^{вИТѕГвИТ1}¬Ј(uвИТn)` on `[n, n+1]`. -/
lemma cpow_diff_bound (n : вДХ) (hn : 1 вЙ§ n) (s : вДВ) (hѕГ : 0 < s.re)
    {u : вДЭ} (hu : u вИИ Set.Icc ((n:вДЭ)) ((n:вДЭ)+1)) :
    вАЦ((n:вДВ)) ^ (-s) - ((u:вДВ)) ^ (-s)вАЦ вЙ§ вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) * (u - (n:вДЭ)) := by
  have hn0 : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast Nat.pos_of_ne_zero (by omega)
  have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
  have hderiv : вИА v вИИ Set.Icc ((n:вДЭ)) ((n:вДЭ)+1),
      HasDerivWithinAt (fun w : вДЭ => ((w:вДВ)) ^ (-s))
        ((-s) * ((v:вДВ)) ^ (-s - 1)) (Set.Icc ((n:вДЭ)) ((n:вДЭ)+1)) v := by
    intro v hv
    have hv0 : (0:вДЭ) < v := lt_of_lt_of_le hn0 hv.1
    exact (hasDerivAt_real_cpow_const hv0 (-s)).hasDerivWithinAt
  have hbound : вИА v вИИ Set.Icc ((n:вДЭ)) ((n:вДЭ)+1),
      вАЦ(-s) * ((v:вДВ)) ^ (-s - 1)вАЦ вЙ§ вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) := by
    intro v hv
    have hv0 : (0:вДЭ) < v := lt_of_lt_of_le hn0 hv.1
    rw [norm_mul, norm_neg, Complex.norm_cpow_eq_rpow_re_of_pos hv0]
    apply mul_le_mul_of_nonneg_left _ (norm_nonneg s)
    have hexp : (-s - 1).re = -s.re - 1 := by simp
    rw [hexp]
    exact Real.rpow_le_rpow_of_nonpos hn0 hv.1 (by linarith)
  have hmvt := Convex.norm_image_sub_le_of_norm_hasDerivWithin_le hderiv hbound
    (convex_Icc _ _) (Set.left_mem_Icc.mpr (by linarith)) hu
  have habs : вАЦu - (n:вДЭ)вАЦ = u - (n:вДЭ) := by
    rw [Real.norm_eq_abs, abs_of_nonneg]
    linarith [hu.1]
  calc вАЦ((n:вДВ)) ^ (-s) - ((u:вДВ)) ^ (-s)вАЦ
      = вАЦ((u:вДВ)) ^ (-s) - (((n:вДЭ):вДВ)) ^ (-s)вАЦ := by
        rw [вЖР norm_neg]
        congr 1
        push_cast
        ring
    _ вЙ§ вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) * вАЦu - (n:вДЭ)вАЦ := hmvt
    _ = вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) * (u - (n:вДЭ)) := by rw [habs]

/-- **The complex Abel kernel bound** (SW brick S4a-4a): for `n вЙ• 1` and `Re s > 0`,
    `вАЦ(sвИТ1)n^{вИТs} вИТ (n^{1вИТs} вИТ (n+1)^{1вИТs})вАЦ вЙ§ вАЦsвИТ1вАЦ¬ЈвАЦsвАЦ¬Јn^{вИТRe s вИТ 1}` вАФ the
    summand of the ќґ-truncation tail, now at COMPLEX `s`. -/
lemma abel_kernel_bound (n : вДХ) (hn : 1 вЙ§ n) (s : вДВ) (hѕГ : 0 < s.re) :
    вАЦ(s - 1) * ((n:вДВ)) ^ (-s) - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s))вАЦ
      вЙ§ вАЦs - 1вАЦ * вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) := by
  have hn0 : (0:вДЭ) < (n:вДЭ) := by exact_mod_cast Nat.pos_of_ne_zero (by omega)
  -- h(u) := u^{1вИТs} + (sвИТ1)¬Јu¬Јn^{вИТs}; K = h(n+1) вИТ h(n)
  have hderiv : вИА v вИИ Set.Icc ((n:вДЭ)) ((n:вДЭ)+1),
      HasDerivWithinAt (fun w : вДЭ => ((w:вДВ)) ^ ((1:вДВ) - s) + (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s))
        ((s-1) * (((n:вДВ)) ^ (-s) - ((v:вДВ)) ^ (-s))) (Set.Icc ((n:вДЭ)) ((n:вДЭ)+1)) v := by
    intro v hv
    have hv0 : (0:вДЭ) < v := lt_of_lt_of_le hn0 hv.1
    have h1 := hasDerivAt_real_cpow_const hv0 ((1:вДВ) - s)
    have h2 : HasDerivAt (fun w : вДЭ => ((w:вДВ))) 1 v := by
      exact (hasDerivAt_id ((v:вДВ))).comp_ofReal
    have h3 : HasDerivAt (fun w : вДЭ => (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s))
        ((s-1) * ((n:вДВ)) ^ (-s)) v := by
      have h4 := (h2.const_mul (s-1)).mul_const (((n:вДВ)) ^ (-s))
      have h5 : (s-1) * 1 * ((n:вДВ)) ^ (-s) = (s-1) * ((n:вДВ)) ^ (-s) := by ring
      rw [h5] at h4
      exact h4
    have h6 := h1.add h3
    have h7 : ((1:вДВ) - s) * ((v:вДВ)) ^ ((1:вДВ) - s - 1) + (s-1) * ((n:вДВ)) ^ (-s)
        = (s-1) * (((n:вДВ)) ^ (-s) - ((v:вДВ)) ^ (-s)) := by
      have h8 : (1:вДВ) - s - 1 = -s := by ring
      rw [h8]
      ring
    rw [h7] at h6
    exact h6.hasDerivWithinAt
  have hbound : вИА v вИИ Set.Icc ((n:вДЭ)) ((n:вДЭ)+1),
      вАЦ(s-1) * (((n:вДВ)) ^ (-s) - ((v:вДВ)) ^ (-s))вАЦ вЙ§ вАЦs-1вАЦ * (вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1)) := by
    intro v hv
    rw [norm_mul]
    apply mul_le_mul_of_nonneg_left _ (norm_nonneg _)
    calc вАЦ((n:вДВ)) ^ (-s) - ((v:вДВ)) ^ (-s)вАЦ
        вЙ§ вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) * (v - (n:вДЭ)) := cpow_diff_bound n hn s hѕГ hv
      _ вЙ§ вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) * 1 := by
          apply mul_le_mul_of_nonneg_left _ (by positivity)
          linarith [hv.2]
      _ = вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) := mul_one _
  have hmvt := Convex.norm_image_sub_le_of_norm_hasDerivWithin_le hderiv hbound
    (convex_Icc _ _) (Set.left_mem_Icc.mpr (by linarith))
    (Set.right_mem_Icc.mpr (by linarith))
  have hcast : (((n+1 : вДХ):вДВ)) = (((((n:вДЭ))+1 : вДЭ)):вДВ) := by push_cast; ring
  have hK : (fun w : вДЭ => ((w:вДВ)) ^ ((1:вДВ) - s) + (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s)) ((n:вДЭ)+1)
      - (fun w : вДЭ => ((w:вДВ)) ^ ((1:вДВ) - s) + (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s)) ((n:вДЭ))
      = (s - 1) * ((n:вДВ)) ^ (-s) - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s)) := by
    simp only
    rw [hcast]
    push_cast
    ring
  have hnorm1 : вАЦ((n:вДЭ)) + 1 - ((n:вДЭ))вАЦ = 1 := by
    rw [show ((n:вДЭ)) + 1 - ((n:вДЭ)) = 1 by ring, norm_one]
  calc вАЦ(s - 1) * ((n:вДВ)) ^ (-s) - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s))вАЦ
      = вАЦ(fun w : вДЭ => ((w:вДВ)) ^ ((1:вДВ) - s) + (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s)) ((n:вДЭ)+1)
        - (fun w : вДЭ => ((w:вДВ)) ^ ((1:вДВ) - s) + (s-1) * ((w:вДВ)) * ((n:вДВ)) ^ (-s)) ((n:вДЭ))вАЦ := by
        rw [hK]
    _ вЙ§ вАЦs-1вАЦ * (вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1)) * вАЦ((n:вДЭ)) + 1 - ((n:вДЭ))вАЦ := hmvt
    _ = вАЦs - 1вАЦ * вАЦsвАЦ * ((n:вДЭ)) ^ (-s.re - 1) := by
        rw [hnorm1, mul_one, mul_assoc]

section ZetaWindow
open Finset Filter Topology Metric

-- verbatim copies from SiegelTheorem.lean (telescope machinery)
lemma tsum_cpow_telescope (x : вДХ) (hx : 1 вЙ§ x) {s : вДВ} (hs : 1 < s.re) :
    вИС' n : вДХ, (if n < x then 0 else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))
      = ((x:вДВ)) ^ ((1:вДВ) - s) := by
  have hs1 : (0:вДЭ) < s.re - 1 := by linarith
  -- partial sums telescope
  have hpartial : вИА z : вДХ, x вЙ§ z вЖТ
      вИС n вИИ range z, (if n < x then 0
        else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))
      = ((x:вДВ)) ^ ((1:вДВ) - s) - ((z:вДВ)) ^ ((1:вДВ) - s) := by
    intro z
    induction z with
    | zero =>
      intro h0
      omega
    | succ m ihm =>
      intro hxm
      rcases Nat.lt_or_ge m x with hlt | hge
      ¬Ј have hx' : x = m + 1 := by omega
        subst hx'
        have hall : вИА n вИИ range (m + 1), (if n < m + 1 then (0:вДВ)
            else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))) = 0 := by
          intro n hn
          rw [Finset.mem_range] at hn
          rw [if_pos hn]
        rw [Finset.sum_congr rfl hall, Finset.sum_const, smul_zero, sub_self]
      ¬Ј rw [Finset.sum_range_succ, ihm hge, if_neg (by omega)]
        push_cast
        ring
  -- the real telescoping majorant
  have hC0 : (0:вДЭ) вЙ§ вАЦs - 1вАЦ / (s.re - 1) := div_nonneg (norm_nonneg _) hs1.le
  have hgmono : вИА n : вДХ, 1 вЙ§ n вЖТ
      (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)) вЙ§ ((n : вДЭ)) ^ (-(s.re - 1)) := by
    intro n hn1
    apply Real.rpow_le_rpow_of_nonpos
      (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_one hn1)
      (by push_cast; linarith)
    linarith
  -- majorant partial sums telescope
  have hpartialR : вИА z : вДХ, x вЙ§ z вЖТ
      вИС n вИИ range z, (if n < x then 0
        else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
          - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1))))
      = (вАЦs - 1вАЦ / (s.re - 1)) * (((x : вДЭ)) ^ (-(s.re - 1)) - ((z : вДЭ)) ^ (-(s.re - 1))) := by
    intro z
    induction z with
    | zero =>
      intro h0
      omega
    | succ m ihm =>
      intro hxm
      rcases Nat.lt_or_ge m x with hlt | hge
      ¬Ј have hx' : x = m + 1 := by omega
        subst hx'
        have hall : вИА n вИИ range (m + 1), (if n < m + 1 then (0:вДЭ)
            else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
              - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)))) = 0 := by
          intro n hn
          rw [Finset.mem_range] at hn
          rw [if_pos hn]
        rw [Finset.sum_congr rfl hall, Finset.sum_const, smul_zero, sub_self, mul_zero]
      ¬Ј rw [Finset.sum_range_succ, ihm hge, if_neg (by omega)]
        push_cast
        ring
  -- summability from the kernel bound at s вИТ 1
  have hsummable : Summable (fun n : вДХ => (if n < x then (0:вДВ)
      else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))) := by
    apply Summable.of_norm_bounded (g := fun n : вДХ => if n < x then 0
      else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
        - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1))))
    ¬Ј -- majorant summable: nonneg terms with telescoping bounded partials
      apply summable_of_sum_range_le (c := вАЦs - 1вАЦ / (s.re - 1))
      ¬Ј intro n
        rcases Nat.lt_or_ge n x with h | h
        ¬Ј rw [if_pos h]
        ¬Ј rw [if_neg (by omega)]
          apply mul_nonneg hC0
          have := hgmono n (le_trans hx h)
          linarith
      ¬Ј intro z
        rcases Nat.lt_or_ge z x with hz | hz
        ¬Ј -- every index n < z вЙ§ x: all terms vanish
          have hall : вИА n вИИ range z, (if n < x then (0:вДЭ)
              else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
                - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)))) = 0 := by
            intro n hn
            rw [Finset.mem_range] at hn
            rw [if_pos (by omega)]
          rw [Finset.sum_congr rfl hall, Finset.sum_const, smul_zero]
          exact hC0
        ¬Ј rw [hpartialR z hz]
          have hx1 : ((x:вДЭ)) ^ (-(s.re - 1)) вЙ§ 1 := by
            apply Real.rpow_le_one_of_one_le_of_nonpos
              (by exact_mod_cast hx)
            linarith
          have hz0 : (0:вДЭ) вЙ§ ((z:вДЭ)) ^ (-(s.re - 1)) :=
            Real.rpow_nonneg (Nat.cast_nonneg z) _
          calc (вАЦs - 1вАЦ / (s.re - 1)) * (((x : вДЭ)) ^ (-(s.re - 1)) - ((z : вДЭ)) ^ (-(s.re - 1)))
              вЙ§ (вАЦs - 1вАЦ / (s.re - 1)) * 1 := by
                apply mul_le_mul_of_nonneg_left _ hC0
                linarith
            _ = вАЦs - 1вАЦ / (s.re - 1) := mul_one _
    ¬Ј intro n
      rcases Nat.lt_or_ge n x with h | h
      ¬Ј rw [if_pos h, if_pos h, norm_zero]
      ¬Ј rw [if_neg (by omega), if_neg (by omega)]
        have hn1 : 1 вЙ§ n := le_trans hx h
        have hker := cpow_diff_kernel_bound n hn1 (s - 1) (by
          simp only [Complex.sub_re, Complex.one_re]
          linarith)
