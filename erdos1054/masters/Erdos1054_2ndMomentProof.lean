  have hgu : 2*|ќ≥| вЙ§ ѕГ - ќ≤ := by rw [hѕГќ≤]; linarith
  have hu3x : ѕГ - ќ≤ вЙ§ 3*((1-ќ≤)+|ќ≥|) := by rw [hѕГќ≤]; linarith
  have hden0 : (0:вДЭ) < (ѕГ-ќ≤)^2 + ќ≥^2 := by nlinarith [hu0, sq_nonneg ќ≥]
  have hden : (ѕГ-ќ≤)^2 + ќ≥^2 вЙ§ (5/4)*(ѕГ-ќ≤)^2 := by
    have h1 : ќ≥^2 = |ќ≥|^2 := (sq_abs ќ≥).symm
