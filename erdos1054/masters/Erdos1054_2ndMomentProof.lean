  have habsorb : u ^ (10*B : вДЭ) * Real.exp (-(cвВЕ * u)) вЙ§ Real.exp (-((cвВЕ/2) * u)) := by
    apply rpow_exp_absorb cвВЕ (10*B) hcвВЕ0 (by linarith) u
