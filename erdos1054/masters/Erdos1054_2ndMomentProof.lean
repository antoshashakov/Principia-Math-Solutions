  have hrange' : Tendsto (fun z : вДХ => вИС n вИИ range z, (if n < x then 0
      else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))
      atTop (nhds (((x:вДВ)) ^ ((1:вДВ) - s))) :=
    (Filter.tendsto_congr' heq).mpr hlim
