/-- **The ќї-extraction at a vanishing continuation** (Siegel brick A3-a): when the
    master inequality's `G(ќ≤).re` term is `вЙ§ 0` (a zero of the L-product) and
    `x вЙ• (820(C+1))^{40}` kills the error term, the main term must carry the unit:
    `1вИТќ≤ вЙ§ 26¬Јќї¬Јx^{1вИТќ≤}`. Pure arithmetic вАФ the quantitative heart of the dichotomy. -/
theorem siegel_lambda_extraction (lam C : вДЭ) (hlam : 0 вЙ§ lam) (hC0 : 0 вЙ§ C)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1) (x : вДХ) (hx : 2 вЙ§ x)
    (hxC : ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) вЙ§ (x:вДЭ))
    (Gre : вДЭ) (hG : Gre вЙ§ 0)
    (hmaster : 1 вЙ§ Gre + lam * (((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤))
        + 12 * lam * (((x:вДЭ)) ^ (-ќ≤) / (1 - ќ≤))
        + 410 * C * ((x:вДЭ)) ^ (7/8 - ќ≤)) :
    1 - ќ≤ вЙ§ 26 * lam * ((x:вДЭ)) ^ (1 - ќ≤) := by
  have hx0 : (0:вДЭ) < (x:вДЭ) := by
    have : (0:вДХ) < x := by omega
    exact_mod_cast this
  have hx1r : (1:вДЭ) вЙ§ (x:вДЭ) := by
    have : (1:вДХ) вЙ§ x := by omega
    exact_mod_cast this
  have h1ќ≤ : (0:вДЭ) < 1 - ќ≤ := by linarith
  have hy0 : (0:вДЭ) < 820 * (C + 1) := by linarith
  -- error term вЙ§ 1/2
  have herr : 410 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) вЙ§ 1/2 := by
    have h1 : ((x:вДЭ)) ^ (7/8 - ќ≤) вЙ§ ((x:вДЭ)) ^ (-(1/40 : вДЭ)) := by
      apply Real.rpow_le_rpow_of_exponent_le hx1r
      linarith
    have h2 : (820 * (C + 1)) вЙ§ ((x:вДЭ)) ^ ((1/40 : вДЭ)) := by
      have h3 : ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) ^ ((1/40 : вДЭ)) вЙ§ ((x:вДЭ)) ^ ((1/40 : вДЭ)) := by
        apply Real.rpow_le_rpow (by positivity) hxC (by norm_num)
      have h4 : ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) ^ ((1/40 : вДЭ)) = 820 * (C + 1) := by
        rw [вЖР Real.rpow_natCast (820 * (C + 1)) 40, вЖР Real.rpow_mul hy0.le]
        norm_num
      rw [h4] at h3
      exact h3
    have h5 : ((x:вДЭ)) ^ (-(1/40 : вДЭ)) вЙ§ 1 / (820 * (C + 1)) := by
      rw [Real.rpow_neg hx0.le, вЖР one_div]
      apply one_div_le_one_div_of_le hy0 h2
    have h6 : 410 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) вЙ§ 410 * C * (1 / (820 * (C + 1))) := by
      apply mul_le_mul_of_nonneg_left (le_trans h1 h5) (by positivity)
    have h7 : 410 * C * (1 / (820 * (C + 1))) вЙ§ 1/2 := by
      rw [mul_one_div, div_le_div_iffвВА hy0 (by norm_num)]
      linarith
    linarith
  -- x^{вИТќ≤} вЙ§ x^{1вИТќ≤}
  have hmono : ((x:вДЭ)) ^ (-ќ≤) вЙ§ ((x:вДЭ)) ^ (1 - ќ≤) := by
    apply Real.rpow_le_rpow_of_exponent_le hx1r
    linarith
  have hx1ќ≤ : (0:вДЭ) вЙ§ ((x:вДЭ)) ^ (1 - ќ≤) := Real.rpow_nonneg hx0.le _
  -- main-term consolidation: 1/2 вЙ§ 13¬Јќї¬Јx^{1вИТќ≤}/(1вИТќ≤)
  have hmain : (1:вДЭ)/2 вЙ§ 13 * lam * ((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤) := by
    have h8 : 12 * lam * (((x:вДЭ)) ^ (-ќ≤) / (1 - ќ≤))
        вЙ§ 12 * lam * (((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤)) := by
      apply mul_le_mul_of_nonneg_left _ (by linarith)
      exact div_le_div_of_nonneg_right hmono h1ќ≤.le
    have h9 : lam * (((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤))
        + 12 * lam * (((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤))
        = 13 * lam * ((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤) := by
      ring
    linarith [hmaster, hG, herr, h8]
  -- clear the denominator
  rw [div_le_div_iffвВА (by norm_num : (0:вДЭ) < 2) h1ќ≤] at hmain
  linarith

/-- **G is the L-product on the slit** (Siegel brick A3-b): the continuation
    `G = ќїќґ + ќ£'E(n)ќФn` of the Dirichlet series agrees at every real
    `ќ≤ вИИ (9/10, 1)` with ANY function `P` that is analytic on the slit half-plane
    and equals the L-series on `Re > 1` вАФ in application, `P = ќґ¬ЈLвВБ¬ЈLвВВ¬ЈLвВБвВВ`,
    which VANISHES at a real zero `ќ≤вВБ` of `L(¬Ј,ѕЗвВБ)`. -/
theorem G_eq_P_at_real (a : вДХ вЖТ вДВ) (lam : вДЭ) (E : вДХ вЖТ вДЭ) (C : вДЭ)
    (hAE : вИА n : вДХ, вИС m вИИ Icc 1 n, a m = (lam * n : вДЭ) + E n)
    (hC0 : 0 вЙ§ C) (hE0 : E 0 = 0)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)))
    (hsum : вИА s : вДВ, 1 < s.re вЖТ LSeriesSummable a s)
    (P : вДВ вЖТ вДВ)
    (hP : вИА s : вДВ, 9/10 < s.re вЖТ s вЙ† 1 вЖТ DifferentiableAt вДВ P s)
    (hPeq : вИА s : вДВ, 1 < s.re вЖТ LSeries a s = P s)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1) :
    (lam : вДВ) * riemannZeta ((ќ≤:вДВ))
      + (вИС' n : вДХ, ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))))
    = P ((ќ≤:вДВ)) := by
  -- the linear E-bound demanded by lseries_eq_G
  have hEb : вИА n : вДХ, |E n| вЙ§ (9 * C) * n := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј rw [hE0]
      simp
    ¬Ј have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
      have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
      have hlogbound : 1 + Real.log n вЙ§ 9 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
        have h1 : Real.log n вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) :=
          Real.log_le_rpow_div hn0.le (by norm_num)
        have h2 : ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) = 8 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by ring
        have h3 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) := Real.one_le_rpow hn1r (by norm_num)
        linarith [h1, h2.le, h2.ge, h3]
      have hcollect : ((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) = ((n:вДЭ)) ^ ((7:вДЭ)/8) := by
        rw [вЖР Real.rpow_add hn0]
        norm_num
      have h78 : ((n:вДЭ)) ^ ((7:вДЭ)/8) вЙ§ (n:вДЭ) := by
        calc ((n:вДЭ)) ^ ((7:вДЭ)/8) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)) :=
              Real.rpow_le_rpow_of_exponent_le hn1r (by norm_num)
          _ = (n:вДЭ) := Real.rpow_one _
      calc |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := hE n hn
        _ вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (9 * ((n:вДЭ)) ^ ((1:вДЭ)/8))) := by
            apply mul_le_mul_of_nonneg_left _ hC0
            apply mul_le_mul_of_nonneg_left hlogbound (Real.rpow_nonneg hn0.le _)
        _ = 9 * C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8)) := by ring
        _ = 9 * C * ((n:вДЭ)) ^ ((7:вДЭ)/8) := by rw [hcollect]
        _ вЙ§ (9 * C) * (n:вДЭ) := by
            apply mul_le_mul_of_nonneg_left h78 (by positivity)
  -- the identity theorem
  have hвВАre : 9/10 < ((ќ≤:вДВ)).re := by
    rw [Complex.ofReal_re]
    exact hќ≤1
  have hвВАne : ((ќ≤:вДВ)) вЙ† 1 := by
    intro h
    rw [Complex.ofReal_eq_one] at h
    linarith
  exact eqOn_slit_halfplane
    (fun s : вДВ => (lam : вДВ) * riemannZeta s
      + вИС' n : вДХ, ((E n : вДЭ) : вДВ) * (((n:вДВ)) ^ (-s) - (((n + 1 : вДХ):вДВ)) ^ (-s)))
    P
    (by
      intro s hs hs1
      apply DifferentiableAt.add
      ¬Ј exact (differentiableAt_riemannZeta hs1).const_mul _
      ¬Ј exact eseries_differentiableAt E C hC0 hE0 hE s hs)
    hP
    (by
      intro s hs
      rw [вЖР lseries_eq_G a lam E (9 * C) hAE hEb hs (hsum s hs)]
      exact hPeq s hs)
    ((ќ≤:вДВ)) hвВАre hвВАne

/-- **The ќї lower bound at an L-product zero** (Siegel brick A3-c): a nonnegative
    coefficient system with `a(1) = 1`, `A = ќї¬Јid + E`, whose continued L-product `P`
    VANISHES at a real `ќ≤ вИИ (9/10, 1)`, forces `1вИТќ≤ вЙ§ 26¬Јќї¬Јx^{1вИТќ≤}` for every
    admissible truncation `x вЙ• (820(C+1))^{40}` вАФ Goldfeld's engine, fully wired. -/
theorem siegel_lambda_lower (a : вДХ вЖТ вДЭ) (lam : вДЭ) (E : вДХ вЖТ вДЭ) (C : вДЭ)
    (ha0 : вИА n, 0 вЙ§ a n) (ha1 : a 1 = 1) (hlam : 0 вЙ§ lam)
    (hAE : вИА n : вДХ, вИС m вИИ Icc 1 n, a m = lam * n + E n)
    (hC0 : 0 вЙ§ C) (hE0 : E 0 = 0)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)))
    (hsum : вИА s : вДВ, 1 < s.re вЖТ LSeriesSummable (fun n => ((a n : вДЭ) : вДВ)) s)
    (P : вДВ вЖТ вДВ)
    (hP : вИА s : вДВ, 9/10 < s.re вЖТ s вЙ† 1 вЖТ DifferentiableAt вДВ P s)
    (hPeq : вИА s : вДВ, 1 < s.re вЖТ LSeries (fun n => ((a n : вДЭ) : вДВ)) s = P s)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1) (hPzero : P ((ќ≤:вДВ)) = 0)
    (x : вДХ) (hx : 2 вЙ§ x) (hxC : ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) вЙ§ (x:вДЭ)) :
    1 - ќ≤ вЙ§ 26 * lam * ((x:вДЭ)) ^ (1 - ќ≤) := by
  -- the complex partial-sum hypothesis
  have hAEc : вИА n : вДХ, вИС m вИИ Icc 1 n, ((a m : вДЭ) : вДВ) = ((lam * n : вДЭ) : вДВ) + ((E n : вДЭ) : вДВ) := by
    intro n
    rw [вЖР Complex.ofReal_sum, hAE n]
    push_cast
    ring
  -- G(ќ≤) = P(ќ≤) = 0
  have hGP := G_eq_P_at_real (fun n => ((a n : вДЭ) : вДВ)) lam E C hAEc hC0 hE0 hE hsum
    P hP hPeq hќ≤1 hќ≤2
  have hGzero : ((lam : вДВ) * riemannZeta ((ќ≤:вДВ))
      + вИС' n : вДХ, ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))).re = 0 := by
    rw [hGP, hPzero]
    exact Complex.zero_re
  -- the master inequality
  have hmaster := goldfeld_master_inequality a lam E C ha0 ha1 hlam hAE hC0 hE0 hE
    hќ≤1 hќ≤2 x hx
  -- extract ќї
  exact siegel_lambda_extraction lam C hlam hC0 hќ≤1 hќ≤2 x hx hxC
    (((lam : вДВ) * riemannZeta ((ќ≤:вДВ))
      + вИС' n : вДХ, ((E n : вДЭ) : вДВ)
          * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))).re)
    (le_of_eq hGzero) hmaster

/-- Values of a quadratic Dirichlet character lie in `{вИТ1, 0, 1}` (A3-d1). -/
lemma real_char_repr {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1)
    (a : ZMod q) : ѕЗ a = -1 вИ® ѕЗ a = 0 вИ® ѕЗ a = 1 := by
  by_cases hu : IsUnit a
  ¬Ј have hsq : ѕЗ a * ѕЗ a = 1 := by
      have h1 : (ѕЗ ^ 2) a = 1 := by
        rw [hѕЗ2]
        exact MulChar.one_apply hu
      rw [pow_two, MulChar.mul_apply] at h1
      exact h1
    have hfactor : (ѕЗ a - 1) * (ѕЗ a + 1) = 0 := by
      linear_combination hsq
    rcases mul_eq_zero.mp hfactor with h | h
    ¬Ј right; right
      exact sub_eq_zero.mp h
    ¬Ј left
      have := eq_neg_of_add_eq_zero_left h
      exact this
  ¬Ј right; left
    exact MulChar.map_nonunit ѕЗ hu

/-- The bare real-valued function of a quadratic Dirichlet character (A3-d0). -/
noncomputable def charFn (q : вДХ) (ѕЗ : DirichletCharacter вДВ q) : вДХ вЖТ вДЭ :=
  fun n => (ѕЗ ((n : ZMod q))).re

/-- `charFn` represents `ѕЗ` (A3-d2): the character IS the cast of its real values. -/
lemma charFn_repr {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (n : вДХ) :
    ((charFn q ѕЗ n : вДЭ) : вДВ) = ѕЗ ((n : ZMod q)) := by
  rcases real_char_repr ѕЗ hѕЗ2 ((n : ZMod q)) with h | h | h <;>
    rw [charFn, h] <;> norm_num

/-- `charFn` takes values in `{вИТ1, 0, 1}` (A3-d3). -/
lemma charFn_values {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (n : вДХ) :
    charFn q ѕЗ n = -1 вИ® charFn q ѕЗ n = 0 вИ® charFn q ѕЗ n = 1 := by
  rcases real_char_repr ѕЗ hѕЗ2 ((n : ZMod q)) with h | h | h <;>
    rw [charFn, h] <;> norm_num

/-- `charFn` is bounded by 1 (A3-d3'). -/
lemma charFn_bound {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (n : вДХ) :
    |charFn q ѕЗ n| вЙ§ 1 := by
  rcases charFn_values ѕЗ hѕЗ2 n with h | h | h <;> rw [h] <;> norm_num

/-- `charFn` is completely multiplicative (A3-d4). -/
lemma charFn_mul {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (m n : вДХ) :
    charFn q ѕЗ (m * n) = charFn q ѕЗ m * charFn q ѕЗ n := by
  have hc : ((charFn q ѕЗ (m * n) : вДЭ) : вДВ)
      = ((charFn q ѕЗ m * charFn q ѕЗ n : вДЭ) : вДВ) := by
    rw [charFn_repr ѕЗ hѕЗ2 (m * n), Nat.cast_mul, map_mul,
      вЖР charFn_repr ѕЗ hѕЗ2 m, вЖР charFn_repr ѕЗ hѕЗ2 n]
    push_cast
    ring
  exact_mod_cast hc

/-- `charFn 1 = 1` (A3-d5). -/
lemma charFn_one {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) : charFn q ѕЗ 1 = 1 := by
  rw [charFn, Nat.cast_one, map_one, Complex.one_re]

/-- **Character partial sums are bounded by the modulus** (Siegel brick A3-e):
    for a nontrivial quadratic `ѕЗ mod q`, `|ќ£_{nвЙ§t} ѕЗ(n)| вЙ§ q` вАФ every block of `q`
    consecutive integers hits each residue once and cancels. The `hG` input of the
    whole divisor-asymptotic ladder. -/
theorem charFn_partial_sum_bound {q : вДХ} (hq : 1 вЙ§ q) (ѕЗ : DirichletCharacter вДВ q)
    (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1) :
    вИА t : вДХ, |вИС n вИИ Icc 1 t, charFn q ѕЗ n| вЙ§ q := by
  haveI : NeZero q := вЯ®by omegaвЯ©
  -- one full block cancels
  have hblock : вИА m : вДХ, вИС n вИИ Icc (m + 1) (m + q), charFn q ѕЗ n = 0 := by
    intro m
    have hinj : вИА nвВБ вИИ Icc (m + 1) (m + q), вИА nвВВ вИИ Icc (m + 1) (m + q),
        ((nвВБ : ZMod q)) = ((nвВВ : ZMod q)) вЖТ nвВБ = nвВВ := by
      intro nвВБ hвВБ nвВВ hвВВ heq
      rw [Finset.mem_Icc] at hвВБ hвВВ
      rcases Nat.le_total nвВБ nвВВ with hle | hle
      ¬Ј have hmod : nвВБ вЙ° nвВВ [MOD q] := (ZMod.natCast_eq_natCast_iff _ _ _).mp heq
        have hdvd : q вИ£ nвВВ - nвВБ := (Nat.modEq_iff_dvd' hle).mp hmod
        have hz : nвВВ - nвВБ = 0 := Nat.eq_zero_of_dvd_of_lt hdvd (by omega)
        omega
      ¬Ј have hmod : nвВВ вЙ° nвВБ [MOD q] := (ZMod.natCast_eq_natCast_iff _ _ _).mp heq.symm
        have hdvd : q вИ£ nвВБ - nвВВ := (Nat.modEq_iff_dvd' hle).mp hmod
        have hz : nвВБ - nвВВ = 0 := Nat.eq_zero_of_dvd_of_lt hdvd (by omega)
        omega
    have himg : (Icc (m + 1) (m + q)).image (fun n : вДХ => ((n : ZMod q)))
        = Finset.univ := by
      apply Finset.eq_univ_of_card
      rw [Finset.card_image_of_injOn (fun nвВБ hвВБ nвВВ hвВВ heq =>
        hinj nвВБ (Finset.mem_coe.mp hвВБ) nвВВ (Finset.mem_coe.mp hвВВ) heq),
        Nat.card_Icc, ZMod.card]
      omega
    have hcsum : вИС n вИИ Icc (m + 1) (m + q), ѕЗ ((n : ZMod q)) = 0 := by
      have h1 : вИС a вИИ (Icc (m + 1) (m + q)).image (fun n : вДХ => ((n : ZMod q))), ѕЗ a
          = вИС n вИИ Icc (m + 1) (m + q), ѕЗ ((n : ZMod q)) := Finset.sum_image hinj
      rw [вЖР h1, himg]
      exact MulChar.sum_eq_zero_of_ne_one hѕЗ1
    have hreal : ((вИС n вИИ Icc (m + 1) (m + q), charFn q ѕЗ n : вДЭ) : вДВ)
        = вИС n вИИ Icc (m + 1) (m + q), ѕЗ ((n : ZMod q)) := by
      rw [Complex.ofReal_sum]
      exact Finset.sum_congr rfl (fun n _ => charFn_repr ѕЗ hѕЗ2 n)
    exact_mod_cast hreal.trans hcsum
  -- strong induction in blocks of q
  intro t
  induction t using Nat.strong_induction_on with
  | _ t ih =>
    rcases Nat.lt_or_ge t q with h | h
    ¬Ј calc |вИС n вИИ Icc 1 t, charFn q ѕЗ n|
          вЙ§ вИС n вИИ Icc 1 t, |charFn q ѕЗ n| := Finset.abs_sum_le_sum_abs _ _
        _ вЙ§ вИС n вИИ Icc 1 t, (1:вДЭ) := Finset.sum_le_sum (fun n _ => charFn_bound ѕЗ hѕЗ2 n)
        _ = t := by
            rw [Finset.sum_const, Nat.card_Icc, nsmul_eq_mul, mul_one]
            norm_num
        _ вЙ§ q := by
            have : t вЙ§ q := h.le
            exact_mod_cast this
    ¬Ј have hsplit : Icc 1 t = Icc 1 (t - q) вИ™ Icc (t - q + 1) t := by
        ext n
        simp only [Finset.mem_union, Finset.mem_Icc]
        omega
      have hdisj : Disjoint (Icc 1 (t - q)) (Icc (t - q + 1) t) := by
        rw [Finset.disjoint_left]
        intro n hn hn2
        rw [Finset.mem_Icc] at hn hn2
        omega
      rw [hsplit, Finset.sum_union hdisj]
      have hb := hblock (t - q)
      rw [show t - q + q = t from by omega] at hb
      rw [hb, add_zero]
      exact ih (t - q) (by omega)

/-- **The product-character bridge** (Siegel brick A3-f): the bare real function of
    the level-`qвВБqвВВ` product character is the pointwise product of the bare
    functions вАФ non-units die on both sides, units factor through `changeLevel`. -/
theorem charFn_mul_char {qвВБ qвВВ : вДХ}
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (n : вДХ) :
    charFn (qвВБ * qвВВ)
      ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) n
    = charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n := by
  simp only [charFn, MulChar.mul_apply]
  by_cases hu : IsUnit ((n : ZMod (qвВБ * qвВВ)))
  ¬Ј have huc : ((hu.unit : (ZMod (qвВБ * qвВВ))Ћ£) : ZMod (qвВБ * qвВВ)) = ((n : ZMod (qвВБ * qвВВ))) :=
      IsUnit.unit_spec hu
    have hвВБ : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ) ((n : ZMod (qвВБ * qвВВ)))
        = ѕЗвВБ ((n : ZMod qвВБ)) := by
      rw [вЖР huc,
        DirichletCharacter.changeLevel_eq_cast_of_dvd ѕЗвВБ (dvd_mul_right qвВБ qвВВ) hu.unit,
        huc, ZMod.cast_natCast (dvd_mul_right qвВБ qвВВ)]
    have hвВВ : (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) ((n : ZMod (qвВБ * qвВВ)))
        = ѕЗвВВ ((n : ZMod qвВВ)) := by
      rw [вЖР huc,
        DirichletCharacter.changeLevel_eq_cast_of_dvd ѕЗвВВ (dvd_mul_left qвВВ qвВБ) hu.unit,
        huc, ZMod.cast_natCast (dvd_mul_left qвВВ qвВБ)]
    rw [hвВБ, hвВВ]
    rcases real_char_repr ѕЗвВБ hѕЗвВБ2 ((n : ZMod qвВБ)) with h1 | h1 | h1 <;>
      rcases real_char_repr ѕЗвВВ hѕЗвВВ2 ((n : ZMod qвВВ)) with h2 | h2 | h2 <;>
      rw [h1, h2] <;> norm_num
  ¬Ј rw [MulChar.map_nonunit _ hu, zero_mul, Complex.zero_re]
    have hcop : ¬ђ Nat.Coprime n (qвВБ * qвВВ) := fun hc =>
      hu ((ZMod.isUnit_iff_coprime n (qвВБ * qвВВ)).mpr hc)
    have hsplit : ¬ђ Nat.Coprime n qвВБ вИ® ¬ђ Nat.Coprime n qвВВ := by
      by_contra hcon
      push_neg at hcon
      exact hcop (Nat.Coprime.mul_right hcon.1 hcon.2)
    rcases hsplit with h | h
    ¬Ј have hnu : ¬ђ IsUnit ((n : ZMod qвВБ)) := fun hun =>
        h ((ZMod.isUnit_iff_coprime _ _).mp hun)
      rw [MulChar.map_nonunit _ hnu, Complex.zero_re, zero_mul]
    ¬Ј have hnu : ¬ђ IsUnit ((n : ZMod qвВВ)) := fun hun =>
        h ((ZMod.isUnit_iff_coprime _ _).mp hun)
      rw [MulChar.map_nonunit _ hnu, Complex.zero_re, mul_zero]

/-- Convolving a power-bounded arithmetic function with a 1-bounded bare function
    raises the power by one (A3-g1a helper). -/
lemma conv_abs_le_pow (F : ArithmeticFunction вДЭ) (k : вДХ вЖТ вДЭ) (t : вДХ)
    (hF : вИА j : вДХ, |F j| вЙ§ ((j:вДЭ)) ^ t) (hkb : вИА j, |k j| вЙ§ 1) (m : вДХ) :
    |(F * toArith k) m| вЙ§ ((m:вДЭ)) ^ (t + 1) := by
  rcases Nat.eq_zero_or_pos m with rfl | hm
  ¬Ј rw [ArithmeticFunction.map_zero, abs_zero, Nat.cast_zero, zero_pow (by omega)]
  ¬Ј have hkb' : вИА j : вДХ, |toArith k j| вЙ§ 1 := by
      intro j
      rcases Nat.eq_zero_or_pos j with rfl | hj
      ¬Ј simp [toArith]
      ¬Ј rw [toArith_apply k j (by omega)]
        exact hkb j
    rw [ArithmeticFunction.mul_apply]
    calc |вИС p вИИ m.divisorsAntidiagonal, F p.1 * toArith k p.2|
        вЙ§ вИС p вИИ m.divisorsAntidiagonal, |F p.1 * toArith k p.2| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС p вИИ m.divisorsAntidiagonal, ((m:вДЭ)) ^ t := by
          apply Finset.sum_le_sum
          intro p hp
          obtain вЯ®he, _вЯ© := Nat.mem_divisorsAntidiagonal.mp hp
          have hp1m : p.1 вЙ§ m := Nat.le_of_dvd hm (Dvd.intro p.2 he)
          have hcast : ((p.1:вДЭ)) ^ t вЙ§ ((m:вДЭ)) ^ t :=
            pow_le_pow_leftвВА (Nat.cast_nonneg _) (by exact_mod_cast hp1m) t
          rw [abs_mul]
          calc |F p.1| * |toArith k p.2| вЙ§ ((p.1:вДЭ)) ^ t * 1 :=
                mul_le_mul (hF p.1) (hkb' p.2) (abs_nonneg _)
                  (le_trans (abs_nonneg _) (hF p.1))
            _ = ((p.1:вДЭ)) ^ t := mul_one _
            _ вЙ§ ((m:вДЭ)) ^ t := hcast
      _ = (m.divisorsAntidiagonal.card : вДЭ) * ((m:вДЭ)) ^ t := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ ((m:вДЭ)) * ((m:вДЭ)) ^ t := by
          apply mul_le_mul_of_nonneg_right _ (by positivity)
          have hcard : m.divisorsAntidiagonal.card вЙ§ m := by
            have hmap : вИА p вИИ m.divisorsAntidiagonal, p.1 вИИ Icc 1 m := by
              intro p hp
              obtain вЯ®he, hm0вЯ© := Nat.mem_divisorsAntidiagonal.mp hp
              rw [Finset.mem_Icc]
              constructor
              ¬Ј by_contra h0
                push_neg at h0
                have h1 : p.1 = 0 := by omega
                rw [h1, zero_mul] at he
                omega
              ¬Ј exact Nat.le_of_dvd hm (Dvd.intro p.2 he)
            have hinj : вИА p вИИ m.divisorsAntidiagonal, вИА p' вИИ m.divisorsAntidiagonal,
                p.1 = p'.1 вЖТ p = p' := by
              intro p hp p' hp' hfst
              obtain вЯ®he, hm0вЯ© := Nat.mem_divisorsAntidiagonal.mp hp
              obtain вЯ®he', _вЯ© := Nat.mem_divisorsAntidiagonal.mp hp'
              have h1 : p.1 вЙ† 0 := by
                intro h0
                rw [h0, zero_mul] at he
                omega
              have h2 : p.2 = p'.2 := by
                apply Nat.eq_of_mul_eq_mul_left (Nat.pos_of_ne_zero h1)
                rw [he, hfst, he']
              exact Prod.ext hfst h2
            calc m.divisorsAntidiagonal.card вЙ§ (Icc 1 m).card :=
                  Finset.card_le_card_of_injOn (fun p => p.1)
                    (fun p hp => hmap p hp)
                    (fun p hp p' hp' h => hinj p hp p' hp' h)
              _ = m := by rw [Nat.card_Icc]; omega
          exact_mod_cast hcard
      _ = ((m:вДЭ)) ^ (t + 1) := by ring

/-- The quadruple convolution is crudely cubed-bounded (A3-g1a): `|a(m)| вЙ§ m¬≥`. -/
lemma quad_value_le_cube (gвВБ gвВВ : вДХ вЖТ вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1) (m : вДХ) :
    |(toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) m| вЙ§ ((m:вДЭ)) ^ (3:вДХ) := by
  have h12b : вИА n, |gвВБ n * gвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |gвВБ n| * |gвВВ n| вЙ§ 1 * 1 :=
        mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have h1 : вИА j : вДХ, |(toArith (fun _ => (1:вДЭ))) j| вЙ§ ((j:вДЭ)) ^ (0:вДХ) := by
    intro j
    rw [pow_zero]
    rcases Nat.eq_zero_or_pos j with rfl | hj
    ¬Ј simp [toArith]
    ¬Ј rw [toArith_apply _ j (by omega)]
      norm_num
  have h2 := fun j => conv_abs_le_pow (toArith (fun _ => (1:вДЭ))) gвВБ 0 h1 h1b j
  have h3 := fun j => conv_abs_le_pow (toArith (fun _ => (1:вДЭ)) * toArith gвВБ) gвВВ 1 h2 h2b j
  exact conv_abs_le_pow (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ)
    (fun k => gвВБ k * gвВВ k) 2 h3 h12b m

/-- **The E-package** (Siegel brick A3-g1): the hyperbola asymptotic upgraded to the
    Goldfeld-shape error bound at EVERY `n вЙ• 1` вАФ `|A(n) вИТ LвВБLk¬Јn| вЙ§ C¬Јn^{3/4}(1+log n)`
    with `C = 30(1+qвВБ)(1+B) + 36 + 3|LвВБLk|` (small `n` patched by the cube bound). -/
theorem quad_E_package (gвВБ gвВВ : вДХ вЖТ вДЭ) (qвВБ B LвВБ Lk : вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1)
    (hLвВБ : вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, gвВБ d / d| вЙ§ 2 * qвВБ / (y + 1))
    (hqвВБ : 0 вЙ§ qвВБ)
    (hH : вИА M : вДХ, 1 вЙ§ M вЖТ
      |вИС n вИИ Icc 1 M, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ) n - LвВБ * M|
        вЙ§ (1 + 4 * qвВБ) * (Real.sqrt M + 1))
    (hKb : вИА t : вДХ, |вИС n вИИ Icc 1 t, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) n|
        вЙ§ B * (Real.sqrt t + 1))
    (hLk : вИА y : вДХ, 1 вЙ§ y вЖТ
      |Lk - вИС d вИИ Icc 1 y, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) d / d|
        вЙ§ 7 * B / Real.sqrt y) :
    вИГ C : вДЭ, 0 вЙ§ C вИІ вИА n : вДХ, 1 вЙ§ n вЖТ
      |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
          * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
  have hB0 : 0 вЙ§ B := by
    have h0 := hKb 0
    rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty, abs_zero,
      Nat.cast_zero, Real.sqrt_zero, zero_add, mul_one] at h0
    exact h0
  refine вЯ®30 * (1 + qвВБ) * (1 + B) + 36 + 3 * |LвВБ * Lk|, by positivity, ?_вЯ©
  intro n hn
  have hn0 : (0:вДЭ) < (n:вДЭ) := by
    have : (0:вДХ) < n := hn
    exact_mod_cast this
  have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
  have htge1 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n) := by
    have h1 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) := Real.one_le_rpow hn1r (by norm_num)
    have h2 : (1:вДЭ) вЙ§ 1 + Real.log n := by
      have := Real.log_nonneg hn1r
      linarith
    nlinarith [h1, h2]
  have ht0 : (0:вДЭ) вЙ§ ((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n) := by linarith
  rcases Nat.lt_or_ge n 4 with h4 | h4
  ¬Ј -- n вИИ {1, 2, 3}: cube bound
    have hA : |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) m| вЙ§ 36 := by
      calc |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m|
          вЙ§ вИС m вИИ Icc 1 n, |(toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m| := Finset.abs_sum_le_sum_abs _ _
        _ вЙ§ вИС m вИИ Icc 1 n, ((m:вДЭ)) ^ (3:вДХ) :=
            Finset.sum_le_sum (fun m _ => quad_value_le_cube gвВБ gвВВ h1b h2b m)
        _ вЙ§ вИС m вИИ Icc (1:вДХ) 3, ((m:вДЭ)) ^ (3:вДХ) := by
            apply Finset.sum_le_sum_of_subset_of_nonneg
            ¬Ј intro m hm
              rw [Finset.mem_Icc] at hm вКҐ
              omega
            ¬Ј intro m _ _
              positivity
        _ = 36 := by
            rw [show (Icc (1:вДХ) 3 : Finset вДХ) = {1, 2, 3} by decide]
            norm_num [Finset.sum_insert, Finset.mem_insert, Finset.sum_singleton]
    have h3n : (n:вДЭ) вЙ§ 3 := by
      have : n вЙ§ 3 := by omega
      exact_mod_cast this
    have hlam : |LвВБ * Lk| * (n:вДЭ) вЙ§ 3 * |LвВБ * Lk| := by
      nlinarith [abs_nonneg (LвВБ * Lk), h3n]
    have htri : |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
            * toArith (fun k => gвВБ k * gвВВ k)) m| + |LвВБ * Lk * (n:вДЭ)| := by
      have h := abs_add_le (вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ
          * toArith gвВВ * toArith (fun k => gвВБ k * gвВВ k)) m) (-(LвВБ * Lk * (n:вДЭ)))
      rw [abs_neg, вЖР sub_eq_add_neg] at h
      exact h
    have habsmul : |LвВБ * Lk * (n:вДЭ)| = |LвВБ * Lk| * (n:вДЭ) := by
      rw [abs_mul, Nat.abs_cast]
    calc |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
          * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ 36 + 3 * |LвВБ * Lk| := by
          rw [habsmul] at htri
          linarith [htri, hA, hlam]
      _ = (36 + 3 * |LвВБ * Lk|) * 1 := (mul_one _).symm
      _ вЙ§ (36 + 3 * |LвВБ * Lk|) * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
          apply mul_le_mul_of_nonneg_left htge1 (by positivity)
      _ вЙ§ (30 * (1 + qвВБ) * (1 + B) + 36 + 3 * |LвВБ * Lk|)
            * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
          apply mul_le_mul_of_nonneg_right _ ht0
          nlinarith [hqвВБ, hB0]
  ¬Ј -- n вЙ• 4: the hyperbola asymptotic
    have hmain := quad_coeff_asymptotic gвВБ gвВВ qвВБ B LвВБ Lk h1b h2b hLвВБ hqвВБ hH hKb hLk n h4
    have hconv : Real.sqrt n * Real.sqrt (Real.sqrt n) = ((n:вДЭ)) ^ ((3:вДЭ)/4) := by
      rw [Real.sqrt_eq_rpow, Real.sqrt_eq_rpow,
        вЖР Real.rpow_mul hn0.le, вЖР Real.rpow_add hn0]
      norm_num
    rw [hconv] at hmain
    calc |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
          * toArith (fun k => gвВБ k * gвВВ k)) m - LвВБ * Lk * n|
        вЙ§ 30 * (1 + qвВБ) * (1 + B) * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := hmain
      _ вЙ§ (30 * (1 + qвВБ) * (1 + B) + 36 + 3 * |LвВБ * Lk|)
            * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
          apply mul_le_mul_of_nonneg_right _ ht0
          nlinarith [abs_nonneg (LвВБ * Lk)]

/-- **The character quad system** (Siegel brick A3-g2): for nontrivial quadratic
    `ѕЗвВБ mod qвВБ`, `ѕЗвВВ mod qвВВ` with nontrivial product, the Goldfeld coefficient system
    exists вАФ `LвВБ, Lk` with their approach rates and the full error package. -/
theorem quad_system_for_chars {qвВБ qвВВ : вДХ} (hqвВБ : 1 вЙ§ qвВБ) (hqвВВ : 1 вЙ§ qвВВ)
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1) :
    вИГ LвВБ Lk C : вДЭ,
      (вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn qвВБ ѕЗвВБ d / d| вЙ§ 2 * (qвВБ:вДЭ) / (y + 1))
      вИІ (вИА y : вДХ, 1 вЙ§ y вЖТ
          |Lk - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
              * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d / d|
            вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y)
      вИІ 0 вЙ§ C
      вИІ вИА n : вДХ, 1 вЙ§ n вЖТ
        |вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
            * toArith (charFn qвВВ ѕЗвВВ)
            * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m - LвВБ * Lk * n|
          вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
  have h1b := fun n => charFn_bound ѕЗвВБ hѕЗвВБ2 n
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  have hGвВБ := charFn_partial_sum_bound hqвВБ ѕЗвВБ hѕЗвВБ2 hѕЗвВБ1
  have hGвВВ := charFn_partial_sum_bound hqвВВ ѕЗвВВ hѕЗвВВ2 hѕЗвВВ1
  obtain вЯ®LвВБ, hLвВБвЯ© := log_mean_exists (charFn qвВБ ѕЗвВБ) ((qвВБ:вДЭ)) hGвВБ
  -- hH: commute the divisor asymptotic
  have hH : вИА M : вДХ, 1 вЙ§ M вЖТ
      |вИС n вИИ Icc 1 M, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)) n - LвВБ * M|
        вЙ§ (1 + 4 * (qвВБ:вДЭ)) * (Real.sqrt M + 1) := by
    intro M hM
    have hcomm : toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
        = toArith (charFn qвВБ ѕЗвВБ) * toArith (fun _ => (1:вДЭ)) := mul_comm _ _
    rw [hcomm]
    exact divisor_char_asymptotic (charFn qвВБ ѕЗвВБ) ((qвВБ:вДЭ)) LвВБ h1b hGвВБ hLвВБ M hM
  -- the product character is quadratic
  have hѕЗвВГ2 : ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
      * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ^ 2 = 1 := by
    rw [mul_pow, вЖР map_pow, вЖР map_pow, hѕЗвВБ2, hѕЗвВВ2, map_one, map_one, mul_one]
  have hqвВБвВВ : 1 вЙ§ qвВБ * qвВВ :=
    Nat.one_le_iff_ne_zero.mpr (Nat.mul_ne_zero (by omega) (by omega))
  have hGвВГ := charFn_partial_sum_bound hqвВБвВВ _ hѕЗвВГ2 hѕЗвВГ1
  -- the product bare function is 1-bounded with qвВБqвВВ-bounded partial sums
  have h12b : вИА n, |charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |charFn qвВБ ѕЗвВБ n| * |charFn qвВВ ѕЗвВВ n| вЙ§ 1 * 1 :=
        mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have hK2 : вИА t : вДХ, |вИС n вИИ Icc 1 t, (charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n)|
      вЙ§ (qвВБ:вДЭ) * (qвВВ:вДЭ) := by
    intro t
    have heq : вИС n вИИ Icc 1 t, (charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n)
        = вИС n вИИ Icc 1 t, charFn (qвВБ * qвВВ)
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) n :=
      Finset.sum_congr rfl (fun n _ => (charFn_mul_char ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 n).symm)
    rw [heq]
    have h := hGвВГ t
    push_cast at h
    exact h
  have hKb : вИА t : вДХ, |вИС n вИИ Icc 1 t, (toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) n|
      вЙ§ (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) * (Real.sqrt t + 1) :=
    fun t => bounded_conv_sqrt_bound (charFn qвВВ ѕЗвВВ)
      (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m) ((qвВВ:вДЭ)) ((qвВБ:вДЭ) * (qвВВ:вДЭ))
      h2b h12b hGвВВ hK2 t
  obtain вЯ®Lk, hLkвЯ© := sqrt_mean_exists
    (fun d => (toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d)
    (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) hKb
  obtain вЯ®C, hC0, hEвЯ© := quad_E_package (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ)
    ((qвВБ:вДЭ)) (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) LвВБ Lk h1b h2b hLвВБ
    (by positivity) hH hKb hLk
  exact вЯ®LвВБ, Lk, C, hLвВБ, hLk, hC0, hEвЯ©

/-- **Nonnegative partial sums force a nonnegative density** (Siegel brick A3-g3a):
    if `A(n) вЙ• 0` and `|A(n) вИТ ќїn| вЙ§ C¬Јn^{3/4}(1+log n)` then `ќї вЙ• 0` вАФ the error is
    `o(n)`, so a negative ќї would drag `A` negative. -/
theorem lam_nonneg (A : вДХ вЖТ вДЭ) (lam C : вДЭ) (hC0 : 0 вЙ§ C)
    (hA0 : вИА n : вДХ, 0 вЙ§ A n)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ
      |A n - lam * n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n))) :
    0 вЙ§ lam := by
  by_contra hneg
  push_neg at hneg
  have hќµ : (0:вДЭ) < -lam := by linarith
  set ќµ : вДЭ := -lam with hќµdef
  have hy0 : (0:вДЭ) вЙ§ 9 * C / ќµ + 1 := by positivity
  -- choose n with n^{1/8} вЙ• 9C/ќµ + 1
  obtain вЯ®nвВА, hnвВАвЯ© := exists_nat_ge ((9 * C / ќµ + 1) ^ (8:вДХ))
  set n : вДХ := max nвВА 1 with hn
  have hn1 : 1 вЙ§ n := le_max_right _ _
  have hn1r : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn1
  have hnr0 : (0:вДЭ) < (n:вДЭ) := by linarith
  have hnbig : ((9 * C / ќµ + 1) ^ (8:вДХ) : вДЭ) вЙ§ (n:вДЭ) := by
    calc ((9 * C / ќµ + 1) ^ (8:вДХ) : вДЭ) вЙ§ (nвВА:вДЭ) := hnвВА
      _ вЙ§ (n:вДЭ) := by
          have : nвВА вЙ§ n := le_max_left _ _
          exact_mod_cast this
  -- n^{1/8} вЙ• 9C/ќµ + 1
  have heighth : 9 * C / ќµ + 1 вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
    have h1 : ((9 * C / ќµ + 1) ^ (8:вДХ) : вДЭ) ^ ((1:вДЭ)/8) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) :=
      Real.rpow_le_rpow (by positivity) hnbig (by norm_num)
    have h2 : ((9 * C / ќµ + 1) ^ (8:вДХ) : вДЭ) ^ ((1:вДЭ)/8) = 9 * C / ќµ + 1 := by
      rw [вЖР Real.rpow_natCast (9 * C / ќµ + 1) 8, вЖР Real.rpow_mul hy0]
      norm_num
    rw [h2] at h1
    exact h1
  -- the E-bound at n: ќµ¬Јn вЙ§ 9C¬Јn^{7/8}
  have hlog : 1 + Real.log n вЙ§ 9 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
    have h1 : Real.log n вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) :=
      Real.log_le_rpow_div hnr0.le (by norm_num)
    have h2 : ((n:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) = 8 * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by ring
    have h3 : (1:вДЭ) вЙ§ ((n:вДЭ)) ^ ((1:вДЭ)/8) := Real.one_le_rpow hn1r (by norm_num)
    linarith [h1, h2.le, h2.ge, h3]
  have hcollect : ((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8) = ((n:вДЭ)) ^ ((7:вДЭ)/8) := by
    rw [вЖР Real.rpow_add hnr0]
    norm_num
  have hbound : ќµ * (n:вДЭ) вЙ§ 9 * C * ((n:вДЭ)) ^ ((7:вДЭ)/8) := by
    have h1 := (abs_le.mp (hE n hn1)).2
    have h2 : lam * n вЙ• A n - C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
      linarith
    have h3 : ќµ * (n:вДЭ) вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := by
      have := hA0 n
      rw [hќµdef]
      nlinarith [h2, this]
    calc ќµ * (n:вДЭ) вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)) := h3
      _ вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (9 * ((n:вДЭ)) ^ ((1:вДЭ)/8))) := by
          apply mul_le_mul_of_nonneg_left _ hC0
          apply mul_le_mul_of_nonneg_left hlog (Real.rpow_nonneg hnr0.le _)
      _ = 9 * C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * ((n:вДЭ)) ^ ((1:вДЭ)/8)) := by ring
      _ = 9 * C * ((n:вДЭ)) ^ ((7:вДЭ)/8) := by rw [hcollect]
  -- divide by n^{7/8}: ќµ¬Јn^{1/8} вЙ§ 9C
  have hsplit : (n:вДЭ) = ((n:вДЭ)) ^ ((7:вДЭ)/8) * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
    rw [вЖР Real.rpow_add hnr0]
    norm_num
  have h78pos : (0:вДЭ) < ((n:вДЭ)) ^ ((7:вДЭ)/8) := Real.rpow_pos_of_pos hnr0 _
  have hdiv : ќµ * ((n:вДЭ)) ^ ((1:вДЭ)/8) вЙ§ 9 * C := by
    have h1 : (ќµ * ((n:вДЭ)) ^ ((1:вДЭ)/8)) * ((n:вДЭ)) ^ ((7:вДЭ)/8)
        вЙ§ (9 * C) * ((n:вДЭ)) ^ ((7:вДЭ)/8) := by
      calc (ќµ * ((n:вДЭ)) ^ ((1:вДЭ)/8)) * ((n:вДЭ)) ^ ((7:вДЭ)/8)
          = ќµ * (((n:вДЭ)) ^ ((7:вДЭ)/8) * ((n:вДЭ)) ^ ((1:вДЭ)/8)) := by ring
        _ = ќµ * (n:вДЭ) := by rw [вЖР hsplit]
        _ вЙ§ 9 * C * ((n:вДЭ)) ^ ((7:вДЭ)/8) := hbound
    exact le_of_mul_le_mul_right h1 h78pos
  -- but ќµ¬Јn^{1/8} вЙ• ќµ¬Ј(9C/ќµ + 1) = 9C + ќµ
  have hlow : 9 * C + ќµ вЙ§ ќµ * ((n:вДЭ)) ^ ((1:вДЭ)/8) := by
    have h1 : ќµ * (9 * C / ќµ + 1) вЙ§ ќµ * ((n:вДЭ)) ^ ((1:вДЭ)/8) :=
      mul_le_mul_of_nonneg_left heighth hќµ.le
    have h2 : ќµ * (9 * C / ќµ + 1) = 9 * C + ќµ := by
      field_simp
    linarith [h1, h2.le, h2.ge]
  linarith [hdiv, hlow, hќµ]

open scoped LSeries.notation in
/-- The quadruple cast bridge exposed (A3-g3b-i): the вДВ-cast of the coefficient
    sequence is the triple `вНЯ`-convolution of the four cast factors. -/
lemma quad_cast_bridge (gвВБ gвВВ : вДХ вЖТ вДЭ) :
    (fun n => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ))
    = ((castFn (fun _ => (1:вДЭ)) вНЯ castFn gвВБ) вНЯ castFn gвВВ)
        вНЯ castFn (fun m => gвВБ m * gвВВ m) := by
  funext n
  have step1 : (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
      * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ)
      = ((fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ) m : вДЭ) : вДВ))
        вНЯ castFn (fun m => gвВБ m * gвВВ m)) n := by
    rw [ArithmeticFunction.mul_apply, LSeries.convolution_def]
    push_cast
    apply Finset.sum_congr rfl
    intro p hp
    rw [Nat.mem_divisorsAntidiagonal] at hp
    have h2 : p.2 вЙ† 0 := by
      intro h0
      rw [h0, mul_zero] at hp
      exact hp.2 hp.1.symm
    rw [castFn]
  rw [step1]
  have step2 : (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ) m : вДЭ) : вДВ))
      = (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ) m : вДЭ) : вДВ)) вНЯ castFn gвВВ := by
    funext m
    rw [ArithmeticFunction.mul_apply, LSeries.convolution_def]
    push_cast
    apply Finset.sum_congr rfl
    intro p hp
    rw [Nat.mem_divisorsAntidiagonal] at hp
    have h2 : p.2 вЙ† 0 := by
      intro h0
      rw [h0, mul_zero] at hp
      exact hp.2 hp.1.symm
    rw [castFn]
  rw [step2]
  have step3 : (fun m => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ) m : вДЭ) : вДВ))
      = castFn (fun _ => (1:вДЭ)) вНЯ castFn gвВБ := by
    funext m
    exact castFn_conv (fun _ => (1:вДЭ)) gвВБ m
  rw [step3]

/-- Summability of the quadruple coefficient series on `Re s > 1` (A3-g3b-ii). -/
lemma quad_LSeriesSummable (gвВБ gвВВ : вДХ вЖТ вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1) {s : вДВ} (hs : 1 < s.re) :
    LSeriesSummable (fun n => (((toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun m => gвВБ m * gвВВ m)) n : вДЭ) : вДВ)) s := by
  have honeb : вИА n : вДХ, |(fun _ : вДХ => (1:вДЭ)) n| вЙ§ 1 := fun n => by norm_num
  have hg12b : вИА n, |gвВБ n * gвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |gвВБ n| * |gвВВ n| вЙ§ 1 * 1 := mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  rw [quad_cast_bridge gвВБ gвВВ]
  exact (((castFn_summable (fun _ => (1:вДЭ)) honeb hs).convolution
    (castFn_summable gвВБ h1b hs)).convolution
    (castFn_summable gвВВ h2b hs)).convolution
    (castFn_summable (fun m => gвВБ m * gвВВ m) hg12b hs)

/-- The cast of `charFn` is the character's naive coefficient function away
    from `0` (A3-g3b-iii). -/
lemma castFn_charFn {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1)
    {n : вДХ} (hn : n вЙ† 0) :
    castFn (charFn q ѕЗ) n = ѕЗ ((n : ZMod q)) := by
  show ((toArith (charFn q ѕЗ) n : вДЭ) : вДВ) = ѕЗ ((n : ZMod q))
  rw [toArith_apply _ n hn, charFn_repr ѕЗ hѕЗ2 n]

/-- **The Goldfeld product identity at characters** (Siegel brick A3-g3b): on
    `Re s > 1` the quadruple L-series IS `ќґ¬ЈL(ѕЗвВБ)¬ЈL(ѕЗвВВ)¬ЈL(ѕЗвВБѕЗвВВ)`. -/
theorem quad_P_identity {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) {s : вДВ} (hs : 1 < s.re) :
    LSeries (fun n => (((toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
        * toArith (charFn qвВВ ѕЗвВВ)
        * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) n : вДЭ) : вДВ)) s
    = riemannZeta s * DirichletCharacter.LFunction ѕЗвВБ s
        * DirichletCharacter.LFunction ѕЗвВВ s
        * DirichletCharacter.LFunction
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) s := by
  have h1b := fun n => charFn_bound ѕЗвВБ hѕЗвВБ2 n
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  rw [quad_LSeries_eq (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ) h1b h2b hs]
  have hѕЗвВГ2 : ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
      * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ^ 2 = 1 := by
    rw [mul_pow, вЖР map_pow, вЖР map_pow, hѕЗвВБ2, hѕЗвВВ2, map_one, map_one, mul_one]
  have hz : LSeries (castFn (fun _ => (1:вДЭ))) s = riemannZeta s := by
    rw [вЖР LSeries_one_eq_riemannZeta hs]
    apply LSeries_congr
    intro n hn
    show ((toArith (fun _ => (1:вДЭ)) n : вДЭ) : вДВ) = (1 : вДХ вЖТ вДВ) n
    rw [toArith_apply _ n hn, Pi.one_apply, Complex.ofReal_one]
  have hL1 : LSeries (castFn (charFn qвВБ ѕЗвВБ)) s = DirichletCharacter.LFunction ѕЗвВБ s := by
    rw [DirichletCharacter.LFunction_eq_LSeries ѕЗвВБ hs]
    exact LSeries_congr (fun {n} hn => castFn_charFn ѕЗвВБ hѕЗвВБ2 hn) s
  have hL2 : LSeries (castFn (charFn qвВВ ѕЗвВВ)) s = DirichletCharacter.LFunction ѕЗвВВ s := by
    rw [DirichletCharacter.LFunction_eq_LSeries ѕЗвВВ hs]
    exact LSeries_congr (fun {n} hn => castFn_charFn ѕЗвВВ hѕЗвВВ2 hn) s
  have hL3 : LSeries (castFn (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) s
      = DirichletCharacter.LFunction
          ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
            * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) s := by
    rw [DirichletCharacter.LFunction_eq_LSeries _ hs]
    apply LSeries_congr
    intro n hn
    show ((toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m) n : вДЭ) : вДВ) = _
    rw [toArith_apply _ n hn, вЖР charFn_mul_char ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 n,
      charFn_repr _ hѕЗвВГ2 n]
  rw [hz, hL1, hL2, hL3]

/-- The four-factor product is analytic on the slit half-plane (A3-g3b-iv). -/
lemma quad_P_differentiableAt {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1)
    (s : вДВ) (hs1 : s вЙ† 1) :
    DifferentiableAt вДВ (fun w => riemannZeta w * DirichletCharacter.LFunction ѕЗвВБ w
      * DirichletCharacter.LFunction ѕЗвВВ w
      * DirichletCharacter.LFunction
          ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
            * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) w) s := by
  apply DifferentiableAt.mul
  ¬Ј apply DifferentiableAt.mul
    ¬Ј apply DifferentiableAt.mul
      ¬Ј exact differentiableAt_riemannZeta hs1
      ¬Ј exact (DirichletCharacter.differentiable_LFunction hѕЗвВБ1).differentiableAt
    ¬Ј exact (DirichletCharacter.differentiable_LFunction hѕЗвВВ1).differentiableAt
  ¬Ј exact (DirichletCharacter.differentiable_LFunction hѕЗвВГ1).differentiableAt

/-- **SIEGEL'S ќї LOWER BOUND AT CHARACTERS** (Siegel brick A3-g3c): if the product
    `ќґ¬ЈL(ѕЗвВБ)¬ЈL(ѕЗвВВ)¬ЈL(ѕЗвВБѕЗвВВ)` vanishes at a real `ќ≤ вИИ (9/10, 1)` вАФ e.g. at a real zero
    of `L(¬Ј,ѕЗвВБ)` вАФ then `ќї = LвВБ¬ЈLk > (1вИТќ≤)/(26¬Јx^{1вИТќ≤})` for every admissible `x`,
    with `LвВБ, Lk` carrying their partial-sum approach rates. -/
theorem siegel_lambda_lower_for_chars {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1)
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1)
    (hzero : DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ)) = 0) :
    вИГ LвВБ Lk C : вДЭ, 0 вЙ§ LвВБ * Lk вИІ 0 вЙ§ C
      вИІ (вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn qвВБ ѕЗвВБ d / d| вЙ§ 2 * (qвВБ:вДЭ) / (y + 1))
      вИІ (вИА y : вДХ, 1 вЙ§ y вЖТ
          |Lk - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
              * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d / d|
            вЙ§ 7 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y)
      вИІ вИА x : вДХ, 2 вЙ§ x вЖТ ((820 * (C + 1)) ^ (40:вДХ) : вДЭ) вЙ§ (x:вДЭ) вЖТ
          1 - ќ≤ вЙ§ 26 * (LвВБ * Lk) * ((x:вДЭ)) ^ (1 - ќ≤) := by
  have hqвВБ : 1 вЙ§ qвВБ := Nat.one_le_iff_ne_zero.mpr (NeZero.ne qвВБ)
  have hqвВВ : 1 вЙ§ qвВВ := Nat.one_le_iff_ne_zero.mpr (NeZero.ne qвВВ)
  obtain вЯ®LвВБ, Lk, C, hr1, hr2, hC0, hEsysвЯ© :=
    quad_system_for_chars hqвВБ hqвВВ ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 hѕЗвВБ1 hѕЗвВВ1 hѕЗвВГ1
  obtain вЯ®ha0, ha1вЯ© := quad_conv_nonneg (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ)
    (charFn_mul ѕЗвВБ hѕЗвВБ2) (charFn_mul ѕЗвВВ hѕЗвВВ2)
    (charFn_one ѕЗвВБ) (charFn_one ѕЗвВВ)
    (charFn_values ѕЗвВБ hѕЗвВБ2) (charFn_values ѕЗвВВ hѕЗвВВ2)
  have h1b := fun n => charFn_bound ѕЗвВБ hѕЗвВБ2 n
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  -- the E-function and its properties
  have hA0 : вИА n : вДХ, 0 вЙ§ вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ))
      * toArith (charFn qвВБ ѕЗвВБ) * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m :=
    fun n => Finset.sum_nonneg (fun m _ => ha0 m)
  have hlam : 0 вЙ§ LвВБ * Lk := by
    apply lam_nonneg (fun n => вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ))
        * toArith (charFn qвВБ ѕЗвВБ) * toArith (charFn qвВВ ѕЗвВВ)
        * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m)
      (LвВБ * Lk) C hC0 hA0
    intro n hn
    exact hEsys n hn
  refine вЯ®LвВБ, Lk, C, hlam, hC0, hr1, hr2, ?_вЯ©
  intro x hx hxC
  apply siegel_lambda_lower
    (fun n => (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
      * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) n)
    (LвВБ * Lk)
    (fun n => (вИС m вИИ Icc 1 n, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
      * toArith (charFn qвВВ ѕЗвВВ)
      * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m) - LвВБ * Lk * n)
    C ha0 ha1 hlam
    (fun n => by ring)
    hC0
    (by
      show (вИС m вИИ Icc 1 0, (toArith (fun _ => (1:вДЭ)) * toArith (charFn qвВБ ѕЗвВБ)
        * toArith (charFn qвВВ ѕЗвВВ)
        * toArith (fun k => charFn qвВБ ѕЗвВБ k * charFn qвВВ ѕЗвВВ k)) m) - LвВБ * Lk * (0:вДХ) = 0
      rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty, Nat.cast_zero, mul_zero,
        sub_zero])
    (fun n hn => hEsys n hn)
    (fun s hs => quad_LSeriesSummable (charFn qвВБ ѕЗвВБ) (charFn qвВВ ѕЗвВВ) h1b h2b hs)
    (fun w => riemannZeta w * DirichletCharacter.LFunction ѕЗвВБ w
      * DirichletCharacter.LFunction ѕЗвВВ w
      * DirichletCharacter.LFunction
          ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
            * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) w)
    (fun s _ hs1 => quad_P_differentiableAt ѕЗвВБ ѕЗвВВ hѕЗвВБ1 hѕЗвВВ1 hѕЗвВГ1 s hs1)
    (fun s hs => quad_P_identity ѕЗвВБ ѕЗвВВ hѕЗвВБ2 hѕЗвВВ2 hs)
    hќ≤1 hќ≤2
    (by
      show riemannZeta ((ќ≤:вДВ)) * DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ))
        * DirichletCharacter.LFunction ѕЗвВВ ((ќ≤:вДВ))
        * DirichletCharacter.LFunction
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ((ќ≤:вДВ)) = 0
      rw [hzero, mul_zero, zero_mul, zero_mul])
    x hx hxC

/-- **The generalized Dirichlet test** (Siegel brick A5-a): `q`-bounded partial sums
    against ANY nonneg antitone weight: `|ќ£_{y<dвЙ§z} g(d)w(d)| вЙ§ 2q¬Јw(y+1)` вАФ the
    uniform-in-`s` engine for the `L(1,ѕЗ)` identifications. -/
lemma abel_tail_general (g : вДХ вЖТ вДЭ) (q : вДЭ) (w : вДХ вЖТ вДЭ)
    (hG : вИА t : вДХ, |вИС n вИИ Icc 1 t, g n| вЙ§ q)
    (hw0 : вИА d, 0 вЙ§ w d) (hwa : вИА d, w (d + 1) вЙ§ w d)
    (y : вДХ) : вИА z : вДХ, y вЙ§ z вЖТ
    |вИС d вИИ Icc (y + 1) z, g d * w d| вЙ§ 2 * q * w (y + 1) := by
  have hq : 0 вЙ§ q := le_trans (abs_nonneg _) (hG 0)
  -- the general Abel window identity
  have hwindow : вИА z : вДХ, y вЙ§ z вЖТ
      вИС d вИИ Icc (y + 1) z, g d * w d
      = вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))
        + (вИС n вИИ Icc 1 z, g n) * w (z + 1) - (вИС n вИИ Icc 1 y, g n) * w (y + 1) := by
    intro z
    induction z with
    | zero =>
      intro hy0
      interval_cases y
      simp
    | succ m ih =>
      intro hym
      rcases Nat.lt_or_ge m y with hlt | hge
      ¬Ј have hy' : y = m + 1 := by omega
        subst hy'
        have hempty : Icc (m + 1 + 1) (m + 1) = (вИЕ : Finset вДХ) :=
          Finset.Icc_eq_empty (by omega)
        rw [hempty, Finset.sum_empty, Finset.sum_empty]
        ring
      ¬Ј have hins : Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) := by
          ext d
          simp only [Finset.mem_insert, Finset.mem_Icc]
          omega
        have hnotmem : (m + 1) вИЙ Icc (y + 1) m := by
          simp only [Finset.mem_Icc]
          omega
        rw [hins, Finset.sum_insert hnotmem, Finset.sum_insert hnotmem, ih hge]
        have hS : вИС n вИИ Icc 1 (m + 1), g n = g (m + 1) + вИС n вИИ Icc 1 m, g n := by
          rw [show Icc 1 (m + 1) = insert (m + 1) (Icc 1 m) from by
            ext d
            simp only [Finset.mem_insert, Finset.mem_Icc]
            omega, Finset.sum_insert (by
              simp only [Finset.mem_Icc]
              omega)]
        rw [hS]
        ring
  -- the weight telescope
  have htel : вИА z : вДХ, y вЙ§ z вЖТ
      вИС d вИИ Icc (y + 1) z, (w d - w (d + 1)) = w (y + 1) - w (z + 1) := by
    intro z
    induction z with
    | zero =>
      intro hy0
      interval_cases y
      simp
    | succ m ih =>
      intro hym
      rcases Nat.lt_or_ge m y with hlt | hge
      ¬Ј have hy' : y = m + 1 := by omega
        subst hy'
        rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty]
        ring
      ¬Ј rw [show Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) from by
          ext d
          simp only [Finset.mem_insert, Finset.mem_Icc]
          omega, Finset.sum_insert (by
            simp only [Finset.mem_Icc]
            omega), ih hge]
        ring
  intro z hz
  rw [hwindow z hz]
  have hterm : вИА d вИИ Icc (y + 1) z,
      |(вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))| вЙ§ q * (w d - w (d + 1)) := by
    intro d _
    rw [abs_mul, abs_of_nonneg (show (0:вДЭ) вЙ§ w d - w (d + 1) from by linarith [hwa d])]
    apply mul_le_mul_of_nonneg_right (hG d)
    linarith [hwa d]
  calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))
        + (вИС n вИИ Icc 1 z, g n) * w (z + 1) - (вИС n вИИ Icc 1 y, g n) * w (y + 1)|
      вЙ§ |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))|
        + |(вИС n вИИ Icc 1 z, g n) * w (z + 1)| + |(вИС n вИИ Icc 1 y, g n) * w (y + 1)| := by
        have h1 := abs_add_le (вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))
          + (вИС n вИИ Icc 1 z, g n) * w (z + 1)) (-((вИС n вИИ Icc 1 y, g n) * w (y + 1)))
        have h2 := abs_add_le (вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1)))
          ((вИС n вИИ Icc 1 z, g n) * w (z + 1))
        rw [abs_neg, вЖР sub_eq_add_neg] at h1
        linarith
    _ вЙ§ q * (w (y + 1) - w (z + 1)) + q * w (z + 1) + q * w (y + 1) := by
        have h1 : |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))|
            вЙ§ q * (w (y + 1) - w (z + 1)) := by
          calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))|
              вЙ§ вИС d вИИ Icc (y + 1) z, |(вИС n вИИ Icc 1 d, g n) * (w d - w (d + 1))| :=
                Finset.abs_sum_le_sum_abs _ _
            _ вЙ§ вИС d вИИ Icc (y + 1) z, q * (w d - w (d + 1)) :=
                Finset.sum_le_sum hterm
            _ = q * вИС d вИИ Icc (y + 1) z, (w d - w (d + 1)) := by
                rw [Finset.mul_sum]
            _ = q * (w (y + 1) - w (z + 1)) := by rw [htel z hz]
        have h2 : |(вИС n вИИ Icc 1 z, g n) * w (z + 1)| вЙ§ q * w (z + 1) := by
          rw [abs_mul, abs_of_nonneg (hw0 _)]
          exact mul_le_mul_of_nonneg_right (hG z) (hw0 _)
        have h3 : |(вИС n вИИ Icc 1 y, g n) * w (y + 1)| вЙ§ q * w (y + 1) := by
          rw [abs_mul, abs_of_nonneg (hw0 _)]
          exact mul_le_mul_of_nonneg_right (hG y) (hw0 _)
        linarith
    _ вЙ§ 2 * q * w (y + 1) := by
        have := hw0 (z + 1)
        linarith

/-- Character sums against `d^{вИТs}` decay at the `s = 1` rate, uniformly in
    `s вЙ• 1` (Siegel brick A5-b1). -/
lemma char_rpow_tail_rate {q : вДХ} (hq : 1 вЙ§ q) (ѕЗ : DirichletCharacter вДВ q)
    (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1) {s : вДЭ} (hs : 1 вЙ§ s) (y : вДХ) :
    вИА z : вДХ, y вЙ§ z вЖТ
    |вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s)| вЙ§ 2 * (q:вДЭ) / (y + 1) := by
  intro z hz
  set w : вДХ вЖТ вДЭ := fun d => if d = 0 then 1 else ((d:вДЭ)) ^ (-s) with hw
  have hw0 : вИА d, 0 вЙ§ w d := by
    intro d
    rw [hw]
    rcases eq_or_ne d 0 with rfl | hd
    ¬Ј simp
    ¬Ј simp only [if_neg hd]
      exact Real.rpow_nonneg (Nat.cast_nonneg _) _
  have hwa : вИА d, w (d + 1) вЙ§ w d := by
    intro d
    rw [hw]
    rcases eq_or_ne d 0 with rfl | hd
    ¬Ј norm_num [Real.one_rpow]
    ¬Ј simp only [if_neg hd, if_neg (by omega : d + 1 вЙ† 0)]
      have hd0 : (0:вДЭ) < (d:вДЭ) := by
        have : (0:вДХ) < d := by omega
        exact_mod_cast this
      apply Real.rpow_le_rpow_of_nonpos hd0 (by push_cast; linarith)
      linarith
  have hG := charFn_partial_sum_bound hq ѕЗ hѕЗ2 hѕЗ1
  have h := abel_tail_general (charFn q ѕЗ) ((q:вДЭ)) w hG hw0 hwa y z hz
  have hcongr : вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * w d
      = вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) := by
    apply Finset.sum_congr rfl
    intro d hd
    rw [Finset.mem_Icc] at hd
    rw [hw]
    simp only [if_neg (by omega : d вЙ† 0)]
  rw [hcongr] at h
  have hwy : w (y + 1) вЙ§ 1 / ((y:вДЭ) + 1) := by
    rw [hw]
    simp only [if_neg (by omega : y + 1 вЙ† 0)]
    have hy0 : (1:вДЭ) вЙ§ ((y + 1 : вДХ):вДЭ) := by
      push_cast
      linarith [Nat.cast_nonneg (ќ± := вДЭ) y]
    calc ((y + 1 : вДХ):вДЭ) ^ (-s) вЙ§ ((y + 1 : вДХ):вДЭ) ^ (-(1:вДЭ)) :=
          Real.rpow_le_rpow_of_exponent_le hy0 (by linarith)
      _ = 1 / ((y:вДЭ) + 1) := by
          rw [Real.rpow_neg_one, вЖР one_div]
          push_cast
          ring_nf
  have hq0 : (0:вДЭ) вЙ§ (q:вДЭ) := Nat.cast_nonneg q
  calc |вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s)|
      вЙ§ 2 * (q:вДЭ) * w (y + 1) := h
    _ вЙ§ 2 * (q:вДЭ) * (1 / ((y:вДЭ) + 1)) := by
        apply mul_le_mul_of_nonneg_left hwy (by positivity)
    _ = 2 * (q:вДЭ) / ((y:вДЭ) + 1) := by ring

/-- **The real representation of `L(s,ѕЗ)` with the uniform Abel rate**
    (Siegel brick A5-b2): for real `s > 1` there is a real value `вДУ` with
    `L(s,ѕЗ) = вДУ` and `|вДУ вИТ ќ£_{dвЙ§y}ѕЗ(d)d^{вИТs}| вЙ§ 2q/(y+1)` for every `y`. -/
theorem LFunction_real_rate {q : вДХ} [NeZero q] (hq : 1 вЙ§ q)
    (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1)
    {s : вДЭ} (hs : 1 < s) :
    вИГ вДУ : вДЭ, DirichletCharacter.LFunction ѕЗ ((s:вДВ)) = ((вДУ : вДЭ) : вДВ)
      вИІ вИА y : вДХ, |вДУ - вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s)| вЙ§ 2 * (q:вДЭ) / (y + 1) := by
  -- the real partial sums are Cauchy with the explicit rate
  set S : вДХ вЖТ вДЭ := fun z => вИС d вИИ Icc 1 z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) with hS
  have hsplit : вИА y z : вДХ, y вЙ§ z вЖТ S z - S y
      = вИС d вИИ Icc (y + 1) z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) := by
    intro y z hyz
    rw [hS]
    simp only
    rw [show Icc 1 z = Icc 1 y вИ™ Icc (y + 1) z from by
      ext d
      simp only [Finset.mem_union, Finset.mem_Icc]
      omega, Finset.sum_union (by
        rw [Finset.disjoint_left]
        intro d hd hd2
        rw [Finset.mem_Icc] at hd hd2
        omega)]
    ring
  have hdiff : вИА y z : вДХ, y вЙ§ z вЖТ |S z - S y| вЙ§ 2 * (q:вДЭ) / (y + 1) := by
    intro y z hyz
    rw [hsplit y z hyz]
    exact char_rpow_tail_rate hq ѕЗ hѕЗ2 hѕЗ1 hs.le y z hyz
  have hb0 : Tendsto (fun y : вДХ => 2 * (q:вДЭ) / ((y:вДЭ) + 1)) atTop (nhds 0) := by
    apply Tendsto.div_atTop tendsto_const_nhds
    exact tendsto_atTop_add_const_right _ _ tendsto_natCast_atTop_atTop
  have hcauchy : CauchySeq S := by
    apply cauchySeq_of_le_tendsto_0 (b := fun y : вДХ => 2 * (q:вДЭ) / ((y:вДЭ) + 1)) _ hb0
    intro m n N hm hn
    rw [Real.dist_eq]
    rcases Nat.le_total m n with h | h
    ¬Ј rw [abs_sub_comm]
      calc |S n - S m| вЙ§ 2 * (q:вДЭ) / ((m:вДЭ) + 1) := hdiff m n h
        _ вЙ§ 2 * (q:вДЭ) / ((N:вДЭ) + 1) := by
            apply div_le_div_of_nonneg_left (by positivity) (by positivity)
            push_cast
            have : (N:вДЭ) вЙ§ (m:вДЭ) := by exact_mod_cast hm
            linarith
    ¬Ј calc |S m - S n| вЙ§ 2 * (q:вДЭ) / ((n:вДЭ) + 1) := hdiff n m h
        _ вЙ§ 2 * (q:вДЭ) / ((N:вДЭ) + 1) := by
            apply div_le_div_of_nonneg_left (by positivity) (by positivity)
            push_cast
            have : (N:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
            linarith
  obtain вЯ®вДУ, hвДУвЯ© := cauchySeq_tendsto_of_complete hcauchy
  refine вЯ®вДУ, ?_, ?_вЯ©
  ¬Ј -- LFunction = ofReal вДУ: both are limits of ofReal вИШ S
    have hre : ((s:вДВ)).re = s := Complex.ofReal_re s
    have hs1 : 1 < ((s:вДВ)).re := by rw [hre]; exact hs
    have hLS : DirichletCharacter.LFunction ѕЗ ((s:вДВ)) = LSeries (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)) :=
      DirichletCharacter.LFunction_eq_LSeries ѕЗ hs1
    -- LSeries summability from |ѕЗ| вЙ§ 1
    have hѕЗb : вИА n : вДХ, n вЙ† 0 вЖТ вАЦѕЗ ((n : ZMod q))вАЦ вЙ§ 1 := by
      intro n _
      rw [вЖР charFn_repr ѕЗ hѕЗ2 n, Complex.norm_real, Real.norm_eq_abs]
      exact charFn_bound ѕЗ hѕЗ2 n
    have hsummable : LSeriesSummable (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)) :=
      LSeriesSummable_of_bounded_of_one_lt_re (m := 1) hѕЗb hs1
    -- вДВ partial sums equal ofReal вИШ S
    have hterm_eq : вИА n : вДХ, 1 вЙ§ n вЖТ
        LSeries.term (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)) n
          = ((charFn q ѕЗ n * ((n:вДЭ)) ^ (-s) : вДЭ) : вДВ) := by
      intro n hn
      rw [LSeries.term_of_ne_zero (by omega), div_eq_mul_inv, вЖР Complex.cpow_neg,
        cpow_real_cast n s, вЖР charFn_repr ѕЗ hѕЗ2 n]
      push_cast
      ring
    have hpartial : Tendsto (fun z : вДХ => ((S z : вДЭ) : вДВ)) atTop
        (nhds (LSeries (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)))) := by
      have h1 : Tendsto (fun z : вДХ => вИС n вИИ range (z + 1),
          LSeries.term (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)) n) atTop
          (nhds (LSeries (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)))) := by
        have := hsummable.hasSum.tendsto_sum_nat
        exact this.comp (tendsto_add_atTop_nat 1)
      apply h1.congr
      intro z
      show вИС n вИИ range (z + 1), LSeries.term (fun n => ѕЗ ((n : ZMod q))) ((s:вДВ)) n
        = ((вИС d вИИ Icc 1 z, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) : вДЭ) : вДВ)
      rw [show range (z + 1) = insert 0 (Icc 1 z) from by
        ext d
        simp only [Finset.mem_insert, Finset.mem_range, Finset.mem_Icc]
        omega, Finset.sum_insert (by
          simp only [Finset.mem_Icc]
          omega), LSeries.term_zero, zero_add, Complex.ofReal_sum]
      exact Finset.sum_congr rfl (fun n hn => by
        rw [Finset.mem_Icc] at hn
        exact hterm_eq n hn.1)
    have hofReal : Tendsto (fun z : вДХ => ((S z : вДЭ) : вДВ)) atTop (nhds ((вДУ : вДВ))) :=
      (Complex.continuous_ofReal.tendsto вДУ).comp hвДУ
    rw [hLS]
    exact tendsto_nhds_unique hpartial hofReal
  ¬Ј -- the rate transfers to the limit
    intro y
    have h1 : вИА z : вДХ, y вЙ§ z вЖТ |S z - S y| вЙ§ 2 * (q:вДЭ) / (y + 1) := fun z hz => hdiff y z hz
    have h2 : Tendsto (fun z : вДХ => S z - S y) atTop (nhds (вДУ - S y)) :=
      hвДУ.sub tendsto_const_nhds
    have h3 : |вДУ - S y| вЙ§ 2 * (q:вДЭ) / (y + 1) := by
      apply le_of_tendsto (h2.abs)
      filter_upwards [eventually_ge_atTop y] with z hz
      exact h1 z hz
    exact h3

/-- **`LвВБ = L(1,ѕЗ)`** (Siegel brick A5-c): the abstract hyperbola limit with the
    `2q/(y+1)` rate IS the analytic `L`-value at `1` вАФ squeeze along `s вЖТ 1вБЇ`. -/
theorem L1_eq_LFunction_one {q : вДХ} [NeZero q] (hq : 1 вЙ§ q)
    (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1)
    (LвВБ : вДЭ)
    (hr : вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, charFn q ѕЗ d / d| вЙ§ 2 * (q:вДЭ) / (y + 1)) :
    DirichletCharacter.LFunction ѕЗ 1 = ((LвВБ : вДЭ) : вДВ) := by
  -- Step 1: the boundary rate at s = 1
  have hy : вИА y : вДХ, вАЦDirichletCharacter.LFunction ѕЗ 1
      - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d / d : вДЭ) : вДВ)вАЦ вЙ§ 2 * (q:вДЭ) / (y + 1) := by
    intro y
    -- the finite sum at exponent вИТs, as a continuous function of s
    have hcont_term : вИА d : вДХ, d вИИ Icc 1 y вЖТ
        Continuous (fun s : вДЭ => charFn q ѕЗ d * ((d:вДЭ)) ^ (-s)) := by
      intro d hd
      rw [Finset.mem_Icc] at hd
      have hd0 : (0:вДЭ) < (d:вДЭ) := by
        have : (0:вДХ) < d := by omega
        exact_mod_cast this
      have hrw : (fun s : вДЭ => ((d:вДЭ)) ^ (-s))
          = fun s : вДЭ => Real.exp (Real.log d * (-s)) := by
        funext s
        rw [Real.rpow_def_of_pos hd0]
      apply Continuous.mul continuous_const
      rw [hrw]
      exact Real.continuous_exp.comp (continuous_const.mul continuous_neg)
    have hcont_sum : Continuous (fun s : вДЭ =>
        вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s)) :=
      continuous_finset_sum _ (fun d hd => hcont_term d hd)
    -- the two limits along s вЖТ 1вБЇ
    have hofReal1 : Tendsto (fun s : вДЭ => ((s:вДЭ):вДВ)) (nhdsWithin 1 (Set.Ioi 1))
        (nhds ((1:вДВ))) := by
      have h := (Complex.continuous_ofReal.tendsto (1:вДЭ)).mono_left
        (nhdsWithin_le_nhds (s := Set.Ioi (1:вДЭ)))
      simpa using h
    have htends1 : Tendsto (fun s : вДЭ => DirichletCharacter.LFunction ѕЗ ((s:вДВ)))
        (nhdsWithin 1 (Set.Ioi 1)) (nhds (DirichletCharacter.LFunction ѕЗ 1)) := by
      have hc : ContinuousAt (DirichletCharacter.LFunction ѕЗ) 1 :=
        (DirichletCharacter.differentiable_LFunction hѕЗ1).continuous.continuousAt
      exact hc.tendsto.comp hofReal1
    have htends2 : Tendsto (fun s : вДЭ =>
        ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) : вДЭ) : вДВ))
        (nhdsWithin 1 (Set.Ioi 1))
        (nhds ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-(1:вДЭ)) : вДЭ) : вДВ)) := by
      have h1 : Tendsto (fun s : вДЭ => вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s))
          (nhdsWithin 1 (Set.Ioi 1))
          (nhds (вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-(1:вДЭ)))) :=
        (hcont_sum.tendsto 1).mono_left nhdsWithin_le_nhds
      exact (Complex.continuous_ofReal.tendsto _).comp h1
    -- the eventual bound
    have hev : вИАбґ† s : вДЭ in nhdsWithin 1 (Set.Ioi 1),
        вАЦDirichletCharacter.LFunction ѕЗ ((s:вДВ))
          - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) : вДЭ) : вДВ)вАЦ
        вЙ§ 2 * (q:вДЭ) / (y + 1) := by
      filter_upwards [self_mem_nhdsWithin] with s hs
      rw [Set.mem_Ioi] at hs
      obtain вЯ®вДУ, hL, hrateвЯ© := LFunction_real_rate hq ѕЗ hѕЗ2 hѕЗ1 hs
      rw [hL, вЖР Complex.ofReal_sub, Complex.norm_real, Real.norm_eq_abs]
      exact hrate y
    -- pass to the limit
    have hlim : Tendsto (fun s : вДЭ => вАЦDirichletCharacter.LFunction ѕЗ ((s:вДВ))
        - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-s) : вДЭ) : вДВ)вАЦ)
        (nhdsWithin 1 (Set.Ioi 1))
        (nhds вАЦDirichletCharacter.LFunction ѕЗ 1
          - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-(1:вДЭ)) : вДЭ) : вДВ)вАЦ) :=
      (htends1.sub htends2).norm
    have hle := le_of_tendsto hlim hev
    have hconv : вИС d вИИ Icc 1 y, charFn q ѕЗ d * ((d:вДЭ)) ^ (-(1:вДЭ))
        = вИС d вИИ Icc 1 y, charFn q ѕЗ d / d := by
      apply Finset.sum_congr rfl
      intro d _
      rw [Real.rpow_neg_one, div_eq_mul_inv]
    rw [hconv] at hle
    exact hle
  -- Step 2: combine with the abstract rate and squeeze to equality
  have hcomb : вИА y : вДХ, вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ
      вЙ§ 4 * (q:вДЭ) / (y + 1) := by
    intro y
    have h1 := hy y
    have h2 : вАЦ((вИС d вИИ Icc 1 y, charFn q ѕЗ d / d : вДЭ) : вДВ) - ((LвВБ : вДЭ) : вДВ)вАЦ
        вЙ§ 2 * (q:вДЭ) / (y + 1) := by
      rw [вЖР Complex.ofReal_sub, Complex.norm_real, Real.norm_eq_abs, abs_sub_comm]
      exact hr y
    calc вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ
        вЙ§ вАЦDirichletCharacter.LFunction ѕЗ 1
            - ((вИС d вИИ Icc 1 y, charFn q ѕЗ d / d : вДЭ) : вДВ)вАЦ
          + вАЦ((вИС d вИИ Icc 1 y, charFn q ѕЗ d / d : вДЭ) : вДВ) - ((LвВБ : вДЭ) : вДВ)вАЦ :=
          norm_sub_le_norm_sub_add_norm_sub _ _ _
      _ вЙ§ 2 * (q:вДЭ) / (y + 1) + 2 * (q:вДЭ) / (y + 1) := add_le_add h1 h2
      _ = 4 * (q:вДЭ) / (y + 1) := by ring
  by_contra hne
  have hpos : 0 < вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ := by
    rw [norm_pos_iff, sub_ne_zero]
    exact hne
  obtain вЯ®y, hy'вЯ© := exists_nat_gt (4 * (q:вДЭ)
    / вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ)
  have h1 := hcomb y
  have hy1 : (0:вДЭ) < (y:вДЭ) + 1 := by positivity
  rw [div_lt_iffвВА hpos] at hy'
  have h2 : 4 * (q:вДЭ) / ((y:вДЭ) + 1)
      < вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ := by
    rw [div_lt_iffвВА hy1]
    calc 4 * (q:вДЭ) < (y:вДЭ) * вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ := hy'
      _ вЙ§ вАЦDirichletCharacter.LFunction ѕЗ 1 - ((LвВБ : вДЭ) : вДВ)вАЦ * ((y:вДЭ) + 1) := by
          nlinarith [hpos, Nat.cast_nonneg (ќ± := вДЭ) y]
  linarith

/-- **The вИЪ-size partial sums against `d^{вИТs}` decay at the `1/вИЪy` rate, uniformly
    in `s вИИ [1,2]`** (Siegel brick A5-d1) вАФ the convolution-side twin of
    `char_rpow_tail_rate`, powering the `Lk` identification. -/
lemma conv_rpow_tail_rate (k : вДХ вЖТ вДЭ) (B : вДЭ)
    (hK : вИА t : вДХ, |вИС n вИИ Icc 1 t, k n| вЙ§ B * (Real.sqrt t + 1))
    {s : вДЭ} (hs1 : 1 вЙ§ s) (hs2 : s вЙ§ 2) (y : вДХ) (hy1 : 1 вЙ§ y) :
    вИА z : вДХ, y вЙ§ z вЖТ
    |вИС d вИИ Icc (y + 1) z, k d * ((d:вДЭ)) ^ (-s)| вЙ§ 30 * B / Real.sqrt y := by
  have hB0 : 0 вЙ§ B := by
    have h0 := hK 0
    rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty, abs_zero,
      Nat.cast_zero, Real.sqrt_zero, zero_add, mul_one] at h0
    exact h0
  set w : вДХ вЖТ вДЭ := fun d => ((d:вДЭ)) ^ (-s) with hw
  -- the Abel window identity (generic in w)
  have hwindow : вИА z : вДХ, y вЙ§ z вЖТ
      вИС d вИИ Icc (y + 1) z, k d * w d
      = вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))
        + (вИС n вИИ Icc 1 z, k n) * w (z + 1) - (вИС n вИИ Icc 1 y, k n) * w (y + 1) := by
    intro z
    induction z with
    | zero =>
      intro hy0
      omega
    | succ m ih =>
      intro hym
      rcases Nat.lt_or_ge m y with hlt | hge
      ¬Ј have hy' : y = m + 1 := by omega
        subst hy'
        have hempty : Icc (m + 1 + 1) (m + 1) = (вИЕ : Finset вДХ) :=
          Finset.Icc_eq_empty (by omega)
        rw [hempty, Finset.sum_empty, Finset.sum_empty]
        ring
      ¬Ј have hins : Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) := by
          ext d
          simp only [Finset.mem_insert, Finset.mem_Icc]
          omega
        have hnotmem : (m + 1) вИЙ Icc (y + 1) m := by
          simp only [Finset.mem_Icc]
          omega
        rw [hins, Finset.sum_insert hnotmem, Finset.sum_insert hnotmem, ih hge]
        have hS : вИС n вИИ Icc 1 (m + 1), k n = k (m + 1) + вИС n вИИ Icc 1 m, k n := by
          rw [show Icc 1 (m + 1) = insert (m + 1) (Icc 1 m) from by
            ext d
            simp only [Finset.mem_insert, Finset.mem_Icc]
            omega, Finset.sum_insert (by
              simp only [Finset.mem_Icc]
              omega)]
        rw [hS]
        ring
  -- per-term kernel bound: |S d|(w d вИТ w(d+1)) вЙ§ 4B/(dвИЪd) for d вЙ• 1
  have hkernel : вИА d : вДХ, 1 вЙ§ d вЖТ
      |(вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))| вЙ§ 4 * B * (1 / ((d:вДЭ) * Real.sqrt d)) := by
    intro d hd
    have hd0 : (0:вДЭ) < (d:вДЭ) := by
      have : (0:вДХ) < d := hd
      exact_mod_cast this
    have hd1r : (1:вДЭ) вЙ§ (d:вДЭ) := by exact_mod_cast hd
    have hsq1 : (1:вДЭ) вЙ§ Real.sqrt d := Real.one_le_sqrt.mpr hd1r
    have hќФ0 : 0 вЙ§ w d - w (d + 1) := by
      rw [hw]
      simp only
      have : (((d + 1 : вДХ)):вДЭ) ^ (-s) вЙ§ ((d:вДЭ)) ^ (-s) := by
        apply Real.rpow_le_rpow_of_nonpos hd0 (by push_cast; linarith)
        linarith
      push_cast at this вКҐ
      linarith
    have hќФle : w d - w (d + 1) вЙ§ 2 * ((d:вДЭ)) ^ (-(2:вДЭ)) := by
      rw [hw]
      simp only
      have h1 := rpow_diff_le d hd s (by linarith)
      have h2 : ((d:вДЭ)) ^ (-s - 1) вЙ§ ((d:вДЭ)) ^ (-(2:вДЭ)) := by
        apply Real.rpow_le_rpow_of_exponent_le hd1r
        linarith
      have h3 : s * ((d:вДЭ)) ^ (-s - 1) вЙ§ 2 * ((d:вДЭ)) ^ (-(2:вДЭ)) := by
        calc s * ((d:вДЭ)) ^ (-s - 1) вЙ§ 2 * ((d:вДЭ)) ^ (-s - 1) := by
              apply mul_le_mul_of_nonneg_right hs2 (Real.rpow_nonneg hd0.le _)
          _ вЙ§ 2 * ((d:вДЭ)) ^ (-(2:вДЭ)) := by
              apply mul_le_mul_of_nonneg_left h2 (by norm_num)

      push_cast at h1 вКҐ
      linarith
    have hSb : |вИС n вИИ Icc 1 d, k n| вЙ§ 2 * B * Real.sqrt d := by
      calc |вИС n вИИ Icc 1 d, k n| вЙ§ B * (Real.sqrt d + 1) := hK d
        _ вЙ§ B * (Real.sqrt d + Real.sqrt d) := by
            apply mul_le_mul_of_nonneg_left _ hB0
            linarith
        _ = 2 * B * Real.sqrt d := by ring
    have hrpow2 : ((d:вДЭ)) ^ (-(2:вДЭ)) = 1 / ((d:вДЭ) * (d:вДЭ)) := by
      rw [show (-(2:вДЭ)) = -(((2:вДХ)):вДЭ) from by norm_num, Real.rpow_neg hd0.le,
        Real.rpow_natCast, pow_two, one_div]
    have hcollect : Real.sqrt d * (1 / ((d:вДЭ) * (d:вДЭ))) = 1 / ((d:вДЭ) * Real.sqrt d) := by
      rw [mul_one_div, div_eq_div_iff (by positivity) (by positivity), one_mul]
      calc Real.sqrt d * ((d:вДЭ) * Real.sqrt d)
          = (Real.sqrt d * Real.sqrt d) * (d:вДЭ) := by ring
        _ = (d:вДЭ) * (d:вДЭ) := by rw [Real.mul_self_sqrt hd0.le]
    rw [abs_mul, abs_of_nonneg hќФ0]
    calc |вИС n вИИ Icc 1 d, k n| * (w d - w (d + 1))
        вЙ§ (2 * B * Real.sqrt d) * (2 * ((d:вДЭ)) ^ (-(2:вДЭ))) := by
          apply mul_le_mul hSb hќФle hќФ0
          positivity
      _ = 4 * B * (Real.sqrt d * ((d:вДЭ)) ^ (-(2:вДЭ))) := by ring
      _ = 4 * B * (Real.sqrt d * (1 / ((d:вДЭ) * (d:вДЭ)))) := by rw [hrpow2]
      _ = 4 * B * (1 / ((d:вДЭ) * Real.sqrt d)) := by rw [hcollect]
  intro z hz
  rw [hwindow z hz]
  have hy0 : (0:вДЭ) < (y:вДЭ) := by
    have : (0:вДХ) < y := hy1
    exact_mod_cast this
  have hz0 : (0:вДЭ) < (z:вДЭ) := by
    have : (0:вДХ) < z := by omega
    exact_mod_cast this
  have hsqy : (1:вДЭ) вЙ§ Real.sqrt y := Real.one_le_sqrt.mpr (by exact_mod_cast hy1)
  have hsqy0 : (0:вДЭ) < Real.sqrt y := by linarith
  have hsqz0 : (0:вДЭ) < Real.sqrt z := Real.sqrt_pos.mpr hz0
  -- the three pieces
  have h1 : |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))|
      вЙ§ 8 * B / Real.sqrt y := by
    calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))|
        вЙ§ вИС d вИИ Icc (y + 1) z, |(вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc (y + 1) z, 4 * B * (1 / ((d:вДЭ) * Real.sqrt d)) := by
          apply Finset.sum_le_sum
          intro d hd
          rw [Finset.mem_Icc] at hd
          exact hkernel d (by omega)
      _ = 4 * B * вИС d вИИ Icc (y + 1) z, (1 : вДЭ) / (d * Real.sqrt d) := by
          rw [Finset.mul_sum]
      _ вЙ§ 4 * B * (2 / Real.sqrt y - 2 / Real.sqrt z) := by
          apply mul_le_mul_of_nonneg_left (sum_three_half_tail_sharp y hy1 z hz)
            (by positivity)
      _ вЙ§ 8 * B / Real.sqrt y := by
          have h3 : (0:вДЭ) вЙ§ 4 * B * (2 / Real.sqrt z) := by positivity
          have heq : 4 * B * (2 / Real.sqrt y - 2 / Real.sqrt z)
              = 8 * B / Real.sqrt y - 4 * B * (2 / Real.sqrt z) := by ring
          linarith [heq.le, heq.ge]
  have hwle : вИА t : вДХ, 1 вЙ§ t вЖТ w (t + 1) вЙ§ 1 / (t:вДЭ) := by
    intro t ht
    have ht0 : (0:вДЭ) < (t:вДЭ) := by
      have : (0:вДХ) < t := ht
      exact_mod_cast this
    have ht1 : (1:вДЭ) вЙ§ ((t + 1 : вДХ):вДЭ) := by push_cast; linarith
    rw [hw]
    simp only
    calc ((t + 1 : вДХ):вДЭ) ^ (-s) вЙ§ ((t + 1 : вДХ):вДЭ) ^ (-(1:вДЭ)) :=
          Real.rpow_le_rpow_of_exponent_le ht1 (by linarith)
      _ = 1 / ((t + 1 : вДХ):вДЭ) := by rw [Real.rpow_neg_one, one_div]
      _ вЙ§ 1 / (t:вДЭ) := by
          apply one_div_le_one_div_of_le ht0
          push_cast
          linarith
  have hbz : |(вИС n вИИ Icc 1 z, k n) * w (z + 1)| вЙ§ 2 * B / Real.sqrt y := by
    have hw0z : 0 вЙ§ w (z + 1) := by
      rw [hw]
      exact Real.rpow_nonneg (Nat.cast_nonneg _) _
    have hsqzz : Real.sqrt z / (z:вДЭ) = 1 / Real.sqrt z := by
      rw [eq_div_iff (ne_of_gt hsqz0)]
      field_simp
      exact Real.sq_sqrt hz0.le
    calc |(вИС n вИИ Icc 1 z, k n) * w (z + 1)|
        = |вИС n вИИ Icc 1 z, k n| * w (z + 1) := by rw [abs_mul, abs_of_nonneg hw0z]
      _ вЙ§ (2 * B * Real.sqrt z) * (1 / (z:вДЭ)) := by
          apply mul_le_mul _ (hwle z (by omega)) hw0z (by positivity)
          calc |вИС n вИИ Icc 1 z, k n| вЙ§ B * (Real.sqrt z + 1) := hK z
            _ вЙ§ B * (Real.sqrt z + Real.sqrt z) := by
                apply mul_le_mul_of_nonneg_left _ hB0
                have : (1:вДЭ) вЙ§ Real.sqrt z := Real.one_le_sqrt.mpr (by
                  have : (1:вДХ) вЙ§ z := by omega
                  exact_mod_cast this)
                linarith
            _ = 2 * B * Real.sqrt z := by ring
      _ = 2 * B * (Real.sqrt z / (z:вДЭ)) := by ring
      _ = 2 * B * (1 / Real.sqrt z) := by rw [hsqzz]
      _ вЙ§ 2 * B / Real.sqrt y := by
          rw [mul_one_div]
          apply div_le_div_of_nonneg_left (by linarith) hsqy0
          exact Real.sqrt_le_sqrt (by exact_mod_cast hz)
  have hby : |(вИС n вИИ Icc 1 y, k n) * w (y + 1)| вЙ§ 2 * B / Real.sqrt y := by
    have hw0y : 0 вЙ§ w (y + 1) := by
      rw [hw]
      exact Real.rpow_nonneg (Nat.cast_nonneg _) _
    have hsqyy : Real.sqrt y / (y:вДЭ) = 1 / Real.sqrt y := by
      rw [eq_div_iff (ne_of_gt hsqy0)]
      field_simp
      exact Real.sq_sqrt hy0.le
    calc |(вИС n вИИ Icc 1 y, k n) * w (y + 1)|
        = |вИС n вИИ Icc 1 y, k n| * w (y + 1) := by rw [abs_mul, abs_of_nonneg hw0y]
      _ вЙ§ (2 * B * Real.sqrt y) * (1 / (y:вДЭ)) := by
          apply mul_le_mul _ (hwle y hy1) hw0y (by positivity)
          calc |вИС n вИИ Icc 1 y, k n| вЙ§ B * (Real.sqrt y + 1) := hK y
            _ вЙ§ B * (Real.sqrt y + Real.sqrt y) := by
                apply mul_le_mul_of_nonneg_left _ hB0
                linarith
            _ = 2 * B * Real.sqrt y := by ring
      _ = 2 * B * (Real.sqrt y / (y:вДЭ)) := by ring
      _ = 2 * B * (1 / Real.sqrt y) := by rw [hsqyy]
      _ = 2 * B / Real.sqrt y := by rw [mul_one_div]
  calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))
        + (вИС n вИИ Icc 1 z, k n) * w (z + 1) - (вИС n вИИ Icc 1 y, k n) * w (y + 1)|
      вЙ§ |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))|
        + |(вИС n вИИ Icc 1 z, k n) * w (z + 1)| + |(вИС n вИИ Icc 1 y, k n) * w (y + 1)| := by
        have ha := abs_add_le (вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1))
          + (вИС n вИИ Icc 1 z, k n) * w (z + 1)) (-((вИС n вИИ Icc 1 y, k n) * w (y + 1)))
        have hb := abs_add_le (вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * (w d - w (d + 1)))
          ((вИС n вИИ Icc 1 z, k n) * w (z + 1))
        rw [abs_neg, вЖР sub_eq_add_neg] at ha
        linarith
    _ вЙ§ 8 * B / Real.sqrt y + 2 * B / Real.sqrt y + 2 * B / Real.sqrt y := by
        linarith [h1, hbz, hby]
    _ вЙ§ 30 * B / Real.sqrt y := by
        have h30 : (12:вДЭ) * B / Real.sqrt y вЙ§ 30 * B / Real.sqrt y := by
          apply div_le_div_of_nonneg_right _ hsqy0.le
          linarith
        have heq : 8 * B / Real.sqrt y + 2 * B / Real.sqrt y + 2 * B / Real.sqrt y
            = 12 * B / Real.sqrt y := by ring
        linarith [heq.le, heq.ge, h30]

/-- **The pair `L(s,ѕЗвВВ)L(s,ѕЗвВБѕЗвВВ)` is real with the `30B/вИЪy` Abel rate**
    (Siegel brick A5-d2): the convolution partial sums identify the product of
    the two L-values at every real `s вИИ (1,2]`. -/
theorem LFunction_pair_real_rate {qвВБ qвВВ : вДХ} [NeZero qвВБ] [NeZero qвВВ]
    (hqвВБ : 1 вЙ§ qвВБ) (hqвВВ : 1 вЙ§ qвВВ)
    (ѕЗвВБ : DirichletCharacter вДВ qвВБ) (ѕЗвВВ : DirichletCharacter вДВ qвВВ)
    (hѕЗвВБ2 : ѕЗвВБ ^ 2 = 1) (hѕЗвВВ2 : ѕЗвВВ ^ 2 = 1) (hѕЗвВБ1 : ѕЗвВБ вЙ† 1) (hѕЗвВВ1 : ѕЗвВВ вЙ† 1)
    (hѕЗвВГ1 : (DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
        * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ) вЙ† 1)
    {s : вДЭ} (hs : 1 < s) (hs2 : s вЙ§ 2) :
    вИГ вДУ : вДЭ, DirichletCharacter.LFunction ѕЗвВВ ((s:вДВ))
        * DirichletCharacter.LFunction
            ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
              * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ((s:вДВ)) = ((вДУ:вДЭ):вДВ)
      вИІ вИА y : вДХ, 1 вЙ§ y вЖТ
        |вДУ - вИС d вИИ Icc 1 y, (toArith (charFn qвВВ ѕЗвВВ)
            * toArith (fun m => charFn qвВБ ѕЗвВБ m * charFn qвВВ ѕЗвВВ m)) d * ((d:вДЭ)) ^ (-s)|
          вЙ§ 30 * (2 * (qвВВ:вДЭ) + (qвВБ:вДЭ) * (qвВВ:вДЭ)) / Real.sqrt y := by
  have h2b := fun n => charFn_bound ѕЗвВВ hѕЗвВВ2 n
  have h12b : вИА n, |charFn qвВБ ѕЗвВБ n * charFn qвВВ ѕЗвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |charFn qвВБ ѕЗвВБ n| * |charFn qвВВ ѕЗвВВ n| вЙ§ 1 * 1 :=
        mul_le_mul (charFn_bound ѕЗвВБ hѕЗвВБ2 n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have hѕЗвВГ2 : ((DirichletCharacter.changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ)
      * (DirichletCharacter.changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ)) ^ 2 = 1 := by
    rw [mul_pow, вЖР map_pow, вЖР map_pow, hѕЗвВБ2, hѕЗвВВ2, map_one, map_one, mul_one]
