namespace GoldbachChain

-- ==== HOISTED shared definitions (single canonical copies) ====
open Finset

/-- `e(x) = exp(2ѕАi x)`, the additive character of the circle. -/
noncomputable def e (x : вДЭ) : вДВ := Complex.exp (2 * Real.pi * Complex.I * x)

lemma e_norm (x : вДЭ) : вАЦe xвАЦ = 1 := by
  rw [e, Complex.norm_exp]
  have : (2 * (Real.pi : вДВ) * Complex.I * (x : вДВ)).re = 0 := by
    simp [Complex.mul_re, Complex.mul_im]
  rw [this, Real.exp_zero]

lemma e_pow (ќ± : вДЭ) (n : вДХ) : e (n * ќ±) = (e ќ±) ^ n := by
  rw [e, e, вЖР Complex.exp_nat_mul]
  congr 1
  push_cast; ring

lemma e_add (x y : вДЭ) : e x * e y = e (x + y) := by
  rw [e, e, e, вЖР Complex.exp_add]; congr 1; push_cast; ring

lemma e_conj (x : вДЭ) : (starRingEnd вДВ) (e x) = e (-x) := by
  rw [e, e, вЖР Complex.exp_conj]; congr 1
  simp only [map_mul, Complex.conj_I, Complex.conj_ofReal, map_ofNat]
  push_cast; ring

lemma geom_exp_bound (z : вДВ) (hz : z вЙ† 1) (hz1 : вАЦzвАЦ = 1) (N : вДХ) :
    вАЦвИС n вИИ Finset.range N, z ^ nвАЦ вЙ§ 2 / вАЦz - 1вАЦ := by
  have hzsub : (0 : вДЭ) < вАЦz - 1вАЦ := by
    rw [norm_pos_iff]; exact sub_ne_zero_of_ne hz
  rw [geom_sum_eq hz, norm_div]
  gcongr
  calc вАЦz ^ N - 1вАЦ вЙ§ вАЦz ^ NвАЦ + вАЦ(1 : вДВ)вАЦ := norm_sub_le _ _
    _ = 2 := by rw [norm_pow, hz1]; norm_num

lemma e_sub_one_norm (ќ± : вДЭ) : вАЦe ќ± - 1вАЦ = 2 * |Real.sin (Real.pi * ќ±)| := by
  have harg : e ќ± = Complex.exp ((вЖС(2 * Real.pi * ќ±) : вДВ) * Complex.I) := by
    rw [e]; congr 1; push_cast; ring
  have hre : (e ќ±).re = Real.cos (2 * Real.pi * ќ±) := by
    rw [harg]; exact Complex.exp_ofReal_mul_I_re _
  have him : (e ќ±).im = Real.sin (2 * Real.pi * ќ±) := by
    rw [harg]; exact Complex.exp_ofReal_mul_I_im _
  have e1 : Real.cos (2 * Real.pi * ќ±) = 2 * Real.cos (Real.pi * ќ±) ^ 2 - 1 := by
    rw [show 2 * Real.pi * ќ± = 2 * (Real.pi * ќ±) by ring]; exact Real.cos_two_mul _
  have e2 : Real.sin (2 * Real.pi * ќ±)
      = 2 * Real.sin (Real.pi * ќ±) * Real.cos (Real.pi * ќ±) := by
    rw [show 2 * Real.pi * ќ± = 2 * (Real.pi * ќ±) by ring]; exact Real.sin_two_mul _
  have hnn : (0 : вДЭ) вЙ§ 2 * |Real.sin (Real.pi * ќ±)| := by positivity
  rw [вЖР Real.sqrt_sq (norm_nonneg (e ќ± - 1)), вЖР Real.sqrt_sq hnn]
  congr 1
  rw [вЖР Complex.normSq_eq_norm_sq, Complex.normSq_apply]
  simp only [Complex.sub_re, Complex.sub_im, Complex.one_re, Complex.one_im, hre, him]
  rw [e1, e2, mul_pow, sq_abs]
  nlinarith [Real.sin_sq_add_cos_sq (Real.pi * ќ±)]

lemma exp_sum_le_sin (ќ± : вДЭ) (hќ± : Real.sin (Real.pi * ќ±) вЙ† 0) (N : вДХ) :
    вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ вЙ§ 1 / |Real.sin (Real.pi * ќ±)| := by
  have hne : e ќ± вЙ† 1 := by
    intro h
    have h0 : вАЦe ќ± - 1вАЦ = 2 * |Real.sin (Real.pi * ќ±)| := e_sub_one_norm ќ±
    rw [h, sub_self, norm_zero] at h0
    have : |Real.sin (Real.pi * ќ±)| = 0 := by linarith [abs_nonneg (Real.sin (Real.pi * ќ±))]
    exact hќ± (abs_eq_zero.mp this)
  have hsum : вИС n вИИ Finset.range N, e (n * ќ±) = вИС n вИИ Finset.range N, (e ќ±) ^ n :=
    Finset.sum_congr rfl (fun n _ => e_pow ќ± n)
  have key : вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ вЙ§ 2 / вАЦe ќ± - 1вАЦ := by
    rw [hsum]; exact geom_exp_bound (e ќ±) hne (e_norm ќ±) N
  rw [e_sub_one_norm ќ±] at key
  have habs : (0 : вДЭ) < |Real.sin (Real.pi * ќ±)| := abs_pos.mpr hќ±
  calc вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ вЙ§ 2 / (2 * |Real.sin (Real.pi * ќ±)|) := key
    _ = 1 / |Real.sin (Real.pi * ќ±)| := by rw [div_mul_eq_div_div]; norm_num

lemma two_dist_le_abs_sin (ќ± : вДЭ) : 2 * |ќ± - round ќ±| вЙ§ |Real.sin (Real.pi * ќ±)| := by
  set m : вД§ := round ќ± with hm
  set r : вДЭ := ќ± - (m : вДЭ) with hr
  have hrabs : |r| вЙ§ 1 / 2 := by rw [hr]; exact abs_sub_round ќ±
  have hќ±split : Real.pi * ќ± = Real.pi * r + (m : вДЭ) * Real.pi := by
    rw [hr]; ring
  have hsin : Real.sin (Real.pi * ќ±) = (-1) ^ m * Real.sin (Real.pi * r) := by
    rw [hќ±split, Real.sin_add_int_mul_pi]
  have habs1 : |Real.sin (Real.pi * ќ±)| = |Real.sin (Real.pi * r)| := by
    rw [hsin, abs_mul, abs_zpow, abs_neg, abs_one, one_zpow, one_mul]
  have hpr : |Real.sin (Real.pi * r)| = Real.sin (Real.pi * |r|) := by
    by_cases hrpos : 0 вЙ§ r
    ¬Ј rw [abs_of_nonneg hrpos,
        abs_of_nonneg (Real.sin_nonneg_of_nonneg_of_le_pi (by positivity)
          (by nlinarith [Real.pi_pos, (abs_le.mp hrabs).2]))]
    ¬Ј replace hrpos : r < 0 := not_le.mp hrpos
      have hle0 : Real.sin (Real.pi * r) вЙ§ 0 := by
        have h1 : 0 вЙ§ Real.sin (Real.pi * (-r)) :=
          Real.sin_nonneg_of_nonneg_of_le_pi (by nlinarith [Real.pi_pos])
            (by nlinarith [Real.pi_pos, (abs_le.mp hrabs).1])
        rw [show Real.pi * (-r) = -(Real.pi * r) by ring, Real.sin_neg] at h1
        linarith
      rw [abs_of_neg hrpos, abs_of_nonpos hle0,
        show Real.pi * -r = -(Real.pi * r) by ring, Real.sin_neg]
  have hjordan : 2 * |r| вЙ§ Real.sin (Real.pi * |r|) := by
    have hj := Real.le_sin_mul (x := 2 * |r|) (by positivity) (by nlinarith [hrabs])
    rwa [show Real.pi / 2 * (2 * |r|) = Real.pi * |r| by ring] at hj
  calc 2 * |ќ± - round ќ±| = 2 * |r| := by rw [hr]
    _ вЙ§ Real.sin (Real.pi * |r|) := hjordan
    _ = |Real.sin (Real.pi * r)| := hpr.symm
    _ = |Real.sin (Real.pi * ќ±)| := habs1.symm

lemma exp_sum_bound (ќ± : вДЭ) (hќ± : Real.sin (Real.pi * ќ±) вЙ† 0) (N : вДХ) :
    вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ вЙ§ 1 / (2 * |ќ± - round ќ±|) := by
  have h2 := two_dist_le_abs_sin ќ±
  have hd : (0 : вДЭ) < 2 * |ќ± - round ќ±| := by
    rcases (abs_nonneg (ќ± - (round ќ± : вДЭ))).lt_or_eq with h | h
    ¬Ј positivity
    ¬Ј exfalso; apply hќ±
      have hz : ќ± - (round ќ± : вДЭ) = 0 := abs_eq_zero.mp h.symm
      have hќ±eq : ќ± = (round ќ± : вДЭ) := by linarith
      rw [hќ±eq, show Real.pi * (round ќ± : вДЭ) = (round ќ± : вДЭ) * Real.pi by ring,
        Real.sin_int_mul_pi]
  exact le_trans (exp_sum_le_sin ќ± hќ± N) (one_div_le_one_div_of_le hd h2)

lemma exp_sum_trivial (ќ± : вДЭ) (N : вДХ) : вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ вЙ§ N := by
  calc вАЦвИС n вИИ Finset.range N, e (n * ќ±)вАЦ
      вЙ§ вИС n вИИ Finset.range N, вАЦe (n * ќ±)вАЦ := norm_sum_le _ _
    _ = N := by simp [e_norm]

/-- The capped exponential-sum bound in workhorse-weight form:
    `вАЦвИС_{n<M} e(nќ≤)вАЦ вЙ§ [if ќ≤вИИвД§ then M else min(M, 1/(2вАЦќ≤вАЦ))]`. -/
lemma exp_sum_min_bound (ќ≤ : вДЭ) (M : вДХ) :
    вАЦвИС n вИИ Finset.range M, e (n * ќ≤)вАЦ
      вЙ§ (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
         else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
  split
  ¬Ј exact exp_sum_trivial ќ≤ M
  ¬Ј rename_i hne
    apply le_min (exp_sum_trivial ќ≤ M)
    have hsin : Real.sin (Real.pi * ќ≤) вЙ† 0 := by
      intro h0
      apply hne
      rw [Real.sin_eq_zero_iff] at h0
      obtain вЯ®n, hnвЯ© := h0
      have h2 : Real.pi * (n : вДЭ) = Real.pi * ќ≤ := by linear_combination hn
      have hќ≤ : ќ≤ = (n : вДЭ) := (mul_left_cancelвВА Real.pi_ne_zero h2).symm
      rw [hќ≤, round_intCast]
      ring
    exact exp_sum_bound ќ≤ hsin M

/-- `e(ќ±) = 1` iff `ќ±` is an integer. -/
lemma e_eq_one_iff (ќ± : вДЭ) : e ќ± = 1 вЖФ вИГ k : вД§, ќ± = (k : вДЭ) := by
  rw [e, Complex.exp_eq_one_iff]
  have h2ѕАI : (2 * (Real.pi : вДВ) * Complex.I) вЙ† 0 :=
    mul_ne_zero (mul_ne_zero (by norm_num) (Complex.ofReal_ne_zero.mpr Real.pi_ne_zero))
      Complex.I_ne_zero
  constructor
  ¬Ј rintro вЯ®k, hkвЯ©
    refine вЯ®k, ?_вЯ©
    rw [mul_comm ((k : вД§) : вДВ) (2 * (Real.pi : вДВ) * Complex.I)] at hk
    exact_mod_cast mul_left_cancelвВА h2ѕАI hk
  ¬Ј rintro вЯ®k, rflвЯ©
    exact вЯ®k, by push_cast; ringвЯ©

open Filter in
/-- The arithmetic model coefficients for `ќЫ` mod `q`: `1/ѕЖ(q)` on units, `0` off. -/
noncomputable def lambdaModel (q : вДХ) : вДХ вЖТ вДВ :=
  fun r => if Nat.gcd r q = 1 then 1 / (Nat.totient q : вДВ) else 0

/-- **The major arcs**: the union of the Farey windows `|ќ± вИТ a/q| вЙ§ 1/(q(Q+1))` over
    moduli `q вЙ§ P`. Countable union of closed balls, hence measurable. -/
def MajorArcs (P Q : вДХ) : Set вДЭ :=
  вЛГ q вИИ Set.Icc 1 P, вЛГ a : вД§, Metric.closedBall ((a : вДЭ) / q) (1 / (q * (Q + 1)))

/-- The finite set of REDUCED Farey anchors with moduli вЙ§ P relevant to `(0,1]`. -/
noncomputable def anchors (P : вДХ) : Finset (вДХ √Ч вД§) :=
  (Finset.Icc 1 P √ЧЋҐ Finset.Icc (-(P : вД§)) (2 * P)).filter
    (fun pq => Int.gcd pq.2 pq.1 = 1)

noncomputable def minorCsup (N U V P Q : вДХ) : вДЭ :=
  2 * Real.log (N + 1) * ((2 * (N : вДЭ) / P) * (1 + Real.log U)
      + (16 * U + 4 * Q) * (2 + Real.log (2 * Q)) + U)
  + Real.log (U * V) * ((2 * (N : вДЭ) / P) * (1 + Real.log (U * V))
      + (16 * (U * V) + 4 * Q) * (2 + Real.log (2 * Q)))
  + (V : вДЭ) * Real.log V
  + Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
      + Real.sqrt 32 * N * ((Nat.log 2 N + 1 : вДХ) : вДЭ) / Real.sqrt P
      + 64 * N * Real.sqrt (1 + Real.log (2 * Q)) / Real.sqrt U
      + 6 * ((Nat.log 2 N + 1 : вДХ) : вДЭ) * Real.sqrt (N * Q * (1 + Real.log (2 * Q))))

