    have hqB2 : (q:вДЭ) вЙ§ Real.log ((t:вДЭ) - 1) ^ ((2*B : вДЭ)) := by
      have h2 : (Real.log N / 2) ^ ((2*B : вДЭ))
          = Real.log N ^ ((2*B:вДЭ)) / 2 ^ ((2*B:вДЭ)) :=
        Real.div_rpow (by linarith) (by norm_num) _
      have h1 : Real.log N ^ (B:вДЭ) вЙ§ (Real.log N / 2) ^ ((2*B : вДЭ)) := by
        rw [h2, le_div_iffвВА (by positivity)]
        have h3 : (2:вДЭ) ^ ((2*B:вДЭ)) вЙ§ Real.log N ^ (B:вДЭ) := by
          have h31 : (2:вДЭ) ^ ((2*B:вДЭ)) = ((2:вДЭ)^(2:вДХ)) ^ (B:вДЭ) := by
            rw [вЖР Real.rpow_natCast (2:вДЭ) 2, вЖР Real.rpow_mul (by norm_num)]
            norm_num
