  have hќЫвВВ256 : 256 вЙ§ ќЫвВВ := by
    rw [hќЫвВВdef]
    have h1 : (0:вДЭ) вЙ§ (4*c+1)^(10:вДХ) := by positivity
    linarith
  refine вЯ®max (вМИReal.exp ќЫвВВвМЙвВК + 2) (вМИ(max XвВА 0 + 2)^(2:вДХ)вМЙвВК + 2), ?_вЯ©
  intro N hNвВА q hq0 hqB r hrq hgcd t htN
