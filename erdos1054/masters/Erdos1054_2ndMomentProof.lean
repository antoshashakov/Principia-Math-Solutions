  have hxќ≤ќ≤ : ((x:вДЭ)) ^ (-ќ≤) вЙ§ ((x:вДЭ)) ^ (-ќ≤) / (1 - ќ≤) := by
    rw [le_div_iffвВА h1ќ≤]
    nlinarith [hxќ≤, hќ≤0]
  -- Step 5: the boundary term
  have hlogx : 1 + Real.log x вЙ§ 9 * ((x:вДЭ)) ^ ((1:вДЭ)/8) := by
