    have h7 := Real.log_le_log (by nlinarith : (0:вДЭ) < (N:вДЭ)*(4*|ѕБ.im|+7)) h6
    linarith
  have hNe0 : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hgap : c * ((N:вДЭ))^(-ќµ) / LT вЙ§ c * ((N:вДЭ))^(-ќµ) / LѕБ := by
    apply div_le_div_of_nonneg_left (by positivity) (by linarith) hLmono
  have hre : s.re - ѕБ.re вЙ§ вАЦs - ѕБвАЦ := by
    have h8 : (s - ѕБ).re = s.re - ѕБ.re := by rw [Complex.sub_re]
    calc s.re - ѕБ.re = (s - ѕБ).re := h8.symm
