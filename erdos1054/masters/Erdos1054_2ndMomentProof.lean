    rw [norm_mul]
    calc вАЦѕЗ aвБї¬євАЦ * вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          ѕЗ ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ)вАЦ
        вЙ§ 1 * (CвВЕ * X * Real.exp (-(cвВЕ * u))) := by
