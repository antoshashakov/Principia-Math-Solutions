    have hIio_val : вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (4 * u ^ 2) = 1 / (4 * ќі) := by
      have hrefl : вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (4 * u ^ 2)
