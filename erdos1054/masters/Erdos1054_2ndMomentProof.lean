      have hprod : вАЦвИП p вИИ N.primeFactors, (1 - ((p:вДВ)) ^ (-z))вАЦ вЙ§ (N:вДЭ) := by
        apply primeFactors_prod_norm_le
        intro p hp
        have hp2 : (2:вДЭ) вЙ§ (p:вДЭ) := by
          exact_mod_cast (Nat.prime_of_mem_primeFactors hp).two_le
        have hp0 : (0:вДЭ) < (p:вДЭ) := by linarith
        calc вАЦ1 - ((p:вДВ)) ^ (-z)вАЦ вЙ§ вАЦ(1:вДВ)вАЦ + вАЦ((p:вДВ)) ^ (-z)вАЦ := norm_sub_le _ _
          _ = 1 + ((p:вДЭ)) ^ (-z.re) := by
              rw [norm_one, show ((p:вДВ)) = (((p:вДЭ)):вДВ) by push_cast; ring,
                Complex.norm_cpow_eq_rpow_re_of_pos hp0, Complex.neg_re]
          _ вЙ§ 2 := by
              have h1 : ((p:вДЭ)) ^ (-z.re) вЙ§ 1 :=
                Real.rpow_le_one_of_one_le_of_nonpos (by linarith) (by linarith)
              linarith
      exact mul_le_mul hprod hzeta (norm_nonneg _) (by linarith)
  -- the anchor
  have hcre1 : 1 < c.re := by
    rw [hcre]
    exact hѕГ1
  have hLne := LFunction_anchor_quantitative N 1 c hcre1
  rw [hcre] at hLne
  have hLpos : (0:вДЭ) < (ѕГ - 1)/ѕГ := by
    apply div_pos <;> linarith
  have hml : (ѕГ-1)^2/2 вЙ§ вАЦDirichletCharacter.LFunctionTrivCharвВБ N cвАЦ := by
    rw [DirichletCharacter.LFunctionTrivCharвВБ, Function.update_of_ne hc1]
    have h1 : ѕГ - 1 вЙ§ вАЦc - 1вАЦ := by
      calc ѕГ - 1 = (c - 1).re := by rw [Complex.sub_re, hcre, Complex.one_re]
        _ вЙ§ |(c - 1).re| := le_abs_self _
        _ вЙ§ вАЦc - 1вАЦ := Complex.abs_re_le_norm _
    have h2 : (ѕГ - 1)/ѕГ вЙ§ вАЦDirichletCharacter.LFunctionTrivChar N cвАЦ := hLne
    have h3 : (ѕГ-1)/2 вЙ§ (ѕГ-1)/ѕГ := by
      apply div_le_div_of_nonneg_left (by linarith) (by linarith)
      linarith
    calc (ѕГ-1)^2/2 = (ѕГ-1) * ((ѕГ-1)/2) := by ring
      _ вЙ§ вАЦc - 1вАЦ * вАЦDirichletCharacter.LFunctionTrivChar N cвАЦ := by
          apply mul_le_mul h1 (le_trans h3 h2) (by positivity) (norm_nonneg _)
      _ = вАЦ(c - 1) * DirichletCharacter.LFunctionTrivChar N cвАЦ := (norm_mul _ _).symm
  have hml0 : (0:вДЭ) < (ѕГ-1)^2/2 := by positivity
  -- Landau on the completed function
  obtain вЯ®S, m, hSz, hm, hcomp, hboundвЯ© := landau_log_deriv
    (DirichletCharacter.LFunctionTrivCharвВБ N) c (1/50) (1/125)
    ((N:вДЭ) * (CвВА * (|t|+3)^2)) ((ѕГ-1)^2/2) (by norm_num) (by norm_num)
    ((DirichletCharacter.differentiable_LFunctionTrivCharвВБ N).differentiableOn) hfb hml0 hml
  have hfc0 : DirichletCharacter.LFunctionTrivCharвВБ N c вЙ† 0 := by
    intro h
    rw [h, norm_zero] at hml
    nlinarith [hml0]
  have hzS : вИА ѕБ вИИ S, c вЙ† ѕБ := by
    intro ѕБ hѕБ h
    rw [h] at hfc0
    exact hfc0 (hSz ѕБ hѕБ).2
  have hb := hbound c (mem_ball_self (by norm_num)) hzS
  -- every zero term has nonnegative real part
  have hreS : вИА ѕБ вИИ S, 0 вЙ§ ((m ѕБ : вДВ) / (c - ѕБ)).re := by
    intro ѕБ hѕБ
    have hѕБz := (hSz ѕБ hѕБ).2
    have hѕБ1 : ѕБ вЙ† 1 := by
      intro h
      rw [h] at hѕБz
      exact DirichletCharacter.LFunctionTrivCharвВБ_apply_one_ne_zero N hѕБz
    have hLѕБ : DirichletCharacter.LFunctionTrivChar N ѕБ = 0 := by
      rw [DirichletCharacter.LFunctionTrivCharвВБ, Function.update_of_ne hѕБ1] at hѕБz
