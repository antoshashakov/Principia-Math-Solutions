open scoped LSeries.notation ArithmeticFunction in
/-- **The trivial-character Landau bound at height** (SW brick S4a-4c): one absolute
    `C` with, for every modulus and `ѕГ вИИ (1,2]`, every height `t`,
    `Re L(ѕЗвБ∞ќЫ, ѕГ+it) вЙ§ (ѕГвИТ1)/((ѕГвИТ1)¬≤+t¬≤) + C(log(N(|t|+3)/(ѕГвИТ1)) + 1)` вАФ the DAMPED
    pole: Landau on the completed `(sвИТ1)L(ѕЗвБ∞,s)` (no pole, fixed radius), every zero
    term dropped by positivity. -/
theorem trivchar_height_bound :
    вИГ C : вДЭ, 1 вЙ§ C вИІ вИА (N : вДХ) [NeZero N], вИА ѕГ t : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
      (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) ((ѕГ:вДВ) + t*I)).re
        вЙ§ (ѕГ-1)/((ѕГ-1)^2 + t^2) + C * (Real.log ((N:вДЭ)*(|t|+3)/(ѕГ-1)) + 1) := by
  obtain вЯ®CвВА, hCвВА1, hCвВАвЯ© := completed_zeta_ball_bound
  have hlogCвВА : 0 вЙ§ Real.log CвВА := Real.log_nonneg hCвВА1
  refine вЯ®1000*(Real.log CвВА + 4), by linarith, ?_вЯ©
  intro N _ ѕГ t hѕГ1 hѕГ2
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  set c : вДВ := (ѕГ:вДВ) + t*I with hcdef
  have hcre : c.re = ѕГ := by rw [hcdef]; simp
  have hcim : c.im = t := by rw [hcdef]; simp
  have hc1 : c вЙ† 1 := by
    intro h
    rw [h, Complex.one_re] at hcre
    linarith
  have hcnorm : вАЦcвАЦ вЙ§ ѕГ + |t| := by
    rw [hcdef]
    calc вАЦ(ѕГ:вДВ) + t*IвАЦ вЙ§ вАЦ(ѕГ:вДВ)вАЦ + вАЦ(t:вДВ)*IвАЦ := norm_add_le _ _
      _ = |ѕГ| + |t| := by
          rw [Complex.norm_real, norm_mul, Complex.norm_I, mul_one, Complex.norm_real]
          simp [Real.norm_eq_abs]
      _ = ѕГ + |t| := by rw [abs_of_pos (by linarith)]
  -- the ball bound for the completed function
  have hfb : вИА z вИИ ball c (1/50),
      вАЦDirichletCharacter.LFunctionTrivCharвВБ N zвАЦ вЙ§ (N:вДЭ) * (CвВА * (|t|+3)^2) := by
    intro z hz
    rw [mem_ball, dist_eq_norm] at hz
    have hzre : 19/20 < z.re := by
      have h1 : |(z - c).re| вЙ§ вАЦz - cвАЦ := Complex.abs_re_le_norm _
      have h2 : |z.re - c.re| < 1/50 := by
        rw [вЖР Complex.sub_re]
        exact lt_of_le_of_lt h1 hz
      have h3 := (abs_lt.mp h2).1
      rw [hcre] at h3
      linarith
    have hznorm : вАЦzвАЦ < |t| + 3 := by
      calc вАЦzвАЦ = вАЦc + (z - c)вАЦ := by ring_nf
        _ вЙ§ вАЦcвАЦ + вАЦz - cвАЦ := norm_add_le _ _
        _ < (ѕГ + |t|) + 1/50 := by
            apply add_lt_add_of_le_of_lt hcnorm hz
        _ вЙ§ |t| + 3 := by linarith
    have hR3 : (2:вДЭ) вЙ§ |t| + 3 := by
      have := abs_nonneg t
      linarith
    have hzeta := hCвВА (|t|+3) hR3 z hzre hznorm
    by_cases hz1 : z = 1
    ¬Ј -- at the removed pole: the update value is the finite Euler product
      subst hz1
      rw [DirichletCharacter.LFunctionTrivCharвВБ, Function.update_self]
      have hprod : вАЦвИП p вИИ N.primeFactors, (1 - ((p:вДВ))вБї¬є)вАЦ вЙ§ (N:вДЭ) := by
        apply primeFactors_prod_norm_le
        intro p hp
        have hp2 : (2:вДЭ) вЙ§ (p:вДЭ) := by
          exact_mod_cast (Nat.prime_of_mem_primeFactors hp).two_le
        calc вАЦ1 - ((p:вДВ))вБї¬євАЦ вЙ§ вАЦ(1:вДВ)вАЦ + вАЦ((p:вДВ))вБї¬євАЦ := norm_sub_le _ _
          _ = 1 + ((p:вДЭ))вБї¬є := by
              rw [norm_one, norm_inv]
              congr 1
              rw [show ((p:вДВ)) = (((p:вДЭ)):вДВ) by push_cast; ring, Complex.norm_real,
                Real.norm_eq_abs, abs_of_pos (by linarith)]
          _ вЙ§ 2 := by
              have : ((p:вДЭ))вБї¬є вЙ§ 1 := by
                rw [inv_le_one_iffвВА]
                right
                linarith
              linarith
      have hbig : (1:вДЭ) вЙ§ CвВА * (|t|+3)^2 := by
        have h9 : (9:вДЭ) вЙ§ (|t|+3)^2 := by nlinarith [abs_nonneg t]
        nlinarith [hCвВА1]
      calc вАЦвИП p вИИ N.primeFactors, (1 - ((p:вДВ))вБї¬є)вАЦ вЙ§ (N:вДЭ) := hprod
        _ вЙ§ (N:вДЭ) * (CвВА * (|t|+3)^2) := by nlinarith [hN1r, hbig]
    ¬Ј -- away from 1: factor through the level-1 completed function
      have hfactor : DirichletCharacter.LFunctionTrivCharвВБ N z
          = (вИП p вИИ N.primeFactors, (1 - ((p:вДВ)) ^ (-z)))
            * DirichletCharacter.LFunctionTrivCharвВБ 1 z := by
        rw [DirichletCharacter.LFunctionTrivCharвВБ, Function.update_of_ne hz1,
          DirichletCharacter.LFunctionTrivCharвВБ, Function.update_of_ne hz1,
          DirichletCharacter.LFunctionTrivChar_eq_mul_riemannZeta hz1,
          DirichletCharacter.LFunctionTrivChar_eq_mul_riemannZeta hz1,
          Nat.primeFactors_one, Finset.prod_empty, one_mul]
        ring
