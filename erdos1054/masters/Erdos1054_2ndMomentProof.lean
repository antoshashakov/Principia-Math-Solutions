    intro q ѕЗ hѕЗ2 p hp hzero'
    have hp2 : 2 вЙ§ p := (Nat.prime_of_mem_primeFactors hp).two_le
    have hp1r : (1:вДЭ) < (p:вДЭ) := by
      have h : (1:вДХ) < p := hp2
      exact_mod_cast h
    have hz : (1:вДВ) = ѕЗ ((p : ZMod q)) * ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ)) := sub_eq_zero.mp hzero'
    have hnorm : (1:вДЭ) = вАЦѕЗ ((p : ZMod q))вАЦ * вАЦ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ := by
      calc (1:вДЭ) = вАЦ(1:вДВ)вАЦ := norm_one.symm
        _ = вАЦѕЗ ((p : ZMod q)) * ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ := by rw [вЖР hz]
        _ = вАЦѕЗ ((p : ZMod q))вАЦ * вАЦ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ := norm_mul _ _
    have hѕЗn : вАЦѕЗ ((p : ZMod q))вАЦ вЙ§ 1 := by
      rcases real_char_repr ѕЗ hѕЗ2 ((p : ZMod q)) with h | h | h <;> rw [h] <;> norm_num
    have hpn : вАЦ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ = ((p:вДЭ)) ^ (-ќ≤) := by
      rw [cpow_real_cast p ќ≤, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (Real.rpow_nonneg (Nat.cast_nonneg p) _)]
    have hlt : ((p:вДЭ)) ^ (-ќ≤) < 1 :=
      Real.rpow_lt_one_of_one_lt_of_neg hp1r (by linarith)
    have hle : вАЦѕЗ ((p : ZMod q))вАЦ * вАЦ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ
        вЙ§ вАЦ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))вАЦ :=
      mul_le_of_le_one_left (norm_nonneg _) hѕЗn
    rw [hpn] at hle hnorm
    linarith [hnorm.le, hnorm.ge, hle, hlt]
  -- transfer through the changeLevel factorizations
  have hL2big : DirichletCharacter.LFunction clвВВ ((ќ≤:вДВ))
      = DirichletCharacter.LFunction ѕЗвВВ ((ќ≤:вДВ))
        * вИП p вИИ (qвВБ * qвВВ).primeFactors,
            (1 - ѕЗвВВ ((p : ZMod qвВВ)) * ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))) :=
    DirichletCharacter.LFunction_changeLevel (dvd_mul_left qвВВ qвВБ) ѕЗвВВ (Or.inr hќ≤ne)
  have hL1big : DirichletCharacter.LFunction clвВБ ((ќ≤:вДВ))
      = DirichletCharacter.LFunction ѕЗвВБ ((ќ≤:вДВ))
        * вИП p вИИ (qвВБ * qвВВ).primeFactors,
            (1 - ѕЗвВБ ((p : ZMod qвВБ)) * ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))) :=
    DirichletCharacter.LFunction_changeLevel (dvd_mul_right qвВБ qвВВ) ѕЗвВБ (Or.inr hќ≤ne)
  have hz2 : DirichletCharacter.LFunction clвВВ ((ќ≤:вДВ)) = 0 := by
    rw [hL2big, hzero, zero_mul]
  rw [hcl, hL1big] at hz2
  rcases mul_eq_zero.mp hz2 with h | h
  ¬Ј exact h
  ¬Ј exfalso
    have hne : вИП p вИИ (qвВБ * qвВВ).primeFactors,
        ((1:вДВ) - ѕЗвВБ ((p : ZMod qвВБ)) * ((p:вДВ)) ^ (-((ќ≤:вДЭ):вДВ))) вЙ† 0 :=
      Finset.prod_ne_zero_iff.mpr (fun p hp => hfac qвВБ ѕЗвВБ hѕЗвВБ2 p hp)
    exact hne h

/-- **The dichotomy gap estimate** (Siegel brick S3c-e): with the exceptional zero
    in the `ќµ/320`-window, the whole denominator of `chi2_zero_gap` is at most
    `K(ќµ,qвВБ)¬ЈqвВВ^{ќµ/2}` вАФ all `qвВВ`-growth tamed to an arbitrarily small power. -/
theorem dichotomy_gap_estimate (ќµ : вДЭ) (hќµ0 : 0 < ќµ) (hќµ1 : ќµ вЙ§ 1/100)
    (qвВБ : вДХ) (hqвВБ : 1 вЙ§ qвВБ) {ќ≤вВБ : вДЭ} (hќ≤w : 1 - ќ≤вВБ вЙ§ ќµ / 320) (hќ≤pos : 0 вЙ§ 1 - ќ≤вВБ) :
    вИГ K : вДЭ, 0 < K вИІ вИА qвВВ : вДХ, 1 вЙ§ qвВВ вЖТ
      26 * ((2 * (820 * (1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2 + 1))
          ^ ((40:вДЭ)))) ^ (1 - ќ≤вВБ)
        * (3 + Real.log qвВБ) * (3 + Real.log ((qвВБ * qвВВ : вДХ)))
      вЙ§ K * ((qвВВ:вДЭ)) ^ (ќµ / 2) := by
  have hqвВБr : (1:вДЭ) вЙ§ (qвВБ:вДЭ) := by exact_mod_cast hqвВБ
  have hA1 : (2:вДЭ) вЙ§ (qвВБ:вДЭ) + 1 := by linarith
  have hlogqвВБ : (0:вДЭ) вЙ§ Real.log qвВБ := Real.log_nonneg hqвВБr
  refine вЯ®(260 / ќµ) * Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
    * (3 + Real.log qвВБ) ^ 2, by positivity, ?_вЯ©
  intro qвВВ hqвВВ
  have hqвВВr : (1:вДЭ) вЙ§ (qвВВ:вДЭ) := by exact_mod_cast hqвВВ
  have hqвВВ0 : (0:вДЭ) < (qвВВ:вДЭ) := by linarith
  have hB1 : (2:вДЭ) вЙ§ (qвВВ:вДЭ) + 1 := by linarith
  have hlogqвВВ : (0:вДЭ) вЙ§ Real.log qвВВ := Real.log_nonneg hqвВВr
  -- name the pieces
  obtain вЯ®P, hPвЯ© : вИГ P : вДЭ,
      P = 1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2 + 1 := вЯ®_, rflвЯ©
  obtain вЯ®T, hTвЯ© : вИГ T : вДЭ, T = ((2 * (820 * P) ^ ((40:вДЭ)))) ^ (1 - ќ≤вВБ) := вЯ®_, rflвЯ©
  rw [вЖР hP, вЖР hT]
  have hP1 : (1:вДЭ) вЙ§ P := by
    rw [hP]
    have h0 : (0:вДЭ) вЙ§ 1000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2 := by positivity
    linarith
  have hP0 : (0:вДЭ) < P := by linarith
  have h820P : (0:вДЭ) < 820 * P := by linarith
  have hinner0 : (0:вДЭ) < (820 * P) ^ ((40:вДЭ)) := Real.rpow_pos_of_pos h820P _
  have hbase0 : (0:вДЭ) < 2 * (820 * P) ^ ((40:вДЭ)) := by linarith
  -- log P вЙ§ log 2000 + 2 log A + 2 log B вЙ§ 2000 + 2 log A + 2 log B
  have hlogP : Real.log P вЙ§ 2000 + 2 * Real.log ((qвВБ:вДЭ) + 1) + 2 * Real.log ((qвВВ:вДЭ) + 1) := by
    have h1 : P вЙ§ 2000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2 := by
      rw [hP]
      have hA2 : (4:вДЭ) вЙ§ ((qвВБ:вДЭ) + 1) ^ 2 := by nlinarith [hA1]
      have hB2 : (4:вДЭ) вЙ§ ((qвВВ:вДЭ) + 1) ^ 2 := by nlinarith [hB1]
      nlinarith [hA2, hB2]
    have h2 : Real.log P вЙ§ Real.log (2000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2) :=
      Real.log_le_log hP0 h1
    have h3 : Real.log (2000 * ((qвВБ:вДЭ) + 1) ^ 2 * ((qвВВ:вДЭ) + 1) ^ 2)
        = Real.log 2000 + 2 * Real.log ((qвВБ:вДЭ) + 1) + 2 * Real.log ((qвВВ:вДЭ) + 1) := by
      rw [Real.log_mul (by positivity) (by positivity),
        Real.log_mul (by positivity) (by positivity),
        Real.log_pow, Real.log_pow]
      push_cast
      ring
    have h4 : Real.log 2000 вЙ§ 2000 := by
      have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < 2000 by norm_num)
      linarith
    linarith
  -- log T вЙ§ (1вИТќ≤вВБ)(112802 + 80 log A) + (1вИТќ≤вВБ)¬Ј80¬Јlog B
  have hlogT : Real.log T вЙ§ (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
      + (ќµ / 4) * Real.log ((qвВВ:вДЭ) + 1) := by
    rw [hT, Real.log_rpow hbase0]
    have h1 : Real.log (2 * (820 * P) ^ ((40:вДЭ)))
        = Real.log 2 + 40 * Real.log (820 * P) := by
      rw [Real.log_mul (by norm_num) (ne_of_gt hinner0), Real.log_rpow h820P]
    have h2 : Real.log (820 * P) = Real.log 820 + Real.log P := by
      rw [Real.log_mul (by norm_num) (ne_of_gt hP0)]
    have h3 : Real.log 820 вЙ§ 820 := by
      have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < 820 by norm_num)
      linarith
    have h4 : Real.log 2 вЙ§ 2 := by
      have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < 2 by norm_num)
      linarith
    have hlogB0 : (0:вДЭ) вЙ§ Real.log ((qвВВ:вДЭ) + 1) := Real.log_nonneg (by linarith)
    have hlogA0 : (0:вДЭ) вЙ§ Real.log ((qвВБ:вДЭ) + 1) := Real.log_nonneg (by linarith)
    have h5 : Real.log (2 * (820 * P) ^ ((40:вДЭ)))
        вЙ§ 112802 + 80 * Real.log ((qвВБ:вДЭ) + 1) + 80 * Real.log ((qвВВ:вДЭ) + 1) := by
      rw [h1, h2]
      linarith [hlogP]
    have h6 : (1 - ќ≤вВБ) * Real.log (2 * (820 * P) ^ ((40:вДЭ)))
        вЙ§ 1 * (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
          + (1 - ќ≤вВБ) * (80 * Real.log ((qвВВ:вДЭ) + 1)) := by
      have h7 : (1 - ќ≤вВБ) * Real.log (2 * (820 * P) ^ ((40:вДЭ)))
          вЙ§ (1 - ќ≤вВБ) * (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1)
            + 80 * Real.log ((qвВВ:вДЭ) + 1)) :=
        mul_le_mul_of_nonneg_left h5 hќ≤pos
      have h8 : (1 - ќ≤вВБ) вЙ§ 1 := by
        have : (0:вДЭ) < ќµ / 320 := by linarith
        linarith [hќ≤w, hќµ1]
      nlinarith [h7, h8, hlogA0, hlogB0, hќ≤pos]
    have h9 : (1 - ќ≤вВБ) * (80 * Real.log ((qвВВ:вДЭ) + 1))
        вЙ§ (ќµ / 4) * Real.log ((qвВВ:вДЭ) + 1) := by
      have : (1 - ќ≤вВБ) * 80 вЙ§ ќµ / 4 := by linarith [hќ≤w]
      nlinarith [hlogB0, this, hќ≤pos]
    linarith [h6, h9]
  -- T вЙ§ KвВБ ¬Ј (qвВВ+1)^{ќµ/4}
  have hT0 : (0:вДЭ) < T := by
    rw [hT]
    exact Real.rpow_pos_of_pos hbase0 _
  have hTle : T вЙ§ Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
      * ((qвВВ:вДЭ) + 1) ^ (ќµ / 4) := by
    have h1 : T = Real.exp (Real.log T) := (Real.exp_log hT0).symm
    rw [h1]
    have h2 : ((qвВВ:вДЭ) + 1) ^ (ќµ / 4)
        = Real.exp ((ќµ / 4) * Real.log ((qвВВ:вДЭ) + 1)) := by
      rw [Real.rpow_def_of_pos (by linarith), mul_comm]
    rw [h2, вЖР Real.exp_add]
    exact Real.exp_le_exp.mpr hlogT
  -- (qвВВ+1)^{ќµ/4} вЙ§ 2¬ЈqвВВ^{ќµ/4}
  have hBpow : ((qвВВ:вДЭ) + 1) ^ (ќµ / 4) вЙ§ 2 * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
    calc ((qвВВ:вДЭ) + 1) ^ (ќµ / 4) вЙ§ (2 * (qвВВ:вДЭ)) ^ (ќµ / 4) := by
          apply Real.rpow_le_rpow (by linarith) (by linarith) (by linarith)
      _ = (2:вДЭ) ^ (ќµ / 4) * ((qвВВ:вДЭ)) ^ (ќµ / 4) :=
          Real.mul_rpow (by norm_num) hqвВВ0.le
      _ вЙ§ 2 * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
          apply mul_le_mul_of_nonneg_right _ (Real.rpow_nonneg hqвВВ0.le _)
          calc (2:вДЭ) ^ (ќµ / 4) вЙ§ (2:вДЭ) ^ ((1:вДЭ)) :=
                Real.rpow_le_rpow_of_exponent_le (by norm_num) (by linarith)
            _ = 2 := Real.rpow_one 2
  -- 3 + log(qвВБqвВВ) вЙ§ (3+log qвВБ)¬Ј(5/ќµ)¬ЈqвВВ^{ќµ/4}
  have hlogsplit : Real.log ((qвВБ * qвВВ : вДХ)) = Real.log qвВБ + Real.log qвВВ := by
    push_cast
    rw [Real.log_mul (by linarith) (by linarith)]
  have hlogqвВВ' : Real.log qвВВ вЙ§ (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
    have h1 : Real.log qвВВ вЙ§ ((qвВВ:вДЭ)) ^ (ќµ / 4) / (ќµ / 4) :=
      Real.log_le_rpow_div hqвВВ0.le (by linarith)
    have h2 : ((qвВВ:вДЭ)) ^ (ќµ / 4) / (ќµ / 4) = (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
      field_simp
    linarith [h1, h2.le, h2.ge]
  have hpow1 : (1:вДЭ) вЙ§ ((qвВВ:вДЭ)) ^ (ќµ / 4) := Real.one_le_rpow hqвВВr (by linarith)
  have hfac : 3 + Real.log ((qвВБ * qвВВ : вДХ))
      вЙ§ (3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
    rw [hlogsplit, вЖР add_assoc]
    have h1 : 3 + Real.log qвВБ + Real.log qвВВ
        вЙ§ (3 + Real.log qвВБ) * (1 + (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
      have h2 : (1:вДЭ) вЙ§ 3 + Real.log qвВБ := by linarith
      nlinarith [hlogqвВВ', h2, hlogqвВВ]
    have h3 : (1:вДЭ) + (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) вЙ§ (5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
      have h4 : (1:вДЭ) вЙ§ (1 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by
        have h5 : (1:вДЭ) вЙ§ 1 / ќµ := by
          rw [le_div_iffвВА hќµ0]
          linarith
        nlinarith [hpow1, h5]
      have h6 : (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) + (1 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)
          = (5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4) := by ring
      linarith
    have h7 : (0:вДЭ) вЙ§ 3 + Real.log qвВБ := by linarith
    calc 3 + Real.log qвВБ + Real.log qвВВ
        вЙ§ (3 + Real.log qвВБ) * (1 + (4 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := h1
      _ вЙ§ (3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) :=
          mul_le_mul_of_nonneg_left h3 h7
  -- assemble
  have hpowmul : ((qвВВ:вДЭ)) ^ (ќµ / 4) * ((qвВВ:вДЭ)) ^ (ќµ / 4) = ((qвВВ:вДЭ)) ^ (ќµ / 2) := by
    rw [вЖР Real.rpow_add hqвВВ0]
    congr 1
    ring
  have hdenвВБ : (0:вДЭ) < 3 + Real.log qвВБ := by linarith
  have hKвВБ0 : (0:вДЭ) < Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1)) := Real.exp_pos _
  calc 26 * T * (3 + Real.log qвВБ) * (3 + Real.log ((qвВБ * qвВВ : вДХ)))
      вЙ§ 26 * (Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
          * (2 * ((qвВВ:вДЭ)) ^ (ќµ / 4))) * (3 + Real.log qвВБ)
        * ((3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4))) := by
        have hT2 : T вЙ§ Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
            * (2 * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
          calc T вЙ§ Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
              * ((qвВВ:вДЭ) + 1) ^ (ќµ / 4) := hTle
            _ вЙ§ Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
                * (2 * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
                apply mul_le_mul_of_nonneg_left hBpow hKвВБ0.le
        have h30 : (0:вДЭ) вЙ§ 3 + Real.log ((qвВБ * qвВВ : вДХ)) := by
          have := Real.log_nonneg (show (1:вДЭ) вЙ§ ((qвВБ * qвВВ : вДХ):вДЭ) from by
            exact_mod_cast Nat.one_le_iff_ne_zero.mpr (Nat.mul_ne_zero (by omega) (by omega)))
          linarith
        have hfac0 : (0:вДЭ) вЙ§ (3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
          positivity
        calc 26 * T * (3 + Real.log qвВБ) * (3 + Real.log ((qвВБ * qвВВ : вДХ)))
            вЙ§ 26 * T * (3 + Real.log qвВБ)
              * ((3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4))) := by
              apply mul_le_mul_of_nonneg_left hfac
              positivity
          _ вЙ§ 26 * (Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
                * (2 * ((qвВВ:вДЭ)) ^ (ќµ / 4))) * (3 + Real.log qвВБ)
              * ((3 + Real.log qвВБ) * ((5 / ќµ) * ((qвВВ:вДЭ)) ^ (ќµ / 4))) := by
              apply mul_le_mul_of_nonneg_right _ hfac0
              apply mul_le_mul_of_nonneg_right _ hdenвВБ.le
              apply mul_le_mul_of_nonneg_left hT2 (by norm_num)
    _ = ((260 / ќµ) * Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
          * (3 + Real.log qвВБ) ^ 2) * (((qвВВ:вДЭ)) ^ (ќµ / 4) * ((qвВВ:вДЭ)) ^ (ќµ / 4)) := by
        ring
    _ = ((260 / ќµ) * Real.exp (112802 + 80 * Real.log ((qвВБ:вДЭ) + 1))
          * (3 + Real.log qвВБ) ^ 2) * ((qвВВ:вДЭ)) ^ (ќµ / 2) := by
        rw [hpowmul]

/-- **The small-modulus gap** (Siegel brick S3c-f): below any threshold `QвВА` there
    are finitely many characters, so a single `c > 0` clears a zero-free interval
    below `1` for all of them at once. -/
theorem small_q_gap (QвВА : вДХ) :
    вИГ c : вДЭ, 0 < c вИІ вИА (q : вДХ) [NeZero q], 3 вЙ§ q вЖТ q < QвВА вЖТ
      вИА ѕЗ : DirichletCharacter вДВ q, ѕЗ вЙ† 1 вЖТ
      вИА ќ≤ : вДЭ, 1 - c вЙ§ ќ≤ вЖТ ќ≤ < 1 вЖТ
        DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ)) вЙ† 0 := by
  induction QвВА with
  | zero =>
    exact вЯ®1, one_pos, fun q _ _ hq0 => absurd hq0 (by omega)вЯ©
  | succ Q ih =>
    obtain вЯ®c', hc'0, hc'вЯ© := ih
    rcases Nat.lt_or_ge Q 3 with hQ3 | hQ3
    ¬Ј -- the new modulus Q is below 3: nothing new to cover
      refine вЯ®c', hc'0, ?_вЯ©
      intro q _ hq3 hqlt ѕЗ hѕЗ1 ќ≤ hќ≤1 hќ≤2
      have hqQ : q < Q := by omega
      exact hc' q hq3 hqQ ѕЗ hѕЗ1 ќ≤ hќ≤1 hќ≤2
    ¬Ј -- take the min over the finitely many characters mod Q
      haveI : NeZero Q := вЯ®by omegaвЯ©
      haveI : Finite (DirichletCharacter вДВ Q) :=
        inferInstanceAs (Finite (MulChar (ZMod Q) вДВ))
      haveI := Fintype.ofFinite (DirichletCharacter вДВ Q)
      have hF : вИА ѕЗ : DirichletCharacter вДВ Q, вИГ ќі : вДЭ, 0 < ќі вИІ
          (ѕЗ вЙ† 1 вЖТ вИА ќ≤ : вДЭ, 1 - ќі вЙ§ ќ≤ вЖТ ќ≤ < 1 вЖТ
            DirichletCharacter.LFunction ѕЗ ((ќ≤:вДВ)) вЙ† 0) := by
        intro ѕЗ
        by_cases h : ѕЗ = 1
        ¬Ј exact вЯ®1, one_pos, fun h1 => absurd h h1вЯ©
        ¬Ј obtain вЯ®ќі, hќі0, hќівЯ© := fixed_char_gap ѕЗ h
          exact вЯ®ќі, hќі0, fun _ => hќівЯ©
      choose ќіf hќіf0 hќіf using hF
      have hne : (Finset.univ : Finset (DirichletCharacter вДВ Q)).Nonempty :=
        вЯ®1, Finset.mem_univ 1вЯ©
