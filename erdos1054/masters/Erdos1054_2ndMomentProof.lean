  have hlogM : Real.log M вЙ§ 2 * sM := by
    have h := Real.log_le_rpow_div hM0.le (show (0:вДЭ) < 1/2 by norm_num)
    rw [вЖР hsMdef] at h
    linarith
  have h80s : 80 * sM вЙ§ M / 2 := by nlinarith [hsq, h160, hsM0]
  -- nonzeroness for log_mul
  have hNne : ((N:вДЭ)) вЙ† 0 := ne_of_gt (lt_of_lt_of_le zero_lt_one hN1)
  have h47ne : (4 * |ќ≥| + 7 : вДЭ) вЙ† 0 := ne_of_gt h47
  have hѕГne : ѕГ вЙ† 0 := ne_of_gt hѕГ0
  have hMne : M вЙ† 0 := ne_of_gt hM0
  -- the a-priori majorant: K_A вЙ§ M
  have hKA : 40 * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)) + 1) вЙ§ M := by
    have hlogѕГ : Real.log ѕГ вЙ§ 1 := by
      have h := Real.log_le_sub_one_of_pos hѕГ0
      have hѕГ1e : ѕГ - 1 вЙ§ 1 := by
        rw [hѕГ1', div_le_one (by linarith)]
        linarith
      linarith
    have hlog100 : Real.log 100 вЙ§ 18 := by
      have h10 : Real.log 10 вЙ§ 9 := by
        have := Real.log_le_sub_one_of_pos (show (0:вДЭ) < 10 by norm_num)
        linarith
      have h100 : Real.log 100 = Real.log 10 + Real.log 10 := by
        rw [вЖР Real.log_mul (by norm_num) (by norm_num)]
        norm_num
      linarith
    have hsplit : (N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)
        = (N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ * (100 * M) := by
      rw [hѕГ1', div_eq_mul_inv, one_div, inv_inv]
    rw [hsplit]
    have hlogprod : Real.log ((N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ * (100 * M))
        = Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + Real.log ѕГ
          + (Real.log 100 + Real.log M) := by
      rw [Real.log_mul (mul_ne_zero (mul_ne_zero hNne h47ne) hѕГne)
          (by norm_num; exact hMne : (100 * M : вДЭ) вЙ† 0),
        Real.log_mul (mul_ne_zero hNne h47ne) hѕГne,
        Real.log_mul (by norm_num : (100:вДЭ) вЙ† 0) hMne]
    rw [hlogprod]
    have hM40 : 80 * Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 1600 вЙ§ M := by
      rw [hMdef]
      nlinarith
    nlinarith [hlogѕГ, hlog100, hlogM, h80s]
  -- far case: trivially deep
  rcases le_or_gt (ѕГ - ќ≤) (1/5) with hnear | hfar
  swap
  ¬Ј have hsmall : 1 / (100 * M) вЙ§ (1:вДЭ) / 2560000 := by
      apply div_le_div_of_nonneg_left (by norm_num) (by norm_num)
      linarith
    rw [hѕГdef] at hfar
    have hќ≤far : ќ≤ < (0.81 : вДЭ) := by linarith
    have hCbig : (10:вДЭ) вЙ§ 335 * (1360 + KP')
        * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20) := by nlinarith
    have hfrac : 1 / (335 * (1360 + KP') * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20))
        вЙ§ 1/10 := div_le_div_of_nonneg_left (by norm_num) (by norm_num) hCbig
    linarith
  -- main case: the 3-4-1 chain at the single ѕГ
  ¬Ј have hcombo := logDeriv_combo_re_nonneg ѕЗ ѕГ ќ≥ hѕГ1
    have hlin : (3 * LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)
         + 4 * LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * I)
         + LSeries (вЖЧ(ѕЗ ^ 2) * вЖЧќЫ) ((ѕГ : вДВ) + 2 * ќ≥ * I)).re
        = 3 * (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re
          + 4 * (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * I)).re
          + (LSeries (вЖЧ(ѕЗ ^ 2) * вЖЧќЫ) ((ѕГ : вДВ) + 2 * ќ≥ * I)).re := by
      simp [Complex.add_re, Complex.mul_re]
    rw [hlin] at hcombo
    have hpole : (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re
        вЙ§ 1 / (ѕГ - 1) + M := by
      have h := hKP N (1 : DirichletCharacter вДВ N) 0 ѕГ hѕГ1 hѕГ2
      have hpt : ((ѕГ : вДВ) + ((0:вДЭ) : вДВ) * I) = (ѕГ : вДВ) := by push_cast; ring
      rw [hpt] at h
      have hKPM : KP вЙ§ M := by
        rw [hMdef]
        nlinarith
      linarith
    have hzb := zero_bound_uniform N ѕЗ hѕЗ ќ≤ ќ≥ hzero ѕГ hѕГ1 hѕГ2 hnear
    have hKU5 : 40 * (Real.log ((N : вДЭ) * (2 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)) + 1)
        вЙ§ 40 * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)) + 1) := by
      have hle : (N : вДЭ) * (2 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)
          вЙ§ (N : вДЭ) * (4 * |ќ≥| + 7) * ѕГ / (ѕГ - 1) := by
        apply div_le_div_of_nonneg_right _ (by rw [hѕГ1']; exact hinv0.le)
        have h1 : (N:вДЭ) * (2 * |ќ≥| + 7) вЙ§ (N:вДЭ) * (4 * |ќ≥| + 7) := by
          nlinarith [abs_nonneg ќ≥]
        exact mul_le_mul_of_nonneg_right h1 hѕГ0.le
      have hpos : (0:вДЭ) < (N : вДЭ) * (2 * |ќ≥| + 7) * ѕГ / (ѕГ - 1) := by
        rw [hѕГ1']
        have h27 : (0:вДЭ) < (N:вДЭ) * (2 * |ќ≥| + 7) := by nlinarith [abs_nonneg ќ≥]
        have := mul_pos h27 hѕГ0
