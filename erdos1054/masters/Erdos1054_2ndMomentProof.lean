      simp only [Finset.mem_Icc]
      omega
    have hterm1 : a 1 * (((1:вДХ)):вДЭ) ^ (-ќ≤) = 1 := by
      rw [ha1, Nat.cast_one, Real.one_rpow, one_mul]
    calc (1:вДЭ) = a 1 * (((1:вДХ)):вДЭ) ^ (-ќ≤) := hterm1.symm
      _ вЙ§ вИС n вИИ Icc 1 x, a n * ((n:вДЭ)) ^ (-ќ≤) := by
          apply Finset.single_le_sum (f := fun n : вДХ => a n * ((n:вДЭ)) ^ (-ќ≤)) _ h1mem
          intro n _
