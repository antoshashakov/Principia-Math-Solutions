/-- `d/dx e(c¬Јx) = 2ѕАi¬Јc¬Јe(c¬Јx)`. -/
lemma hasDerivAt_e (c x : вДЭ) :
    HasDerivAt (fun t : вДЭ => e (c * t)) (2 * Real.pi * Complex.I * c * e (c * x)) x := by
  have hr : HasDerivAt (fun t : вДЭ => c * t) c x := by
    simpa using (hasDerivAt_id x).const_mul c
  have h2 := (hr.ofReal_comp.const_mul (2 * Real.pi * Complex.I : вДВ)).cexp
  have hfe : (fun t : вДЭ => e (c * t))
      = (fun t : вДЭ => Complex.exp ((2 * Real.pi * Complex.I : вДВ) * ((c * t : вДЭ) : вДВ))) := by
    funext t; simp only [e]
  rw [hfe]
  have hv : 2 * Real.pi * Complex.I * c * e (c * x)
      = Complex.exp ((2 * Real.pi * Complex.I : вДВ) * ((c * x : вДЭ) : вДВ))
        * (2 * Real.pi * Complex.I * (c : вДВ)) := by
    simp only [e]; push_cast; ring
  rw [hv]; exact h2

/-- **Character orthogonality**: `вИЂвВА¬є e(m¬Јx) dx = 1` if `m = 0`, else `0`, for `m : вД§`. The
    backbone of the full-period Dirichlet-kernel value and the major-arc extraction. -/
lemma integral_e_int (m : вД§) :
    (вИЂ x in (0:вДЭ)..1, e ((m : вДЭ) * x)) = if m = 0 then 1 else 0 := by
  by_cases hm : m = 0
  ¬Ј subst hm
    simp only [Int.cast_zero, zero_mul, if_pos rfl, e]
    simp
  ¬Ј rw [if_neg hm]
    have hc : (2 * Real.pi * Complex.I * (m : вДЭ)) вЙ† 0 := by
      have hpi : (Real.pi : вДЭ) вЙ† 0 := Real.pi_ne_zero
      have hmr : ((m : вДЭ) : вДВ) вЙ† 0 := by exact_mod_cast (by exact_mod_cast hm : (m : вДЭ) вЙ† 0)
      simp only [ne_eq, mul_eq_zero, not_or]
      exact вЯ®вЯ®вЯ®by norm_num, by exact_mod_cast hpiвЯ©, Complex.I_ne_zeroвЯ©, hmrвЯ©
    have hderiv : вИА x вИИ Set.uIcc (0:вДЭ) 1,
        HasDerivAt (fun t : вДЭ => e ((m : вДЭ) * t) / (2 * Real.pi * Complex.I * (m : вДЭ)))
          (e ((m : вДЭ) * x)) x := by
      intro x _
      have h2 := (hasDerivAt_e (m : вДЭ) x).div_const (2 * Real.pi * Complex.I * (m : вДЭ))
      have hval : 2 * Real.pi * Complex.I * (m : вДЭ) * e ((m : вДЭ) * x)
            / (2 * Real.pi * Complex.I * (m : вДЭ)) = e ((m : вДЭ) * x) := by
        rw [mul_comm (2 * Real.pi * Complex.I * (m : вДЭ)) (e ((m : вДЭ) * x)),
          mul_div_assoc, div_self hc, mul_one]
      rw [hval] at h2
      exact h2
    rw [intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv
      (Continuous.intervalIntegrable (by simp only [e]; fun_prop) 0 1)]
    have he1 : e ((m : вДЭ) * 1) = 1 := by
      have harg : (2 * Real.pi * Complex.I : вДВ) * (((m : вДЭ) * 1 : вДЭ) : вДВ)
          = ((m : вД§) : вДВ) * (2 * (Real.pi : вДВ) * Complex.I) := by push_cast; ring
      simp only [e]
      rw [harg]
      exact Complex.exp_int_mul_two_pi_mul_I m
    have he0 : e ((m : вДЭ) * 0) = 1 := by simp [e]
    rw [he1, he0]; ring


/-- **Full-period Dirichlet-kernel value**: `вИЂвВА¬є (вИС_{k<N} e(kќ≤))¬≤ e(вИТnќ≤) dќ≤ = r_N(n)`, the
    count `#{(k,k')вИИ[0,N)¬≤: k+k'=n}`. Termwise orthogonality picks out `k+k'=n`; this is the
    value each major arc localizes. -/
lemma dirichlet_full (N n : вДХ) :
    (вИЂ ќ≤ in (0:вДЭ)..1, (вИС k вИИ Finset.range N, e ((k:вДЭ) * ќ≤))^2 * e (-(n:вДЭ) * ќ≤))
      = (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) := by
  have key : (fun ќ≤ : вДЭ => (вИС k вИИ Finset.range N, e ((k:вДЭ) * ќ≤))^2 * e (-(n:вДЭ) * ќ≤))
      = (fun ќ≤ : вДЭ => вИС p вИИ Finset.range N √ЧЋҐ Finset.range N,
          e (((((p.1 : вД§) + (p.2 : вД§) - (n : вД§)) : вД§) : вДЭ) * ќ≤)) := by
    funext ќ≤
    rw [sq, Finset.sum_mul_sum, вЖР Finset.sum_product', Finset.sum_mul]
    apply Finset.sum_congr rfl
    intro p _
    rw [e_add, e_add]
    congr 1
    push_cast; ring
  rw [key, intervalIntegral.integral_finset_sum
    (fun p _ => Continuous.intervalIntegrable (by simp only [e]; fun_prop) 0 1)]
  rw [Finset.sum_congr rfl (fun p (_ : p вИИ Finset.range N √ЧЋҐ Finset.range N) =>
    integral_e_int ((p.1 : вД§) + (p.2 : вД§) - (n : вД§)))]
  rw [Finset.sum_ite, Finset.sum_const_zero, add_zero, Finset.sum_const, nsmul_eq_mul, mul_one]
  congr 1
  congr 1
  refine Finset.filter_congr (fun p _ => ?_)
  constructor <;> intro h <;> omega

/-- **Kernel count**: for `n вЙ§ X`, the number of ordered pairs `(k,k') вИИ [0,X]¬≤` with
    `k+k'=n` is exactly `n+1` (`k` ranges freely over `0..n`, `k'=n-k` always fits). This is
    `r_{X+1}(n)`, the full-period value `вИЂвВА¬є D_{X+1}(ќ≤)¬≤ e(вИТnќ≤) dќ≤` of the Dirichlet kernel. -/
lemma kernel_count (X n : вДХ) (hn : n вЙ§ X) :
    ((Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun p => p.1 + p.2 = n)).card
      = n + 1 := by
  rw [вЖР Finset.card_range (n + 1)]
  apply Finset.card_bij (fun p _ => p.1)
  ¬Ј intro p hp
    rw [Finset.mem_filter, Finset.mem_product, Finset.mem_range, Finset.mem_range] at hp
    rw [Finset.mem_range]; omega
  ¬Ј intro p hp p' hp' heq
    rw [Finset.mem_filter, Finset.mem_product, Finset.mem_range, Finset.mem_range] at hp hp'
    have : p.2 = p'.2 := by omega
    exact Prod.ext heq this
  ¬Ј intro k hk
    rw [Finset.mem_range] at hk
    refine вЯ®(k, n - k), ?_, rflвЯ©
    rw [Finset.mem_filter, Finset.mem_product, Finset.mem_range, Finset.mem_range]
    omega

/-- **Kernel factor is `вЙН X`**: for `n вИИ (X/2, X]`, the (real) kernel count `r_{X+1}(n) = n+1`
    is `вЙ• X/2`. This is the `r_N(n)` factor of the main term `рЭФЦ_P(n)¬Јr_N(n)`; combined with
    singular-series positivity `рЭФЦ_P(n) вЙ• cвВА` it gives `hmain`'s lower bound `вЙ• cвВА¬ЈX/2`. -/
lemma kernel_real_lb (X n : вДХ) (h1 : X / 2 < n) (h2 : n вЙ§ X) :
    (X : вДЭ) / 2
      вЙ§ (((Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter
          (fun p => p.1 + p.2 = n)).card : вДЭ) := by
  rw [kernel_count X n h2]
  have hXle : X вЙ§ 2 * n := by omega
  have hXR : (X : вДЭ) вЙ§ 2 * (n : вДЭ) := by exact_mod_cast hXle
  push_cast
  linarith

/-- The Ramanujan sum `c_q(n) = вИС_{r<q, gcd(r,q)=1} e(nr/q)` вАФ the arithmetic factor of the
    singular-series local terms `ќЉ(q)¬≤¬Јc_q(n)/ѕЖ(q)¬≤`. -/
noncomputable def ramSum (q n : вДХ) : вДВ :=
  вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((n : вДЭ) * r / q)

/-- The Ramanujan sum as an explicit **integer**: `c_q(n) = вИС_{dвИ£q} ќЉ(d)¬Ј[ (q/d)вИ£n ]¬Ј(q/d)`.
    Having a вД§-valued form makes the singular series `рЭФЦ_P(n) = вИС_{qвЙ§P} ќЉ(q)¬≤¬Јc_q(n)/ѕЖ(q)¬≤` a
    genuinely real object (no `.re` juggling). -/
def cRam (q n : вДХ) : вД§ :=
  вИС d вИИ q.divisors, ArithmeticFunction.moebius d * (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0)

/-- **The Ramanujan sum is real (integer-valued)**: `ramSum q n = (cRam q n : вДВ)`. -/
lemma ramSum_eq_cRam (q n : вДХ) (hq : 0 < q) : ramSum q n = (cRam q n : вДВ) := by
  have h := ramanujan_sum_divisor (n : вД§) q hq
  rw [ramSum]
  have hlhs : (вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((n : вДЭ) * r / q))
      = вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e (((n : вД§) : вДЭ) * r / q) := by
    apply Finset.sum_congr rfl; intro r _; rw [Int.cast_natCast]
  rw [hlhs, h, cRam, Int.cast_sum]
  refine Finset.sum_congr rfl (fun d _ => ?_)
  rw [Int.cast_mul, Int.cast_ite, Int.cast_natCast, Int.cast_zero]
  congr 1
  exact if_congr Int.natCast_dvd_natCast rfl rfl

/-- `g_n(m) = [m вИ£ n]¬Јm`, a multiplicative arithmetic function; the point is `cRam(¬Ј,n) = ќЉ вЛЖ g_n`,
    which makes `cRam` multiplicative in `q` for free (Dirichlet-convolution of two multiplicative
    functions). This is the engine of the singular series' Euler product. -/
def gArith (n : вДХ) : ArithmeticFunction вД§ :=
  вЯ®fun m => if m вИ£ n then (m : вД§) else 0, by simpвЯ©

lemma gArith_apply (n m : вДХ) : gArith n m = if m вИ£ n then (m : вД§) else 0 := rfl

/-- `cRam(¬Ј,n)` is the Dirichlet convolution `ќЉ вЛЖ g_n`. -/
lemma cRam_eq_conv (q n : вДХ) : cRam q n = (ArithmeticFunction.moebius * gArith n) q := by
  rw [ArithmeticFunction.mul_apply, Nat.sum_divisorsAntidiagonal
      (f := fun d e => (ArithmeticFunction.moebius d) * gArith n e)]
  rw [cRam]
  apply Finset.sum_congr rfl
  intro d _
  rw [gArith_apply]

lemma isMult_gArith (n : вДХ) : (gArith n).IsMultiplicative := by
  refine вЯ®by rw [gArith_apply]; simp, ?_вЯ©
  intro a b hab
  simp only [gArith_apply]
  by_cases ha : a вИ£ n <;> by_cases hb : b вИ£ n
  ¬Ј rw [if_pos ha, if_pos hb, if_pos (Nat.Coprime.mul_dvd_of_dvd_of_dvd hab ha hb)]; push_cast; ring
  ¬Ј rw [if_pos ha, if_neg hb, if_neg (fun h => hb (dvd_trans (Dvd.intro_left a rfl) h))]; ring
  ¬Ј rw [if_neg ha, if_pos hb, if_neg (fun h => ha (dvd_trans (Dvd.intro b rfl) h))]; ring
  ¬Ј rw [if_neg ha, if_neg hb, if_neg (fun h => ha (dvd_trans (Dvd.intro b rfl) h))]; ring

/-- **Ramanujan-sum multiplicativity**: `c_{qвВБqвВВ}(n) = c_{qвВБ}(n)¬Јc_{qвВВ}(n)` for coprime `qвВБ,qвВВ`.
    Combined with `ramSum_prime` this evaluates `c_q(n)` over the primes and drives the Euler
    product of the singular series. -/
lemma cRam_mul (n q1 q2 : вДХ) (h : Nat.Coprime q1 q2) :
    cRam (q1 * q2) n = cRam q1 n * cRam q2 n := by
  rw [cRam_eq_conv, cRam_eq_conv, cRam_eq_conv]
  exact (ArithmeticFunction.isMultiplicative_moebius.mul (isMult_gArith n)).2 h

/-- **Ramanujan sum at a prime**: `c_p(n) = pвИТ1` if `p вИ£ n`, else `вИТ1`. The base case of the
    singular series' Euler product: at `p вИ§ n` it is `ќЉ(p) = вИТ1` (via `ramanujan_sum_coprime`,
    since `gcd(n,p)=1`); at `p вИ£ n` every `e(nr/p) = 1` so the sum is `ѕЖ(p) = pвИТ1`. -/
lemma ramSum_prime (p n : вДХ) (hp : p.Prime) :
    ramSum p n = if p вИ£ n then (p - 1 : вДВ) else -1 := by
  by_cases hd : p вИ£ n
  ¬Ј rw [if_pos hd]
    have hp0 : (p : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hp.pos.ne'
    obtain вЯ®k, hkвЯ© := hd
    have hval : ramSum p n
        = вИС _r вИИ (Finset.range p).filter (fun r => Nat.gcd r p = 1), (1 : вДВ) := by
      rw [ramSum]
      apply Finset.sum_congr rfl
      intro r _
      have hpr : ((n : вДЭ) * (r : вДЭ) / (p : вДЭ)) = ((k * r : вДХ) : вДЭ) := by
        rw [hk]; push_cast; field_simp
      rw [hpr]
      simp only [e]
      rw [show (2 * Real.pi * Complex.I * (((k * r : вДХ) : вДЭ) : вДВ))
            = ((k * r : вД§) : вДВ) * (2 * (Real.pi : вДВ) * Complex.I) by push_cast; ring]
      exact Complex.exp_int_mul_two_pi_mul_I _
    rw [hval, Finset.sum_const, nsmul_eq_mul, mul_one]
    have hcard : ((Finset.range p).filter (fun r => Nat.gcd r p = 1)).card = p - 1 := by
      rw [вЖР Nat.totient_prime hp, Nat.totient_eq_card_coprime]
      apply Finset.card_bij (fun r _ => r)
      ¬Ј intro r hr
        rw [Finset.mem_filter] at hr вКҐ
        exact вЯ®hr.1, by rw [Nat.Coprime, Nat.gcd_comm]; exact hr.2вЯ©
      ¬Ј intro r _ r' _ h; exact h
      ¬Ј intro r hr
        rw [Finset.mem_filter] at hr
        exact вЯ®r, by rw [Finset.mem_filter]; exact вЯ®hr.1, by rw [Nat.gcd_comm]; exact hr.2вЯ©, rflвЯ©
    rw [hcard]
    have hp1 : 1 вЙ§ p := hp.one_lt.le
    push_cast [Nat.cast_sub hp1]
    ring
  ¬Ј rw [if_neg hd]
    have hcop : Int.gcd (n : вД§) p = 1 := by
      have hc : Nat.Coprime n p := (hp.coprime_iff_not_dvd.mpr hd).symm
      rw [Int.gcd_natCast_natCast]; exact hc
    have hr := ramanujan_sum_coprime (n : вД§) p hp.pos hcop
    have hbridge : ramSum p n
        = вИС r вИИ (Finset.range p).filter (fun r => Nat.gcd r p = 1),
            e ((((n : вД§) : вДЭ)) * r / p) := by
      rw [ramSum]
      apply Finset.sum_congr rfl
      intro r _
      rw [Int.cast_natCast]
    rw [hbridge, hr]
    norm_num [ArithmeticFunction.moebius_apply_prime hp]

/-- **The integer Ramanujan sum at a prime**: `c_p(n) = pвИТ1` if `pвИ£n`, else `вИТ1`. Follows from
    `ramSum_prime` through `ramSum_eq_cRam` + injectivity of `вД§ вЖ™ вДВ`. Together with `cRam_mul`
    this gives `c_q(n) = вИП_{pвИ£q}(вА¶)` for every squarefree `q`. -/
lemma cRam_prime (p n : вДХ) (hp : p.Prime) :
    cRam p n = if p вИ£ n then ((p : вД§) - 1) else -1 := by
  have h1 : (cRam p n : вДВ) = if p вИ£ n then ((p : вДВ) - 1) else -1 := by
    rw [вЖР ramSum_eq_cRam p n hp.pos, ramSum_prime p n hp]
  have h2 : ((if p вИ£ n then ((p : вД§) - 1) else -1 : вД§) : вДВ)
      = if p вИ£ n then ((p : вДВ) - 1) else -1 := by
    split <;> push_cast <;> ring
  exact_mod_cast h1.trans h2.symm

/-- `c_1(n) = 1` (the `q=1` term of the singular series). -/
lemma cRam_one (n : вДХ) : cRam 1 n = 1 := by
  simp [cRam, Nat.divisors_one]

/-- **Closed Ramanujan formula (squared)**: for squarefree `q`, `c_q(n)¬≤ = ѕЖ(gcd(q,n))¬≤`. Since
    `c_q(n) = ќЉ(q/g)¬ЈѕЖ(g)` (`g = gcd(q,n)`) and `ќЉ¬≤ = 1` on squarefree, the square drops the sign.
    Strong induction peeling `minFac`, via `cRam_mul` (multiplicativity) + `cRam_prime` (base) +
    `gcd(pm,n)=gcd(p,n)gcd(m,n)` (coprime). This is the clean `|c_q(n)| = ѕЖ(gcd(q,n))` that makes the
    Ramanujan sum constant on gcd-fibers вАФ the crux of the arithmetic length-capped mean square
    `вИС_{n<N} c_q(n)¬≤ вЙ§ e¬ЈN¬ЈѕЖ(q)` (avoids the `ѕГ(q)¬≤` error of the naive lcm-expansion). -/
lemma cRam_sq_sqfree (q n : вДХ) (hq : Squarefree q) :
    (cRam q n) ^ 2 = (Nat.totient (Nat.gcd q n) : вД§) ^ 2 := by
  induction q using Nat.strong_induction_on with
  | _ q IH =>
    rcases eq_or_ne q 1 with rfl | hq1
    ¬Ј simp [cRam_one, Nat.gcd_one_left, Nat.totient_one]
    ¬Ј have hq0 : q вЙ† 0 := hq.ne_zero
      have hpp : (q.minFac).Prime := Nat.minFac_prime hq1
      have hpdvd : q.minFac вИ£ q := Nat.minFac_dvd q
      set p := q.minFac with hp
      set m := q / p with hm
      have hpm : p * m = q := Nat.mul_div_cancel' hpdvd
      have hmpos : 0 < m := by
        rcases Nat.eq_zero_or_pos m with h | h
        ¬Ј rw [h, mul_zero] at hpm; omega
        ¬Ј exact h
      have hmdvd : m вИ£ q := вЯ®p, by rw [вЖР hpm]; ringвЯ©
      have hcop : Nat.Coprime p m := by
        rw [hpp.coprime_iff_not_dvd]
        intro hdvd
        have hpp2 : p * p вИ£ q := by rw [вЖР hpm]; exact mul_dvd_mul_left p hdvd
        exact hpp.ne_one (Nat.isUnit_iff.mp (hq p hpp2))
      have hmsq : Squarefree m := hq.squarefree_of_dvd hmdvd
      have hmlt : m < q := by rw [вЖР hpm]; exact (Nat.lt_mul_iff_one_lt_left hmpos).mpr hpp.one_lt
      have hIH := IH m hmlt hmsq
      have hgcd : Nat.gcd (p * m) n = Nat.gcd p n * Nat.gcd m n := by
        rw [Nat.gcd_comm (p * m) n, hcop.gcd_mul n, Nat.gcd_comm n p, Nat.gcd_comm n m]
      have hcopg : Nat.Coprime (Nat.gcd p n) (Nat.gcd m n) :=
        (hcop.coprime_dvd_left (Nat.gcd_dvd_left p n)).coprime_dvd_right (Nat.gcd_dvd_left m n)
      rw [вЖР hpm, cRam_mul n p m hcop, mul_pow, hIH, hgcd, Nat.totient_mul hcopg]
      push_cast
      rw [mul_pow]
      congr 1
      rw [cRam_prime p n hpp]
      by_cases hpn : p вИ£ n
      ¬Ј rw [if_pos hpn]
        have hgp : Nat.gcd p n = p := Nat.gcd_eq_left hpn
        rw [hgp, Nat.totient_prime hpp]
        push_cast [Nat.cast_sub hpp.one_le]
        ring
      ¬Ј rw [if_neg hpn]
        have hgp : Nat.gcd p n = 1 := hpp.coprime_iff_not_dvd.mpr hpn
        rw [hgp, Nat.totient_one]
        norm_num

/-- **Multiples count** (`n=0` excluded вЗТ no `+1`): `#{nвИИ[1,N) : gвИ£n} вЙ§ (N-1)/g` for `g вЙ• 1`. The
    gcd-fiber `{n : gcd(q,n)=g} вКЖ {n : gвИ£n}`, so this bounds each fiber in the arithmetic
    length-capped mean square `вИС_{n<N} c_q(n)¬≤ = вИС_{g|q} ѕЖ(g)¬≤¬Ј#{gcd=g} вЙ§ (N-1)вИС ѕЖ(g)¬≤/g`. -/
lemma card_multiples_Ico_le (N g : вДХ) (hg : 1 вЙ§ g) :
    ((Finset.Ico 1 N).filter (fun n => g вИ£ n)).card вЙ§ (N - 1) / g := by
  have hsub : (Finset.Ico 1 N).filter (fun n => g вИ£ n)
      вКЖ (Finset.Ico 1 ((N - 1) / g + 1)).image (fun k => g * k) := by
    intro n hn
    rw [Finset.mem_filter, Finset.mem_Ico] at hn
    obtain вЯ®вЯ®hn1, hn2вЯ©, hgnвЯ© := hn
    rw [Finset.mem_image]
    refine вЯ®n / g, ?_, Nat.mul_div_cancel' hgnвЯ©
    rw [Finset.mem_Ico]
    refine вЯ®(Nat.one_le_div_iff (by omega)).mpr (Nat.le_of_dvd (by omega) hgn), ?_вЯ©
    have hle : n вЙ§ N - 1 := by omega
    exact Nat.lt_succ_of_le (Nat.div_le_div_right hle)
  calc ((Finset.Ico 1 N).filter (fun n => g вИ£ n)).card
      вЙ§ ((Finset.Ico 1 ((N - 1) / g + 1)).image (fun k => g * k)).card :=
        Finset.card_le_card hsub
    _ вЙ§ (Finset.Ico 1 ((N - 1) / g + 1)).card := Finset.card_image_le
    _ = (N - 1) / g := by rw [Nat.card_Ico, Nat.add_sub_cancel]

/-- The **truncated singular series** `рЭФЦ_P(n) = вИС_{1вЙ§qвЙ§P} ќЉ(q)¬≤¬Јc_q(n)/ѕЖ(q)¬≤`, real-valued (via
    the integer `cRam`). The `q=1` term is `1`; `q=2` contributes `+1` for even `n`; the Euler
    product `вИП_{pвИ£n}(1+1/(p-1))¬ЈвИП_{pвИ§n}(1-1/(p-1)¬≤) вЙ• 2¬ЈвИП_{pвЙ•3}(1-1/(p-1)¬≤)` bounds it below by a
    positive constant for even `n` вАФ the lower bound `hmain` consumes (`рЭФЦ_P(n)¬Јr_N(n) вЙ• cвВА¬ЈX`). -/
noncomputable def singSeries (P n : вДХ) : вДЭ :=
  вИС q вИИ Finset.Icc 1 P, ((ArithmeticFunction.moebius q : вДЭ) ^ 2)
    * (cRam q n : вДЭ) / ((Nat.totient q : вДЭ) ^ 2)

/-- The singular-series **local term** `T(q) = ќЉ(q)¬≤¬Јc_q(n)/ѕЖ(q)¬≤` as an arithmetic function.
    Multiplicative (product of the multiplicative `ќЉ¬≤`, `cRam(¬Ј,n)`, `1/ѕЖ¬≤`), so its total sum
    factors as an Euler product `вИП_p (1+T(p))` вАФ the route to `рЭФЦ(n) вЙ• 1.32` for even `n`. -/
noncomputable def Tarith (n : вДХ) : ArithmeticFunction вДЭ :=
  вЯ®fun q => (ArithmeticFunction.moebius q : вДЭ) ^ 2 * (cRam q n : вДЭ) / (Nat.totient q : вДЭ) ^ 2,
    by simpвЯ©

lemma Tarith_apply (n q : вДХ) :
    Tarith n q = (ArithmeticFunction.moebius q : вДЭ) ^ 2 * (cRam q n : вДЭ)
      / (Nat.totient q : вДЭ) ^ 2 := rfl

lemma isMult_Tarith (n : вДХ) : (Tarith n).IsMultiplicative := by
  refine вЯ®?_, ?_вЯ©
  ¬Ј simp [Tarith_apply, cRam_one, ArithmeticFunction.isMultiplicative_moebius.1]
  ¬Ј intro a b hab
    simp only [Tarith_apply]
    rw [cRam_mul n a b hab, ArithmeticFunction.isMultiplicative_moebius.2 hab,
      Nat.totient_mul hab]
    push_cast
    ring

/-- **Euler local factor**: `вИС'_k T(p^k) = 1 + T(p)` for prime `p` вАФ the sum over prime powers
    collapses to `k=0,1` since `T(p^k)=0` for `kвЙ•2` (`p^k` not squarefree вЗТ `ќЉ(p^k)=0`). This is
    the per-prime factor Mathlib's `eulerProduct_tprod` produces for `рЭФЦ(n) = вИП_p (1+T(p))`. -/
lemma Tarith_local (p n : вДХ) (hp : p.Prime) :
    вИС' k : вДХ, Tarith n (p ^ k) = 1 + Tarith n p := by
  have hsupp : вИА k вИЙ ({0, 1} : Finset вДХ), Tarith n (p ^ k) = 0 := by
    intro k hk
    simp only [Finset.mem_insert, Finset.mem_singleton] at hk
    push_neg at hk
    have hk2 : 2 вЙ§ k := by omega
    rw [Tarith_apply]
    have hќЉ : ArithmeticFunction.moebius (p ^ k) = 0 := by
      apply ArithmeticFunction.moebius_eq_zero_of_not_squarefree
      rw [Nat.squarefree_pow_iff hp.ne_one (by omega)]
      rintro вЯ®_, hk1вЯ©
      omega
    rw [hќЉ]; simp
  rw [tsum_eq_sum hsupp, Finset.sum_pair (by norm_num), pow_zero, pow_one,
    (isMult_Tarith n).1]

/-- The singular-series local term at a prime: `T(p) = (pвИТ1)/(pвИТ1)¬≤ = 1/(pвИТ1)` if `pвИ£n`, else
    `вИТ1/(pвИТ1)¬≤`. -/
lemma Tarith_prime (p n : вДХ) (hp : p.Prime) :
    Tarith n p = (if p вИ£ n then ((p : вДЭ) - 1) else -1) / ((p : вДЭ) - 1) ^ 2 := by
  have hќЉ : ((ArithmeticFunction.moebius p : вДЭ)) ^ 2 = 1 := by
    rw [ArithmeticFunction.moebius_apply_prime hp]; norm_num
  have hѕЖ : ((Nat.totient p : вДЭ)) = (p : вДЭ) - 1 := by
    rw [Nat.totient_prime hp, Nat.cast_sub hp.one_lt.le]; norm_num
  have hc : ((cRam p n : вДЭ)) = if p вИ£ n then ((p : вДЭ) - 1) else -1 := by
    rw [cRam_prime p n hp, Int.cast_ite]; push_cast; norm_num
  rw [Tarith_apply, hќЉ, hѕЖ, hc, one_mul]

/-- **Euler factor positivity** (for even `n`): `0 < 1 + T(p)` for every prime `p`. At `p=2`
    (`2вИ£n`) the factor is `2`; at `pвЙ•3` it is `1+1/(p-1) > 0` (if `pвИ£n`) or `1-1/(p-1)¬≤ вЙ• 3/4`
    (if `pвИ§n`). This makes the Euler product `вИП_p (1+T(p))` a product of positive factors. -/
lemma one_add_Tarith_pos (p n : вДХ) (hp : p.Prime) (hn : Even n) : 0 < 1 + Tarith n p := by
  rw [Tarith_prime p n hp]
  have hp2 : (2 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp.two_le
  have hpos : (0 : вДЭ) < (p : вДЭ) - 1 := by linarith
  by_cases hd : p вИ£ n
  ¬Ј rw [if_pos hd]
    have : (0 : вДЭ) < ((p : вДЭ) - 1) / ((p : вДЭ) - 1) ^ 2 := by positivity
    linarith
  ¬Ј rw [if_neg hd]
    have hp3 : (3 : вДЭ) вЙ§ (p : вДЭ) := by
      rcases hp.eq_two_or_odd' with h2 | hodd
      ¬Ј exact absurd (h2 вЦЄ (even_iff_two_dvd.mp hn)) hd
      ¬Ј have : p вЙ† 2 := by rintro rfl; exact hd (even_iff_two_dvd.mp hn)
        have : 3 вЙ§ p := by
          rcases hp.two_le.lt_or_eq with h | h
          ¬Ј omega
          ¬Ј exact absurd h.symm this
        exact_mod_cast this
    have hp1 : (2 : вДЭ) вЙ§ (p : вДЭ) - 1 := by linarith
    have hsq : (4 : вДЭ) вЙ§ ((p : вДЭ) - 1) ^ 2 := by nlinarith
    have hb : (1 : вДЭ) / ((p : вДЭ) - 1) ^ 2 вЙ§ 1 / 4 :=
      one_div_le_one_div_of_le (by norm_num) hsq
    have hrw : (-1 : вДЭ) / ((p : вДЭ) - 1) ^ 2 = -(1 / ((p : вДЭ) - 1) ^ 2) := by ring
    rw [hrw]
    linarith [hb]

/-- `K¬Ј(log X)¬≥ вЙ§ вИЪX` eventually вАФ the poly-beats-вИЪ estimate for `hnegl`. Route: `u=log X`,
    `вИЪX=exp(u/2)=(exp(u/8))вБі вЙ• (1+u/8)вБі вЙ• (u/8)вБі = uвБі/4096 вЙ• K u¬≥` once `u вЙ• 4096K`. -/
lemma poly3_le_sqrt (K : вДЭ) (hK : 0 < K) :
    вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ K * Real.log X ^ 3 вЙ§ Real.sqrt X := by
  refine вЯ®Nat.ceil (Real.exp (4096 * K)) + 2, fun X hX => ?_вЯ©
  have hexp1 : (1 : вДЭ) вЙ§ Real.exp (4096 * K) := by
    rw [вЖР Real.exp_zero]; exact Real.exp_le_exp.mpr (by positivity)
  have hXexp : Real.exp (4096 * K) вЙ§ (X : вДЭ) := by
    have h1 : (вМИReal.exp (4096 * K)вМЙвВК : вДЭ) вЙ§ (X : вДЭ) := by
      have : вМИReal.exp (4096 * K)вМЙвВК вЙ§ X := by omega
      exact_mod_cast this
    linarith [Nat.le_ceil (Real.exp (4096 * K))]
  have hXpos : (0 : вДЭ) < X := lt_of_lt_of_le (by linarith) hXexp
  have hu : 4096 * K вЙ§ Real.log X := by
    rw [вЖР Real.log_exp (4096 * K)]; exact Real.log_le_log (Real.exp_pos _) hXexp
  set u := Real.log X with hudef
  have hu0 : 0 < u := lt_of_lt_of_le (by positivity) hu
  have hsqrt : Real.sqrt X = Real.exp (u / 2) := by
    rw [Real.sqrt_eq_rpow, Real.rpow_def_of_pos hXpos, hudef]; ring_nf
  rw [hsqrt]
  have hle : 1 + u / 8 вЙ§ Real.exp (u / 8) := by
    have := Real.add_one_le_exp (u / 8); linarith
  have hpow : (1 + u / 8) ^ 4 вЙ§ Real.exp (u / 2) := by
    have h4 : (1 + u / 8) ^ 4 вЙ§ (Real.exp (u / 8)) ^ 4 :=
      pow_le_pow_leftвВА (by positivity) hle 4
    rwa [вЖР Real.exp_nat_mul, show ((4 : вДХ) : вДЭ) * (u / 8) = u / 2 by push_cast; ring] at h4
  have hb1 : (u / 8) ^ 4 вЙ§ (1 + u / 8) ^ 4 :=
    pow_le_pow_leftвВА (by positivity) (by linarith) 4
  have hb2 : K * u ^ 3 вЙ§ (u / 8) ^ 4 := by
    have hid : (u / 8) ^ 4 = u ^ 4 / 4096 := by ring
    have hkey : 4096 * K * u ^ 3 вЙ§ u * u ^ 3 :=
      mul_le_mul_of_nonneg_right hu (pow_nonneg hu0.le 3)
    rw [hid]
    nlinarith [hkey, hu0]
  linarith [hpow, hb1, hb2]

/-- **`hnegl` discharged** (for any `cвВА > 0`): the prime-power negligibility hypothesis of the
    weighted reduction вАФ `2 log¬≤n¬ЈвИЪn¬Ј(logвВВn+1) вЙ§ cвВА¬ЈX/2` for `n вИИ (X/2,X]`, `X` large. Bounds
    every factor by its `X`-value, reducing to `K(log X)¬≥ вЙ§ вИЪX` (`poly3_le_sqrt`). -/
lemma negl_bound (cвВА : вДЭ) (hcвВА : 0 < cвВА) :
    вИГ XвВБ : вДХ, вИА X : вДХ, XвВБ вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ
      2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) вЙ§ cвВА * X / 2 := by
  have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
  set CL : вДЭ := 1 / Real.log 2 + 1 with hCL
  have hCLpos : 0 < CL := by rw [hCL]; positivity
  obtain вЯ®XвВА, hXвВАвЯ© := poly3_le_sqrt (4 * CL / cвВА) (by positivity)
  refine вЯ®max XвВА 3, fun X hX n hn1 hn2 => ?_вЯ©
  have hX3 : 3 вЙ§ X := le_trans (le_max_right _ _) hX
  have hX0X : XвВА вЙ§ X := le_trans (le_max_left _ _) hX
  have hn1' : 1 вЙ§ n := by omega
  have hXR : (3 : вДЭ) вЙ§ (X : вДЭ) := by exact_mod_cast hX3
  have hnR1 : (1 : вДЭ) вЙ§ (n : вДЭ) := by exact_mod_cast hn1'
  have hnXR : (n : вДЭ) вЙ§ (X : вДЭ) := by exact_mod_cast hn2
  have hXpos : (0 : вДЭ) < X := by linarith
  have hlogn0 : 0 вЙ§ Real.log n := Real.log_nonneg hnR1
  have hlognX : Real.log n вЙ§ Real.log X := Real.log_le_log (by linarith) hnXR
  have hlogX0 : 0 вЙ§ Real.log X := Real.log_nonneg (by linarith)
  have hlogX1 : 1 вЙ§ Real.log X := by
    have he3 : Real.exp 1 вЙ§ (X : вДЭ) := le_trans (le_of_lt Real.exp_one_lt_d9) (by linarith)
    calc (1 : вДЭ) = Real.log (Real.exp 1) := (Real.log_exp 1).symm
      _ вЙ§ Real.log X := Real.log_le_log (Real.exp_pos 1) he3
  have hsqrtn : (Nat.sqrt n : вДЭ) вЙ§ Real.sqrt X := by
    have h2 : (Nat.sqrt n : вДЭ) ^ 2 вЙ§ (X : вДЭ) := by
      have hh : (Nat.sqrt n : вДЭ) ^ 2 вЙ§ (n : вДЭ) := by exact_mod_cast Nat.sqrt_le' n
      linarith [hnXR]
    calc (Nat.sqrt n : вДЭ) = Real.sqrt ((Nat.sqrt n : вДЭ) ^ 2) := by
          rw [Real.sqrt_sq (by positivity)]
      _ вЙ§ Real.sqrt X := Real.sqrt_le_sqrt h2
  have hlog2n : (Nat.log 2 n : вДЭ) вЙ§ Real.log X / Real.log 2 := by
    have h1 : 2 ^ (Nat.log 2 n) вЙ§ n := Nat.pow_log_le_self 2 (by omega)
    have h2 : ((2 : вДЭ) ^ (Nat.log 2 n)) вЙ§ (n : вДЭ) := by exact_mod_cast h1
    have h3 : Real.log (2 ^ (Nat.log 2 n)) вЙ§ Real.log n :=
      Real.log_le_log (by positivity) h2
    rw [Real.log_pow] at h3
    rw [le_div_iffвВА hlog2]
    calc (Nat.log 2 n : вДЭ) * Real.log 2 вЙ§ Real.log n := h3
      _ вЙ§ Real.log X := hlognX
  have hC : (Nat.log 2 n : вДЭ) + 1 вЙ§ CL * Real.log X := by
    have hdiv : Real.log X / Real.log 2 = (1 / Real.log 2) * Real.log X := by ring
    rw [hCL]
    nlinarith [hlog2n, hlogX1, hlog2, hdiv]
  have hsqrtX0 : 0 вЙ§ Real.sqrt X := Real.sqrt_nonneg _
  have hlog2n0 : (0 : вДЭ) вЙ§ (Nat.log 2 n : вДЭ) + 1 := by positivity
  have hmid : 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1))
      вЙ§ 2 * CL * Real.log X ^ 3 * Real.sqrt X := by
    have hA : Real.log n ^ 2 вЙ§ Real.log X ^ 2 := pow_le_pow_leftвВА hlogn0 hlognX 2
    have hD : (Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1) вЙ§ Real.sqrt X * (CL * Real.log X) :=
      mul_le_mul hsqrtn hC hlog2n0 hsqrtX0
    have hrhs : 2 * CL * Real.log X ^ 3 * Real.sqrt X
        = 2 * Real.log X ^ 2 * (Real.sqrt X * (CL * Real.log X)) := by ring
    rw [hrhs]
    have h2A : 2 * Real.log n ^ 2 вЙ§ 2 * Real.log X ^ 2 := by linarith
    apply mul_le_mul h2A hD (by positivity) (by positivity)
  have hsqX : Real.sqrt X * Real.sqrt X = (X : вДЭ) := Real.mul_self_sqrt (by linarith)
  have hfin : 2 * CL * Real.log X ^ 3 * Real.sqrt X вЙ§ cвВА * X / 2 := by
    have hstep : 4 * CL / cвВА * Real.log X ^ 3 вЙ§ Real.sqrt X := hXвВА X hX0X
    have h4 : 4 * CL * Real.log X ^ 3 вЙ§ cвВА * Real.sqrt X := by
      rw [div_mul_eq_mul_div, div_le_iffвВА hcвВА] at hstep
      nlinarith [hstep]
    nlinarith [h4, hsqX, hsqrtX0, mul_le_mul_of_nonneg_right h4 hsqrtX0]
  linarith [hmid, hfin]

/-- Per-prime totient bound `(p-1)¬≤ вЙ• p^(6/5)` for `p вЙ• 3` (from the integer `(p-1)^10 вЙ• p^6`
    via `(k+3)¬≥ вЙ§ (k+2)вБµ` squared, bridged with `rpow`). The multiplicative seed for
    `ѕЖ(q)¬≤ вЙ• c¬Јq^(6/5)` (squarefree `q`) вЗТ `вИС 1/ѕЖ(q)¬≤` converges вЗТ `Tarith_summable`. -/
lemma prime_factor_rpow (p : вДХ) (hp : 3 вЙ§ p) :
    (p : вДЭ) ^ ((6 : вДЭ) / 5) вЙ§ ((p : вДЭ) - 1) ^ 2 := by
  have hpR : (3 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp
  have hint : (p : вДЭ) ^ 6 вЙ§ ((p : вДЭ) - 1) ^ 10 := by
    obtain вЯ®k, rflвЯ© : вИГ k, p = k + 3 := вЯ®p - 3, by omegaвЯ©
    push_cast
    have hpm : ((k : вДЭ) + 3 - 1) = (k : вДЭ) + 2 := by ring
    have h5 : ((k : вДЭ) + 3) ^ 3 вЙ§ ((k : вДЭ) + 2) ^ 5 := by
      nlinarith [pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 5,
        pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 4,
        pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 3, sq_nonneg (k:вДЭ)]
    calc ((k : вДЭ) + 3) ^ 6 = (((k : вДЭ) + 3) ^ 3) ^ 2 := by ring
      _ вЙ§ (((k : вДЭ) + 2) ^ 5) ^ 2 := by apply pow_le_pow_leftвВА (by positivity) h5
      _ = ((k : вДЭ) + 2) ^ 10 := by ring
      _ = ((k : вДЭ) + 3 - 1) ^ 10 := by rw [hpm]
  have h15 := Real.rpow_le_rpow (by positivity : (0 : вДЭ) вЙ§ (p : вДЭ) ^ 6) hint
    (by norm_num : (0 : вДЭ) вЙ§ (1 : вДЭ) / 5)
  rw [вЖР Real.rpow_natCast (p : вДЭ) 6, вЖР Real.rpow_natCast ((p : вДЭ) - 1) 10,
    вЖР Real.rpow_mul (by positivity : (0 : вДЭ) вЙ§ (p : вДЭ)),
    вЖР Real.rpow_mul (by linarith : (0 : вДЭ) вЙ§ (p : вДЭ) - 1)] at h15
  norm_num at h15
  exact h15

/-- `q^(6/5) вЙ§ ѕЖ(q)¬≤` for **odd squarefree** `q` (all prime factors вЙ• 3, so `prime_factor_rpow`
    applies with multiplicative constant 1). Strong induction peeling the minimal prime factor. -/
lemma odd_sqfree_totient (q : вДХ) (hq : Squarefree q) (hodd : Odd q) :
    (q : вДЭ) ^ ((6 : вДЭ) / 5) вЙ§ (Nat.totient q : вДЭ) ^ 2 := by
  induction q using Nat.strong_induction_on with
  | _ q IH =>
    rcases eq_or_ne q 1 with rfl | hq1
    ¬Ј norm_num
    ¬Ј have hq0 : q вЙ† 0 := hq.ne_zero
      have hq2 : 2 вЙ§ q := by omega
      have hpp : (q.minFac).Prime := Nat.minFac_prime hq1
      have hpdvd : q.minFac вИ£ q := Nat.minFac_dvd q
      set p := q.minFac with hp
      set m := q / p with hm
      have hpm : p * m = q := Nat.mul_div_cancel' hpdvd
      have hmpos : 0 < m := by
        rcases Nat.eq_zero_or_pos m with h | h
        ¬Ј rw [h, mul_zero] at hpm; omega
        ¬Ј exact h
      have hp3 : 3 вЙ§ p := by
        have hp2 : p вЙ† 2 := by
          intro h2
          have h2q : (2 : вДХ) вИ£ q := h2 вЦЄ hpdvd
          exact (Nat.not_even_iff_odd.mpr hodd) (even_iff_two_dvd.mpr h2q)
        have := hpp.two_le; omega
      have hmdvd : m вИ£ q := вЯ®p, by rw [вЖР hpm]; ringвЯ©
      have hcop : Nat.Coprime p m := by
        rw [hpp.coprime_iff_not_dvd]
        intro hdvd
        have hpp2 : p * p вИ£ q := by rw [вЖР hpm]; exact mul_dvd_mul_left p hdvd
        exact hpp.ne_one (Nat.isUnit_iff.mp (hq p hpp2))
      have hmsq : Squarefree m := Squarefree.squarefree_of_dvd hmdvd hq
      have hmodd : Odd m := by
        rcases Nat.even_or_odd m with he | ho
        ¬Ј exfalso
          have hqe : Even q := by rw [вЖР hpm]; exact he.mul_left p
          exact (Nat.not_even_iff_odd.mpr hodd) hqe
        ¬Ј exact ho
      have hmlt : m < q := by
        rw [вЖР hpm]; exact (Nat.lt_mul_iff_one_lt_left hmpos).mpr hpp.one_lt
      have hIH := IH m hmlt hmsq hmodd
      rw [вЖР hpm, Nat.totient_mul hcop, Nat.totient_prime hpp]
      have hp1 : 1 вЙ§ p := hpp.one_le
      push_cast [Nat.cast_sub hp1]
      rw [Real.mul_rpow (by positivity) (by positivity)]
      calc (p : вДЭ) ^ ((6 : вДЭ) / 5) * (m : вДЭ) ^ ((6 : вДЭ) / 5)
          вЙ§ ((p : вДЭ) - 1) ^ 2 * (Nat.totient m : вДЭ) ^ 2 :=
            mul_le_mul (prime_factor_rpow p hp3) hIH (by positivity) (by positivity)
        _ = (((p : вДЭ) - 1) * (Nat.totient m : вДЭ)) ^ 2 := by ring

/-- `q^(6/5) вЙ§ 4¬ЈѕЖ(q)¬≤` for **all squarefree** `q` (even case `q=2m`, `m` odd squarefree,
    `ѕЖ(2m)=ѕЖ(m)`, absorbing `2^(6/5) < 4`). The totient lower bound driving `Tarith_summable`. -/
lemma sqfree_totient (q : вДХ) (hq : Squarefree q) :
    (q : вДЭ) ^ ((6 : вДЭ) / 5) вЙ§ 4 * (Nat.totient q : вДЭ) ^ 2 := by
  rcases Nat.even_or_odd q with he | ho
  ¬Ј obtain вЯ®m, hmвЯ© := he
    have hm2 : q = 2 * m := by omega
    have hmpos : 0 < m := by
      rcases Nat.eq_zero_or_pos m with h | h
      ¬Ј rw [h, mul_zero] at hm2; exact absurd hm2 hq.ne_zero
      ¬Ј exact h
    have hmodd : Odd m := by
      rcases Nat.even_or_odd m with hme | hmo
      ¬Ј exfalso
        obtain вЯ®k, hkвЯ© := hme
        have : (2 * 2) вИ£ q := вЯ®k, by omegaвЯ©
        exact (by decide : ¬ђ IsUnit 2) (hq 2 this)
      ¬Ј exact hmo
    have hmsq : Squarefree m := hq.squarefree_of_dvd вЯ®2, by rw [hm2]; ringвЯ©
    have hcop : Nat.Coprime 2 m := by
      rw [Nat.Prime.coprime_iff_not_dvd Nat.prime_two]
      intro h
      exact (Nat.not_even_iff_odd.mpr hmodd) (even_iff_two_dvd.mpr h)
    have hIH := odd_sqfree_totient m hmsq hmodd
    rw [hm2, Nat.totient_mul hcop, Nat.totient_prime Nat.prime_two]
    push_cast
    rw [Real.mul_rpow (by positivity) (by positivity)]
    have h2r : (2 : вДЭ) ^ ((6 : вДЭ) / 5) вЙ§ 4 := by
      calc (2 : вДЭ) ^ ((6 : вДЭ) / 5) вЙ§ (2 : вДЭ) ^ (2 : вДЭ) :=
            Real.rpow_le_rpow_of_exponent_le (by norm_num) (by norm_num)
        _ = 4 := by norm_num
    have hstep : (2 : вДЭ) ^ ((6 : вДЭ) / 5) * (m : вДЭ) ^ ((6 : вДЭ) / 5)
        вЙ§ 4 * (Nat.totient m : вДЭ) ^ 2 :=
      mul_le_mul h2r hIH (by positivity) (by norm_num)
    nlinarith [hstep]
  ¬Ј have h := odd_sqfree_totient q hq ho
    nlinarith [h, sq_nonneg (Nat.totient q : вДЭ)]

/-- **Sharper per-prime totient seed**: `(p-1)¬≤ вЙ• p^(3/2)` for `p вЙ• 5` (constant 1). Squares to the
    integer `(p-1)^4 вЙ• p^3` (holds for `pвЙ•4`), bridged with `rpow`. Multiplicative seed for
    `ѕЖ(q)¬≤ вЙ• c¬Јq^(3/2)` (squarefree q, exponent 3/2 > 4/3) вЗТ `вИС 1/ѕЖ(q)^(3/2)` converges вАФ the
    Minkowski-route summability the harc truncation needs (crude `p^(6/5)` gives only exponent 6/5
    < 4/3, too weak). Small primes 2,3 are absorbed into `c` separately in `sqfree_totient_strong`. -/
lemma prime_factor_rpow_strong (p : вДХ) (hp : 5 вЙ§ p) :
    (p : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ ((p : вДЭ) - 1) ^ 2 := by
  have hpR : (5 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp
  have hint : (p : вДЭ) ^ 3 вЙ§ ((p : вДЭ) - 1) ^ 4 := by
    obtain вЯ®k, rflвЯ© : вИГ k, p = k + 5 := вЯ®p - 5, by omegaвЯ©
    push_cast
    nlinarith [pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 4,
      pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 3,
      pow_nonneg (show (0:вДЭ) вЙ§ (k:вДЭ) by positivity) 2, sq_nonneg (k:вДЭ)]
  have h12 := Real.rpow_le_rpow (by positivity : (0 : вДЭ) вЙ§ (p : вДЭ) ^ 3) hint
    (by norm_num : (0 : вДЭ) вЙ§ (1 : вДЭ) / 2)
  rw [вЖР Real.rpow_natCast (p : вДЭ) 3, вЖР Real.rpow_natCast ((p : вДЭ) - 1) 4,
    вЖР Real.rpow_mul (by positivity : (0 : вДЭ) вЙ§ (p : вДЭ)),
    вЖР Real.rpow_mul (by linarith : (0 : вДЭ) вЙ§ (p : вДЭ) - 1)] at h12
  norm_num at h12
  exact h12

/-- `q^(3/2) вЙ§ ѕЖ(q)¬≤` for squarefree `q` with **all prime factors вЙ• 5** (constant 1). Strong
    induction peeling the minimal prime factor; `prime_factor_rpow_strong` supplies the per-prime step. -/
lemma ge5_totient (q : вДХ) (hq : Squarefree q) (h5 : вИА p, p.Prime вЖТ p вИ£ q вЖТ 5 вЙ§ p) :
    (q : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ (Nat.totient q : вДЭ) ^ 2 := by
  induction q using Nat.strong_induction_on with
  | _ q IH =>
    rcases eq_or_ne q 1 with rfl | hq1
    ¬Ј norm_num
    ¬Ј have hq0 : q вЙ† 0 := hq.ne_zero
      have hpp : (q.minFac).Prime := Nat.minFac_prime hq1
      have hpdvd : q.minFac вИ£ q := Nat.minFac_dvd q
      set p := q.minFac with hp
      set m := q / p with hm
      have hpm : p * m = q := Nat.mul_div_cancel' hpdvd
      have hmpos : 0 < m := by
        rcases Nat.eq_zero_or_pos m with h | h
        ¬Ј rw [h, mul_zero] at hpm; omega
        ¬Ј exact h
      have hp5 : 5 вЙ§ p := h5 p hpp hpdvd
      have hmdvd : m вИ£ q := вЯ®p, by rw [вЖР hpm]; ringвЯ©
      have hcop : Nat.Coprime p m := by
        rw [hpp.coprime_iff_not_dvd]
        intro hdvd
        have hpp2 : p * p вИ£ q := by rw [вЖР hpm]; exact mul_dvd_mul_left p hdvd
        exact hpp.ne_one (Nat.isUnit_iff.mp (hq p hpp2))
      have hmsq : Squarefree m := hq.squarefree_of_dvd hmdvd
      have hm5 : вИА r, r.Prime вЖТ r вИ£ m вЖТ 5 вЙ§ r := fun r hr hrm => h5 r hr (hrm.trans hmdvd)
      have hmlt : m < q := by rw [вЖР hpm]; exact (Nat.lt_mul_iff_one_lt_left hmpos).mpr hpp.one_lt
      have hIH := IH m hmlt hmsq hm5
      rw [вЖР hpm, Nat.totient_mul hcop, Nat.totient_prime hpp]
      have hp1 : 1 вЙ§ p := hpp.one_le
      push_cast [Nat.cast_sub hp1]
      rw [Real.mul_rpow (by positivity) (by positivity)]
      calc (p : вДЭ) ^ ((3 : вДЭ) / 2) * (m : вДЭ) ^ ((3 : вДЭ) / 2)
          вЙ§ ((p : вДЭ) - 1) ^ 2 * (Nat.totient m : вДЭ) ^ 2 :=
            mul_le_mul (prime_factor_rpow_strong p hp5) hIH (by positivity) (by positivity)
        _ = (((p : вДЭ) - 1) * (Nat.totient m : вДЭ)) ^ 2 := by ring

/-- `q^(3/2) вЙ§ 2¬ЈѕЖ(q)¬≤` for **odd squarefree** `q` (constant 2). Peels the possible factor 3
    (which needs its own constant); the rest has all factors вЙ•5 and feeds `ge5_totient`. -/
lemma odd_totient_strong (q : вДХ) (hq : Squarefree q) (hodd : Odd q) :
    (q : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ 2 * (Nat.totient q : вДЭ) ^ 2 := by
  have hq0 : q вЙ† 0 := hq.ne_zero
  by_cases h3 : 3 вИ£ q
  ¬Ј have h3p : Nat.Prime 3 := by norm_num
    set m := q / 3 with hm
    have hpm : 3 * m = q := Nat.mul_div_cancel' h3
    have hmpos : 0 < m := by
      rcases Nat.eq_zero_or_pos m with h | h
      ¬Ј rw [h, mul_zero] at hpm; omega
      ¬Ј exact h
    have hmdvd : m вИ£ q := вЯ®3, by rw [вЖР hpm]; ringвЯ©
    have hmsq : Squarefree m := hq.squarefree_of_dvd hmdvd
    have hcop : Nat.Coprime 3 m := by
      rw [h3p.coprime_iff_not_dvd]; intro hdvd
      have : (3 * 3) вИ£ q := by rw [вЖР hpm]; exact mul_dvd_mul_left 3 hdvd
      exact h3p.ne_one (Nat.isUnit_iff.mp (hq 3 this))
    have hm5 : вИА r, r.Prime вЖТ r вИ£ m вЖТ 5 вЙ§ r := by
      intro r hr hrm
      have hrq : r вИ£ q := hrm.trans hmdvd
      have hr2 : r вЙ† 2 := by
        intro h; rw [h] at hrq
        exact (Nat.not_even_iff_odd.mpr hodd) (even_iff_two_dvd.mpr hrq)
      have hr3 : r вЙ† 3 := by
        intro h; rw [h] at hrm
        have h31 : (3 : вДХ) вИ£ 1 := by
          have := Nat.dvd_gcd (dvd_refl 3) hrm; rwa [hcop] at this
        exact absurd (Nat.le_of_dvd one_pos h31) (by norm_num)
      have hr2le := hr.two_le
      rcases Nat.lt_or_ge r 5 with hlt | hge
      ¬Ј interval_cases r
        ¬Ј exact absurd rfl hr2
        ¬Ј exact absurd rfl hr3
        ¬Ј exact absurd hr (by norm_num)
      ¬Ј exact hge
    have hIH := ge5_totient m hmsq hm5
    have ht3 : Nat.totient 3 = 2 := by decide
    rw [вЖР hpm, Nat.totient_mul hcop, ht3]
    push_cast
    rw [Real.mul_rpow (by positivity) (by positivity)]
    have h32 : (3 : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ 8 := by
      have h1 : ((3 : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2 = 27 := by
        rw [вЖР Real.rpow_natCast ((3 : вДЭ) ^ ((3 : вДЭ) / 2)) 2, вЖР Real.rpow_mul (by norm_num)]; norm_num
      nlinarith [Real.rpow_nonneg (show (0 : вДЭ) вЙ§ 3 by norm_num) ((3 : вДЭ) / 2), h1]
    calc (3 : вДЭ) ^ ((3 : вДЭ) / 2) * (m : вДЭ) ^ ((3 : вДЭ) / 2)
        вЙ§ (3 : вДЭ) ^ ((3 : вДЭ) / 2) * (Nat.totient m : вДЭ) ^ 2 :=
          mul_le_mul_of_nonneg_left hIH (by positivity)
      _ вЙ§ 8 * (Nat.totient m : вДЭ) ^ 2 := mul_le_mul_of_nonneg_right h32 (by positivity)
      _ = 2 * (2 * (Nat.totient m : вДЭ)) ^ 2 := by ring
  ¬Ј have h5 : вИА p, p.Prime вЖТ p вИ£ q вЖТ 5 вЙ§ p := by
      intro p hp hpq
      have hp2 : p вЙ† 2 := by
        intro h; rw [h] at hpq
        exact (Nat.not_even_iff_odd.mpr hodd) (even_iff_two_dvd.mpr hpq)
      have hp3 : p вЙ† 3 := fun h => h3 (h вЦЄ hpq)
      have hp2le := hp.two_le
      rcases Nat.lt_or_ge p 5 with hlt | hge
      ¬Ј interval_cases p
        ¬Ј exact absurd rfl hp2
        ¬Ј exact absurd rfl hp3
        ¬Ј exact absurd hp (by norm_num)
      ¬Ј exact hge
    have hg := ge5_totient q hq h5
    nlinarith [hg, sq_nonneg (Nat.totient q : вДЭ)]

/-- **Sharper totient bound**: `q^(3/2) вЙ§ 8¬ЈѕЖ(q)¬≤` for all squarefree `q` (exponent 3/2 > 4/3).
    Peels the possible factor 2 (`2^(5/2) вЙИ 5.66 вЙ§ 8`); the odd part feeds `odd_totient_strong`.
    Gives `ѕЖ(q) вЙ• q^(3/4)/вИЪ8`, so `вИС 1/ѕЖ(q)^(3/2)` converges вАФ the Minkowski-route summability harc needs. -/
lemma sqfree_totient_strong (q : вДХ) (hq : Squarefree q) :
    (q : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ 8 * (Nat.totient q : вДЭ) ^ 2 := by
  rcases Nat.even_or_odd q with he | ho
  ¬Ј obtain вЯ®m, hmвЯ© := he
    have hm2 : q = 2 * m := by omega
    have hmpos : 0 < m := by
      rcases Nat.eq_zero_or_pos m with h | h
      ¬Ј rw [h, mul_zero] at hm2; exact absurd hm2 hq.ne_zero
      ¬Ј exact h
    have hmodd : Odd m := by
      rcases Nat.even_or_odd m with hme | hmo
      ¬Ј exfalso; obtain вЯ®k, hkвЯ© := hme
        have : (2 * 2) вИ£ q := вЯ®k, by omegaвЯ©
        exact (by decide : ¬ђ IsUnit 2) (hq 2 this)
      ¬Ј exact hmo
    have hmsq : Squarefree m := hq.squarefree_of_dvd вЯ®2, by rw [hm2]; ringвЯ©
    have hcop : Nat.Coprime 2 m := by
      rw [Nat.Prime.coprime_iff_not_dvd Nat.prime_two]; intro h
      exact (Nat.not_even_iff_odd.mpr hmodd) (even_iff_two_dvd.mpr h)
    have hIH := odd_totient_strong m hmsq hmodd
    rw [hm2, Nat.totient_mul hcop, Nat.totient_two, one_mul]
    push_cast
    rw [Real.mul_rpow (by positivity) (by positivity)]
    have h2 : (2 : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ 4 := by
      have h1 : ((2 : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2 = 8 := by
        rw [вЖР Real.rpow_natCast ((2 : вДЭ) ^ ((3 : вДЭ) / 2)) 2, вЖР Real.rpow_mul (by norm_num)]; norm_num
      nlinarith [Real.rpow_nonneg (show (0 : вДЭ) вЙ§ 2 by norm_num) ((3 : вДЭ) / 2), h1]
    calc (2 : вДЭ) ^ ((3 : вДЭ) / 2) * (m : вДЭ) ^ ((3 : вДЭ) / 2)
        вЙ§ (2 : вДЭ) ^ ((3 : вДЭ) / 2) * (2 * (Nat.totient m : вДЭ) ^ 2) :=
          mul_le_mul_of_nonneg_left hIH (by positivity)
      _ вЙ§ 8 * (Nat.totient m : вДЭ) ^ 2 := by nlinarith [h2, sq_nonneg (Nat.totient m : вДЭ)]
  ¬Ј have := odd_totient_strong q hq ho
    nlinarith [this, sq_nonneg (Nat.totient q : вДЭ)]

/-- `|c_q(n)| вЙ§ ѕГ(n) = вИС_{dвИ£n} d` (uniform in `q`), for `n вЙ• 1`. Triangle inequality on the divisor
    sum + `|ќЉ|вЙ§1`, reindex `dвЖ¶q/d`, then `{eвИ£q : eвИ£n} вКЖ divisors n`. -/
lemma cRam_abs_le (q n : вДХ) (hn : 1 вЙ§ n) :
    |cRam q n| вЙ§ вИС d вИИ n.divisors, (d : вД§) := by
  rw [cRam]
  calc |вИС d вИИ q.divisors, ArithmeticFunction.moebius d
          * (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0)|
      вЙ§ вИС d вИИ q.divisors, |ArithmeticFunction.moebius d
          * (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0)| := Finset.abs_sum_le_sum_abs _ _
    _ вЙ§ вИС d вИИ q.divisors, (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0) := by
        apply Finset.sum_le_sum
        intro d _
        rw [abs_mul]
        have hќЉ : |(ArithmeticFunction.moebius d : вД§)| вЙ§ 1 := ArithmeticFunction.abs_moebius_le_one
        have hnn : (0 : вД§) вЙ§ (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0) := by
          split <;> positivity
        calc |(ArithmeticFunction.moebius d : вД§)| * |if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0|
            вЙ§ 1 * |if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0| :=
              mul_le_mul_of_nonneg_right hќЉ (abs_nonneg _)
          _ = (if q / d вИ£ n then ((q / d : вДХ) : вД§) else 0) := by rw [one_mul, abs_of_nonneg hnn]
    _ = вИС d вИИ q.divisors, (if d вИ£ n then ((d : вДХ) : вД§) else 0) :=
        Nat.sum_div_divisors q (fun e => if e вИ£ n then ((e : вДХ) : вД§) else 0)
    _ = вИС d вИИ q.divisors.filter (fun d => d вИ£ n), (d : вД§) := (Finset.sum_filter _ _).symm
    _ вЙ§ вИС d вИИ n.divisors, (d : вД§) := by
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro d hd
          rw [Finset.mem_filter] at hd
          rw [Nat.mem_divisors]
          exact вЯ®hd.2, by omegaвЯ©
        ¬Ј intro d _ _; positivity

/-- **Singular-series convergence** вАФ `вИС_q |T(q)| < вИЮ`, for `n вЙ• 1` (FALSE at n=0).
    Comparison `вАЦT(q)вАЦ вЙ§ 4ѕГ(n)/q^(6/5)` (squarefree: `cRam_abs_le` + `sqfree_totient`;
    else `ќЉ¬≤=0`) against the summable `вИС 1/q^(6/5)` (`summable_one_div_nat_rpow`). -/
lemma Tarith_summable (n : вДХ) (hn : 1 вЙ§ n) : Summable (fun q => вАЦTarith n qвАЦ) := by
  have hѕГ : (0 : вДЭ) вЙ§ (вИС d вИИ n.divisors, (d : вДЭ)) := by positivity
  apply Summable.of_nonneg_of_le (fun q => norm_nonneg _)
    (f := fun q : вДХ => 4 * (вИС d вИИ n.divisors, (d : вДЭ)) * (1 / (q : вДЭ) ^ ((6 : вДЭ) / 5)))
  ¬Ј intro q
    rw [Tarith_apply, norm_div, norm_mul]
    have hќЉsq : вАЦ(ArithmeticFunction.moebius q : вДЭ) ^ 2вАЦ = (ArithmeticFunction.moebius q : вДЭ) ^ 2 := by
      rw [Real.norm_eq_abs, abs_of_nonneg (by positivity)]
    have hѕЖsq : вАЦ(Nat.totient q : вДЭ) ^ 2вАЦ = (Nat.totient q : вДЭ) ^ 2 := by
      rw [Real.norm_eq_abs, abs_of_nonneg (by positivity)]
    rw [hќЉsq, hѕЖsq]
    have hcR : вАЦ(cRam q n : вДЭ)вАЦ вЙ§ (вИС d вИИ n.divisors, (d : вДЭ)) := by
      have heq : вАЦ(cRam q n : вДЭ)вАЦ = ((|cRam q n| : вД§) : вДЭ) := by
        rw [Real.norm_eq_abs, Int.cast_abs]
      rw [heq]
      calc ((|cRam q n| : вД§) : вДЭ) вЙ§ ((вИС d вИИ n.divisors, (d : вД§) : вД§) : вДЭ) := by
            exact_mod_cast cRam_abs_le q n hn
        _ = вИС d вИИ n.divisors, (d : вДЭ) := by push_cast; rfl
    have hcRnn : (0 : вДЭ) вЙ§ вАЦ(cRam q n : вДЭ)вАЦ := norm_nonneg _
    by_cases hsf : Squarefree q
    ¬Ј have hќЉ2 : (ArithmeticFunction.moebius q : вДЭ) ^ 2 вЙ§ 1 := by
        have h' : |(ArithmeticFunction.moebius q : вДЭ)| вЙ§ 1 := by
          exact_mod_cast ArithmeticFunction.abs_moebius_le_one (n := q)
        nlinarith [sq_abs (ArithmeticFunction.moebius q : вДЭ),
          abs_nonneg (ArithmeticFunction.moebius q : вДЭ), h']
      have hѕЖpos : (0 : вДЭ) < (Nat.totient q : вДЭ) ^ 2 := by
        have : 0 < Nat.totient q := Nat.totient_pos.mpr hsf.ne_zero.bot_lt
        positivity
      have hqpos : (0 : вДЭ) < (q : вДЭ) ^ ((6 : вДЭ) / 5) := by
        have hq0 : 0 < q := hsf.ne_zero.bot_lt
        have : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast hq0
        positivity
      rw [mul_one_div, div_le_div_iffвВА hѕЖpos hqpos]
      nlinarith [hќЉ2, hcR, hcRnn, hѕГ, sqfree_totient q hsf,
        mul_le_mul hcR (sqfree_totient q hsf) hqpos.le hѕГ,
        mul_nonneg hcRnn hqpos.le]
    ¬Ј rw [ArithmeticFunction.moebius_eq_zero_of_not_squarefree hsf]
      simp
      positivity
  ¬Ј apply Summable.mul_left
    exact (Real.summable_one_div_nat_rpow).mpr (by norm_num)

/-- **Euler product for the singular series** (from `Tarith_summable`): `рЭФЦ(n) = вИС'_q T(q) =
    вИП'_p (1 + T(p))`. Combined with `one_add_Tarith_pos` (each factor `> 0` for even `n`) this is
    the route to `рЭФЦ(n) вЙ• cвВА > 0`. -/
lemma singSeries_eq_prod (n : вДХ) (hn : 1 вЙ§ n) :
    (вИС' q, Tarith n q) = вИП' p : Nat.Primes, (1 + Tarith n (p : вДХ)) := by
  rw [вЖР (isMult_Tarith n).eulerProduct_tprod (Tarith_summable n hn)]
  refine tprod_congr (fun p => ?_)
  exact Tarith_local (p : вДХ) n p.2

/-- `вИП_{iвИИs}(1-a_i) вЙ• 1 - вИС_{iвИИs} a_i` for `a_i вИИ [0,1]` (Weierstrass product inequality). -/
lemma prod_one_sub_ge {ќє : Type*} (s : Finset ќє) (a : ќє вЖТ вДЭ)
    (ha : вИА i вИИ s, 0 вЙ§ a i) (ha1 : вИА i вИИ s, a i вЙ§ 1) :
    1 - вИС i вИИ s, a i вЙ§ вИП i вИИ s, (1 - a i) := by
  classical
  induction s using Finset.induction with
  | empty => simp
  | @insert j t hj IH =>
    rw [Finset.sum_insert hj, Finset.prod_insert hj]
    have haj0 : 0 вЙ§ a j := ha j (Finset.mem_insert_self j t)
    have hIH : 1 - вИС i вИИ t, a i вЙ§ вИП i вИИ t, (1 - a i) :=
      IH (fun i hi => ha i (Finset.mem_insert_of_mem hi))
        (fun i hi => ha1 i (Finset.mem_insert_of_mem hi))
    have hsum0 : 0 вЙ§ вИС i вИИ t, a i :=
      Finset.sum_nonneg (fun i hi => ha i (Finset.mem_insert_of_mem hi))
    have h1 : (1 - a j) * (1 - вИС i вИИ t, a i) вЙ§ (1 - a j) * вИП i вИИ t, (1 - a i) :=
      mul_le_mul_of_nonneg_left hIH (by linarith [ha1 j (Finset.mem_insert_self j t)])
    nlinarith [h1, haj0, hsum0, mul_nonneg haj0 hsum0]

/-- Per-prime lower bound: for even `n` and prime `p`, `1 + T(p) вЙ• 1 - 1/(p-1)¬≤`. (Equality at
    `pвИ§n`; at `pвИ£n` the LHS is `вЙ• 1`.) -/
lemma one_add_Tarith_ge (p n : вДХ) (hp : p.Prime) (hn : Even n) :
    1 - 1 / ((p : вДЭ) - 1) ^ 2 вЙ§ 1 + Tarith n p := by
  rw [Tarith_prime p n hp]
  have hp2 : (2 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp.two_le
  have hpos : (0 : вДЭ) < (p : вДЭ) - 1 := by linarith
  by_cases hd : p вИ£ n
  ¬Ј rw [if_pos hd]
    have h0 : (0 : вДЭ) вЙ§ ((p : вДЭ) - 1) / ((p : вДЭ) - 1) ^ 2 := by positivity
    have h1 : (0 : вДЭ) вЙ§ 1 / ((p : вДЭ) - 1) ^ 2 := by positivity
    linarith
  ¬Ј rw [if_neg hd]
    have hrw : (-1 : вДЭ) / ((p : вДЭ) - 1) ^ 2 = -(1 / ((p : вДЭ) - 1) ^ 2) := by ring
    rw [hrw]; linarith

/-- Telescoping: `вИС_{k=2}^{M} (1/(k-1) - 1/k) = 1 - 1/M`. -/
lemma telescope_sum (M : вДХ) (hM : 2 вЙ§ M) :
    вИС k вИИ Finset.Icc 2 M, (1 / ((k : вДЭ) - 1) - 1 / (k : вДЭ)) = 1 - 1 / (M : вДЭ) := by
  induction M, hM using Nat.le_induction with
  | base => norm_num [Finset.Icc_self, Finset.sum_singleton]
  | succ M hM IH =>
    rw [Finset.sum_Icc_succ_top (by omega), IH]
    have hM0 : (M : вДЭ) вЙ† 0 := by positivity
    have hM1 : (M : вДЭ) + 1 вЙ† 0 := by positivity
    rw [show ((M + 1 : вДХ) : вДЭ) = (M : вДЭ) + 1 by push_cast; ring,
      show ((M : вДЭ) + 1) - 1 = (M : вДЭ) by ring]
    field_simp
    ring

/-- `вИС_{kвИИT} 1/k¬≤ < 1` for any finite `T вКЖ {k : 2 вЙ§ k}` (Basel partial-sum bound, elementary:
    `1/k¬≤ вЙ§ 1/(k-1)-1/k`, telescope over `Icc 2 (max T)`). -/
lemma sum_inv_sq_lt_one (T : Finset вДХ) (hT : вИА k вИИ T, 2 вЙ§ k) :
    вИС k вИИ T, 1 / ((k : вДЭ)) ^ 2 < 1 := by
  rcases T.eq_empty_or_nonempty with rfl | hne
  ¬Ј simp
  set M := T.max' hne with hMdef
  have hM2 : 2 вЙ§ M := hT _ (T.max'_mem hne)
  have hsub : T вКЖ Finset.Icc 2 M := by
    intro k hk
    rw [Finset.mem_Icc]
    exact вЯ®hT k hk, T.le_max' k hkвЯ©
  have hterm : вИА k вИИ T, 1 / ((k : вДЭ)) ^ 2 вЙ§ 1 / ((k : вДЭ) - 1) - 1 / (k : вДЭ) := by
    intro k hk
    have hkR : (2 : вДЭ) вЙ§ (k : вДЭ) := by exact_mod_cast hT k hk
    rw [div_sub_div _ _ (by linarith) (by linarith),
      div_le_div_iffвВА (by nlinarith [hkR]) (by nlinarith [hkR])]
    ring_nf
    nlinarith [hkR]
  calc вИС k вИИ T, 1 / ((k : вДЭ)) ^ 2
      вЙ§ вИС k вИИ T, (1 / ((k : вДЭ) - 1) - 1 / (k : вДЭ)) := Finset.sum_le_sum hterm
    _ вЙ§ вИС k вИИ Finset.Icc 2 M, (1 / ((k : вДЭ) - 1) - 1 / (k : вДЭ)) := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsub
        intro k hk _
        rw [Finset.mem_Icc] at hk
        have hkR : (2 : вДЭ) вЙ§ (k : вДЭ) := by exact_mod_cast hk.1
        rw [div_sub_div _ _ (by linarith) (by linarith)]
        apply div_nonneg <;> nlinarith [hkR]
    _ = 1 - 1 / (M : вДЭ) := telescope_sum M hM2
    _ < 1 := by
        have hMpos : (0 : вДЭ) < (M : вДЭ) := by
          have : 0 < M := by omega
          exact_mod_cast this
        have : (0 : вДЭ) < 1 / (M : вДЭ) := by positivity
        linarith

/-- Uniform Basel partial bound: `вИС_{k=2}^M 1/k¬≤ вЙ§ 3/4 - 1/M` (invariant induction, using
    `1/(M+1)¬≤ вЙ§ 1/(M(M+1)) = 1/M - 1/(M+1)`). -/
lemma sum_inv_sq_Icc_le (M : вДХ) (hM : 2 вЙ§ M) :
    вИС k вИИ Finset.Icc 2 M, 1 / ((k : вДЭ)) ^ 2 вЙ§ 3 / 4 - 1 / (M : вДЭ) := by
  induction M, hM using Nat.le_induction with
  | base => norm_num [Finset.Icc_self, Finset.sum_singleton]
  | succ M hM IH =>
    rw [Finset.sum_Icc_succ_top (by omega)]
    have hM0 : (0 : вДЭ) < (M : вДЭ) := by exact_mod_cast (by omega : 0 < M)
    have hcast : ((M + 1 : вДХ) : вДЭ) = (M : вДЭ) + 1 := by push_cast; ring
    have hkey : 1 / ((M + 1 : вДХ) : вДЭ) ^ 2 вЙ§ 1 / (M : вДЭ) - 1 / ((M + 1 : вДХ) : вДЭ) := by
      rw [hcast, div_sub_div _ _ (by positivity) (by positivity),
        div_le_div_iffвВА (by positivity) (by positivity)]
      ring_nf
      nlinarith [hM0]
    rw [hcast] at hkey вКҐ
    linarith [IH, hkey]

/-- `вИС_{kвИИT} 1/k¬≤ вЙ§ 3/4` **uniformly**, for any finite `T вКЖ {k : 2 вЙ§ k}`. (The uniform bound
    the partial Euler product needs вАФ the earlier `<1` bound isn't uniform in `T`.) -/
lemma sum_inv_sq_le34 (T : Finset вДХ) (hT : вИА k вИИ T, 2 вЙ§ k) :
    вИС k вИИ T, 1 / ((k : вДЭ)) ^ 2 вЙ§ 3 / 4 := by
  rcases T.eq_empty_or_nonempty with rfl | hne
  ¬Ј norm_num
  set M := T.max' hne with hMdef
  have hM2 : 2 вЙ§ M := hT _ (T.max'_mem hne)
  have hsub : T вКЖ Finset.Icc 2 M := fun k hk => Finset.mem_Icc.mpr вЯ®hT k hk, T.le_max' k hkвЯ©
  calc вИС k вИИ T, 1 / ((k : вДЭ)) ^ 2
      вЙ§ вИС k вИИ Finset.Icc 2 M, 1 / ((k : вДЭ)) ^ 2 := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsub
        intro k _ _; positivity
    _ вЙ§ 3 / 4 - 1 / (M : вДЭ) := sum_inv_sq_Icc_le M hM2
    _ вЙ§ 3 / 4 := by
        have hMpos : (0 : вДЭ) < (M : вДЭ) := by exact_mod_cast (by omega : 0 < M)
        have hp : (0 : вДЭ) < 1 / (M : вДЭ) := by positivity
        linarith

/-- **Uniform partial Euler product bound**: for even `n`, every finite partial product
    `вИП_{pвИИS}(1+T(p)) вЙ• 1/4`. Uses `a_p = [pвЙ†2]¬Ј1/(p-1)¬≤`: then `1+T(p) вЙ• 1-a_p`, `вИП(1-a) вЙ• 1-вИСa`
    (`prod_one_sub_ge`), and `вИС a_p вЙ§ 3/4` (`sum_inv_sq_le34` on the `pвЙ†2` part). -/
lemma partial_prod_ge (n : вДХ) (hn : Even n) (S : Finset Nat.Primes) :
    (1 : вДЭ) / 4 вЙ§ вИП p вИИ S, (1 + Tarith n (вЖСp : вДХ)) := by
  classical
  set a : Nat.Primes вЖТ вДЭ := fun p => if (вЖСp : вДХ) = 2 then 0 else 1 / ((вЖСp : вДЭ) - 1) ^ 2 with ha
  have hfac : вИА p вИИ S, 1 - a p вЙ§ 1 + Tarith n (вЖСp : вДХ) := by
    intro p _
    have hp2 : (2 : вДЭ) вЙ§ (вЖСp : вДЭ) := by exact_mod_cast p.2.two_le
    by_cases h2 : (вЖСp : вДХ) = 2
    ¬Ј simp only [ha, if_pos h2]
      have hval : Tarith n (вЖСp : вДХ) = 1 := by
        rw [Tarith_prime _ n p.2, if_pos (h2 вЦЄ (even_iff_two_dvd.mp hn))]
        rw [h2]; norm_num
      rw [hval]; norm_num
    ¬Ј simp only [ha, if_neg h2]
      exact one_add_Tarith_ge (вЖСp) n p.2 hn
  have ha01 : вИА p вИИ S, 0 вЙ§ a p вИІ a p вЙ§ 1 := by
    intro p _
    have hp3 : (2 : вДЭ) вЙ§ (вЖСp : вДЭ) := by exact_mod_cast p.2.two_le
    by_cases h2 : (вЖСp : вДХ) = 2
    ¬Ј simp only [ha, if_pos h2]; norm_num
    ¬Ј simp only [ha, if_neg h2]
      have hp3' : (3 : вДЭ) вЙ§ (вЖСp : вДЭ) := by
        rcases (p.2.eq_two_or_odd').symm with hodd | h2'
        ¬Ј rcases lt_or_eq_of_le p.2.two_le with h | h
          ¬Ј exact_mod_cast h
          ¬Ј exact absurd h.symm h2
        ¬Ј exact absurd h2' h2
      constructor
      ¬Ј positivity
      ¬Ј rw [div_le_one (by nlinarith [hp3'])]; nlinarith [hp3']
  have hfac0 : вИА p вИИ S, 0 вЙ§ 1 - a p := fun p hp => by linarith [(ha01 p hp).2]
  have hstep1 : вИП p вИИ S, (1 - a p) вЙ§ вИП p вИИ S, (1 + Tarith n (вЖСp : вДХ)) :=
    Finset.prod_le_prod (fun p hp => hfac0 p hp) hfac
  have hstep2 : 1 - вИС p вИИ S, a p вЙ§ вИП p вИИ S, (1 - a p) :=
    prod_one_sub_ge S a (fun p hp => (ha01 p hp).1) (fun p hp => (ha01 p hp).2)
  have hsum : вИС p вИИ S, a p вЙ§ 3 / 4 := by
    have hg : вИА p вИИ S,
        a p = (if 2 вЙ§ (вЖСp : вДХ) - 1 then 1 / (((вЖСp : вДХ) - 1 : вДХ) : вДЭ) ^ 2 else 0) := by
      intro p _
      have hp2 : 2 вЙ§ (вЖСp : вДХ) := p.2.two_le
      simp only [ha]
      by_cases h2 : (вЖСp : вДХ) = 2
      ¬Ј rw [if_pos h2, if_neg (by omega)]
      ¬Ј rw [if_neg h2, if_pos (by omega)]
        congr 1
        rw [Nat.cast_sub p.2.one_le]; norm_num
    have himg : (вИС p вИИ S,
          (if 2 вЙ§ (вЖСp : вДХ) - 1 then 1 / (((вЖСp : вДХ) - 1 : вДХ) : вДЭ) ^ 2 else 0))
        = вИС k вИИ S.image (fun p : Nat.Primes => (вЖСp : вДХ) - 1),
            (if 2 вЙ§ k then 1 / ((k : вДЭ)) ^ 2 else 0) := by
      rw [Finset.sum_image]
      intro x _ y _ hxy
      have hx2 : 1 вЙ§ (вЖСx : вДХ) := x.2.one_le
      have hy2 : 1 вЙ§ (вЖСy : вДХ) := y.2.one_le
      have hxy' : (вЖСx : вДХ) - 1 = (вЖСy : вДХ) - 1 := hxy
      exact Subtype.ext (by omega)
    rw [Finset.sum_congr rfl hg, himg, вЖР Finset.sum_filter]
    apply sum_inv_sq_le34
    intro k hk
    rw [Finset.mem_filter] at hk
    exact hk.2
  linarith [hstep1, hstep2, hsum]

/-- **Singular-series positivity** (conditional on `Tarith_summable`): `рЭФЦ(n) = вИС'_q T(q) вЙ• 1/4`
    for every even `n`. Passes the uniform partial-product bound `partial_prod_ge` through the
    `HasProd` limit (`eulerProduct_hasProd` + `Tarith_local`). This `cвВА = 1/4` is the constant
    `hmain` consumes: `рЭФЦ(n)¬Јr_N(n) вЙ• (1/4)¬Ј(X/2)`. -/
lemma singSeries_ge (n : вДХ) (hn1 : 1 вЙ§ n) (hn : Even n) : (1 : вДЭ) / 4 вЙ§ вИС' q, Tarith n q := by
  have hprod : HasProd (fun p : Nat.Primes => 1 + Tarith n (вЖСp : вДХ)) (вИС' q, Tarith n q) := by
    have h := (isMult_Tarith n).eulerProduct_hasProd (Tarith_summable n hn1)
    have heq : (fun p : Nat.Primes => вИС' e, Tarith n ((вЖСp : вДХ) ^ e))
        = (fun p : Nat.Primes => 1 + Tarith n (вЖСp : вДХ)) := by
      funext p; exact Tarith_local (вЖСp) n p.2
    rwa [heq] at h
  exact ge_of_tendsto hprod (Filter.Eventually.of_forall (fun S => partial_prod_ge n hn S))

/-- The **HardyвАУLittlewood main term** `m_X(n) = рЭФЦ(n)¬Јr_{X+1}(n)` (singular series √Ч kernel count). -/
noncomputable def mainTerm (X n : вДХ) : вДЭ :=
  (вИС' q, Tarith n q)
    * (((Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter (fun p => p.1 + p.2 = n)).card : вДЭ)

/-- **`hmain` discharged** (conditional on `Tarith_summable`): with `ќі X = (X+1)/16`, the main
    term dominates `ќі X` on the upper block for even `n`. Combines `singSeries_ge` (`рЭФЦвЙ•1/4`) and
    `kernel_real_lb` (`r_{X+1}(n)вЙ•X/2`): `m_X(n) вЙ• (1/4)(X/2) = X/8 вЙ• (X+1)/16` for `XвЙ•1`. -/
lemma hmain_bound :
    вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ вИА n : вДХ, X / 2 < n вЖТ n вЙ§ X вЖТ Even n вЖТ
      ((X : вДЭ) + 1) / 16 вЙ§ mainTerm X n := by
  refine вЯ®1, fun X hX n hn1 hn2 hne => ?_вЯ©
  rw [mainTerm]
  have hS : (1 : вДЭ) / 4 вЙ§ вИС' q, Tarith n q := singSeries_ge n (by omega) hne
  have hK : (X : вДЭ) / 2 вЙ§ (((Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter
      (fun p => p.1 + p.2 = n)).card : вДЭ) := kernel_real_lb X n hn1 hn2
  have hXR : (1 : вДЭ) вЙ§ (X : вДЭ) := by exact_mod_cast hX
  have hprod : (1 / 4) * ((X : вДЭ) / 2)
      вЙ§ (вИС' q, Tarith n q) * (((Finset.range (X + 1) √ЧЋҐ Finset.range (X + 1)).filter
        (fun p => p.1 + p.2 = n)).card : вДЭ) :=
    mul_le_mul hS hK (by positivity) (by linarith)
  have hcmp : ((X : вДЭ) + 1) / 16 вЙ§ (1 / 4) * ((X : вДЭ) / 2) := by nlinarith [hXR]
  linarith [hprod, hcmp]

/-- **`hvar` reduction (abstract triangle inequality)**: the reduction's weighted variance
    `вИС(repW вИТ mterm)¬≤ вЙ§ ќµXќі¬≤` follows from the two L¬≤-in-`n` bounds вАФ the core variance
    `вИС(repW вИТ cmodelRe)¬≤ вЙ§ ќµX¬≥` (banked `core_variance_repWeight`) and the **major-arc L¬≤ error**
    `вИС(cmodelRe вИТ mterm)¬≤ вЙ§ ќµX¬≥` (the one remaining analytic gap) вАФ plus `ќіX¬≤ вЙ• (X¬≤)/256`.
    Isolates the arc error as the sole missing input. -/
lemma hvar_of_arc_error
    (repW cmodelRe mterm : вДХ вЖТ вДХ вЖТ вДЭ)
    (hcore : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - cmodelRe X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3)
    (harc : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (cmodelRe X n - mterm X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3) :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - mterm X n) ^ 2
        вЙ§ ќµ * (X : вДЭ) * (((X : вДЭ) + 1) / 16) ^ 2 := by
  intro ќµ hќµ
  obtain вЯ®XвВБ, hXвВБвЯ© := hcore (ќµ / 1024) (by positivity)
  obtain вЯ®XвВВ, hXвВВвЯ© := harc (ќµ / 1024) (by positivity)
  refine вЯ®max 1 (max XвВБ XвВВ), fun X hX => ?_вЯ©
  have hX1 : 1 вЙ§ X := le_trans (le_max_left _ _) hX
  have hX1X : XвВБ вЙ§ X := le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hX
  have hX2X : XвВВ вЙ§ X := le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) hX
  have hXR : (1 : вДЭ) вЙ§ (X : вДЭ) := by exact_mod_cast hX1
  have hpt : вИА n вИИ Finset.Ioc (X / 2) X, (repW X n - mterm X n) ^ 2
      вЙ§ 2 * (repW X n - cmodelRe X n) ^ 2 + 2 * (cmodelRe X n - mterm X n) ^ 2 := by
    intro n _; nlinarith [sq_nonneg (repW X n - cmodelRe X n - (cmodelRe X n - mterm X n))]
  calc вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - mterm X n) ^ 2
      вЙ§ вИС n вИИ Finset.Ioc (X / 2) X,
          (2 * (repW X n - cmodelRe X n) ^ 2 + 2 * (cmodelRe X n - mterm X n) ^ 2) :=
        Finset.sum_le_sum hpt
    _ = 2 * (вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - cmodelRe X n) ^ 2)
          + 2 * (вИС n вИИ Finset.Ioc (X / 2) X, (cmodelRe X n - mterm X n) ^ 2) := by
        rw [Finset.sum_add_distrib, Finset.mul_sum, Finset.mul_sum]
    _ вЙ§ 2 * (ќµ / 1024 * (X : вДЭ) ^ 3) + 2 * (ќµ / 1024 * (X : вДЭ) ^ 3) := by
        have h1 := hXвВБ X hX1X
        have h2 := hXвВВ X hX2X
        linarith
    _ вЙ§ ќµ * (X : вДЭ) * (((X : вДЭ) + 1) / 16) ^ 2 := by
        have hkey : (X : вДЭ) ^ 3 вЙ§ (X : вДЭ) * ((X : вДЭ) + 1) ^ 2 := by nlinarith [hXR]
        have hrhs : ќµ * (X : вДЭ) * (((X : вДЭ) + 1) / 16) ^ 2
            = ќµ / 256 * ((X : вДЭ) * ((X : вДЭ) + 1) ^ 2) := by ring
        have hlhs : 2 * (ќµ / 1024 * (X : вДЭ) ^ 3) + 2 * (ќµ / 1024 * (X : вДЭ) ^ 3)
            = ќµ / 256 * (X : вДЭ) ^ 3 := by ring
        rw [hrhs, hlhs]
        exact mul_le_mul_of_nonneg_left hkey (by positivity)

/-- **L¬≤ triangle split** for the major-arc error: `вИС(fвИТh)¬≤ вЙ§ ќµX¬≥` follows from the two L¬≤-in-`n`
    bounds `вИС(fвИТg)¬≤ вЙ§ ќµX¬≥` and `вИС(gвИТh)¬≤ вЙ§ ќµX¬≥`. Isolates `harc` (with `f = Re coeffModel`,
    `g = рЭФЦ_P¬Јr_N`, `h = рЭФЦ¬Јr_N`) into the **arc-tail** error `fвИТg` and the **truncation** error
    `gвИТh` вАФ the two deepest circle-method sub-pieces. -/
lemma l2_error_triangle (f g h : вДХ вЖТ вДХ вЖТ вДЭ)
    (h1 : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (f X n - g X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3)
    (h2 : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (g X n - h X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3) :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (f X n - h X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3 := by
  intro ќµ hќµ
  obtain вЯ®XвВБ, hXвВБвЯ© := h1 (ќµ / 4) (by positivity)
  obtain вЯ®XвВВ, hXвВВвЯ© := h2 (ќµ / 4) (by positivity)
  refine вЯ®max XвВБ XвВВ, fun X hX => ?_вЯ©
  have hX1X : XвВБ вЙ§ X := le_trans (le_max_left _ _) hX
  have hX2X : XвВВ вЙ§ X := le_trans (le_max_right _ _) hX
  have hpt : вИА n вИИ Finset.Ioc (X / 2) X, (f X n - h X n) ^ 2
      вЙ§ 2 * (f X n - g X n) ^ 2 + 2 * (g X n - h X n) ^ 2 := by
    intro n _; nlinarith [sq_nonneg (f X n - g X n - (g X n - h X n))]
  calc вИС n вИИ Finset.Ioc (X / 2) X, (f X n - h X n) ^ 2
      вЙ§ вИС n вИИ Finset.Ioc (X / 2) X,
          (2 * (f X n - g X n) ^ 2 + 2 * (g X n - h X n) ^ 2) := Finset.sum_le_sum hpt
    _ = 2 * (вИС n вИИ Finset.Ioc (X / 2) X, (f X n - g X n) ^ 2)
          + 2 * (вИС n вИИ Finset.Ioc (X / 2) X, (g X n - h X n) ^ 2) := by
        rw [Finset.sum_add_distrib, Finset.mul_sum, Finset.mul_sum]
    _ вЙ§ 2 * (ќµ / 4 * (X : вДЭ) ^ 3) + 2 * (ќµ / 4 * (X : вДЭ) ^ 3) := by
        have := hXвВБ X hX1X; have := hXвВВ X hX2X; linarith
    _ = ќµ * (X : вДЭ) ^ 3 := by ring

/-- The truncated singular series is the partial sum of the arithmetic function `T`:
    `рЭФЦ_P(n) = вИС_{1вЙ§qвЙ§P} T(q)`. Bridges `singSeries` (the `hvar`-side truncation) to `Tarith`
    (whose tsum is `рЭФЦ(n)`), so the truncation error `рЭФЦ_P вИТ рЭФЦ = вИТвИС_{q>P} T(q)` is a `Tarith` tail. -/
lemma singSeries_eq_sum_Tarith (P n : вДХ) :
    singSeries P n = вИС q вИИ Finset.Icc 1 P, Tarith n q := by
  rw [singSeries]
  apply Finset.sum_congr rfl
  intro q _
  rw [Tarith_apply]


/-- **Finite geometric character sum**: `вИС_{n<N} e(nќЄ) = N` if `e(ќЄ)=1`, else `(e(NќЄ)вИТ1)/(e(ќЄ)вИТ1)`.
    The Dirichlet-kernel identity underlying finite character orthogonality вАФ the seed of the
    Ramanujan-sum orthogonality `вИС_{n<N} c_q(n)c_{q'}(n)` for `harc`'s truncation error. -/
lemma sum_e_geom (ќЄ : вДЭ) (N : вДХ) :
    вИС n вИИ Finset.range N, e ((n : вДЭ) * ќЄ)
      = if e ќЄ = 1 then (N : вДВ) else (e ((N : вДЭ) * ќЄ) - 1) / (e ќЄ - 1) := by
  have hsum : вИС n вИИ Finset.range N, e ((n : вДЭ) * ќЄ) = вИС n вИИ Finset.range N, (e ќЄ) ^ n := by
    apply Finset.sum_congr rfl; intro n _; exact e_pow ќЄ n
  rw [hsum]
  by_cases h : e ќЄ = 1
  ¬Ј rw [if_pos h]; simp [h]
  ¬Ј rw [if_neg h, geom_sum_eq h, e_pow ќЄ N]


/-- Trivial bound `вАЦвИС_{n<N} e(nќЄ)вАЦ вЙ§ N`. -/
lemma sum_e_norm_le_card (ќЄ : вДЭ) (N : вДХ) :
    вАЦвИС n вИИ Finset.range N, e ((n : вДЭ) * ќЄ)вАЦ вЙ§ (N : вДЭ) := by
  calc вАЦвИС n вИИ Finset.range N, e ((n : вДЭ) * ќЄ)вАЦ
      вЙ§ вИС n вИИ Finset.range N, вАЦe ((n : вДЭ) * ќЄ)вАЦ := norm_sum_le _ _
    _ = вИС n вИИ Finset.range N, (1 : вДЭ) := by
        apply Finset.sum_congr rfl; intro n _; exact e_norm _
    _ = (N : вДЭ) := by simp

/-- Geometric bound `вАЦвИС_{n<N} e(nќЄ)вАЦ вЙ§ 2/вАЦe(ќЄ)вИТ1вАЦ` for `e(ќЄ) вЙ† 1` вАФ the off-diagonal decay that
    powers Ramanujan-sum orthogonality (`harc` truncation error). -/
lemma sum_e_norm_le_geom (ќЄ : вДЭ) (N : вДХ) (h : e ќЄ вЙ† 1) :
    вАЦвИС n вИИ Finset.range N, e ((n : вДЭ) * ќЄ)вАЦ вЙ§ 2 / вАЦe ќЄ - 1вАЦ := by
  rw [sum_e_geom ќЄ N, if_neg h, norm_div]
  have hn : вАЦe ((N : вДЭ) * ќЄ) - 1вАЦ вЙ§ 2 := by
    calc вАЦe ((N : вДЭ) * ќЄ) - 1вАЦ вЙ§ вАЦe ((N : вДЭ) * ќЄ)вАЦ + вАЦ(1 : вДВ)вАЦ := norm_sub_le _ _
      _ = 2 := by rw [e_norm]; norm_num
  gcongr


/-- `e ќЄ ¬Ј e(вИТќЄ) = 1`. -/
lemma e_mul_neg (ќЄ : вДЭ) : e ќЄ * e (-ќЄ) = 1 := by
  simp only [e, вЖР Complex.exp_add]
  rw [вЖР Complex.exp_zero]
  congr 1
  push_cast
  ring

/-- **Trivial pointwise bound**: `вАЦc_q(n)вАЦ вЙ§ ѕЖ(q)` вАФ the Ramanujan sum is `ѕЖ(q)` unit-modulus
    terms. The length-capped mean square `вИС_{n<N}вАЦc_qвАЦ¬≤ вЙ§ N¬ЈѕЖ(q)¬≤` (harc `q > X` diagonal) rests on
    this. -/
lemma ramSum_norm_le (q n : вДХ) : вАЦramSum q nвАЦ вЙ§ (Nat.totient q : вДЭ) := by
  simp only [ramSum]
  calc вАЦвИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((n : вДЭ) * r / q)вАЦ
      вЙ§ вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), вАЦe ((n : вДЭ) * r / q)вАЦ :=
        norm_sum_le _ _
    _ = ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).card := by simp [e_norm]
    _ = (Nat.totient q : вДЭ) := by
        rw [Nat.totient]; congr 2; ext r; simp [Nat.Coprime, Nat.gcd_comm]

/-- **Ramanujan-sum full-period mean square (complex form)**: `вИС_{n<q} c_q(n)¬Јconj c_q(n) = q¬ЈѕЖ(q)`.
    The diagonal of Ramanujan orthogonality вАФ the L¬≤ engine of the harc truncation error: the
    character double-sum collapses via `char_orthogonality` to the diagonal `r = r'`, giving
    `q` per unit and `ѕЖ(q)` units. -/
lemma ramSum_mean_square_complex (q : вДХ) (hq : 0 < q) :
    вИС n вИИ Finset.range q, ramSum q n * (starRingEnd вДВ) (ramSum q n)
      = (q : вДВ) * (Nat.totient q) := by
  set U := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hU
  have step1 : вИА n вИИ Finset.range q,
      ramSum q n * (starRingEnd вДВ) (ramSum q n)
        = вИС r вИИ U, вИС r' вИИ U, e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) := by
    intro n _
    simp only [ramSum]
    rw [map_sum, Finset.sum_mul_sum]
    apply Finset.sum_congr rfl; intro r _
    apply Finset.sum_congr rfl; intro r' _
    rw [e_conj, e_add]
    congr 1
    push_cast; ring
  have step2 : вИС n вИИ Finset.range q, вИС r вИИ U, вИС r' вИИ U,
        e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q)
      = вИС r вИИ U, вИС r' вИИ U, (if (q : вД§) вИ£ ((r : вД§) - (r' : вД§)) then (q : вДВ) else 0) := by
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro r _
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro r' _
    exact char_orthogonality ((r : вД§) - (r' : вД§)) q hq.ne'
  have hdiag : вИА r вИИ U,
      (вИС r' вИИ U, (if (q : вД§) вИ£ ((r : вД§) - (r' : вД§)) then (q : вДВ) else 0)) = (q : вДВ) := by
    intro r hr
    rw [Finset.sum_eq_single r]
    ¬Ј simp
    ¬Ј intro r' hr' hne
      rw [if_neg]
      intro hdvd
      have hrq : r < q := Finset.mem_range.mp (Finset.mem_filter.mp hr).1
      have hr'q : r' < q := Finset.mem_range.mp (Finset.mem_filter.mp hr').1
      have hri : (0 : вД§) вЙ§ (r : вД§) := by positivity
      have hr'i : (0 : вД§) вЙ§ (r' : вД§) := by positivity
      have hrqi : (r : вД§) < q := by exact_mod_cast hrq
      have hr'qi : (r' : вД§) < q := by exact_mod_cast hr'q
      obtain вЯ®c, hcвЯ© := hdvd
      rcases lt_trichotomy c 0 with h1 | h1 | h1
      ¬Ј have hle : (r : вД§) - (r' : вД§) вЙ§ -(q : вД§) := by
          rw [hc]
          nlinarith [mul_le_mul_of_nonneg_left (show c вЙ§ -1 by omega)
            (show (0 : вД§) вЙ§ (q : вД§) by positivity)]
        omega
      ¬Ј apply hne
        have hz : (r' : вД§) = (r : вД§) := by rw [h1, mul_zero] at hc; omega
        exact_mod_cast hz
      ¬Ј have hge : (q : вД§) вЙ§ (r : вД§) - (r' : вД§) := by
          rw [hc]
          nlinarith [mul_le_mul_of_nonneg_left (show (1 : вД§) вЙ§ c by omega)
            (show (0 : вД§) вЙ§ (q : вД§) by positivity)]
        omega
    ¬Ј intro hnr; exact absurd hr hnr
  have hcard : U.card = Nat.totient q := by
    rw [hU, Nat.totient]
    apply Finset.card_nbij' id id <;> intro x hx <;>
      simp_all [Finset.mem_filter, Nat.Coprime, Nat.gcd_comm]
  rw [Finset.sum_congr rfl step1, step2, Finset.sum_congr rfl hdiag,
    Finset.sum_const, hcard, nsmul_eq_mul, mul_comm]

/-- **Ramanujan-sum full-period mean square (real form)**: `вИС_{n<q} вАЦc_q(n)вАЦ¬≤ = q¬ЈѕЖ(q)`. The
    L¬≤-per-period identity feeding the harc truncation bound `вИС_n(рЭФЦ_PвИТрЭФЦ)¬≤r_N¬≤ вЙ≤ X¬≥/P¬≤`. -/
lemma ramSum_mean_square (q : вДХ) (hq : 0 < q) :
    вИС n вИИ Finset.range q, вАЦramSum q nвАЦ ^ 2 = (q : вДЭ) * (Nat.totient q) := by
  have h := ramSum_mean_square_complex q hq
  have hterm : вИА n, ramSum q n * (starRingEnd вДВ) (ramSum q n)
      = ((вАЦramSum q nвАЦ ^ 2 : вДЭ) : вДВ) := by
    intro n
    rw [Complex.mul_conj]
    norm_cast
    rw [Complex.normSq_eq_norm_sq]
  rw [Finset.sum_congr rfl (fun n _ => hterm n), вЖР Complex.ofReal_sum] at h
  exact_mod_cast h

/-- **Ramanujan-sum off-diagonal orthogonality**: for `q вЙ† q'`, `вИС_{n<qq'} c_q(n)¬Јconj c_{q'}(n) = 0`.
    Distinct moduli are orthogonal вАФ coprimality (`gcd(r,q)=gcd(r',q')=1`) forces `qq'вИ§(rq'вИТr'q)`,
    so every character cross-term vanishes. This is what kills the `ѕГ(n)¬≤` loss: in the truncation
    L¬≤, `вИС_n(вИС_{q>P}T_q)¬≤` has no surviving cross terms, collapsing to the diagonal mean squares. -/
lemma ramSum_orthogonal_offdiag (q q' : вДХ) (hq : 0 < q) (hq' : 0 < q') (hne : q вЙ† q') :
    вИС n вИИ Finset.range (q * q'), ramSum q n * (starRingEnd вДВ) (ramSum q' n) = 0 := by
  set Uq := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hUq
  set Uq' := (Finset.range q').filter (fun r => Nat.gcd r q' = 1) with hUq'
  have hmul : 0 < q * q' := Nat.mul_pos hq hq'
  have hqR : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq.ne'
  have hq'R : (q' : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq'.ne'
  have step1 : вИА n вИИ Finset.range (q * q'),
      ramSum q n * (starRingEnd вДВ) (ramSum q' n)
        = вИС r вИИ Uq, вИС r' вИИ Uq',
            e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ)) := by
    intro n _
    simp only [ramSum]
    rw [map_sum, Finset.sum_mul_sum]
    apply Finset.sum_congr rfl; intro r _
    apply Finset.sum_congr rfl; intro r' _
    rw [e_conj, e_add]
    congr 1
    push_cast
    field_simp
    ring
  have step2 : (вИС n вИИ Finset.range (q * q'), вИС r вИИ Uq, вИС r' вИИ Uq',
        e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ)))
      = вИС r вИИ Uq, вИС r' вИИ Uq',
          (if ((q * q' : вДХ) : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) then
            ((q * q' : вДХ) : вДВ) else 0) := by
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro r _
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro r' _
    exact char_orthogonality ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) (q * q') hmul.ne'
  rw [Finset.sum_congr rfl step1, step2]
  apply Finset.sum_eq_zero; intro r hr
  apply Finset.sum_eq_zero; intro r' hr'
  rw [if_neg]
  intro hdvd
  have hrc : Nat.gcd r q = 1 := (Finset.mem_filter.mp hr).2
  have hr'c : Nat.gcd r' q' = 1 := (Finset.mem_filter.mp hr').2
  have hqdvd_prod : (q : вД§) вИ£ ((q * q' : вДХ) : вД§) := вЯ®(q' : вД§), by push_cast; ringвЯ©
  have h1 : (q : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) := dvd_trans hqdvd_prod hdvd
  have h2 : (q : вД§) вИ£ (r : вД§) * (q' : вД§) := by
    have h3 := dvd_add h1 (dvd_mul_left (q : вД§) (r' : вД§))
    have he : (r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) + (r' : вД§) * (q : вД§) = (r : вД§) * (q' : вД§) := by
      ring
    rwa [he] at h3
  have hcopq : IsCoprime (q : вД§) (r : вД§) := by
    rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_natCast_natCast, Nat.gcd_comm]; exact hrc
  have hqq' : (q : вД§) вИ£ (q' : вД§) := hcopq.dvd_of_dvd_mul_left h2
  have hq'dvd_prod : (q' : вД§) вИ£ ((q * q' : вДХ) : вД§) := вЯ®(q : вД§), by push_cast; ringвЯ©
  have h1' : (q' : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) := dvd_trans hq'dvd_prod hdvd
  have h2' : (q' : вД§) вИ£ (r' : вД§) * (q : вД§) := by
    have h3 := dvd_sub (dvd_mul_left (q' : вД§) (r : вД§)) h1'
    have he : (r : вД§) * (q' : вД§) - ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) = (r' : вД§) * (q : вД§) := by
      ring
    rwa [he] at h3
  have hcopq' : IsCoprime (q' : вД§) (r' : вД§) := by
    rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_natCast_natCast, Nat.gcd_comm]; exact hr'c
  have hq'q : (q' : вД§) вИ£ (q : вД§) := hcopq'.dvd_of_dvd_mul_left h2'
  exact hne (Nat.dvd_antisymm (by exact_mod_cast hqq') (by exact_mod_cast hq'q))

/-- `e(m) = 1` for integer `m` (period-1 of the additive character). -/
lemma e_natCast_eq_one (m : вДХ) : e (m : вДЭ) = 1 := by
  simp only [e]
  rw [show (2 * Real.pi * Complex.I * (m : вДЭ)) = ((m : вД§) : вДВ) * (2 * Real.pi * Complex.I) by
      push_cast; ring]
  exact Complex.exp_int_mul_two_pi_mul_I m

/-- **Ramanujan sum is `q`-periodic in `n`**: `c_q(n+q) = c_q(n)`. Lets a mean square over any
    multiple of the period reduce to the one-period identity (`ramSum_mean_square`). -/
lemma ramSum_periodic (q n : вДХ) : ramSum q (n + q) = ramSum q n := by
  simp only [ramSum]
  apply Finset.sum_congr rfl
  intro r hr
  have hqn : 0 < q := Nat.pos_of_ne_zero (by rintro rfl; simp at hr)
  have hqR : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hqn.ne'
  have hid : ((n + q : вДХ) : вДЭ) * (r : вДЭ) / q = (n : вДЭ) * (r : вДЭ) / q + (r : вДЭ) := by
    rw [Nat.cast_add]; field_simp
  rw [hid, вЖР e_add, e_natCast_eq_one, mul_one]

/-- **Period divides**: `c_q(n + kq) = c_q(n)` for all `k` вАФ iterated `ramSum_periodic`. -/
lemma ramSum_periodic_mul (q n k : вДХ) : ramSum q (n + k * q) = ramSum q n := by
  induction k with
  | zero => simp
  | succ k ih =>
    have h : n + (k + 1) * q = (n + k * q) + q := by ring
    rw [h, ramSum_periodic, ih]

/-- **Sum over multiple periods**: for `q`-periodic `f`, `вИС_{n<kq} f = k¬ЈвИС_{n<q} f`. Splits
    `range (kq)` into `k` consecutive period blocks, each equal to the base sum. -/
lemma periodic_sum_mul {M : Type*} [AddCommMonoid M] (f : вДХ вЖТ M) (q : вДХ)
    (hper : вИА n, f (n + q) = f n) (k : вДХ) :
    вИС n вИИ Finset.range (k * q), f n = k вАҐ вИС n вИИ Finset.range q, f n := by
  have hperk : вИА j i, f (i + j * q) = f i := by
    intro j
    induction j with
    | zero => intro i; simp
    | succ j ih =>
      intro i
      have h : i + (j + 1) * q = (i + j * q) + q := by ring
      rw [h, hper, ih]
  induction k with
  | zero => simp
  | succ k ih =>
    rw [show (k + 1) * q = k * q + q by ring, Finset.range_eq_Ico,
      вЖР Finset.sum_Ico_consecutive f (Nat.zero_le (k * q)) (Nat.le_add_right (k * q) q),
      вЖР Finset.range_eq_Ico, ih, succ_nsmul]
    congr 1
    rw [Finset.sum_Ico_eq_sum_range]
    simp only [Nat.add_sub_cancel_left]
    apply Finset.sum_congr rfl
    intro i _
    rw [add_comm (k * q) i, hperk]

/-- **Multi-period mean square (diagonal over a common period)**: `вИС_{n<kq} вАЦc_q(n)вАЦ¬≤ = kq¬ЈѕЖ(q)`.
    Applies `periodic_sum_mul` to the `q`-periodic `вАЦc_qвАЦ¬≤` and the one-period identity. -/
lemma ramSum_mean_square_multi (q k : вДХ) (hq : 0 < q) :
    вИС n вИИ Finset.range (k * q), вАЦramSum q nвАЦ ^ 2 = (k * q : вДЭ) * (Nat.totient q) := by
  have hper : вИА n, вАЦramSum q (n + q)вАЦ ^ 2 = вАЦramSum q nвАЦ ^ 2 := by
    intro n; rw [ramSum_periodic]
  rw [periodic_sum_mul (fun n => вАЦramSum q nвАЦ ^ 2) q hper k, ramSum_mean_square q hq,
    nsmul_eq_mul]
  push_cast; ring

/-- **Multi-period off-diagonal**: `вИС_{n<k(qq')} c_q(n)¬Јconj c_{q'}(n) = 0` for `q вЙ† q'`. The
    product is `(qq')`-periodic (both factors' periods divide `qq'`), so `periodic_sum_mul`
    reduces to the one-period vanishing `ramSum_orthogonal_offdiag`. -/
lemma ramSum_orthogonal_offdiag_multi (q q' k : вДХ) (hq : 0 < q) (hq' : 0 < q') (hne : q вЙ† q') :
    вИС n вИИ Finset.range (k * (q * q')), ramSum q n * (starRingEnd вДВ) (ramSum q' n) = 0 := by
  have hper : вИА n, ramSum q (n + q * q') * (starRingEnd вДВ) (ramSum q' (n + q * q'))
      = ramSum q n * (starRingEnd вДВ) (ramSum q' n) := by
    intro n
    have e1 : ramSum q (n + q * q') = ramSum q n := by
      rw [show n + q * q' = n + q' * q by ring]; exact ramSum_periodic_mul q n q'
    have e2 : ramSum q' (n + q * q') = ramSum q' n := ramSum_periodic_mul q' n q
    rw [e1, e2]
  rw [periodic_sum_mul (fun n => ramSum q n * (starRingEnd вДВ) (ramSum q' n)) (q * q') hper k,
    ramSum_orthogonal_offdiag q q' hq hq' hne, smul_zero]

/-- Ramanujan sum is real: `(c_q(n)).im = 0` (it equals the integer `cRam q n`). -/
lemma ramSum_im_zero (q n : вДХ) (hq : 0 < q) : (ramSum q n).im = 0 := by
  rw [ramSum_eq_cRam q n hq, Complex.intCast_im]

/-- **Real multi-period off-diagonal**: `вИС_{n<k(qq')} (c_q(n)).re¬Ј(c_{q'}(n)).re = 0` for `qвЙ†q'`.
    The real part of the complex vanishing (both sums real, so cross-terms drop). -/
lemma ramSum_re_orthogonal_offdiag_multi (q q' k : вДХ) (hq : 0 < q) (hq' : 0 < q') (hne : q вЙ† q') :
    вИС n вИИ Finset.range (k * (q * q')), (ramSum q n).re * (ramSum q' n).re = 0 := by
  have h := ramSum_orthogonal_offdiag_multi q q' k hq hq' hne
  have hre : вИА n, ((ramSum q n) * (starRingEnd вДВ) (ramSum q' n)).re
      = (ramSum q n).re * (ramSum q' n).re := by
    intro n
    rw [Complex.mul_re, Complex.conj_re, Complex.conj_im, ramSum_im_zero q' n hq']
    ring
  have hsum : (вИС n вИИ Finset.range (k * (q * q')),
      (ramSum q n) * (starRingEnd вДВ) (ramSum q' n)).re = 0 := by rw [h]; simp
  rw [Complex.re_sum] at hsum
  rw [вЖР hsum]
  apply Finset.sum_congr rfl; intro n _; exact (hre n).symm

/-- **Real multi-period diagonal**: `вИС_{n<kq} (c_q(n)).re¬≤ = kq¬ЈѕЖ(q)`. -/
lemma ramSum_re_sq_sum_multi (q k : вДХ) (hq : 0 < q) :
    вИС n вИИ Finset.range (k * q), (ramSum q n).re ^ 2 = (k * q : вДЭ) * (Nat.totient q) := by
  rw [вЖР ramSum_mean_square_multi q k hq]
  apply Finset.sum_congr rfl
  intro n _
  rw [вЖР Complex.normSq_eq_norm_sq, Complex.normSq_apply, ramSum_im_zero q n hq]
  ring

/-- **Aggregate quadratic form over a common period** (Ramanujan-sum large sieve): with `M` a
    common multiple of every `qвИИS` and every `qq'` (`qвЙ†q'вИИS`), the mean square of the character
    combination collapses to the diagonal:
    `вИС_{n<M} (вИС_{qвИИS} a_q c_q(n))¬≤ = вИС_{qвИИS} a_q¬≤¬ЈM¬ЈѕЖ(q)`.
    Off-diagonal cross-terms vanish by orthogonality; each diagonal contributes `M¬ЈѕЖ(q)`. This is
    the engine that removes the `ѕГ(n)¬≤` loss in the harc truncation error. -/
lemma aggregate_meansq (S : Finset вДХ) (a : вДХ вЖТ вДЭ) (M : вДХ)
    (hpos : вИА q вИИ S, 0 < q)
    (hdvd : вИА q вИИ S, q вИ£ M)
    (hdvd2 : вИА q вИИ S, вИА q' вИИ S, q вЙ† q' вЖТ (q * q') вИ£ M) :
    вИС n вИИ Finset.range M, (вИС q вИИ S, a q * (ramSum q n).re) ^ 2
      = вИС q вИИ S, (a q) ^ 2 * (M : вДЭ) * (Nat.totient q) := by
  have hexp : вИА n вИИ Finset.range M, (вИС q вИИ S, a q * (ramSum q n).re) ^ 2
      = вИС q вИИ S, вИС q' вИИ S, (a q * (ramSum q n).re) * (a q' * (ramSum q' n).re) := by
    intro n _
    rw [sq, Finset.sum_mul_sum]
  rw [Finset.sum_congr rfl hexp, Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro q hq
  rw [Finset.sum_comm]
  rw [Finset.sum_eq_single q]
  ¬Ј have hqpos : 0 < q := hpos q hq
    have hMq : (M / q) * q = M := Nat.div_mul_cancel (hdvd q hq)
    have hdiag : вИС n вИИ Finset.range M, (ramSum q n).re ^ 2 = (M : вДЭ) * (Nat.totient q) := by
      have h := ramSum_re_sq_sum_multi q (M / q) hqpos
      rw [hMq] at h
      have hMqR : (вЖС(M / q) : вДЭ) * вЖСq = (вЖСM : вДЭ) := by rw [вЖР Nat.cast_mul, hMq]
      rw [hMqR] at h
      exact h
    calc вИС n вИИ Finset.range M, (a q * (ramSum q n).re) * (a q * (ramSum q n).re)
        = a q ^ 2 * вИС n вИИ Finset.range M, (ramSum q n).re ^ 2 := by
          rw [Finset.mul_sum]; apply Finset.sum_congr rfl; intro n _; ring
      _ = a q ^ 2 * ((M : вДЭ) * (Nat.totient q)) := by rw [hdiag]
      _ = a q ^ 2 * (M : вДЭ) * (Nat.totient q) := by ring
  ¬Ј intro q' hq' hne
    have hMqq' : (M / (q * q')) * (q * q') = M := Nat.div_mul_cancel (hdvd2 q hq q' hq' hne.symm)
    have hoff : вИС n вИИ Finset.range M, (ramSum q n).re * (ramSum q' n).re = 0 := by
      have h := ramSum_re_orthogonal_offdiag_multi q q' (M / (q * q')) (hpos q hq) (hpos q' hq') hne.symm
      rwa [hMqq'] at h
    calc вИС n вИИ Finset.range M, (a q * (ramSum q n).re) * (a q' * (ramSum q' n).re)
        = a q * a q' * вИС n вИИ Finset.range M, (ramSum q n).re * (ramSum q' n).re := by
          rw [Finset.mul_sum]; apply Finset.sum_congr rfl; intro n _; ring
      _ = a q * a q' * 0 := by rw [hoff]
      _ = 0 := by ring
  ¬Ј intro hnq; exact absurd hq hnq

/-- **Minkowski-route summability**: `вИС_q ќЉ(q)¬≤/ѕЖ(q)^{3/2} < вИЮ`. From `sqfree_totient_strong`
    (`ѕЖ¬≤ вЙ• q^{3/2}/8` вЗТ `ѕЖ^{3/2} вЙ• q^{9/8}/2^{9/4}`) vs the summable `вИС 1/q^{9/8}` (9/8 > 1). This is the
    convergent Minkowski bound `вИЪL¬ЈвИС ќЉ¬≤/ѕЖ^{3/2}` the harc truncation needs (the naive diagonal+off-
    diagonal route diverges вАФ the signed off-diagonal's large-sieve cancellation is lost to triangle). -/
lemma phi_pow32_summable :
    Summable (fun q : вДХ => (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) := by
  apply Summable.of_nonneg_of_le (fun q => by positivity)
    (f := fun q : вДХ => (2 : вДЭ) ^ ((9 : вДЭ) / 4) * (1 / (q : вДЭ) ^ ((9 : вДЭ) / 8)))
  ¬Ј intro q
    by_cases hsq : Squarefree q
    ¬Ј have hqpos : 0 < q := Nat.pos_of_ne_zero hsq.ne_zero
      have hѕЖpos : 0 < (Nat.totient q : вДЭ) := by
        have := Nat.totient_pos.mpr hqpos; positivity
      have hќЉ2 : (ArithmeticFunction.moebius q : вДЭ) ^ 2 вЙ§ 1 := by
        have h1 : |((ArithmeticFunction.moebius q : вД§) : вДЭ)| вЙ§ 1 := by
          exact_mod_cast ArithmeticFunction.abs_moebius_le_one
        nlinarith [h1, abs_nonneg ((ArithmeticFunction.moebius q : вД§) : вДЭ),
          sq_abs ((ArithmeticFunction.moebius q : вД§) : вДЭ)]
      have hts := sqfree_totient_strong q hsq
      have h8 : (8 : вДЭ) ^ ((3 : вДЭ) / 4) = (2 : вДЭ) ^ ((9 : вДЭ) / 4) := by
        rw [show (8 : вДЭ) = (2 : вДЭ) ^ (3 : вДХ) by norm_num, вЖР Real.rpow_natCast (2 : вДЭ) 3,
          вЖР Real.rpow_mul (by norm_num)]
        norm_num
      have hpow : (q : вДЭ) ^ ((9 : вДЭ) / 8) вЙ§ (2 : вДЭ) ^ ((9 : вДЭ) / 4) * (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) := by
        have hѕЖ2 : (Nat.totient q : вДЭ) ^ 2 = (Nat.totient q : вДЭ) ^ (2 : вДЭ) := (Real.rpow_natCast _ 2).symm
        have hts' : (q : вДЭ) ^ ((3 : вДЭ) / 2) вЙ§ 8 * (Nat.totient q : вДЭ) ^ (2 : вДЭ) := by rw [вЖР hѕЖ2]; exact hts
        have hb := Real.rpow_le_rpow (by positivity) hts' (by norm_num : (0 : вДЭ) вЙ§ (3 : вДЭ) / 4)
        rw [Real.mul_rpow (by norm_num) (by positivity),
          вЖР Real.rpow_mul (by positivity : (0 : вДЭ) вЙ§ (q : вДЭ)),
          вЖР Real.rpow_mul (by positivity : (0 : вДЭ) вЙ§ (Nat.totient q : вДЭ))] at hb
        norm_num at hb
        rw [h8] at hb
        exact hb
      rw [mul_one_div, div_le_div_iffвВА (by positivity) (by positivity)]
      calc (ArithmeticFunction.moebius q : вДЭ) ^ 2 * (q : вДЭ) ^ ((9 : вДЭ) / 8)
          вЙ§ 1 * (q : вДЭ) ^ ((9 : вДЭ) / 8) := mul_le_mul_of_nonneg_right hќЉ2 (by positivity)
        _ = (q : вДЭ) ^ ((9 : вДЭ) / 8) := one_mul _
        _ вЙ§ (2 : вДЭ) ^ ((9 : вДЭ) / 4) * (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) := hpow
    ¬Ј rw [ArithmeticFunction.moebius_eq_zero_of_not_squarefree hsq]
      have hz : ((0 : вД§) : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) = 0 := by norm_num
      rw [hz]; positivity
  ¬Ј exact (Real.summable_one_div_nat_rpow.mpr (by norm_num)).mul_left _

/-- Telescoping: `вИС_{n=2}^{m} 1/(n(n-1)) = 1 - 1/m` for `m вЙ• 2`. -/
lemma sum_Icc_inv_mul_pred (m : вДХ) (hm : 2 вЙ§ m) :
    вИС n вИИ Finset.Icc 2 m, 1 / ((n : вДЭ) * ((n : вДЭ) - 1)) = 1 - 1 / (m : вДЭ) := by
  induction m with
  | zero => omega
  | succ k ih =>
    rcases Nat.lt_or_ge k 2 with hk | hk
    ¬Ј interval_cases k
      ¬Ј omega
      ¬Ј norm_num [Finset.Icc_self]
    ¬Ј rw [Finset.sum_Icc_succ_top (by omega : 2 вЙ§ k + 1), ih hk]
      have hk0 : (2 : вДЭ) вЙ§ (k : вДЭ) := by exact_mod_cast hk
      have hk1 : ((k : вДЭ) + 1) вЙ† 0 := by positivity
      have hk2 : (k : вДЭ) вЙ† 0 := by linarith
      have hterm : (1 : вДЭ) / ((вЖС(k + 1) : вДЭ) * ((вЖС(k + 1) : вДЭ) - 1)) = 1 / (k : вДЭ) - 1 / ((k : вДЭ) + 1) := by
        push_cast
        rw [show ((k : вДЭ) + 1 - 1) = (k : вДЭ) from by ring]
        field_simp
        ring
      rw [hterm]
      push_cast
      ring

/-- **The carefree product** `вИП_{p|q}(1 + 1/(p(p-1))) вЙ§ e` (absolute constant). Via `1+x вЙ§ exp x`
    and `вИС_{p|q} 1/(p(p-1)) вЙ§ 1` (telescoping over `p вИИ [2,q]`). This is the `CвВА = e` in the
    arithmetic length-capped mean square `вИС_{n<N} c_q(n)¬≤ вЙ§ CвВА¬ЈN¬ЈѕЖ(q)` вАФ the only such bound that
    closes the Minkowski route for `q > N` (the cosecant/min boundary `~ѕЖq` diverges there). -/
lemma carefree_prod_le (q : вДХ) :
    вИП p вИИ q.primeFactors, (1 + 1 / ((p : вДЭ) * ((p : вДЭ) - 1))) вЙ§ Real.exp 1 := by
  have hstep : вИА p вИИ q.primeFactors,
      (1 + 1 / ((p : вДЭ) * ((p : вДЭ) - 1))) вЙ§ Real.exp (1 / ((p : вДЭ) * ((p : вДЭ) - 1))) := by
    intro p hp
    linarith [Real.add_one_le_exp (1 / ((p : вДЭ) * ((p : вДЭ) - 1)))]
  have hnn : вИА p вИИ q.primeFactors, (0 : вДЭ) вЙ§ 1 + 1 / ((p : вДЭ) * ((p : вДЭ) - 1)) := by
    intro p hp
    have hp2 : 2 вЙ§ p := (Nat.prime_of_mem_primeFactors hp).two_le
    have hpR : (2 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp2
    have : (0 : вДЭ) < (p : вДЭ) * ((p : вДЭ) - 1) := by nlinarith
    positivity
  calc вИП p вИИ q.primeFactors, (1 + 1 / ((p : вДЭ) * ((p : вДЭ) - 1)))
      вЙ§ вИП p вИИ q.primeFactors, Real.exp (1 / ((p : вДЭ) * ((p : вДЭ) - 1))) :=
        Finset.prod_le_prod hnn hstep
    _ = Real.exp (вИС p вИИ q.primeFactors, 1 / ((p : вДЭ) * ((p : вДЭ) - 1))) := (Real.exp_sum _ _).symm
    _ вЙ§ Real.exp 1 := by
        apply Real.exp_le_exp.mpr
        rcases Nat.lt_or_ge q 2 with hq | hq
        ¬Ј interval_cases q <;> simp
        ¬Ј have hsub : q.primeFactors вКЖ Finset.Icc 2 q := by
            intro p hp
            rw [Finset.mem_Icc]
            exact вЯ®(Nat.prime_of_mem_primeFactors hp).two_le, Nat.le_of_mem_primeFactors hpвЯ©
          calc вИС p вИИ q.primeFactors, 1 / ((p : вДЭ) * ((p : вДЭ) - 1))
              вЙ§ вИС n вИИ Finset.Icc 2 q, 1 / ((n : вДЭ) * ((n : вДЭ) - 1)) := by
                apply Finset.sum_le_sum_of_subset_of_nonneg hsub
                intro n hn _
                rw [Finset.mem_Icc] at hn
                have hnR : (2 : вДЭ) вЙ§ (n : вДЭ) := by exact_mod_cast hn.1
                have : (0 : вДЭ) < (n : вДЭ) * ((n : вДЭ) - 1) := by nlinarith
                positivity
            _ = 1 - 1 / (q : вДЭ) := sum_Icc_inv_mul_pred q hq
            _ вЙ§ 1 := by
                have hqR : (0 : вДЭ) вЙ§ (q : вДЭ) := by positivity
                linarith [div_nonneg (zero_le_one) hqR]

/-- `h(g) = ѕЖ(g)¬≤/g` as a multiplicative arithmetic function (the summand of the length-capped
    mean-square divisor sum). -/
noncomputable def hphi : ArithmeticFunction вДЭ :=
  вЯ®fun g => (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ), by simpвЯ©

lemma hphi_apply (g : вДХ) : hphi g = (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ) := rfl

lemma isMult_hphi : hphi.IsMultiplicative := by
  refine вЯ®?_, ?_вЯ©
  ¬Ј simp [hphi_apply]
  ¬Ј intro a b hab
    simp only [hphi_apply, Nat.totient_mul hab]
    push_cast
    rw [mul_pow, div_mul_div_comm]

/-- **Multiplicative divisor sum**: `вИС_{g|q} ѕЖ(g)¬≤/g = вИП_{p|q}(1+(p-1)¬≤/p)` for squarefree `q`.
    Via `вИС_{d|q} h(d) = (ќґ вЛЖ h)(q)` (multiplicative, `IsMultiplicative.multiplicative_factorization`)
    factoring over `primeFactors` at squarefree `q`, with `(ќґвЛЖh)(p) = h(1)+h(p) = 1+(p-1)¬≤/p`. -/
lemma div_sum_phisq (q : вДХ) (hq : Squarefree q) :
    вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ)
      = вИП p вИИ q.primeFactors, (1 + ((p : вДЭ) - 1) ^ 2 / (p : вДЭ)) := by
  have hq0 : q вЙ† 0 := hq.ne_zero
  have hzm : (вЖС(ArithmeticFunction.zeta) : ArithmeticFunction вДЭ).IsMultiplicative :=
    ArithmeticFunction.IsMultiplicative.natCast ArithmeticFunction.isMultiplicative_zeta
  have hmultF : ((вЖС(ArithmeticFunction.zeta) : ArithmeticFunction вДЭ) * hphi).IsMultiplicative :=
    hzm.mul isMult_hphi
  have hconv : ((вЖС(ArithmeticFunction.zeta) : ArithmeticFunction вДЭ) * hphi) q
      = вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ) := by
    rw [ArithmeticFunction.coe_zeta_mul_apply]
    exact Finset.sum_congr rfl (fun g _ => hphi_apply g)
  rw [вЖР hconv,
    ArithmeticFunction.IsMultiplicative.multiplicative_factorization _ hmultF hq0,
    Finsupp.prod, Nat.support_factorization]
  apply Finset.prod_congr rfl
  intro p hp
  have hpp : p.Prime := Nat.prime_of_mem_primeFactors hp
  have hpdvd : p вИ£ q := Nat.dvd_of_mem_primeFactors hp
  have hfp : q.factorization p = 1 := by
    have h1 : q.factorization p вЙ§ 1 := (Nat.squarefree_iff_factorization_le_one hq0).mp hq p
    have h2 : 0 < q.factorization p := hpp.factorization_pos_of_dvd hq0 hpdvd
    omega
  rw [hfp, pow_one, ArithmeticFunction.coe_zeta_mul_apply, hpp.divisors,
    Finset.sum_pair hpp.one_lt.ne, hphi_apply, hphi_apply, Nat.totient_one, Nat.totient_prime hpp]
  push_cast [Nat.cast_sub hpp.one_le]
  ring

/-- `вИП_{p|q}(p-1) = ѕЖ(q)` for squarefree `q`. -/
lemma prod_sub_one_eq_totient (q : вДХ) (hq : Squarefree q) :
    вИП p вИИ q.primeFactors, (p - 1) = Nat.totient q := by
  rw [Nat.totient_eq_prod_factorization hq.ne_zero, Finsupp.prod, Nat.support_factorization]
  apply Finset.prod_congr rfl
  intro p hp
  have hfp : q.factorization p = 1 := by
    have h1 : q.factorization p вЙ§ 1 := (Nat.squarefree_iff_factorization_le_one hq.ne_zero).mp hq p
    have h2 : 0 < q.factorization p :=
      (Nat.prime_of_mem_primeFactors hp).factorization_pos_of_dvd hq.ne_zero
        (Nat.dvd_of_mem_primeFactors hp)
    omega
  rw [hfp]; simp

/-- **`вИС_{g|q} ѕЖ(g)¬≤/g вЙ§ e¬ЈѕЖ(q)`** for squarefree `q` вАФ the sharp divisor-sum bound. Combines the
    multiplicative identity `= вИП(1+(p-1)¬≤/p) = ѕЖ(q)¬ЈвИП(1+1/(p(p-1)))` with `carefree_prod_le вЙ§ e`. The
    RHS of the arithmetic length-capped mean square `вИС_{n<N} c_q¬≤ вЙ§ (N-1)¬Ј(вИСѕЖ(g)¬≤/g) вЙ§ e¬ЈN¬ЈѕЖ(q)`. -/
lemma div_sum_phisq_le (q : вДХ) (hq : Squarefree q) :
    вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ) вЙ§ Real.exp 1 * (Nat.totient q : вДЭ) := by
  rw [div_sum_phisq q hq]
  have hfact : вИП p вИИ q.primeFactors, (1 + ((p : вДЭ) - 1) ^ 2 / (p : вДЭ))
      = (вИП p вИИ q.primeFactors, ((p : вДЭ) - 1))
        * вИП p вИИ q.primeFactors, (1 + 1 / ((p : вДЭ) * ((p : вДЭ) - 1))) := by
    rw [вЖР Finset.prod_mul_distrib]
    apply Finset.prod_congr rfl
    intro p hp
    have hp2 : 2 вЙ§ p := (Nat.prime_of_mem_primeFactors hp).two_le
    have hpR : (2 : вДЭ) вЙ§ (p : вДЭ) := by exact_mod_cast hp2
    have hpne : (p : вДЭ) вЙ† 0 := by linarith
    have hp1ne : (p : вДЭ) - 1 вЙ† 0 := by linarith
    field_simp
    ring
  have hphiprod : (вИП p вИИ q.primeFactors, ((p : вДЭ) - 1)) = (Nat.totient q : вДЭ) := by
    rw [вЖР prod_sub_one_eq_totient q hq, Nat.cast_prod]
    apply Finset.prod_congr rfl
    intro p hp
    have hp1 : 1 вЙ§ p := (Nat.prime_of_mem_primeFactors hp).one_le
    rw [Nat.cast_sub hp1, Nat.cast_one]
  rw [hfact, hphiprod, mul_comm (Real.exp 1)]
  exact mul_le_mul_of_nonneg_left (carefree_prod_le q) (by positivity)

/-- **Length-capped mean square (assembled)**: `вИС_{nвИИ[1,N)} c_q(n)¬≤ вЙ§ e¬ЈѕЖ(q)¬Ј(N-1)` for squarefree `q`.
    The arithmetic bound that closes the Minkowski route (the cosecant/min boundary `~ѕЖq` diverges for
    `q>N`). Via `cRam_sq_sqfree` (`c_q(n)¬≤=ѕЖ(gcd(q,n))¬≤`, constant on gcd-fibers), regroup over `g|q`
    (`sum_fiberwise_of_maps_to`), bound each fiber `#{n:gcd=g} вЙ§ #{n:gвИ£n} вЙ§ (N-1)/g`
    (`card_multiples_Ico_le`), then the sharp divisor sum `вИСѕЖ(g)¬≤/g вЙ§ e¬ЈѕЖ(q)` (`div_sum_phisq_le`). -/
lemma cRam_meansq_Ico_le (q N : вДХ) (hq : Squarefree q) :
    вИС n вИИ Finset.Ico 1 N, ((cRam q n : вДЭ)) ^ 2
      вЙ§ Real.exp 1 * (Nat.totient q : вДЭ) * ((N - 1 : вДХ) : вДЭ) := by
  have hq0 : q вЙ† 0 := hq.ne_zero
  have hrw : вИА n, ((cRam q n : вДЭ)) ^ 2 = ((Nat.totient (Nat.gcd q n) : вДЭ)) ^ 2 := by
    intro n; exact_mod_cast cRam_sq_sqfree q n hq
  simp_rw [hrw]
  have hmaps : вИА n вИИ Finset.Ico 1 N, Nat.gcd q n вИИ q.divisors := by
    intro n hn
    rw [Nat.mem_divisors]
    exact вЯ®Nat.gcd_dvd_left q n, hq0вЯ©
  rw [вЖР Finset.sum_fiberwise_of_maps_to hmaps (fun n => (Nat.totient (Nat.gcd q n) : вДЭ) ^ 2)]
  calc вИС g вИИ q.divisors, вИС n вИИ (Finset.Ico 1 N).filter (fun n => Nat.gcd q n = g),
          (Nat.totient (Nat.gcd q n) : вДЭ) ^ 2
      = вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2
          * (((Finset.Ico 1 N).filter (fun n => Nat.gcd q n = g)).card : вДЭ) := by
        apply Finset.sum_congr rfl; intro g _
        have heq : вИА n вИИ (Finset.Ico 1 N).filter (fun n => Nat.gcd q n = g),
            (Nat.totient (Nat.gcd q n) : вДЭ) ^ 2 = (Nat.totient g : вДЭ) ^ 2 := by
          intro n hn; rw [(Finset.mem_filter.mp hn).2]
        rw [Finset.sum_congr rfl heq, Finset.sum_const, nsmul_eq_mul, mul_comm]
    _ вЙ§ вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 * (((N - 1) / g : вДХ) : вДЭ) := by
        apply Finset.sum_le_sum; intro g hg
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        have hsub : (Finset.Ico 1 N).filter (fun n => Nat.gcd q n = g)
            вКЖ (Finset.Ico 1 N).filter (fun n => g вИ£ n) := by
          intro n hn; rw [Finset.mem_filter] at hn вКҐ
          exact вЯ®hn.1, hn.2 вЦЄ Nat.gcd_dvd_right q nвЯ©
        have hg1 : 1 вЙ§ g := Nat.pos_of_mem_divisors hg
        have hc := le_trans (Finset.card_le_card hsub) (card_multiples_Ico_le N g hg1)
        exact_mod_cast hc
    _ вЙ§ вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 * (((N - 1 : вДХ) : вДЭ) / (g : вДЭ)) := by
        apply Finset.sum_le_sum; intro g _
        apply mul_le_mul_of_nonneg_left (Nat.cast_div_le) (by positivity)
    _ = ((N - 1 : вДХ) : вДЭ) * вИС g вИИ q.divisors, (Nat.totient g : вДЭ) ^ 2 / (g : вДЭ) := by
        rw [Finset.mul_sum]; apply Finset.sum_congr rfl; intro g _; ring
    _ вЙ§ ((N - 1 : вДХ) : вДЭ) * (Real.exp 1 * (Nat.totient q : вДЭ)) :=
        mul_le_mul_of_nonneg_left (div_sum_phisq_le q hq) (by positivity)
    _ = Real.exp 1 * (Nat.totient q : вДЭ) * ((N - 1 : вДХ) : вДЭ) := by ring

/-- **Per-q bound**: `вИЪ(вИС_{nвИИ(X/2,X]}(Tarith n q)¬≤) вЙ§ вИЪ(eX)¬ЈќЉ(q)¬≤/ѕЖ(q)^{3/2}` for squarefree `q`. The
    per-modulus вДУ¬≤ norm feeding the truncation Minkowski assembly (its RHS is exactly the summand of
    `phi_pow32_summable`). Uses `ќЉ(q)¬≤=1` (squarefree) + `cRam_meansq_Ico_le` (`вИСc_q¬≤вЙ§eѕЖ(q)X`). -/
lemma tarith_l2_le (q X : вДХ) (hq : Squarefree q) :
    Real.sqrt (вИС n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2)
      вЙ§ Real.sqrt (Real.exp 1 * (X : вДЭ))
        * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) := by
  have hqpos : 0 < q := Nat.pos_of_ne_zero hq.ne_zero
  have hFpos : (0 : вДЭ) < (Nat.totient q : вДЭ) := by
    have := Nat.totient_pos.mpr hqpos; positivity
  have hmu : ((ArithmeticFunction.moebius q : вДЭ)) ^ 2 = 1 := by
    have hne : ArithmeticFunction.moebius q вЙ† 0 :=
      ArithmeticFunction.moebius_ne_zero_iff_squarefree.mpr hq
    have habs : |ArithmeticFunction.moebius q| = 1 :=
      le_antisymm ArithmeticFunction.abs_moebius_le_one (Int.one_le_abs hne)
    have : (ArithmeticFunction.moebius q) ^ 2 = 1 := by rw [вЖР sq_abs, habs]; norm_num
    exact_mod_cast this
  have hcm : вИС n вИИ Finset.Ioc (X / 2) X, ((cRam q n : вДЭ)) ^ 2
      вЙ§ Real.exp 1 * (Nat.totient q : вДЭ) * (X : вДЭ) := by
    calc вИС n вИИ Finset.Ioc (X / 2) X, ((cRam q n : вДЭ)) ^ 2
        вЙ§ вИС n вИИ Finset.Ico 1 (X + 1), ((cRam q n : вДЭ)) ^ 2 := by
          apply Finset.sum_le_sum_of_subset_of_nonneg
          ¬Ј intro n hn; simp only [Finset.mem_Ioc, Finset.mem_Ico] at *; omega
          ¬Ј intro n _ _; positivity
      _ вЙ§ Real.exp 1 * (Nat.totient q : вДЭ) * (((X + 1) - 1 : вДХ) : вДЭ) := cRam_meansq_Ico_le q (X + 1) hq
      _ = Real.exp 1 * (Nat.totient q : вДЭ) * (X : вДЭ) := by norm_num
  have hexp2 : ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2
      = 1 / (Nat.totient q : вДЭ) ^ 3 := by
    rw [div_pow, hmu, one_pow, вЖР Real.rpow_natCast ((Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) 2,
      вЖР Real.rpow_mul hFpos.le]
    norm_num
  have hpull : вИС n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2
      = (1 / (Nat.totient q : вДЭ) ^ 4) * вИС n вИИ Finset.Ioc (X / 2) X, ((cRam q n : вДЭ)) ^ 2 := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl; intro n _
    rw [Tarith_apply, hmu]
    field_simp
  have hsq : вИС n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2
      вЙ§ Real.exp 1 * (X : вДЭ)
        * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2 := by
    rw [hexp2, hpull]
    calc (1 / (Nat.totient q : вДЭ) ^ 4) * вИС n вИИ Finset.Ioc (X / 2) X, ((cRam q n : вДЭ)) ^ 2
        вЙ§ (1 / (Nat.totient q : вДЭ) ^ 4) * (Real.exp 1 * (Nat.totient q : вДЭ) * (X : вДЭ)) :=
          mul_le_mul_of_nonneg_left hcm (by positivity)
      _ = Real.exp 1 * (X : вДЭ) * (1 / (Nat.totient q : вДЭ) ^ 3) := by field_simp
  calc Real.sqrt (вИС n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2)
      вЙ§ Real.sqrt (Real.exp 1 * (X : вДЭ)
          * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2) :=
        Real.sqrt_le_sqrt hsq
    _ = Real.sqrt (Real.exp 1 * (X : вДЭ))
          * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) := by
        rw [Real.sqrt_mul (by positivity), Real.sqrt_sq (by positivity)]

/-- **Per-q вДУ¬≤ bound for ALL q** (non-squarefree вЗТ `ќЉ=0` вЗТ both sides 0). The all-`q` form that
    plugs into the truncation Minkowski assembly's finite sum over `q вИИ S`. -/
lemma tarith_l2_le_all (q X : вДХ) :
    Real.sqrt (вИС n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2)
      вЙ§ Real.sqrt (Real.exp 1 * (X : вДЭ))
        * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) := by
  by_cases hq : Squarefree q
  ¬Ј exact tarith_l2_le q X hq
  ¬Ј have hmu : (ArithmeticFunction.moebius q : вДЭ) = 0 := by
      rw [ArithmeticFunction.moebius_eq_zero_of_not_squarefree hq]; norm_num
    have hz : вИА n вИИ Finset.Ioc (X / 2) X, (Tarith n q) ^ 2 = 0 := by
      intro n _; rw [Tarith_apply, hmu]; ring
    rw [Finset.sum_congr rfl hz, Finset.sum_const_zero, Real.sqrt_zero, hmu]
    simp

/-- `вИС_q ќЉ(q)¬≤/ѕЖ(q)¬≥` converges вАФ bounded termwise by `4/q^{6/5}` (via `1/ѕЖ¬≥ вЙ§ 1/ѕЖ¬≤` for `ѕЖ вЙ• 1`
    and `sqfree_totient`). This is the diagonal of the aggregate at `a_q = ќЉ(q)¬≤/ѕЖ(q)¬≤`, so its
    tail `вИС_{q>P} ќЉ(q)¬≤/ѕЖ(q)¬≥ вЖТ 0` bounds the harc truncation error. -/
lemma phi_cube_summable :
    Summable (fun q : вДХ => (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 3) := by
  apply Summable.of_nonneg_of_le (fun q => by positivity)
    (f := fun q : вДХ => 4 * (1 / (q : вДЭ) ^ ((6 : вДЭ) / 5)))
  ¬Ј intro q
    by_cases hsf : Squarefree q
    ¬Ј have hѕЖpos : (0 : вДЭ) < (Nat.totient q : вДЭ) := by
        have : 0 < Nat.totient q := Nat.totient_pos.mpr hsf.ne_zero.bot_lt
        positivity
      have hѕЖ1 : (1 : вДЭ) вЙ§ (Nat.totient q : вДЭ) := by
        have : 1 вЙ§ Nat.totient q := Nat.totient_pos.mpr hsf.ne_zero.bot_lt
        exact_mod_cast this
      have hќЉ2 : (ArithmeticFunction.moebius q : вДЭ) ^ 2 вЙ§ 1 := by
        have h' : |(ArithmeticFunction.moebius q : вДЭ)| вЙ§ 1 := by
          exact_mod_cast ArithmeticFunction.abs_moebius_le_one (n := q)
        nlinarith [sq_abs (ArithmeticFunction.moebius q : вДЭ),
          abs_nonneg (ArithmeticFunction.moebius q : вДЭ), h']
      have hq6 : (0 : вДЭ) < (q : вДЭ) ^ ((6 : вДЭ) / 5) := by
        have hq0 : 0 < q := hsf.ne_zero.bot_lt
        have : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast hq0
        positivity
      have hst := sqfree_totient q hsf
      rw [mul_one_div, div_le_div_iffвВА (by positivity) hq6]
      nlinarith [hst, hќЉ2, hѕЖ1, hѕЖpos, hq6.le,
        mul_nonneg (show (0 : вДЭ) вЙ§ 1 - (ArithmeticFunction.moebius q : вДЭ) ^ 2 by linarith) hq6.le,
        mul_nonneg (sq_nonneg (Nat.totient q : вДЭ)) (show (0 : вДЭ) вЙ§ (Nat.totient q : вДЭ) - 1 by linarith)]
    ¬Ј rw [ArithmeticFunction.moebius_eq_zero_of_not_squarefree hsf]
      simp
      positivity
  ¬Ј apply Summable.mul_left
    exact (Real.summable_one_div_nat_rpow).mpr (by norm_num)

/-- `(c_q(n)).re = cRam q n` (the Ramanujan sum is that integer). -/
lemma ramSum_re_eq_cRam (q n : вДХ) (hq : 0 < q) : (ramSum q n).re = (cRam q n : вДЭ) := by
  rw [ramSum_eq_cRam q n hq, Complex.intCast_re]

/-- **Bridge**: `Tarith n q = (ќЉ(q)¬≤/ѕЖ(q)¬≤)¬Ј(c_q(n)).re` вАФ the singular-series term as a coefficient
    times the (real) Ramanujan sum, matching the aggregate's shape (`a_q = ќЉ(q)¬≤/ѕЖ(q)¬≤`). -/
lemma Tarith_eq (q n : вДХ) (hq : 0 < q) :
    Tarith n q
      = ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 2) * (ramSum q n).re := by
  rw [Tarith_apply, ramSum_re_eq_cRam q n hq]
  ring

/-- **Singular-series mean square over a period**: `вИС_{n<M}(вИС_{qвИИS} Tarith n q)¬≤ = вИС_{qвИИS}(ќЉ¬≤/ѕЖ¬≤)¬≤¬ЈM¬ЈѕЖ`.
    Combines the aggregate large sieve with the `Tarith вЖТ a_q¬Јc_q` bridge вАФ the truncation-tail L¬≤
    over a full period, before instantiating `S = {q > P}` and bounding by `phi_cube_summable`. -/
lemma Tarith_aggregate_meansq (S : Finset вДХ) (M : вДХ)
    (hpos : вИА q вИИ S, 0 < q) (hdvd : вИА q вИИ S, q вИ£ M)
    (hdvd2 : вИА q вИИ S, вИА q' вИИ S, q вЙ† q' вЖТ (q * q') вИ£ M) :
    вИС n вИИ Finset.range M, (вИС q вИИ S, Tarith n q) ^ 2
      = вИС q вИИ S, ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 2) ^ 2
          * (M : вДЭ) * (Nat.totient q) := by
  have hbridge : вИА n вИИ Finset.range M, (вИС q вИИ S, Tarith n q) ^ 2
      = (вИС q вИИ S, ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 2)
          * (ramSum q n).re) ^ 2 := by
    intro n _
    congr 1
    apply Finset.sum_congr rfl
    intro q hq
    exact Tarith_eq q n (hpos q hq)
  rw [Finset.sum_congr rfl hbridge]
  exact aggregate_meansq S (fun q => (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 2)
    M hpos hdvd hdvd2

/-- **Clean truncation-tail L¬≤ over a period**: `вИС_{n<M}(вИС_{qвИИS} Tarith n q)¬≤ = M¬ЈвИС_{qвИИS} ќЉ(q)¬≤/ѕЖ(q)¬≥`.
    Simplifies the aggregate's diagonal via `ќЉвБі=ќЉ¬≤`. With `S = {q вИИ (P, вА¶]}` this is exactly the tail
    controlled by `phi_cube_summable` вАФ the ѕГ(n)¬≤-free bound the harc truncation needs. -/
lemma Tarith_aggregate_meansq_clean (S : Finset вДХ) (M : вДХ)
    (hpos : вИА q вИИ S, 0 < q) (hdvd : вИА q вИИ S, q вИ£ M)
    (hdvd2 : вИА q вИИ S, вИА q' вИИ S, q вЙ† q' вЖТ (q * q') вИ£ M) :
    вИС n вИИ Finset.range M, (вИС q вИИ S, Tarith n q) ^ 2
      = (M : вДЭ) * вИС q вИИ S, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ 3 := by
  rw [Tarith_aggregate_meansq S M hpos hdvd hdvd2, Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro q hq
  have hѕЖpos : (0 : вДЭ) < (Nat.totient q : вДЭ) := by
    have : 0 < Nat.totient q := Nat.totient_pos.mpr (hpos q hq)
    positivity
  have hќЉ4 : (ArithmeticFunction.moebius q : вДЭ) ^ 4 = (ArithmeticFunction.moebius q : вДЭ) ^ 2 := by
    have h := ArithmeticFunction.abs_moebius_le_one (n := q)
    rw [abs_le] at h
    have hm : ArithmeticFunction.moebius q = -1 вИ® ArithmeticFunction.moebius q = 0
        вИ® ArithmeticFunction.moebius q = 1 := by omega
    rcases hm with h1 | h1 | h1 <;> rw [h1] <;> norm_num
  rw [div_pow, show ((ArithmeticFunction.moebius q : вДЭ) ^ 2) ^ 2
      = (ArithmeticFunction.moebius q : вДЭ) ^ 4 by ring, hќЉ4]
  field_simp

/-- **Interval expansion**: `вИС_{n<N} c_q(n)¬Јconj c_q(n) = вИС_{r,r'вИИU_q} вИС_{n<N} e((rвИТr')n/q)` вАФ the
    character double-sum over an ARBITRARY interval (the direct route to the interval mean square,
    which the full-period aggregate cannot reach since `lcm(moduli) вЙЂ N`). No collapse yet: the
    inner `вИС_{n<N} e(¬Ј)` is bounded by `N` on the diagonal, by `2/вАЦe(ќЄ)вИТ1вАЦ` off it. -/
lemma ramSum_sq_interval_expand (q N : вДХ) :
    вИС n вИИ Finset.range N, ramSum q n * (starRingEnd вДВ) (ramSum q n)
      = вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
          вИС r' вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
            вИС n вИИ Finset.range N, e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) := by
  have step1 : вИА n вИИ Finset.range N, ramSum q n * (starRingEnd вДВ) (ramSum q n)
      = вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
          вИС r' вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
            e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) := by
    intro n _
    simp only [ramSum]
    rw [map_sum, Finset.sum_mul_sum]
    apply Finset.sum_congr rfl; intro r _
    apply Finset.sum_congr rfl; intro r' _
    rw [e_conj, e_add]
    congr 1
    push_cast; ring
  rw [Finset.sum_congr rfl step1, Finset.sum_comm]
  apply Finset.sum_congr rfl; intro r _
  rw [Finset.sum_comm]


/-- Off the integers, `e ќЄ вЙ† 1` вАФ the non-degeneracy that makes the off-diagonal geometric bound
    `sum_e_norm_le_geom` apply to `ќЄ = (rвИТr')/q` when `0 < |rвИТr'| < q`. -/
lemma e_ne_one_of_not_int (x : вДЭ) (h : вИА m : вД§, x вЙ† m) : e x вЙ† 1 := by
  intro he
  rw [e_eq_one_iff] at he
  obtain вЯ®m, hmвЯ© := he
  exact h m hm

/-- **Off-diagonal geometric bound**: for `r вЙ† r'` with `r, r' < q`, the interval character sum
    `вИС_{n<N} e((rвИТr')n/q)` is bounded вАФ independent of `N` вАФ by `2/вАЦe((rвИТr')/q)вИТ1вАЦ`. The `N`-free
    boundary term of the interval mean square. -/
lemma offdiag_geom_bound (q N r r' : вДХ) (hq : 0 < q) (hr : r < q) (hr' : r' < q) (hne : r вЙ† r') :
    вАЦвИС n вИИ Finset.range N, e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / (q : вДЭ))вАЦ
      вЙ§ 2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ := by
  have hqR : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq.ne'
  have hќЄne : e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) вЙ† 1 := by
    apply e_ne_one_of_not_int
    intro m hm
    rw [div_eq_iff hqR] at hm
    have hint : (r : вД§) - (r' : вД§) = m * q := by exact_mod_cast hm
    have hri : (0 : вД§) вЙ§ (r : вД§) := by positivity
    have hr'i : (0 : вД§) вЙ§ (r' : вД§) := by positivity
    have hrqi : (r : вД§) < q := by exact_mod_cast hr
    have hr'qi : (r' : вД§) < q := by exact_mod_cast hr'
    have hqz : (0 : вД§) < q := by exact_mod_cast hq
    rcases lt_trichotomy m 0 with hm0 | hm0 | hm0
    ¬Ј have : (r : вД§) - (r' : вД§) вЙ§ -(q : вД§) := by
        rw [hint]; nlinarith [mul_le_mul_of_nonneg_right (show m вЙ§ -1 by omega) hqz.le]
      omega
    ¬Ј rw [hm0, zero_mul] at hint; omega
    ¬Ј have : (q : вД§) вЙ§ (r : вД§) - (r' : вД§) := by
        rw [hint]; nlinarith [mul_le_mul_of_nonneg_right (show (1 : вД§) вЙ§ m by omega) hqz.le]
      omega
  have hrw : вИА n : вДХ, e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / (q : вДЭ))
      = e ((n : вДЭ) * ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ))) := by
    intro n; congr 1; ring
  rw [Finset.sum_congr rfl (fun n _ => hrw n)]
  exact sum_e_norm_le_geom ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) N hќЄne

/-- **Interval diagonal extraction**: the interval mean square `вИС_{n<N} c_q(n)¬Јconj c_q(n)` splits
    into `N¬ЈѕЖ(q)` (diagonal `r'=r`, each inner sum `= N`) plus an off-diagonal remainder (bounded
    by `offdiag_geom_bound` per pair). The `N¬ЈѕЖ(q)` main term is exactly the full-period value's
    per-period average times `N`. -/
lemma ramSum_sq_interval_diag (q N : вДХ) (hq : 0 < q) :
    вИС n вИИ Finset.range N, ramSum q n * (starRingEnd вДВ) (ramSum q n)
      = (N : вДВ) * (Nat.totient q)
        + вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
            вИС r' вИИ ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).erase r,
              вИС n вИИ Finset.range N, e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) := by
  set U := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hU
  have he0 : e 0 = 1 := by simp [e]
  rw [ramSum_sq_interval_expand q N]
  have hsplit : вИА r вИИ U, вИС r' вИИ U, (вИС n вИИ Finset.range N,
        e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q))
      = (вИС n вИИ Finset.range N, e ((((r : вД§) - (r : вД§) : вД§) : вДЭ) * (n : вДЭ) / q))
        + вИС r' вИИ U.erase r, вИС n вИИ Finset.range N,
            e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) := by
    intro r hr
    exact (Finset.add_sum_erase U _ hr).symm
  rw [Finset.sum_congr rfl hsplit, Finset.sum_add_distrib]
  congr 1
  have hdiag : вИА r вИИ U, вИС n вИИ Finset.range N,
      e ((((r : вД§) - (r : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) = (N : вДВ) := by
    intro r _
    have hone : вИА n : вДХ, e ((((r : вД§) - (r : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) = 1 := by
      intro n
      rw [show ((((r : вД§) - (r : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) = 0 by push_cast; ring]
      exact he0
    rw [Finset.sum_congr rfl (fun n _ => hone n)]
    simp
  have hcard : U.card = Nat.totient q := by
    rw [hU, Nat.totient]
    apply Finset.card_nbij' id id <;> intro x hx <;>
      simp_all [Finset.mem_filter, Nat.Coprime, Nat.gcd_comm]
  rw [Finset.sum_congr rfl hdiag, Finset.sum_const, hcard, nsmul_eq_mul, mul_comm]

/-- **Interval single-modulus mean square bound**: `|вИС_{n<N}вАЦc_q(n)вАЦ¬≤ вИТ N¬ЈѕЖ(q)|` is at most the
    summed off-diagonal geometric bounds вАФ an `N`-free error. This is the interval analogue of the
    full-period identity `вИСвАЦc_qвАЦ¬≤=q¬ЈѕЖ(q)`: main term `N¬ЈѕЖ(q)`, boundary `O_q(1)` in `N`. -/
lemma ramSum_sq_interval_bound (q N : вДХ) (hq : 0 < q) :
    |(вИС n вИИ Finset.range N, вАЦramSum q nвАЦ ^ 2) - (N : вДЭ) * (Nat.totient q)|
      вЙ§ вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
          вИС r' вИИ ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).erase r,
            2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ := by
  set U := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hU
  set D := вИС r вИИ U, вИС r' вИИ U.erase r, вИС n вИИ Finset.range N,
    e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q) with hD
  have hre : вИС n вИИ Finset.range N, вАЦramSum q nвАЦ ^ 2
      = (вИС n вИИ Finset.range N, ramSum q n * (starRingEnd вДВ) (ramSum q n)).re := by
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro n _
    rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
  rw [hre, ramSum_sq_interval_diag q N hq, Complex.add_re]
  have hNѕЖ : ((N : вДВ) * (Nat.totient q)).re = (N : вДЭ) * (Nat.totient q) := by simp
  rw [hNѕЖ, show (N : вДЭ) * (Nat.totient q) + D.re - (N : вДЭ) * (Nat.totient q) = D.re by ring]
  calc |D.re| вЙ§ вАЦDвАЦ := by
        have h1 : D.re ^ 2 вЙ§ вАЦDвАЦ ^ 2 := by
          rw [вЖР Complex.normSq_eq_norm_sq, Complex.normSq_apply]
          nlinarith [sq_nonneg D.im]
        nlinarith [h1, norm_nonneg D, abs_nonneg D.re, sq_abs D.re]
    _ вЙ§ вИС r вИИ U, вАЦвИС r' вИИ U.erase r, вИС n вИИ Finset.range N,
          e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q)вАЦ := norm_sum_le _ _
    _ вЙ§ вИС r вИИ U, вИС r' вИИ U.erase r, вАЦвИС n вИИ Finset.range N,
          e ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) * (n : вДЭ) / q)вАЦ := by
        apply Finset.sum_le_sum; intro r _; exact norm_sum_le _ _
    _ вЙ§ вИС r вИИ U, вИС r' вИИ U.erase r,
          2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ := by
        apply Finset.sum_le_sum; intro r hr
        apply Finset.sum_le_sum; intro r' hr'
        have hrq : r < q := Finset.mem_range.mp (Finset.mem_filter.mp hr).1
        have hr'mem : r' вИИ U := Finset.mem_of_mem_erase hr'
        have hr'q : r' < q := Finset.mem_range.mp (Finset.mem_filter.mp hr'mem).1
        have hne : r вЙ† r' := (Finset.ne_of_mem_erase hr').symm
        exact offdiag_geom_bound q N r r' hq hrq hr'q hne

/-- **Cross-moduli interval bound**: for `q вЙ† q'`, `вИС_{n<N} c_q(n)¬Јconj c_{q'}(n)` has NO main term
    (unlike the `q=q'` diagonal `ramSum_sq_interval_bound`) вАФ over any interval it is at most the
    summed off-diagonal cosecant boundary. This is the orthogonality that kills the pointwise
    `ѕГ(n)¬≤` loss for the harc truncation's cross terms. Holds for ANY distinct `q,q'` (no coprimality
    needed): the full-period contradiction `qq'|(rq'вИТr'q) вЯє q|q' вИІ q'|q вЯє q=q'` (same as
    `ramSum_orthogonal_offdiag`) makes every character `e((rq'вИТr'q)/(qq'))вЙ†1`. -/
lemma ramSum_cross_interval_bound (q q' N : вДХ) (hq : 0 < q) (hq' : 0 < q') (hne : q вЙ† q') :
    вАЦвИС n вИИ Finset.range N, ramSum q n * (starRingEnd вДВ) (ramSum q' n)вАЦ
      вЙ§ вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
          вИС r' вИИ (Finset.range q').filter (fun r => Nat.gcd r q' = 1),
            2 / вАЦe ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ)
                      / ((q * q' : вДХ) : вДЭ)) - 1вАЦ := by
  set Uq := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hUq
  set Uq' := (Finset.range q').filter (fun r => Nat.gcd r q' = 1) with hUq'
  have hmul : 0 < q * q' := Nat.mul_pos hq hq'
  have hqR : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq.ne'
  have hq'R : (q' : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq'.ne'
  have step1 : вИА n вИИ Finset.range N,
      ramSum q n * (starRingEnd вДВ) (ramSum q' n)
        = вИС r вИИ Uq, вИС r' вИИ Uq',
            e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ)) := by
    intro n _
    simp only [ramSum]
    rw [map_sum, Finset.sum_mul_sum]
    apply Finset.sum_congr rfl; intro r _
    apply Finset.sum_congr rfl; intro r' _
    rw [e_conj, e_add]
    congr 1
    push_cast; field_simp; ring
  rw [Finset.sum_congr rfl step1]
  have hswap : вИС n вИИ Finset.range N, вИС r вИИ Uq, вИС r' вИИ Uq',
        e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ))
      = вИС r вИИ Uq, вИС r' вИИ Uq', вИС n вИИ Finset.range N,
        e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ)) := by
    rw [Finset.sum_comm]; apply Finset.sum_congr rfl; intro r _; rw [Finset.sum_comm]
  rw [hswap]
  calc вАЦвИС r вИИ Uq, вИС r' вИИ Uq', вИС n вИИ Finset.range N,
          e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ))вАЦ
      вЙ§ вИС r вИИ Uq, вАЦвИС r' вИИ Uq', вИС n вИИ Finset.range N,
          e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ))вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС r вИИ Uq, вИС r' вИИ Uq', вАЦвИС n вИИ Finset.range N,
          e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ))вАЦ := by
        apply Finset.sum_le_sum; intro r _; exact norm_sum_le _ _
    _ вЙ§ вИС r вИИ Uq, вИС r' вИИ Uq',
          2 / вАЦe ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) / ((q * q' : вДХ) : вДЭ)) - 1вАЦ := by
        apply Finset.sum_le_sum; intro r hr
        apply Finset.sum_le_sum; intro r' hr'
        have hrc : Nat.gcd r q = 1 := (Finset.mem_filter.mp hr).2
        have hr'c : Nat.gcd r' q' = 1 := (Finset.mem_filter.mp hr').2
        have hќЄne : e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ)
                        / ((q * q' : вДХ) : вДЭ)) вЙ† 1 := by
          apply e_ne_one_of_not_int
          intro m hm
          have hDR : ((q * q' : вДХ) : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hmul.ne'
          rw [div_eq_iff hDR] at hm
          have hM : (r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) = m * ((q * q' : вДХ) : вД§) := by
            exact_mod_cast hm
          have hdvd : ((q * q' : вДХ) : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) :=
            вЯ®m, by rw [hM]; ringвЯ©
          have hqdvd_prod : (q : вД§) вИ£ ((q * q' : вДХ) : вД§) := вЯ®(q' : вД§), by push_cast; ringвЯ©
          have h1 : (q : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) := dvd_trans hqdvd_prod hdvd
          have h2 : (q : вД§) вИ£ (r : вД§) * (q' : вД§) := by
            have h3 := dvd_add h1 (dvd_mul_left (q : вД§) (r' : вД§))
            have he : (r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) + (r' : вД§) * (q : вД§)
                = (r : вД§) * (q' : вД§) := by ring
            rwa [he] at h3
          have hcopq : IsCoprime (q : вД§) (r : вД§) := by
            rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_natCast_natCast, Nat.gcd_comm]; exact hrc
          have hqq' : (q : вД§) вИ£ (q' : вД§) := hcopq.dvd_of_dvd_mul_left h2
          have hq'dvd_prod : (q' : вД§) вИ£ ((q * q' : вДХ) : вД§) := вЯ®(q : вД§), by push_cast; ringвЯ©
          have h1' : (q' : вД§) вИ£ ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§)) := dvd_trans hq'dvd_prod hdvd
          have h2' : (q' : вД§) вИ£ (r' : вД§) * (q : вД§) := by
            have h3 := dvd_sub (dvd_mul_left (q' : вД§) (r : вД§)) h1'
            have he : (r : вД§) * (q' : вД§) - ((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§))
                = (r' : вД§) * (q : вД§) := by ring
            rwa [he] at h3
          have hcopq' : IsCoprime (q' : вД§) (r' : вД§) := by
            rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_natCast_natCast, Nat.gcd_comm]; exact hr'c
          have hq'q : (q' : вД§) вИ£ (q : вД§) := hcopq'.dvd_of_dvd_mul_left h2'
          exact hne (Nat.dvd_antisymm (by exact_mod_cast hqq') (by exact_mod_cast hq'q))
        have hrw : вИА n : вДХ,
            e ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ) * (n : вДЭ) / ((q * q' : вДХ) : вДЭ))
              = e ((n : вДЭ) * ((((r : вД§) * (q' : вД§) - (r' : вД§) * (q : вД§) : вД§) : вДЭ)
                    / ((q * q' : вДХ) : вДЭ))) := by
          intro n; congr 1; ring
        rw [Finset.sum_congr rfl (fun n _ => hrw n)]
        exact sum_e_norm_le_geom _ N hќЄne

/-- `вАЦe ќЄ вИТ 1вАЦ¬≤ = 2 вИТ 2cos(2ѕАќЄ)` (`= 4 sin¬≤(ѕАќЄ)`). The magnitude of the additive-character
    displacement вАФ the analytic input to bounding the off-diagonal boundary term `вИС 2/вАЦe(ќЄ)вИТ1вАЦ`. -/
lemma norm_e_sub_one_sq (ќЄ : вДЭ) : вАЦe ќЄ - 1вАЦ ^ 2 = 2 - 2 * Real.cos (2 * Real.pi * ќЄ) := by
  have he : e ќЄ = Complex.exp (вЖС(2 * Real.pi * ќЄ) * Complex.I) := by
    rw [e]; congr 1; push_cast; ring
  have hre : (e ќЄ).re = Real.cos (2 * Real.pi * ќЄ) := by
    rw [he]; exact Complex.exp_ofReal_mul_I_re _
  have him : (e ќЄ).im = Real.sin (2 * Real.pi * ќЄ) := by
    rw [he]; exact Complex.exp_ofReal_mul_I_im _
  rw [вЖР Complex.normSq_eq_norm_sq, Complex.normSq_apply, Complex.sub_re, Complex.sub_im,
    Complex.one_re, Complex.one_im, hre, him]
  linear_combination Real.sin_sq_add_cos_sq (2 * Real.pi * ќЄ)

/-- `вАЦe ќЄ вИТ 1вАЦ = 2|sin(ѕАќЄ)|` вАФ the exact character-displacement magnitude. The off-diagonal
    boundary bound becomes `вИС 1/|sin(ѕА(rвИТr')/q)|`, a cosecant sum controlled by `|sin| вЙ• 2¬Јdist(¬Ј,вД§)`. -/
lemma norm_e_sub_one (ќЄ : вДЭ) : вАЦe ќЄ - 1вАЦ = 2 * |Real.sin (Real.pi * ќЄ)| := by
  have hcos : 2 - 2 * Real.cos (2 * Real.pi * ќЄ) = (2 * |Real.sin (Real.pi * ќЄ)|) ^ 2 := by
    rw [show 2 * Real.pi * ќЄ = 2 * (Real.pi * ќЄ) by ring, Real.cos_two_mul, mul_pow, sq_abs]
    linear_combination (-4 : вДЭ) * Real.sin_sq_add_cos_sq (Real.pi * ќЄ)
  have h2 : вАЦe ќЄ - 1вАЦ ^ 2 = (2 * |Real.sin (Real.pi * ќЄ)|) ^ 2 := by
    rw [norm_e_sub_one_sq, hcos]
  rw [вЖР Real.sqrt_sq (norm_nonneg (e ќЄ - 1)), h2, Real.sqrt_sq (by positivity)]

/-- **Jordan-type bound**: `2x вЙ§ sin(ѕАx)` for `x вИИ [0, 1/2]` (from Mathlib's `Real.mul_le_sin`).
    Converts `1/|sin(ѕА(rвИТr')/q)|` into the harmonic bound `q/(2¬Јmin(rвИТr', qвИТ(rвИТr')))` вАФ the seed
    of the `O(q log q)` cosecant boundary sum. -/
lemma two_mul_le_sin_pi_mul (x : вДЭ) (h0 : 0 вЙ§ x) (h1 : x вЙ§ 1 / 2) :
    2 * x вЙ§ Real.sin (Real.pi * x) := by
  have hpx : Real.pi * x вЙ§ Real.pi / 2 := by
    nlinarith [Real.pi_pos, mul_le_mul_of_nonneg_left h1 Real.pi_pos.le]
  have h := Real.mul_le_sin (x := Real.pi * x) (by positivity) hpx
  have heq : 2 / Real.pi * (Real.pi * x) = 2 * x := by field_simp
  rwa [heq] at h

/-- **Per-term cosecant lower bound**: `2¬Јmin(k,qвИТk)/q вЙ§ |sin(ѕАk/q)|` for `0 < k < q`. The
    `sin(ѕАвИТx)=sin x` symmetry folds the upper half `k > q/2` onto Jordan's inequality for `qвИТk`. -/
lemma sin_pi_ratio_lower (q k : вДХ) (hq : 0 < q) (hk : 0 < k) (hkq : k < q) :
    (2 : вДЭ) * (min k (q - k) : вДХ) / q вЙ§ |Real.sin (Real.pi * (k : вДЭ) / q)| := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  have helper : вИА j : вДХ, 2 * j вЙ§ q вЖТ (2 : вДЭ) * (j : вДЭ) / q вЙ§ Real.sin (Real.pi * (j : вДЭ) / q) := by
    intro j hj2
    have hjR : 2 * (j : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hj2
    have hx : (j : вДЭ) / q вЙ§ 1 / 2 := by rw [div_le_div_iffвВА hqR (by norm_num)]; nlinarith [hjR]
    have hjb := two_mul_le_sin_pi_mul ((j : вДЭ) / q) (by positivity) hx
    calc (2 : вДЭ) * (j : вДЭ) / q = 2 * ((j : вДЭ) / q) := by ring
      _ вЙ§ Real.sin (Real.pi * ((j : вДЭ) / q)) := hjb
      _ = Real.sin (Real.pi * (j : вДЭ) / q) := by rw [mul_div_assoc]
  by_cases hcase : 2 * k вЙ§ q
  ¬Ј have hmin : min k (q - k) = k := by omega
    have hkb := helper k hcase
    rw [hmin, abs_of_nonneg (le_trans (by positivity) hkb)]
    exact hkb
  ¬Ј have hc2 : q < 2 * k := Nat.lt_of_not_le hcase
    have hle : k вЙ§ q := le_of_lt hkq
    have hqk2 : 2 * (q - k) вЙ§ q := by omega
    have hmin : min k (q - k) = q - k := by omega
    have hjb := helper (q - k) hqk2
    have hsub : Real.sin (Real.pi * ((q - k : вДХ) : вДЭ) / q) = Real.sin (Real.pi * (k : вДЭ) / q) := by
      have heq : Real.pi * ((q - k : вДХ) : вДЭ) / q = Real.pi - Real.pi * (k : вДЭ) / q := by
        rw [Nat.cast_sub hle]; field_simp
      rw [heq, Real.sin_pi_sub]
    rw [hmin]
    rw [hsub] at hjb
    rw [abs_of_nonneg (le_trans (by positivity) hjb)]
    exact hjb

/-- Boundary term in cosecant form: `2/вАЦe ќЄ вИТ 1вАЦ = 1/|sin(ѕАќЄ)|` (both `0` when `sin ѕАќЄ = 0`). With
    `sin_pi_ratio_lower` this bounds each boundary summand by `q/(2¬Јmin(rвИТr',qвИТ(rвИТr')))`. -/
lemma two_div_norm_e_sub_one (ќЄ : вДЭ) : 2 / вАЦe ќЄ - 1вАЦ = 1 / |Real.sin (Real.pi * ќЄ)| := by
  rw [norm_e_sub_one]
  by_cases h : Real.sin (Real.pi * ќЄ) = 0
  ¬Ј rw [h]; simp
  ¬Ј have hne : |Real.sin (Real.pi * ќЄ)| вЙ† 0 := abs_ne_zero.mpr h
    rw [mul_comm]; field_simp

/-- **Per-pair boundary bound**: `2/вАЦe((rвИТr')/q)вИТ1вАЦ вЙ§ q/(2¬Јmin(d,qвИТd))`, `d = |rвИТr'|`. Combines the
    cosecant form with the Jordan-based `sin_pi_ratio_lower`; the signed `rвИТr'` reduces via `|sin|`
    evenness. Each interval-boundary summand is thus at most `q/(2¬Јmin)`. -/
lemma boundary_summand_bound (q r r' : вДХ) (hq : 0 < q) (hr : r < q) (hr' : r' < q) (hne : r вЙ† r') :
    2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ
      вЙ§ (q : вДЭ) / (2 * (min (max r r' - min r r') (q - (max r r' - min r r')) : вДХ)) := by
  set d := max r r' - min r r' with hd
  have hd0 : 0 < d := by omega
  have hdq : d < q := by omega
  have hqR : (0 : вДЭ) < q := by exact_mod_cast hq
  have hminpos : 0 < min d (q - d) := by omega
  have habs : |Real.sin (Real.pi * (((r : вД§) - (r' : вД§) : вД§) : вДЭ) / q)|
      = |Real.sin (Real.pi * (d : вДЭ) / q)| := by
    rcases Nat.le_total r' r with h | h
    ¬Ј have he : (((r : вД§) - (r' : вД§) : вД§) : вДЭ) = (d : вДЭ) := by
        rw [hd, max_eq_left h, min_eq_right h, Nat.cast_sub h]; push_cast; ring
      rw [he]
    ¬Ј rcases eq_or_lt_of_le h with heq | hlt
      ¬Ј exact absurd heq hne
      ¬Ј have he : (((r : вД§) - (r' : вД§) : вД§) : вДЭ) = -(d : вДЭ) := by
          rw [hd, max_eq_right (le_of_lt hlt), min_eq_left (le_of_lt hlt), Nat.cast_sub (le_of_lt hlt)]
          push_cast; ring
        rw [he, show Real.pi * (-(d : вДЭ)) / q = -(Real.pi * (d : вДЭ) / q) by ring,
          Real.sin_neg, abs_neg]
  have hlow := sin_pi_ratio_lower q d hq hd0 hdq
  rw [two_div_norm_e_sub_one, вЖР mul_div_assoc, habs]
  have hspos : (0 : вДЭ) < 2 * ((min d (q - d) : вДХ) : вДЭ) / q := by
    have : (0 : вДЭ) < ((min d (q - d) : вДХ) : вДЭ) := by exact_mod_cast hminpos
    positivity
  have hsinpos : 0 < |Real.sin (Real.pi * (d : вДЭ) / q)| := lt_of_lt_of_le hspos hlow
  rw [div_le_div_iffвВА hsinpos (by positivity)]
  have h2 : 2 * ((min d (q - d) : вДХ) : вДЭ) вЙ§ |Real.sin (Real.pi * (d : вДЭ) / q)| * q :=
    (div_le_iffвВА hqR).mp hlow
  nlinarith [h2]

/-- `вИС_{k=1}^{q-1} 1/min(k,qвИТk) вЙ§ 2¬ЈвИС_{k=1}^{q-1} 1/k` вАФ termwise `1/min(a,b) вЙ§ 1/a+1/b`, then the
    reflection `k вЖ¶ qвИТk` folds `вИС 1/(qвИТk)` back to `вИС 1/k`. With `harmonic_le_one_add_log` this
    gives the `O(log q)` needed to keep the cosecant boundary at `O(q¬≤ log q)` (summable vs coeffs). -/
lemma min_sum_le (q : вДХ) (hq : 2 вЙ§ q) :
    вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min k (q - k) : вДХ) : вДЭ)
      вЙ§ 2 * вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ) := by
  have hterm : вИА k вИИ Finset.Icc 1 (q - 1),
      (1 : вДЭ) / ((min k (q - k) : вДХ) : вДЭ) вЙ§ (1 : вДЭ) / (k : вДЭ) + (1 : вДЭ) / ((q - k : вДХ) : вДЭ) := by
    intro k hk
    rw [Finset.mem_Icc] at hk
    rcases le_total k (q - k) with h | h
    ¬Ј rw [min_eq_left h]; have : (0 : вДЭ) вЙ§ 1 / ((q - k : вДХ) : вДЭ) := by positivity
      linarith
    ¬Ј rw [min_eq_right h]; have : (0 : вДЭ) вЙ§ 1 / (k : вДЭ) := by positivity
      linarith
  have hreflect : вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((q - k : вДХ) : вДЭ)
      = вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ) := by
    refine Finset.sum_nbij' (fun k => q - k) (fun k => q - k) ?_ ?_ ?_ ?_ ?_ <;>
      intro k hk <;> simp only [Finset.mem_Icc] at hk вКҐ <;> first | omega | rfl
  calc вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min k (q - k) : вДХ) : вДЭ)
      вЙ§ вИС k вИИ Finset.Icc 1 (q - 1), ((1 : вДЭ) / (k : вДЭ) + (1 : вДЭ) / ((q - k : вДХ) : вДЭ)) :=
        Finset.sum_le_sum hterm
    _ = (вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ))
        + вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((q - k : вДХ) : вДЭ) := Finset.sum_add_distrib
    _ = 2 * вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ) := by rw [hreflect]; ring

/-- `вИС_{k=1}^{q-1} 1/min(k,qвИТk) вЙ§ 2(1 + log q)` вАФ `min_sum_le` chained with `harmonic_eq_sum_Icc`
    and `harmonic_le_one_add_log`. The explicit `O(log q)` bound on the per-modulus cosecant sum. -/
lemma min_sum_le_log (q : вДХ) (hq : 2 вЙ§ q) :
    вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min k (q - k) : вДХ) : вДЭ) вЙ§ 2 * (1 + Real.log q) := by
  have hharm : вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ) = ((harmonic (q - 1) : вДЪ) : вДЭ) := by
    rw [harmonic_eq_sum_Icc]
    push_cast
    apply Finset.sum_congr rfl; intro k _; rw [one_div]
  have hlog := harmonic_le_one_add_log (q - 1)
  have hq1 : (0 : вДЭ) < ((q - 1 : вДХ) : вДЭ) := by
    have : 1 вЙ§ q - 1 := by omega
    exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_one this
  have hlogq : Real.log ((q - 1 : вДХ) : вДЭ) вЙ§ Real.log (q : вДЭ) := by
    apply Real.log_le_log hq1
    have : q - 1 вЙ§ q := by omega
    exact_mod_cast this
  calc вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min k (q - k) : вДХ) : вДЭ)
      вЙ§ 2 * вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / (k : вДЭ) := min_sum_le q hq
    _ = 2 * ((harmonic (q - 1) : вДЪ) : вДЭ) := by rw [hharm]
    _ вЙ§ 2 * (1 + Real.log ((q - 1 : вДХ) : вДЭ)) := by linarith [hlog]
    _ вЙ§ 2 * (1 + Real.log (q : вДЭ)) := by linarith [hlogq]

/-- **EraseвЖТmin-sum bijection**: `вИС_{r'вИИ(range q)\{r}} 1/min(|rвИТr'|,qвИТ|rвИТr'|) = вИС_{m=1}^{q-1} 1/min(m,qвИТm)`
    via the circular representative `r' вЖ¶ (rвИТr' mod q)` (`min(|rвИТr'|,qвИТ|rвИТr'|)=min(m,qвИТm)`, a clean
    bijection with NO multiplicity). Lets the per-`r` boundary sum inherit `min_sum_le_log`. -/
lemma erase_min_sum (q r : вДХ) (hq2 : 2 вЙ§ q) (hr : r < q) :
    вИС r' вИИ (Finset.range q).erase r,
        (1 : вДЭ) / ((min (max r r' - min r r') (q - (max r r' - min r r')) : вДХ) : вДЭ)
      = вИС m вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min m (q - m) : вДХ) : вДЭ) := by
  refine Finset.sum_nbij' (fun r' => if r' вЙ§ r then r - r' else q - (r' - r))
    (fun m => if m вЙ§ r then r - m else r + q - m) ?_ ?_ ?_ ?_ ?_
  ¬Ј intro r' hr'; simp only [Finset.mem_erase, Finset.mem_range] at hr'
    simp only [Finset.mem_Icc]; split_ifs with h <;> omega
  ¬Ј intro m hm; simp only [Finset.mem_Icc] at hm
    simp only [Finset.mem_erase, Finset.mem_range]; split_ifs with h <;> omega
  ¬Ј intro r' hr'; simp only [Finset.mem_erase, Finset.mem_range] at hr'; split_ifs <;> omega
  ¬Ј intro m hm; simp only [Finset.mem_Icc] at hm; split_ifs <;> omega
  ¬Ј intro r' hr'; simp only [Finset.mem_erase, Finset.mem_range] at hr'
    have h : min (max r r' - min r r') (q - (max r r' - min r r'))
        = min (if r' вЙ§ r then r - r' else q - (r' - r))
            (q - (if r' вЙ§ r then r - r' else q - (r' - r))) := by
      split_ifs <;> omega
    rw [h]

/-- **Per-`r` boundary bound**: `вИС_{r'вИИU_q\{r}} 2/вАЦe((rвИТr')/q)вИТ1вАЦ вЙ§ q(1+log q)`. Chains
    `boundary_summand_bound` (per term `вЙ§ q/(2¬Јmin)`) вЖТ superset `U_q вКЖ range q` вЖТ `erase_min_sum`
    вЖТ `min_sum_le_log`. The inner sum of the interval boundary. -/
lemma erase_boundary_le (q r : вДХ) (hq2 : 2 вЙ§ q) (hr : r < q) :
    вИС r' вИИ ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).erase r,
        2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ
      вЙ§ (q : вДЭ) * (1 + Real.log q) := by
  have hq0 : 0 < q := by omega
  set U := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hU
  set g : вДХ вЖТ вДЭ := fun r' => (q : вДЭ) / (2 * ((min (max r r' - min r r')
    (q - (max r r' - min r r')) : вДХ) : вДЭ)) with hg
  calc вИС r' вИИ U.erase r, 2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ
      вЙ§ вИС r' вИИ U.erase r, g r' := by
        apply Finset.sum_le_sum; intro r' hr'
        have hr'q : r' < q :=
          Finset.mem_range.mp (Finset.mem_filter.mp (Finset.mem_of_mem_erase hr')).1
        have hne : r вЙ† r' := (Finset.ne_of_mem_erase hr').symm
        exact boundary_summand_bound q r r' hq0 hr hr'q hne
    _ вЙ§ вИС r' вИИ (Finset.range q).erase r, g r' := by
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј exact Finset.erase_subset_erase r (Finset.filter_subset _ _)
        ¬Ј intro r' _ _; rw [hg]; positivity
    _ = (q : вДЭ) / 2 * вИС r' вИИ (Finset.range q).erase r,
          (1 : вДЭ) / ((min (max r r' - min r r') (q - (max r r' - min r r')) : вДХ) : вДЭ) := by
        rw [Finset.mul_sum]; apply Finset.sum_congr rfl; intro r' _; rw [hg]; ring
    _ = (q : вДЭ) / 2 * вИС m вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / ((min m (q - m) : вДХ) : вДЭ) := by
        rw [erase_min_sum q r hq2 hr]
    _ вЙ§ (q : вДЭ) * (1 + Real.log q) := by
        have hml := min_sum_le_log q hq2
        have hqh : (0 : вДЭ) вЙ§ (q : вДЭ) / 2 := by positivity
        nlinarith [mul_le_mul_of_nonneg_left hml hqh]

end MajorArcMainTerm

