open DirichletCharacter Complex

/-- `LFunctionTrivChar N ѕГ вЙ† 0` for real `ѕГ > 1` (it equals `LSeries вЖЧ1 ѕГ`, nonzero on `Re>1`). -/
lemma LFunctionTrivChar_ne_zero_of_one_lt {N : вДХ} [NeZero N] {ѕГ : вДЭ} (hѕГ : 1 < ѕГ) :
    LFunctionTrivChar N (ѕГ : вДВ) вЙ† 0 := by
  have hs : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ
  rw [show LFunctionTrivChar N (ѕГ : вДВ) = (1 : DirichletCharacter вДВ N).LFunction (ѕГ : вДВ) from rfl,
    DirichletCharacter.LFunction_eq_LSeries _ hs]
  exact LSeries_ne_zero_of_one_lt_re _ hs

/-- `g = -logDeriv (LFunctionTrivCharвВБ N)` is bounded on the real interval `[1,2]` (continuous
    on a compact set). -/
lemma g_bounded (N : вДХ) [NeZero N] : вИГ K : вДЭ, вИА ѕГ : вДЭ, 1 вЙ§ ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
    вАЦ-deriv (LFunctionTrivCharвВБ N) (ѕГ : вДВ) / LFunctionTrivCharвВБ N (ѕГ : вДВ)вАЦ вЙ§ K := by
  have hcont := continuousOn_neg_logDeriv_LFunctionTrivCharвВБ N
  set S : Set вДВ := (fun ѕГ : вДЭ => (ѕГ : вДВ)) '' Set.Icc 1 2 with hS
  have hcompact : IsCompact S := (isCompact_Icc).image (by fun_prop)
  have hsub : S вКЖ {s | s = 1 вИ® LFunctionTrivChar N s вЙ† 0} := by
    rintro s вЯ®ѕГ, hѕГ, rflвЯ©
    rcases eq_or_lt_of_le hѕГ.1 with h1 | h1
    ¬Ј left; rw [вЖР h1]; norm_num
    ¬Ј exact Or.inr (LFunctionTrivChar_ne_zero_of_one_lt h1)
  obtain вЯ®K, hKвЯ© := hcompact.exists_bound_of_continuousOn (hcont.mono hsub)
  exact вЯ®K, fun ѕГ h1 h2 => hK _ вЯ®ѕГ, вЯ®h1, h2вЯ©, rflвЯ©вЯ©

open scoped LSeries.notation ArithmeticFunction in
/-- The identity: for ѕГ>1, `L(ѕЗвБ∞ќЫ,ѕГ) = 1/(ѕГ-1) + g(ѕГ)` with `g = -logDeriv(LFunctionTrivCharвВБ)`. -/
lemma twist_eq_pole_plus_g {N : вДХ} [NeZero N] {ѕГ : вДЭ} (hѕГ : 1 < ѕГ) :
    LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)
      = 1 / ((ѕГ : вДВ) - 1)
        + (-deriv (LFunctionTrivCharвВБ N) (ѕГ : вДВ) / LFunctionTrivCharвВБ N (ѕГ : вДВ)) := by
  have hs : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ
  have hs1 : (ѕГ : вДВ) вЙ† 1 := by exact_mod_cast ne_of_gt hѕГ
  have hs1' : (ѕГ : вДВ) - 1 вЙ† 0 := sub_ne_zero_of_ne hs1
  have hLne : LFunctionTrivChar N (ѕГ : вДВ) вЙ† 0 := LFunctionTrivChar_ne_zero_of_one_lt hѕГ
  have htwist : LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)
      = -deriv (LFunctionTrivChar N) (ѕГ : вДВ) / LFunctionTrivChar N (ѕГ : вДВ) := by
    rw [DirichletCharacter.LSeries_twist_vonMangoldt_eq _ hs,
      вЖР DirichletCharacter.deriv_LFunction_eq_deriv_LSeries _ hs,
      вЖР DirichletCharacter.LFunction_eq_LSeries _ hs]
  rw [htwist]
  have hup : LFunctionTrivCharвВБ N (ѕГ : вДВ) = ((ѕГ : вДВ) - 1) * LFunctionTrivChar N (ѕГ : вДВ) := by
    rw [LFunctionTrivCharвВБ, Function.update_of_ne hs1]
  have hd : deriv (LFunctionTrivCharвВБ N) (ѕГ : вДВ)
      = ((ѕГ : вДВ) - 1) * deriv (LFunctionTrivChar N) (ѕГ : вДВ) + LFunctionTrivChar N (ѕГ : вДВ) :=
    deriv_LFunctionTrivCharвВБ_apply_of_ne_one N hs1
  rw [hup, hd]; field_simp; ring

open scoped LSeries.notation ArithmeticFunction in
/-- **THE POLE BOUND** (raw input for 1d): `Re L(ѕЗвБ∞ќЫ,ѕГ) вЙ§ 1/(ѕГ-1) + K` for ѕГ вИИ (1,2]. -/
lemma pole_bound (N : вДХ) [NeZero N] : вИГ K : вДЭ, вИА ѕГ : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
    (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re вЙ§ 1 / (ѕГ - 1) + K := by
  obtain вЯ®K, hKвЯ© := g_bounded N
  refine вЯ®K, fun ѕГ hѕГ1 hѕГ2 => ?_вЯ©
  rw [twist_eq_pole_plus_g hѕГ1, Complex.add_re]
  have h1 : (1 / ((ѕГ : вДВ) - 1)).re = 1 / (ѕГ - 1) := by
    rw [show ((ѕГ : вДВ) - 1) = (((ѕГ - 1 : вДЭ)) : вДВ) by push_cast; ring, вЖР Complex.ofReal_one,
      вЖР Complex.ofReal_div]
    exact Complex.ofReal_re _
  rw [h1]
  have h2 : (-deriv (LFunctionTrivCharвВБ N) (ѕГ : вДВ) / LFunctionTrivCharвВБ N (ѕГ : вДВ)).re вЙ§ K :=
    le_trans (Complex.re_le_norm _) (hK ѕГ (le_of_lt hѕГ1) hѕГ2)
  linarith

open scoped LSeries.notation ArithmeticFunction in
/-- **THE GROWTH BOUND** (raw input #3, nontrivial ѕЗ¬≤): for `ѕИ = ѕЗ¬≤ вЙ† 1` and fixed ќ≥,
    `Re L(ѕИќЫ, ѕГ+2iќ≥) вЙ§ K` on ѕГ вИИ (1,2] вАФ `L(ѕИ)` entire + nonzero on ReвЙ•1, neg-log-deriv
    bounded on the compact segment. -/
lemma growth_bound_nontriv {N : вДХ} [NeZero N] (ѕИ : DirichletCharacter вДВ N) (hѕИ : ѕИ вЙ† 1) (ќ≥ : вДЭ) :
    вИГ K : вДЭ, вИА ѕГ : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
      (LSeries (вЖЧѕИ * вЖЧќЫ) ((ѕГ : вДВ) + 2 * ќ≥ * I)).re вЙ§ K := by
  have hcont := continuousOn_neg_logDeriv_LFunction_of_nontriv hѕИ
  set S : Set вДВ := (fun ѕГ : вДЭ => (ѕГ : вДВ) + 2 * ќ≥ * I) '' Set.Icc 1 2 with hS
  have hcompact : IsCompact S := isCompact_Icc.image (by fun_prop)
  have hre : вИА ѕГ : вДЭ, ((ѕГ : вДВ) + 2 * ќ≥ * I).re = ѕГ := by
    intro ѕГ; simp [Complex.add_re, Complex.mul_re, Complex.mul_im]
  have hsub : S вКЖ {s | LFunction ѕИ s вЙ† 0} := by
    rintro s вЯ®ѕГ, hѕГ, rflвЯ©
    simp only [Set.mem_setOf_eq]
    rcases eq_or_lt_of_le hѕГ.1 with h1 | h1
    ¬Ј apply DirichletCharacter.LFunction_ne_zero_of_re_eq_one <;>
        first
        | (rw [hre]; linarith)
        | exact Or.inl hѕИ
    ¬Ј have hs : 1 < ((ѕГ : вДВ) + 2 * ќ≥ * I).re := by rw [hre]; exact h1
      rw [DirichletCharacter.LFunction_eq_LSeries _ hs]
      exact LSeries_ne_zero_of_one_lt_re _ hs
  obtain вЯ®K, hKвЯ© := hcompact.exists_bound_of_continuousOn (hcont.mono hsub)
  refine вЯ®K, fun ѕГ hѕГ1 hѕГ2 => ?_вЯ©
  have hs : 1 < ((ѕГ : вДВ) + 2 * ќ≥ * I).re := by rw [hre]; exact hѕГ1
  have hid : LSeries (вЖЧѕИ * вЖЧќЫ) ((ѕГ : вДВ) + 2 * ќ≥ * I)
      = -deriv (LFunction ѕИ) ((ѕГ : вДВ) + 2 * ќ≥ * I) / LFunction ѕИ ((ѕГ : вДВ) + 2 * ќ≥ * I) := by
    rw [DirichletCharacter.LSeries_twist_vonMangoldt_eq _ hs,
      вЖР DirichletCharacter.deriv_LFunction_eq_deriv_LSeries _ hs,
      вЖР DirichletCharacter.LFunction_eq_LSeries _ hs]
  rw [hid]
  exact le_trans (Complex.re_le_norm _) (hK _ вЯ®ѕГ, вЯ®le_of_lt hѕГ1, hѕГ2вЯ©, rflвЯ©)

open scoped LSeries.notation ArithmeticFunction in
/-- **THE ZERO BOUND (fixed ѕЗ, ќ≥)** вАФ the last raw input of the zero-free-region chain:
    a zero `ѕБ = ќ≤ + iќ≥` of `L(¬Ј,ѕЗ)` pulls the twisted log-derivative down by `1/(ѕГвИТќ≤)`.
    Pure compactness вАФ the pole-removed `вИТL'/L + 1/(sвИТѕБ)` is continuous on the segment
    `[1,2] + iќ≥` (no zeros there), hence bounded; no Hadamard product needed at fixed ќ≥. -/
lemma zero_bound_fixed {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (ќ≥ ќ≤ : вДЭ) (hќ≤1 : ќ≤ < 1) (hzero : LFunction ѕЗ ((ќ≤ : вДВ) + ќ≥ * I) = 0) :
    вИГ K : вДЭ, вИА ѕГ : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
      (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * I)).re вЙ§ K - 1 / (ѕГ - ќ≤) := by
  set ѕБ : вДВ := (ќ≤ : вДВ) + ќ≥ * I with hѕБ
  set F : вДВ вЖТ вДВ := fun s => -deriv (LFunction ѕЗ) s / LFunction ѕЗ s + 1 / (s - ѕБ) with hF
  set Sg : Set вДВ := (fun ѕГ : вДЭ => (ѕГ : вДВ) + ќ≥ * I) '' Set.Icc 1 2 with hSg
  have hre : вИА ѕГ : вДЭ, ((ѕГ : вДВ) + ќ≥ * I).re = ѕГ := by
    intro ѕГ
    simp [Complex.add_re, Complex.mul_re, Complex.mul_im]
  have hLne : вИА s вИИ Sg, LFunction ѕЗ s вЙ† 0 := by
    rintro s вЯ®ѕГ, hѕГ, rflвЯ©
    rcases eq_or_lt_of_le hѕГ.1 with h1 | h1
    ¬Ј apply DirichletCharacter.LFunction_ne_zero_of_re_eq_one <;>
        first
        | (rw [hre]; linarith)
        | exact Or.inl hѕЗ
    ¬Ј have hs : 1 < ((ѕГ : вДВ) + ќ≥ * I).re := by rw [hre]; exact h1
      rw [DirichletCharacter.LFunction_eq_LSeries _ hs]
      exact LSeries_ne_zero_of_one_lt_re _ hs
  have hsne : вИА s вИИ Sg, s - ѕБ вЙ† 0 := by
    rintro s вЯ®ѕГ, hѕГ, rflвЯ©
    intro hc
    rw [sub_eq_zero] at hc
    have hѕГќ≤ : ѕГ = ќ≤ := by
      have := congrArg Complex.re hc
      rw [hre] at this
      rw [hѕБ] at this
      simpa [Complex.add_re, Complex.mul_re, Complex.mul_im] using this
    linarith [hѕГ.1]
  have hcont : ContinuousOn F Sg := by
    rw [hF]
    apply ContinuousOn.add
    ¬Ј exact (continuousOn_neg_logDeriv_LFunction_of_nontriv hѕЗ).mono
        (fun s hs => hLne s hs)
    ¬Ј apply ContinuousOn.div continuousOn_const (by fun_prop)
      exact hsne
  have hcompact : IsCompact Sg := isCompact_Icc.image (by fun_prop)
  obtain вЯ®K, hKвЯ© := hcompact.exists_bound_of_continuousOn hcont
  refine вЯ®K, fun ѕГ hѕГ1 hѕГ2 => ?_вЯ©
  have hs : 1 < ((ѕГ : вДВ) + ќ≥ * I).re := by rw [hre]; exact hѕГ1
  have hmem : ((ѕГ : вДВ) + ќ≥ * I) вИИ Sg := вЯ®ѕГ, вЯ®le_of_lt hѕГ1, hѕГ2вЯ©, rflвЯ©
  have hid : LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * I)
      = F ((ѕГ : вДВ) + ќ≥ * I) - 1 / (((ѕГ : вДВ) + ќ≥ * I) - ѕБ) := by
    rw [hF]
    dsimp only
    rw [DirichletCharacter.LSeries_twist_vonMangoldt_eq _ hs,
      вЖР DirichletCharacter.deriv_LFunction_eq_deriv_LSeries _ hs,
      вЖР DirichletCharacter.LFunction_eq_LSeries _ hs]
    ring
  rw [hid]
  have hreal : (((ѕГ : вДВ) + ќ≥ * I) - ѕБ) = ((ѕГ - ќ≤ : вДЭ) : вДВ) := by
    rw [hѕБ]
    push_cast
    ring
  have hre1 : (1 / (((ѕГ : вДВ) + ќ≥ * I) - ѕБ)).re = 1 / (ѕГ - ќ≤) := by
    rw [hreal, show (1 : вДВ) / ((ѕГ - ќ≤ : вДЭ) : вДВ) = (((1 / (ѕГ - ќ≤) : вДЭ)) : вДВ) by
      push_cast; ring]
    exact Complex.ofReal_re _
  rw [Complex.sub_re, hre1]
  have hFK : (F ((ѕГ : вДВ) + ќ≥ * I)).re вЙ§ K :=
    le_trans (Complex.re_le_norm _) (hK _ hmem)
  linarith

open ArithmeticFunction Complex in
open scoped LSeries.notation ArithmeticFunction in
/-- **THE UNIFORM POLE BOUND вАФ first brick of the SiegelвАУWalfisz uniformity layer**:
    a SINGLE constant works for every modulus, because the trivial-character twisted
    series has nonneg coefficients dominated termwise by the full `вИТќґ'/ќґ` (`N = 1`).
    No Hadamard needed for `AвВА`'s uniformity. -/
theorem pole_bound_uniform : вИГ K : вДЭ, вИА (N : вДХ) [NeZero N], вИА ѕГ : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
    (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re вЙ§ 1 / (ѕГ - 1) + K := by
  obtain вЯ®K, hKвЯ© := pole_bound 1
  refine вЯ®K, fun N _ ѕГ hѕГ1 hѕГ2 => ?_вЯ©
  have hѕГre : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ1
  have hsumќЫ : LSeriesSummable (вЖЧќЫ) (ѕГ : вДВ) :=
    ArithmeticFunction.LSeriesSummable_vonMangoldt hѕГre
  have hsumN : LSeriesSummable (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ) :=
    DirichletCharacter.LSeriesSummable_mul _ hsumќЫ
  have hsum1 : LSeriesSummable (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) :=
    DirichletCharacter.LSeriesSummable_mul _ hsumќЫ
  -- per-term real parts
  have hterm : вИА (M : вДХ) [NeZero M], вИА n : вДХ,
      (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ M) * вЖЧќЫ) (ѕГ : вДВ) n).re
      = if n = 0 then 0
        else (if IsUnit ((n : ZMod M)) then ќЫ n / (n : вДЭ) ^ ѕГ else 0) := by
    intro M _ n
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј rw [if_pos rfl]
      simp [LSeries.term]
    have hne : n вЙ† 0 := hn0.ne'
    rw [LSeries.term_of_ne_zero hne, if_neg hne]
    have hpow : ((n : вДВ)) ^ ((ѕГ : вДВ)) = (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ) := by
      rw [show ((n : вДВ)) = (((n : вДЭ)) : вДВ) by push_cast; rfl,
        Complex.ofReal_cpow (Nat.cast_nonneg n)]
    have happ : (вЖЧ(1 : DirichletCharacter вДВ M) * вЖЧќЫ) n
        = (if IsUnit ((n : ZMod M)) then ((ќЫ n : вДЭ) : вДВ) else 0) := by
      show (1 : DirichletCharacter вДВ M) (n : ZMod M) * ((ќЫ n : вДЭ) : вДВ) = _
      by_cases h : IsUnit ((n : ZMod M))
      ¬Ј simp [MulChar.one_apply, h]
      ¬Ј simp [MulChar.map_nonunit _ h, h]
    rw [happ]
    by_cases h : IsUnit ((n : ZMod M))
    ¬Ј rw [if_pos h, if_pos h, hpow]
      rw [show (((ќЫ n : вДЭ)) : вДВ) / (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ)
          = (((ќЫ n / (n : вДЭ) ^ ѕГ : вДЭ)) : вДВ) by push_cast; ring]
      exact Complex.ofReal_re _
    ¬Ј rw [if_neg h, if_neg h, zero_div]
      simp
  -- compare the real tsums
  have hreN : (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re
      = вИС' n, (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ) n).re :=
    ((Complex.hasSum_re hsumN.hasSum).tsum_eq).symm
  have hre1 : (LSeries (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ)).re
      = вИС' n, (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) n).re :=
    ((Complex.hasSum_re hsum1.hasSum).tsum_eq).symm
  have hcomp : (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re
      вЙ§ (LSeries (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ)).re := by
    rw [hreN, hre1]
    have hsumNre : Summable (fun n => (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ) n).re) :=
      (Complex.hasSum_re hsumN.hasSum).summable
    have hsum1re : Summable (fun n => (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) n).re) :=
      (Complex.hasSum_re hsum1.hasSum).summable
    apply Summable.tsum_mono hsumNre hsum1re
    intro n
    dsimp only
    rw [hterm N n, hterm 1 n]
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј simp
    rw [if_neg hn0.ne', if_neg hn0.ne']
    have hden : (0:вДЭ) < (n : вДЭ) ^ ѕГ := by
      apply Real.rpow_pos_of_pos
      exact_mod_cast hn0
    have hќЫnn : 0 вЙ§ ќЫ n / (n : вДЭ) ^ ѕГ :=
      div_nonneg ArithmeticFunction.vonMangoldt_nonneg hden.le
    have hu1 : IsUnit ((n : ZMod 1)) := isUnit_of_subsingleton _
    rw [if_pos hu1]
    by_cases h : IsUnit ((n : ZMod N))
    ¬Ј rw [if_pos h]
    ¬Ј rw [if_neg h]
      exact hќЫnn
  calc (LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)).re
      вЙ§ (LSeries (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ)).re := hcomp
    _ вЙ§ 1 / (ѕГ - 1) + K := hK ѕГ hѕГ1 hѕГ2

open ArithmeticFunction Complex in
open scoped LSeries.notation ArithmeticFunction in
/-- **The uniform trivial twist bound**: for EVERY modulus, character, and height,
    `Re L(ѕЗќЫ, ѕГ+it) вЙ§ 1/(ѕГвИТ1) + K` with ONE constant вАФ termwise `Re вЙ§ вАЦ¬ЈвАЦ вЙ§ ќЫ(n)/n^ѕГ`.
    The crude-but-uniform input the classical ѕГ = 1 + c/log(q(t+2)) argument quotes
    wherever the Hadamard log-bound is not needed. -/
theorem twist_re_le_uniform : вИГ K : вДЭ, вИА (N : вДХ) [NeZero N],
    вИА (ѕЗ : DirichletCharacter вДВ N), вИА t ѕГ : вДЭ, 1 < ѕГ вЖТ ѕГ вЙ§ 2 вЖТ
    (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + t * I)).re вЙ§ 1 / (ѕГ - 1) + K := by
  obtain вЯ®K, hKвЯ© := pole_bound 1
  refine вЯ®K, fun N _ ѕЗ t ѕГ hѕГ1 hѕГ2 => ?_вЯ©
  set s : вДВ := (ѕГ : вДВ) + t * I with hs
  have hsre : s.re = ѕГ := by
    rw [hs]
    simp
  have hѕГre : 1 < s.re := by rw [hsre]; exact hѕГ1
  have hsumќЫ : LSeriesSummable (вЖЧќЫ) s :=
    ArithmeticFunction.LSeriesSummable_vonMangoldt hѕГre
  have hsumѕЗ : LSeriesSummable (вЖЧѕЗ * вЖЧќЫ) s :=
    DirichletCharacter.LSeriesSummable_mul _ hsumќЫ
  have hѕГre1 : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ1
  have hsumќЫѕГ : LSeriesSummable (вЖЧќЫ) (ѕГ : вДВ) :=
    ArithmeticFunction.LSeriesSummable_vonMangoldt hѕГre1
  have hsum1 : LSeriesSummable (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) :=
    DirichletCharacter.LSeriesSummable_mul _ hsumќЫѕГ
  -- termwise: Re вЙ§ вАЦ¬ЈвАЦ вЙ§ the N=1 real term
  have hpt : вИА n : вДХ, (LSeries.term (вЖЧѕЗ * вЖЧќЫ) s n).re
      вЙ§ (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) n).re := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј rw [LSeries.term_zero, LSeries.term_zero]
    have hne : n вЙ† 0 := hn0.ne'
    rw [LSeries.term_of_ne_zero hne, LSeries.term_of_ne_zero hne]
    have hnormpow : вАЦ((n : вДВ)) ^ sвАЦ = (n : вДЭ) ^ ѕГ := by
      rw [Complex.norm_natCast_cpow_of_pos hn0, hsre]
    have hpow1 : ((n : вДВ)) ^ ((ѕГ : вДВ)) = (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ) := by
      rw [show ((n : вДВ)) = (((n : вДЭ)) : вДВ) by push_cast; rfl,
        Complex.ofReal_cpow (Nat.cast_nonneg n)]
    have h1app : (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) n = ((ќЫ n : вДЭ) : вДВ) := by
      show (1 : DirichletCharacter вДВ 1) (n : ZMod 1) * ((ќЫ n : вДЭ) : вДВ) = _
      have h1 : ((n : ZMod 1)) = 1 := Subsingleton.elim _ _
      rw [h1, MulChar.map_one, one_mul]
    calc (((вЖЧѕЗ * вЖЧќЫ) n) / ((n : вДВ)) ^ s).re
        вЙ§ вАЦ(((вЖЧѕЗ * вЖЧќЫ) n) / ((n : вДВ)) ^ s)вАЦ := Complex.re_le_norm _
      _ = вАЦ(вЖЧѕЗ * вЖЧќЫ) nвАЦ / (n : вДЭ) ^ ѕГ := by rw [norm_div, hnormpow]
      _ вЙ§ ќЫ n / (n : вДЭ) ^ ѕГ := by
          apply div_le_div_of_nonneg_right _
            (Real.rpow_pos_of_pos (show (0:вДЭ) < (n:вДЭ) by exact_mod_cast hn0) ѕГ).le
          show вАЦѕЗ (n : ZMod N) * ((ќЫ n : вДЭ) : вДВ)вАЦ вЙ§ ќЫ n
          rw [norm_mul, Complex.norm_real, Real.norm_eq_abs,
            abs_of_nonneg ArithmeticFunction.vonMangoldt_nonneg]
          calc вАЦѕЗ ((n : ZMod N))вАЦ * ќЫ n вЙ§ 1 * ќЫ n := by
                apply mul_le_mul_of_nonneg_right (ѕЗ.norm_le_one _)
                  ArithmeticFunction.vonMangoldt_nonneg
            _ = ќЫ n := one_mul _
      _ = ((вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) n / ((n : вДВ)) ^ ((ѕГ : вДВ))).re := by
          rw [h1app, hpow1]
          rw [show (((ќЫ n : вДЭ)) : вДВ) / (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ)
              = (((ќЫ n / (n : вДЭ) ^ ѕГ : вДЭ)) : вДВ) by push_cast; ring]
          rw [Complex.ofReal_re]
  -- sum up
  have hre1 : (LSeries (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ)).re
      = вИС' n, (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) n).re :=
    ((Complex.hasSum_re hsum1.hasSum).tsum_eq).symm
  have hreѕЗ : (LSeries (вЖЧѕЗ * вЖЧќЫ) s).re
      = вИС' n, (LSeries.term (вЖЧѕЗ * вЖЧќЫ) s n).re :=
    ((Complex.hasSum_re hsumѕЗ.hasSum).tsum_eq).symm
  calc (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + t * I)).re
      = вИС' n, (LSeries.term (вЖЧѕЗ * вЖЧќЫ) s n).re := hreѕЗ
    _ вЙ§ вИС' n, (LSeries.term (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ) n).re := by
        apply Summable.tsum_mono
        ¬Ј exact (Complex.hasSum_re hsumѕЗ.hasSum).summable
        ¬Ј exact (Complex.hasSum_re hsum1.hasSum).summable
        ¬Ј intro n
          exact hpt n
    _ = (LSeries (вЖЧ(1 : DirichletCharacter вДВ 1) * вЖЧќЫ) (ѕГ : вДВ)).re := hre1.symm
    _ вЙ§ 1 / (ѕГ - 1) + K := hK ѕГ hѕГ1 hѕГ2

open Finset in
/-- Sum of a Dirichlet character over one period, as a range sum. -/
lemma char_range_period (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1) :
    вИС j вИИ Finset.range N, ѕЗ ((j : ZMod N)) = 0 := by
  have hbij : вИС j вИИ Finset.range N, ѕЗ ((j : ZMod N)) = вИС a : ZMod N, ѕЗ a := by
    apply Finset.sum_nbij' (i := fun j : вДХ => ((j : ZMod N))) (j := fun a : ZMod N => a.val)
    ¬Ј intro j _
      exact Finset.mem_univ _
    ¬Ј intro a _
      rw [Finset.mem_range]
      exact ZMod.val_lt a
    ¬Ј intro j hj
      rw [Finset.mem_range] at hj
      exact ZMod.val_natCast_of_lt hj
    ¬Ј intro a _
      exact ZMod.natCast_rightInverse a
    ¬Ј intro j _
      rfl
  rw [hbij]
  exact MulChar.sum_eq_zero_of_ne_one hѕЗ

open Finset in
/-- **Character partial sums are bounded by the modulus** вАФ the seed of the uniform
    polynomial growth bound `|L(s,ѕЗ)| вЙ™ q(1+|s|)` that the Hadamard layer consumes. -/
lemma char_partial_sum_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (x : вДХ) : вАЦвИС n вИИ Finset.range x, ѕЗ ((n : ZMod N))вАЦ вЙ§ N := by
  have hN0 : 0 < N := Nat.pos_of_ne_zero (NeZero.ne N)
  -- full periods vanish
  have hfull : вИА k : вДХ, вИС n вИИ Finset.range (N * k), ѕЗ ((n : ZMod N)) = 0 := by
    intro k
    induction k with
    | zero => simp
    | succ k ih =>
      rw [Nat.mul_succ, Finset.sum_range_add, ih, zero_add]
      have hshift : вИА j : вДХ, ѕЗ (((N * k + j : вДХ) : ZMod N)) = ѕЗ ((j : ZMod N)) := by
        intro j
        congr 1
        push_cast
        simp [ZMod.natCast_self]
      rw [Finset.sum_congr rfl (fun j _ => hshift j)]
      exact char_range_period N ѕЗ hѕЗ
  -- split off the incomplete period
  have hsplit : вИС n вИИ Finset.range x, ѕЗ ((n : ZMod N))
      = вИС n вИИ Finset.range (N * (x / N) + x % N), ѕЗ ((n : ZMod N)) := by
    rw [Nat.div_add_mod]
  rw [hsplit, Finset.sum_range_add, hfull, zero_add]
  have hshift : вИА j : вДХ, ѕЗ (((N * (x / N) + j : вДХ) : ZMod N)) = ѕЗ ((j : ZMod N)) := by
    intro j
    congr 1
    push_cast
    simp [ZMod.natCast_self]
  rw [Finset.sum_congr rfl (fun j _ => hshift j)]
  calc вАЦвИС j вИИ Finset.range (x % N), ѕЗ ((j : ZMod N))вАЦ
      вЙ§ вИС j вИИ Finset.range (x % N), вАЦѕЗ ((j : ZMod N))вАЦ := norm_sum_le _ _
    _ вЙ§ вИС _j вИИ Finset.range (x % N), 1 :=
        Finset.sum_le_sum (fun j _ => ѕЗ.norm_le_one _)
    _ = ((x % N : вДХ) : вДЭ) := by simp
    _ вЙ§ N := by
        have h := (Nat.mod_lt x hN0).le
        exact_mod_cast h

open intervalIntegral in
/-- **The Abel kernel inequality**: `вАЦn^{вИТs} вИТ (n+1)^{вИТs}вАЦ вЙ§ (вАЦsвАЦ/ѕГ)(n^{вИТѕГ} вИТ (n+1)^{вИТѕГ})`
    for `ѕГ = Re s > 0` вАФ the summand bound that turns bounded character sums into the
    uniform polynomial growth of `L(s,ѕЗ)` by partial summation. -/
lemma cpow_diff_kernel_bound (n : вДХ) (hn : 1 вЙ§ n) (s : вДВ) (hѕГ : 0 < s.re) :
    вАЦ((n : вДВ)) ^ (-s) - (((n + 1 : вДХ) : вДВ)) ^ (-s)вАЦ
      вЙ§ (вАЦsвАЦ / s.re) * ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re)) := by
  have hs0 : s вЙ† 0 := fun h => by simp [h] at hѕГ
  have hnR : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
  have hab : (n:вДЭ) вЙ§ ((n+1 : вДХ):вДЭ) := by exact_mod_cast Nat.le_succ n
  have h0notin : (0:вДЭ) вИЙ Set.uIcc ((n:вДЭ)) (((n+1 : вДХ)):вДЭ) := by
    rw [Set.uIcc_of_le hab]
    intro h0
    rw [Set.mem_Icc] at h0
    linarith [h0.1]
  -- FTC via integral_cpow at r = вИТsвИТ1
  have hr : (-s - 1 : вДВ) вЙ† -1 := by
    intro h
    apply hs0
    have : -s = 0 := by linear_combination h
    linear_combination -this
  have hint := integral_cpow (a := (n:вДЭ)) (b := ((n+1 : вДХ):вДЭ)) (r := -s - 1)
    (Or.inr вЯ®hr, h0notinвЯ©)
  have hexp : (-s - 1 : вДВ) + 1 = -s := by ring
  rw [hexp] at hint
  have hFTC : ((n : вДВ)) ^ (-s) - (((n + 1 : вДХ) : вДВ)) ^ (-s)
      = s * вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), ((x:вДВ)) ^ (-s - 1) := by
    rw [hint]
    have hcast1 : (((n:вДЭ)) : вДВ) = ((n : вДХ) : вДВ) := by push_cast; rfl
    have hcast2 : ((((n+1 : вДХ)):вДЭ) : вДВ) = (((n+1) : вДХ) : вДВ) := by push_cast; rfl
    rw [hcast1, hcast2]
    field_simp
    ring
  rw [hFTC, norm_mul]
  -- bound the integral
  have hnorm_int : вАЦвИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), ((x:вДВ)) ^ (-s - 1)вАЦ
      вЙ§ вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), x ^ (-s.re - 1) := by
    have h1 : вАЦвИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), ((x:вДВ)) ^ (-s - 1)вАЦ
        вЙ§ вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), вАЦ((x:вДВ)) ^ (-s - 1)вАЦ :=
      intervalIntegral.norm_integral_le_integral_norm hab
    have h2 : вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), вАЦ((x:вДВ)) ^ (-s - 1)вАЦ
        = вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), x ^ (-s.re - 1) := by
      apply intervalIntegral.integral_congr
      intro x hx
      rw [Set.uIcc_of_le hab, Set.mem_Icc] at hx
      have hx0 : 0 < x := by linarith [hx.1]
      dsimp only
      rw [Complex.norm_cpow_eq_rpow_re_of_pos hx0]
      norm_num
    linarith [h1, h2.le, h2.ge]
  have hreal : вИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), x ^ (-s.re - 1)
      = ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re)) / s.re := by
    have hrne : (-s.re - 1 : вДЭ) вЙ† -1 := by
      intro h
      have : s.re = 0 := by linarith
      linarith
    have h := integral_rpow (a := (n:вДЭ)) (b := ((n+1 : вДХ):вДЭ)) (r := -s.re - 1)
      (Or.inr вЯ®hrne, h0notinвЯ©)
    rw [show (-s.re - 1 : вДЭ) + 1 = -s.re by ring] at h
    rw [h]
    field_simp
    ring
  rw [hreal] at hnorm_int
  have hѕГne : s.re вЙ† 0 := hѕГ.ne'
  have hmono : 0 вЙ§ ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re)) := by
    have h1 : ((n + 1 : вДХ) : вДЭ) ^ (-s.re) вЙ§ (n : вДЭ) ^ (-s.re) := by
      apply Real.rpow_le_rpow_of_nonpos (by linarith) hab (by linarith)
    linarith
  calc вАЦsвАЦ * вАЦвИЂ x in ((n:вДЭ))..(((n+1 : вДХ)):вДЭ), ((x:вДВ)) ^ (-s - 1)вАЦ
      вЙ§ вАЦsвАЦ * (((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re)) / s.re) :=
        mul_le_mul_of_nonneg_left hnorm_int (norm_nonneg s)
    _ = (вАЦsвАЦ / s.re) * ((n : вДЭ) ^ (-s.re) - ((n + 1 : вДХ) : вДЭ) ^ (-s.re)) := by
        field_simp

open Finset in
/-- **Uniform growth of twisted partial sums** (SW uniformity brick 6): for every
    nontrivial ѕЗ mod N and `Re s > 0`,
    `вАЦвИС_{n<x} ѕЗ(n)n^{вИТs}вАЦ вЙ§ N(2 + вАЦsвАЦ/Re s)` вАФ partial summation of the bounded
    character sums against the Abel kernel. The finite heart of the uniform polynomial
    growth of `L(s,ѕЗ)` off `Re s > 1`. -/
lemma char_twisted_partial_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (s : вДВ) (hѕГ : 0 < s.re) (x : вДХ) :
    вАЦвИС n вИИ Finset.range x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)вАЦ
      вЙ§ (N : вДЭ) * (2 + вАЦsвАЦ / s.re) := by
  have hs0 : s вЙ† 0 := fun h => by simp [h] at hѕГ
  have hNnn : (0:вДЭ) вЙ§ (N:вДЭ) := Nat.cast_nonneg N
  have hfac : (0:вДЭ) вЙ§ 2 + вАЦsвАЦ / s.re := by positivity
  rcases Nat.lt_or_ge x 2 with hx2 | hx2
  ¬Ј -- x = 0 or 1: only the vanishing n = 0 term
    interval_cases x
    ¬Ј simp
      positivity
    ¬Ј rw [Finset.sum_range_one]
      rw [show ((0 : вДХ) : вДВ) ^ (-s) = 0 by
        rw [Nat.cast_zero]; exact Complex.zero_cpow (neg_ne_zero.mpr hs0)]
      rw [mul_zero, norm_zero]
      positivity
  -- Abel summation
  have habel := Finset.sum_range_by_parts
    (f := fun n : вДХ => ((n : вДВ)) ^ (-s)) (g := fun n : вДХ => ѕЗ ((n : ZMod N))) (n := x)
  simp only [smul_eq_mul] at habel
  have hswap : вИС n вИИ Finset.range x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)
      = вИС n вИИ Finset.range x, ((n : вДВ)) ^ (-s) * ѕЗ ((n : ZMod N)) := by
    apply Finset.sum_congr rfl
    intro n _
    ring
  rw [hswap, habel]
  set A : вДХ вЖТ вДВ := fun t => вИС j вИИ Finset.range t, ѕЗ ((j : ZMod N)) with hA
  have hAbound : вИА t, вАЦA tвАЦ вЙ§ N := fun t => char_partial_sum_bound N ѕЗ hѕЗ t
  -- step bounds
  have hstep : вИА i вИИ Finset.range (x - 1),
      вАЦ(((i + 1 : вДХ) : вДВ) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ
      вЙ§ (if i = 0 then (1:вДЭ)
         else (вАЦsвАЦ / s.re) * ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re))) * N := by
    intro i _
    rw [norm_mul]
    rcases Nat.eq_zero_or_pos i with rfl | hi0
    ¬Ј rw [if_pos rfl]
      apply mul_le_mul _ (hAbound 1) (norm_nonneg _) (by norm_num)
      rw [show ((0 : вДХ) : вДВ) ^ (-s) = 0 by
        rw [Nat.cast_zero]; exact Complex.zero_cpow (neg_ne_zero.mpr hs0)]
      rw [sub_zero]
      rw [show (((0 + 1 : вДХ)) : вДВ) = 1 by norm_num, Complex.one_cpow, norm_one]
    ¬Ј rw [if_neg hi0.ne']
      apply mul_le_mul _ (hAbound (i + 1)) (norm_nonneg _) ?_
      ¬Ј rw [вЖР norm_neg]
        rw [show -(((i + 1 : вДХ) : вДВ) ^ (-s) - ((i : вДВ)) ^ (-s))
            = ((i : вДВ)) ^ (-s) - ((i + 1 : вДХ) : вДВ) ^ (-s) by ring]
        exact cpow_diff_kernel_bound i hi0 s hѕГ
      ¬Ј have := cpow_diff_kernel_bound i hi0 s hѕГ
        have h0 : (0:вДЭ) вЙ§ вАЦ((i : вДВ)) ^ (-s) - ((i + 1 : вДХ) : вДВ) ^ (-s)вАЦ := norm_nonneg _
        linarith
  -- telescoping the kernel sums
  have htele : вИС i вИИ Finset.range (x - 1),
      (if i = 0 then (1:вДЭ)
       else (вАЦsвАЦ / s.re) * ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re)))
      вЙ§ 1 + вАЦsвАЦ / s.re := by
    have hm : 1 вЙ§ x - 1 := by omega
    rw [show x - 1 = 1 + (x - 2) by omega, Finset.sum_range_add]
    rw [Finset.sum_range_one, if_pos rfl]
    have hrest : вИС i вИИ Finset.range (x - 2),
        (if 1 + i = 0 then (1:вДЭ)
         else (вАЦsвАЦ / s.re) * (((1 + i : вДХ) : вДЭ) ^ (-s.re) - ((1 + i + 1 : вДХ) : вДЭ) ^ (-s.re)))
        вЙ§ вАЦsвАЦ / s.re := by
      have hcongr : вИА i вИИ Finset.range (x - 2),
          (if 1 + i = 0 then (1:вДЭ)
           else (вАЦsвАЦ / s.re) * (((1 + i : вДХ) : вДЭ) ^ (-s.re) - ((1 + i + 1 : вДХ) : вДЭ) ^ (-s.re)))
          = (вАЦsвАЦ / s.re) * (((i + 1 : вДХ) : вДЭ) ^ (-s.re) - ((i + 2 : вДХ) : вДЭ) ^ (-s.re)) := by
        intro i _
        rw [if_neg (by omega), show 1 + i = i + 1 from by omega]
      rw [Finset.sum_congr rfl hcongr, вЖР Finset.mul_sum]
      have htel : вИС i вИИ Finset.range (x - 2),
          (((i + 1 : вДХ) : вДЭ) ^ (-s.re) - ((i + 2 : вДХ) : вДЭ) ^ (-s.re))
          = ((1 : вДХ) : вДЭ) ^ (-s.re) - ((x - 1 : вДХ) : вДЭ) ^ (-s.re) := by
        have h := Finset.sum_range_sub' (f := fun j : вДХ => ((j + 1 : вДХ) : вДЭ) ^ (-s.re))
          (n := x - 2)
        calc вИС i вИИ Finset.range (x - 2),
            (((i + 1 : вДХ) : вДЭ) ^ (-s.re) - ((i + 2 : вДХ) : вДЭ) ^ (-s.re))
            = вИС i вИИ Finset.range (x - 2),
              ((((i + 1 : вДХ)) : вДЭ) ^ (-s.re) - (((i + 1 + 1 : вДХ)) : вДЭ) ^ (-s.re)) := by
              apply Finset.sum_congr rfl
              intro i _
              rw [show (i + 2 : вДХ) = i + 1 + 1 from by omega]
          _ = (((0 + 1 : вДХ)) : вДЭ) ^ (-s.re) - (((x - 2 + 1 : вДХ)) : вДЭ) ^ (-s.re) := h
          _ = ((1 : вДХ) : вДЭ) ^ (-s.re) - ((x - 1 : вДХ) : вДЭ) ^ (-s.re) := by
              rw [show (0 + 1 : вДХ) = 1 from rfl, show x - 2 + 1 = x - 1 from by omega]
      rw [htel]
      have h1 : ((1 : вДХ) : вДЭ) ^ (-s.re) = 1 := by
        norm_num
      have h2 : (0:вДЭ) вЙ§ ((x - 1 : вДХ) : вДЭ) ^ (-s.re) := by positivity
      rw [h1]
      have hq : (0:вДЭ) вЙ§ вАЦsвАЦ / s.re := by positivity
      nlinarith [mul_nonneg hq h2]
    exact add_le_add (le_refl (1:вДЭ)) hrest
  -- assemble
  calc вАЦ((x - 1 : вДХ) : вДВ) ^ (-s) * A x
        - вИС i вИИ Finset.range (x - 1),
            ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ
      вЙ§ вАЦ((x - 1 : вДХ) : вДВ) ^ (-s) * A xвАЦ
        + вАЦвИС i вИИ Finset.range (x - 1),
            ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ := norm_sub_le _ _
    _ вЙ§ 1 * (N : вДЭ)
        + вИС i вИИ Finset.range (x - 1),
            (if i = 0 then (1:вДЭ)
             else (вАЦsвАЦ / s.re) * ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re))) * N := by
        apply add_le_add
        ¬Ј rw [norm_mul]
          apply mul_le_mul _ (hAbound x) (norm_nonneg _) (by norm_num)
          rw [show ((x - 1 : вДХ) : вДВ) = (((x - 1 : вДХ) : вДЭ) : вДВ) by push_cast; rfl]
          rw [Complex.norm_cpow_eq_rpow_re_of_pos (by exact_mod_cast Nat.sub_pos_of_lt (by omega))]
          simp only [Complex.neg_re]
          apply Real.rpow_le_one_of_one_le_of_nonpos
          ¬Ј exact_mod_cast Nat.one_le_iff_ne_zero.mpr (by omega)
          ¬Ј linarith
        ¬Ј exact le_trans (norm_sum_le _ _) (Finset.sum_le_sum hstep)
    _ = 1 * (N : вДЭ) + (вИС i вИИ Finset.range (x - 1),
            (if i = 0 then (1:вДЭ)
             else (вАЦsвАЦ / s.re) * ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re)))) * N := by
        rw [Finset.sum_mul]
    _ вЙ§ 1 * (N : вДЭ) + (1 + вАЦsвАЦ / s.re) * N := by
        have := mul_le_mul_of_nonneg_right htele hNnn
        linarith
    _ = (N : вДЭ) * (2 + вАЦsвАЦ / s.re) := by ring

open Finset in
open scoped LSeries.notation in
/-- **Uniform L-series bound** (SW uniformity brick 7): on `Re s > 1`,
    `вАЦL(s,ѕЗ)вАЦ вЙ§ N(2 + вАЦsвАЦ/Re s)` for every nontrivial ѕЗ вАФ the partial-sum bound survives
    the limit. Transfers to `LFunction` on `Re s > 1` via `LFunction_eq_LSeries`. -/
lemma char_LSeries_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (s : вДВ) (hs : 1 < s.re) :
    вАЦLSeries (вЖЧѕЗ) sвАЦ вЙ§ (N : вДЭ) * (2 + вАЦsвАЦ / s.re) := by
  have hѕГ : 0 < s.re := lt_trans one_pos hs
  have hsum : LSeriesSummable (вЖЧѕЗ) s := by
    apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ hs
    intro n hn
    exact ѕЗ.norm_le_one _
  have hterm_eq : вИА n : вДХ, LSeries.term (вЖЧѕЗ) s n = ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј rw [LSeries.term_zero]
      rw [show ((0 : вДХ) : вДВ) ^ (-s) = 0 by
        rw [Nat.cast_zero]
        exact Complex.zero_cpow (neg_ne_zero.mpr (fun h => by simp [h] at hѕГ))]
      rw [mul_zero]
    ¬Ј rw [LSeries.term_of_ne_zero hn0.ne']
      rw [Complex.cpow_neg]
      rw [div_eq_mul_inv]
  have htend : Filter.Tendsto (fun x : вДХ => вИС n вИИ Finset.range x, LSeries.term (вЖЧѕЗ) s n)
      Filter.atTop (nhds (LSeries (вЖЧѕЗ) s)) := hsum.hasSum.tendsto_sum_nat
  have hnorm_tend : Filter.Tendsto
      (fun x : вДХ => вАЦвИС n вИИ Finset.range x, LSeries.term (вЖЧѕЗ) s nвАЦ)
      Filter.atTop (nhds вАЦLSeries (вЖЧѕЗ) sвАЦ) := htend.norm
  apply le_of_tendsto hnorm_tend
  apply Filter.Eventually.of_forall
  intro x
  have hcongr : вИС n вИИ Finset.range x, LSeries.term (вЖЧѕЗ) s n
      = вИС n вИИ Finset.range x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) :=
    Finset.sum_congr rfl (fun n _ => hterm_eq n)
  rw [hcongr]
  exact char_twisted_partial_bound N ѕЗ hѕЗ s hѕГ x

open Finset in
/-- **The decaying tail bound** (SW uniformity brick 8): for `1 вЙ§ x < y`,
    `вАЦвИС_{xвЙ§n<y} ѕЗ(n)n^{вИТs}вАЦ вЙ§ N¬Јx^{вИТѕГ}¬Ј(2 + вАЦsвАЦ/ѕГ)` вАФ the partial sums are uniformly
    Cauchy on `Re s вЙ• ѕГвВА > 0`; the continuation of `L(s,ѕЗ)` to the strip inherits the
    uniform bound. -/
lemma char_twisted_tail_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (s : вДВ) (hѕГ : 0 < s.re) (x y : вДХ) (hx : 1 вЙ§ x) (hxy : x < y) :
    вАЦвИС n вИИ Finset.Ico x y, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)вАЦ
      вЙ§ (N : вДЭ) * ((x : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re)) := by
  have hNnn : (0:вДЭ) вЙ§ (N:вДЭ) := Nat.cast_nonneg N
  have hxR : (1:вДЭ) вЙ§ (x:вДЭ) := by exact_mod_cast hx
  have hxѕГ : (0:вДЭ) < (x:вДЭ) ^ (-s.re) := by positivity
  set A : вДХ вЖТ вДВ := fun t => вИС j вИИ Finset.range t, ѕЗ ((j : ZMod N)) with hA
  have hAbound : вИА t, вАЦA tвАЦ вЙ§ N := fun t => char_partial_sum_bound N ѕЗ hѕЗ t
  have hnormpow : вИА k : вДХ, 1 вЙ§ k вЖТ вАЦ((k : вДВ)) ^ (-s)вАЦ = (k : вДЭ) ^ (-s.re) := by
    intro k hk
    rw [Complex.norm_natCast_cpow_of_pos (by omega) (-s), Complex.neg_re]
  have hanti : вИА k : вДХ, x вЙ§ k вЖТ ((k : вДЭ)) ^ (-s.re) вЙ§ ((x : вДЭ)) ^ (-s.re) := by
    intro k hk
    apply Real.rpow_le_rpow_of_nonpos (by linarith) (by exact_mod_cast hk) (by linarith)
  -- Abel on the tail
  have habel := Finset.sum_Ico_by_parts
    (f := fun n : вДХ => ((n : вДВ)) ^ (-s)) (g := fun n : вДХ => ѕЗ ((n : ZMod N))) hxy
  simp only [smul_eq_mul] at habel
  have hswap : вИС n вИИ Finset.Ico x y, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)
      = вИС n вИИ Finset.Ico x y, ((n : вДВ)) ^ (-s) * ѕЗ ((n : ZMod N)) :=
    Finset.sum_congr rfl (fun n _ => by ring)
  rw [hswap, habel]
  -- the three pieces
  have hp1 : вАЦ((y - 1 : вДХ) : вДВ) ^ (-s) * A yвАЦ вЙ§ (x : вДЭ) ^ (-s.re) * N := by
    rw [norm_mul, hnormpow (y - 1) (by omega)]
    apply mul_le_mul (hanti (y - 1) (by omega)) (hAbound y) (norm_nonneg _) hxѕГ.le
  have hp2 : вАЦ((x : вДХ) : вДВ) ^ (-s) * A xвАЦ вЙ§ (x : вДЭ) ^ (-s.re) * N := by
    rw [norm_mul, hnormpow x hx]
    apply mul_le_mul le_rfl (hAbound x) (norm_nonneg _) hxѕГ.le
  have hp3 : вАЦвИС i вИИ Finset.Ico x (y - 1),
      ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ
      вЙ§ (вАЦsвАЦ / s.re) * (x : вДЭ) ^ (-s.re) * N := by
    calc вАЦвИС i вИИ Finset.Ico x (y - 1),
        ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ
        вЙ§ вИС i вИИ Finset.Ico x (y - 1),
          вАЦ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ := norm_sum_le _ _
      _ вЙ§ вИС i вИИ Finset.Ico x (y - 1),
          ((вАЦsвАЦ / s.re) * ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re))) * N := by
          apply Finset.sum_le_sum
          intro i hi
          rw [Finset.mem_Ico] at hi
          rw [norm_mul]
          refine mul_le_mul ?_ (hAbound (i + 1)) (norm_nonneg _) ?_
          ¬Ј rw [вЖР norm_neg, show -(((((i + 1 : вДХ) : вДВ)) ^ (-s)) - ((i : вДВ)) ^ (-s))
                = ((i : вДВ)) ^ (-s) - (((i + 1 : вДХ) : вДВ)) ^ (-s) by ring]
            exact cpow_diff_kernel_bound i (by omega) s hѕГ
          ¬Ј have h := cpow_diff_kernel_bound i (by omega) s hѕГ
            have h0 : (0:вДЭ) вЙ§ вАЦ((i : вДВ)) ^ (-s) - (((i + 1 : вДХ) : вДВ)) ^ (-s)вАЦ :=
              norm_nonneg _
            linarith
      _ = (вАЦsвАЦ / s.re) * (вИС i вИИ Finset.Ico x (y - 1),
            ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re))) * N := by
          rw [вЖР Finset.sum_mul, вЖР Finset.mul_sum]
      _ вЙ§ (вАЦsвАЦ / s.re) * (x : вДЭ) ^ (-s.re) * N := by
          apply mul_le_mul_of_nonneg_right _ hNnn
          apply mul_le_mul_of_nonneg_left _ (by positivity)
          rcases Nat.lt_or_ge x (y - 1) with hlt | hge
          ¬Ј have htel : вИС i вИИ Finset.Ico x (y - 1),
                ((i : вДЭ) ^ (-s.re) - ((i + 1 : вДХ) : вДЭ) ^ (-s.re))
                = (x : вДЭ) ^ (-s.re) - ((y - 1 : вДХ) : вДЭ) ^ (-s.re) := by
              rw [Finset.sum_Ico_eq_sum_range]
              have hcongr : вИА j вИИ Finset.range (y - 1 - x),
                  (((x + j : вДХ) : вДЭ) ^ (-s.re) - (((x + j) + 1 : вДХ) : вДЭ) ^ (-s.re))
                  = (fun t : вДХ => ((x + t : вДХ) : вДЭ) ^ (-s.re)) j
                    - (fun t : вДХ => ((x + t : вДХ) : вДЭ) ^ (-s.re)) (j + 1) := by
                intro j _
                rfl
              rw [Finset.sum_congr rfl hcongr, Finset.sum_range_sub']
              rw [show x + 0 = x from by omega, show x + (y - 1 - x) = y - 1 from by omega]
            rw [htel]
            have h2 : (0:вДЭ) вЙ§ ((y - 1 : вДХ) : вДЭ) ^ (-s.re) := by positivity
            linarith
          ¬Ј have hempty : Finset.Ico x (y - 1) = вИЕ := Finset.Ico_eq_empty (by omega)
            rw [hempty, Finset.sum_empty]
            positivity
  calc вАЦ((y - 1 : вДХ) : вДВ) ^ (-s) * A y - ((x : вДХ) : вДВ) ^ (-s) * A x
        - вИС i вИИ Finset.Ico x (y - 1),
            ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ
      вЙ§ вАЦ((y - 1 : вДХ) : вДВ) ^ (-s) * A y - ((x : вДХ) : вДВ) ^ (-s) * A xвАЦ
        + вАЦвИС i вИИ Finset.Ico x (y - 1),
            ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ := norm_sub_le _ _
    _ вЙ§ (вАЦ((y - 1 : вДХ) : вДВ) ^ (-s) * A yвАЦ + вАЦ((x : вДХ) : вДВ) ^ (-s) * A xвАЦ)
        + вАЦвИС i вИИ Finset.Ico x (y - 1),
            ((((i + 1 : вДХ) : вДВ)) ^ (-s) - ((i : вДВ)) ^ (-s)) * A (i + 1)вАЦ := by
        have := norm_sub_le (((y - 1 : вДХ) : вДВ) ^ (-s) * A y) (((x : вДХ) : вДВ) ^ (-s) * A x)
        linarith
    _ вЙ§ ((x : вДЭ) ^ (-s.re) * N + (x : вДЭ) ^ (-s.re) * N)
        + (вАЦsвАЦ / s.re) * (x : вДЭ) ^ (-s.re) * N := by
        linarith [hp1, hp2, hp3]
    _ = (N : вДЭ) * ((x : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re)) := by ring

open Finset in
/-- The truncated twisted sums are ENTIRE вАФ each term `s вЖ¶ ѕЗ(n)¬Јn^{вИТs}` is
    (for `n вЙ• 1`) a constant times `const_cpow` of the entire `вИТs`. Input to the
    Weierstrass step of the strip continuation. -/
lemma twisted_partial_differentiable (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (x : вДХ) :
    Differentiable вДВ (fun s : вДВ =>
      вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)) := by
  apply Differentiable.fun_sum
  intro n hn
  rw [Finset.mem_Ico] at hn
  have hne : ((n : вДВ)) вЙ† 0 := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mp hn.1
  apply Differentiable.const_mul
  exact (differentiable_neg).const_cpow (Or.inl hne)

open Finset in
open scoped LSeries.notation in
/-- The truncations `P_x(s) = вИС_{1вЙ§n<x} ѕЗ(n)n^{вИТs}` converge to `L(s,ѕЗ)` on `Re s > 1`
    вАФ step 3 of the strip-identification plan. -/
lemma twisted_partial_tendsto (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (s : вДВ) (hs : 1 < s.re) :
    Filter.Tendsto (fun x : вДХ =>
        вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s))
      Filter.atTop (nhds (LSeries (вЖЧѕЗ) s)) := by
  have hѕГ : 0 < s.re := lt_trans one_pos hs
  have hs0 : s вЙ† 0 := fun h => by simp [h] at hѕГ
  have hsum : LSeriesSummable (вЖЧѕЗ) s := by
    apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ hs
    intro n hn
    exact ѕЗ.norm_le_one _
  have hterm_eq : вИА n : вДХ, 1 вЙ§ n вЖТ
      LSeries.term (вЖЧѕЗ) s n = ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) := by
    intro n hn
    rw [LSeries.term_of_ne_zero (by omega), Complex.cpow_neg, div_eq_mul_inv]
  have hbridge : вИА x : вДХ, вИС n вИИ Finset.range x, LSeries.term (вЖЧѕЗ) s n
      = вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) := by
    intro x
    rcases Nat.eq_zero_or_pos x with rfl | hx0
    ¬Ј simp
    rw [Finset.range_eq_Ico, вЖР Finset.sum_Ico_consecutive _ (Nat.zero_le 1) hx0]
    rw [show вИС n вИИ Finset.Ico 0 1, LSeries.term (вЖЧѕЗ) s n = 0 by
      rw [Finset.sum_Ico_eq_sum_range]
      simp [LSeries.term_zero]]
    rw [zero_add]
    exact Finset.sum_congr rfl (fun n hn => hterm_eq n (Finset.mem_Ico.mp hn).1)
  have htend := hsum.hasSum.tendsto_sum_nat
  rw [show (fun x : вДХ => вИС n вИИ Finset.range x, LSeries.term (вЖЧѕЗ) s n)
      = (fun x : вДХ => вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s)) from
    funext hbridge] at htend
  exact htend

open Finset Filter in
/-- **Uniform Cauchy on strips** (SW uniformity brick 11): the truncations are uniformly
    Cauchy on every `{ѕГвВА вЙ§ Re s, вАЦsвАЦ вЙ§ R}` вАФ the Weierstrass input for the strip
    continuation of `L(s,ѕЗ)` with its uniform bound. -/
lemma twisted_partial_uniformCauchy (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ѕГвВА R : вДЭ) (hѕГвВА : 0 < ѕГвВА) (hR : 0 вЙ§ R) :
    UniformCauchySeqOn (fun x : вДХ => fun s : вДВ =>
        вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s))
      Filter.atTop {s : вДВ | ѕГвВА вЙ§ s.re вИІ вАЦsвАЦ вЙ§ R} := by
  rw [Metric.uniformCauchySeqOn_iff]
  intro ќµ hќµ
  set C : вДЭ := (N:вДЭ) * (2 + R / ѕГвВА) + 1 with hCdef
  have hC : (0:вДЭ) < C := by positivity
  have htend : Filter.Tendsto (fun k : вДХ => C * (k : вДЭ) ^ (-ѕГвВА))
      Filter.atTop (nhds 0) := by
    have h2 : Filter.Tendsto (fun k : вДХ => ((k : вДЭ)) ^ (-ѕГвВА)) Filter.atTop (nhds 0) :=
      (tendsto_rpow_neg_atTop hѕГвВА).comp tendsto_natCast_atTop_atTop
    simpa using h2.const_mul C
  obtain вЯ®KвВА, hKвВАвЯ© := Filter.eventually_atTop.mp (htend.eventually (gt_mem_nhds hќµ))
  refine вЯ®max KвВА 1, fun m hm n hn s hsmem => ?_вЯ©
  obtain вЯ®hs1, hs2вЯ© := hsmem
  have hѕГ : 0 < s.re := lt_of_lt_of_le hѕГвВА hs1
  -- one-sided estimate
  have hside : вИА a b : вДХ, max KвВА 1 вЙ§ a вЖТ a < b вЖТ
      dist (вИС k вИИ Finset.Ico 1 a, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s))
        (вИС k вИИ Finset.Ico 1 b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s)) < ќµ := by
    intro a b ha hab
    have ha1 : 1 вЙ§ a := le_trans (le_max_right _ _) ha
    have haK : KвВА вЙ§ a := le_trans (le_max_left _ _) ha
    have hsplit : вИС k вИИ Finset.Ico 1 b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s)
        = (вИС k вИИ Finset.Ico 1 a, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s))
          + вИС k вИИ Finset.Ico a b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s) :=
      (Finset.sum_Ico_consecutive _ ha1 hab.le).symm
    rw [dist_eq_norm, hsplit]
    rw [show (вИС k вИИ Finset.Ico 1 a, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s))
        - ((вИС k вИИ Finset.Ico 1 a, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s))
          + вИС k вИИ Finset.Ico a b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s))
        = -(вИС k вИИ Finset.Ico a b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s)) by ring]
    rw [norm_neg]
    have htail := char_twisted_tail_bound N ѕЗ hѕЗ s hѕГ a b ha1 hab
    have haR : (1:вДЭ) вЙ§ (a:вДЭ) := by exact_mod_cast ha1
    have hmono1 : ((a:вДЭ)) ^ (-s.re) вЙ§ ((a:вДЭ)) ^ (-ѕГвВА) :=
      Real.rpow_le_rpow_of_exponent_le haR (by linarith)
    have hmono2 : вАЦsвАЦ / s.re вЙ§ R / ѕГвВА := by
      gcongr
    have hbound2 : (N : вДЭ) * ((a : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re))
        вЙ§ C * (a : вДЭ) ^ (-ѕГвВА) := by
      have h1 : (0:вДЭ) вЙ§ (a:вДЭ) ^ (-s.re) := by positivity
      have h2 : (0:вДЭ) вЙ§ 2 + вАЦsвАЦ / s.re := by positivity
      have h3 : (a : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re)
          вЙ§ (a : вДЭ) ^ (-ѕГвВА) * (2 + R / ѕГвВА) := by
        apply mul_le_mul hmono1 (by linarith) h2 (by positivity)
      have h4 : (N:вДЭ) * ((a : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re))
          вЙ§ (N:вДЭ) * ((a : вДЭ) ^ (-ѕГвВА) * (2 + R / ѕГвВА)) :=
        mul_le_mul_of_nonneg_left h3 (Nat.cast_nonneg N)
      have h5 : (N:вДЭ) * ((a : вДЭ) ^ (-ѕГвВА) * (2 + R / ѕГвВА))
          вЙ§ C * (a : вДЭ) ^ (-ѕГвВА) := by
        rw [hCdef]
        have h6 : (0:вДЭ) вЙ§ (a:вДЭ) ^ (-ѕГвВА) := by positivity
        nlinarith
      linarith
    calc вАЦвИС k вИИ Finset.Ico a b, ѕЗ ((k : ZMod N)) * ((k : вДВ)) ^ (-s)вАЦ
        вЙ§ (N : вДЭ) * ((a : вДЭ) ^ (-s.re) * (2 + вАЦsвАЦ / s.re)) := htail
      _ вЙ§ C * (a : вДЭ) ^ (-ѕГвВА) := hbound2
      _ < ќµ := hKвВА a haK
  rcases lt_trichotomy m n with h | h | h
  ¬Ј exact hside m n hm h
  ¬Ј subst h
    rw [dist_self]
    exact hќµ
  ¬Ј rw [dist_comm]
    exact hside n m hn h

open Finset Filter in
open scoped LSeries.notation in
/-- **THE UNIFORM STRIP BOUND** (SW uniformity brick 12 вАФ the free layer's capstone):
    `вАЦL(s,ѕЗ)вАЦ вЙ§ N(2 + вАЦsвАЦ/Re s)` for every nontrivial ѕЗ on ALL of `Re s > 0` вАФ the
    truncations' locally uniform limit is analytic, agrees with `LFunction` past the
    1-line, and the identity theorem carries the uniform bound into the strip. -/
theorem LFunction_strip_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (s : вДВ) (hѕГ : 0 < s.re) :
    вАЦDirichletCharacter.LFunction ѕЗ sвАЦ вЙ§ (N : вДЭ) * (2 + вАЦsвАЦ / s.re) := by
  classical
  set U : Set вДВ := {z : вДВ | 0 < z.re} with hU
  have hUopen : IsOpen U := isOpen_lt continuous_const Complex.continuous_re
  have hUconv : Convex вДЭ U := convex_halfSpace_re_gt 0
  set P : вДХ вЖТ вДВ вЖТ вДВ := fun x z =>
    вИС n вИИ Finset.Ico 1 x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-z) with hP
  -- pointwise Cauchy вЖТ pointwise limit F on U
  have hcau : вИА z вИИ U, CauchySeq (fun x => P x z) := by
    intro z hz
    have hz' : 0 < z.re := hz
    have huc := twisted_partial_uniformCauchy N ѕЗ hѕЗ (z.re) (вАЦzвАЦ) hz' (norm_nonneg z)
    have hmem : z вИИ {w : вДВ | z.re вЙ§ w.re вИІ вАЦwвАЦ вЙ§ вАЦzвАЦ} := вЯ®le_refl _, le_refl _вЯ©
    exact huc.cauchySeq hmem
  set F : вДВ вЖТ вДВ := fun z => limUnder Filter.atTop (fun x => P x z) with hF
  have hFtend : вИА z вИИ U, Filter.Tendsto (fun x => P x z) Filter.atTop (nhds (F z)) := by
    intro z hz
    exact (hcau z hz).tendsto_limUnder
  -- locally uniform convergence on U
  have hlocal : TendstoLocallyUniformlyOn P F Filter.atTop U := by
    rw [tendstoLocallyUniformlyOn_iff_forall_isCompact hUopen]
    intro K hKU hK
    rcases K.eq_empty_or_nonempty with rfl | hKne
    ¬Ј exact tendstoUniformlyOn_empty
    ¬Ј -- compact K has positive min re and bounded norm
      obtain вЯ®zвВА, hzвВАK, hzвВАminвЯ© := hK.exists_isMinOn hKne
        (Complex.continuous_re.continuousOn)
      obtain вЯ®R, hRвЯ© := hK.isBounded.subset_ball 0
      have hѕГвВА : 0 < zвВА.re := hKU hzвВАK
      have hsub : K вКЖ {w : вДВ | zвВА.re вЙ§ w.re вИІ вАЦwвАЦ вЙ§ max R 0} := by
        intro w hw
        constructor
        ¬Ј exact hzвВАmin hw
        ¬Ј have := hR hw
          rw [Metric.mem_ball, dist_zero_right] at this
          exact le_trans this.le (le_max_left _ _)
      have huc := twisted_partial_uniformCauchy N ѕЗ hѕЗ (zвВА.re) (max R 0) hѕГвВА
        (le_max_right _ _)
      have hucK := huc.mono hsub
      exact hucK.tendstoUniformlyOn_of_tendsto (fun z hz => hFtend z (hKU hz))
  -- F analytic on U
  have hFdiff : DifferentiableOn вДВ F U :=
    hlocal.differentiableOn
      (Filter.Eventually.of_forall (fun x => (twisted_partial_differentiable N ѕЗ x).differentiableOn))
      hUopen
  -- F = LFunction on {re > 1}
  have hagree : вИА z : вДВ, 1 < z.re вЖТ F z = DirichletCharacter.LFunction ѕЗ z := by
    intro z hz
    have h1 := hFtend z (by simp only [hU, Set.mem_setOf_eq]; linarith)
    have h2 := twisted_partial_tendsto N ѕЗ z hz
    have := tendsto_nhds_unique h1 h2
    rw [this, DirichletCharacter.LFunction_eq_LSeries _ hz]
  -- identity theorem
  have hLdiff : DifferentiableOn вДВ (DirichletCharacter.LFunction ѕЗ) U :=
    (DirichletCharacter.differentiable_LFunction hѕЗ).differentiableOn
  have heq : Set.EqOn F (DirichletCharacter.LFunction ѕЗ) U := by
    apply AnalyticOnNhd.eqOn_of_preconnected_of_eventuallyEq
      (hFdiff.analyticOnNhd hUopen) (hLdiff.analyticOnNhd hUopen)
      hUconv.isPreconnected (show (2 : вДВ) вИИ U by simp [hU])
    have hV : {z : вДВ | 1 < z.re} вИИ nhds (2 : вДВ) := by
      apply IsOpen.mem_nhds (isOpen_lt continuous_const Complex.continuous_re)
      simp
    exact Filter.eventuallyEq_of_mem hV (fun z hz => hagree z hz)
  -- transfer the bound
  have hsU : s вИИ U := hѕГ
  rw [вЖР heq hsU]
  have htends := hFtend s hsU
  apply le_of_tendsto htends.norm
  apply Filter.Eventually.of_forall
  intro x
  -- P x s = range-sum minus the vanishing n=0 term
  have hzero : ѕЗ (((0 : вДХ) : ZMod N)) * (((0 : вДХ) : вДВ)) ^ (-s) = 0 := by
    rw [show (((0 : вДХ)) : вДВ) ^ (-s) = 0 by
      rw [Nat.cast_zero]
      exact Complex.zero_cpow (neg_ne_zero.mpr (fun h => by simp [h] at hѕГ))]
    rw [mul_zero]
  have hbridge : P x s = вИС n вИИ Finset.range x, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) := by
    rcases Nat.eq_zero_or_pos x with rfl | hx0
    ¬Ј simp [hP]
    rw [hP]
    rw [Finset.range_eq_Ico, вЖР Finset.sum_Ico_consecutive _ (Nat.zero_le 1) hx0]
    rw [show вИС n вИИ Finset.Ico (0:вДХ) 1, ѕЗ ((n : ZMod N)) * ((n : вДВ)) ^ (-s) = 0 by
      rw [Finset.sum_Ico_eq_sum_range]
      simpa using hzero]
    rw [zero_add]
  rw [hbridge]
  exact char_twisted_partial_bound N ѕЗ hѕЗ s hѕГ x

/-- Constant-form window bound: on `{ѕГвВА вЙ§ Re s, вАЦsвАЦ вЙ§ R}`,
    `вАЦL(s,ѕЗ)вАЦ вЙ§ N(2 + R/ѕГвВА)` вАФ the `M` that BorelвАУCarath√©odory consumes. -/
lemma LFunction_window_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ѕГвВА R : вДЭ) (hѕГвВА : 0 < ѕГвВА) (hR : 0 вЙ§ R) (s : вДВ)
    (hs1 : ѕГвВА вЙ§ s.re) (hs2 : вАЦsвАЦ вЙ§ R) :
    вАЦDirichletCharacter.LFunction ѕЗ sвАЦ вЙ§ (N : вДЭ) * (2 + R / ѕГвВА) := by
  have hѕГ : 0 < s.re := lt_of_lt_of_le hѕГвВА hs1
  calc вАЦDirichletCharacter.LFunction ѕЗ sвАЦ
      вЙ§ (N : вДЭ) * (2 + вАЦsвАЦ / s.re) := LFunction_strip_bound N ѕЗ hѕЗ s hѕГ
    _ вЙ§ (N : вДЭ) * (2 + R / ѕГвВА) := by
        gcongr

open Metric in
/-- **Uniform derivative bound** (SW uniformity brick 14): whenever the closed `r`-ball
    around `s` stays in the window `{ѕГвВА вЙ§ Re, вАЦ¬ЈвАЦ вЙ§ R}`,
    `вАЦL'(s,ѕЗ)вАЦ вЙ§ N(2 + R/ѕГвВА)/r` вАФ the Cauchy estimate over the uniform window bound.
    Feeds the 3-4-1 error terms and the Landau assembly. -/
lemma LFunction_deriv_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ѕГвВА R r : вДЭ) (hѕГвВА : 0 < ѕГвВА) (hr : 0 < r) (s : вДВ)
    (h1 : ѕГвВА + r вЙ§ s.re) (h2 : вАЦsвАЦ + r вЙ§ R) :
    вАЦderiv (DirichletCharacter.LFunction ѕЗ) sвАЦ вЙ§ (N : вДЭ) * (2 + R / ѕГвВА) / r := by
  have hR0 : (0:вДЭ) вЙ§ R := le_trans (by positivity) h2
  apply Complex.norm_deriv_le_of_forall_mem_sphere_norm_le hr
    ((DirichletCharacter.differentiable_LFunction hѕЗ).diffContOnCl)
  intro z hz
  rw [mem_sphere_iff_norm] at hz
  have hzre : ѕГвВА вЙ§ z.re := by
    have hd : |(z - s).re| вЙ§ вАЦz - sвАЦ := Complex.abs_re_le_norm _
    have h3 : z.re = s.re + (z - s).re := by
      simp [Complex.sub_re]
    rw [h3]
    have := abs_le.mp (hz вЦЄ hd)
    linarith
  have hznorm : вАЦzвАЦ вЙ§ R := by
    calc вАЦzвАЦ = вАЦs + (z - s)вАЦ := by ring_nf
      _ вЙ§ вАЦsвАЦ + вАЦz - sвАЦ := norm_add_le _ _
      _ = вАЦsвАЦ + r := by rw [hz]
      _ вЙ§ R := h2
  exact LFunction_window_bound N ѕЗ hѕЗ ѕГвВА R hѕГвВА hR0 z hzre hznorm

open Finset in
open scoped LSeries.notation in
/-- **The uniform non-vanishing anchor** (SW uniformity brick 15): for EVERY modulus and
    nontrivial character, `вАЦL(2,ѕЗ)вАЦ вЙ• 2 вИТ ѕА¬≤/6 > 0` вАФ the `f(sвВА)` lower bound the Landau
    log-derivative lemma normalizes against. -/
lemma LFunction_two_lower_uniform (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) :
    2 - Real.pi ^ 2 / 6 вЙ§ вАЦDirichletCharacter.LFunction ѕЗ 2вАЦ := by
  have h2re : (1:вДЭ) < ((2:вДВ)).re := by norm_num
  rw [DirichletCharacter.LFunction_eq_LSeries _ h2re]
  have hsum : LSeriesSummable (вЖЧѕЗ) 2 := by
    apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ h2re
    intro n hn
    exact ѕЗ.norm_le_one _
  -- split off the first two terms
  have hsplit := hsum.sum_add_tsum_nat_add 2
  have hterm0 : LSeries.term (вЖЧѕЗ) 2 0 = 0 := LSeries.term_zero _ _
  have hterm1 : LSeries.term (вЖЧѕЗ) 2 1 = 1 := by
    rw [LSeries.term_of_ne_zero one_ne_zero]
    simp
  have hhead : вИС i вИИ Finset.range 2, LSeries.term (вЖЧѕЗ) 2 i = 1 := by
    rw [Finset.sum_range_succ, Finset.sum_range_one, hterm0, hterm1, zero_add]
  -- tail norm bound via Basel
  have hbasel : Summable (fun n : вДХ => (1:вДЭ) / ((n:вДЭ)) ^ 2) := hasSum_zeta_two.summable
  have htails : Summable (fun i : вДХ => (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2) := by
    exact_mod_cast (summable_nat_add_iff 2).mpr hbasel
  have htermbound : вИА i : вДХ, вАЦLSeries.term (вЖЧѕЗ) 2 (i + 2)вАЦ вЙ§ (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2 := by
    intro i
    rw [LSeries.term_of_ne_zero (by omega)]
    rw [norm_div]
    have hpow : вАЦ(((i + 2 : вДХ)) : вДВ) ^ (2 : вДВ)вАЦ = (((i + 2 : вДХ)):вДЭ) ^ 2 := by
      rw [Complex.norm_natCast_cpow_of_pos (by omega)]
      rw [show ((2:вДВ)).re = (2:вДЭ) by norm_num]
      rw [Real.rpow_two]
    rw [hpow]
    have hnum : вАЦ(вЖЧѕЗ) ((i + 2 : вДХ))вАЦ вЙ§ 1 := ѕЗ.norm_le_one _
    exact div_le_div_of_nonneg_right hnum (by positivity)
  have htailnorm : вАЦвИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2)вАЦ вЙ§ Real.pi ^ 2 / 6 - 1 := by
    have hsumtail : Summable (fun i : вДХ => LSeries.term (вЖЧѕЗ) 2 (i + 2)) :=
      (summable_nat_add_iff 2).mpr hsum
    calc вАЦвИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2)вАЦ
        вЙ§ вИС' i : вДХ, вАЦLSeries.term (вЖЧѕЗ) 2 (i + 2)вАЦ := norm_tsum_le_tsum_norm hsumtail.norm
      _ вЙ§ вИС' i : вДХ, (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2 :=
          Summable.tsum_mono hsumtail.norm htails (fun i => htermbound i)
      _ = Real.pi ^ 2 / 6 - 1 := by
          have hfull := hasSum_zeta_two.summable.sum_add_tsum_nat_add 2
          have hh : вИС i вИИ Finset.range 2, (1:вДЭ) / ((i:вДЭ)) ^ 2 = 1 := by
            rw [Finset.sum_range_succ, Finset.sum_range_one]
            norm_num
          rw [hh, hasSum_zeta_two.tsum_eq] at hfull
          have : вИС' (i : вДХ), (1:вДЭ) / ((((i + 2 : вДХ)):вДЭ)) ^ 2
              = Real.pi ^ 2 / 6 - 1 := by
            push_cast at hfull вКҐ
            linarith
          exact this
  -- reverse triangle
  have hLS : LSeries (вЖЧѕЗ) 2 = 1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2) := by
    rw [LSeries, вЖР hsplit, hhead]
  rw [hLS]
  have htri := norm_sub_le (1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2))
    (вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2))
  have hone : вАЦ(1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2))
      - вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2)вАЦ = 1 := by
    rw [show (1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2))
        - вИС' i : вДХ, LSeries.term (вЖЧѕЗ) 2 (i + 2) = 1 by ring]
    norm_num
  rw [hone] at htri
  linarith [htailnorm, htri]

/-- **The normalized log-ratio bound** (SW uniformity brick 16): on the window,
    `logвАЦL(s,ѕЗ)вАЦ вИТ logвАЦL(2,ѕЗ)вАЦ вЙ§ log(N(2+R/ѕГвВА)) вИТ log(2вИТѕА¬≤/6)` вАФ exactly the `M` that
    BorelвАУCarath√©odory takes when applied to `log(L(z)/L(2))` in the Landau assembly. -/
lemma LFunction_log_ratio_bound (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ѕГвВА R : вДЭ) (hѕГвВА : 0 < ѕГвВА) (hR : 0 вЙ§ R) (s : вДВ)
    (hs1 : ѕГвВА вЙ§ s.re) (hs2 : вАЦsвАЦ вЙ§ R) :
    Real.log вАЦDirichletCharacter.LFunction ѕЗ sвАЦ
      - Real.log вАЦDirichletCharacter.LFunction ѕЗ 2вАЦ
      вЙ§ Real.log ((N : вДЭ) * (2 + R / ѕГвВА)) - Real.log (2 - Real.pi ^ 2 / 6) := by
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hM : (1:вДЭ) вЙ§ (N : вДЭ) * (2 + R / ѕГвВА) := by
    have h2 : (2:вДЭ) вЙ§ 2 + R / ѕГвВА := by linarith [div_nonneg hR hѕГвВА.le]
    nlinarith
  have hanchor_pos : (0:вДЭ) < 2 - Real.pi ^ 2 / 6 := by
    nlinarith [Real.pi_lt_d2, Real.pi_pos]
  -- upper piece
  have hup : Real.log вАЦDirichletCharacter.LFunction ѕЗ sвАЦ
      вЙ§ Real.log ((N : вДЭ) * (2 + R / ѕГвВА)) := by
    rcases eq_or_lt_of_le (norm_nonneg (DirichletCharacter.LFunction ѕЗ s)) with h0 | h0
    ¬Ј rw [вЖР h0, Real.log_zero]
      exact Real.log_nonneg hM
    ¬Ј exact Real.log_le_log h0 (LFunction_window_bound N ѕЗ hѕЗ ѕГвВА R hѕГвВА hR s hs1 hs2)
  -- lower piece
  have hlow : Real.log (2 - Real.pi ^ 2 / 6)
      вЙ§ Real.log вАЦDirichletCharacter.LFunction ѕЗ 2вАЦ :=
    Real.log_le_log hanchor_pos (LFunction_two_lower_uniform N ѕЗ hѕЗ)
  linarith

open Finset in
/-- Log-derivative of a linear factor: `logDeriv (¬Ј вИТ ѕБ) z = 1/(z вИТ ѕБ)`. -/
lemma logDeriv_sub_const (ѕБ z : вДВ) (hz : z вЙ† ѕБ) :
    logDeriv (fun w => w - ѕБ) z = 1 / (z - ѕБ) := by
  rw [logDeriv_apply]
  rw [deriv_sub_const, deriv_id'']

open Finset in
/-- **The Landau partial-fraction skeleton** (SW uniformity brick 17): if
    `f = g¬ЈвИП_{ѕБвИИS}(¬ЈвИТѕБ)` with `g(z) вЙ† 0` and `z` off the zero set, then
    `f'/f(z) = g'/g(z) + вИС_{ѕБвИИS} 1/(zвИТѕБ)` вАФ the exact shape Landau's lemma extracts:
    the log-derivative equals the nearby-zero partial fractions plus a BC-bounded rest. -/
lemma logDeriv_factored (g : вДВ вЖТ вДВ) (S : Finset вДВ) (z : вДВ)
    (hg : g z вЙ† 0) (hz : вИА ѕБ вИИ S, z вЙ† ѕБ) (hgd : DifferentiableAt вДВ g z) :
    logDeriv (fun w => g w * вИП ѕБ вИИ S, (w - ѕБ)) z
      = logDeriv g z + вИС ѕБ вИИ S, 1 / (z - ѕБ) := by
  have hfac : вИА ѕБ вИИ S, (fun w : вДВ => w - ѕБ) z вЙ† 0 := by
    intro ѕБ hѕБ
    exact sub_ne_zero_of_ne (hz ѕБ hѕБ)
  have hfacd : вИА ѕБ вИИ S, DifferentiableAt вДВ (fun w : вДВ => w - ѕБ) z := by
    intro ѕБ _
    exact (differentiable_id.sub_const ѕБ).differentiableAt
  rw [logDeriv_mul z hg ?_ hgd ?_]
  ¬Ј congr 1
    rw [show logDeriv (fun w : вДВ => вИП ѕБ вИИ S, (w - ѕБ)) z
        = вИС ѕБ вИИ S, logDeriv (fun w : вДВ => w - ѕБ) z from logDeriv_prod hfac hfacd]
    apply Finset.sum_congr rfl
    intro ѕБ hѕБ
    exact logDeriv_sub_const ѕБ z (hz ѕБ hѕБ)
  ¬Ј rw [Finset.prod_ne_zero_iff]
    intro ѕБ hѕБ
    exact sub_ne_zero_of_ne (hz ѕБ hѕБ)
  ¬Ј apply DifferentiableAt.fun_finsetProd
    intro ѕБ hѕБ
    exact hfacd ѕБ hѕБ

/-- **Log-derivative of the canonical factor** (SW uniformity brick 19):
    `logDeriv (canonicalFactor R w) z = вИТwћД/(R¬≤вИТwћДz) вИТ 1/(zвИТw)` вАФ the per-factor
    contribution in the Landau assembly over `exists_canonicalDecomp`. -/
lemma logDeriv_canonicalFactor (R : вДЭ) (w z : вДВ) (hR : (R:вДВ) вЙ† 0)
    (hN : (R:вДВ) ^ 2 - (starRingEnd вДВ) w * z вЙ† 0) (hD : z вЙ† w) :
    logDeriv (Complex.canonicalFactor R w) z
      = (-(starRingEnd вДВ) w) / ((R:вДВ) ^ 2 - (starRingEnd вДВ) w * z) - 1 / (z - w) := by
  rw [Complex.canonicalFactor_def]
  have hDen : (R:вДВ) * (z - w) вЙ† 0 := mul_ne_zero hR (sub_ne_zero_of_ne hD)
  have hdifN : DifferentiableAt вДВ (fun y : вДВ => (R:вДВ) ^ 2 - (starRingEnd вДВ) w * y) z := by
    fun_prop
  have hdifD : DifferentiableAt вДВ (fun y : вДВ => (R:вДВ) * (y - w)) z := by
    fun_prop
  rw [logDeriv_div z hN hDen hdifN hdifD]
  congr 1
  ¬Ј rw [logDeriv_apply]
    have hder : deriv (fun y : вДВ => (R:вДВ) ^ 2 - (starRingEnd вДВ) w * y) z
        = -(starRingEnd вДВ) w := by
      rw [deriv_fun_sub (by fun_prop) (by fun_prop)]
      simp [deriv_const_mul_field]
    rw [hder]
  ¬Ј have hsplit : logDeriv (fun y : вДВ => (R:вДВ) * (y - w)) z
        = logDeriv (fun y : вДВ => y - w) z := logDeriv_const_mul z (R:вДВ) hR
    rw [hsplit, logDeriv_sub_const w z hD]

open Finset in
open scoped LSeries.notation in
/-- **Anchor on the whole line Re s = 2** (Landau brick L1): `вАЦL(s,ѕЗ)вАЦ вЙ• 2 вИТ ѕА¬≤/6` for
    every modulus, nontrivial character, and s with `Re s = 2` вАФ the normalization lower
    bound at the Landau ball's center `2 + itвВА`. -/
lemma LFunction_anchor_re_two (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (s : вДВ) (hs : s.re = 2) :
    2 - Real.pi ^ 2 / 6 вЙ§ вАЦDirichletCharacter.LFunction ѕЗ sвАЦ := by
  have h2re : (1:вДЭ) < s.re := by rw [hs]; norm_num
  rw [DirichletCharacter.LFunction_eq_LSeries _ h2re]
  have hsum : LSeriesSummable (вЖЧѕЗ) s := by
    apply LSeriesSummable_of_bounded_of_one_lt_re (m := 1) _ h2re
    intro n hn
    exact ѕЗ.norm_le_one _
  have hsplit := hsum.sum_add_tsum_nat_add 2
  have hterm0 : LSeries.term (вЖЧѕЗ) s 0 = 0 := LSeries.term_zero _ _
  have hterm1 : LSeries.term (вЖЧѕЗ) s 1 = 1 := by
    rw [LSeries.term_of_ne_zero one_ne_zero]
    simp
  have hhead : вИС i вИИ Finset.range 2, LSeries.term (вЖЧѕЗ) s i = 1 := by
    rw [Finset.sum_range_succ, Finset.sum_range_one, hterm0, hterm1, zero_add]
  have hbasel : Summable (fun n : вДХ => (1:вДЭ) / ((n:вДЭ)) ^ 2) := hasSum_zeta_two.summable
  have htails : Summable (fun i : вДХ => (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2) := by
    exact_mod_cast (summable_nat_add_iff 2).mpr hbasel
  have htermbound : вИА i : вДХ, вАЦLSeries.term (вЖЧѕЗ) s (i + 2)вАЦ вЙ§ (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2 := by
    intro i
    rw [LSeries.term_of_ne_zero (by omega)]
    rw [norm_div]
    have hpow : вАЦ(((i + 2 : вДХ)) : вДВ) ^ sвАЦ = (((i + 2 : вДХ)):вДЭ) ^ 2 := by
      rw [Complex.norm_natCast_cpow_of_pos (by omega), hs, Real.rpow_two]
    rw [hpow]
    have hnum : вАЦ(вЖЧѕЗ) ((i + 2 : вДХ))вАЦ вЙ§ 1 := ѕЗ.norm_le_one _
    exact div_le_div_of_nonneg_right hnum (by positivity)
  have htailnorm : вАЦвИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2)вАЦ вЙ§ Real.pi ^ 2 / 6 - 1 := by
    have hsumtail : Summable (fun i : вДХ => LSeries.term (вЖЧѕЗ) s (i + 2)) :=
      (summable_nat_add_iff 2).mpr hsum
    calc вАЦвИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2)вАЦ
        вЙ§ вИС' i : вДХ, вАЦLSeries.term (вЖЧѕЗ) s (i + 2)вАЦ := norm_tsum_le_tsum_norm hsumtail.norm
      _ вЙ§ вИС' i : вДХ, (1:вДЭ) / (((i + 2 : вДХ)):вДЭ) ^ 2 :=
          Summable.tsum_mono hsumtail.norm htails (fun i => htermbound i)
      _ = Real.pi ^ 2 / 6 - 1 := by
          have hfull := hasSum_zeta_two.summable.sum_add_tsum_nat_add 2
          have hh : вИС i вИИ Finset.range 2, (1:вДЭ) / ((i:вДЭ)) ^ 2 = 1 := by
            rw [Finset.sum_range_succ, Finset.sum_range_one]
            norm_num
          rw [hh, hasSum_zeta_two.tsum_eq] at hfull
          push_cast at hfull вКҐ
          linarith
  have hLS : LSeries (вЖЧѕЗ) s = 1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2) := by
    rw [LSeries, вЖР hsplit, hhead]
  rw [hLS]
  have htri := norm_sub_le (1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2))
    (вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2))
  have hone : вАЦ(1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2))
      - вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2)вАЦ = 1 := by
    rw [show (1 + вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2))
        - вИС' i : вДХ, LSeries.term (вЖЧѕЗ) s (i + 2) = 1 by ring]
    norm_num
  rw [hone] at htri
  linarith [htailnorm, htri]

open Metric Complex in
/-- **The holomorphic logarithm on a disk** (Landau brick L2): a nonvanishing holomorphic
    function on a ball is `g(c)¬Јexp(h)` for a primitive `h` of `gвА≤/g` with `h(c) = 0`.
    Then `Re h = logвАЦgвАЦ вИТ logвАЦg(c)вАЦ`, which BorelвАУCarath√©odory consumes. -/
lemma exists_exp_eq_of_ne_zero (g : вДВ вЖТ вДВ) (c : вДВ) (R : вДЭ)
    (hg : DifferentiableOn вДВ g (ball c R))
    (hne : вИА z вИИ ball c R, g z вЙ† 0) :
    вИГ h : вДВ вЖТ вДВ, h c = 0 вИІ (вИА z вИИ ball c R, HasDerivAt h (deriv g z / g z) z) вИІ
      вИА z вИИ ball c R, g z = g c * Complex.exp (h z) := by
  by_cases hR : R вЙ§ 0
  ¬Ј exact вЯ®fun _ => 0, rfl, fun z hz => absurd hz (by simp [ball_eq_empty.mpr hR]),
      fun z hz => absurd hz (by simp [ball_eq_empty.mpr hR])вЯ©
  push_neg at hR
  have hcball : c вИИ ball c R := mem_ball_self hR
  -- the logarithmic derivative is holomorphic on the ball
  have hganal : AnalyticOnNhd вДВ g (ball c R) := hg.analyticOnNhd isOpen_ball
  have hderivg : DifferentiableOn вДВ (deriv g) (ball c R) :=
    (hganal.deriv).differentiableOn
  have hѕЖ : DifferentiableOn вДВ (fun z => deriv g z / g z) (ball c R) :=
    hderivg.div hg hne
  -- primitive normalized at c
  obtain вЯ®h, hc0, hdвЯ© := (hѕЖ.isExactOn_ball).with_val_at c 0
  refine вЯ®h, hc0, fun z hz => hd z hz, ?_вЯ©
  -- k := g¬Јexp(вИТh) has zero derivative on the ball
  set k : вДВ вЖТ вДВ := fun z => g z * Complex.exp (-h z) with hk
  have hkderiv : вИА z вИИ ball c R, HasDerivAt k 0 z := by
    intro z hz
    have h1 : HasDerivAt g (deriv g z) z :=
      ((hg.differentiableAt (isOpen_ball.mem_nhds hz))).hasDerivAt
    have h2 : HasDerivAt (fun w => Complex.exp (-h w))
        (Complex.exp (-h z) * (-(deriv g z / g z))) z := by
      have := ((hd z hz).neg).cexp
      simpa using this
    rw [hk]
    have hgѕЖ : g z * (deriv g z / g z) = deriv g z := by
      rw [mul_comm]
      exact div_mul_cancelвВА _ (hne z hz)
    have h3 := h1.mul h2
    have heq : deriv g z * Complex.exp (-h z)
        + g z * (Complex.exp (-h z) * -(deriv g z / g z)) = 0 := by
      calc deriv g z * Complex.exp (-h z)
            + g z * (Complex.exp (-h z) * -(deriv g z / g z))
          = deriv g z * Complex.exp (-h z)
            - Complex.exp (-h z) * (g z * (deriv g z / g z)) := by ring
        _ = 0 := by rw [hgѕЖ]; ring
    exact heq вЦЄ h3
  -- constant on the convex ball
  have hconst : вИА z вИИ ball c R, k z = k c := by
    intro z hz
    apply Convex.is_const_of_fderivWithin_eq_zero (рЭХЬ := вДВ) (convex_ball c R)
    ¬Ј intro x hx
      exact ((hkderiv x hx).differentiableAt).differentiableWithinAt
    ¬Ј intro x hx
      rw [fderivWithin_of_isOpen isOpen_ball hx]
      exact ((hkderiv x hx).hasFDerivAt).fderiv.trans (by ext; simp)
    ¬Ј exact hz
    ¬Ј exact hcball
  intro z hz
  have hkz := hconst z hz
  rw [hk] at hkz
  simp only at hkz
  rw [hc0] at hkz
  simp at hkz
  rw [вЖР hkz, mul_assoc, вЖР Complex.exp_add]
  simp

open Metric Complex in
/-- **The Landau bound for nonvanishing functions** (brick L3): if `g` is holomorphic and
    nonvanishing on `B(c,R)` with `вАЦgвАЦ вЙ§ Mb` there and `вАЦg(c)вАЦ вЙ• ml > 0`, then on the
    quarter ball `вАЦgвА≤/gвАЦ вЙ§ 8(log(Mb/ml)+1)/R` вАФ BorelвАУCarath√©odory on the holomorphic
    logarithm, then the Cauchy estimate. -/
lemma logDeriv_bound_of_ne_zero (g : вДВ вЖТ вДВ) (c : вДВ) (R Mb ml : вДЭ)
    (hR : 0 < R) (hg : DifferentiableOn вДВ g (ball c R))
    (hne : вИА z вИИ ball c R, g z вЙ† 0)
    (hMb : вИА z вИИ ball c R, вАЦg zвАЦ вЙ§ Mb) (hml : 0 < ml) (hlow : ml вЙ§ вАЦg cвАЦ)
    (z : вДВ) (hz : z вИИ ball c (R / 4)) :
    вАЦderiv g z / g zвАЦ вЙ§ 8 * (Real.log (Mb / ml) + 1) / R := by
  obtain вЯ®h, hc0, hd, hexpвЯ© := exists_exp_eq_of_ne_zero g c R hg hne
  set M : вДЭ := Real.log (Mb / ml) + 1 with hM
  have hcball : c вИИ ball c R := mem_ball_self hR
  have hgcpos : 0 < вАЦg cвАЦ := lt_of_lt_of_le hml hlow
  have hMbml : ml вЙ§ Mb := le_trans hlow (hMb c hcball)
  have hM0 : 0 < M := by
    have : (0:вДЭ) вЙ§ Real.log (Mb / ml) :=
      Real.log_nonneg ((one_le_div hml).mpr hMbml)
    linarith
  -- Re h вЙ§ M on the ball
  have hre : вИА w вИИ ball c R, (h w).re вЙ§ M := by
    intro w hw
    have hnorm : вАЦg wвАЦ = вАЦg cвАЦ * Real.exp ((h w).re) := by
      rw [hexp w hw, norm_mul, Complex.norm_exp]
    have hgwpos : 0 < вАЦg wвАЦ := norm_pos_iff.mpr (hne w hw)
    have hlog : Real.log вАЦg wвАЦ = Real.log вАЦg cвАЦ + (h w).re := by
      rw [hnorm, Real.log_mul hgcpos.ne' (Real.exp_ne_zero _), Real.log_exp]
    have h1 : Real.log вАЦg wвАЦ вЙ§ Real.log Mb := Real.log_le_log hgwpos (hMb w hw)
    have h2 : Real.log ml вЙ§ Real.log вАЦg cвАЦ := Real.log_le_log hml hlow
    have h3 : Real.log (Mb / ml) = Real.log Mb - Real.log ml :=
      Real.log_div (by linarith) hml.ne'
    rw [hM]
    linarith
  -- shifted function for center-0 BorelвАУCarath√©odory
  set hвВА : вДВ вЖТ вДВ := fun w => h (c + w) with hhвВА
  have hmem : вИА w : вДВ, w вИИ ball (0:вДВ) R вЖТ c + w вИИ ball c R := by
    intro w hw
    rw [mem_ball] at hw вКҐ
    simpa [dist_eq_norm] using hw
  have hhвВА0 : hвВА 0 = 0 := by
    rw [hhвВА]
    simpa using hc0
  have hhвВАdiff : DifferentiableOn вДВ hвВА (ball 0 R) := by
    intro w hw
    exact (((hd (c + w) (hmem w hw)).differentiableAt).comp w
      ((differentiableAt_const c).add differentiableAt_id)).differentiableWithinAt
  have hhвВАre : Set.MapsTo hвВА (ball 0 R) {w : вДВ | w.re вЙ§ M} := by
    intro w hw
    exact hre (c + w) (hmem w hw)
  -- вАЦhвАЦ вЙ§ 2M on the half ball
  have hhbound : вИА w вИИ ball c (R / 2), вАЦh wвАЦ вЙ§ 2 * M := by
    intro w hw
    have hwc : вАЦw - cвАЦ < R / 2 := by
      rw [mem_ball, dist_eq_norm] at hw
      exact hw
    have hw0 : w - c вИИ ball (0:вДВ) R := by
      rw [mem_ball, dist_zero_right]
      linarith
    have hbc := Complex.borelCaratheodory hM0 hhвВАdiff hhвВАre hR hw0
    have hval : hвВА (w - c) = h w := by
      rw [hhвВА]
      simp
    have hzeroterm : вАЦhвВА 0вАЦ = 0 := by
      rw [hhвВА0, norm_zero]
    rw [hval, hzeroterm] at hbc
    simp only [zero_mul, zero_div, add_zero] at hbc
    have hden : R / 2 вЙ§ R - вАЦw - cвАЦ := by linarith
    have hdenpos : (0:вДЭ) < R - вАЦw - cвАЦ := by linarith [norm_nonneg (w - c)]
    calc вАЦh wвАЦ вЙ§ 2 * M * вАЦw - cвАЦ / (R - вАЦw - cвАЦ) := hbc
      _ вЙ§ 2 * M * (R / 2) / (R / 2) := by
          gcongr <;> linarith
      _ = 2 * M := by field_simp
  -- Cauchy estimate on the quarter ball
  have hzc : вАЦz - cвАЦ < R / 4 := by
    rw [mem_ball, dist_eq_norm] at hz
    exact hz
  have hzball : z вИИ ball c R := by
    rw [mem_ball, dist_eq_norm]
    linarith
  have hr4 : (0:вДЭ) < R / 4 := by linarith
  have hsub : closedBall z (R / 4) вКЖ ball c R := by
    intro y hy
    rw [mem_closedBall, dist_eq_norm] at hy
    rw [mem_ball, dist_eq_norm]
    calc вАЦy - cвАЦ = вАЦ(y - z) + (z - c)вАЦ := by ring_nf
      _ вЙ§ вАЦy - zвАЦ + вАЦz - cвАЦ := norm_add_le _ _
      _ < R / 4 + R / 4 := by linarith
      _ вЙ§ R := by linarith
  have hdiffh : DifferentiableOn вДВ h (ball c R) := by
    intro y hy
    exact ((hd y hy).differentiableAt).differentiableWithinAt
  have hdccl : DiffContOnCl вДВ h (ball z (R / 4)) := by
    apply DifferentiableOn.diffContOnCl
    rw [closure_ball z hr4.ne']
    exact hdiffh.mono hsub
  have hsphere : вИА y вИИ sphere z (R / 4), вАЦh yвАЦ вЙ§ 2 * M := by
    intro y hy
    rw [mem_sphere_iff_norm] at hy
    apply hhbound
    rw [mem_ball, dist_eq_norm]
    calc вАЦy - cвАЦ = вАЦ(y - z) + (z - c)вАЦ := by ring_nf
      _ вЙ§ вАЦy - zвАЦ + вАЦz - cвАЦ := norm_add_le _ _
      _ < R / 4 + R / 4 := by
          rw [hy]
          linarith
      _ = R / 2 := by ring
  have hcauchy := Complex.norm_deriv_le_of_forall_mem_sphere_norm_le hr4 hdccl hsphere
  have hderiv_eq : deriv h z = deriv g z / g z := (hd z hzball).deriv
  rw [hderiv_eq] at hcauchy
  calc вАЦderiv g z / g zвАЦ вЙ§ 2 * M / (R / 4) := hcauchy
    _ = 8 * M / R := by
        field_simp
        ring

open Metric Complex Finset in
/-- Log-derivative of a finite product of powered linear factors:
    `logDeriv (вИП (¬ЈвИТѕБ)^{m ѕБ}) z = вИС m ѕБ/(zвИТѕБ)`. -/
lemma logDeriv_prod_pow (S : Finset вДВ) (m : вДВ вЖТ вДХ) (z : вДВ) (hz : вИА ѕБ вИИ S, z вЙ† ѕБ) :
    logDeriv (fun w => вИП ѕБ вИИ S, (w - ѕБ) ^ (m ѕБ)) z
      = вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ) := by
  have hfac : вИА ѕБ вИИ S, (fun w : вДВ => (w - ѕБ) ^ (m ѕБ)) z вЙ† 0 := by
    intro ѕБ hѕБ
    exact pow_ne_zero _ (sub_ne_zero_of_ne (hz ѕБ hѕБ))
  have hfacd : вИА ѕБ вИИ S, DifferentiableAt вДВ (fun w : вДВ => (w - ѕБ) ^ (m ѕБ)) z := by
    intro ѕБ _
    exact ((differentiable_id.sub_const ѕБ).pow _).differentiableAt
  rw [show logDeriv (fun w : вДВ => вИП ѕБ вИИ S, (w - ѕБ) ^ (m ѕБ)) z
      = вИС ѕБ вИИ S, logDeriv (fun w : вДВ => (w - ѕБ) ^ (m ѕБ)) z from
    logDeriv_prod hfac hfacd]
  apply Finset.sum_congr rfl
  intro ѕБ hѕБ
  have h1 : logDeriv (fun w : вДВ => (w - ѕБ) ^ (m ѕБ)) z
      = (m ѕБ : вДВ) * logDeriv (fun w : вДВ => w - ѕБ) z := by
    have := logDeriv_fun_zpow (f := fun w : вДВ => w - ѕБ) (x := z)
      ((differentiable_id.sub_const ѕБ).differentiableAt) (m ѕБ : вД§)
    simpa using this
  rw [h1, logDeriv_sub_const ѕБ z (hz ѕБ hѕБ)]
  ring

open Metric Complex Finset in
/-- **The conditional Landau lemma** (brick L5): given a factorization
    `f = g¬ЈвИП(¬ЈвИТѕБ)^{m ѕБ}` on `B(c,R)` with `g` holomorphic nonvanishing, `вАЦgвАЦ вЙ§ Mb`,
    `вАЦg(c)вАЦ вЙ• ml`, the log-derivative of `f` on the quarter ball is the zero
    partial-fractions plus an `8(log(Mb/ml)+1)/R` remainder. -/
lemma landau_of_factorization (f g : вДВ вЖТ вДВ) (c : вДВ) (R Mb ml : вДЭ) (S : Finset вДВ)
    (m : вДВ вЖТ вДХ) (hR : 0 < R)
    (hfac : вИА z вИИ ball c R, f z = g z * вИП ѕБ вИИ S, (z - ѕБ) ^ (m ѕБ))
    (hg : DifferentiableOn вДВ g (ball c R)) (hgne : вИА z вИИ ball c R, g z вЙ† 0)
    (hMb : вИА z вИИ ball c R, вАЦg zвАЦ вЙ§ Mb) (hml : 0 < ml) (hlow : ml вЙ§ вАЦg cвАЦ)
    (z : вДВ) (hz : z вИИ ball c (R / 4)) (hzS : вИА ѕБ вИИ S, z вЙ† ѕБ) :
    вАЦlogDeriv f z - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ)вАЦ
      вЙ§ 8 * (Real.log (Mb / ml) + 1) / R := by
  have hzR : z вИИ ball c R := by
    rw [mem_ball] at hz вКҐ
    linarith [hz]
  -- logDeriv f = logDeriv g + partial fractions at z
  have hPne : (fun w : вДВ => вИП ѕБ вИИ S, (w - ѕБ) ^ (m ѕБ)) z вЙ† 0 := by
    rw [Finset.prod_ne_zero_iff]
    intro ѕБ hѕБ
    exact pow_ne_zero _ (sub_ne_zero_of_ne (hzS ѕБ hѕБ))
  have hPd : DifferentiableAt вДВ (fun w : вДВ => вИП ѕБ вИИ S, (w - ѕБ) ^ (m ѕБ)) z := by
    apply DifferentiableAt.fun_finsetProd
    intro ѕБ _
    exact ((differentiable_id.sub_const ѕБ).pow _).differentiableAt
  have hgd : DifferentiableAt вДВ g z :=
    hg.differentiableAt (isOpen_ball.mem_nhds hzR)
  have hlog_eq : logDeriv f z = logDeriv g z + вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ) := by
    have hfeq : f =бґ†[nhds z] (fun w => g w * вИП ѕБ вИИ S, (w - ѕБ) ^ (m ѕБ)) := by
      filter_upwards [isOpen_ball.mem_nhds hzR] with w hw
      exact hfac w hw
    rw [logDeriv_apply, Filter.EventuallyEq.deriv_eq hfeq, hfeq.eq_of_nhds,
      вЖР logDeriv_apply]
    rw [logDeriv_mul z (hgne z hzR) hPne hgd hPd]
    rw [logDeriv_prod_pow S m z hzS]
  rw [hlog_eq]
  rw [show logDeriv g z + вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ)
      - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ) = logDeriv g z by ring]
  rw [logDeriv_apply]
  exact logDeriv_bound_of_ne_zero g c R Mb ml hR hg hgne hMb hml hlow z hz

open Metric in
/-- **Finiteness of zeros on a compact sub-ball** (Landau brick L4a): a holomorphic
    function on `B(c,RвВБ)`, nonzero at the center, has finitely many zeros in
    `closedBall c R` for `R < RвВБ` вАФ zeros are isolated (else the identity theorem
    contradicts `f(c) вЙ† 0`), and a discrete compact set is finite. -/
lemma zeros_finite_of_ne_center (f : вДВ вЖТ вДВ) (c : вДВ) (RвВБ R : вДЭ)
    (hR : 0 < R) (hRR : R < RвВБ)
    (hf : DifferentiableOn вДВ f (ball c RвВБ)) (hfc : f c вЙ† 0) :
    {z | z вИИ closedBall c R вИІ f z = 0}.Finite := by
  have hanal : AnalyticOnNhd вДВ f (ball c RвВБ) := hf.analyticOnNhd isOpen_ball
  have hsub : closedBall c R вКЖ ball c RвВБ := closedBall_subset_ball hRR
  have hcball : c вИИ ball c RвВБ := mem_ball_self (lt_trans hR hRR)
  have hnotloc : вИА z вИИ ball c RвВБ, ¬ђ (вИАбґ† w in nhds z, f w = 0) := by
    intro z hz hev
    have heq : Set.EqOn f 0 (ball c RвВБ) :=
      hanal.eqOn_zero_of_preconnected_of_eventuallyEq_zero
        (convex_ball c RвВБ).isPreconnected hz hev
    exact hfc (heq hcball)
  set Z : Set вДВ := {z | z вИИ closedBall c R вИІ f z = 0} with hZ
  -- Z is compact
  have hfcont : ContinuousOn f (closedBall c R) := (hf.mono hsub).continuousOn
  have hZclosed : IsClosed Z := by
    have h1 : Z = closedBall c R вИ© f вБї¬є' {0} := by
      ext w
      simp [hZ, Set.mem_inter_iff]
    rw [h1]
    exact hfcont.preimage_isClosed_of_isClosed isClosed_closedBall isClosed_singleton
  have hZcompact : IsCompact Z :=
    (isCompact_closedBall c R).of_isClosed_subset hZclosed
      (by intro w hw; exact hw.1)
  -- Z is discrete
  have hZdisc : IsDiscrete Z := by
    rw [isDiscrete_iff_nhdsNE]
    intro z hzZ
    obtain вЯ®hzball, hz0вЯ© := hzZ
    have hzb : z вИИ ball c RвВБ := hsub hzball
    rcases (hanal z hzb).eventually_eq_zero_or_eventually_ne_zero with h | h
    ¬Ј exact absurd h (hnotloc z hzb)
    ¬Ј rw [Filter.inf_principal_eq_bot]
      filter_upwards [h] with w hw
      intro hwZ
      exact hw hwZ.2
  exact hZcompact.finite hZdisc

open Metric in
/-- **The global one-zero peel** (Landau brick L4b): if `f` is holomorphic on open `U`
    with `analyticOrderAt f ѕБ = n` at `ѕБ вИИ U`, then `f = (¬ЈвИТѕБ)^n ¬Ј g` on ALL of `U`
    with `g` holomorphic on `U` and `g(ѕБ) вЙ† 0` вАФ the local order factorization glued
    with the direct quotient off `ѕБ`. -/
lemma peel_zero (f : вДВ вЖТ вДВ) (U : Set вДВ) (hU : IsOpen U) (hf : DifferentiableOn вДВ f U)
    (ѕБ : вДВ) (hѕБ : ѕБ вИИ U) (n : вДХ) (hn : analyticOrderAt f ѕБ = n) :
    вИГ g : вДВ вЖТ вДВ, DifferentiableOn вДВ g U вИІ g ѕБ вЙ† 0 вИІ
      вИА z вИИ U, f z = (z - ѕБ) ^ n * g z := by
  have hanal : AnalyticOnNhd вДВ f U := hf.analyticOnNhd hU
  obtain вЯ®gвВА, hgвВАanal, hgвВАne, hgвВАevвЯ© :=
    ((hanal ѕБ hѕБ).analyticOrderAt_eq_natCast).mp hn
  classical
  set g : вДВ вЖТ вДВ := fun z => if z = ѕБ then gвВА ѕБ else f z / (z - ѕБ) ^ n with hg
  have hg_near : g =бґ†[nhds ѕБ] gвВА := by
    filter_upwards [hgвВАev] with z hz
    by_cases hzѕБ : z = ѕБ
    ¬Ј simp [hg, hzѕБ]
    ¬Ј simp only [hg, if_neg hzѕБ]
      rw [hz, smul_eq_mul]
      field_simp [sub_ne_zero_of_ne hzѕБ]
  have hgѕБ : g ѕБ = gвВА ѕБ := by
    simp [hg]
  refine вЯ®g, ?_, by rw [hgѕБ]; exact hgвВАne, ?_вЯ©
  ¬Ј -- differentiability
    intro z hz
    by_cases hzѕБ : z = ѕБ
    ¬Ј subst hzѕБ
      exact ((hgвВАanal.differentiableAt).congr_of_eventuallyEq hg_near
        ).differentiableWithinAt
    ¬Ј have hev : g =бґ†[nhds z] (fun w => f w / (w - ѕБ) ^ n) := by
        have hopen : IsOpen (U \ {ѕБ}) := hU.sdiff isClosed_singleton
        filter_upwards [hopen.mem_nhds вЯ®hz, by simpa using hzѕБвЯ©] with w hw
        simp only [hg, if_neg (show w вЙ† ѕБ by simpa using hw.2)]
      have hd : DifferentiableAt вДВ (fun w => f w / (w - ѕБ) ^ n) z := by
        apply DifferentiableAt.div
        ¬Ј exact hf.differentiableAt (hU.mem_nhds hz)
        ¬Ј exact ((differentiable_id.sub_const ѕБ).pow n).differentiableAt
        ¬Ј exact pow_ne_zero _ (sub_ne_zero_of_ne hzѕБ)
      exact (hd.congr_of_eventuallyEq hev).differentiableWithinAt
  ¬Ј -- factorization
    intro z hz
    by_cases hzѕБ : z = ѕБ
    ¬Ј rw [hzѕБ]
      rcases Nat.eq_zero_or_pos n with rfl | hn0
      ¬Ј have h0 := hgвВАev.self_of_nhds
        simp only [pow_zero, one_mul] at h0 вКҐ
        simp [hg, h0]
      ¬Ј have hfѕБ : f ѕБ = 0 := by
          have := hgвВАev.self_of_nhds
          rw [this]
          simp [zero_pow hn0.ne']
        rw [hfѕБ, sub_self, zero_pow hn0.ne', zero_mul]
    ¬Ј simp only [hg, if_neg hzѕБ]
      field_simp [pow_ne_zero n (sub_ne_zero_of_ne hzѕБ)]

open Metric in
/-- **The full zero factorization on a compact sub-ball** (Landau brick L4c): a
    holomorphic `f` on `B(c,RвВБ)`, nonzero at the center, factors on the whole ball as
    `f = g¬ЈвИП_{ѕБвИИS}(¬ЈвИТѕБ)^{m ѕБ}` with `S вКЖ closedBall c R` its zeros there, `m ѕБ вЙ• 1`,
    and `g` holomorphic, nonvanishing on `closedBall c R`. Induction on the number of
    zeros with the one-zero peel. -/
lemma exists_zero_factorization (c : вДВ) (RвВБ R : вДЭ) (hR : 0 < R) (hRR : R < RвВБ) :
    вИА (k : вДХ) (f : вДВ вЖТ вДВ), DifferentiableOn вДВ f (ball c RвВБ) вЖТ f c вЙ† 0 вЖТ
    вИА (hfin : {z | z вИИ closedBall c R вИІ f z = 0}.Finite), hfin.toFinset.card = k вЖТ
    вИГ (S : Finset вДВ) (m : вДВ вЖТ вДХ) (g : вДВ вЖТ вДВ),
      (вИА ѕБ вИИ S, ѕБ вИИ closedBall c R вИІ f ѕБ = 0) вИІ
      DifferentiableOn вДВ g (ball c RвВБ) вИІ
      (вИА z вИИ closedBall c R, g z вЙ† 0) вИІ
      (вИА z вИИ ball c RвВБ, f z = g z * вИП ѕБ вИИ S, (z - ѕБ) ^ (m ѕБ)) := by
  intro k
  induction k with
  | zero =>
    intro f hf hfc hfin hcard
    refine вЯ®вИЕ, fun _ => 0, f, by simp, hf, ?_, by simpвЯ©
    intro z hz
    intro hz0
    have : z вИИ hfin.toFinset := by
      rw [Set.Finite.mem_toFinset]
      exact вЯ®hz, hz0вЯ©
    rw [Finset.card_eq_zero] at hcard
    rw [hcard] at this
    simp at this
  | succ k ih =>
    intro f hf hfc hfin hcard
    -- pick a zero ѕБ
    have hne : hfin.toFinset.Nonempty := by
      rw [вЖР Finset.card_pos, hcard]
      omega
    obtain вЯ®ѕБ, hѕБmemвЯ© := hne
    rw [Set.Finite.mem_toFinset] at hѕБmem
    obtain вЯ®hѕБball, hѕБ0вЯ© := hѕБmem
    have hѕБball' : ѕБ вИИ ball c RвВБ := closedBall_subset_ball hRR hѕБball
    have hcball : c вИИ ball c RвВБ := mem_ball_self (lt_trans hR hRR)
    -- the order at ѕБ is a positive natural
    have hanal : AnalyticOnNhd вДВ f (ball c RвВБ) := hf.analyticOnNhd isOpen_ball
    have hnotloc : ¬ђ (вИАбґ† w in nhds ѕБ, f w = 0) := by
      intro hev
      have heq : Set.EqOn f 0 (ball c RвВБ) :=
        hanal.eqOn_zero_of_preconnected_of_eventuallyEq_zero
          (convex_ball c RвВБ).isPreconnected hѕБball' hev
      exact hfc (heq hcball)
    have hordtop : analyticOrderAt f ѕБ вЙ† вК§ := by
      intro htop
      exact hnotloc (analyticOrderAt_eq_top.mp htop)
    set n : вДХ := analyticOrderNatAt f ѕБ with hn
    have hncast : (n : вДХвИЮ) = analyticOrderAt f ѕБ := Nat.cast_analyticOrderNatAt hordtop
    have hn0 : 0 < n := by
      rcases Nat.eq_zero_or_pos n with h0 | h
      ¬Ј exfalso
        have hoz : analyticOrderAt f ѕБ = ((0 : вДХ) : вДХвИЮ) := by
          rw [вЖР hncast, h0]
        rw [Nat.cast_zero, analyticOrderAt_eq_zero] at hoz
        rcases hoz with h | h
        ¬Ј exact h (hanal ѕБ hѕБball')
        ¬Ј exact h hѕБ0
      ¬Ј exact h
    -- peel
    obtain вЯ®gвВБ, hgвВБdiff, hgвВБѕБ, hgвВБfacвЯ© :=
      peel_zero f (ball c RвВБ) isOpen_ball hf ѕБ hѕБball' n hncast.symm
    -- gвВБ has one fewer zero
    have hgвВБc : gвВБ c вЙ† 0 := by
      intro h0
      apply hfc
      rw [hgвВБfac c hcball, h0, mul_zero]
    have hZeq : {z | z вИИ closedBall c R вИІ gвВБ z = 0}
        = {z | z вИИ closedBall c R вИІ f z = 0} \ {ѕБ} := by
      ext w
      simp only [Set.mem_setOf_eq, Set.mem_diff, Set.mem_singleton_iff]
      constructor
      ¬Ј rintro вЯ®hwball, hw0вЯ©
        refine вЯ®вЯ®hwball, ?_вЯ©, ?_вЯ©
        ¬Ј rw [hgвВБfac w (closedBall_subset_ball hRR hwball), hw0, mul_zero]
        ¬Ј intro hwѕБ
          rw [hwѕБ] at hw0
          exact hgвВБѕБ hw0
      ¬Ј rintro вЯ®вЯ®hwball, hw0вЯ©, hwѕБвЯ©
        refine вЯ®hwball, ?_вЯ©
        have := hgвВБfac w (closedBall_subset_ball hRR hwball)
        rw [this] at hw0
        rcases mul_eq_zero.mp hw0 with h | h
        ¬Ј exact absurd h (pow_ne_zero _ (sub_ne_zero_of_ne hwѕБ))
        ¬Ј exact h
    have hfinвВБ : {z | z вИИ closedBall c R вИІ gвВБ z = 0}.Finite := by
      rw [hZeq]
      exact hfin.diff
    have hcardвВБ : hfinвВБ.toFinset.card = k := by
      have htf : hfinвВБ.toFinset = hfin.toFinset.erase ѕБ := by
        ext w
        simp only [Set.Finite.mem_toFinset, Finset.mem_erase]
        rw [hZeq]
        simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_setOf_eq]
        tauto
      rw [htf, Finset.card_erase_of_mem (by
        rw [Set.Finite.mem_toFinset]
        exact вЯ®hѕБball, hѕБ0вЯ©), hcard]
      omega
    -- induction hypothesis on gвВБ
    obtain вЯ®SвВБ, mвВБ, g, hSвВБ, hgdiff, hgne, hgfacвЯ© := ih gвВБ hgвВБdiff hgвВБc hfinвВБ hcardвВБ
    -- ѕБ is not in SвВБ
    have hѕБSвВБ : ѕБ вИЙ SвВБ := by
      intro hmem
      have := (hSвВБ ѕБ hmem).2
      exact hgвВБѕБ this
    refine вЯ®insert ѕБ SвВБ, fun x => if x = ѕБ then n else mвВБ x, g, ?_, hgdiff, hgne, ?_вЯ©
    ¬Ј intro ѕГ hѕГ
      rcases Finset.mem_insert.mp hѕГ with rfl | hѕГвВБ
      ¬Ј exact вЯ®hѕБball, hѕБ0вЯ©
      ¬Ј obtain вЯ®hѕГball, hѕГ0вЯ© := hSвВБ ѕГ hѕГвВБ
        refine вЯ®hѕГball, ?_вЯ©
        rw [hgвВБfac ѕГ (closedBall_subset_ball hRR hѕГball), hѕГ0, mul_zero]
    ¬Ј intro z hz
      rw [hgвВБfac z hz, hgfac z hz, Finset.prod_insert hѕБSвВБ]
      dsimp only
      rw [if_pos rfl]
      have hcongr : вИП ѕГ вИИ SвВБ, (z - ѕГ) ^ (if ѕГ = ѕБ then n else mвВБ ѕГ)
          = вИП ѕГ вИИ SвВБ, (z - ѕГ) ^ (mвВБ ѕГ) := by
        apply Finset.prod_congr rfl
        intro ѕГ hѕГ
        rw [if_neg (by
          intro h
          rw [h] at hѕГ
          exact hѕБSвВБ hѕГ)]
      rw [hcongr]
      ring

open Metric in
/-- **Order preservation off the peeled zero** (Landau brick L4d-bridge): if
    `f = (¬ЈвИТѕБ)^n¬Јg` near `ѕГ вЙ† ѕБ`, the analytic orders of `f` and `g` at `ѕГ` agree. -/
lemma analyticOrderAt_peel (f g : вДВ вЖТ вДВ) (ѕБ ѕГ : вДВ) (n : вДХ) (hѕГѕБ : ѕГ вЙ† ѕБ)
    (hg : AnalyticAt вДВ g ѕГ) (hev : вИАбґ† z in nhds ѕГ, f z = (z - ѕБ) ^ n * g z) :
    analyticOrderAt f ѕГ = analyticOrderAt g ѕГ := by
  have hpow : AnalyticAt вДВ (fun z : вДВ => (z - ѕБ) ^ n) ѕГ :=
    ((analyticAt_id.sub analyticAt_const).pow n)
  have h1 : analyticOrderAt f ѕГ
      = analyticOrderAt (fun z => (z - ѕБ) ^ n * g z) ѕГ :=
    analyticOrderAt_congr hev
  have h2 : analyticOrderAt (fun z => (z - ѕБ) ^ n * g z) ѕГ
      = analyticOrderAt (fun z : вДВ => (z - ѕБ) ^ n) ѕГ + analyticOrderAt g ѕГ := by
    have h := analyticOrderAt_smul (f := fun z : вДВ => (z - ѕБ) ^ n) (g := g)
      (zвВА := ѕГ) hpow hg
    simp only [smul_eq_mul] at h
    exact h
  have h3 : analyticOrderAt (fun z : вДВ => (z - ѕБ) ^ n) ѕГ = 0 := by
    rw [analyticOrderAt_eq_zero]
    right
    exact pow_ne_zero _ (sub_ne_zero_of_ne hѕГѕБ)
  rw [h1, h2, h3, zero_add]

open Metric in
/-- **The full zero factorization on a compact sub-ball** (Landau brick L4c): a
    holomorphic `f` on `B(c,RвВБ)`, nonzero at the center, factors on the whole ball as
    `f = g¬ЈвИП_{ѕБвИИS}(¬ЈвИТѕБ)^{m ѕБ}` with `S вКЖ closedBall c R` its zeros there, `m ѕБ вЙ• 1`,
    and `g` holomorphic, nonvanishing on `closedBall c R`. Induction on the number of
    zeros with the one-zero peel. -/
lemma exists_zero_factorization' (c : вДВ) (RвВБ R : вДЭ) (hR : 0 < R) (hRR : R < RвВБ) :
    вИА (k : вДХ) (f : вДВ вЖТ вДВ), DifferentiableOn вДВ f (ball c RвВБ) вЖТ f c вЙ† 0 вЖТ
    вИА (hfin : {z | z вИИ closedBall c R вИІ f z = 0}.Finite), hfin.toFinset.card = k вЖТ
    вИГ (S : Finset вДВ) (m : вДВ вЖТ вДХ) (g : вДВ вЖТ вДВ),
      (вИА ѕБ вИИ S, ѕБ вИИ closedBall c R вИІ f ѕБ = 0) вИІ
      (вИА ѕБ вИИ S, m ѕБ = analyticOrderNatAt f ѕБ) вИІ
      DifferentiableOn вДВ g (ball c RвВБ) вИІ
      (вИА z вИИ closedBall c R, g z вЙ† 0) вИІ
      (вИА z вИИ ball c RвВБ, f z = g z * вИП ѕБ вИИ S, (z - ѕБ) ^ (m ѕБ)) := by
  intro k
  induction k with
  | zero =>
    intro f hf hfc hfin hcard
    refine вЯ®вИЕ, fun _ => 0, f, by simp, by simp, hf, ?_, by simpвЯ©
    intro z hz
    intro hz0
    have : z вИИ hfin.toFinset := by
      rw [Set.Finite.mem_toFinset]
      exact вЯ®hz, hz0вЯ©
    rw [Finset.card_eq_zero] at hcard
    rw [hcard] at this
    simp at this
  | succ k ih =>
    intro f hf hfc hfin hcard
    -- pick a zero ѕБ
    have hne : hfin.toFinset.Nonempty := by
      rw [вЖР Finset.card_pos, hcard]
      omega
    obtain вЯ®ѕБ, hѕБmemвЯ© := hne
    rw [Set.Finite.mem_toFinset] at hѕБmem
    obtain вЯ®hѕБball, hѕБ0вЯ© := hѕБmem
    have hѕБball' : ѕБ вИИ ball c RвВБ := closedBall_subset_ball hRR hѕБball
    have hcball : c вИИ ball c RвВБ := mem_ball_self (lt_trans hR hRR)
    -- the order at ѕБ is a positive natural
    have hanal : AnalyticOnNhd вДВ f (ball c RвВБ) := hf.analyticOnNhd isOpen_ball
    have hnotloc : ¬ђ (вИАбґ† w in nhds ѕБ, f w = 0) := by
      intro hev
      have heq : Set.EqOn f 0 (ball c RвВБ) :=
        hanal.eqOn_zero_of_preconnected_of_eventuallyEq_zero
          (convex_ball c RвВБ).isPreconnected hѕБball' hev
      exact hfc (heq hcball)
    have hordtop : analyticOrderAt f ѕБ вЙ† вК§ := by
      intro htop
      exact hnotloc (analyticOrderAt_eq_top.mp htop)
    set n : вДХ := analyticOrderNatAt f ѕБ with hn
    have hncast : (n : вДХвИЮ) = analyticOrderAt f ѕБ := Nat.cast_analyticOrderNatAt hordtop
    have hn0 : 0 < n := by
      rcases Nat.eq_zero_or_pos n with h0 | h
      ¬Ј exfalso
        have hoz : analyticOrderAt f ѕБ = ((0 : вДХ) : вДХвИЮ) := by
          rw [вЖР hncast, h0]
        rw [Nat.cast_zero, analyticOrderAt_eq_zero] at hoz
        rcases hoz with h | h
        ¬Ј exact h (hanal ѕБ hѕБball')
        ¬Ј exact h hѕБ0
      ¬Ј exact h
    -- peel
    obtain вЯ®gвВБ, hgвВБdiff, hgвВБѕБ, hgвВБfacвЯ© :=
      peel_zero f (ball c RвВБ) isOpen_ball hf ѕБ hѕБball' n hncast.symm
    -- gвВБ has one fewer zero
    have hgвВБc : gвВБ c вЙ† 0 := by
      intro h0
      apply hfc
      rw [hgвВБfac c hcball, h0, mul_zero]
    have hZeq : {z | z вИИ closedBall c R вИІ gвВБ z = 0}
        = {z | z вИИ closedBall c R вИІ f z = 0} \ {ѕБ} := by
      ext w
      simp only [Set.mem_setOf_eq, Set.mem_diff, Set.mem_singleton_iff]
      constructor
      ¬Ј rintro вЯ®hwball, hw0вЯ©
        refine вЯ®вЯ®hwball, ?_вЯ©, ?_вЯ©
        ¬Ј rw [hgвВБfac w (closedBall_subset_ball hRR hwball), hw0, mul_zero]
        ¬Ј intro hwѕБ
          rw [hwѕБ] at hw0
          exact hgвВБѕБ hw0
      ¬Ј rintro вЯ®вЯ®hwball, hw0вЯ©, hwѕБвЯ©
        refine вЯ®hwball, ?_вЯ©
        have := hgвВБfac w (closedBall_subset_ball hRR hwball)
        rw [this] at hw0
        rcases mul_eq_zero.mp hw0 with h | h
        ¬Ј exact absurd h (pow_ne_zero _ (sub_ne_zero_of_ne hwѕБ))
        ¬Ј exact h
    have hfinвВБ : {z | z вИИ closedBall c R вИІ gвВБ z = 0}.Finite := by
      rw [hZeq]
      exact hfin.diff
    have hcardвВБ : hfinвВБ.toFinset.card = k := by
      have htf : hfinвВБ.toFinset = hfin.toFinset.erase ѕБ := by
        ext w
        simp only [Set.Finite.mem_toFinset, Finset.mem_erase]
        rw [hZeq]
        simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_setOf_eq]
        tauto
      rw [htf, Finset.card_erase_of_mem (by
        rw [Set.Finite.mem_toFinset]
        exact вЯ®hѕБball, hѕБ0вЯ©), hcard]
      omega
    -- induction hypothesis on gвВБ
    obtain вЯ®SвВБ, mвВБ, g, hSвВБ, hmвВБ, hgdiff, hgne, hgfacвЯ© := ih gвВБ hgвВБdiff hgвВБc hfinвВБ hcardвВБ
    -- ѕБ is not in SвВБ
    have hѕБSвВБ : ѕБ вИЙ SвВБ := by
      intro hmem
      have := (hSвВБ ѕБ hmem).2
      exact hgвВБѕБ this
    refine вЯ®insert ѕБ SвВБ, fun x => if x = ѕБ then n else mвВБ x, g, ?_, ?_, hgdiff, hgne, ?_вЯ©
    ¬Ј intro ѕГ hѕГ
      rcases Finset.mem_insert.mp hѕГ with rfl | hѕГвВБ
      ¬Ј exact вЯ®hѕБball, hѕБ0вЯ©
      ¬Ј obtain вЯ®hѕГball, hѕГ0вЯ© := hSвВБ ѕГ hѕГвВБ
        refine вЯ®hѕГball, ?_вЯ©
        rw [hgвВБfac ѕГ (closedBall_subset_ball hRR hѕГball), hѕГ0, mul_zero]
    ¬Ј intro ѕГ hѕГ
      rcases Finset.mem_insert.mp hѕГ with rfl | hѕГвВБ
      ¬Ј dsimp only
        rw [if_pos rfl, hn]
      ¬Ј have hѕГѕБ : ѕГ вЙ† ѕБ := by
          intro h
          rw [h] at hѕГвВБ
          exact hѕБSвВБ hѕГвВБ
        dsimp only
        rw [if_neg hѕГѕБ, hmвВБ ѕГ hѕГвВБ]
        have hѕГball' : ѕГ вИИ ball c RвВБ :=
          closedBall_subset_ball hRR (hSвВБ ѕГ hѕГвВБ).1
        have hord : analyticOrderAt f ѕГ = analyticOrderAt gвВБ ѕГ := by
          apply analyticOrderAt_peel f gвВБ ѕБ ѕГ n hѕГѕБ
            ((hgвВБdiff.analyticOnNhd isOpen_ball) ѕГ hѕГball')
          filter_upwards [isOpen_ball.mem_nhds hѕГball'] with w hw
          exact hgвВБfac w hw
        rw [analyticOrderNatAt, analyticOrderNatAt, hord]
    ¬Ј intro z hz
      rw [hgвВБfac z hz, hgfac z hz, Finset.prod_insert hѕБSвВБ]
      dsimp only
      rw [if_pos rfl]
      have hcongr : вИП ѕГ вИИ SвВБ, (z - ѕГ) ^ (if ѕГ = ѕБ then n else mвВБ ѕГ)
          = вИП ѕГ вИИ SвВБ, (z - ѕГ) ^ (mвВБ ѕГ) := by
        apply Finset.prod_congr rfl
        intro ѕГ hѕГ
        rw [if_neg (by
          intro h
          rw [h] at hѕГ
          exact hѕБSвВБ hѕГ)]
      rw [hcongr]
      ring

open Metric MeromorphicOn in
/-- **The Jensen bridge** (Landau brick L4d): the multiplicity sum of a zero Finset with
    `m ѕБ = analyticOrderNatAt f ѕБ` in `closedBall c r` is bounded by
    `log(M/вАЦf(c)вАЦ)/log(R/r)` вАФ Mathlib's `AnalyticOnNhd.sum_divisor_le` pulled through
    the divisorвЖФorder dictionary. -/
lemma sum_m_le_jensen (f : вДВ вЖТ вДВ) (c : вДВ) (r R M : вДЭ) (hr : 0 < r) (hrR : r < R)
    (hM : 1 вЙ§ M) (hвВБf : AnalyticOnNhd вДВ f (closedBall c R)) (hвВВf : f c вЙ† 0)
    (fbound : вИА z вИИ sphere c R, вАЦf zвАЦ вЙ§ M)
    (S : Finset вДВ) (m : вДВ вЖТ вДХ)
    (hS : вИА ѕБ вИИ S, ѕБ вИИ closedBall c r вИІ f ѕБ = 0)
    (hm : вИА ѕБ вИИ S, m ѕБ = analyticOrderNatAt f ѕБ) :
    (вИС ѕБ вИИ S, (m ѕБ : вДЭ)) вЙ§ Real.log (M / вАЦf cвАЦ) / Real.log (R / r) := by
  have hrabs : |r| = r := abs_of_pos hr
  have hRabs : |R| = R := abs_of_pos (lt_trans hr hrR)
  have hвВБf' : AnalyticOnNhd вДВ f (closedBall c |R|) := by rwa [hRabs]
  have fbound' : вИА z вИИ sphere c |R|, вАЦf zвАЦ вЙ§ M := by rwa [hRabs]
  have hjensen := AnalyticOnNhd.sum_divisor_le (c := c) (r := r) (R := R) (M := M)
    (by rwa [hrabs]) (by rwa [hrabs, hRabs]) hM hвВБf' hвВВf fbound'
  -- orders are finite everywhere on the closed ball
  have hordtop : вИА z вИИ closedBall c R, analyticOrderAt f z вЙ† вК§ := by
    intro z hz htop
    rw [analyticOrderAt_eq_top] at htop
    have heq : Set.EqOn f 0 (closedBall c R) :=
      hвВБf.eqOn_zero_of_preconnected_of_eventuallyEq_zero
        (convex_closedBall c R).isPreconnected hz htop
    exact hвВВf (heq (mem_closedBall_self (by linarith)))
  -- per-point: divisor = m on S
  have hdiv : вИА ѕБ вИИ S, MeromorphicOn.divisor f (closedBall c |r|) ѕБ = (m ѕБ : вД§) := by
    intro ѕБ hѕБ
    obtain вЯ®hѕБball, hѕБ0вЯ© := hS ѕБ hѕБ
    have hѕБball' : ѕБ вИИ closedBall c |r| := by rwa [hrabs]
    have hвВБf'' : AnalyticOnNhd вДВ f (closedBall c |r|) := by
      apply hвВБf.mono
      rw [hrabs]
      gcongr
    rw [hвВБf''.divisor_apply hѕБball']
    have hne : analyticOrderAt f ѕБ вЙ† вК§ :=
      hordtop ѕБ (by rw [hrabs] at hѕБball'; exact closedBall_subset_closedBall hrR.le hѕБball')
    rw [hm ѕБ hѕБ, analyticOrderNatAt]
    lift analyticOrderAt f ѕБ to вДХ using hne with n hn
    simp
  -- the finsum dominates the Finset sum
  set D := MeromorphicOn.divisor f (closedBall c |r|) with hD
  have hfin : (Function.support (D : вДВ вЖТ вД§)).Finite := by
    have := D.finiteSupport (isCompact_closedBall c |r|)
    exact this
  have hnonneg : вИА u, 0 вЙ§ D u := by
    intro u
    by_cases hu : u вИИ closedBall c |r|
    ¬Ј have hвВБf'' : AnalyticOnNhd вДВ f (closedBall c |r|) := by
        apply hвВБf.mono
        rw [hrabs]
        gcongr
      rw [hвВБf''.divisor_apply hu]
      cases hord : analyticOrderAt f u with
      | top => simp
      | coe n => simp
    ¬Ј rcases eq_or_ne (D u) 0 with h | h
      ¬Ј rw [h]
      ¬Ј exact absurd (D.supportWithinDomain (Function.mem_support.mpr h)) hu
  have hSsub : S вКЖ hfin.toFinset := by
    intro ѕБ hѕБ
    rw [Set.Finite.mem_toFinset, Function.mem_support]
    rw [hdiv ѕБ hѕБ]
    obtain вЯ®hѕБball, hѕБ0вЯ© := hS ѕБ hѕБ
    -- m ѕБ вЙ• 1 since f ѕБ = 0
    have hord1 : analyticOrderAt f ѕБ вЙ† 0 := by
      intro h0
      rw [analyticOrderAt_eq_zero] at h0
      rcases h0 with h | h
      ¬Ј exact h (hвВБf ѕБ (closedBall_subset_closedBall hrR.le hѕБball))
      ¬Ј exact h hѕБ0
    have hne : analyticOrderAt f ѕБ вЙ† вК§ :=
      hordtop ѕБ (closedBall_subset_closedBall hrR.le hѕБball)
    rw [hm ѕБ hѕБ, analyticOrderNatAt]
    intro hc
    apply hord1
    have : (analyticOrderAt f ѕБ).toNat = 0 := by exact_mod_cast hc
    rw [вЖР ENat.coe_toNat hne, this]
    rfl
  have hsum_le : (вИС ѕБ вИИ S, (m ѕБ : вД§)) вЙ§ вИСбґ† u, D u := by
    rw [finsum_eq_sum (D : вДВ вЖТ вД§) hfin]
    calc вИС ѕБ вИИ S, (m ѕБ : вД§) = вИС ѕБ вИИ S, D ѕБ := by
          apply Finset.sum_congr rfl
          intro ѕБ hѕБ
          rw [hdiv ѕБ hѕБ]
      _ вЙ§ вИС u вИИ hfin.toFinset, D u :=
          Finset.sum_le_sum_of_subset_of_nonneg hSsub (fun u _ _ => hnonneg u)
  calc (вИС ѕБ вИИ S, (m ѕБ : вДЭ)) = ((вИС ѕБ вИИ S, (m ѕБ : вД§) : вД§) : вДЭ) := by push_cast; rfl
    _ вЙ§ ((вИСбґ† u, D u : вД§) : вДЭ) := by exact_mod_cast hsum_le
    _ вЙ§ Real.log (M / вАЦf cвАЦ) / Real.log (R / r) := by exact_mod_cast hjensen

open Metric in
/-- **The peeled function's bounds** (Landau brick L4e): from `f = g¬ЈвИП(zвИТѕБ)^{m_ѕБ}` with
    zeros in `BћД(c,r)`, `вАЦfвАЦ вЙ§ Mb` on `B(c,RвВБ)`, `вАЦf(c)вАЦ вЙ• ml`: the anchor
    `вАЦg(c)вАЦ вЙ• ml/r^K` and, by the maximum principle through the `RвВВ`-sphere (every
    factor `вЙ• RвВВвИТr` there), the sup `вАЦgвАЦ вЙ§ Mb/(RвВВвИТr)^K` on `BћД(c,RвВВ)`, `K = ќ£ m_ѕБ`. -/
lemma peeled_g_bounds (f g : вДВ вЖТ вДВ) (c : вДВ) (RвВБ r RвВВ Mb ml : вДЭ) (S : Finset вДВ)
    (m : вДВ вЖТ вДХ) (hr : 0 < r) (hrRвВВ : r < RвВВ) (hRвВВRвВБ : RвВВ < RвВБ)
    (hfb : вИА z вИИ ball c RвВБ, вАЦf zвАЦ вЙ§ Mb) (hml : 0 < ml) (hmlc : ml вЙ§ вАЦf cвАЦ)
    (hS : вИА ѕБ вИИ S, ѕБ вИИ closedBall c r вИІ f ѕБ = 0)
    (hgdiff : DifferentiableOn вДВ g (ball c RвВБ))
    (hfac : вИА z вИИ ball c RвВБ, f z = g z * вИП ѕБ вИИ S, (z - ѕБ) ^ (m ѕБ)) :
    ml / r ^ (вИС ѕБ вИИ S, m ѕБ) вЙ§ вАЦg cвАЦ вИІ
    вИА z вИИ closedBall c RвВВ, вАЦg zвАЦ вЙ§ Mb / (RвВВ - r) ^ (вИС ѕБ вИИ S, m ѕБ) := by
  set K : вДХ := вИС ѕБ вИИ S, m ѕБ with hK
  have hcball : c вИИ ball c RвВБ := mem_ball_self (by linarith)
  have hMb0 : 0 вЙ§ Mb := le_trans (norm_nonneg _) (hfb c hcball)
  have hfc0 : f c вЙ† 0 := by
    intro h
    rw [h, norm_zero] at hmlc
    linarith
  have hnorm_eq : вИА w вИИ ball c RвВБ, вАЦf wвАЦ = вАЦg wвАЦ * вИП ѕБ вИИ S, вАЦw - ѕБвАЦ ^ (m ѕБ) := by
    intro w hw
    rw [hfac w hw, norm_mul, norm_prod]
    congr 1
    exact Finset.prod_congr rfl (fun ѕБ _ => norm_pow _ _)
  constructor
  ¬Ј -- anchor
    have hcѕБ : вИА ѕБ вИИ S, c вЙ† ѕБ := by
      intro ѕБ hѕБ hc
      exact hfc0 (hc вЦЄ (hS ѕБ hѕБ).2)
    have hprod_pos : (0:вДЭ) < вИП ѕБ вИИ S, вАЦc - ѕБвАЦ ^ (m ѕБ) :=
      Finset.prod_pos (fun ѕБ hѕБ =>
        pow_pos (norm_pos_iff.mpr (sub_ne_zero_of_ne (hcѕБ ѕБ hѕБ))) _)
    have hprod_le : вИП ѕБ вИИ S, вАЦc - ѕБвАЦ ^ (m ѕБ) вЙ§ r ^ K := by
      rw [hK, вЖР Finset.prod_pow_eq_pow_sum]
      apply Finset.prod_le_prod
      ¬Ј intro ѕБ _
        positivity
      ¬Ј intro ѕБ hѕБ
        apply pow_le_pow_leftвВА (norm_nonneg _)
        have := (hS ѕБ hѕБ).1
        rwa [mem_closedBall, dist_comm, dist_eq_norm] at this
    have hgc_eq : вАЦg cвАЦ = вАЦf cвАЦ / вИП ѕБ вИИ S, вАЦc - ѕБвАЦ ^ (m ѕБ) := by
      rw [hnorm_eq c hcball]
      field_simp
    rw [hgc_eq]
    calc ml / r ^ K вЙ§ вАЦf cвАЦ / r ^ K := by gcongr
      _ вЙ§ вАЦf cвАЦ / вИП ѕБ вИИ S, вАЦc - ѕБвАЦ ^ (m ѕБ) := by
          gcongr
  ¬Ј -- sup via the maximum principle
    have hRr : (0:вДЭ) < RвВВ - r := by linarith
    have hRrK : (0:вДЭ) < (RвВВ - r) ^ K := by positivity
    have hbdry : вИА w вИИ sphere c RвВВ, вАЦg wвАЦ вЙ§ Mb / (RвВВ - r) ^ K := by
      intro w hw
      rw [mem_sphere_iff_norm] at hw
      have hwball : w вИИ ball c RвВБ := by
        rw [mem_ball, dist_eq_norm, hw]
        linarith
      have hprod_ge : (RвВВ - r) ^ K вЙ§ вИП ѕБ вИИ S, вАЦw - ѕБвАЦ ^ (m ѕБ) := by
        rw [hK, вЖР Finset.prod_pow_eq_pow_sum]
        apply Finset.prod_le_prod
        ¬Ј intro ѕБ _
          exact pow_nonneg hRr.le _
        ¬Ј intro ѕБ hѕБ
          apply pow_le_pow_leftвВА hRr.le
          have hѕБr := (hS ѕБ hѕБ).1
          rw [mem_closedBall, dist_comm, dist_eq_norm] at hѕБr
          calc RвВВ - r вЙ§ вАЦw - cвАЦ - вАЦc - ѕБвАЦ := by
                rw [hw]
                linarith
            _ вЙ§ вАЦw - ѕБвАЦ := by
                have h1 := norm_add_le (w - ѕБ) (ѕБ - c)
                have h2 : (w - ѕБ) + (ѕБ - c) = w - c := by ring
                rw [h2] at h1
                have h3 : вАЦѕБ - cвАЦ = вАЦc - ѕБвАЦ := by rw [norm_sub_rev]
                linarith
      have h1 : вАЦg wвАЦ * (RвВВ - r) ^ K вЙ§ Mb := by
        calc вАЦg wвАЦ * (RвВВ - r) ^ K вЙ§ вАЦg wвАЦ * вИП ѕБ вИИ S, вАЦw - ѕБвАЦ ^ (m ѕБ) := by
              gcongr
          _ = вАЦf wвАЦ := (hnorm_eq w hwball).symm
          _ вЙ§ Mb := hfb w hwball
      exact (le_div_iffвВА hRrK).mpr h1
    intro z hz
    have hRвВВ0 : RвВВ вЙ† 0 := by linarith
    have hdccl : DiffContOnCl вДВ g (ball c RвВВ) := by
      apply DifferentiableOn.diffContOnCl
      rw [closure_ball c hRвВВ0]
      exact hgdiff.mono (closedBall_subset_ball hRвВВRвВБ)
    apply Complex.norm_le_of_forall_mem_frontier_norm_le isBounded_ball hdccl
    ¬Ј intro w hw
      rw [frontier_ball c hRвВВ0] at hw
      exact hbdry w hw
    ¬Ј rw [closure_ball c hRвВВ0]
      exact hz

open Metric in
/-- **The Landau log-derivative lemma** (brick L6, the unconditional assembly): a
    holomorphic `f` on `B(c,RвВБ)` with `вАЦfвАЦ вЙ§ Mb`, `вАЦf(c)вАЦ вЙ• ml > 0`, `2R < RвВБ` has a
    finite multiset of zeros `(S, m)` in `BћД(c,R)` вАФ with true analytic multiplicities вАФ
    such that on the quarter ball, away from the zeros,
    `вАЦfвА≤/f(z) вИТ ќ£_ѕБ m_ѕБ/(zвИТѕБ)вАЦ вЙ§ 8(log(Mb/ml)+1)/R`. The peel at `RвВВ = 2R` makes the
    peeled function's sup/anchor ratio collapse to `Mb/ml`, so no multiplicity count
    enters the remainder. -/
theorem landau_log_deriv (f : вДВ вЖТ вДВ) (c : вДВ) (RвВБ R Mb ml : вДЭ) (hR : 0 < R)
    (hRR : 2 * R < RвВБ) (hf : DifferentiableOn вДВ f (ball c RвВБ))
    (hfb : вИА z вИИ ball c RвВБ, вАЦf zвАЦ вЙ§ Mb) (hml : 0 < ml) (hmlc : ml вЙ§ вАЦf cвАЦ) :
    вИГ (S : Finset вДВ) (m : вДВ вЖТ вДХ),
      (вИА ѕБ вИИ S, ѕБ вИИ closedBall c R вИІ f ѕБ = 0) вИІ
      (вИА ѕБ вИИ S, m ѕБ = analyticOrderNatAt f ѕБ) вИІ
      (вИА ѕБ вИИ closedBall c R, f ѕБ = 0 вЖТ ѕБ вИИ S) вИІ
      вИА z вИИ ball c (R / 4), (вИА ѕБ вИИ S, z вЙ† ѕБ) вЖТ
        вАЦlogDeriv f z - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ)вАЦ
          вЙ§ 8 * (Real.log (Mb / ml) + 1) / R := by
  have hRRвВБ : R < RвВБ := by linarith
  have hfc0 : f c вЙ† 0 := by
    intro h
    rw [h, norm_zero] at hmlc
    linarith
  have hfin := zeros_finite_of_ne_center f c RвВБ R hR hRRвВБ hf hfc0
  obtain вЯ®S, m, g, hSz, hm, hgdiff, hgne, hfacвЯ© :=
    exists_zero_factorization' c RвВБ R hR hRRвВБ hfin.toFinset.card f hf hfc0 hfin rfl
  obtain вЯ®hanchor, hsupвЯ© :=
    peeled_g_bounds f g c RвВБ R (2 * R) Mb ml S m hR (by linarith) hRR
      hfb hml hmlc hSz hgdiff hfac
  set K : вДХ := вИС ѕБ вИИ S, m ѕБ with hK
  have hRK : (0:вДЭ) < R ^ K := by positivity
  have h2RR : 2 * R - R = R := by ring
  rw [h2RR] at hsup
  have hcomplete : вИА ѕБвВА вИИ closedBall c R, f ѕБвВА = 0 вЖТ ѕБвВА вИИ S := by
    intro ѕБвВА hѕБвВА hf0
    by_contra hѕБS
    have hfaceq := hfac ѕБвВА ((closedBall_subset_ball hRRвВБ) hѕБвВА)
    rw [hf0] at hfaceq
    have hg0 : g ѕБвВА вЙ† 0 := hgne ѕБвВА hѕБвВА
    have hprod : вИП ѕБ вИИ S, (ѕБвВА - ѕБ) ^ (m ѕБ) вЙ† 0 := by
      rw [Finset.prod_ne_zero_iff]
      intro ѕБ hѕБ
      exact pow_ne_zero _ (sub_ne_zero_of_ne (fun hEq => hѕБS (hEq вЦЄ hѕБ)))
    exact (mul_ne_zero hg0 hprod) hfaceq.symm
  refine вЯ®S, m, hSz, hm, hcomplete, ?_вЯ©
  intro z hz hzS
  have hbound := landau_of_factorization f g c R (Mb / R ^ K) (ml / R ^ K) S m hR
    (fun w hw => hfac w (ball_subset_ball hRRвВБ.le hw))
    (hgdiff.mono (ball_subset_ball hRRвВБ.le))
    (fun w hw => hgne w (ball_subset_closedBall hw))
    (fun w hw => hsup w (closedBall_subset_closedBall (by linarith)
      (ball_subset_closedBall hw)))
    (by positivity) hanchor z hz hzS
  have hratio : Mb / R ^ K / (ml / R ^ K) = Mb / ml := by
    field_simp
  rwa [hratio] at hbound

open scoped LSeries.notation ArithmeticFunction ArithmeticFunction.Moebius in
/-- **The uniform EulerвАУM√ґbius anchor** (SW instantiation brick U1): for EVERY modulus,
    character, and point with `Re s > 1`,
    `вАЦL(s,ѕЗ)вАЦ вЙ• (вИС 1/n^{Re s})вБї¬є` вАФ from `L(s,ѕЗ)¬ЈL(s,ѕЗќЉ) = 1` and the trivial bound
    `вАЦL(s,ѕЗќЉ)вАЦ вЙ§ вИС 1/n^{Re s}`. The `ml` the Landau lemma normalizes against, uniform
    in `(N, ѕЗ, t)` and depending only on `ѕГ = Re s`. -/
lemma LFunction_anchor_euler (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (s : вДВ)
    (hs : 1 < s.re) :
    (вИС' n : вДХ, 1 / (n : вДЭ) ^ s.re)вБї¬є вЙ§ вАЦDirichletCharacter.LFunction ѕЗ sвАЦ := by
  set S : вДЭ := вИС' n : вДХ, 1 / (n : вДЭ) ^ s.re with hSdef
  have hmaj : Summable (fun n : вДХ => 1 / (n : вДЭ) ^ s.re) :=
    Real.summable_one_div_nat_rpow.mpr hs
  have hS1 : (1:вДЭ) вЙ§ S := by
    have h1 : 1 / ((1:вДХ) : вДЭ) ^ s.re = 1 := by norm_num
    calc (1:вДЭ) = 1 / ((1:вДХ) : вДЭ) ^ s.re := h1.symm
      _ вЙ§ S := hmaj.le_tsum 1 (fun i _ => by positivity)
  have hS0 : (0:вДЭ) < S := by linarith
  have hќЉsum : LSeriesSummable (вЖЧѕЗ * вЖЧќЉ) s :=
    DirichletCharacter.LSeriesSummable_mul ѕЗ
      (ArithmeticFunction.LSeriesSummable_moebius_iff.mpr hs)
  -- the trivial bound on the inverse series
  have hMle : вАЦL (вЖЧѕЗ * вЖЧќЉ) sвАЦ вЙ§ S := by
    calc вАЦL (вЖЧѕЗ * вЖЧќЉ) sвАЦ вЙ§ вИС' n, вАЦLSeries.term (вЖЧѕЗ * вЖЧќЉ) s nвАЦ :=
          norm_tsum_le_tsum_norm hќЉsum.norm
      _ вЙ§ S := by
          apply hќЉsum.norm.tsum_mono hmaj
          intro n
          dsimp only
          rcases Nat.eq_zero_or_pos n with rfl | hn0
          ¬Ј simp [LSeries.term_zero]
            positivity
          ¬Ј rw [LSeries.term_of_ne_zero hn0.ne']
            rw [norm_div, Complex.norm_natCast_cpow_of_pos hn0]
            apply div_le_div_of_nonneg_right _ (Real.rpow_pos_of_pos
              (show (0:вДЭ) < (n:вДЭ) by exact_mod_cast hn0) s.re).le
            show вАЦѕЗ ((n : ZMod N)) * ((ќЉ n : вД§) : вДВ)вАЦ вЙ§ 1
            rw [norm_mul]
            calc вАЦѕЗ ((n : ZMod N))вАЦ * вАЦ((ќЉ n : вД§) : вДВ)вАЦ
                вЙ§ 1 * 1 := by
                  apply mul_le_mul (ѕЗ.norm_le_one _) _ (norm_nonneg _) zero_le_one
                  rw [Complex.norm_intCast]
                  exact_mod_cast ArithmeticFunction.abs_moebius_le_one
              _ = 1 := one_mul 1
  -- assemble
  have hmul := DirichletCharacter.LSeries.mul_mu_eq_one ѕЗ hs
  rw [DirichletCharacter.LFunction_eq_LSeries ѕЗ hs]
  have h1 : (1:вДЭ) вЙ§ вАЦL вЖЧѕЗ sвАЦ * S := by
    calc (1:вДЭ) = вАЦL вЖЧѕЗ s * L (вЖЧѕЗ * вЖЧќЉ) sвАЦ := by rw [hmul, norm_one]
      _ = вАЦL вЖЧѕЗ sвАЦ * вАЦL (вЖЧѕЗ * вЖЧќЉ) sвАЦ := norm_mul _ _
      _ вЙ§ вАЦL вЖЧѕЗ sвАЦ * S := by
          apply mul_le_mul_of_nonneg_left hMle (norm_nonneg _)
  rw [inv_eq_one_div, div_le_iffвВА hS0]
  linarith

/-- **The explicit zeta-sum bound** (SW instantiation brick U2):
    `вИС 1/n^ѕГ вЙ§ ѕГ/(ѕГвИТ1)` for `ѕГ > 1` вАФ integral comparison against `вИЂ x^{вИТѕГ}`.
    Turns the U1 anchor into the uniform quantitative `ml вЙ• (ѕГвИТ1)/ѕГ`. -/
lemma tsum_one_div_nat_rpow_le (ѕГ : вДЭ) (hѕГ : 1 < ѕГ) :
    вИС' n : вДХ, 1 / (n : вДЭ) ^ ѕГ вЙ§ ѕГ / (ѕГ - 1) := by
  have hѕГ0 : (0:вДЭ) < ѕГ := by linarith
  have hѕГ1 : ѕГ - 1 вЙ† 0 := by linarith
  have hѕГ1' : (0:вДЭ) < ѕГ - 1 := by linarith
  have hmaj : Summable (fun n : вДХ => 1 / (n : вДЭ) ^ ѕГ) :=
    Real.summable_one_div_nat_rpow.mpr hѕГ
  apply Real.tsum_le_of_sum_range_le (fun n => by positivity)
  intro N
  rcases Nat.lt_or_ge N 2 with hN | hN
  ¬Ј -- N = 0 or 1: sum is 0
    interval_cases N
    ¬Ј simp
      positivity
    ¬Ј rw [Finset.sum_range_one, Nat.cast_zero, Real.zero_rpow (by linarith), div_zero]
      positivity
  ¬Ј -- N вЙ• 2: peel n = 0, 1 and integral-compare the rest
    rw [Finset.range_eq_Ico, вЖР Finset.sum_Ico_consecutive _ (by omega : 0 вЙ§ 2) hN]
    have hhead : вИС i вИИ Finset.Ico (0:вДХ) 2, 1 / (i : вДЭ) ^ ѕГ = 1 := by
      rw [Nat.Ico_zero_eq_range]
      rw [Finset.sum_range_succ, Finset.sum_range_one]
      rw [Nat.cast_zero, Real.zero_rpow (by linarith), div_zero, zero_add]
      norm_num
    have htail : вИС i вИИ Finset.Ico 2 N, 1 / (i : вДЭ) ^ ѕГ вЙ§ 1 / (ѕГ - 1) := by
      have hshift : вИС i вИИ Finset.Ico 2 N, 1 / (i : вДЭ) ^ ѕГ
          = вИС i вИИ Finset.Ico 1 (N - 1), (fun x : вДЭ => x ^ (-ѕГ)) ((i + 1 : вДХ) : вДЭ) := by
        rw [show (2:вДХ) = 1 + 1 by rfl, show N = (N - 1) + 1 by omega]
        rw [вЖР Finset.sum_Ico_add]
        apply Finset.sum_congr rfl
        intro i hi
        simp only
        rw [Real.rpow_neg (Nat.cast_nonneg _), inv_eq_one_div]
        congr 2
        push_cast
        ring
      rw [hshift]
      have hab : (1:вДХ) вЙ§ N - 1 := by omega
      have hanti : AntitoneOn (fun x : вДЭ => x ^ (-ѕГ)) (Set.Icc ((1:вДХ):вДЭ) ((N-1:вДХ):вДЭ)) := by
        intro x hx y hy hxy
        simp only
        have hx0 : (0:вДЭ) < x := lt_of_lt_of_le one_pos (by exact_mod_cast hx.1)
        have hy0 : (0:вДЭ) < y := lt_of_lt_of_le hx0 hxy
        rw [Real.rpow_neg hx0.le, Real.rpow_neg hy0.le]
        exact inv_antiвВА (Real.rpow_pos_of_pos hx0 ѕГ)
          (Real.rpow_le_rpow hx0.le hxy hѕГ0.le)
      have hint := AntitoneOn.sum_le_integral_Ico hab hanti
      apply le_trans hint
      have hN1 : ((1:вДХ):вДЭ) вЙ§ ((N - 1 : вДХ) : вДЭ) := by exact_mod_cast hab
      have h0mem : (0:вДЭ) вИЙ Set.uIcc ((1:вДХ):вДЭ) ((N-1:вДХ):вДЭ) := by
        rw [Set.uIcc_of_le hN1]
        rintro вЯ®h0, -вЯ©
        norm_num at h0
      rw [integral_rpow (Or.inr вЯ®by linarith, h0memвЯ©)]
      rw [Nat.cast_one, Real.one_rpow]
      have hpow0 : (0:вДЭ) вЙ§ ((N - 1 : вДХ) : вДЭ) ^ (-ѕГ + 1) :=
        Real.rpow_nonneg (by linarith) _
      have heq : (((N - 1 : вДХ) : вДЭ) ^ (-ѕГ + 1) - 1) / (-ѕГ + 1)
          = (1 - ((N - 1 : вДХ) : вДЭ) ^ (-ѕГ + 1)) / (ѕГ - 1) := by
        rw [show (-ѕГ + 1) = -(ѕГ - 1) by ring, div_neg, вЖР neg_div]
        congr 1
        ring
      rw [heq]
      gcongr
      linarith
    calc вИС i вИИ Finset.Ico (0:вДХ) 2, 1 / (i : вДЭ) ^ ѕГ + вИС i вИИ Finset.Ico (2:вДХ) N, 1 / (i : вДЭ) ^ ѕГ
        вЙ§ 1 + 1 / (ѕГ - 1) := by
          rw [hhead]
          linarith [htail]
      _ = ѕГ / (ѕГ - 1) := by
          field_simp
          ring

/-- **The quantitative uniform anchor** (SW instantiation brick U3 = U1 вИШ U2): for EVERY
    modulus, character, and `Re s > 1`, `вАЦL(s,ѕЗ)вАЦ вЙ• (Re s вИТ 1)/Re s` вАФ the explicit `ml`
    the Landau lemma takes at the center `ѕГвВА + it`, uniform in `(N, ѕЗ, t)`. -/
lemma LFunction_anchor_quantitative (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (s : вДВ) (hs : 1 < s.re) :
    (s.re - 1) / s.re вЙ§ вАЦDirichletCharacter.LFunction ѕЗ sвАЦ := by
  have hѕГ1' : (0:вДЭ) < s.re - 1 := by linarith
  have hѕГ0 : (0:вДЭ) < s.re := by linarith
  have hmaj : Summable (fun n : вДХ => 1 / (n : вДЭ) ^ s.re) :=
    Real.summable_one_div_nat_rpow.mpr hs
  have hS1 : (1:вДЭ) вЙ§ вИС' n : вДХ, 1 / (n : вДЭ) ^ s.re := by
    have h1 : 1 / ((1:вДХ) : вДЭ) ^ s.re = 1 := by norm_num
    calc (1:вДЭ) = 1 / ((1:вДХ) : вДЭ) ^ s.re := h1.symm
      _ вЙ§ _ := hmaj.le_tsum 1 (fun i _ => by positivity)
  have hS0 : (0:вДЭ) < вИС' n : вДХ, 1 / (n : вДЭ) ^ s.re := by linarith
  calc (s.re - 1) / s.re = (s.re / (s.re - 1))вБї¬є := by
        rw [inv_div]
    _ вЙ§ (вИС' n : вДХ, 1 / (n : вДЭ) ^ s.re)вБї¬є :=
        inv_antiвВА hS0 (tsum_one_div_nat_rpow_le s.re hs)
    _ вЙ§ вАЦDirichletCharacter.LFunction ѕЗ sвАЦ := LFunction_anchor_euler N ѕЗ s hs

open Metric in
/-- **Landau's lemma for Dirichlet L-functions** (SW brick U4): for every modulus `N`,
    nontrivial `ѕЗ`, height `t`, and `ѕГвВА вИИ (1,2]`, the log-derivative of `L(¬Ј,ѕЗ)` near
    `c = ѕГвВА + it` is the partial-fraction sum over the zeros in `BћД(c,1/5)` (true
    multiplicities) up to `40(log(N(2|t|+7)¬ЈѕГвВА/(ѕГвВАвИТ1)) + 1)` вАФ the classical
    `вИТLвА≤/L = ќ£_{nearby ѕБ} 1/(sвИТѕБ) + O(log(N(2+|t|)) + log(1/(ѕГвВАвИТ1)))`, fully explicit
    and uniform in `(N, ѕЗ, t)`. -/
theorem landau_LFunction (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (ѕГвВА t : вДЭ) (hѕГвВА : 1 < ѕГвВА) (hѕГвВА2 : ѕГвВА вЙ§ 2) :
    вИГ (S : Finset вДВ) (m : вДВ вЖТ вДХ),
      (вИА ѕБ вИИ S, ѕБ вИИ closedBall ((ѕГвВА : вДВ) + t * Complex.I) (1/5) вИІ
        DirichletCharacter.LFunction ѕЗ ѕБ = 0) вИІ
      (вИА ѕБ вИИ S, m ѕБ = analyticOrderNatAt (DirichletCharacter.LFunction ѕЗ) ѕБ) вИІ
      (вИА ѕБ вИИ closedBall ((ѕГвВА : вДВ) + t * Complex.I) (1/5),
        DirichletCharacter.LFunction ѕЗ ѕБ = 0 вЖТ ѕБ вИИ S) вИІ
      (вИА ѕБ вИИ S, 1 вЙ§ m ѕБ) вИІ
      вИА z вИИ ball ((ѕГвВА : вДВ) + t * Complex.I) (1/20), (вИА ѕБ вИИ S, z вЙ† ѕБ) вЖТ
        вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) z - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (z - ѕБ)вАЦ
          вЙ§ 40 * (Real.log ((N : вДЭ) * (2 * |t| + 7) * ѕГвВА / (ѕГвВА - 1)) + 1) := by
  set c : вДВ := (ѕГвВА : вДВ) + t * Complex.I with hc
  have hcre : c.re = ѕГвВА := by
    rw [hc]
    simp
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  set Mb : вДЭ := (N : вДЭ) * (2 * |t| + 7) with hMb
  set ml : вДЭ := (ѕГвВА - 1) / ѕГвВА with hml_def
  have hml : 0 < ml := div_pos (by linarith) (by linarith)
  have hmlc : ml вЙ§ вАЦDirichletCharacter.LFunction ѕЗ cвАЦ := by
    have := LFunction_anchor_quantitative N ѕЗ c (by rw [hcre]; exact hѕГвВА)
    rwa [hcre] at this
  have hfb : вИА z вИИ ball c (1/2), вАЦDirichletCharacter.LFunction ѕЗ zвАЦ вЙ§ Mb := by
    intro z hz
    rw [mem_ball, dist_eq_norm] at hz
    have hre : (1/2 : вДЭ) вЙ§ z.re := by
      have h1 : |(z - c).re| вЙ§ вАЦz - cвАЦ := Complex.abs_re_le_norm _
      have h2 : |z.re - c.re| < 1/2 := by
        rw [вЖР Complex.sub_re]
        exact lt_of_le_of_lt h1 hz
      have h3 := (abs_lt.mp h2).1
      rw [hcre] at h3
      linarith
    have hnorm : вАЦzвАЦ вЙ§ |t| + 5/2 := by
      have hcnorm : вАЦcвАЦ вЙ§ ѕГвВА + |t| := by
        calc вАЦcвАЦ вЙ§ вАЦ(ѕГвВА : вДВ)вАЦ + вАЦ(t : вДВ) * Complex.IвАЦ := norm_add_le _ _
          _ = |ѕГвВА| + |t| := by
              rw [Complex.norm_real, norm_mul, Complex.norm_I, mul_one, Complex.norm_real]
              simp [Real.norm_eq_abs]
          _ = ѕГвВА + |t| := by rw [abs_of_pos (by linarith)]
      calc вАЦzвАЦ = вАЦc + (z - c)вАЦ := by ring_nf
        _ вЙ§ вАЦcвАЦ + вАЦz - cвАЦ := norm_add_le _ _
        _ вЙ§ (ѕГвВА + |t|) + 1/2 := by
            apply add_le_add hcnorm hz.le
        _ вЙ§ |t| + 5/2 := by linarith
    have hw := LFunction_window_bound N ѕЗ hѕЗ (1/2) (|t| + 5/2) (by norm_num)
      (by positivity) z hre hnorm
    calc вАЦDirichletCharacter.LFunction ѕЗ zвАЦ вЙ§ (N : вДЭ) * (2 + (|t| + 5/2) / (1/2)) := hw
      _ = Mb := by
          rw [hMb]
          ring
  obtain вЯ®S, m, hSz, hm, hcomp, hboundвЯ© := landau_log_deriv
    (DirichletCharacter.LFunction ѕЗ) c (1/2) (1/5) Mb ml (by norm_num) (by norm_num)
    ((DirichletCharacter.differentiable_LFunction hѕЗ).differentiableOn) hfb hml hmlc
  have hLne : DirichletCharacter.LFunction ѕЗ 2 вЙ† 0 := by
    have h2 := LFunction_two_lower_uniform N ѕЗ hѕЗ
    intro h0
    rw [h0, norm_zero] at h2
    nlinarith [Real.pi_lt_d2, Real.pi_pos]
  have hmpos : вИА ѕБ вИИ S, 1 вЙ§ m ѕБ := by
    intro ѕБ hѕБ
    have hLѕБ : DirichletCharacter.LFunction ѕЗ ѕБ = 0 := (hSz ѕБ hѕБ).2
    have hAnal : AnalyticAt вДВ (DirichletCharacter.LFunction ѕЗ) ѕБ :=
      (DirichletCharacter.differentiable_LFunction hѕЗ).analyticAt ѕБ
    have hordtop : analyticOrderAt (DirichletCharacter.LFunction ѕЗ) ѕБ вЙ† вК§ := by
      intro htop
      have hev := analyticOrderAt_eq_top.mp htop
      have hanalU : AnalyticOnNhd вДВ (DirichletCharacter.LFunction ѕЗ) Set.univ :=
        fun z _ => (DirichletCharacter.differentiable_LFunction hѕЗ).analyticAt z
      have hzero := hanalU.eqOn_zero_of_preconnected_of_eventuallyEq_zero
        isPreconnected_univ (Set.mem_univ ѕБ) hev
      exact hLne (hzero (Set.mem_univ 2))
    have hordzero : analyticOrderAt (DirichletCharacter.LFunction ѕЗ) ѕБ вЙ† 0 := by
      intro h0
      rcases analyticOrderAt_eq_zero.mp h0 with h | h
      ¬Ј exact h hAnal
      ¬Ј exact h hLѕБ
    rw [hm ѕБ hѕБ, analyticOrderNatAt]
    apply Nat.one_le_iff_ne_zero.mpr
    intro h0
    rcases ENat.toNat_eq_zero.mp h0 with h | h
    ¬Ј exact hordzero h
    ¬Ј exact hordtop h
  refine вЯ®S, m, hSz, hm, hcomp, hmpos, ?_вЯ©
  intro z hz hzS
  have hz' : z вИИ ball c ((1/5) / 4) := by
    rw [show ((1:вДЭ)/5) / 4 = 1/20 by norm_num]
    exact hz
  have hb := hbound z hz' hzS
  have hconst : 8 * (Real.log (Mb / ml) + 1) / (1/5)
      = 40 * (Real.log (Mb / ml) + 1) := by ring
  have hratio : Mb / ml = (N : вДЭ) * (2 * |t| + 7) * ѕГвВА / (ѕГвВА - 1) := by
    rw [hMb, hml_def]
    field_simp
  rw [hconst, hratio] at hb
  exact hb

open Metric ArithmeticFunction in
open scoped LSeries.notation ArithmeticFunction in
/-- **The UNIFORM zero bound** (SW brick U5 вАФ the AвВБ ingredient of 3-4-1 with uniform
    constant): a zero `ќ≤ + iќ≥` of `L(¬Ј,ѕЗ)` with `ѕГ вИТ ќ≤ вЙ§ 1/5`, `ѕГ вИИ (1,2]`, forces
    `Re L(ѕЗќЫ, ѕГ+iќ≥) вЙ§ 40(log(N(2|ќ≥|+7)ѕГ/(ѕГвИТ1)) + 1) вИТ 1/(ѕГвИТќ≤)` вАФ Landau's partial
    fractions at the center, all other zero terms dropped by positivity. The constant
    is explicit and uniform in `(N, ѕЗ, ќ≥, ќ≤)`: THE Hadamard-grade input the classical
    zero-free region needs. -/
theorem zero_bound_uniform (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (ќ≤ ќ≥ : вДЭ) (hzero : DirichletCharacter.LFunction ѕЗ ((ќ≤ : вДВ) + ќ≥ * Complex.I) = 0)
    (ѕГ : вДЭ) (hѕГ1 : 1 < ѕГ) (hѕГ2 : ѕГ вЙ§ 2) (hnear : ѕГ - ќ≤ вЙ§ 1/5) :
    (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + ќ≥ * Complex.I)).re
      вЙ§ 40 * (Real.log ((N : вДЭ) * (2 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)) + 1) - 1 / (ѕГ - ќ≤) := by
  set c : вДВ := (ѕГ : вДВ) + ќ≥ * Complex.I with hc
  set ѕБвВА : вДВ := (ќ≤ : вДВ) + ќ≥ * Complex.I with hѕБвВАdef
  have hcre : c.re = ѕГ := by rw [hc]; simp
  have hѕБвВАre : ѕБвВА.re = ќ≤ := by rw [hѕБвВАdef]; simp
  have hcre1 : 1 < c.re := by rw [hcre]; exact hѕГ1
  -- every zero has Re < 1 (Mathlib nonvanishing on Re вЙ• 1)
  have hzlt : вИА w : вДВ, DirichletCharacter.LFunction ѕЗ w = 0 вЖТ w.re < 1 := by
    intro w hw
    by_contra hwre
    push_neg at hwre
    exact DirichletCharacter.LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ) hwre hw
  have hќ≤1 : ќ≤ < 1 := by
    have := hzlt ѕБвВА hzero
    rwa [hѕБвВАre] at this
  have hќ≤ѕГ : ќ≤ < ѕГ := by linarith
  have hѕГќ≤0 : (0:вДЭ) < ѕГ - ќ≤ := by linarith
  obtain вЯ®S, m, hSz, hm, hcomp, hmpos, hboundвЯ© := landau_LFunction N ѕЗ hѕЗ ѕГ ќ≥ hѕГ1 hѕГ2
  have hѕБвВАball : ѕБвВА вИИ closedBall c (1/5) := by
    rw [mem_closedBall, dist_eq_norm]
    have hdiff : ѕБвВА - c = ((ќ≤ - ѕГ : вДЭ) : вДВ) := by
      rw [hѕБвВАdef, hc]
      push_cast
      ring
    rw [hdiff, Complex.norm_real, Real.norm_eq_abs, abs_of_nonpos (by linarith)]
    linarith
  have hѕБвВАS : ѕБвВА вИИ S := hcomp ѕБвВА hѕБвВАball hzero
  have hcz : c вИИ ball c (1/20) := mem_ball_self (by norm_num)
  have hzS : вИА ѕБ вИИ S, c вЙ† ѕБ := by
    intro ѕБ hѕБ hEq
    have hLѕБ := (hSz ѕБ hѕБ).2
    rw [вЖР hEq] at hLѕБ
    have := hzlt c hLѕБ
    rw [hcre] at this
    linarith
  have hb := hbound c hcz hzS
  -- real part of each partial-fraction term is nonneg
  have hreS : вИА ѕБ вИИ S, 0 вЙ§ ((m ѕБ : вДВ) / (c - ѕБ)).re := by
    intro ѕБ hѕБ
    have hѕБre : ѕБ.re < 1 := hzlt ѕБ (hSz ѕБ hѕБ).2
    rw [div_eq_mul_inv, show ((m ѕБ : вДХ) : вДВ) = (((m ѕБ : вДХ) : вДЭ) : вДВ) by push_cast; rfl,
      Complex.re_ofReal_mul, Complex.inv_re]
    apply mul_nonneg (Nat.cast_nonneg _)
    apply div_nonneg _ (Complex.normSq_nonneg _)
    rw [Complex.sub_re, hcre]
    linarith
  -- the ѕБвВА term alone is вЙ• 1/(ѕГвИТќ≤)
  have hterm : 1 / (ѕГ - ќ≤) вЙ§ ((m ѕБвВА : вДВ) / (c - ѕБвВА)).re := by
    have hdiff : c - ѕБвВА = ((ѕГ - ќ≤ : вДЭ) : вДВ) := by
      rw [hѕБвВАdef, hc]
      push_cast
      ring
    rw [hdiff, show ((m ѕБвВА : вДХ) : вДВ) = (((m ѕБвВА : вДХ) : вДЭ) : вДВ) by push_cast; rfl,
      вЖР Complex.ofReal_div, Complex.ofReal_re]
    gcongr
    exact_mod_cast hmpos ѕБвВА hѕБвВАS
  -- the sum's real part dominates the single ѕБвВА term
  have hsum : 1 / (ѕГ - ќ≤) вЙ§ (вИС ѕБ вИИ S, (m ѕБ : вДВ) / (c - ѕБ)).re := by
    rw [Complex.re_sum]
    calc 1 / (ѕГ - ќ≤) вЙ§ ((m ѕБвВА : вДВ) / (c - ѕБвВА)).re := hterm
      _ вЙ§ вИС ѕБ вИИ S, ((m ѕБ : вДВ) / (c - ѕБ)).re :=
          Finset.single_le_sum hreS hѕБвВАS
  have hrediff : -(40 * (Real.log ((N : вДЭ) * (2 * |ќ≥| + 7) * ѕГ / (ѕГ - 1)) + 1))
      вЙ§ (logDeriv (DirichletCharacter.LFunction ѕЗ) c
          - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (c - ѕБ)).re := by
    have habs := (Complex.abs_re_le_norm _).trans hb
    linarith [(abs_le.mp habs).1]
  have hident : LSeries (вЖЧѕЗ * вЖЧќЫ) c = - logDeriv (DirichletCharacter.LFunction ѕЗ) c := by
    rw [DirichletCharacter.LSeries_twist_vonMangoldt_eq _ hcre1,
      вЖР DirichletCharacter.deriv_LFunction_eq_deriv_LSeries _ hcre1,
      вЖР DirichletCharacter.LFunction_eq_LSeries _ hcre1, neg_div, вЖР logDeriv_apply]
  rw [hident, Complex.neg_re]
  rw [Complex.sub_re] at hrediff
  linarith [hrediff, hsum]

open Metric ArithmeticFunction in
open scoped LSeries.notation ArithmeticFunction in
/-- **The UNIFORM growth bound** (SW brick U6 вАФ the AвВВ ingredient of 3-4-1 with uniform
    constant): for every nontrivial `ѕЗ`, `ѕГ вИИ (1,2]`, and height `t`,
    `Re L(ѕЗќЫ, ѕГ+it) вЙ§ 40(log(N(2|t|+7)ѕГ/(ѕГвИТ1)) + 1)` вАФ Landau's partial fractions at
    the center with EVERY zero term dropped by positivity. Uniform in `(N, ѕЗ, t)`;
    replaces the compactness-per-`(ѕЗ,ќ≥)` bound `growth_bound_nontriv`. -/
theorem growth_bound_uniform (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (t ѕГ : вДЭ) (hѕГ1 : 1 < ѕГ) (hѕГ2 : ѕГ вЙ§ 2) :
    (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + t * Complex.I)).re
      вЙ§ 40 * (Real.log ((N : вДЭ) * (2 * |t| + 7) * ѕГ / (ѕГ - 1)) + 1) := by
  set c : вДВ := (ѕГ : вДВ) + t * Complex.I with hc
  have hcre : c.re = ѕГ := by rw [hc]; simp
  have hcre1 : 1 < c.re := by rw [hcre]; exact hѕГ1
  have hzlt : вИА w : вДВ, DirichletCharacter.LFunction ѕЗ w = 0 вЖТ w.re < 1 := by
    intro w hw
    by_contra hwre
    push_neg at hwre
    exact DirichletCharacter.LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ) hwre hw
  obtain вЯ®S, m, hSz, hm, hcomp, hmpos, hboundвЯ© := landau_LFunction N ѕЗ hѕЗ ѕГ t hѕГ1 hѕГ2
  have hcz : c вИИ ball c (1/20) := mem_ball_self (by norm_num)
  have hzS : вИА ѕБ вИИ S, c вЙ† ѕБ := by
    intro ѕБ hѕБ hEq
    have hLѕБ := (hSz ѕБ hѕБ).2
    rw [вЖР hEq] at hLѕБ
    have := hzlt c hLѕБ
    rw [hcre] at this
    linarith
  have hb := hbound c hcz hzS
  have hreS : вИА ѕБ вИИ S, 0 вЙ§ ((m ѕБ : вДВ) / (c - ѕБ)).re := by
    intro ѕБ hѕБ
    have hѕБre : ѕБ.re < 1 := hzlt ѕБ (hSz ѕБ hѕБ).2
    rw [div_eq_mul_inv, show ((m ѕБ : вДХ) : вДВ) = (((m ѕБ : вДХ) : вДЭ) : вДВ) by push_cast; rfl,
      Complex.re_ofReal_mul, Complex.inv_re]
    apply mul_nonneg (Nat.cast_nonneg _)
    apply div_nonneg _ (Complex.normSq_nonneg _)
    rw [Complex.sub_re, hcre]
    linarith
  have hsum : 0 вЙ§ (вИС ѕБ вИИ S, (m ѕБ : вДВ) / (c - ѕБ)).re := by
    rw [Complex.re_sum]
    exact Finset.sum_nonneg hreS
  have hrediff : -(40 * (Real.log ((N : вДЭ) * (2 * |t| + 7) * ѕГ / (ѕГ - 1)) + 1))
      вЙ§ (logDeriv (DirichletCharacter.LFunction ѕЗ) c
          - вИС ѕБ вИИ S, (m ѕБ : вДВ) / (c - ѕБ)).re := by
    have habs := (Complex.abs_re_le_norm _).trans hb
    linarith [(abs_le.mp habs).1]
  have hident : LSeries (вЖЧѕЗ * вЖЧќЫ) c = - logDeriv (DirichletCharacter.LFunction ѕЗ) c := by
    rw [DirichletCharacter.LSeries_twist_vonMangoldt_eq _ hcre1,
      вЖР DirichletCharacter.deriv_LFunction_eq_deriv_LSeries _ hcre1,
      вЖР DirichletCharacter.LFunction_eq_LSeries _ hcre1, neg_div, вЖР logDeriv_apply]
  rw [hident, Complex.neg_re]
  rw [Complex.sub_re] at hrediff
  linarith [hrediff, hsum]

/-! ## The 3-4-1 positivity engine (mirrored from DirichletZeroFreeComposed.lean) -/

/-- The 3-4-1 trigonometric inequality: `3 + 4cosќЄ + cos2ќЄ = 2(1+cosќЄ)¬≤ вЙ• 0`.
    Foundation of the classical de la Vall√©e-Poussin zero-free region (for ќґ and L(s,ѕЗ)). -/
lemma three_four_one (ќЄ : вДЭ) : 0 вЙ§ 3 + 4 * Real.cos ќЄ + Real.cos (2 * ќЄ) := by
  have h : Real.cos (2 * ќЄ) = 2 * Real.cos ќЄ ^ 2 - 1 := Real.cos_two_mul ќЄ
  rw [h]; nlinarith [sq_nonneg (Real.cos ќЄ + 1)]

/-- Complex 3-4-1: for a unit `w = ѕЗ(n)¬Јn^{-it}`, `Re(3 + 4w + w¬≤) = 2(Re w + 1)¬≤ вЙ• 0`.
    This is the term-by-term positivity feeding the log-derivative combination
    `-Re[ 3¬Ј(L'/L)(ѕГ,ѕЗвВА) + 4¬Ј(L'/L)(ѕГ+it,ѕЗ) + (L'/L)(ѕГ+2it,ѕЗ¬≤) ]`. -/
lemma three_four_one_complex (w : вДВ) (hw : вАЦwвАЦ = 1) :
    0 вЙ§ (3 + 4 * w + w ^ 2).re := by
  have h1 : w.re ^ 2 + w.im ^ 2 = 1 := by
    have h : (w.re * w.re + w.im * w.im : вДЭ) = 1 := by
      rw [вЖР Complex.normSq_apply, Complex.normSq_eq_norm_sq, hw]; norm_num
    nlinarith [h]
  have h2 : (w ^ 2).re = w.re ^ 2 - w.im ^ 2 := by
    rw [sq, Complex.mul_re]; ring
  simp only [Complex.add_re, Complex.mul_re, Complex.ofReal_re, Complex.re_ofNat,
    Complex.im_ofNat, Complex.ofReal_im, h2]
  nlinarith [sq_nonneg (w.re + 1), h1]

/-- Termwise 3-4-1 for the Dirichlet log-derivative combination: for a coprime `n`,
    `ѕЗвБ∞(n)=1`, `wвВА = ѕЗ(n)` is a unit and `u = n^{-it}` is a unit, so the bracket
    `3¬Ј1 + 4¬Ј(wвВА¬Јu) + (wвВА¬Јu)¬≤` (the `n`-th term of `3(L'/L)(ѕГ,ѕЗвБ∞)+4(L'/L)(ѕГ+it,ѕЗ)+(L'/L)(ѕГ+2it,ѕЗ¬≤)`
    up to the positive weight `ќЫ(n)n^{-ѕГ}`) has nonnegative real part. -/
lemma three_four_one_char (wвВА u : вДВ) (hвВА : вАЦwвВАвАЦ = 1) (hu : вАЦuвАЦ = 1) :
    0 вЙ§ (3 + 4 * (wвВА * u) + (wвВА * u) ^ 2).re := by
  apply three_four_one_complex
  rw [norm_mul, hвВА, hu, mul_one]

/-- The weighted term stays nonnegative: multiplying by a nonnegative real weight
    (`ќЫ(n)¬Јn^{-ѕГ} вЙ• 0`) preserves the sign. -/
lemma three_four_one_char_weighted (c : вДЭ) (hc : 0 вЙ§ c) (wвВА u : вДВ) (hвВА : вАЦwвВАвАЦ = 1)
    (hu : вАЦuвАЦ = 1) : 0 вЙ§ c * (3 + 4 * (wвВА * u) + (wвВА * u) ^ 2).re :=
  mul_nonneg hc (three_four_one_char wвВА u hвВА hu)

open Complex in
/-- 1c-i: `n^{it}` (equivalently `n^{-it}`) is a unit for `n вЙ• 1` вАФ the imaginary exponent
    contributes no modulus. -/
lemma norm_nat_cpow_I (n : вДХ) (hn : 1 вЙ§ n) (t : вДЭ) : вАЦ(n : вДВ) ^ ((t : вДВ) * I)вАЦ = 1 := by
  have hp : (0 : вДЭ) < (n : вДЭ) := by exact_mod_cast hn
  rw [show ((n : вДВ)) = ((n : вДЭ) : вДВ) by push_cast; ring,
    Complex.norm_cpow_eq_rpow_re_of_pos hp]
  simp [Complex.mul_re, Complex.mul_im]

open Complex in
/-- 1c-ii (the analytic core): the `n`-th term of the 3-4-1 log-derivative combination has
    nonnegative real part. `c0,c1,c2 = ѕЗвБ∞(n),ѕЗ(n),ѕЗ¬≤(n)` obey the dichotomy: all zero off the
    coprime set, else `c0=1, вАЦc1вАЦ=1, c2=c1¬≤`. -/
lemma term_combination_re_nonneg (n : вДХ) (hn : 1 вЙ§ n) (ѕГ t : вДЭ) (c0 c1 c2 : вДВ)
    (hcase : (c0 = 0 вИІ c1 = 0 вИІ c2 = 0) вИ® (c0 = 1 вИІ вАЦc1вАЦ = 1 вИІ c2 = c1 ^ 2)) :
    0 вЙ§ (3 * (c0 * (ArithmeticFunction.vonMangoldt n : вДВ) / (n : вДВ) ^ (ѕГ : вДВ))
       + 4 * (c1 * (ArithmeticFunction.vonMangoldt n : вДВ) / (n : вДВ) ^ ((ѕГ : вДВ) + t * I))
       + (c2 * (ArithmeticFunction.vonMangoldt n : вДВ) / (n : вДВ) ^ ((ѕГ : вДВ) + 2 * t * I))).re := by
  have hn0 : (n : вДВ) вЙ† 0 := by exact_mod_cast Nat.one_le_iff_ne_zero.mp hn
  rcases hcase with вЯ®h0, h1, h2вЯ© | вЯ®h0, h1, h2вЯ©
  ¬Ј subst h0 h1 h2; simp
  ¬Ј subst h0 h2
    have hd1 : (n : вДВ) ^ ((ѕГ : вДВ) + t * I) = (n : вДВ) ^ (ѕГ : вДВ) * (n : вДВ) ^ ((t : вДВ) * I) := by
      rw [вЖР Complex.cpow_add _ _ hn0]
    have hd2 : (n : вДВ) ^ ((ѕГ : вДВ) + 2 * t * I)
        = (n : вДВ) ^ (ѕГ : вДВ) * ((n : вДВ) ^ ((t : вДВ) * I)) ^ 2 := by
      rw [show (ѕГ : вДВ) + 2 * (t : вДВ) * I = (ѕГ : вДВ) + (t : вДВ) * I + (t : вДВ) * I by ring,
        Complex.cpow_add _ _ hn0, Complex.cpow_add _ _ hn0, sq]
      try ring
    rw [hd1, hd2]
    set P : вДВ := (n : вДВ) ^ (ѕГ : вДВ) with hP
    set U : вДВ := (n : вДВ) ^ ((t : вДВ) * I) with hU
    set vm : вДЭ := ArithmeticFunction.vonMangoldt n with hvm
    have hUnorm : вАЦUвАЦ = 1 := norm_nat_cpow_I n hn t
    have hUne : U вЙ† 0 := by
      intro h; rw [h, norm_zero] at hUnorm; norm_num at hUnorm
    have hPreal : P = (((n : вДЭ) ^ ѕГ : вДЭ) : вДВ) := by
      rw [hP, вЖР Complex.ofReal_natCast n, вЖР Complex.ofReal_cpow (by positivity : (0:вДЭ) вЙ§ (n:вДЭ))]
    have hPpos : (0 : вДЭ) < (n : вДЭ) ^ ѕГ := by positivity
    have hPne : P вЙ† 0 := by rw [hPreal]; exact_mod_cast ne_of_gt hPpos
    have key : 3 * ((1 : вДВ) * (vm : вДВ) / P) + 4 * (c1 * (vm : вДВ) / (P * U))
        + c1 ^ 2 * (vm : вДВ) / (P * U ^ 2)
        = (((vm / (n : вДЭ) ^ ѕГ : вДЭ)) : вДВ) * (3 + 4 * (c1 * UвБї¬є) + (c1 * UвБї¬є) ^ 2) := by
      rw [hPreal]; push_cast; field_simp; try ring
    rw [key, Complex.re_ofReal_mul]
    apply mul_nonneg
    ¬Ј apply div_nonneg ArithmeticFunction.vonMangoldt_nonneg (le_of_lt hPpos)
    ¬Ј exact three_four_one_char c1 UвБї¬є h1 (by rw [norm_inv, hUnorm, inv_one])

/-- 1c-iii (character dichotomy): the triple `(ѕЗвБ∞(n), ѕЗ(n), ѕЗ¬≤(n))` obeys the dichotomy
    required by `term_combination_re_nonneg`. -/
lemma char_triple_dichotomy {N : вДХ} (ѕЗ : DirichletCharacter вДВ N) (n : вДХ) :
    (((1 : DirichletCharacter вДВ N) (n : ZMod N) = 0 вИІ ѕЗ (n : ZMod N) = 0
        вИІ (ѕЗ ^ 2) (n : ZMod N) = 0)
     вИ® ((1 : DirichletCharacter вДВ N) (n : ZMod N) = 1 вИІ вАЦѕЗ (n : ZMod N)вАЦ = 1
        вИІ (ѕЗ ^ 2) (n : ZMod N) = (ѕЗ (n : ZMod N)) ^ 2)) := by
  by_cases h : IsUnit (n : ZMod N)
  ¬Ј right
    refine вЯ®MulChar.one_apply h, ?_, MulChar.pow_apply' ѕЗ (by norm_num) _вЯ©
    obtain вЯ®u, huвЯ© := h
    rw [вЖР hu]; exact ѕЗ.unit_norm_eq_one u
  ¬Ј exact Or.inl вЯ®MulChar.map_nonunit _ h, MulChar.map_nonunit _ h, MulChar.map_nonunit _ hвЯ©

open ArithmeticFunction Complex in
open scoped LSeries.notation ArithmeticFunction in
/-- 1c (assembled): the log-derivative 3-4-1 combination has nonnegative real part for ѕГ>1. -/
lemma logDeriv_combo_re_nonneg {N : вДХ} (ѕЗ : DirichletCharacter вДВ N) (ѕГ t : вДЭ) (hѕГ : 1 < ѕГ) :
    0 вЙ§ (3 * LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (ѕГ : вДВ)
       + 4 * LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ) + t * I)
       + LSeries (вЖЧ(ѕЗ ^ 2) * вЖЧќЫ) ((ѕГ : вДВ) + 2 * t * I)).re := by
  have hs0 : 1 < ((ѕГ : вДВ)).re := by simpa using hѕГ
  have hs1 : 1 < ((ѕГ : вДВ) + t * I).re := by simp; linarith
  have hs2 : 1 < ((ѕГ : вДВ) + 2 * t * I).re := by simp; linarith
  have S0 := DirichletCharacter.LSeriesSummable_twist_vonMangoldt (1 : DirichletCharacter вДВ N) hs0
  have S1 := DirichletCharacter.LSeriesSummable_twist_vonMangoldt ѕЗ hs1
  have S2 := DirichletCharacter.LSeriesSummable_twist_vonMangoldt (ѕЗ ^ 2) hs2
  simp only [LSeries]
  have H := ((S0.hasSum.mul_left 3).add (S1.hasSum.mul_left 4)).add S2.hasSum
  rw [вЖР H.tsum_eq, re_tsum H.summable]
  apply tsum_nonneg
  intro n
  rcases eq_or_ne n 0 with rfl | hn
  ¬Ј simp [LSeries.term]
  ¬Ј rw [LSeries.term_of_ne_zero hn, LSeries.term_of_ne_zero hn, LSeries.term_of_ne_zero hn]
    simp only [Pi.mul_apply]
    exact term_combination_re_nonneg n (Nat.one_le_iff_ne_zero.mpr hn) ѕГ t _ _ _
      (char_triple_dichotomy ѕЗ n)

/-- 1d (assembly): plug the three raw `L'/L` bounds into the 1c combination `0 вЙ§ 3AвВА+4AвВБ+AвВВ`
    (where `AвВА = Re L(ѕЗвБ∞ќЫ,ѕГ)`, `AвВБ = Re L(ѕЗќЫ,ѕГ+iќ≥)`, `AвВВ = Re L(ѕЗ¬≤ќЫ,ѕГ+2iќ≥)`) to get the combined
    bound consumed by `zero_free_region_from_bounds`. Reduces all of 1d to the raw bounds:
    (pole) `AвВА вЙ§ 1/(ѕГ-1)+K`, (zero) `AвВБ вЙ§ K - 1/(ѕГ-ќ≤)`, (growth) `AвВВ вЙ§ K`. -/
lemma combined_bound_from_ingredients (ќ≤ ѕГ K AвВА AвВБ AвВВ : вДЭ)
    (hcombo : 0 вЙ§ 3 * AвВА + 4 * AвВБ + AвВВ)
    (hpole : AвВА вЙ§ 1 / (ѕГ - 1) + K) (hzero : AвВБ вЙ§ K - 1 / (ѕГ - ќ≤)) (hgrowth : AвВВ вЙ§ K) :
    1 / (ѕГ - ќ≤) вЙ§ 3 / (4 * (ѕГ - 1)) + 2 * K := by
  have hbridge : 3 / 4 * (1 / (ѕГ - 1)) = 3 / (4 * (ѕГ - 1)) := by
    rw [div_mul_div_comm]; norm_num
  linarith [hcombo, hpole, hzero, hgrowth, hbridge]

open ArithmeticFunction Complex in
open scoped LSeries.notation ArithmeticFunction in
/-- **THE UNIFORM ZERO-FREE REGION** (SW brick U7 вАФ de la Vall√©e-Poussin with an
    absolute constant): there is one `C` such that EVERY zero `ќ≤ + iќ≥` of EVERY
    `L(¬Ј,ѕЗ)` with `ѕЗ` nontrivial non-quadratic satisfies
    `ќ≤ вЙ§ 1 вИТ 1/(335(1360+C)(log(N(4|ќ≥|+7)) + 20))` вАФ the classical
    `1 вИТ c/log(N(|ќ≥|+2))` region, fully uniform in `(N, ѕЗ, ќ≥)`. Composition: the
    positivity engine + uniform pole (twist_re_le_uniform) + uniform zero (U5) +
    uniform growth (U6) at the single point `ѕГ = 1 + 1/(100M)`, where
    `M = 80(log+20) + 20¬Јmax(K_P,1) + 24000` a-priori majorizes the Landau constant
    (via `log M вЙ§ 2вИЪM вЙ§ M/160`). -/
theorem dvp_zero_free_uniform :
    вИГ C : вДЭ, 1 вЙ§ C вИІ вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N),
      ѕЗ вЙ† 1 вЖТ ѕЗ ^ 2 вЙ† 1 вЖТ вИА ќ≤ ќ≥ : вДЭ,
      DirichletCharacter.LFunction ѕЗ ((ќ≤ : вДВ) + ќ≥ * Complex.I) = 0 вЖТ
      ќ≤ вЙ§ 1 - 1 / (335 * (1360 + C) * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20)) := by
  obtain вЯ®KP, hKPвЯ© := twist_re_le_uniform
  set KP' : вДЭ := max KP 1 with hKP'def
  have hKP'1 : 1 вЙ§ KP' := le_max_right _ _
  have hKPle : KP вЙ§ KP' := le_max_left _ _
  refine вЯ®KP', hKP'1, ?_вЯ©
  intro N _ ѕЗ hѕЗ hѕЗ2 ќ≤ ќ≥ hzero
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have h47 : (0:вДЭ) < 4 * |ќ≥| + 7 := by positivity
  have harg1 : (1:вДЭ) вЙ§ (N : вДЭ) * (4 * |ќ≥| + 7) := by nlinarith [abs_nonneg ќ≥]
  have hLвВА : 0 вЙ§ Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) := Real.log_nonneg harg1
  set M : вДЭ := 80 * (Real.log ((N : вДЭ) * (4 * |ќ≥| + 7)) + 20) + 20 * KP' + 24000 with hMdef
  have hM25600 : 25600 вЙ§ M := by rw [hMdef]; nlinarith
  have hM0 : (0:вДЭ) < M := by linarith
  set ѕГ : вДЭ := 1 + 1 / (100 * M) with hѕГdef
  have hinv0 : (0:вДЭ) < 1 / (100 * M) := by
    apply div_pos one_pos
    linarith
  have hѕГ1 : 1 < ѕГ := by rw [hѕГdef]; linarith
  have hѕГ0 : (0:вДЭ) < ѕГ := by linarith
  have hѕГ2 : ѕГ вЙ§ 2 := by
    rw [hѕГdef]
    have h1 : 1 / (100 * M) вЙ§ 1 := by
      rw [div_le_one (by linarith)]
      linarith
    linarith
  have hѕГ1' : ѕГ - 1 = 1 / (100 * M) := by rw [hѕГdef]; ring
  have hќ≤1 : ќ≤ < 1 := by
    by_contra hќ≤'
    push_neg at hќ≤'
    have hre : (1:вДЭ) вЙ§ ((ќ≤ : вДВ) + ќ≥ * Complex.I).re := by simp; linarith
    exact DirichletCharacter.LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ) hre hzero
  have hѕГќ≤0 : (0:вДЭ) < ѕГ - ќ≤ := by linarith
  -- log M вЙ§ 2вИЪM and 80вИЪM вЙ§ M/2
  set sM : вДЭ := M ^ ((1:вДЭ)/2) with hsMdef
  have hsM0 : 0 вЙ§ sM := Real.rpow_nonneg hM0.le _
  have hsq : sM ^ (2:вДХ) = M := by
    rw [hsMdef, вЖР Real.rpow_natCast (M ^ ((1:вДЭ)/2)) 2, вЖР Real.rpow_mul hM0.le]
    norm_num
