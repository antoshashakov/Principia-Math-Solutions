theorem negl_bound_ax : вИА cвВА : вДЭ, 0 < cвВА вЖТ вИГ XвВБ : вДХ, вИА X : вДХ, XвВБ вЙ§ X вЖТ вИА n : вДХ,
    X / 2 < n вЖТ n вЙ§ X вЖТ
    2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) вЙ§ cвВА * X / 2 := negl_bound

theorem hvar_of_arc_error_ax (repW cmodelRe mterm : вДХ вЖТ вДХ вЖТ вДЭ)
    (hcore : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - cmodelRe X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3)
    (harc : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (cmodelRe X n - mterm X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3) :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, (repW X n - mterm X n) ^ 2
        вЙ§ ќµ * (X : вДЭ) * (((X : вДЭ) + 1) / 16) ^ 2 :=
  hvar_of_arc_error repW cmodelRe mterm hcore harc

/-- **Almost-all binary Goldbach вАФ final assembly.** `DensityZero notSumOfTwoPrimes` (almost
    every even number is a sum of two primes) follows from the ONE remaining analytic input:
    the major-arc L¬≤ error `вИС_{nвИИ(X/2,X]} (Re cmodel(X+1,n) вИТ mainTerm(X,n))¬≤ вЙ§ ќµX¬≥`. Everything
    else is proven: `hmain` (singular-series positivity `рЭФЦ(n)вЙ•1/4` + kernel bound), `hnegl`, and
    the variance bridge (`core_variance` вЖТ `core_variance_repWeight` вЖТ triangle). -/
theorem almost_all_goldbach_final
    (harc : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, ((cmodel (X + 1) n).re - mainTerm X n) ^ 2 вЙ§ ќµ * (X : вДЭ) ^ 3) :
    DensityZero notSumOfTwoPrimes := by
  apply almost_all_goldbach_of_weighted_variance_indexed mainTerm (fun X => ((X : вДЭ) + 1) / 16)
  ¬Ј intro X; positivity
  ¬Ј exact hmain_bound_ax
  ¬Ј obtain вЯ®XвВБ, hXвВБвЯ© := negl_bound_ax (1 / 16) (by norm_num)
    refine вЯ®XвВБ, fun X hX n hn1 hn2 => ?_вЯ©
    have h := hXвВБ X hX n hn1 hn2
