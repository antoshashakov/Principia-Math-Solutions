    intro z
    induction z with
    | zero =>
      intro h0
      omega
    | succ m ihm =>
      intro hxm
      rcases Nat.lt_or_ge m x with hlt | hge
      ¬Ј have hx' : x = m + 1 := by omega
        subst hx'
        have hall : вИА n вИИ range (m + 1), (if n < m + 1 then (0:вДЭ)
            else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
              - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)))) = 0 := by
          intro n hn
          rw [Finset.mem_range] at hn
          rw [if_pos hn]
        rw [Finset.sum_congr rfl hall, Finset.sum_const, smul_zero, sub_self, mul_zero]
      ¬Ј rw [Finset.sum_range_succ, ihm hge, if_neg (by omega)]
        push_cast
        ring
