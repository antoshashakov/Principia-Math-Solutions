theorem reflect_mem_right (e d q : Nat) (he : 0 < e) (hd : 0 < d)
    (hq : q вИИ (e * d).divisors.filter (fun q => q вЙ§ d)) :
    (e * d) / q вИИ (e * d).divisors.filter (fun r => e вЙ§ r) := by
  rw [Finset.mem_filter] at hq вКҐ
  rcases hq with вЯ®hqdivs, hqleвЯ©
  have hqdvd : q вИ£ e * d := (Nat.mem_divisors.mp hqdivs).1
  have hned0 : e * d вЙ† 0 := (Nat.mem_divisors.mp hqdivs).2
  have hqpos : 0 < q := Nat.pos_of_dvd_of_pos hqdvd (Nat.mul_pos he hd)
  constructor
  ¬Ј exact Nat.mem_divisors.mpr вЯ®Nat.div_dvd_of_dvd hqdvd, hned0вЯ©
  ¬Ј exact (Nat.le_div_iff_mul_le hqpos).2 (by
      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
        using Nat.mul_le_mul_left e hqle)

theorem reflect_mem_left (e d r : Nat) (_he : 0 < e) (_hd : 0 < d)
    (hr : r вИИ (e * d).divisors.filter (fun r => e вЙ§ r)) :
    (e * d) / r вИИ (e * d).divisors.filter (fun q => q вЙ§ d) := by
  rw [Finset.mem_filter] at hr вКҐ
