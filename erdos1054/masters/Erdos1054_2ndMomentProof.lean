    have h26 : (40:вДЭ) вЙ§ 40 * (Kc*LT) := by nlinarith [hKc3, hLT20]
    have h27 : 80 * (Kc*LT) вЙ§ 80*Kc*LT^2 := by nlinarith [hKc3, hLT20]
    have h28 : 80*Kc*LT^2 вЙ§ 80*Kc*LT^2 * ((N:вДЭ))^ќµ := by
      nlinarith [hNp1, hKc3, hLT20]
    have h29 : 80*Kc*LT^2 * ((N:вДЭ))^ќµ = 80*Kc * ((N:вДЭ))^ќµ * LT^2 := by ring
    linarith [h25, h26, h27, h28, h29.le, h29.ge]
  have hCexp : C * ((N:вДЭ))^ќµ * LT^2
      = (4*Kc/c) * ((N:вДЭ))^ќµ * LT^2 + 80*Kc * ((N:вДЭ))^ќµ * LT^2 := by
    rw [hCdef]
    ring
  linarith [htri, hsumA, h40A, hCexp.le, hCexp.ge]

open Finset in
open scoped ArithmeticFunction in
/-- **Character orthogonality for the AP prime-counting sum** (SW brick B5a): for a
    unit residue `a` mod `q`, exactly
    `ѕЖ(q)¬ЈвИС_{n<X, nвЙ°a} ќЫ(n) = вИС_ѕЗ ѕЗ(aвБї¬є)¬ЈвИС_{n<X} ѕЗ(n)ќЫ(n)` вАФ the bridge from the
    twisted sums `ѕИ(X,ѕЗ)` to primes in the progression. EXACT identity: terms with
    `gcd(n,q) > 1` vanish on both sides. -/
theorem psi_ap_orthogonality (q : вДХ) [NeZero q] (a : ZMod q) (ha : IsUnit a) (X : вДХ) :
    (q.totient : вДВ) * (вИС n вИИ Finset.range X,
        if a = ((n : ZMod q)) then ((ќЫ n : вДЭ) : вДВ) else 0)
      = вИС ѕЗ : DirichletCharacter вДВ q, (ѕЗ aвБї¬є) *
          (вИС n вИИ Finset.range X, ѕЗ ((n : ZMod q)) * ((ќЫ n : вДЭ) : вДВ)) := by
  symm
  calc вИС ѕЗ : DirichletCharacter вДВ q, (ѕЗ aвБї¬є) *
      (вИС n вИИ Finset.range X, ѕЗ ((n : ZMod q)) * ((ќЫ n : вДЭ) : вДВ))
      = вИС ѕЗ : DirichletCharacter вДВ q, вИС n вИИ Finset.range X,
          (ѕЗ aвБї¬є * ѕЗ ((n : ZMod q))) * ((ќЫ n : вДЭ) : вДВ) := by
        apply Finset.sum_congr rfl
        intro ѕЗ _
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro n _
        ring
    _ = вИС n вИИ Finset.range X, вИС ѕЗ : DirichletCharacter вДВ q,
          (ѕЗ aвБї¬є * ѕЗ ((n : ZMod q))) * ((ќЫ n : вДЭ) : вДВ) := Finset.sum_comm
    _ = вИС n вИИ Finset.range X,
          (if a = ((n : ZMod q)) then (q.totient : вДВ) else 0) * ((ќЫ n : вДЭ) : вДВ) := by
        apply Finset.sum_congr rfl
        intro n _
        rw [вЖР Finset.sum_mul,
          DirichletCharacter.sum_char_inv_mul_char_eq (R := вДВ) ha ((n : ZMod q))]
    _ = (q.totient : вДВ) * (вИС n вИИ Finset.range X,
          if a = ((n : ZMod q)) then ((ќЫ n : вДЭ) : вДВ) else 0) := by
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro n _
        split_ifs
        ¬Ј ring
        ¬Ј ring

/-- **вИТLвА≤/L(ѕЗ) as the ѕЗ¬ЈќЫ Dirichlet series** (SW Perron input, brick B2a): for `Re s > 1`, the
    negative logarithmic derivative of `LFunction ѕЗ` equals `вИС_n ѕЗ(n)ќЫ(n) n^{-s}`. Bridges the contour
    `logDeriv` bounds (`contour_logDeriv_bound`, stated for `LFunction ѕЗ`) to the Perron integrand
    (the twisted von-Mangoldt series). Mathlib `deriv_LFunction_eq_deriv_LSeries` +
    `LFunction_eq_LSeries` + `LSeries_twist_vonMangoldt_eq`. (`вЖЧ` avoided вАФ `open Metric` shadows the
    `scoped[LSeries.notation]` arrow.) -/
lemma neg_logDeriv_LFunction_eq {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) {s : вДВ}
    (hs : 1 < s.re) :
    -deriv (DirichletCharacter.LFunction ѕЗ) s / DirichletCharacter.LFunction ѕЗ s
      = LSeries (fun n : вДХ => ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ)) s := by
  rw [deriv_LFunction_eq_deriv_LSeries ѕЗ hs, LFunction_eq_LSeries ѕЗ hs]
  exact (LSeries_twist_vonMangoldt_eq ѕЗ hs).symm

/-- **`LFunction ѕЗ` is entire for `ѕЗ вЙ† 1`** (SW brick B3 input): no poles inside the contour
    rectangle. Mathlib `differentiable_LFunction`. -/
lemma LFunction_entire {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1) :
    Differentiable вДВ (DirichletCharacter.LFunction ѕЗ) :=
  differentiable_LFunction hѕЗ

/-- **`LFunction ѕЗ` has no zeros on `Re s вЙ• 1` for `ѕЗ вЙ† 1`** (SW brick B3 input): the contour's
    right edge `Re = ѕГвВА > 1` (and the boundary `Re = 1`) is zero-free, so `LвА≤/L` is holomorphic there.
    Mathlib `LFunction_ne_zero_of_one_le_re`. -/
lemma LFunction_ne_zero_re_ge_one {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    {s : вДВ} (hs : 1 вЙ§ s.re) : DirichletCharacter.LFunction ѕЗ s вЙ† 0 :=
  LFunction_ne_zero_of_one_le_re ѕЗ (Or.inl hѕЗ) hs


/-- **Perron-integrand reshape** (SW brick W1j): `(вИТLвА≤/L ¬Ј X^s)/(s(s+1)) = вИТLвА≤/L ¬Ј (X^s/(s(s+1)))`
    under the integral вАФ aligns `smoothed_perron_LFunction`'s form with the `G`-form used by every
    W1 estimate lemma (`mul_div_assoc` under `funext`). -/
lemma perron_integrand_reshape {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (X ѕГ : вДЭ) :
    (вИЂ t : вДЭ, (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I))
        * (X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1)))
      = вИЂ t : вДЭ, (-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I))
        * ((X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1))) := by
  congr 1
  funext t
  rw [mul_div_assoc]

