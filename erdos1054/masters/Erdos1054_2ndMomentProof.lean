  have hcombo := logDeriv_combo_re_nonneg ѕЗ (1+d) ќ≥ hѕГ1
  rw [hѕЗ2] at hcombo
  have hlin : (3 * LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) (((1+d : вДЭ) : вДВ))
       + 4 * LSeries (вЖЧѕЗ * вЖЧќЫ) ((((1+d : вДЭ)) : вДВ) + ќ≥ * I)
       + LSeries (вЖЧ(1 : DirichletCharacter вДВ N) * вЖЧќЫ) ((((1+d : вДЭ)) : вДВ) + 2 * ќ≥ * I)).re
