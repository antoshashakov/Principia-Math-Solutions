open Finset in
set_option maxHeartbeats 4000000 in
/-- **Per-anchor integral error** (brick D2a): over one Farey window (radius
    `1/(q(N+1))`, so `N|ќ≤| вЙ§ 1` and the `(1+2ѕАN|ќ≤|)` factor is `вЙ§ 1+2ѕА`), the
    integral of `(S¬≤ вИТ model¬≤)¬Јe(вИТnќ±)` is bounded вАФ uniformly in `n` and the
    anchor вАФ by `C¬ЈN¬Ј(log N + 1)¬Јexp(вИТc(log N)^{1/10})`; the window length
    `2/(q(N+1))` cancels the `q¬ЈN¬≤` of the pointwise D1 bound. -/
theorem anchor_integral_error (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИА q : вДХ, 0 < q вЖТ (q : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) вЖТ
    вИА a : вД§, вИА n : вДХ,
    вАЦвИЂ ќ± in Metric.closedBall ((a : вДЭ) / q) (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1,
        ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
          - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
      вЙ§ C * N * (Real.log N + 1) * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
  obtain вЯ®c, C, hc0, hC0, NвВА, hD1вЯ© := rated_arc_sq_model B hB
  refine вЯ®c, 20 * C, hc0, by positivity, max NвВА 3, ?_вЯ©
  intro N hNвВА q hq0 hqB a n
  have hNNвВА : NвВА вЙ§ N := le_trans (le_max_left _ _) hNвВА
  have hN3 : 3 вЙ§ N := le_trans (le_max_right _ _) hNвВА
  have hq0R : (0:вДЭ) < (q:вДЭ) := by exact_mod_cast hq0
  have hq1R : (1:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq0
  have hN0R : (0:вДЭ) < (N:вДЭ) := by
    have h1 : 0 < N := by omega
    exact_mod_cast h1
  have hr0 : (0:вДЭ) вЙ§ 1 / (q * (N + 1)) := by positivity
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := by
    apply Real.log_nonneg
    have h5 : 1 вЙ§ N := by omega
    exact_mod_cast h5
  have hK : (0:вДЭ) вЙ§ C * q * N ^ 2 * (Real.log N + 1)
      * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi) := by
    have h1 : (0:вДЭ) вЙ§ 1 + 2 * Real.pi := by nlinarith [Real.pi_pos]
    positivity
  -- pointwise bound on the window
  have hpt : вИА ќ± вИИ Metric.closedBall ((a : вДЭ) / q) (1 / (q * (N + 1)))
      вИ© Set.Ioc (0:вДЭ) 1,
      вАЦ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
        - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
            * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
      вЙ§ C * q * N ^ 2 * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi) := by
    intro ќ± hќ±
    obtain вЯ®hball, -вЯ© := hќ±
    rw [Metric.mem_closedBall, Real.dist_eq] at hball
    rw [norm_mul, e_norm, mul_one]
    have hќ≤ := hD1 N hNNвВА q hq0 hqB a (ќ± - (a : вДЭ) / (q : вДЭ))
    have hќ±eq : (a : вДЭ) / (q : вДЭ) + (ќ± - (a : вДЭ) / (q : вДЭ)) = ќ± := by ring
    rw [hќ±eq] at hќ≤
    refine hќ≤.trans ?_
    have hfac : 1 + 2 * Real.pi * N * |ќ± - (a : вДЭ) / (q : вДЭ)| вЙ§ 1 + 2 * Real.pi := by
      have h3 : (N:вДЭ) * (1 / (q * (N + 1))) вЙ§ 1 := by
        rw [mul_one_div, div_le_one (by positivity)]
        nlinarith
      have h1 : (N:вДЭ) * |ќ± - (a : вДЭ) / (q : вДЭ)| вЙ§ 1 := by
        calc (N:вДЭ) * |ќ± - (a : вДЭ) / (q : вДЭ)| вЙ§ (N:вДЭ) * (1 / (q * (N + 1))) := by
              apply mul_le_mul_of_nonneg_left hball (by positivity)
          _ вЙ§ 1 := h3
      nlinarith [Real.pi_pos]
    have hK2 : (0:вДЭ) вЙ§ C * q * N ^ 2 * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by positivity
    exact mul_le_mul_of_nonneg_left hfac hK2
  -- the window has small measure
  have hvol : (MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
      (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)).toReal вЙ§ 2 / (q * (N + 1)) := by
    have h1 : MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
        (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)
        вЙ§ ENNReal.ofReal (2 * (1 / (q * (N + 1)))) := by
      calc MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
          (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)
          вЙ§ MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
            (1 / (q * (N + 1)))) :=
            MeasureTheory.measure_mono Set.inter_subset_left
        _ = ENNReal.ofReal (2 * (1 / (q * (N + 1)))) :=
            Real.volume_closedBall _ _
    calc (MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
        (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)).toReal
        вЙ§ (ENNReal.ofReal (2 * (1 / (q * (N + 1))))).toReal :=
          ENNReal.toReal_mono ENNReal.ofReal_ne_top h1
      _ = 2 * (1 / (q * (N + 1))) := ENNReal.toReal_ofReal (by positivity)
      _ = 2 / (q * (N + 1)) := by ring
  have hfin : MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
      (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1) < вК§ :=
    lt_of_le_of_lt (MeasureTheory.measure_mono Set.inter_subset_left)
      MeasureTheory.measure_closedBall_lt_top
  have hint : вАЦвИЂ ќ± in Metric.closedBall ((a : вДЭ) / q) (1 / (q * (N + 1)))
      вИ© Set.Ioc (0:вДЭ) 1,
      ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
        - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
            * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
      вЙ§ C * q * N ^ 2 * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi)
        * (MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
            (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)).toReal := by
    have h := MeasureTheory.norm_setIntegral_le_of_norm_le_const hfin hpt
    simpa [MeasureTheory.measureReal_def] using h
  refine hint.trans ?_
  -- (K')¬Јvol вЙ§ 20C¬ЈN¬Ј(log N+1)¬Јe^{вИТcL}
  have hѕА4 : Real.pi вЙ§ 4 := Real.pi_le_four
  calc C * q * N ^ 2 * (Real.log N + 1)
      * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi)
      * (MeasureTheory.volume (Metric.closedBall ((a : вДЭ) / q)
          (1 / (q * (N + 1))) вИ© Set.Ioc (0:вДЭ) 1)).toReal
      вЙ§ C * q * N ^ 2 * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi)
        * (2 / (q * (N + 1))) := by
        apply mul_le_mul_of_nonneg_left hvol hK
    _ = (2 * (1 + 2 * Real.pi)) * (C * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))) * ((N:вДЭ) ^ 2 / (N + 1)) := by
        field_simp
    _ вЙ§ (2 * (1 + 2 * Real.pi)) * (C * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10))) * (N:вДЭ) := by
        apply mul_le_mul_of_nonneg_left ?_ ?_
        ¬Ј rw [div_le_iffвВА (by positivity)]
          nlinarith
        ¬Ј have h1 : (0:вДЭ) вЙ§ 1 + 2 * Real.pi := by nlinarith [Real.pi_pos]
          positivity
    _ вЙ§ 20 * C * N * (Real.log N + 1)
        * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) := by
        have h1 : 2 * (1 + 2 * Real.pi) вЙ§ 20 := by nlinarith
        have h2 : (0:вДЭ) вЙ§ C * (Real.log N + 1)
            * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (N:вДЭ) := by positivity
        nlinarith [h2, mul_nonneg (mul_nonneg hC0.le
          (by linarith : (0:вДЭ) вЙ§ Real.log N + 1)) (Real.exp_pos
          (-c * Real.log N ^ ((1:вДЭ)/10))).le]

