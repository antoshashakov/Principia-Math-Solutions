/-- **R2+R3: the gapвАУsaving balance at `T = exp u`** вАФ with `u вЙ§ LT вЙ§ 2u`, `u^{вИТ1/2} вЙ§ Ne вЙ§ 1`,
    `0 < c вЙ§ 1/2`: the exponential saving grows, `(c/2)¬Јu^{1/2} вЙ§ g¬Јu¬≤` (R2), while the strip stays
    thin enough that `g¬Јu¬≤ вЙ§ u/2` (R3) вАФ so `X^g/T = exp(g¬Јu¬≤ вИТ u) вЙ§ exp(вИТu/2)`. Here `g = c¬ЈNe/LT`,
    `u¬≤ = log X`. -/
lemma rate_g_bounds (c u LT Ne : вДЭ) (hc0 : 0 < c) (hc12 : c вЙ§ 1/2)
    (hu1 : 1 вЙ§ u) (hLTlo : u вЙ§ LT) (hLThi : LT вЙ§ 2*u)
    (hNe_lo : u ^ (-(1:вДЭ)/2) вЙ§ Ne) (hNe_hi : Ne вЙ§ 1) :
    (c/2) * u ^ ((1:вДЭ)/2) вЙ§ (c * Ne / LT) * (u * u) вИІ (c * Ne / LT) * (u * u) вЙ§ u/2 := by
  have hu0 : (0:вДЭ) < u := by linarith
  have hLT0 : (0:вДЭ) < LT := by linarith
  have hNe0 : (0:вДЭ) < Ne := lt_of_lt_of_le (Real.rpow_pos_of_pos hu0 _) hNe_lo
  have hu2 : u * u = u ^ ((2:вДХ):вДЭ) := by
    rw [Real.rpow_natCast]
    ring
  have e1 : u ^ ((1:вДЭ)/2) * u = u ^ ((3:вДЭ)/2) := by
    nth_rewrite 2 [show u = u ^ (1:вДЭ) from (Real.rpow_one u).symm]
    rw [вЖР Real.rpow_add hu0]
    norm_num
  have e2 : u ^ (-(1:вДЭ)/2) * (u * u) = u ^ ((3:вДЭ)/2) := by
    rw [hu2, вЖР Real.rpow_add hu0]
    norm_num
  constructor
  ¬Ј -- R2: (c/2)¬Јu^{1/2} вЙ§ g¬Јu¬≤
    rw [show (c * Ne / LT) * (u * u) = (c * Ne * (u * u)) / LT from by ring,
        le_div_iffвВА hLT0]
    have h1 : (c/2) * u ^ ((1:вДЭ)/2) * LT вЙ§ (c/2) * u ^ ((1:вДЭ)/2) * (2*u) := by
      apply mul_le_mul_of_nonneg_left hLThi (by positivity)
    have h2 : (c/2) * u ^ ((1:вДЭ)/2) * (2*u) = c * (u ^ ((1:вДЭ)/2) * u) := by ring
    have h3 : u ^ ((3:вДЭ)/2) вЙ§ Ne * (u * u) := by
      calc u ^ ((3:вДЭ)/2) = u ^ (-(1:вДЭ)/2) * (u * u) := e2.symm
        _ вЙ§ Ne * (u * u) := by
            apply mul_le_mul_of_nonneg_right hNe_lo (by positivity)
    have h4 : c * (u ^ ((1:вДЭ)/2) * u) вЙ§ c * (Ne * (u * u)) := by
      apply mul_le_mul_of_nonneg_left _ hc0.le
      rw [e1]
      exact h3
    calc (c/2) * u ^ ((1:вДЭ)/2) * LT вЙ§ c * (u ^ ((1:вДЭ)/2) * u) := by linarith
      _ вЙ§ c * (Ne * (u * u)) := h4
      _ = c * Ne * (u * u) := by ring
  ¬Ј -- R3: g¬Јu¬≤ вЙ§ u/2
    have h5 : c * Ne / LT вЙ§ c / u := by
      have h5a : c * Ne / LT вЙ§ c / LT := by
        apply div_le_div_of_nonneg_right _ hLT0.le
        nlinarith
      have h5b : c / LT вЙ§ c / u := div_le_div_of_nonneg_left hc0.le hu0 hLTlo
      linarith
    have h6 : (c / u) * (u * u) = c * u := by
      field_simp
    calc (c * Ne / LT) * (u * u) вЙ§ (c / u) * (u * u) := by
          apply mul_le_mul_of_nonneg_right h5 (by positivity)
      _ = c * u := h6
      _ вЙ§ u/2 := by nlinarith

/-- **R4a: polylog absorption into the exponential saving** вАФ for `u вЙ• max((80/c)вБі, 256)`:
    `C¬Јu^{5/2}¬Јe^{вИТ(c/4)вИЪu} + K¬Јu¬≥¬Јe^{вИТu/2} вЙ§ (C+K)¬Јe^{вИТ(c/8)вИЪu}`. Via `log a вЙ§ xвИТy вЗТ
    a¬Јe^{вИТx} вЙ§ e^{вИТy}` + `log u вЙ§ 4u^{1/4}` (`log_le_rpow_div`). -/
lemma poly_exp_absorption (c C K : вДЭ) (hc0 : 0 < c) (hc12 : c вЙ§ 1/2)
    (hC0 : 0 вЙ§ C) (hK0 : 0 вЙ§ K) :
    вИА u : вДЭ, max ((80/c)^4) 256 вЙ§ u вЖТ
      C * u ^ ((5:вДЭ)/2) * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))
        + K * u ^ (3:вДЭ) * Real.exp (-(u/2))
      вЙ§ (C + K) * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) := by
  intro u hu
  have hu256 : (256:вДЭ) вЙ§ u := le_trans (le_max_right _ _) hu
  have hu80c : (80/c)^4 вЙ§ u := le_trans (le_max_left _ _) hu
  have hu0 : (0:вДЭ) < u := by linarith
  have hu1 : (1:вДЭ) вЙ§ u := by linarith
  have hs0 : (0:вДЭ) < u ^ ((1:вДЭ)/2) := Real.rpow_pos_of_pos hu0 _
  have hq0 : (0:вДЭ) < u ^ ((1:вДЭ)/4) := Real.rpow_pos_of_pos hu0 _
  -- log u вЙ§ 4¬Јu^{1/4}
  have hlogu : Real.log u вЙ§ 4 * u ^ ((1:вДЭ)/4) := by
    have := Real.log_le_rpow_div hu0.le (by norm_num : (0:вДЭ) < 1/4)
    calc Real.log u вЙ§ u ^ ((1:вДЭ)/4) / (1/4) := this
      _ = 4 * u ^ ((1:вДЭ)/4) := by ring
  -- u^{1/4}¬Јu^{1/4} = u^{1/2}
  have hqq : u ^ ((1:вДЭ)/4) * u ^ ((1:вДЭ)/4) = u ^ ((1:вДЭ)/2) := by
    rw [вЖР Real.rpow_add hu0]; norm_num
  have hss : u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) = u := by
    rw [вЖР Real.rpow_add hu0]; norm_num
  -- (80/c) вЙ§ u^{1/4}
  have h80 : 80/c вЙ§ u ^ ((1:вДЭ)/4) := by
    have h1 : ((80/c)^4 : вДЭ) ^ ((1:вДЭ)/4) вЙ§ u ^ ((1:вДЭ)/4) :=
      Real.rpow_le_rpow (by positivity) hu80c (by norm_num)
    rwa [show ((80/c):вДЭ)^4 = ((80/c):вДЭ)^((4:вДХ):вДЭ) from by rw [Real.rpow_natCast],
      вЖР Real.rpow_mul (by positivity), show ((4:вДХ):вДЭ) * ((1:вДЭ)/4) = 1 by norm_num,
      Real.rpow_one] at h1
  -- 4 вЙ§ u^{1/4} (from u вЙ• 256)
  have h4q : (4:вДЭ) вЙ§ u ^ ((1:вДЭ)/4) := by
    have h1 : ((256:вДЭ)) ^ ((1:вДЭ)/4) вЙ§ u ^ ((1:вДЭ)/4) :=
      Real.rpow_le_rpow (by norm_num) hu256 (by norm_num)
    rwa [show (256:вДЭ) = (4:вДЭ)^((4:вДХ):вДЭ) from by rw [Real.rpow_natCast]; norm_num,
      вЖР Real.rpow_mul (by norm_num), show ((4:вДХ):вДЭ) * ((1:вДЭ)/4) = 1 by norm_num,
      Real.rpow_one] at h1
  -- helper: log a вЙ§ x вИТ y вЗТ a¬Јe^{вИТx} вЙ§ e^{вИТy}
  have haux : вИА a x y : вДЭ, 0 < a вЖТ Real.log a вЙ§ x - y вЖТ
      a * Real.exp (-x) вЙ§ Real.exp (-y) := by
    intro a x y ha hlog
    have h1 : a вЙ§ Real.exp (x - y) := (Real.log_le_iff_le_exp ha).mp hlog
    calc a * Real.exp (-x) вЙ§ Real.exp (x - y) * Real.exp (-x) :=
          mul_le_mul_of_nonneg_right h1 (Real.exp_pos _).le
      _ = Real.exp (-y) := by rw [вЖР Real.exp_add]; ring_nf
  -- term 1
  have hterm1 : u ^ ((5:вДЭ)/2) * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))
      вЙ§ Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) := by
    apply haux _ _ _ (Real.rpow_pos_of_pos hu0 _)
    rw [Real.log_rpow hu0]
    have h1 : (5:вДЭ)/2 * Real.log u вЙ§ 10 * u ^ ((1:вДЭ)/4) := by
      have hlogu0 : (0:вДЭ) вЙ§ Real.log u := Real.log_nonneg hu1
      nlinarith
    have h2 : 10 * u ^ ((1:вДЭ)/4) вЙ§ (c/8) * u ^ ((1:вДЭ)/2) := by
      have h3 : (80:вДЭ) вЙ§ c * u ^ ((1:вДЭ)/4) := by
        have := mul_le_mul_of_nonneg_left h80 hc0.le
        calc (80:вДЭ) = c * (80/c) := by field_simp
          _ вЙ§ c * u ^ ((1:вДЭ)/4) := this
      calc 10 * u ^ ((1:вДЭ)/4) = (80 * (u ^ ((1:вДЭ)/4) * u ^ ((1:вДЭ)/4))) / (8 * u ^ ((1:вДЭ)/4)) := by
            field_simp
            ring
        _ вЙ§ ((c * u ^ ((1:вДЭ)/4)) * (u ^ ((1:вДЭ)/4) * u ^ ((1:вДЭ)/4))) / (8 * u ^ ((1:вДЭ)/4)) := by
            apply div_le_div_of_nonneg_right _ (by positivity)
            apply mul_le_mul_of_nonneg_right h3 (by positivity)
        _ = (c/8) * (u ^ ((1:вДЭ)/4) * u ^ ((1:вДЭ)/4)) := by
            field_simp
        _ = (c/8) * u ^ ((1:вДЭ)/2) := by rw [hqq]
    have hgoal : (c/4) * u ^ ((1:вДЭ)/2) - (c/8) * u ^ ((1:вДЭ)/2) = (c/8) * u ^ ((1:вДЭ)/2) := by ring
    linarith
  -- term 2
  have hterm2 : u ^ (3:вДЭ) * Real.exp (-(u/2))
      вЙ§ Real.exp (-((c/8) * u ^ ((1:вДЭ)/2))) := by
    apply haux _ _ _ (Real.rpow_pos_of_pos hu0 _)
    rw [Real.log_rpow hu0]
    have h1 : (3:вДЭ) * Real.log u вЙ§ 12 * u ^ ((1:вДЭ)/4) := by
      have hlogu0 : (0:вДЭ) вЙ§ Real.log u := Real.log_nonneg hu1
      nlinarith
    -- 12¬Јu^{1/4} вЙ§ u/4: 12 вЙ§ (1/4)¬Јu^{3/4} вЯЄ u^{3/4} = u^{1/4}¬Јu^{1/2} вЙ• 4¬Ј16 = 64 вЙ• 48
    have h16 : (16:вДЭ) вЙ§ u ^ ((1:вДЭ)/2) := by
      have h := mul_le_mul h4q h4q (by norm_num) hq0.le
