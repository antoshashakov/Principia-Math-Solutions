open DirichletCharacter Complex ArithmeticFunction Finset in
/-- **W5: SIEGELвАУWALFISZ, the statement of the RatedWindow axiom, PROVEN** вАФ orthogonality wiring
    of the ѕЗвВА bound (W3) and the sharp ѕЗвЙ†1 bound (W4) with the character count `ѕЖ(q)`. -/
theorem siegel_walfisz_proven (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ XвВА : вДЭ, вИА X : вДЭ, XвВА вЙ§ X вЖТ
    вИА (q : вДХ) [NeZero q], (q : вДЭ) вЙ§ Real.log X ^ (B : вДЭ) вЖТ
    вИА a : ZMod q, IsUnit a вЖТ
    |(вИС n вИИ Finset.range (вМКXвМЛвВК + 1), if a = ((n : ZMod q)) then vonMangoldt n else 0)
      - X / q.totient| вЙ§ C * X * Real.exp (-c * Real.log X ^ ((1:вДЭ)/10)) := by
  obtain вЯ®cвВГ, CвВГ, hcвВГ0, hCвВГ0, hѕЗвВАвЯ© := psi_unit_sum_bound
  obtain вЯ®cвВЕ, CвВЕ, XвВЕ, hcвВЕ0, hCвВЕ0, hsharpвЯ© := psi_sharp_SW_rate B hB
  set c := min (min cвВГ (cвВЕ/2)) (1/2) with hcdef
  have hc0 : 0 < c := by
    apply lt_min (lt_min hcвВГ0 (by linarith)) (by norm_num)
  set M := max 2 (max ((40*B/cвВЕ)^2) (Real.log (60*B))) with hMdef
  have hM2 : (2:вДЭ) вЙ§ M := le_max_left _ _
  refine вЯ®c, CвВГ + CвВЕ + 1, by positivity, by positivity,
    max XвВЕ (Real.exp (M^10)), ?_вЯ©
  intro X hX q _ hqB a ha
  have hXXвВЕ : XвВЕ вЙ§ X := le_trans (le_max_left _ _) hX
  have hLM : M^10 вЙ§ Real.log X := by
    have h1 : Real.exp (M^10) вЙ§ X := le_trans (le_max_right _ _) hX
    have h2 := Real.log_le_log (Real.exp_pos _) h1
    rwa [Real.log_exp] at h2
  have hM10 : (1024:вДЭ) вЙ§ M^10 := by
    calc (1024:вДЭ) = 2^10 := by norm_num
      _ вЙ§ M^10 := pow_le_pow_leftвВА (by norm_num) hM2 10
  have hL1 : (1:вДЭ) вЙ§ Real.log X := by linarith
  have hL0 : (0:вДЭ) < Real.log X := by linarith
  have hX2 : (2:вДЭ) вЙ§ X := by
    have h1 : Real.exp (M^10) вЙ§ X := le_trans (le_max_right _ _) hX
    have h2 := Real.add_one_le_exp (M^10)
    linarith
  have hX0 : (0:вДЭ) < X := by linarith
  set u := Real.log X ^ ((1:вДЭ)/10) with hudef
  have hu0 : (0:вДЭ) < u := Real.rpow_pos_of_pos hL0 _
  have huM : M вЙ§ u := by
    have h1 : (M^10) ^ ((1:вДЭ)/10) вЙ§ (Real.log X) ^ ((1:вДЭ)/10) :=
      Real.rpow_le_rpow (by positivity) hLM (by norm_num)
    rwa [show (M:вДЭ)^10 = M^((10:вДХ):вДЭ) from by rw [Real.rpow_natCast],
      вЖР Real.rpow_mul (by linarith : (0:вДЭ) вЙ§ M),
      show ((10:вДХ):вДЭ) * ((1:вДЭ)/10) = 1 by norm_num, Real.rpow_one] at h1
  have hu2 : (2:вДЭ) вЙ§ u := le_trans hM2 huM
  have hu10 : u ^ (10:вДЭ) = Real.log X := by
    rw [hudef, вЖР Real.rpow_mul hL0.le]
    norm_num
  -- q and totient facts
  have hq1 : 1 вЙ§ q := Nat.one_le_iff_ne_zero.mpr (NeZero.ne q)
  have hѕЖ1 : 1 вЙ§ q.totient := Nat.totient_pos.mpr (by omega)
  have hѕЖq : q.totient вЙ§ q := Nat.totient_le q
  -- the вДВ-level orthogonality split
  have hAP := psi_ap_orthogonality q a ha (вМКXвМЛвВК + 1)
  have ha_inv : IsUnit (aвБї¬є : ZMod q) :=
    IsUnit.of_mul_eq_one a (ZMod.inv_mul_of_unit a ha)
  have hone : (1 : DirichletCharacter вДВ q) aвБї¬є = 1 := MulChar.one_apply ha_inv
  -- ѕИвВА as the real unit-restricted sum
  have hѕИвВА : (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
      (1 : DirichletCharacter вДВ q) ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ))
      = (((вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0 : вДЭ)) : вДВ) := by
    rw [Complex.ofReal_sum]
    apply Finset.sum_congr rfl
    intro n _
    by_cases h : IsUnit ((n : вДХ) : ZMod q)
    ¬Ј rw [MulChar.one_apply h, if_pos h, one_mul]
    ¬Ј rw [MulChar.map_nonunit _ h, if_neg h, zero_mul, Complex.ofReal_zero]
