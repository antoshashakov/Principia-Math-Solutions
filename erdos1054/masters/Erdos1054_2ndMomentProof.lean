            - ((t:вДЭ) - 1) / (q.totient : вДЭ)| + 1 := by
      have h1 : |((t:вДЭ) - 1) / (q.totient : вДЭ) - (t:вДЭ) * (1 / (q.totient : вДЭ))|
          вЙ§ 1 := by
        have hѕЖ0 : (q.totient : вДЭ) вЙ† 0 := by linarith
        rw [show ((t:вДЭ) - 1) / (q.totient : вДЭ) - (t:вДЭ) * (1 / (q.totient : вДЭ))
            = -(1 / (q.totient : вДЭ)) from by field_simp; ring,
          abs_neg, abs_of_pos (by positivity), div_le_one (by linarith)]
        exact hѕЖ1
      calc |(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
          - (t:вДЭ) * (1 / (q.totient : вДЭ))|
          = |((вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
              - ((t:вДЭ) - 1) / (q.totient : вДЭ))
            + (((t:вДЭ) - 1) / (q.totient : вДЭ)
