    rw [eq_div_iff (ne_of_gt hsqrtP0), Real.sqrt_eq_rpow, вЖР Real.rpow_add hP0R]
    rw [show (5 : вДЭ) / 2 + 1 / 2 = ((3 : вДХ) : вДЭ) by norm_num]
