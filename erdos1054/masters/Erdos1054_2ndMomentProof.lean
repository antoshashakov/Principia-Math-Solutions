/-- **THE GOLDFELD MASTER INEQUALITY** (Siegel brick A2h-iv): for a nonnegative
    Dirichlet-coefficient system with `a(1) = 1` and partial sums `ќїy + E(y)`,
    `|E(n)| вЙ§ C¬Јn^{3/4}(1+log n)`: at every real `ќ≤ вИИ (9/10, 1)` and every `x вЙ• 2`,
    `1 вЙ§ G(ќ≤).re + ќї¬Јx^{1вИТќ≤}/(1вИТќ≤) + 12ќї¬Јx^{вИТќ≤}/(1вИТќ≤) + 410C¬Јx^{7/8вИТќ≤}`
    where `G = ќїќґ + ќ£'E(n)ќФn` is the analytic continuation of `ќ£a(n)n^{вИТs}`.
    At a zero of the L-product `G(ќ≤) = 0` and `x вЖТ вИЮ` forces `ќї` large вАФ Siegel. -/
theorem goldfeld_master_inequality (a : вДХ вЖТ вДЭ) (lam : вДЭ) (E : вДХ вЖТ вДЭ) (C : вДЭ)
    (ha0 : вИА n, 0 вЙ§ a n) (ha1 : a 1 = 1) (hlam : 0 вЙ§ lam)
    (hAE : вИА n : вДХ, вИС m вИИ Icc 1 n, a m = lam * n + E n)
    (hC0 : 0 вЙ§ C) (hE0 : E 0 = 0)
    (hE : вИА n : вДХ, 1 вЙ§ n вЖТ |E n| вЙ§ C * (((n:вДЭ)) ^ ((3:вДЭ)/4) * (1 + Real.log n)))
    {ќ≤ : вДЭ} (hќ≤1 : 9/10 < ќ≤) (hќ≤2 : ќ≤ < 1) (x : вДХ) (hx : 2 вЙ§ x) :
    1 вЙ§ ((lam : вДВ) * riemannZeta ((ќ≤:вДВ))
          + вИС' n : вДХ, ((E n : вДЭ) : вДВ)
              * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))).re
        + lam * (((x:вДЭ)) ^ (1 - ќ≤) / (1 - ќ≤))
        + 12 * lam * (((x:вДЭ)) ^ (-ќ≤) / (1 - ќ≤))
        + 410 * C * ((x:вДЭ)) ^ (7/8 - ќ≤) := by
  have hx1 : 1 вЙ§ x := by omega
  have hx0 : (0:вДЭ) < (x:вДЭ) := by
    have : (0:вДХ) < x := by omega
    exact_mod_cast this
  have hx1r : (1:вДЭ) вЙ§ (x:вДЭ) := by
    have : (1:вДХ) вЙ§ x := hx1
    exact_mod_cast this
  have h1ќ≤ : (0:вДЭ) < 1 - ќ≤ := by linarith
  have hќ≤0 : (0:вДЭ) < ќ≤ := by linarith
  have hxќ≤ : (0:вДЭ) вЙ§ ((x:вДЭ)) ^ (-ќ≤) := Real.rpow_nonneg hx0.le _
  have hx78 : (0:вДЭ) вЙ§ ((x:вДЭ)) ^ (7/8 - ќ≤) := Real.rpow_nonneg hx0.le _
  have hx1ќ≤ : (0:вДЭ) вЙ§ ((x:вДЭ)) ^ (1 - ќ≤) := Real.rpow_nonneg hx0.le _
  -- abbreviations
  set Z : вДВ := riemannZeta ((ќ≤:вДВ)) with hZ
  set ES : вДВ := вИС' n : вДХ, ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) with hES
  set SC : вДВ := вИС n вИИ range x, ((n:вДВ)) ^ (-(ќ≤:вДВ)) with hSC
  set SF : вДВ := вИС n вИИ Icc 1 (x - 1), ((E n : вДЭ) : вДВ)
      * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ))) with hSF
  -- Step 1: the unit lower bound
