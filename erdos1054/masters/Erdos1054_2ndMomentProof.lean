  -- term 1: вЙ§ 64N¬≥/вИЪP вЙ§ (ќµ/2)N¬≥
  have hterm1 : ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2)) вЙ§ ќµ / 2 * (N : вДЭ) ^ 3 := by
    rw [hrpow]
    have hcube : ((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ 3 вЙ§ 8 * (N : вДЭ) ^ 3 := by
      calc ((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ 3 = (((Q : вДЭ) + 1) * (P : вДЭ)) ^ 3 := by ring
        _ вЙ§ (2 * (N : вДЭ)) ^ 3 := pow_le_pow_leftвВА (by positivity) hQPR 3
        _ = 8 * (N : вДЭ) ^ 3 := by ring
    have hchain : ((Q : вДЭ) + 1) ^ 3 * (8 * ((P : вДЭ) ^ 3 / Real.sqrt (P : вДЭ)))
        = 8 * (((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ 3) / Real.sqrt (P : вДЭ) := by ring
    rw [hchain]
    rw [div_le_iffвВА hsqrtP0]
    have h64 : 64 вЙ§ ќµ / 2 * Real.sqrt (P : вДЭ) := by
      calc (64:вДЭ) = ќµ / 2 * (128 / ќµ) := by field_simp; norm_num
        _ вЙ§ ќµ / 2 * Real.sqrt (P : вДЭ) := by
            apply mul_le_mul_of_nonneg_left hsqrtP (by positivity)
    have hN3 : (0:вДЭ) вЙ§ (N : вДЭ) ^ 3 := by positivity
    calc 8 * (((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ 3)
        вЙ§ 8 * (8 * (N : вДЭ) ^ 3) := by linarith
      _ = (N : вДЭ) ^ 3 * 64 := by ring
      _ вЙ§ (N : вДЭ) ^ 3 * (ќµ / 2 * Real.sqrt (P : вДЭ)) :=
          mul_le_mul_of_nonneg_left h64 hN3
      _ = ќµ / 2 * (N : вДЭ) ^ 3 * Real.sqrt (P : вДЭ) := by ring
  -- term 2: вЙ§ 384N¬ЈLвБµвБі вЙ§ (ќµ/2)N¬≥
  have hterm2 : 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 7 вЙ§ ќµ / 2 * (N : вДЭ) ^ 3 := by
    have hL54 : 768 / ќµ * L ^ 54 вЙ§ (N : вДЭ) := hNвВВ N hN2'
    have hP6 : (P : вДЭ) ^ 6 вЙ§ (L ^ 9) ^ 6 := pow_le_pow_leftвВА (by positivity) hPleL9 6
    calc 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 7
        = 192 * ((((Q : вДЭ) + 1) * (P : вДЭ)) * (P : вДЭ) ^ 6) := by ring
      _ вЙ§ 192 * ((2 * (N : вДЭ)) * (L ^ 9) ^ 6) := by
          apply mul_le_mul_of_nonneg_left _ (by norm_num)
          exact mul_le_mul hQPR hP6 (by positivity) (by positivity)
      _ = 384 * (N : вДЭ) * L ^ 54 := by ring
      _ вЙ§ ќµ / 2 * (N : вДЭ) ^ 3 := by
          have hL54' : L ^ 54 вЙ§ ќµ * (N : вДЭ) / 768 := by
            have h := mul_le_mul_of_nonneg_left hL54 (by positivity : (0:вДЭ) вЙ§ ќµ / 768)
            have hne : ќµ вЙ† 0 := ne_of_gt hќµ
            calc L ^ 54 = ќµ / 768 * (768 / ќµ * L ^ 54) := by field_simp
              _ вЙ§ ќµ / 768 * (N : вДЭ) := h
              _ = ќµ * (N : вДЭ) / 768 := by ring
          have h1 : 384 * (N : вДЭ) * L ^ 54 вЙ§ 384 * (N : вДЭ) * (ќµ * (N : вДЭ) / 768) :=
            mul_le_mul_of_nonneg_left hL54' (by positivity)
          have h2 : 384 * (N : вДЭ) * (ќµ * (N : вДЭ) / 768) = ќµ / 2 * (N : вДЭ) ^ 2 := by ring
          have h3 : ќµ / 2 * (N : вДЭ) ^ 2 вЙ§ ќµ / 2 * (N : вДЭ) ^ 3 := by
            apply mul_le_mul_of_nonneg_left _ (by positivity)
            nlinarith [hN1R]
