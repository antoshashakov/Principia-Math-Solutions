/-- **The ѕЗвЙ†1 smoothed ѕИ bound** (W1 MAIN): for every nontrivial character, the smoothed sum obeys
    `вАЦѕИ_smooth(X,ѕЗ)вАЦ вЙ§ (6M¬ЈX^{1вИТg/2} + 2¬Ј(3g/2)¬ЈM¬ЈX^{1+g}/T¬≤ + 2B¬ЈX^{1+g}/T)/(2ѕА)` with
    `g = c¬ЈN^{вИТќµ}/L_T`, `M = C¬ЈN^ќµ¬ЈL_T¬≤`. All five skeleton hypotheses discharged. -/
theorem psi_smooth_bound_chi_ne_one (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c C : вДЭ, 0 < c вИІ c вЙ§ 1/2 вИІ 1 вЙ§ C вИІ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА X : вДЭ, 1 < X вЖТ вИА T : вДЭ, 0 < T вЖТ
    вИГ B : вДЭ, 0 вЙ§ B вИІ
    вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X)вАЦ
      вЙ§ (6 * (C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2)
            * X ^ (1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2)
          + 2 * (((1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20))
                - (1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2))
              * ((C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2)
                * X ^ (1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)) / T ^ 2))
          + 2 * (B * X ^ (1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20))) / T)
        / (2 * Real.pi) := by
  obtain вЯ®c, C, hc0, hc12, hC1, hccвЯ© := contour_combined ќµ hќµ0
  refine вЯ®c, C, hc0, hc12, hC1, ?_вЯ©
  intro N _ ѕЗ hѕЗ X hX T hT
  have hX0 : (0:вДЭ) < X := by linarith
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hNe0 : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hNe1 : ((N:вДЭ))^(-ќµ) вЙ§ 1 := Real.rpow_le_one_of_one_le_of_nonpos hN1r (by linarith)
  have hNp1 : (1:вДЭ) вЙ§ ((N:вДЭ))^ќµ := Real.one_le_rpow hN1r (by linarith)
  set LT := Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 with hLTdef
  have hLT20 : (20:вДЭ) вЙ§ LT := by
    rw [hLTdef]
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*(T+1)+7)) := Real.log_nonneg (by nlinarith)
    linarith
  obtain вЯ®hg0, hg40, hѕГ'34, hѕГ1, hѕГ'ѕГ, hѕГ2вЯ© :=
    strip_numerics c (((N:вДЭ))^(-ќµ)) LT hc0 hc12 hNe0 hNe1 hLT20
  set g := c * ((N:вДЭ))^(-ќµ) / LT with hgdef
  set ѕГ' := 1 - g / 2 with hѕГ'def
  set ѕГ := 1 + g with hѕГdef
  set M := C * ((N:вДЭ))^ќµ * LT^2 with hMdef
  have hM0 : (0:вДЭ) вЙ§ M := by rw [hMdef]; positivity
  -- the contour_combined data in strip_point_M_bound's hcc shape
  have hccM : вИА s : вДВ, |s.im| вЙ§ T вЖТ ѕГ' вЙ§ s.re вЖТ s.re вЙ§ ѕГ вЖТ
      вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ вЙ§ M := by
    intro s him hre1 hre2
    exact ((hcc N ѕЗ hѕЗ T hT.le s him hre1).2 hre2)
  have hzf : вИА s : вДВ, |s.im| вЙ§ T вЖТ ѕГ' вЙ§ s.re вЖТ DirichletCharacter.LFunction ѕЗ s вЙ† 0 := by
    intro s him hre
    exact (hcc N ѕЗ hѕЗ T hT.le s him hre).1
  -- B from the ѕГ-line tail
  obtain вЯ®B, hB0, hBtвЯ© := sigma_line_tail_bound ѕЗ X ѕГ hX0 hѕГ1
  refine вЯ®B, hB0, ?_вЯ©
  -- the five skeleton hypotheses
  have hrep : (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
      ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X))
      = (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I) := by
    rw [smoothed_perron_LFunction ѕЗ X hX ѕГ hѕГ1, perron_integrand_reshape]
    rfl
  have htail : вАЦ(вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I))
      - вИЂ t in (-T)..T, G' ѕЗ X ((ѕГ : вДВ) + t * I)вАЦ вЙ§ 2 * (B * X ^ ѕГ) / T :=
    truncation_tail_bound _ (integrand_integrable_on_line ѕЗ hѕЗ X hX0 ѕГ hѕГ1)
      (B * X ^ ѕГ) T hT (fun t ht => hBt t ht)
  have hMseg : вИА tt : вДЭ, |tt| вЙ§ T вЖТ вИА x вИИ Set.uIcc ѕГ' ѕГ,
      вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((x:вДВ) + tt * I) / DirichletCharacter.LFunction ѕЗ ((x:вДВ) + tt * I)вАЦ вЙ§ M := by
    intro tt httT x hx
    rw [Set.uIcc_of_le hѕГ'ѕГ] at hx
    exact strip_point_M_bound ѕЗ M T ѕГ' ѕГ hccM x tt hx.1 hx.2 httT
  have hconnT : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) :=
    horizontal_connector_bound ѕЗ X hX.le ѕГ' ѕГ T M hѕГ'ѕГ hT.ne' hM0
      (hMseg T (by rw [abs_of_pos hT]))
  have hconnB : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((-T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) := by
    have hb := horizontal_connector_bound ѕЗ X hX.le ѕГ' ѕГ (-T) M hѕГ'ѕГ
      (by simpa using hT.ne') hM0 (hMseg (-T) (by rw [abs_neg, abs_of_pos hT]))
    rwa [neg_sq] at hb
  have hline : вАЦвИЂ y in (-T)..T, G' ѕЗ X ((ѕГ':вДВ) + (y:вДВ) * I)вАЦ вЙ§ 6 * M * X ^ ѕГ' := by
    apply shifted_line_integral_bound _ M (X ^ ѕГ') ѕГ' T hM0 (Real.rpow_nonneg hX0.le _) hѕГ'34 hT.le
    intro t ht
    have htT : |t| вЙ§ T := by
      rw [abs_le]
      exact вЯ®ht.1.le, ht.2вЯ©
    exact integrand_pointwise_bound ѕЗ X ѕГ' t M hX0 (by linarith) hM0
      (strip_point_M_bound ѕЗ M T ѕГ' ѕГ hccM ѕГ' t le_rfl hѕГ'ѕГ htT)
  exact psi_smooth_bound_skeleton ѕЗ hѕЗ _ X hX ѕГ' ѕГ T M B hѕГ'34 hѕГ'ѕГ hT hM0
    hrep htail hconnT hconnB hline hzf



open ArithmeticFunction in
/-- **Quantitative вИТLвА≤/L on the ѕГ-line** (SW brick W2aвА≤): `вАЦвИТLвА≤/L(ѕГ+it,ѕЗ)вАЦ вЙ§ 6/(ѕГвИТ1)¬≤` for
    `1 < ѕГ вЙ§ 2` вАФ makes the tail constant `B` explicit (`ќЫ вЙ§ log`, `log n вЙ§ (2/(ѕГвИТ1))¬Јn^{(ѕГвИТ1)/2}`,
    `вИС n^{вИТ(ѕГ+1)/2} вЙ§ (ѕГ+1)/(ѕГвИТ1)`). -/
lemma neg_logDeriv_quantitative {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (ѕГ : вДЭ) (hѕГ1 : 1 < ѕГ) (hѕГ2 : ѕГ вЙ§ 2) (t : вДЭ) :
    вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I)вАЦ
      вЙ§ 6 / (ѕГ - 1) ^ 2 := by
  have hre : ((ѕГ:вДВ) + t * I).re = ѕГ := by simp
  have hs : 1 < ((ѕГ:вДВ) + t * I).re := by rw [hre]; exact hѕГ1
  rw [neg_logDeriv_LFunction_eq ѕЗ hs]
  have hsummable : Summable (fun n : вДХ =>
      вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) ((ѕГ:вДВ) + t * I) nвАЦ) :=
    summable_norm_iff.mpr (LSeriesSummable_twist_vonMangoldt ѕЗ hs)
  have hmaj : Summable (fun n : вДХ => (2 / (ѕГ - 1)) * (1 / (n : вДЭ) ^ ((ѕГ + 1) / 2))) :=
    (Real.summable_one_div_nat_rpow.mpr (by linarith)).mul_left _
  have hterm : вИА n : вДХ,
      вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) ((ѕГ:вДВ) + t * I) nвАЦ
        вЙ§ (2 / (ѕГ - 1)) * (1 / (n : вДЭ) ^ ((ѕГ + 1) / 2)) := by
    intro n
    rw [LSeries.norm_term_eq, hre]
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј rw [if_pos rfl]
      positivity
    ¬Ј have hn1 : (1:вДЭ) вЙ§ (n:вДЭ) := by exact_mod_cast hn
      have hn0 : (0:вДЭ) < (n:вДЭ) := by linarith
      rw [if_neg hn.ne']
      have h1 : вАЦѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)вАЦ вЙ§ vonMangoldt n := by
        rw [norm_mul, Complex.norm_real, Real.norm_eq_abs,
          abs_of_nonneg vonMangoldt_nonneg]
        calc вАЦѕЗ (n : ZMod N)вАЦ * vonMangoldt n вЙ§ 1 * vonMangoldt n :=
              mul_le_mul_of_nonneg_right (DirichletCharacter.norm_le_one ѕЗ _) vonMangoldt_nonneg
          _ = vonMangoldt n := one_mul _
      have h2 : vonMangoldt n вЙ§ Real.log n := vonMangoldt_le_log
      have h3 : Real.log n вЙ§ (2 / (ѕГ - 1)) * (n:вДЭ) ^ ((ѕГ - 1) / 2) := by
        have := Real.log_le_rpow_div hn0.le (by linarith : (0:вДЭ) < (ѕГ - 1) / 2)
        calc Real.log n вЙ§ (n:вДЭ) ^ ((ѕГ - 1) / 2) / ((ѕГ - 1) / 2) := this
          _ = (2 / (ѕГ - 1)) * (n:вДЭ) ^ ((ѕГ - 1) / 2) := by
              field_simp
      have h4 : (n:вДЭ) ^ ((ѕГ - 1) / 2) / (n:вДЭ) ^ ѕГ = 1 / (n:вДЭ) ^ ((ѕГ + 1) / 2) := by
        rw [вЖР Real.rpow_sub hn0, one_div, вЖР Real.rpow_neg hn0.le]
        congr 1
        ring
      calc вАЦѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)вАЦ / (n : вДЭ) ^ ѕГ
          вЙ§ Real.log n / (n : вДЭ) ^ ѕГ := by
            apply div_le_div_of_nonneg_right (le_trans h1 h2) (Real.rpow_pos_of_pos hn0 ѕГ).le
        _ вЙ§ ((2 / (ѕГ - 1)) * (n:вДЭ) ^ ((ѕГ - 1) / 2)) / (n : вДЭ) ^ ѕГ := by
            apply div_le_div_of_nonneg_right h3 (Real.rpow_pos_of_pos hn0 ѕГ).le
        _ = (2 / (ѕГ - 1)) * ((n:вДЭ) ^ ((ѕГ - 1) / 2) / (n:вДЭ) ^ ѕГ) := by ring
        _ = (2 / (ѕГ - 1)) * (1 / (n : вДЭ) ^ ((ѕГ + 1) / 2)) := by rw [h4]
  calc вАЦLSeries (fun n : вДХ => ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) ((ѕГ:вДВ) + t * I)вАЦ
      вЙ§ вИС' n : вДХ, вАЦLSeries.term (fun n : вДХ => ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ)) ((ѕГ:вДВ) + t * I) nвАЦ :=
        norm_tsum_le_tsum_norm hsummable
    _ вЙ§ вИС' n : вДХ, (2 / (ѕГ - 1)) * (1 / (n : вДЭ) ^ ((ѕГ + 1) / 2)) :=
        hsummable.tsum_le_tsum hterm hmaj
    _ = (2 / (ѕГ - 1)) * вИС' n : вДХ, 1 / (n : вДЭ) ^ ((ѕГ + 1) / 2) := tsum_mul_left
    _ вЙ§ (2 / (ѕГ - 1)) * (((ѕГ + 1) / 2) / (((ѕГ + 1) / 2) - 1)) := by
        apply mul_le_mul_of_nonneg_left (tsum_one_div_nat_rpow_le _ (by linarith)) (by positivity)
    _ вЙ§ 6 / (ѕГ - 1) ^ 2 := by
        have hѕГ1' : (0:вДЭ) < ѕГ - 1 := by linarith
        have heq : (2 / (ѕГ - 1)) * (((ѕГ + 1) / 2) / (((ѕГ + 1) / 2) - 1))
            = (2 * (ѕГ + 1)) / (ѕГ - 1) ^ 2 := by
          rw [show ((ѕГ + 1) / 2) - 1 = (ѕГ - 1) / 2 by ring]
          field_simp
        rw [heq]
        gcongr
        linarith


/-- **Quantitative ѕГ-line tail** (SW brick W2aвА≥): the smoothed integrand on `Re = ѕГ вИИ (1,2]` is
    dominated by `((6/(ѕГвИТ1)¬≤)¬ЈX^ѕГ)/t¬≤` вАФ `truncation_tail_bound`'s input with EXPLICIT constant,
    replacing the existential `B` of `sigma_line_tail_bound`. -/
lemma sigma_line_tail_quantitative {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (X ѕГ : вДЭ) (hX : 0 < X) (hѕГ1 : 1 < ѕГ) (hѕГ2 : ѕГ вЙ§ 2) :
    вИА t : вДЭ, t вЙ† 0 вЖТ
      вАЦG' ѕЗ X ((ѕГ:вДВ) + t * I)вАЦ вЙ§ ((6 / (ѕГ - 1) ^ 2) * X ^ ѕГ) / t ^ 2 := by
  intro t ht
  have him : ((ѕГ:вДВ) + t * I).im = t := by simp
  have hre : ((ѕГ:вДВ) + t * I).re = ѕГ := by simp
  have hkd := perron_kernel_decay X hX ((ѕГ:вДВ) + t * I) (by rw [him]; exact ht)
  rw [hre, him] at hkd
  have hq := neg_logDeriv_quantitative ѕЗ ѕГ hѕГ1 hѕГ2 t
  have hq0 : (0:вДЭ) вЙ§ 6 / (ѕГ - 1) ^ 2 := by positivity
  rw [G', norm_mul]
  calc вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((ѕГ:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((ѕГ:вДВ) + t * I)вАЦ
        * вАЦ(X:вДВ) ^ ((ѕГ:вДВ) + t * I) / (((ѕГ:вДВ) + t * I) * ((ѕГ:вДВ) + t * I + 1))вАЦ
      вЙ§ (6 / (ѕГ - 1) ^ 2) * (X ^ ѕГ / t ^ 2) := mul_le_mul hq hkd (norm_nonneg _) hq0
    _ = ((6 / (ѕГ - 1) ^ 2) * X ^ ѕГ) / t ^ 2 := by ring

/-- **The ѕЗвЙ†1 smoothed ѕИ bound, fully quantitative** (W1 MAINвА≤): every constant explicit вАФ
    `вАЦѕИ_smooth(X,ѕЗ)вАЦ вЙ§ (6M¬ЈX^{1вИТg/2} + 3g¬ЈM¬ЈX^{1+g}/T¬≤ + 2¬Ј(6/g¬≤)¬ЈX^{1+g}/T)/(2ѕА)`. -/
theorem psi_smooth_bound_quantitative (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c C : вДЭ, 0 < c вИІ c вЙ§ 1/2 вИІ 1 вЙ§ C вИІ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА X : вДЭ, 1 < X вЖТ вИА T : вДЭ, 0 < T вЖТ
    вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X)вАЦ
      вЙ§ (6 * (C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2)
            * X ^ (1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2)
          + 2 * (((1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20))
                - (1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2))
              * ((C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2)
                * X ^ (1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)) / T ^ 2))
          + 2 * ((6 / (c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)) ^ 2)
              * X ^ (1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20))) / T)
        / (2 * Real.pi) := by
  obtain вЯ®c, C, hc0, hc12, hC1, hccвЯ© := contour_combined ќµ hќµ0
  refine вЯ®c, C, hc0, hc12, hC1, ?_вЯ©
  intro N _ ѕЗ hѕЗ X hX T hT
  have hX0 : (0:вДЭ) < X := by linarith
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hNe0 : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hNe1 : ((N:вДЭ))^(-ќµ) вЙ§ 1 := Real.rpow_le_one_of_one_le_of_nonpos hN1r (by linarith)
  set LT := Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 with hLTdef
  have hLT20 : (20:вДЭ) вЙ§ LT := by
    rw [hLTdef]
    have : (0:вДЭ) вЙ§ Real.log ((N:вДЭ)*(4*(T+1)+7)) := Real.log_nonneg (by nlinarith)
    linarith
  obtain вЯ®hg0, hg40, hѕГ'34, hѕГ1, hѕГ'ѕГ, hѕГ2вЯ© :=
    strip_numerics c (((N:вДЭ))^(-ќµ)) LT hc0 hc12 hNe0 hNe1 hLT20
  set g := c * ((N:вДЭ))^(-ќµ) / LT with hgdef
  set ѕГ' := 1 - g / 2 with hѕГ'def
  set ѕГ := 1 + g with hѕГdef
  set M := C * ((N:вДЭ))^ќµ * LT^2 with hMdef
  have hM0 : (0:вДЭ) вЙ§ M := by rw [hMdef]; positivity
  have hccM : вИА s : вДВ, |s.im| вЙ§ T вЖТ ѕГ' вЙ§ s.re вЖТ s.re вЙ§ ѕГ вЖТ
      вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ вЙ§ M := by
    intro s him hre1 hre2
    exact ((hcc N ѕЗ hѕЗ T hT.le s him hre1).2 hre2)
  have hzf : вИА s : вДВ, |s.im| вЙ§ T вЖТ ѕГ' вЙ§ s.re вЖТ DirichletCharacter.LFunction ѕЗ s вЙ† 0 := by
    intro s him hre
    exact (hcc N ѕЗ hѕЗ T hT.le s him hre).1
  have hѕГm1 : ѕГ - 1 = g := by rw [hѕГdef]; ring
  have hrep : (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
      ѕЗ (n : ZMod N) * ((ArithmeticFunction.vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X))
      = (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I) := by
    rw [smoothed_perron_LFunction ѕЗ X hX ѕГ hѕГ1, perron_integrand_reshape]
    rfl
  have htail : вАЦ(вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I))
      - вИЂ t in (-T)..T, G' ѕЗ X ((ѕГ : вДВ) + t * I)вАЦ вЙ§ 2 * ((6 / g ^ 2) * X ^ ѕГ) / T := by
    have hq := sigma_line_tail_quantitative ѕЗ X ѕГ hX0 hѕГ1 hѕГ2
    have := truncation_tail_bound _ (integrand_integrable_on_line ѕЗ hѕЗ X hX0 ѕГ hѕГ1)
      ((6 / (ѕГ - 1) ^ 2) * X ^ ѕГ) T hT (fun t ht => hq t ht)
    rwa [hѕГm1] at this
  have hMseg : вИА tt : вДЭ, |tt| вЙ§ T вЖТ вИА x вИИ Set.uIcc ѕГ' ѕГ,
      вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((x:вДВ) + tt * I) / DirichletCharacter.LFunction ѕЗ ((x:вДВ) + tt * I)вАЦ вЙ§ M := by
    intro tt httT x hx
    rw [Set.uIcc_of_le hѕГ'ѕГ] at hx
    exact strip_point_M_bound ѕЗ M T ѕГ' ѕГ hccM x tt hx.1 hx.2 httT
  have hconnT : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) :=
    horizontal_connector_bound ѕЗ X hX.le ѕГ' ѕГ T M hѕГ'ѕГ hT.ne' hM0
      (hMseg T (by rw [abs_of_pos hT]))
  have hconnB : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((-T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2) := by
    have hb := horizontal_connector_bound ѕЗ X hX.le ѕГ' ѕГ (-T) M hѕГ'ѕГ
      (by simpa using hT.ne') hM0 (hMseg (-T) (by rw [abs_neg, abs_of_pos hT]))
    rwa [neg_sq] at hb
  have hline : вАЦвИЂ y in (-T)..T, G' ѕЗ X ((ѕГ':вДВ) + (y:вДВ) * I)вАЦ вЙ§ 6 * M * X ^ ѕГ' := by
    apply shifted_line_integral_bound _ M (X ^ ѕГ') ѕГ' T hM0 (Real.rpow_nonneg hX0.le _) hѕГ'34 hT.le
    intro t ht
    have htT : |t| вЙ§ T := by
      rw [abs_le]
      exact вЯ®ht.1.le, ht.2вЯ©
    exact integrand_pointwise_bound ѕЗ X ѕГ' t M hX0 (by linarith) hM0
      (strip_point_M_bound ѕЗ M T ѕГ' ѕГ hccM ѕГ' t le_rfl hѕГ'ѕГ htT)
  exact psi_smooth_bound_skeleton ѕЗ hѕЗ _ X hX ѕГ' ѕГ T M (6 / g ^ 2) hѕГ'34 hѕГ'ѕГ hT hM0
    hrep htail hconnT hconnB hline hzf

/-- **R1: L_T two-sided bounds at `T = exp u`** вАФ for `u вЙ• (4B+23)¬≤` and `1 вЙ§ Nr вЙ§ u^{2B}`:
    `u вЙ§ log(Nr¬Ј(4(e^u+1)+7)) + 20 вЙ§ 2u`. Upper: `log Nr вЙ§ 2B¬Јlog u вЙ§ 4B¬ЈвИЪu` (`log_le_rpow_div`),
    `4e^u+11 вЙ§ 15e^u`, `log 15 вЙ§ 3`; lower: the argument dominates `e^u`. -/
lemma LT_bounds_at_exp (B : вДЭ) (hB : 1 вЙ§ B) :
    вИА u : вДЭ, (4*B + 23)^2 вЙ§ u вЖТ вИА Nr : вДЭ, 1 вЙ§ Nr вЖТ Nr вЙ§ u ^ (2*B : вДЭ) вЖТ
    u вЙ§ Real.log (Nr * (4*(Real.exp u + 1) + 7)) + 20 вИІ
    Real.log (Nr * (4*(Real.exp u + 1) + 7)) + 20 вЙ§ 2*u := by
  intro u hu Nr hNr1 hNru
  have hB0 : (0:вДЭ) < B := by linarith
  have hu0 : (0:вДЭ) < u := lt_of_lt_of_le (by nlinarith) hu
  have hu1 : (1:вДЭ) вЙ§ u := le_trans (by nlinarith) hu
  have hexp0 : (0:вДЭ) < Real.exp u := Real.exp_pos u
  have harg0 : (0:вДЭ) < Nr * (4*(Real.exp u + 1) + 7) := by positivity
  constructor
  ¬Ј -- lower: Nr¬Ј(4(e^u+1)+7) вЙ• e^u
    have h1 : Real.exp u вЙ§ Nr * (4*(Real.exp u + 1) + 7) := by nlinarith
    have h2 := Real.log_le_log hexp0 h1
    rw [Real.log_exp] at h2
    linarith
  ¬Ј -- upper
    have hsplit : Real.log (Nr * (4*(Real.exp u + 1) + 7))
        = Real.log Nr + Real.log (4*(Real.exp u + 1) + 7) := by
      rw [Real.log_mul (by linarith) (by positivity)]
    have hlogNr : Real.log Nr вЙ§ 4 * B * u ^ ((1:вДЭ)/2) := by
      have h3 : Real.log Nr вЙ§ Real.log (u ^ (2*B : вДЭ)) := Real.log_le_log (by linarith) hNru
      rw [Real.log_rpow hu0] at h3
      have h4 : Real.log u вЙ§ u ^ ((1:вДЭ)/2) / ((1:вДЭ)/2) :=
        Real.log_le_rpow_div hu0.le (by norm_num)
      have h5 : u ^ ((1:вДЭ)/2) / ((1:вДЭ)/2) = 2 * u ^ ((1:вДЭ)/2) := by ring
      rw [h5] at h4
      have hlogu0 : (0:вДЭ) вЙ§ Real.log u := Real.log_nonneg hu1
      calc Real.log Nr вЙ§ 2*B * Real.log u := h3
        _ вЙ§ 2*B * (2 * u ^ ((1:вДЭ)/2)) := by
            apply mul_le_mul_of_nonneg_left h4 (by linarith)
        _ = 4 * B * u ^ ((1:вДЭ)/2) := by ring
    have hlogT : Real.log (4*(Real.exp u + 1) + 7) вЙ§ 3 + u := by
      have h6 : 4*(Real.exp u + 1) + 7 вЙ§ 15 * Real.exp u := by
        nlinarith [Real.one_le_exp (le_of_lt hu0)]
      have h7 := Real.log_le_log (by positivity) h6
      rw [Real.log_mul (by norm_num) hexp0.ne', Real.log_exp] at h7
      have h8 : Real.log 15 вЙ§ 3 := by
        have h9 : (15:вДЭ) вЙ§ Real.exp 3 := by
          have h10 : (2.7:вДЭ) вЙ§ Real.exp 1 := by
            have := Real.exp_one_gt_d9
            linarith
          calc (15:вДЭ) вЙ§ 2.7^3 := by norm_num
            _ вЙ§ (Real.exp 1)^3 := pow_le_pow_leftвВА (by norm_num) h10 3
            _ = Real.exp 3 := by
                rw [вЖР Real.exp_one_rpow 3]
                norm_num
        calc Real.log 15 вЙ§ Real.log (Real.exp 3) := Real.log_le_log (by norm_num) h9
          _ = 3 := Real.log_exp 3
      linarith
    have hsq : (4*B + 23) вЙ§ u ^ ((1:вДЭ)/2) := by
      have h11 : ((4*B + 23)^2) ^ ((1:вДЭ)/2) вЙ§ u ^ ((1:вДЭ)/2) :=
        Real.rpow_le_rpow (by positivity) hu (by norm_num)
      rwa [show ((4*B + 23):вДЭ)^2 = (4*B+23)*(4*B+23) by ring,
        вЖР Real.sqrt_eq_rpow, Real.sqrt_mul_self (by linarith)] at h11
    have hsqu : u ^ ((1:вДЭ)/2) * u ^ ((1:вДЭ)/2) = u := by
      rw [вЖР Real.rpow_add hu0]
      norm_num
    have hsqnn : (0:вДЭ) вЙ§ u ^ ((1:вДЭ)/2) := Real.rpow_nonneg hu0.le _
    have hsq1 : (1:вДЭ) вЙ§ u ^ ((1:вДЭ)/2) := by nlinarith
    -- 4BвИЪu + 3 + u + 20 вЙ§ 2u вЯЄ 4BвИЪu + 23 вЙ§ u = вИЪu¬ЈвИЪu
    have hmain : 4 * B * u ^ ((1:вДЭ)/2) + 23 вЙ§ u := by
      have h12 : (4*B + 23) * u ^ ((1:вДЭ)/2) вЙ§ u := by
