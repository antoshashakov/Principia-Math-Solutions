/-- Pointwise subtraction for arithmetic functions (no `sub_apply` in Mathlib). -/

theorem vinogradov_sup_tight (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hU : U вЙ§ N) (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) *
          (((2 * (N : вДЭ) / q) * (1 + Real.log U)
            + ((U / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) + U)
        + Real.log (U * V) *
          ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
            + ((U * V / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))))
        + (V : вДЭ) * Real.log V
        + ((Nat.log 2 N + 1 : вДХ) : вДЭ) *
          Real.sqrt ((N : вДЭ) * (Real.log N ^ 2
            * (((N / 2 ^ Nat.log 2 (U + 1) : вДХ) : вДЭ) + 1)
            * ((N : вДЭ) + 2 * ((((N / 2 ^ Nat.log 2 (U + 1) : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * N + 4 * q * (1 + Real.log (2 * q)))))) := by
  refine le_trans (vinogradov_sup_skeleton U V N ќ±) ?_
  have h1 := S1_bound_tight a q hq ha ќ± hќ± U N hU
  have h2 := S2_bound_tight a q hq ha ќ± hќ± U V N hUV hUV1
  have h3 := S3_bound V N ќ±
  have h4 := S4_bound a q hq ha ќ± hќ± U V N
  linarith

/-- **THE TIGHT VINOGRADOV SUP BOUND** вАФ with the large-sieve Type-II estimate
    (`S4_bound_tight`). The Type-II term is now the four-term geometric envelope
    `logN¬Ј(N/вИЪ(V+1) + N¬Јk/вИЪq + N/вИЪU + k¬ЈвИЪ(Nq))¬Јpolylog`, small on minor arcs, rather
    than the vacuous `вИЪ(N¬ЈMom) вЙ≥ N¬Јlog¬≤N` of `vinogradov_sup_tight`. -/
theorem vinogradov_sup_tight2 (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hU : U вЙ§ N) (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) *
          (((2 * (N : вДЭ) / q) * (1 + Real.log U)
            + ((U / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) + U)
        + Real.log (U * V) *
          ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
            + ((U * V / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))))
        + (V : вДЭ) * Real.log V
        + Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
            + Real.sqrt 32 * N
                * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ) / Real.sqrt q
            + 64 * N * Real.sqrt (1 + Real.log (2 * q)) / Real.sqrt U
            + 6 * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
                * Real.sqrt (N * q * (1 + Real.log (2 * q)))) := by
  have hN1 : 1 вЙ§ N := le_trans hUV1 hUV
  have hU1 : 1 вЙ§ U := Nat.one_le_iff_ne_zero.mpr (by rintro rfl; simp at hUV1)
  refine le_trans (vinogradov_sup_skeleton U V N ќ±) ?_
  have h1 := S1_bound_tight a q hq ha ќ± hќ± U N hU
  have h2 := S2_bound_tight a q hq ha ќ± hќ± U V N hUV hUV1
  have h3 := S3_bound V N ќ±
  have h4 := S4_bound_tight a q hq ha ќ± hќ± U V N hU1 hN1
  linarith

end VaughanDecomposition

