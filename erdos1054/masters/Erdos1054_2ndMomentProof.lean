  have hint : вИА m k : вДХ, IntervalIntegrable
      (fun ќ± : вДЭ => (a m * a k) * e ((((m : вД§) + k - n : вД§) : вДЭ) * ќ±))
      MeasureTheory.volume 0 1 := by
    intro m k
    apply Continuous.intervalIntegrable; unfold e; fun_prop
  have hint2 : вИА m : вДХ, IntervalIntegrable
      (fun ќ± : вДЭ => вИС k вИИ Finset.range N,
        (a m * a k) * e ((((m : вД§) + k - n : вД§) : вДЭ) * ќ±))
      MeasureTheory.volume 0 1 := by
    intro m
    apply Continuous.intervalIntegrable
    apply continuous_finsetSum
    intro k _
    unfold e; fun_prop
  have hpt : вИА ќ± вИИ Set.uIcc (0:вДЭ) 1,
      (вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2 * e (-((n : вДЭ) * ќ±))
      = вИС m вИИ Finset.range N, вИС k вИИ Finset.range N,
          (a m * a k) * e ((((m : вД§) + k - n : вД§) : вДЭ) * ќ±) := by
    intro ќ± _
    rw [sq, Finset.sum_mul_sum, Finset.sum_mul]
    apply Finset.sum_congr rfl; intro m _
    rw [Finset.sum_mul]
    apply Finset.sum_congr rfl; intro k _
    have harg : (((m : вД§) + k - n : вД§) : вДЭ) * ќ±
        = (m : вДЭ) * ќ± + ((k : вДЭ) * ќ± + (-((n : вДЭ) * ќ±))) := by
      push_cast; ring
    rw [harg, вЖР e_add, вЖР e_add]
    ring
  rw [intervalIntegral.integral_congr hpt,
    intervalIntegral.integral_finsetSum (fun m _ => hint2 m)]
  have hinner : вИА m вИИ Finset.range N,
      (вИЂ ќ± in (0:вДЭ)..1, вИС k вИИ Finset.range N,
        (a m * a k) * e ((((m : вД§) + k - n : вД§) : вДЭ) * ќ±))
      = вИС k вИИ Finset.range N, if m + k = n then a m * a k else 0 := by
    intro m _
    rw [intervalIntegral.integral_finsetSum (fun k _ => hint m k)]
    apply Finset.sum_congr rfl; intro k _
    rw [intervalIntegral.integral_const_mul, integral_e ((m : вД§) + k - n)]
    have hiff : ((m : вД§) + k - n = 0) вЖФ (m + k = n) := by omega
    by_cases h : m + k = n
    ¬Ј rw [if_pos (hiff.mpr h), if_pos h, mul_one]
    ¬Ј rw [if_neg (fun hc => h (hiff.mp hc)), if_neg h, mul_zero]
  rw [Finset.sum_congr rfl hinner, Finset.sum_filter, Finset.sum_product]

/-- Parseval, complex pairing form: `вИЂвВА¬є S¬Јconj S = вИС aвВЩ¬Јconj aвВЩ`. -/
lemma parseval_aux (a : вДХ вЖТ вДВ) (N : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1,
        (вИС m вИИ Finset.range N, a m * e (m * ќ±)) *
          (starRingEnd вДВ) (вИС n вИИ Finset.range N, a n * e (n * ќ±))
      = вИС n вИИ Finset.range N, a n * (starRingEnd вДВ) (a n) := by
  have hint : вИА m n : вДХ, IntervalIntegrable
      (fun ќ± : вДЭ => (a m * (starRingEnd вДВ) (a n)) * e (((m : вДЭ) - n) * ќ±))
      MeasureTheory.volume 0 1 := by
    intro m n
    apply Continuous.intervalIntegrable; unfold e; fun_prop
  have hint2 : вИА m : вДХ, IntervalIntegrable
      (fun ќ± : вДЭ => вИС n вИИ Finset.range N,
        (a m * (starRingEnd вДВ) (a n)) * e (((m : вДЭ) - n) * ќ±))
      MeasureTheory.volume 0 1 := by
    intro m
    apply Continuous.intervalIntegrable
    apply continuous_finsetSum
    intro n _
    unfold e; fun_prop
  have hpt : вИА ќ± вИИ Set.uIcc (0:вДЭ) 1,
      (вИС m вИИ Finset.range N, a m * e (m * ќ±)) *
        (starRingEnd вДВ) (вИС n вИИ Finset.range N, a n * e (n * ќ±))
      = вИС m вИИ Finset.range N, вИС n вИИ Finset.range N,
          (a m * (starRingEnd вДВ) (a n)) * e (((m : вДЭ) - n) * ќ±) := by
    intro ќ± _
    rw [map_sum, Finset.sum_mul_sum]
    apply Finset.sum_congr rfl; intro m _
    apply Finset.sum_congr rfl; intro n _
    rw [map_mul, e_conj]
    have h1 : e ((m : вДЭ) * ќ±) * e (-((n : вДЭ) * ќ±)) = e (((m : вДЭ) - n) * ќ±) := by
      rw [e_add]; congr 1; ring
    calc a m * e ((m : вДЭ) * ќ±) * ((starRingEnd вДВ) (a n) * e (-((n : вДЭ) * ќ±)))
        = a m * (starRingEnd вДВ) (a n) * (e ((m : вДЭ) * ќ±) * e (-((n : вДЭ) * ќ±))) := by ring
      _ = a m * (starRingEnd вДВ) (a n) * e (((m : вДЭ) - n) * ќ±) := by rw [h1]
  rw [intervalIntegral.integral_congr hpt]
  rw [intervalIntegral.integral_finsetSum (fun m _ => hint2 m)]
  have hinner : вИА m вИИ Finset.range N,
      (вИЂ ќ± in (0:вДЭ)..1, вИС n вИИ Finset.range N,
        (a m * (starRingEnd вДВ) (a n)) * e (((m : вДЭ) - n) * ќ±))
      = a m * (starRingEnd вДВ) (a m) := by
    intro m hm
    rw [intervalIntegral.integral_finsetSum (fun n _ => hint m n)]
    have hterm : вИА n вИИ Finset.range N,
        (вИЂ ќ± in (0:вДЭ)..1, (a m * (starRingEnd вДВ) (a n)) * e (((m : вДЭ) - n) * ќ±))
        = (a m * (starRingEnd вДВ) (a n)) * (if m = n then 1 else 0) := by
      intro n _
      rw [intervalIntegral.integral_const_mul, integral_e_nat]
    rw [Finset.sum_congr rfl hterm]
    rw [Finset.sum_eq_single m
      (fun n _ hne => by rw [if_neg (fun h => hne h.symm), mul_zero])
      (fun hm' => absurd hm hm')]
    rw [if_pos rfl, mul_one]
  exact Finset.sum_congr rfl hinner

/-- **Parseval / the L¬≤ mean value of an exponential sum**:
    `вИЂвВА¬є вАЦвИС_{n<N} aвВЩ e(nќ±)вАЦ¬≤ dќ± = вИС_{n<N} вАЦaвВЩвАЦ¬≤`. The engine of the circle-method
    variance computation and the base case of the large sieve. -/
lemma parseval (a : вДХ вЖТ вДВ) (N : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range N, a n * e (n * ќ±)вАЦ ^ 2
      = вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2 := by
  have key := parseval_aux a N
  have hpt : вИА z : вДВ, z * (starRingEnd вДВ) z = ((вАЦzвАЦ ^ 2 : вДЭ) : вДВ) := by
    intro z
    rw [Complex.mul_conj, Complex.normSq_eq_norm_sq]
  have hL : (вИЂ ќ± in (0:вДЭ)..1,
      (вИС m вИИ Finset.range N, a m * e (m * ќ±)) *
        (starRingEnd вДВ) (вИС n вИИ Finset.range N, a n * e (n * ќ±)))
      = ((вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range N, a n * e (n * ќ±)вАЦ ^ 2 : вДЭ) : вДВ) := by
    rw [вЖР intervalIntegral.integral_ofReal]
    apply intervalIntegral.integral_congr
    intro ќ± _
    exact hpt _
  have hR : (вИС n вИИ Finset.range N, a n * (starRingEnd вДВ) (a n))
      = ((вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2 : вДЭ) : вДВ) := by
    rw [Complex.ofReal_sum]
    exact Finset.sum_congr rfl (fun n _ => hpt (a n))
  rw [hL, hR] at key
  exact_mod_cast key







/-- `S(ќ±)¬≤` is itself a trig polynomial, with coefficients the representation sums
    `R(n) = вИС_{m+k=n} aвВШaвВЦ`. -/
lemma sq_expsum_eq (a : вДХ вЖТ вДВ) (N : вДХ) (ќ± : вДЭ) :
    (вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2
      = вИС n вИИ Finset.range (2 * N),
          (вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) * e ((n : вДЭ) * ќ±) := by
  rw [sq, Finset.sum_mul_sum, вЖР Finset.sum_product']
  rw [вЖР Finset.sum_fiberwise_of_maps_to (g := fun p : вДХ √Ч вДХ => p.1 + p.2)
      (t := Finset.range (2 * N))
      (fun p hp => by
        rw [Finset.mem_product, Finset.mem_range, Finset.mem_range] at hp
        rw [Finset.mem_range]
        omega)]
  apply Finset.sum_congr rfl
  intro n _
  rw [Finset.sum_mul]
  apply Finset.sum_congr rfl
  intro p hp
  rw [Finset.mem_filter] at hp
  have harg : (p.1 : вДЭ) * ќ± + (p.2 : вДЭ) * ќ± = (n : вДЭ) * ќ± := by
    rw [вЖР hp.2]; push_cast; ring
  calc a p.1 * e ((p.1 : вДЭ) * ќ±) * (a p.2 * e ((p.2 : вДЭ) * ќ±))
      = a p.1 * a p.2 * (e ((p.1 : вДЭ) * ќ±) * e ((p.2 : вДЭ) * ќ±)) := by ring
    _ = a p.1 * a p.2 * e ((n : вДЭ) * ќ±) := by rw [e_add, harg]

/-- **The variance identity**: `вИС_{n<2N} вАЦR(n)вАЦ¬≤ = вИЂвВА¬є вАЦS(ќ±)вАЦвБі dќ±` вАФ Parseval applied to
    the trig polynomial `S¬≤`. The bridge between the minor-arc LвБі bound and the
    sum-over-n variance that `almost_all_goldbach_of_variance` consumes. -/
lemma sum_repCoeff_sq_eq_L4 (a : вДХ вЖТ вДВ) (N : вДХ) :
    вИС n вИИ Finset.range (2 * N),
        вАЦвИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
          a p.1 * a p.2вАЦ ^ 2
      = вИЂ ќ± in (0:вДЭ)..1, вАЦвИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)вАЦ ^ 4 := by
  calc вИС n вИИ Finset.range (2 * N),
        вАЦвИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
          a p.1 * a p.2вАЦ ^ 2
      = вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range (2 * N),
          (вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) * e ((n : вДЭ) * ќ±)вАЦ ^ 2 :=
        (parseval (fun n => вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter
          (fun p => p.1 + p.2 = n), a p.1 * a p.2) (2 * N)).symm
    _ = вИЂ ќ± in (0:вДЭ)..1, вАЦ(вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2вАЦ ^ 2 := by
        apply intervalIntegral.integral_congr
        intro ќ± _
        dsimp only
        rw [sq_expsum_eq]
    _ = вИЂ ќ± in (0:вДЭ)..1, вАЦвИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)вАЦ ^ 4 := by
        apply intervalIntegral.integral_congr
        intro ќ± _
        dsimp only
        rw [norm_pow, вЖР pow_mul]

/-- **Variance = L¬≤ error**: for ANY candidate main term `c(n)`, the variance
    `вИС_{n<2N} вАЦR(n) вИТ c(n)вАЦ¬≤` equals `вИЂвВА¬є вАЦS(ќ±)¬≤ вИТ C(ќ±)вАЦ¬≤ dќ±` where `C` is the trig
    polynomial with coefficients `c`. Reduces the Goldbach variance hypothesis to an
    L¬≤ bound on the circle, which the arc dichotomy then splits. -/
lemma variance_eq_L2_error (a c : вДХ вЖТ вДВ) (N : вДХ) :
    вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c nвАЦ ^ 2
      = вИЂ ќ± in (0:вДЭ)..1,
          вАЦ(вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2
            - вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2 := by
  calc вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c nвАЦ ^ 2
      = вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range (2 * N),
          ((вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c n) * e ((n : вДЭ) * ќ±)вАЦ ^ 2 :=
        (parseval (fun n => (вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter
          (fun p => p.1 + p.2 = n), a p.1 * a p.2) - c n) (2 * N)).symm
    _ = вИЂ ќ± in (0:вДЭ)..1,
          вАЦ(вИС m вИИ Finset.range N, a m * e ((m : вДЭ) * ќ±)) ^ 2
            - вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2 := by
        apply intervalIntegral.integral_congr
        intro ќ± _
        dsimp only
        rw [sq_expsum_eq]
        simp only [sub_mul, Finset.sum_sub_distrib]

open MeasureTheory in
/-- **Circle split**: the L¬≤ integral over `(0,1]` splits exactly into the minor-arc set
    and its complement (the major arcs). -/
lemma L2_circle_split (f : вДЭ вЖТ вДВ) (hf : Continuous f) (m : Set вДЭ)
    (hm : MeasurableSet m) (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) :
    вИЂ ќ± in (0:вДЭ)..1, вАЦf ќ±вАЦ ^ 2
      = (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) + вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, вАЦf ќ±вАЦ ^ 2 := by
  have hi : IntegrableOn (fun ќ± => вАЦf ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1) volume :=
    (hf.norm.pow 2).integrableOn_Ioc
  rw [intervalIntegral.integral_of_le zero_le_one,
    вЖР setIntegral_union Set.disjoint_sdiff_right (measurableSet_Ioc.diff hm)
      (hi.mono_set hsub) (hi.mono_set Set.diff_subset),
    Set.union_diff_cancel hsub]

open MeasureTheory in
/-- **Elementary L¬≤ triangle bound on a set**: `вИЂ_m вАЦfвИТgвАЦ¬≤ вЙ§ 2вИЂ_mвАЦfвАЦ¬≤ + 2вИЂ_mвАЦgвАЦ¬≤`. -/
lemma L2_diff_le (f g : вДЭ вЖТ вДВ) (hf : Continuous f) (hg : Continuous g) (m : Set вДЭ)
    (hm : MeasurableSet m) (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) :
    вИЂ ќ± in m, вАЦf ќ± - g ќ±вАЦ ^ 2
      вЙ§ 2 * (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) + 2 * вИЂ ќ± in m, вАЦg ќ±вАЦ ^ 2 := by
  have hif : IntegrableOn (fun ќ± => вАЦf ќ±вАЦ ^ 2) m volume :=
    ((hf.norm.pow 2).integrableOn_Ioc).mono_set hsub
  have hig : IntegrableOn (fun ќ± => вАЦg ќ±вАЦ ^ 2) m volume :=
    ((hg.norm.pow 2).integrableOn_Ioc).mono_set hsub
  have hifg : IntegrableOn (fun ќ± => вАЦf ќ± - g ќ±вАЦ ^ 2) m volume :=
    (((hf.sub hg).norm.pow 2).integrableOn_Ioc).mono_set hsub
  have hpt : вИА ќ± вИИ m, вАЦf ќ± - g ќ±вАЦ ^ 2 вЙ§ 2 * вАЦf ќ±вАЦ ^ 2 + 2 * вАЦg ќ±вАЦ ^ 2 := by
    intro ќ± _
    have h1 : вАЦf ќ± - g ќ±вАЦ вЙ§ вАЦf ќ±вАЦ + вАЦg ќ±вАЦ := norm_sub_le _ _
    have h2 : вАЦf ќ± - g ќ±вАЦ ^ 2 вЙ§ (вАЦf ќ±вАЦ + вАЦg ќ±вАЦ) ^ 2 :=
      pow_le_pow_leftвВА (norm_nonneg _) h1 2
    nlinarith [sq_nonneg (вАЦf ќ±вАЦ - вАЦg ќ±вАЦ)]
  have hsum : IntegrableOn (fun ќ± => 2 * вАЦf ќ±вАЦ ^ 2 + 2 * вАЦg ќ±вАЦ ^ 2) m volume := by
    exact (hif.const_mul 2).add (hig.const_mul 2)
  calc вИЂ ќ± in m, вАЦf ќ± - g ќ±вАЦ ^ 2
      вЙ§ вИЂ ќ± in m, (2 * вАЦf ќ±вАЦ ^ 2 + 2 * вАЦg ќ±вАЦ ^ 2) :=
        setIntegral_mono_on hifg hsum hm hpt
    _ = 2 * (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) + 2 * вИЂ ќ± in m, вАЦg ќ±вАЦ ^ 2 := by
        rw [integral_add (hif.const_mul 2) (hig.const_mul 2),
          integral_const_mul, integral_const_mul]

open MeasureTheory in
/-- L¬≤ mass on any sub-arc set is at most the full-circle L¬≤ mass. -/
lemma setL2_le_circle (f : вДЭ вЖТ вДВ) (hf : Continuous f) (m : Set вДЭ)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) :
    вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2 вЙ§ вИЂ ќ± in (0:вДЭ)..1, вАЦf ќ±вАЦ ^ 2 := by
  rw [intervalIntegral.integral_of_le zero_le_one]
  apply setIntegral_mono_set ((hf.norm.pow 2).integrableOn_Ioc)
  ¬Ј filter_upwards with ќ± using by positivity
  ¬Ј exact HasSubset.Subset.eventuallyLE hsub

lemma expsum_continuous (a : вДХ вЖТ вДВ) (N : вДХ) :
    Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±)) := by
  apply continuous_finsetSum
  intro n _
  unfold e
  fun_prop

open MeasureTheory in
/-- General LвБі-on-a-set bound: sup on one factor, Parseval on the other. -/
lemma L4_set_bound (a : вДХ вЖТ вДВ) (N : вДХ) (m : Set вДЭ) (hm : MeasurableSet m)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (Csup : вДЭ)
    (hsup : вИА ќ± вИИ m, вАЦвИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±)вАЦ вЙ§ Csup) :
    вИЂ ќ± in m, вАЦ(вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2
      вЙ§ Csup ^ 2 * вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2 := by
  set S := fun ќ± : вДЭ => вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±) with hS
  have hcont : Continuous S := expsum_continuous a N
  rcases Set.eq_empty_or_nonempty m with hempty | вЯ®ќ±вВА, hќ±вВАвЯ©
  ¬Ј rw [hempty]
    simp only [Measure.restrict_empty, integral_zero_measure]
    exact mul_nonneg (sq_nonneg Csup) (Finset.sum_nonneg fun n _ => sq_nonneg _)
  have hCnn : 0 вЙ§ Csup := le_trans (norm_nonneg _) (hsup ќ±вВА hќ±вВА)
  have hint2 : IntegrableOn (fun ќ± => вАЦS ќ±вАЦ ^ 2) m volume :=
    ((hcont.norm.pow 2).integrableOn_Ioc).mono_set hsub
  have hint4 : IntegrableOn (fun ќ± => вАЦS ќ± ^ 2вАЦ ^ 2) m volume := by
    exact (((hcont.pow 2).norm.pow 2).integrableOn_Ioc).mono_set hsub
  calc вИЂ ќ± in m, вАЦS ќ± ^ 2вАЦ ^ 2
      вЙ§ вИЂ ќ± in m, Csup ^ 2 * вАЦS ќ±вАЦ ^ 2 := by
        apply setIntegral_mono_on hint4 (hint2.const_mul _) hm
        intro ќ± hќ±
        rw [norm_pow]
        have hsq : вАЦS ќ±вАЦ ^ 2 вЙ§ Csup ^ 2 := pow_le_pow_leftвВА (norm_nonneg _) (hsup ќ± hќ±) 2
        calc (вАЦS ќ±вАЦ ^ 2) ^ 2 = вАЦS ќ±вАЦ ^ 2 * вАЦS ќ±вАЦ ^ 2 := by ring
          _ вЙ§ Csup ^ 2 * вАЦS ќ±вАЦ ^ 2 := mul_le_mul_of_nonneg_right hsq (by positivity)
    _ = Csup ^ 2 * вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 2 := by rw [integral_const_mul]
    _ вЙ§ Csup ^ 2 * вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2 := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        calc вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 2 вЙ§ вИЂ ќ± in (0:вДЭ)..1, вАЦS ќ±вАЦ ^ 2 :=
              setL2_le_circle S hcont m hsub
          _ = вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2 := parseval a N

open MeasureTheory in
/-- **THE VARIANCE ASSEMBLY**: for any coefficients `a`, main term `c`, and minor set `m`
    with sup bound `Csup`, the full variance is at most the (finished) minor contribution
    plus the major-arc L¬≤ integral вАФ the SINGLE remaining analytic input. -/
theorem variance_le_of_arcs (a c : вДХ вЖТ вДВ) (N : вДХ) (m : Set вДЭ) (hm : MeasurableSet m)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (Csup : вДЭ)
    (hsup : вИА ќ± вИИ m, вАЦвИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±)вАЦ вЙ§ Csup) :
    вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c nвАЦ ^ 2
      вЙ§ 2 * (Csup ^ 2 * вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2)
        + 2 * вИС n вИИ Finset.range (2 * N), вАЦc nвАЦ ^ 2
        + вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m,
            вАЦ(вИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±)) ^ 2
              - вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2 := by
  have hScont : Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ±)) :=
    expsum_continuous a N
  have hCcont : Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)) :=
    expsum_continuous c (2 * N)
  have hEcont : Continuous (fun ќ± : вДЭ =>
      (вИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±)) ^ 2
        - вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)) :=
    (hScont.pow 2).sub hCcont
  rw [variance_eq_L2_error a c N, L2_circle_split _ hEcont m hm hsub]
  have hminor : (вИЂ ќ± in m,
      вАЦ(вИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±)) ^ 2
        - вИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2)
      вЙ§ 2 * (Csup ^ 2 * вИС n вИИ Finset.range N, вАЦa nвАЦ ^ 2)
        + 2 * вИС n вИИ Finset.range (2 * N), вАЦc nвАЦ ^ 2 := by
    have h1 := L2_diff_le _ _ (hScont.pow 2) hCcont m hm hsub
    have h2 := L4_set_bound a N m hm hsub Csup hsup
    have h3 : (вИЂ ќ± in m, вАЦвИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2)
        вЙ§ вИС n вИИ Finset.range (2 * N), вАЦc nвАЦ ^ 2 := by
      calc (вИЂ ќ± in m, вАЦвИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2)
          вЙ§ вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range (2 * N), c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2 :=
            setL2_le_circle _ hCcont m hsub
        _ = вИС n вИИ Finset.range (2 * N), вАЦc nвАЦ ^ 2 := parseval c (2 * N)
    linarith
  linarith

open MeasureTheory in
/-- **Bessel's inequality on a sub-arc set**: the Fourier coefficients of `f` restricted
    to any measurable `m вКЖ (0,1]` satisfy `вИС_{n<M} вАЦвИЂ_m f¬Јe(вИТnќ±)вАЦ¬≤ вЙ§ вИЂ_m вАЦfвАЦ¬≤`.
    This is the lossless replacement for the crude main-term bound on minor arcs. -/
lemma bessel_minor (f : вДЭ вЖТ вДВ) (hf : Continuous f) (m : Set вДЭ)
    (hm : MeasurableSet m) (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (M : вДХ) :
    вИС n вИИ Finset.range M, вАЦвИЂ ќ± in m, f ќ± * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
      вЙ§ вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2 := by
  set c : вДХ вЖТ вДВ := fun n => вИЂ ќ± in m, f ќ± * e (-((n : вДЭ) * ќ±)) with hc
  set T : вДЭ вЖТ вДВ := fun ќ± => вИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±) with hT
  have hTcont : Continuous T := expsum_continuous c M
  have hecont : вИА n : вДХ, Continuous fun ќ± : вДЭ => e (-((n : вДЭ) * ќ±)) := by
    intro n
    unfold e
    fun_prop
  -- integrability workhorses on m
  have hInt : вИА g : вДЭ вЖТ вДВ, Continuous g вЖТ IntegrableOn g m volume := fun g hg =>
    (hg.integrableOn_Ioc).mono_set hsub
  have hIntR : вИА g : вДЭ вЖТ вДЭ, Continuous g вЖТ IntegrableOn g m volume := fun g hg =>
    (hg.integrableOn_Ioc).mono_set hsub
  -- Key 1: вИЂ_m f¬Јconj T = вИС c n ¬Ј conj (c n)
  have hkey1 : (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±))
      = вИС n вИИ Finset.range M, c n * (starRingEnd вДВ) (c n) := by
    have hexp : вИА ќ± : вДЭ, f ќ± * (starRingEnd вДВ) (T ќ±)
        = вИС n вИИ Finset.range M, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
      intro ќ±
      rw [hT]
      dsimp only
      rw [map_sum, Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro n _
      rw [map_mul, e_conj]
      ring
    calc (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±))
        = вИЂ ќ± in m, вИС n вИИ Finset.range M, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
          apply setIntegral_congr_fun hm
          intro ќ± _
          exact hexp ќ±
      _ = вИС n вИИ Finset.range M, вИЂ ќ± in m, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
          apply integral_finset_sum
          intro n _
          exact (hInt _ ((hf.mul (hecont n)).const_mul _))
      _ = вИС n вИИ Finset.range M, (starRingEnd вДВ) (c n) * вИЂ ќ± in m, f ќ± * e (-((n : вДЭ) * ќ±)) := by
          apply Finset.sum_congr rfl
          intro n _
          exact integral_const_mul _ _
      _ = вИС n вИИ Finset.range M, c n * (starRingEnd вДВ) (c n) := by
          apply Finset.sum_congr rfl
          intro n _
          have hfold : (вИЂ ќ± in m, f ќ± * e (-((n : вДЭ) * ќ±))) = c n := rfl
          rw [hfold]
          ring
  -- Key 2: the expansion of вИЂ_m вАЦf вИТ TвАЦ¬≤
  have hptwise : вИА ќ± : вДЭ, вАЦf ќ± - T ќ±вАЦ ^ 2
      = вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re + вАЦT ќ±вАЦ ^ 2 := by
    intro ќ±
    have h1 : (вАЦf ќ± - T ќ±вАЦ : вДЭ) ^ 2 = ((f ќ± - T ќ±) * (starRingEnd вДВ) (f ќ± - T ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have h2 : (вАЦf ќ±вАЦ : вДЭ) ^ 2 = (f ќ± * (starRingEnd вДВ) (f ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have h3 : (вАЦT ќ±вАЦ : вДЭ) ^ 2 = (T ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have hconjswap : (T ќ± * (starRingEnd вДВ) (f ќ±)).re = (f ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      have : T ќ± * (starRingEnd вДВ) (f ќ±) = (starRingEnd вДВ) (f ќ± * (starRingEnd вДВ) (T ќ±)) := by
        rw [map_mul, Complex.conj_conj]
        ring
      rw [this, Complex.conj_re]
    rw [h1, h2, h3]
    have hexpand : (f ќ± - T ќ±) * (starRingEnd вДВ) (f ќ± - T ќ±)
        = f ќ± * (starRingEnd вДВ) (f ќ±) - f ќ± * (starRingEnd вДВ) (T ќ±)
          - T ќ± * (starRingEnd вДВ) (f ќ±) + T ќ± * (starRingEnd вДВ) (T ќ±) := by
      rw [map_sub]
      ring
    rw [hexpand]
    simp only [Complex.add_re, Complex.sub_re]
    rw [hconjswap]
    ring
  have hIfT : IntegrableOn (fun ќ± => (f ќ± * (starRingEnd вДВ) (T ќ±)).re) m volume := by
    apply hIntR
    exact (Complex.continuous_re.comp (hf.mul (Complex.continuous_conj.comp hTcont)))
  have hIf2 : IntegrableOn (fun ќ± => вАЦf ќ±вАЦ ^ 2) m volume := hIntR _ (hf.norm.pow 2)
  have hIT2 : IntegrableOn (fun ќ± => вАЦT ќ±вАЦ ^ 2) m volume := hIntR _ (hTcont.norm.pow 2)
  have hkey2 : (вИЂ ќ± in m, вАЦf ќ± - T ќ±вАЦ ^ 2)
      = (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) - 2 * (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±)).re
        + вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2 := by
    have hre : (вИЂ ќ± in m, (f ќ± * (starRingEnd вДВ) (T ќ±)).re)
        = (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      have h := integral_re (hInt (fun ќ± => f ќ± * (starRingEnd вДВ) (T ќ±))
        (hf.mul (Complex.continuous_conj.comp hTcont)))
      simpa [RCLike.re_to_complex] using h
    calc (вИЂ ќ± in m, вАЦf ќ± - T ќ±вАЦ ^ 2)
        = вИЂ ќ± in m, (вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re + вАЦT ќ±вАЦ ^ 2) := by
          apply setIntegral_congr_fun hm
          intro ќ± _
          exact hptwise ќ±
      _ = (вИЂ ќ± in m, (вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re))
          + вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2 := by
          apply integral_add _ hIT2
          exact hIf2.sub (hIfT.const_mul 2)
      _ = (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) - (вИЂ ќ± in m, 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re)
          + вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2 := by
          rw [integral_sub hIf2 (hIfT.const_mul 2)]
      _ = (вИЂ ќ± in m, вАЦf ќ±вАЦ ^ 2) - 2 * (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±)).re
          + вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2 := by
          rw [integral_const_mul, hre]
  -- Key 3: вИЂ_m вАЦTвАЦ¬≤ вЙ§ вИС вАЦc nвАЦ¬≤
  have hkey3 : (вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2) вЙ§ вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
    calc (вИЂ ќ± in m, вАЦT ќ±вАЦ ^ 2) вЙ§ вИЂ ќ± in (0:вДЭ)..1, вАЦT ќ±вАЦ ^ 2 :=
          setL2_le_circle T hTcont m hsub
      _ = вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := parseval c M
  -- the cross term is the coefficient mass
  have hcross : (вИЂ ќ± in m, f ќ± * (starRingEnd вДВ) (T ќ±)).re
      = вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
    rw [hkey1]
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro n _
    rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
  -- combine: 0 вЙ§ вИЂвАЦfвИТTвАЦ¬≤ = вИЂвАЦfвАЦ¬≤ вИТ 2вИСвАЦcвАЦ¬≤ + вИЂ_mвАЦTвАЦ¬≤ вЙ§ вИЂвАЦfвАЦ¬≤ вИТ вИСвАЦcвАЦ¬≤
  have hnonneg : (0:вДЭ) вЙ§ вИЂ ќ± in m, вАЦf ќ± - T ќ±вАЦ ^ 2 := by
    apply integral_nonneg
    intro ќ±
    positivity
  rw [hkey2, hcross] at hnonneg
  linarith [hkey3]

open MeasureTheory in
/-- Splitting a continuous complex integrand over the circle into a sub-arc set and its
    complement. -/
lemma integral_circle_split (g : вДЭ вЖТ вДВ) (hg : Continuous g) (m : Set вДЭ)
    (hm : MeasurableSet m) (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) :
    вИЂ ќ± in (0:вДЭ)..1, g ќ±
      = (вИЂ ќ± in m, g ќ±) + вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, g ќ± := by
  have hi : IntegrableOn g (Set.Ioc (0:вДЭ) 1) volume := hg.integrableOn_Ioc
  rw [intervalIntegral.integral_of_le zero_le_one,
    вЖР setIntegral_union Set.disjoint_sdiff_right (measurableSet_Ioc.diff hm)
      (hi.mono_set hsub) (hi.mono_set Set.diff_subset),
    Set.union_diff_cancel hsub]

open MeasureTheory in
/-- **The lossless variance assembly**: the variance against ANY main term `c` is at most
    twice the minor-arc LвБі integral plus twice the major-arc coefficient error вАФ with NO
    loss on the main term (Bessel replaces the crude full-circle Parseval bound). The
    second sum is exactly the SiegelвАУWalfisz-grade object. -/
theorem variance_le_bessel (a : вДХ вЖТ вДВ) (N : вДХ) (m : Set вДЭ) (hm : MeasurableSet m)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (c : вДХ вЖТ вДВ) :
    вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c nвАЦ ^ 2
      вЙ§ 2 * (вИЂ ќ± in m, вАЦвИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±)вАЦ ^ 4)
        + 2 * вИС n вИИ Finset.range (2 * N),
            вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m,
                (вИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±)) ^ 2 * e (-((n : вДЭ) * ќ±)))
              - c nвАЦ ^ 2 := by
  set S : вДЭ вЖТ вДВ := fun ќ± => вИС k вИИ Finset.range N, a k * e ((k : вДЭ) * ќ±) with hS
  have hScont : Continuous S := expsum_continuous a N
  have hS2cont : Continuous (fun ќ± => S ќ± ^ 2) := hScont.pow 2
  have hgcont : вИА n : вДХ, Continuous (fun ќ± => S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) := by
    intro n
    apply hS2cont.mul
    unfold e
    fun_prop
  -- coefficient split: R(n) = minor coefficient + major coefficient
  have hsplitn : вИА n : вДХ,
      (вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
        a p.1 * a p.2)
      = (вИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±)))
        + вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±)) := by
    intro n
    rw [вЖР fourier_coeff_sq a N n]
    exact integral_circle_split _ (hgcont n) m hm hsub
  -- pointwise: вАЦx + y вИТ cвАЦ¬≤ вЙ§ 2вАЦxвАЦ¬≤ + 2вАЦy вИТ cвАЦ¬≤
  have hpt : вИА n вИИ Finset.range (2 * N),
      вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
          a p.1 * a p.2) - c nвАЦ ^ 2
      вЙ§ 2 * вАЦвИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
        + 2 * вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c nвАЦ ^ 2 := by
    intro n _
    rw [hsplitn n]
    set x := вИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))
    set y := (вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c n
    have hxy : x + (вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c n
        = x + y := by ring
    rw [hxy]
    have htri : вАЦx + yвАЦ вЙ§ вАЦxвАЦ + вАЦyвАЦ := norm_add_le x y
    have hsq : вАЦx + yвАЦ ^ 2 вЙ§ (вАЦxвАЦ + вАЦyвАЦ) ^ 2 :=
      pow_le_pow_leftвВА (norm_nonneg _) htri 2
    nlinarith [sq_nonneg (вАЦxвАЦ - вАЦyвАЦ), norm_nonneg x, norm_nonneg y]
  -- sum up and apply Bessel to the minor coefficients
  have hbessel : вИС n вИИ Finset.range (2 * N),
      вАЦвИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
      вЙ§ вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 4 := by
    have hb := bessel_minor (fun ќ± => S ќ± ^ 2) hS2cont m hm hsub (2 * N)
    calc вИС n вИИ Finset.range (2 * N), вАЦвИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
        вЙ§ вИЂ ќ± in m, вАЦS ќ± ^ 2вАЦ ^ 2 := hb
      _ = вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 4 := by
          apply setIntegral_congr_fun hm
          intro ќ± _
          dsimp only
          rw [norm_pow, вЖР pow_mul]
  calc вИС n вИИ Finset.range (2 * N),
        вАЦ(вИС p вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n),
            a p.1 * a p.2) - c nвАЦ ^ 2
      вЙ§ вИС n вИИ Finset.range (2 * N),
          (2 * вАЦвИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
            + 2 * вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c nвАЦ ^ 2) :=
        Finset.sum_le_sum hpt
    _ = 2 * (вИС n вИИ Finset.range (2 * N),
            вАЦвИЂ ќ± in m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2)
        + 2 * вИС n вИИ Finset.range (2 * N),
            вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c nвАЦ ^ 2 := by
        rw [Finset.sum_add_distrib, вЖР Finset.mul_sum, вЖР Finset.mul_sum]
    _ вЙ§ 2 * (вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 4)
        + 2 * вИС n вИИ Finset.range (2 * N),
            вАЦ(вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ m, S ќ± ^ 2 * e (-((n : вДЭ) * ќ±))) - c nвАЦ ^ 2 := by
        have h2 : (0:вДЭ) вЙ§ 2 := by norm_num
        linarith [mul_le_mul_of_nonneg_left hbessel h2]

/-- **Major-arc residue decomposition** вАФ the entry point of the major-arc evaluation:
    at `ќ± = a/q + ќ≤`, any weighted exponential sum regroups into the `q` residue classes,
    `вИС g(n)e(nќ±) = вИС_{r<q} e(ra/q)¬ЈвИС_{nвЙ°r(q)} g(n)e(nќ≤)` вАФ reducing the window evaluation
    to AP-restricted sums (the `WeakPNT_AP` shape) twisted by the smooth `e(nќ≤)`. -/
lemma major_arc_residue_decomp (g : вДХ вЖТ вДВ) (N : вДХ) (a : вД§) (q : вДХ) (hq : 0 < q) (ќ≤ : вДЭ) :
    вИС n вИИ Finset.range N, g n * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))
      = вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
          * вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤) := by
  rw [вЖР Finset.sum_fiberwise_of_maps_to (g := fun n => n % q) (t := Finset.range q)
      (fun n _ => Finset.mem_range.mpr (Nat.mod_lt n hq))]
  apply Finset.sum_congr rfl
  intro r _
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro n hn
  rw [Finset.mem_filter] at hn
  obtain вЯ®-, hrвЯ© := hn
  have hq' : (q : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hq.ne'
  have hn_nat : q * (n / q) + r = n := by
    rw [вЖР hr]
    exact Nat.div_add_mod n q
  have hn_eq : (n : вДЭ) = (q : вДЭ) * ((n / q : вДХ) : вДЭ) + (r : вДЭ) := by
    exact_mod_cast hn_nat.symm
  have key : (n : вДЭ) * ((a : вДЭ) / (q : вДЭ))
      = ((a * (n / q : вДХ) : вД§) : вДЭ) + (r : вДЭ) * (a : вДЭ) / (q : вДЭ) := by
    rw [hn_eq, Int.cast_mul, Int.cast_natCast]
    field_simp
  have hdecomp : (n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)
      = ((a * (n / q : вДХ) : вД§) : вДЭ) + ((r : вДЭ) * (a : вДЭ) / (q : вДЭ) + (n : вДЭ) * ќ≤) := by
    calc (n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)
        = (n : вДЭ) * ((a : вДЭ) / (q : вДЭ)) + (n : вДЭ) * ќ≤ := by ring
      _ = (((a * (n / q : вДХ) : вД§) : вДЭ) + (r : вДЭ) * (a : вДЭ) / (q : вДЭ)) + (n : вДЭ) * ќ≤ := by
          rw [key]
      _ = ((a * (n / q : вДХ) : вД§) : вДЭ) + ((r : вДЭ) * (a : вДЭ) / (q : вДЭ) + (n : вДЭ) * ќ≤) := by
          ring
  calc g n * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤))
      = g n * e (((a * (n / q : вДХ) : вД§) : вДЭ)
          + ((r : вДЭ) * (a : вДЭ) / (q : вДЭ) + (n : вДЭ) * ќ≤)) := by rw [hdecomp]
    _ = g n * (e (((a * (n / q : вДХ) : вД§) : вДЭ))
          * e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ) + (n : вДЭ) * ќ≤)) := by rw [e_add]
    _ = g n * e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ) + (n : вДЭ) * ќ≤) := by
        rw [e_int]
        ring
    _ = g n * (e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * e ((n : вДЭ) * ќ≤)) := by rw [e_add]
    _ = e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * (g n * e ((n : вДЭ) * ќ≤)) := by ring

/-- **Abel bound for a twisted sum**: if all partial sums of `a` are `вЙ§ B` in norm, the
    `e(nќ≤)`-twisted sum is `вЙ§ B(1 + 2ѕАN|ќ≤|)` вАФ the summation-by-parts step that converts
    `WeakPNT_AP`-style partial-sum control into major-arc window evaluations, with the
    window factor `N|ќ≤| = O(P)` bounded on a Farey arc. -/
lemma abel_twisted_error (a : вДХ вЖТ вДВ) (ќ≤ : вДЭ) (N : вДХ) (B : вДЭ)
    (hB : вИА t вЙ§ N, вАЦвИС n вИИ Finset.range t, a nвАЦ вЙ§ B) :
    вАЦвИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ B * (1 + 2 * Real.pi * N * |ќ≤|) := by
  have hB0 : 0 вЙ§ B := le_trans (norm_nonneg _) (hB 0 (Nat.zero_le N))
  have hfac : (0:вДЭ) вЙ§ 2 * Real.pi * N * |ќ≤| := by positivity
  rcases Nat.eq_zero_or_pos N with hN0 | hNpos
  ¬Ј subst hN0
    simp only [Finset.range_zero, Finset.sum_empty, norm_zero]
    exact mul_nonneg hB0 (by linarith)
  have hstep : вИА i : вДХ, вАЦe (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)вАЦ
      вЙ§ 2 * Real.pi * |ќ≤| := by
    intro i
    have hfact : e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)
        = e ((i : вДЭ) * ќ≤) * (e ќ≤ - 1) := by
      rw [mul_sub, mul_one, e_add]
      congr 1
      push_cast
      ring
    rw [hfact, norm_mul, e_norm, one_mul, e_sub_one_norm]
    have hsin := Real.abs_sin_le_abs (x := Real.pi * ќ≤)
    have hpi : |Real.pi * ќ≤| = Real.pi * |ќ≤| := by
      rw [abs_mul, abs_of_pos Real.pi_pos]
    linarith [hsin, hpi.le, hpi.ge]
  have habel : вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ≤)
      = e (((N - 1 : вДХ) : вДЭ) * ќ≤) * (вИС n вИИ Finset.range N, a n)
        - вИС i вИИ Finset.range (N - 1),
            (e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)) * вИС j вИИ Finset.range (i + 1), a j := by
    have h := Finset.sum_range_by_parts (f := fun m : вДХ => e ((m : вДЭ) * ќ≤)) (g := a) (n := N)
    simp only [smul_eq_mul] at h
    calc вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ≤)
        = вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤) * a n := by
          apply Finset.sum_congr rfl
          intro n _
          ring
      _ = _ := h
  rw [habel]
  calc вАЦe (((N - 1 : вДХ) : вДЭ) * ќ≤) * (вИС n вИИ Finset.range N, a n)
        - вИС i вИИ Finset.range (N - 1),
            (e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)) * вИС j вИИ Finset.range (i + 1), a jвАЦ
      вЙ§ вАЦe (((N - 1 : вДХ) : вДЭ) * ќ≤) * (вИС n вИИ Finset.range N, a n)вАЦ
        + вАЦвИС i вИИ Finset.range (N - 1),
            (e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)) * вИС j вИИ Finset.range (i + 1), a jвАЦ :=
        norm_sub_le _ _
    _ вЙ§ B + ((N - 1 : вДХ) : вДЭ) * (2 * Real.pi * |ќ≤| * B) := by
        apply add_le_add
        ¬Ј rw [norm_mul, e_norm, one_mul]
          exact hB N le_rfl
        ¬Ј calc вАЦвИС i вИИ Finset.range (N - 1),
              (e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)) * вИС j вИИ Finset.range (i + 1), a jвАЦ
              вЙ§ вИС i вИИ Finset.range (N - 1),
                вАЦ(e (((i + 1 : вДХ) : вДЭ) * ќ≤) - e ((i : вДЭ) * ќ≤)) * вИС j вИИ Finset.range (i + 1), a jвАЦ :=
                norm_sum_le _ _
            _ вЙ§ вИС _i вИИ Finset.range (N - 1), 2 * Real.pi * |ќ≤| * B := by
                apply Finset.sum_le_sum
                intro i hi
                rw [norm_mul]
                apply mul_le_mul (hstep i) (hB (i + 1) ?_) (norm_nonneg _) (by positivity)
                rw [Finset.mem_range] at hi
                omega
            _ = ((N - 1 : вДХ) : вДЭ) * (2 * Real.pi * |ќ≤| * B) := by
                rw [Finset.sum_const, nsmul_eq_mul, Finset.card_range]
    _ вЙ§ B * (1 + 2 * Real.pi * N * |ќ≤|) := by
        have hle : ((N - 1 : вДХ) : вДЭ) вЙ§ (N : вДЭ) := by
          exact_mod_cast Nat.sub_le N 1
        have hnn : (0:вДЭ) вЙ§ 2 * Real.pi * |ќ≤| := by positivity
        nlinarith [hB0, hnn, hle, mul_le_mul_of_nonneg_right hle hnn]

/-- **AP window sum vs smooth model**: if the residue-class partial sums of `g` track the
    linear model `t¬ЈќЇ` within `B` (the `WeakPNT_AP` error shape with `ќЇ = 1/ѕЖ(q)`), then
    the twisted window sum tracks `ќЇ¬ЈвИСe(nќ≤)` within `B(1 + 2ѕАN|ќ≤|)`. With
    `major_arc_residue_decomp` this evaluates `S` on a whole Farey window. -/
lemma ap_twisted_model (g : вДХ вЖТ вДВ) (ќЇ : вДВ) (q r N : вДХ) (ќ≤ : вДЭ) (B : вДЭ)
    (hB : вИА t вЙ§ N, вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n)
        - (t : вДВ) * ќЇвАЦ вЙ§ B) :
    вАЦ(вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤))
      - ќЇ * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ B * (1 + 2 * Real.pi * N * |ќ≤|) := by
  set a : вДХ вЖТ вДВ := fun n => (if n % q = r then g n else 0) - ќЇ with ha
  have hpartial : вИА t : вДХ, вИС n вИИ Finset.range t, a n
      = (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n) - (t : вДВ) * ќЇ := by
    intro t
    rw [ha]
    rw [Finset.sum_sub_distrib, Finset.sum_ite, Finset.sum_const_zero, add_zero,
      Finset.sum_const, Finset.card_range]
    simp [nsmul_eq_mul]
  have htwist : вИС n вИИ Finset.range N, a n * e ((n : вДЭ) * ќ≤)
      = (вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤))
        - ќЇ * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤) := by
    rw [ha]
    have hterm : вИА n : вДХ, ((if n % q = r then g n else 0) - ќЇ) * e ((n : вДЭ) * ќ≤)
        = (if n % q = r then g n * e ((n : вДЭ) * ќ≤) else 0) - ќЇ * e ((n : вДЭ) * ќ≤) := by
      intro n
      by_cases h : n % q = r
      ¬Ј rw [if_pos h, if_pos h]
        ring
      ¬Ј rw [if_neg h, if_neg h]
        ring
    calc вИС n вИИ Finset.range N, ((if n % q = r then g n else 0) - ќЇ) * e ((n : вДЭ) * ќ≤)
        = вИС n вИИ Finset.range N,
            ((if n % q = r then g n * e ((n : вДЭ) * ќ≤) else 0) - ќЇ * e ((n : вДЭ) * ќ≤)) := by
          apply Finset.sum_congr rfl
          intro n _
          exact hterm n
      _ = (вИС n вИИ Finset.range N, if n % q = r then g n * e ((n : вДЭ) * ќ≤) else 0)
          - вИС n вИИ Finset.range N, ќЇ * e ((n : вДЭ) * ќ≤) := by
          rw [Finset.sum_sub_distrib]
      _ = (вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤))
          - ќЇ * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤) := by
          rw [Finset.sum_ite, Finset.sum_const_zero, add_zero, Finset.mul_sum]
  rw [вЖР htwist]
  apply abel_twisted_error
  intro t ht
  rw [hpartial t]
  exact hB t ht

/-- **Ces√†ro limit to window bound**: if `(вИС_{n<t} c(n))/t вЖТ ќЇ`, then for every `ќµ > 0`
    there is a constant `C` with `вАЦвИС_{n<t} c(n) вИТ tќЇвАЦ вЙ§ ќµN + C` for ALL `t вЙ§ N` вАФ the
    exact `B` that `ap_twisted_model` consumes. Converts `WeakPNT_AP`'s Tendsto into
    per-window control, with the small-`t` range absorbed into `C`. -/
lemma partial_sum_window_bound (c : вДХ вЖТ вДВ) (ќЇ : вДВ)
    (h : Filter.Tendsto (fun t : вДХ => (вИС n вИИ Finset.range t, c n) / (t : вДВ))
      Filter.atTop (nhds ќЇ)) (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ C : вДЭ, 0 вЙ§ C вИІ вИА N : вДХ, вИА t вЙ§ N,
      вАЦ(вИС n вИИ Finset.range t, c n) - (t : вДВ) * ќЇвАЦ вЙ§ ќµ * N + C := by
  have hev : вИАбґ† t : вДХ in Filter.atTop,
      вАЦ(вИС n вИИ Finset.range t, c n) / (t : вДВ) - ќЇвАЦ < ќµ := by
    have := Metric.tendsto_nhds.mp h ќµ hќµ
    simpa [dist_eq_norm] using this
  obtain вЯ®TвВА, hTвВАвЯ© := Filter.eventually_atTop.mp hev
  refine вЯ®(вИС n вИИ Finset.range TвВА, вАЦc nвАЦ) + TвВА * вАЦќЇвАЦ, by positivity, ?_вЯ©
  intro N t htN
  have hNnn : (0:вДЭ) вЙ§ ќµ * N := by positivity
  rcases Nat.eq_zero_or_pos t with rfl | ht0
  ¬Ј simp only [Finset.range_zero, Finset.sum_empty, Nat.cast_zero, zero_mul, sub_zero,
      norm_zero]
    positivity
  by_cases hT : TвВА вЙ§ t
  ¬Ј have h1 := hTвВА t hT
    have hne : ((t : вДХ) : вДВ) вЙ† 0 := by exact_mod_cast ht0.ne'
    have hfact : (вИС n вИИ Finset.range t, c n) - (t : вДВ) * ќЇ
        = (t : вДВ) * ((вИС n вИИ Finset.range t, c n) / (t : вДВ) - ќЇ) := by
      field_simp
    rw [hfact, norm_mul, Complex.norm_natCast]
    have htN' : (t : вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast htN
    calc (t : вДЭ) * вАЦ(вИС n вИИ Finset.range t, c n) / (t : вДВ) - ќЇвАЦ
        вЙ§ (t : вДЭ) * ќµ := mul_le_mul_of_nonneg_left h1.le (Nat.cast_nonneg t)
      _ вЙ§ (N : вДЭ) * ќµ := mul_le_mul_of_nonneg_right htN' hќµ.le
      _ = ќµ * N := by ring
      _ вЙ§ ќµ * N + ((вИС n вИИ Finset.range TвВА, вАЦc nвАЦ) + TвВА * вАЦќЇвАЦ) := by
          have hCnn : (0:вДЭ) вЙ§ (вИС n вИИ Finset.range TвВА, вАЦc nвАЦ) + TвВА * вАЦќЇвАЦ := by positivity
          linarith
  ¬Ј push_neg at hT
    calc вАЦ(вИС n вИИ Finset.range t, c n) - (t : вДВ) * ќЇвАЦ
        вЙ§ вАЦвИС n вИИ Finset.range t, c nвАЦ + вАЦ(t : вДВ) * ќЇвАЦ := norm_sub_le _ _
      _ вЙ§ (вИС n вИИ Finset.range t, вАЦc nвАЦ) + (t : вДЭ) * вАЦќЇвАЦ := by
          apply add_le_add (norm_sum_le _ _)
          rw [norm_mul, Complex.norm_natCast]
      _ вЙ§ (вИС n вИИ Finset.range TвВА, вАЦc nвАЦ) + (TвВА : вДЭ) * вАЦќЇвАЦ := by
          apply add_le_add
          ¬Ј apply Finset.sum_le_sum_of_subset_of_nonneg
            ¬Ј intro x hx
              rw [Finset.mem_range] at hx вКҐ
              omega
            ¬Ј intro n _ _
              exact norm_nonneg _
          ¬Ј apply mul_le_mul_of_nonneg_right _ (norm_nonneg ќЇ)
            exact_mod_cast hT.le
      _ вЙ§ ќµ * N + ((вИС n вИИ Finset.range TвВА, вАЦc nвАЦ) + TвВА * вАЦќЇвАЦ) := by linarith

/-- **The window evaluation** (route-1 capstone): if each residue class of `g` has Ces√†ro
    density `ќЇ(r)` (the `WeakPNT_AP` shape for each FIXED `q`), then for every `ќµ > 0`
    there is `C` such that on EVERY window `a/q + ќ≤`,
    `вАЦS вИТ (вИС_r e(ra/q)ќЇ(r))¬ЈвИСe(nќ≤)вАЦ вЙ§ q(ќµN+C)(1+2ѕАN|ќ≤|)` вАФ with `N|ќ≤| = O(P)` bounded on
    a Farey arc, this is `o(N)` per window with NO uniformity in `q`. -/
theorem major_window_eval (g : вДХ вЖТ вДВ) (q : вДХ) (hq : 0 < q) (ќЇ : вДХ вЖТ вДВ)
    (hќЇ : вИА r, r < q вЖТ Filter.Tendsto
      (fun t : вДХ => (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n) / (t : вДВ))
      Filter.atTop (nhds (ќЇ r)))
    (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ C : вДЭ, 0 вЙ§ C вИІ вИА N : вДХ, вИА a : вД§, вИА ќ≤ : вДЭ,
      вАЦ(вИС n вИИ Finset.range N, g n * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
        - (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * ќЇ r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ (q : вДЭ) * ((ќµ * N + C) * (1 + 2 * Real.pi * N * |ќ≤|)) := by
  classical
  -- per-residue constants from the extractor
  have hres : вИА r, r < q вЖТ вИГ C : вДЭ, 0 вЙ§ C вИІ вИА N : вДХ, вИА t вЙ§ N,
      вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n) - (t : вДВ) * ќЇ rвАЦ
        вЙ§ ќµ * N + C := by
    intro r hr
    have hconv : (fun t : вДХ => (вИС n вИИ Finset.range t,
          if n % q = r then g n else 0) / (t : вДВ))
        = (fun t : вДХ => (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n) / (t : вДВ)) := by
      funext t
      rw [Finset.sum_ite, Finset.sum_const_zero, add_zero]
    obtain вЯ®C, hC0, hCвЯ© := partial_sum_window_bound
      (fun n => if n % q = r then g n else 0) (ќЇ r) (by rw [hconv]; exact hќЇ r hr) ќµ hќµ
    refine вЯ®C, hC0, fun N t ht => ?_вЯ©
    have := hC N t ht
    rwa [Finset.sum_ite, Finset.sum_const_zero, add_zero] at this
  -- a single constant dominating all residues
  set Cf : вДХ вЖТ вДЭ := fun r => if h : r < q then (hres r h).choose else 0 with hCf
  set Ctot : вДЭ := вИС r вИИ Finset.range q, Cf r with hCtot
  have hCf0 : вИА r, 0 вЙ§ Cf r := by
    intro r
    by_cases h : r < q
    ¬Ј simp only [hCf, dif_pos h]
      exact (hres r h).choose_spec.1
    ¬Ј simp only [hCf, dif_neg h]
      exact le_refl 0
  have hCtot0 : 0 вЙ§ Ctot := Finset.sum_nonneg fun r _ => hCf0 r
  have hCfle : вИА r вИИ Finset.range q, Cf r вЙ§ Ctot := by
    intro r hr
    exact Finset.single_le_sum (fun i _ => hCf0 i) hr
  refine вЯ®Ctot, hCtot0, fun N a ќ≤ => ?_вЯ©
  rw [major_arc_residue_decomp g N a q hq ќ≤, Finset.sum_mul, вЖР Finset.sum_sub_distrib]
  have hfac : (0:вДЭ) вЙ§ 1 + 2 * Real.pi * N * |ќ≤| := by positivity
  calc вАЦвИС r вИИ Finset.range q,
        (e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
            * вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤)
          - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * ќЇ r * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤))вАЦ
      вЙ§ вИС r вИИ Finset.range q,
        вАЦe ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
            * вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤)
          - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * ќЇ r * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС _r вИИ Finset.range q, (ќµ * N + Ctot) * (1 + 2 * Real.pi * N * |ќ≤|) := by
        apply Finset.sum_le_sum
        intro r hr
        have hrq : r < q := Finset.mem_range.mp hr
        have hfactor : e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
              * вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤)
            - e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * ќЇ r * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)
            = e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ))
              * ((вИС n вИИ (Finset.range N).filter (fun n => n % q = r), g n * e ((n : вДЭ) * ќ≤))
                - ќЇ r * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)) := by
          ring
        rw [hfactor, norm_mul, e_norm, one_mul]
        have hB : вИА t вЙ§ N,
            вАЦ(вИС n вИИ (Finset.range t).filter (fun n => n % q = r), g n) - (t : вДВ) * ќЇ rвАЦ
              вЙ§ ќµ * N + Ctot := by
          intro t ht
          have h1 := (hres r hrq).choose_spec.2 N t ht
          have h2 : Cf r = (hres r hrq).choose := by
            simp only [hCf, dif_pos hrq]
          have h3 := hCfle r hr
          rw [h2] at h3
          linarith
        exact ap_twisted_model g (ќЇ r) q r N ќ≤ (ќµ * N + Ctot) hB
    _ = (q : вДЭ) * ((ќµ * N + Ctot) * (1 + 2 * Real.pi * N * |ќ≤|)) := by
        rw [Finset.sum_const, nsmul_eq_mul, Finset.card_range]

/-- **Squaring a window estimate**: `вАЦSвИТMвАЦ вЙ§ E вЯє вАЦS¬≤вИТM¬≤вАЦ вЙ§ E(E+2вАЦMвАЦ)` вАФ converts the
    window evaluation of `S` into the window evaluation of `S¬≤` that the major
    coefficient `вИЂ_рЭФР S¬≤e(вИТnќ±)` consumes. -/
lemma sq_diff_norm_le (S M : вДВ) (E : вДЭ) (h : вАЦS - MвАЦ вЙ§ E) :
    вАЦS ^ 2 - M ^ 2вАЦ вЙ§ E * (E + 2 * вАЦMвАЦ) := by
  have hE0 : 0 вЙ§ E := le_trans (norm_nonneg _) h
  have hfact : S ^ 2 - M ^ 2 = (S - M) * ((S - M) + 2 * M) := by ring
  rw [hfact, norm_mul]
  apply mul_le_mul h _ (norm_nonneg _) hE0
  calc вАЦ(S - M) + 2 * MвАЦ вЙ§ вАЦS - MвАЦ + вАЦ(2 : вДВ) * MвАЦ := norm_add_le _ _
    _ вЙ§ E + 2 * вАЦMвАЦ := by
        rw [norm_mul]
        have h2 : вАЦ(2 : вДВ)вАЦ = 2 := by norm_num
        rw [h2]
        linarith

open ArithmeticFunction in
/-- **Ramanujan sum at coprime argument**: `вИС_{r<q, gcd(r,q)=1} e(ar/q) = ќЉ(q)` вАФ
    the arithmetic heart of the singular series. M√ґbius inclusion-exclusion over the
    banked additive-character orthogonality. -/
lemma ramanujan_sum_coprime (a : вД§) (q : вДХ) (hq : 0 < q) (ha : Int.gcd a q = 1) :
    вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)
      = (ArithmeticFunction.moebius q : вДВ) := by
  classical
  have hq' : q вЙ† 0 := hq.ne'
  have hind : вИА n : вДХ, n вЙ† 0 вЖТ
      (вИС d вИИ n.divisors, (ArithmeticFunction.moebius d : вДВ)) = if n = 1 then 1 else 0 := by
    intro n hn
    have h : ((ArithmeticFunction.moebius * ArithmeticFunction.zeta :
        ArithmeticFunction вД§)) n = (1 : ArithmeticFunction вД§) n := by
      rw [ArithmeticFunction.moebius_mul_coe_zeta]
    rw [ArithmeticFunction.coe_mul_zeta_apply, ArithmeticFunction.one_apply] at h
    by_cases h1 : n = 1
    ¬Ј rw [if_pos h1, h1]
      simp
    ¬Ј rw [if_neg h1]
      rw [if_neg h1] at h
      have : ((вИС d вИИ n.divisors, ArithmeticFunction.moebius d : вД§) : вДВ) = 0 := by
        rw [h]
        norm_num
      push_cast at this
      exact this
  have hdivset : вИА r : вДХ, (Nat.gcd r q).divisors = q.divisors.filter (fun d => d вИ£ r) := by
    intro r
    ext d
    simp only [Nat.mem_divisors, Finset.mem_filter]
    constructor
    ¬Ј rintro вЯ®hdvd, -вЯ©
      rw [Nat.dvd_gcd_iff] at hdvd
      exact вЯ®вЯ®hdvd.2, hq'вЯ©, hdvd.1вЯ©
    ¬Ј rintro вЯ®вЯ®hdq, -вЯ©, hdrвЯ©
      exact вЯ®Nat.dvd_gcd hdr hdq, fun hc => hq' (Nat.gcd_eq_zero_iff.mp hc).2вЯ©
  have hstep : вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)
      = вИС d вИИ q.divisors, (ArithmeticFunction.moebius d : вДВ)
          * вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q) := by
    rw [Finset.sum_filter]
    have hpt : вИА r вИИ Finset.range q,
        (if Nat.gcd r q = 1 then e ((a : вДЭ) * r / q) else 0)
        = вИС d вИИ q.divisors, if d вИ£ r then (ArithmeticFunction.moebius d : вДВ)
            * e ((a : вДЭ) * r / q) else 0 := by
      intro r _
      have hgpos : Nat.gcd r q вЙ† 0 := fun hc => hq' (Nat.gcd_eq_zero_iff.mp hc).2
      calc (if Nat.gcd r q = 1 then e ((a : вДЭ) * r / q) else 0)
          = (if Nat.gcd r q = 1 then (1:вДВ) else 0) * e ((a : вДЭ) * r / q) := by
            by_cases h : Nat.gcd r q = 1
            ¬Ј rw [if_pos h, if_pos h, one_mul]
            ¬Ј rw [if_neg h, if_neg h, zero_mul]
        _ = (вИС d вИИ (Nat.gcd r q).divisors, (ArithmeticFunction.moebius d : вДВ))
              * e ((a : вДЭ) * r / q) := by rw [hind _ hgpos]
        _ = вИС d вИИ q.divisors.filter (fun d => d вИ£ r),
              (ArithmeticFunction.moebius d : вДВ) * e ((a : вДЭ) * r / q) := by
            rw [hdivset r, Finset.sum_mul]
        _ = вИС d вИИ q.divisors, if d вИ£ r then (ArithmeticFunction.moebius d : вДВ)
              * e ((a : вДЭ) * r / q) else 0 := by
            rw [Finset.sum_filter]
    rw [Finset.sum_congr rfl hpt, Finset.sum_comm]
    apply Finset.sum_congr rfl
    intro d _
    rw [Finset.mul_sum, Finset.sum_filter]
  have hinner : вИА d вИИ q.divisors,
      (вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q))
      = if ((q / d : вДХ) : вД§) вИ£ a then ((q / d : вДХ) : вДВ) else 0 := by
    intro d hd
    rw [Nat.mem_divisors] at hd
    obtain вЯ®hdq, -вЯ© := hd
    have hd0 : 0 < d := Nat.pos_of_dvd_of_pos hdq hq
    have hm0 : q / d вЙ† 0 := (Nat.div_pos (Nat.le_of_dvd hq hdq) hd0).ne'
    have hqe : d * (q / d) = q := Nat.mul_div_cancel' hdq
    have hreindex : (вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q))
        = вИС s вИИ Finset.range (q / d), e ((a : вДЭ) * s / (q / d : вДХ)) := by
      apply Finset.sum_nbij' (fun r => r / d) (fun s => d * s)
      ¬Ј intro r hr
        simp only [Finset.mem_filter, Finset.mem_range] at hr
        rw [Finset.mem_range]
        exact Nat.div_lt_div_of_lt_of_dvd hdq hr.1
      ¬Ј intro s hs
        rw [Finset.mem_range] at hs
        simp only [Finset.mem_filter, Finset.mem_range]
        refine вЯ®?_, Dvd.intro s rflвЯ©
        have h1 : d * s < d * (q / d) := mul_lt_mul_of_pos_left hs hd0
        rwa [hqe] at h1
      ¬Ј intro r hr
        simp only [Finset.mem_filter] at hr
        exact Nat.mul_div_cancel' hr.2
      ¬Ј intro s _
        exact Nat.mul_div_cancel_left s hd0
      ¬Ј intro r hr
        simp only [Finset.mem_filter, Finset.mem_range] at hr
        congr 1
        have hcast : ((q : вДЭ)) = (d : вДЭ) * ((q / d : вДХ) : вДЭ) := by
          exact_mod_cast hqe.symm
        have hrr : (r : вДЭ) = (d : вДЭ) * ((r / d : вДХ) : вДЭ) := by
          exact_mod_cast (Nat.mul_div_cancel' hr.2).symm
        have hd0R : (d : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hd0.ne'
        have hm0R : ((q / d : вДХ) : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hm0
        rw [hcast, hrr]
        field_simp
    rw [hreindex, char_orthogonality a (q / d) hm0]
  rw [hstep]
  have hcongr : вИС d вИИ q.divisors, (ArithmeticFunction.moebius d : вДВ)
      * вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q)
      = вИС d вИИ q.divisors, (ArithmeticFunction.moebius d : вДВ)
        * (if ((q / d : вДХ) : вД§) вИ£ a then ((q / d : вДХ) : вДВ) else 0) :=
    Finset.sum_congr rfl (fun d hd => by rw [hinner d hd])
  rw [hcongr, Finset.sum_eq_single q]
  ¬Ј rw [Nat.div_self hq]
    simp
  ¬Ј intro d hd hne
    rw [Nat.mem_divisors] at hd
    obtain вЯ®hdq, -вЯ© := hd
    have hd0 : 0 < d := Nat.pos_of_dvd_of_pos hdq hq
    rw [if_neg, mul_zero]
    intro hdvd
    have hmq : (q / d : вДХ) вИ£ q := Nat.div_dvd_of_dvd hdq
    have hgcd : (q / d) вИ£ Int.gcd a q := Int.dvd_gcd hdvd (by exact_mod_cast hmq)
    rw [ha] at hgcd
    have hm1 : (q / d : вДХ) = 1 := Nat.dvd_one.mp hgcd
    apply hne
    have hqe : d * (q / d) = q := Nat.mul_div_cancel' hdq
    rw [hm1, mul_one] at hqe
    omega
  ¬Ј intro hqmem
    exact absurd (Nat.mem_divisors_self q hq') hqmem

/-- **General Ramanujan sum evaluation** (no coprimality hypothesis): the same M√ґbius
    inclusionвАУexclusion over character orthogonality that gives `ramanujan_sum_coprime`, but
    stopped *before* the coprime collapse вАФ valid for every `a`. Yields
    `c_q(a) = вИС_{d вИ£ q} ќЉ(d)¬Ј[ (q/d) вИ£ a ]¬Ј(q/d)`, the arithmetic engine of the truncated
    singular series `рЭФЦ_P(n) = вИС_{qвЙ§P} ќЉ(q)¬≤c_q(n)/ѕЖ(q)¬≤`. -/
lemma ramanujan_sum_divisor (a : вД§) (q : вДХ) (hq : 0 < q) :
    вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)
      = вИС d вИИ q.divisors, (ArithmeticFunction.moebius d : вДВ)
          * (if ((q / d : вДХ) : вД§) вИ£ a then ((q / d : вДХ) : вДВ) else 0) := by
  classical
  have hq' : q вЙ† 0 := hq.ne'
  have hind : вИА n : вДХ, n вЙ† 0 вЖТ
      (вИС d вИИ n.divisors, (ArithmeticFunction.moebius d : вДВ)) = if n = 1 then 1 else 0 := by
    intro n hn
    have h : ((ArithmeticFunction.moebius * ArithmeticFunction.zeta :
        ArithmeticFunction вД§)) n = (1 : ArithmeticFunction вД§) n := by
      rw [ArithmeticFunction.moebius_mul_coe_zeta]
    rw [ArithmeticFunction.coe_mul_zeta_apply, ArithmeticFunction.one_apply] at h
    by_cases h1 : n = 1
    ¬Ј rw [if_pos h1, h1]
      simp
    ¬Ј rw [if_neg h1]
      rw [if_neg h1] at h
      have : ((вИС d вИИ n.divisors, ArithmeticFunction.moebius d : вД§) : вДВ) = 0 := by
        rw [h]
        norm_num
      push_cast at this
      exact this
  have hdivset : вИА r : вДХ, (Nat.gcd r q).divisors = q.divisors.filter (fun d => d вИ£ r) := by
    intro r
    ext d
    simp only [Nat.mem_divisors, Finset.mem_filter]
    constructor
    ¬Ј rintro вЯ®hdvd, -вЯ©
      rw [Nat.dvd_gcd_iff] at hdvd
      exact вЯ®вЯ®hdvd.2, hq'вЯ©, hdvd.1вЯ©
    ¬Ј rintro вЯ®вЯ®hdq, -вЯ©, hdrвЯ©
      exact вЯ®Nat.dvd_gcd hdr hdq, fun hc => hq' (Nat.gcd_eq_zero_iff.mp hc).2вЯ©
  have hstep : вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)
      = вИС d вИИ q.divisors, (ArithmeticFunction.moebius d : вДВ)
          * вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q) := by
    rw [Finset.sum_filter]
    have hpt : вИА r вИИ Finset.range q,
        (if Nat.gcd r q = 1 then e ((a : вДЭ) * r / q) else 0)
        = вИС d вИИ q.divisors, if d вИ£ r then (ArithmeticFunction.moebius d : вДВ)
            * e ((a : вДЭ) * r / q) else 0 := by
      intro r _
      have hgpos : Nat.gcd r q вЙ† 0 := fun hc => hq' (Nat.gcd_eq_zero_iff.mp hc).2
      calc (if Nat.gcd r q = 1 then e ((a : вДЭ) * r / q) else 0)
          = (if Nat.gcd r q = 1 then (1:вДВ) else 0) * e ((a : вДЭ) * r / q) := by
            by_cases h : Nat.gcd r q = 1
            ¬Ј rw [if_pos h, if_pos h, one_mul]
            ¬Ј rw [if_neg h, if_neg h, zero_mul]
        _ = (вИС d вИИ (Nat.gcd r q).divisors, (ArithmeticFunction.moebius d : вДВ))
              * e ((a : вДЭ) * r / q) := by rw [hind _ hgpos]
        _ = вИС d вИИ q.divisors.filter (fun d => d вИ£ r),
              (ArithmeticFunction.moebius d : вДВ) * e ((a : вДЭ) * r / q) := by
            rw [hdivset r, Finset.sum_mul]
        _ = вИС d вИИ q.divisors, if d вИ£ r then (ArithmeticFunction.moebius d : вДВ)
              * e ((a : вДЭ) * r / q) else 0 := by
            rw [Finset.sum_filter]
    rw [Finset.sum_congr rfl hpt, Finset.sum_comm]
    apply Finset.sum_congr rfl
    intro d _
    rw [Finset.mul_sum, Finset.sum_filter]
  have hinner : вИА d вИИ q.divisors,
      (вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q))
      = if ((q / d : вДХ) : вД§) вИ£ a then ((q / d : вДХ) : вДВ) else 0 := by
    intro d hd
    rw [Nat.mem_divisors] at hd
    obtain вЯ®hdq, -вЯ© := hd
    have hd0 : 0 < d := Nat.pos_of_dvd_of_pos hdq hq
    have hm0 : q / d вЙ† 0 := (Nat.div_pos (Nat.le_of_dvd hq hdq) hd0).ne'
    have hqe : d * (q / d) = q := Nat.mul_div_cancel' hdq
    have hreindex : (вИС r вИИ (Finset.range q).filter (fun r => d вИ£ r), e ((a : вДЭ) * r / q))
        = вИС s вИИ Finset.range (q / d), e ((a : вДЭ) * s / (q / d : вДХ)) := by
      apply Finset.sum_nbij' (fun r => r / d) (fun s => d * s)
      ¬Ј intro r hr
        simp only [Finset.mem_filter, Finset.mem_range] at hr
        rw [Finset.mem_range]
        exact Nat.div_lt_div_of_lt_of_dvd hdq hr.1
      ¬Ј intro s hs
        rw [Finset.mem_range] at hs
        simp only [Finset.mem_filter, Finset.mem_range]
        refine вЯ®?_, Dvd.intro s rflвЯ©
        have h1 : d * s < d * (q / d) := mul_lt_mul_of_pos_left hs hd0
        rwa [hqe] at h1
      ¬Ј intro r hr
        simp only [Finset.mem_filter] at hr
        exact Nat.mul_div_cancel' hr.2
      ¬Ј intro s _
        exact Nat.mul_div_cancel_left s hd0
      ¬Ј intro r hr
        simp only [Finset.mem_filter, Finset.mem_range] at hr
        congr 1
        have hcast : ((q : вДЭ)) = (d : вДЭ) * ((q / d : вДХ) : вДЭ) := by
          exact_mod_cast hqe.symm
        have hrr : (r : вДЭ) = (d : вДЭ) * ((r / d : вДХ) : вДЭ) := by
          exact_mod_cast (Nat.mul_div_cancel' hr.2).symm
        have hd0R : (d : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hd0.ne'
        have hm0R : ((q / d : вДХ) : вДЭ) вЙ† 0 := Nat.cast_ne_zero.mpr hm0
        rw [hcast, hrr]
        field_simp
    rw [hreindex, char_orthogonality a (q / d) hm0]
  rw [hstep]
  exact Finset.sum_congr rfl (fun d hd => by rw [hinner d hd])


/-- **The Dirichlet-kernel square's Fourier coefficient is the pair count**:
    `вИЂвВА¬є D_N(ќ±)¬≤ e(вИТnќ±) dќ± = #{(i,j) : i,j < N, i+j = n}` вАФ the model's contribution to
    each representation count, in exact form. -/
lemma model_sq_coeff (N n : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1,
        (вИС m вИИ Finset.range N, e ((m : вДЭ) * ќ±)) ^ 2 * e (-((n : вДЭ) * ќ±))
      = (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) := by
  have h := fourier_coeff_sq (fun _ => (1 : вДВ)) N n
  simp only [one_mul] at h
  rw [h]
  rw [Finset.sum_const, nsmul_eq_mul, mul_one]

/-- **The tent count**: for `n < N` the number of ordered pairs `i+j = n` inside the
    `N√ЧN` box is exactly `n+1` вАФ the model main term grows linearly on the upper block,
    which is what the reduction's `ќі`-lower-bound consumes. -/
lemma pair_count_eq (N n : вДХ) (hn : n < N) :
    ((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card = n + 1 := by
  have himg : (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)
      = (Finset.range (n + 1)).image (fun i => (i, n - i)) := by
    ext p
    obtain вЯ®p1, p2вЯ© := p
    simp only [Finset.mem_filter, Finset.mem_product, Finset.mem_range, Finset.mem_image,
      Prod.mk.injEq]
    constructor
    ¬Ј rintro вЯ®вЯ®h1, h2вЯ©, h3вЯ©
      exact вЯ®p1, by omega, rfl, by omegaвЯ©
    ¬Ј rintro вЯ®i, hi, rfl, rflвЯ©
      omega
  rw [himg, Finset.card_image_of_injOn, Finset.card_range]
  intro i _ j _ h
  exact (Prod.mk.injEq _ _ _ _).mp h |>.1

/-- Upper slope of the tent: for `N вЙ§ n вЙ§ 2NвИТ2` the pair count is `2NвИТ1вИТn`. -/
lemma pair_count_eq_upper (N n : вДХ) (hn1 : N вЙ§ n) (hn2 : n вЙ§ 2 * N - 2) :
    ((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card
      = 2 * N - 1 - n := by
  rcases Nat.eq_zero_or_pos N with rfl | hN0
  ¬Ј simp
  have hN : 2 вЙ§ N := by omega
  have himg : (Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)
      = (Finset.Icc (n - N + 1) (N - 1)).image (fun i => (i, n - i)) := by
    ext p
    obtain вЯ®p1, p2вЯ© := p
    simp only [Finset.mem_filter, Finset.mem_product, Finset.mem_range, Finset.mem_image,
      Finset.mem_Icc, Prod.mk.injEq]
    constructor
    ¬Ј rintro вЯ®вЯ®h1, h2вЯ©, h3вЯ©
      exact вЯ®p1, вЯ®by omega, by omegaвЯ©, rfl, by omegaвЯ©
    ¬Ј rintro вЯ®i, вЯ®hi1, hi2вЯ©, rfl, rflвЯ©
      omega
  rw [himg, Finset.card_image_of_injOn, Nat.card_Icc]
  ¬Ј omega
  ¬Ј intro i _ j _ h
    exact (Prod.mk.injEq _ _ _ _).mp h |>.1

/-- Beyond the tent: for `n вЙ• 2NвИТ1` the pair count vanishes. -/
lemma pair_count_eq_zero (N n : вДХ) (hn : 2 * N - 1 вЙ§ n) (hN : 0 < N) :
    ((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card = 0 := by
  rw [Finset.card_eq_zero, Finset.filter_eq_empty_iff]
  rintro вЯ®p1, p2вЯ© hp
  rw [Finset.mem_product, Finset.mem_range, Finset.mem_range] at hp
  simp only
  omega

open MeasureTheory in
/-- **Small-set L¬≤ bound**: on a measurable `s вКЖ (0,1]` where `вАЦfвАЦ вЙ§ B`, the L¬≤ mass is
    at most `vol(s)¬ЈB¬≤` вАФ the per-window error estimate: window measure `2/(q(Q+1))`
    times the squared window evaluation. -/
lemma setIntegral_sq_le_measure_mul_sup (f : вДЭ вЖТ вДВ) (hf : Continuous f) (s : Set вДЭ)
    (hs : MeasurableSet s) (hsub : s вКЖ Set.Ioc (0:вДЭ) 1) (B : вДЭ)
    (hB : вИА x вИИ s, вАЦf xвАЦ вЙ§ B) :
    вИЂ x in s, вАЦf xвАЦ ^ 2 вЙ§ (volume s).toReal * B ^ 2 := by
  have hint : IntegrableOn (fun x => вАЦf xвАЦ ^ 2) s volume :=
    ((hf.norm.pow 2).integrableOn_Ioc).mono_set hsub
  have hfin : volume s вЙ† вК§ := by
    apply ne_top_of_le_ne_top _ (measure_mono hsub)
    simp [Real.volume_Ioc]
  calc вИЂ x in s, вАЦf xвАЦ ^ 2
      вЙ§ вИЂ _x in s, B ^ 2 := by
        apply setIntegral_mono_on hint (integrableOn_const hfin) hs
        intro x hx
        have h := hB x hx
        have h0 : 0 вЙ§ вАЦf xвАЦ := norm_nonneg _
        nlinarith
    _ = (volume s).toReal * B ^ 2 := by
        rw [setIntegral_const, smul_eq_mul]
        rfl

/-- A Farey window's measure in usable form: `vol(BћД(c,r)) = 2r`. -/
lemma window_volume (c r : вДЭ) (hr : 0 вЙ§ r) :
    (MeasureTheory.volume (Metric.closedBall c r)).toReal = 2 * r := by
  rw [Real.volume_closedBall, ENNReal.toReal_ofReal (by linarith)]

/-- Trivial bound for Ramanujan-type sums: `вАЦвИС_{units} e(ar/q)вАЦ вЙ§ ѕЖ(q)`. -/
lemma ramanujan_sum_norm_le (a : вД§) (q : вДХ) :
    вАЦвИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)вАЦ
      вЙ§ (Nat.totient q : вДЭ) := by
  calc вАЦвИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q)вАЦ
      вЙ§ вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), вАЦe ((a : вДЭ) * r / q)вАЦ :=
        norm_sum_le _ _
    _ = ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).card := by
        simp [e_norm]
    _ = (Nat.totient q : вДЭ) := by
        rw [Nat.totient]
        congr 2
        ext r
        simp [Nat.Coprime, Nat.gcd_comm]

open MeasureTheory in
/-- Two-set L¬є subadditivity for nonneg integrands on subsets of `(0,1]`. -/
lemma setIntegral_union_le (A B : Set вДЭ) (hA : MeasurableSet A) (hB : MeasurableSet B)
    (hAsub : A вКЖ Set.Ioc (0:вДЭ) 1) (hBsub : B вКЖ Set.Ioc (0:вДЭ) 1)
    (g : вДЭ вЖТ вДЭ) (hg : Continuous g) (hgnn : вИА x, 0 вЙ§ g x) :
    вИЂ x in A вИ™ B, g x вЙ§ (вИЂ x in A, g x) + вИЂ x in B, g x := by
  have hint : IntegrableOn g (Set.Ioc (0:вДЭ) 1) volume := hg.integrableOn_Ioc
  have hunion : A вИ™ (B \ A) = A вИ™ B := Set.union_diff_self
  calc вИЂ x in A вИ™ B, g x
      = вИЂ x in A вИ™ (B \ A), g x := by rw [hunion]
    _ = (вИЂ x in A, g x) + вИЂ x in B \ A, g x := by
        apply setIntegral_union Set.disjoint_sdiff_right (hB.diff hA)
        ¬Ј exact hint.mono_set hAsub
        ¬Ј exact hint.mono_set (le_trans Set.diff_subset hBsub)
    _ вЙ§ (вИЂ x in A, g x) + вИЂ x in B, g x := by
        have hmono : вИЂ x in B \ A, g x вЙ§ вИЂ x in B, g x := by
          apply setIntegral_mono_set (hint.mono_set hBsub)
          ¬Ј filter_upwards with x using hgnn x
          ¬Ј exact HasSubset.Subset.eventuallyLE Set.diff_subset
        linarith

open MeasureTheory in
/-- **Finite-union L¬є subadditivity**: the integral of a nonneg integrand over a finite
    union is at most the sum of the per-set integrals вАФ the major-arc integral's split
    over the anchor windows (disjointness not even needed for the вЙ§ direction). -/
lemma setIntegral_biUnion_le_sum {ќє : Type*} [DecidableEq ќє] (s : Finset ќє) (t : ќє вЖТ Set вДЭ)
    (ht : вИА i вИИ s, MeasurableSet (t i)) (hsub : вИА i вИИ s, t i вКЖ Set.Ioc (0:вДЭ) 1)
    (g : вДЭ вЖТ вДЭ) (hg : Continuous g) (hgnn : вИА x, 0 вЙ§ g x) :
    вИЂ x in вЛГ i вИИ s, t i, g x вЙ§ вИС i вИИ s, вИЂ x in t i, g x := by
  classical
  induction s using Finset.induction_on with
  | empty =>
    simp
  | insert a s ha ih =>
    rw [Finset.sum_insert ha]
    have hun : (вЛГ i вИИ insert a s, t i) = t a вИ™ вЛГ i вИИ s, t i := by
      simp [Set.biUnion_insert]
    rw [hun]
    have htm : вИА i вИИ s, MeasurableSet (t i) := fun i hi => ht i (Finset.mem_insert_of_mem hi)
    have hsm : вИА i вИИ s, t i вКЖ Set.Ioc (0:вДЭ) 1 := fun i hi => hsub i (Finset.mem_insert_of_mem hi)
    have hUm : MeasurableSet (вЛГ i вИИ s, t i) := by
      apply MeasurableSet.biUnion (Finset.countable_toSet s)
      intro i hi
      exact htm i hi
    have hUsub : (вЛГ i вИИ s, t i) вКЖ Set.Ioc (0:вДЭ) 1 := by
      apply Set.iUnionвВВ_subset
      intro i hi
      exact hsm i hi
    calc вИЂ x in t a вИ™ вЛГ i вИИ s, t i, g x
        вЙ§ (вИЂ x in t a, g x) + вИЂ x in вЛГ i вИИ s, t i, g x :=
          setIntegral_union_le _ _ (ht a (Finset.mem_insert_self a s)) hUm
            (hsub a (Finset.mem_insert_self a s)) hUsub g hg hgnn
      _ вЙ§ (вИЂ x in t a, g x) + вИС i вИИ s, вИЂ x in t i, g x := by
          gcongr
          exact ih htm hsm

section VonMangoldtParseval

open ArithmeticFunction
open scoped ArithmeticFunction

/-- **The ќЫ-weighted Parseval**: `вИЂвВА¬є вАЦвИС_{nвЙ§N} ќЫ(n)e(nќ±)вАЦ¬≤ dќ± = вИС_{nвЙ§N} ќЫ(n)¬≤` вАФ
    the variance integral's denominator. -/
lemma parseval_vonMangoldt (N : вДХ) :
    вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 2
      = вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
  have hsub : Finset.Ioc 0 N вКЖ Finset.range (N + 1) := by
    intro n hn
    simp only [Finset.mem_Ioc] at hn
    simp only [Finset.mem_range]
    omega
  have hzero : вИА n вИИ Finset.range (N + 1), n вИЙ Finset.Ioc 0 N вЖТ
      ((ќЫ n : вДЭ) : вДВ) = 0 := by
    intro n hn hnot
    simp only [Finset.mem_range] at hn
    simp only [Finset.mem_Ioc] at hnot
    have hn0 : n = 0 := by omega
    subst hn0
    rw [ArithmeticFunction.map_zero]
    norm_num
  have hsum_eq : вИА ќ± : вДЭ,
      вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)
      = вИС n вИИ Finset.range (N + 1), ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±) := by
    intro ќ±
    apply Finset.sum_subset hsub
    intro n hn hnot
    rw [hzero n hn hnot, zero_mul]
  calc вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 2
      = вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range (N + 1),
          ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 2 := by
        apply intervalIntegral.integral_congr
        intro ќ± _
        dsimp only
        rw [hsum_eq ќ±]
    _ = вИС n вИИ Finset.range (N + 1), вАЦ((ќЫ n : вДЭ) : вДВ)вАЦ ^ 2 :=
        parseval (fun n => ((ќЫ n : вДЭ) : вДВ)) (N + 1)
    _ = вИС n вИИ Finset.range (N + 1), ќЫ n ^ 2 := by
        apply Finset.sum_congr rfl
        intro n _
        rw [Complex.norm_real, Real.norm_eq_abs, abs_of_nonneg vonMangoldt_nonneg]
    _ = вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
        symm
        apply Finset.sum_subset hsub
        intro n hn hnot
        simp only [Finset.mem_range] at hn
        simp only [Finset.mem_Ioc] at hnot
        have hn0 : n = 0 := by omega
        subst hn0
        rw [ArithmeticFunction.map_zero]
        norm_num

/-- The second-moment size: `вИС_{nвЙ§N} ќЫ(n)¬≤ вЙ§ N¬Ј(log N)¬≤`. -/
lemma sum_vonMangoldt_sq_le (N : вДХ) :
    вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 вЙ§ (N : вДЭ) * Real.log N ^ 2 := by
  calc вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2
      вЙ§ вИС _n вИИ Finset.Ioc 0 N, Real.log N ^ 2 := by
        apply Finset.sum_le_sum
        intro n hn
        simp only [Finset.mem_Ioc] at hn
        have h1 : ќЫ n вЙ§ Real.log n := vonMangoldt_le_log
        have h2 : Real.log n вЙ§ Real.log N := by
          apply Real.log_le_log (by exact_mod_cast hn.1)
          exact_mod_cast hn.2
        have h3 : ќЫ n вЙ§ Real.log N := le_trans h1 h2
        exact pow_le_pow_leftвВА vonMangoldt_nonneg h3 2
    _ = (N : вДЭ) * Real.log N ^ 2 := by
        rw [Finset.sum_const, Nat.card_Ioc, Nat.sub_zero, nsmul_eq_mul]

/-- The ќЫ-exponential sum is continuous in `ќ±`. -/
lemma vonMangoldt_expsum_continuous (N : вДХ) :
    Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) := by
  apply continuous_finsetSum
  intro n _
  unfold e
  fun_prop

/-- Any power of the ќЫ-exponential sum's norm is interval-integrable. -/
lemma vonMangoldt_expsum_pow_integrable (N k : вДХ) (a b : вДЭ) :
    IntervalIntegrable
      (fun ќ± : вДЭ => вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ k)
      MeasureTheory.volume a b := by
  apply Continuous.intervalIntegrable
  exact ((vonMangoldt_expsum_continuous N).norm).pow k


open MeasureTheory in
/-- **Minor-arc LвБі bound**: if the exp sum is вЙ§ C in sup on a measurable minor-arc set
    `m вКЖ (0,1]`, then `вИЂ_m вАЦSвАЦвБі вЙ§ C¬≤ ¬Ј вИС_{nвЙ§N} ќЫ(n)¬≤` вАФ one factor `вАЦSвАЦ¬≤` capped by the
    sup, the other integrated out by Parseval. This is Vinogradov's fundamental trick. -/
lemma minor_arc_L4_bound (N : вДХ) (m : Set вДЭ) (hm : MeasurableSet m)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (C : вДЭ)
    (hsup : вИА ќ± вИИ m, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ C) :
    вИЂ ќ± in m, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 4
      вЙ§ C ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
  set S : вДЭ вЖТ вДВ := fun ќ± => вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)
    with hS
  have hcont : Continuous S := vonMangoldt_expsum_continuous N
  have hint2 : IntegrableOn (fun ќ± => вАЦS ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1) volume :=
    (hcont.norm.pow 2).integrableOn_Ioc
  have hint2m : IntegrableOn (fun ќ± => вАЦS ќ±вАЦ ^ 2) m volume := hint2.mono_set hsub
  have hint4m : IntegrableOn (fun ќ± => вАЦS ќ±вАЦ ^ 4) m volume :=
    ((hcont.norm.pow 4).integrableOn_Ioc).mono_set hsub
  rcases Set.eq_empty_or_nonempty m with hempty | вЯ®ќ±вВА, hќ±вВАвЯ©
  ¬Ј rw [hempty]
    simp only [Measure.restrict_empty, integral_zero_measure]
    exact mul_nonneg (sq_nonneg C) (Finset.sum_nonneg fun n _ => sq_nonneg _)
  have hCnn : 0 вЙ§ C := le_trans (norm_nonneg _) (hsup ќ±вВА hќ±вВА)
  -- pointwise: вАЦSвАЦвБі вЙ§ C¬≤ вАЦSвАЦ¬≤ on m
  have hpt : вИА ќ± вИИ m, вАЦS ќ±вАЦ ^ 4 вЙ§ C ^ 2 * вАЦS ќ±вАЦ ^ 2 := by
    intro ќ± hќ±
    have hsq : вАЦS ќ±вАЦ ^ 2 вЙ§ C ^ 2 := pow_le_pow_leftвВА (norm_nonneg _) (hsup ќ± hќ±) 2
    calc вАЦS ќ±вАЦ ^ 4 = вАЦS ќ±вАЦ ^ 2 * вАЦS ќ±вАЦ ^ 2 := by ring
      _ вЙ§ C ^ 2 * вАЦS ќ±вАЦ ^ 2 := mul_le_mul_of_nonneg_right hsq (by positivity)
  calc вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 4
      вЙ§ вИЂ ќ± in m, C ^ 2 * вАЦS ќ±вАЦ ^ 2 :=
        setIntegral_mono_on hint4m (hint2m.const_mul _) hm hpt
    _ = C ^ 2 * вИЂ ќ± in m, вАЦS ќ±вАЦ ^ 2 := by rw [integral_const_mul]
    _ вЙ§ C ^ 2 * вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦS ќ±вАЦ ^ 2 := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        apply setIntegral_mono_set hint2
        ¬Ј filter_upwards with ќ± using by positivity
        ¬Ј exact HasSubset.Subset.eventuallyLE hsub
    _ = C ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
        rw [вЖР intervalIntegral.integral_of_le zero_le_one, parseval_vonMangoldt N]


open MeasureTheory in
/-- **The complete minor-arc variance piece**: on any minor-arc set where the ќЫ-exp-sum
    is вЙ§ Csup in sup, the L¬≤ error against ANY trig-polynomial main term is
    `вЙ§ 2¬ЈCsup¬≤¬ЈвИСќЫ(n)¬≤ + 2¬ЈвИСвАЦc(n)вАЦ¬≤`. Composes L2_diff_le + minor_arc_L4_bound +
    setL2_le_circle + parseval; with `vinogradov_sup` as Csup this is the finished
    minor-arc half of the Goldbach variance bound. -/
theorem minor_arc_variance_piece (N M : вДХ) (m : Set вДЭ) (hm : MeasurableSet m)
    (hsub : m вКЖ Set.Ioc (0:вДЭ) 1) (c : вДХ вЖТ вДВ) (Csup : вДЭ)
    (hsup : вИА ќ± вИИ m, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ Csup) :
    вИЂ ќ± in m, вАЦ(вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2
        - вИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ 2 * (Csup ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2)
        + 2 * вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
  have hS : Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) :=
    vonMangoldt_expsum_continuous N
  have hCp : Continuous (fun ќ± : вДЭ => вИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)) := by
    apply continuous_finsetSum
    intro n _
    unfold e
    fun_prop
  have h1 := L2_diff_le _ _ (hS.pow 2) hCp m hm hsub
  have h2 : (вИЂ ќ± in m,
      вАЦ(вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2)
      вЙ§ Csup ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
    have hcongr : (вИЂ ќ± in m,
        вАЦ(вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2)
        = вИЂ ќ± in m, вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 4 := by
      apply setIntegral_congr_fun hm
      intro ќ± _
      dsimp only
      rw [norm_pow, вЖР pow_mul]
    rw [hcongr]
    exact minor_arc_L4_bound N m hm hsub Csup hsup
  have h3 : (вИЂ ќ± in m, вАЦвИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2)
      вЙ§ вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
    calc (вИЂ ќ± in m, вАЦвИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2)
        вЙ§ вИЂ ќ± in (0:вДЭ)..1, вАЦвИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2 :=
          setL2_le_circle _ hCp m hsub
      _ = вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := parseval c M
  linarith


/-- **Proper prime powers are rare**: the count of `m вЙ§ n` with `ќЫ(m) вЙ† 0` but `m` not
    prime is at most `вИЪn ¬Ј (logвВВn + 1)` вАФ the elementary input for converting the
    ќЫ-weighted Goldbach count into the prime-pair count. -/
lemma card_properPrimePow_le (n : вДХ) :
    (((Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0)).card : вДЭ)
      вЙ§ (Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1) := by
  set s := (Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0) with hs
  have hcard : s.card вЙ§ (Nat.log 2 n + 1) * (Finset.Ioc 0 (Nat.sqrt n)).card := by
    apply Finset.card_le_mul_card_image_of_maps_to (f := Nat.minFac)
    ¬Ј intro m hm
      rw [hs, Finset.mem_filter, Finset.mem_Ioc] at hm
      obtain вЯ®вЯ®hm0, hmnвЯ©, hnp, hќЫвЯ© := hm
      rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ
      obtain вЯ®p, k, hp, hk, rflвЯ© := hќЫ
      have hp' := hp.nat_prime
      have hmf : (p ^ k).minFac = p := Nat.Prime.pow_minFac hp' hk.ne'
      rw [hmf, Finset.mem_Ioc]
      have hk2 : 2 вЙ§ k := by
        by_contra hcon
        interval_cases k
        exact hnp (by simpa using hp')
      refine вЯ®hp'.pos, ?_вЯ©
      rw [Nat.le_sqrt]
      calc p * p = p ^ 2 := by ring
        _ вЙ§ p ^ k := Nat.pow_le_pow_right hp'.pos hk2
        _ вЙ§ n := hmn
    ¬Ј intro p _
      have hsubfiber : (s.filter (fun m => m.minFac = p)).card
          вЙ§ (Finset.Icc 2 (Nat.log 2 n)).card := by
        apply Finset.card_le_card_of_injOn (fun m => Nat.log p m)
        ¬Ј intro m hm
          simp only [Finset.mem_coe, Finset.mem_filter] at hm
          obtain вЯ®hms, hmfвЯ© := hm
          rw [hs, Finset.mem_filter, Finset.mem_Ioc] at hms
          obtain вЯ®вЯ®hm0, hmnвЯ©, hnp, hќЫвЯ© := hms
          rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ
          obtain вЯ®q, k, hq, hk, rflвЯ© := hќЫ
          have hq' := hq.nat_prime
          have hqf : (q ^ k).minFac = q := Nat.Prime.pow_minFac hq' hk.ne'
          have hqp : q = p := by rw [вЖР hqf, hmf]
          subst hqp
          have hk2 : 2 вЙ§ k := by
            by_contra hcon
            interval_cases k
            exact hnp (by simpa using hq')
          simp only [Finset.mem_coe, Finset.mem_Icc, Nat.log_pow hq'.one_lt]
          refine вЯ®hk2, ?_вЯ©
          have h2k : 2 ^ k вЙ§ n := le_trans (Nat.pow_le_pow_left hq'.two_le k) hmn
          exact Nat.le_log_of_pow_le (by norm_num) h2k
        ¬Ј intro m1 hm1 m2 hm2 heq
          simp only [Finset.mem_coe, Finset.mem_filter] at hm1 hm2
          obtain вЯ®hms1, hmf1вЯ© := hm1
          obtain вЯ®hms2, hmf2вЯ© := hm2
          rw [hs, Finset.mem_filter] at hms1 hms2
          obtain вЯ®-, -, hќЫ1вЯ© := hms1
          obtain вЯ®-, -, hќЫ2вЯ© := hms2
          rw [ArithmeticFunction.vonMangoldt_ne_zero_iff] at hќЫ1 hќЫ2
          obtain вЯ®q1, k1, hq1, hk1, rflвЯ© := hќЫ1
          obtain вЯ®q2, k2, hq2, hk2, rflвЯ© := hќЫ2
          have hq1' := hq1.nat_prime
          have hq2' := hq2.nat_prime
          have hf1 : (q1 ^ k1).minFac = q1 := Nat.Prime.pow_minFac hq1' hk1.ne'
          have hf2 : (q2 ^ k2).minFac = q2 := Nat.Prime.pow_minFac hq2' hk2.ne'
          have hq1p : q1 = p := by rw [вЖР hf1, hmf1]
          have hq2p : q2 = p := by rw [вЖР hf2, hmf2]
          subst hq1p
          subst hq2p
          simp only [Nat.log_pow hq1'.one_lt] at heq
          rw [heq]
      calc (s.filter (fun m => m.minFac = p)).card
          вЙ§ (Finset.Icc 2 (Nat.log 2 n)).card := hsubfiber
        _ вЙ§ Nat.log 2 n + 1 := by rw [Nat.card_Icc]; omega
  have hIoc : (Finset.Ioc 0 (Nat.sqrt n)).card = Nat.sqrt n := by
    rw [Nat.card_Ioc, Nat.sub_zero]
  rw [hIoc] at hcard
  calc (s.card : вДЭ) вЙ§ ((Nat.log 2 n + 1) * Nat.sqrt n : вДХ) := by exact_mod_cast hcard
    _ = (Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1) := by push_cast; ring


/-- **The bad-n bound**: if `n` is NOT a sum of two primes, the ќЫ-weighted representation
    count is supported on pairs containing a proper prime power, hence
    `вЙ§ 2¬Јlog¬≤n¬ЈвИЪn¬Ј(logвВВn+1)` вАФ negligible against the main term `вЙН n`. -/
lemma badRep_le (N n : вДХ) (hn : 1 вЙ§ n)
    (hbad : ¬ђ вИГ p q, Nat.Prime p вИІ Nat.Prime q вИІ n = p + q) :
    вИС pr вИИ (Finset.range N √ЧЋҐ Finset.range N).filter (fun pr => pr.1 + pr.2 = n),
        ќЫ pr.1 * ќЫ pr.2
      вЙ§ 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) := by
  classical
  set F := (Finset.range N √ЧЋҐ Finset.range N).filter (fun pr => pr.1 + pr.2 = n) with hF
  set F' := F.filter (fun pr => ќЫ pr.1 * ќЫ pr.2 вЙ† 0) with hF'
  set PP := (Finset.Ioc 0 n).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0) with hPP
  have hlogn : 0 вЙ§ Real.log n := Real.log_nonneg (by exact_mod_cast hn)
  have hmem : вИА pr вИИ F', pr.1 + pr.2 = n вИІ ќЫ pr.1 вЙ† 0 вИІ ќЫ pr.2 вЙ† 0 := by
    intro pr hpr
    rw [hF', Finset.mem_filter] at hpr
    obtain вЯ®hprF, hneвЯ© := hpr
    rw [hF, Finset.mem_filter] at hprF
    exact вЯ®hprF.2, fun h => hne (by rw [h, zero_mul]),
      fun h => hne (by rw [h, mul_zero])вЯ©
  have hterm : вИА pr вИИ F', ќЫ pr.1 * ќЫ pr.2 вЙ§ Real.log n ^ 2 := by
    intro pr hpr
    obtain вЯ®hsum, h1, h2вЯ© := hmem pr hpr
    have h1le : 2 вЙ§ pr.1 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h1).two_le
    have h2le : 2 вЙ§ pr.2 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h2).two_le
    have hb1 : ќЫ pr.1 вЙ§ Real.log n :=
      le_trans ArithmeticFunction.vonMangoldt_le_log
        (Real.log_le_log (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_two h1le)
          (by exact_mod_cast Nat.le.intro hsum))
    have hb2 : ќЫ pr.2 вЙ§ Real.log n :=
      le_trans ArithmeticFunction.vonMangoldt_le_log
        (Real.log_le_log (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_two h2le)
          (by exact_mod_cast Nat.le.intro (by omega : pr.2 + pr.1 = n)))
    calc ќЫ pr.1 * ќЫ pr.2 вЙ§ Real.log n * Real.log n :=
          mul_le_mul hb1 hb2 ArithmeticFunction.vonMangoldt_nonneg hlogn
      _ = Real.log n ^ 2 := (sq (Real.log n)).symm
  have hsplit : вИС pr вИИ F', ќЫ pr.1 * ќЫ pr.2
      = (вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2)
        + вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2 :=
    (Finset.sum_filter_add_sum_filter_not F' _ _).symm
  -- the ¬ђprime-first-coordinate class injects into PP via pr вЖ¶ pr.1
  have hcardA : (F'.filter (fun pr => ¬ђ pr.1.Prime)).card вЙ§ PP.card := by
    apply Finset.card_le_card_of_injOn (fun pr => pr.1)
    ¬Ј intro pr hpr
      simp only [Finset.mem_coe, Finset.mem_filter] at hpr
      obtain вЯ®hprF', hnpвЯ© := hpr
      obtain вЯ®hsum, h1, _вЯ© := hmem pr hprF'
      have h1le : 2 вЙ§ pr.1 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h1).two_le
      simp only [Finset.mem_coe, hPP, Finset.mem_filter, Finset.mem_Ioc]
      exact вЯ®вЯ®by omega, Nat.le.intro hsumвЯ©, hnp, h1вЯ©
    ¬Ј intro p1 hp1 p2 hp2 heq
      simp only [Finset.mem_coe, Finset.mem_filter] at hp1 hp2
      have hs1 := (hmem p1 hp1.1).1
      have hs2 := (hmem p2 hp2.1).1
      dsimp only at heq
      have : p1.2 = p2.2 := by omega
      exact Prod.ext heq this
  -- the prime-first-coordinate class: second coordinate is a proper prime power
  have hcardB : (F'.filter (fun pr => pr.1.Prime)).card вЙ§ PP.card := by
    apply Finset.card_le_card_of_injOn (fun pr => pr.2)
    ¬Ј intro pr hpr
      simp only [Finset.mem_coe, Finset.mem_filter] at hpr
      obtain вЯ®hprF', hp1вЯ© := hpr
      obtain вЯ®hsum, h1, h2вЯ© := hmem pr hprF'
      have h2le : 2 вЙ§ pr.2 := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp h2).two_le
      have hnp2 : ¬ђ pr.2.Prime := by
        intro hp2
        exact hbad вЯ®pr.1, pr.2, hp1, hp2, hsum.symmвЯ©
      simp only [Finset.mem_coe, hPP, Finset.mem_filter, Finset.mem_Ioc]
      exact вЯ®вЯ®by omega, Nat.le.intro (by omega : pr.2 + pr.1 = n)вЯ©, hnp2, h2вЯ©
    ¬Ј intro p1 hp1 p2 hp2 heq
      simp only [Finset.mem_coe, Finset.mem_filter] at hp1 hp2
      have hs1 := (hmem p1 hp1.1).1
      have hs2 := (hmem p2 hp2.1).1
      dsimp only at heq
      have : p1.1 = p2.1 := by omega
      exact Prod.ext this heq
  have hboundA : вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
      вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
    calc вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
        вЙ§ вИС _pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), Real.log n ^ 2 :=
          Finset.sum_le_sum (fun pr hpr => hterm pr (Finset.mem_of_mem_filter pr hpr))
      _ = ((F'.filter (fun pr => ¬ђ pr.1.Prime)).card : вДЭ) * Real.log n ^ 2 := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ (by positivity)
          exact_mod_cast hcardA
  have hboundB : вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
      вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
    calc вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2
        вЙ§ вИС _pr вИИ F'.filter (fun pr => pr.1.Prime), Real.log n ^ 2 :=
          Finset.sum_le_sum (fun pr hpr => hterm pr (Finset.mem_of_mem_filter pr hpr))
      _ = ((F'.filter (fun pr => pr.1.Prime)).card : вДЭ) * Real.log n ^ 2 := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 := by
          apply mul_le_mul_of_nonneg_right _ (by positivity)
          exact_mod_cast hcardB
  have hPPbound := card_properPrimePow_le n
  rw [вЖР hPP] at hPPbound
  calc вИС pr вИИ F, ќЫ pr.1 * ќЫ pr.2
      = вИС pr вИИ F', ќЫ pr.1 * ќЫ pr.2 := (Finset.sum_filter_ne_zero F).symm
    _ = (вИС pr вИИ F'.filter (fun pr => pr.1.Prime), ќЫ pr.1 * ќЫ pr.2)
        + вИС pr вИИ F'.filter (fun pr => ¬ђ pr.1.Prime), ќЫ pr.1 * ќЫ pr.2 := hsplit
    _ вЙ§ (PP.card : вДЭ) * Real.log n ^ 2 + (PP.card : вДЭ) * Real.log n ^ 2 :=
        add_le_add hboundB hboundA
    _ = 2 * Real.log n ^ 2 * (PP.card : вДЭ) := by ring
    _ вЙ§ 2 * Real.log n ^ 2 * ((Nat.sqrt n : вДЭ) * (Nat.log 2 n + 1)) := by
        apply mul_le_mul_of_nonneg_left hPPbound (by positivity)


/-- **Non-unit residue classes carry negligible ќЫ-mass**: if `gcd(r,q) > 1`, every
    prime in the class `n вЙ° r (q)` divides `q` (finitely many, вЙ§ q+1) and everything
    else is a proper prime power (вЙ§ вИЪt¬Ј(logвВВt+1)); each term is вЙ§ log t. Hence the
    class sum is `O(вИЪt ¬Ј polylog t) = o(t)` вАФ its Ces√†ro density is 0, completing
    `major_window_eval`'s hypothesis for `g = ќЫ` off the units. -/
lemma nonunit_class_vonMangoldt_sum_le (q r t : вДХ) (hq : 0 < q) (hd : 1 < Nat.gcd r q) :
    вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n
      вЙ§ ((q : вДЭ) + 1) * Real.log t
        + (Nat.sqrt t : вДЭ) * (Nat.log 2 t + 1) * Real.log t := by
  classical
  set F := (Finset.range t).filter (fun n => n % q = r) with hF
  have hlogt : 0 вЙ§ Real.log t := Real.log_natCast_nonneg t
  have hterm : вИА n вИИ F, ќЫ n вЙ§ Real.log t := by
    intro n hn
    rw [hF, Finset.mem_filter, Finset.mem_range] at hn
    rcases Nat.eq_zero_or_pos n with rfl | hn0
    ¬Ј simpa using hlogt
    calc ќЫ n вЙ§ Real.log n := ArithmeticFunction.vonMangoldt_le_log
      _ вЙ§ Real.log t := Real.log_le_log (by exact_mod_cast hn0)
          (by exact_mod_cast hn.1.le)
  have hќЫnn : вИА n, 0 вЙ§ ќЫ n := fun n => ArithmeticFunction.vonMangoldt_nonneg
  rw [вЖР Finset.sum_filter_add_sum_filter_not F (fun n => n.Prime) ќЫ]
  have hprime_bound : вИС n вИИ F.filter (fun n => n.Prime), ќЫ n вЙ§ ((q : вДЭ) + 1) * Real.log t := by
    have hsub : F.filter (fun n => n.Prime) вКЖ Finset.range (q + 1) := by
      intro n hn
      rw [Finset.mem_filter] at hn
      obtain вЯ®hnF, hpвЯ© := hn
      rw [hF, Finset.mem_filter] at hnF
      have hgcd : Nat.gcd n q = Nat.gcd r q := by
        rw [Nat.gcd_comm n q, Nat.gcd_rec q n, hnF.2]
      have hdvd : n вИ£ q := by
        have h1 : Nat.gcd n q вИ£ n := Nat.gcd_dvd_left n q
        have h2 : 1 < Nat.gcd n q := by rw [hgcd]; exact hd
        rcases (Nat.Prime.eq_one_or_self_of_dvd hp _ h1) with h | h
        ¬Ј omega
        ¬Ј rw [вЖР h]
          exact Nat.gcd_dvd_right n q
      rw [Finset.mem_range]
      have := Nat.le_of_dvd hq hdvd
      omega
    calc вИС n вИИ F.filter (fun n => n.Prime), ќЫ n
        вЙ§ вИС _n вИИ F.filter (fun n => n.Prime), Real.log t :=
          Finset.sum_le_sum (fun n hn => hterm n (Finset.mem_of_mem_filter n hn))
      _ = ((F.filter (fun n => n.Prime)).card : вДЭ) * Real.log t := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ ((q : вДЭ) + 1) * Real.log t := by
          apply mul_le_mul_of_nonneg_right _ hlogt
          have := Finset.card_le_card hsub
          rw [Finset.card_range] at this
          exact_mod_cast this
  have hpp_bound : вИС n вИИ F.filter (fun n => ¬ђ n.Prime), ќЫ n
      вЙ§ (Nat.sqrt t : вДЭ) * (Nat.log 2 t + 1) * Real.log t := by
    have hdrop : вИС n вИИ F.filter (fun n => ¬ђ n.Prime), ќЫ n
        = вИС n вИИ (F.filter (fun n => ¬ђ n.Prime)).filter (fun n => ќЫ n вЙ† 0), ќЫ n :=
      (Finset.sum_filter_ne_zero _).symm
    rw [hdrop]
    have hsub : (F.filter (fun n => ¬ђ n.Prime)).filter (fun n => ќЫ n вЙ† 0)
        вКЖ (Finset.Ioc 0 t).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0) := by
      intro n hn
      simp only [Finset.mem_filter] at hn
      obtain вЯ®вЯ®hnF, hnpвЯ©, hќЫвЯ© := hn
      rw [hF, Finset.mem_filter, Finset.mem_range] at hnF
      rw [Finset.mem_filter, Finset.mem_Ioc]
      have h2 : 2 вЙ§ n := (ArithmeticFunction.vonMangoldt_ne_zero_iff.mp hќЫ).two_le
      exact вЯ®вЯ®by omega, by omegaвЯ©, hnp, hќЫвЯ©
    calc вИС n вИИ (F.filter (fun n => ¬ђ n.Prime)).filter (fun n => ќЫ n вЙ† 0), ќЫ n
        вЙ§ вИС n вИИ (Finset.Ioc 0 t).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0), ќЫ n :=
          Finset.sum_le_sum_of_subset_of_nonneg hsub (fun n _ _ => hќЫnn n)
      _ вЙ§ вИС _n вИИ (Finset.Ioc 0 t).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0), Real.log t := by
          apply Finset.sum_le_sum
          intro n hn
          rw [Finset.mem_filter, Finset.mem_Ioc] at hn
          rcases Nat.eq_zero_or_pos n with rfl | hn0
          ¬Ј simpa using hlogt
          calc ќЫ n вЙ§ Real.log n := ArithmeticFunction.vonMangoldt_le_log
            _ вЙ§ Real.log t := Real.log_le_log (by exact_mod_cast hn0)
                (by exact_mod_cast hn.1.2)
      _ = ((((Finset.Ioc 0 t).filter (fun m => ¬ђ m.Prime вИІ ќЫ m вЙ† 0)).card : вДЭ))
            * Real.log t := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ вЙ§ (Nat.sqrt t : вДЭ) * (Nat.log 2 t + 1) * Real.log t :=
          mul_le_mul_of_nonneg_right (card_properPrimePow_le t) hlogt
  linarith


open Filter Real in
/-- **Non-unit classes have Ces√†ro density 0** (вДВ-cast form consumed by
    `major_window_eval`): the `O(вИЪt¬Јpolylog)` mass bound divided by `t` vanishes. -/
lemma nonunit_class_tendsto_zero (q r : вДХ) (hq : 0 < q) (hd : 1 < Nat.gcd r q) :
    Filter.Tendsto (fun t : вДХ =>
      (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ)) / (t : вДВ))
      Filter.atTop (nhds 0) := by
  set f : вДХ вЖТ вДЭ := fun t =>
    (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n) / (t : вДЭ) with hf
  have hreal : Tendsto f atTop (nhds 0) := by
    set K : вДЭ := 8 * ((q : вДЭ) + 1) + 136 with hK
    have hg0 : Tendsto (fun t : вДХ => K * (t : вДЭ) ^ (-(1/8) : вДЭ)) atTop (nhds 0) := by
      have h2 : Tendsto (fun t : вДХ => ((t : вДЭ)) ^ (-(1/8) : вДЭ)) atTop (nhds 0) :=
        (tendsto_rpow_neg_atTop (by norm_num)).comp tendsto_natCast_atTop_atTop
      simpa using h2.const_mul K
    apply tendsto_of_tendsto_of_tendsto_of_le_of_le' tendsto_const_nhds hg0
    ¬Ј apply Eventually.of_forall
      intro t
      apply div_nonneg (Finset.sum_nonneg fun n _ => vonMangoldt_nonneg) (Nat.cast_nonneg t)
    ¬Ј filter_upwards [eventually_ge_atTop 2] with t ht
      have ht0 : (0:вДЭ) < (t:вДЭ) := by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_two ht
      have ht1 : (1:вДЭ) вЙ§ (t:вДЭ) := by exact_mod_cast le_trans (by norm_num : (1:вДХ) вЙ§ 2) ht
      have hrp1 : (1:вДЭ) вЙ§ (t:вДЭ) ^ ((1/8) : вДЭ) := Real.one_le_rpow ht1 (by norm_num)
      have hrpnn : (0:вДЭ) вЙ§ (t:вДЭ) ^ ((1/8) : вДЭ) := by positivity
      -- log t вЙ§ 8 t^{1/8}
      have hlog8 : Real.log t вЙ§ 8 * (t:вДЭ) ^ ((1/8) : вДЭ) := by
        have h := Real.log_le_rpow_div (le_of_lt ht0) (show (0:вДЭ) < 1/8 by norm_num)
        have h8 : (t:вДЭ) ^ ((1/8) : вДЭ) / (1/8) = 8 * (t:вДЭ) ^ ((1/8) : вДЭ) := by ring
        linarith [h, h8.le, h8.ge]
      have hlognn : (0:вДЭ) вЙ§ Real.log t := Real.log_natCast_nonneg t
      -- Nat.log 2 t + 1 вЙ§ 17 t^{1/8}
      have hnlog : (Nat.log 2 t : вДЭ) + 1 вЙ§ 17 * (t:вДЭ) ^ ((1/8) : вДЭ) := by
        have hpow : (2:вДХ) ^ (Nat.log 2 t) вЙ§ t := Nat.pow_log_le_self 2 (by omega)
        have hlogle : (Nat.log 2 t : вДЭ) * Real.log 2 вЙ§ Real.log t := by
          have hcast : ((2:вДХ) ^ (Nat.log 2 t) : вДЭ) вЙ§ (t : вДЭ) := by exact_mod_cast hpow
          have := Real.log_le_log (by positivity) hcast
          rwa [Real.log_pow, Nat.cast_ofNat] at this
        have hl2 : (0.6931471803 : вДЭ) < Real.log 2 := Real.log_two_gt_d9
        have hk2 : (Nat.log 2 t : вДЭ) вЙ§ 2 * Real.log t := by
          nlinarith [hlogle, hl2, (by positivity : (0:вДЭ) вЙ§ ((Nat.log 2 t : вДХ) : вДЭ))]
        nlinarith [hlog8, hrp1]
      -- Nat.sqrt t вЙ§ t^{1/2}
      have hsqrt : (Nat.sqrt t : вДЭ) вЙ§ (t:вДЭ) ^ ((1/2) : вДЭ) := by
        have h1 : (Nat.sqrt t : вДЭ) ^ 2 вЙ§ (t : вДЭ) := by
          exact_mod_cast Nat.sqrt_le' t
        have h4 : (Nat.sqrt t : вДЭ) вЙ§ Real.sqrt (t:вДЭ) :=
          (Real.le_sqrt (Nat.cast_nonneg _) (le_of_lt ht0)).mpr h1
        rwa [Real.sqrt_eq_rpow] at h4
      -- assemble
      have hsum := nonunit_class_vonMangoldt_sum_le q r t hq hd
      have hnum : (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
          вЙ§ 8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8) : вДЭ) + 136 * (t:вДЭ) ^ ((3/4) : вДЭ) := by
        have hA : ((q : вДЭ) + 1) * Real.log t вЙ§ 8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8) : вДЭ) := by
          have hq1 : (0:вДЭ) вЙ§ (q:вДЭ) + 1 := by positivity
          nlinarith [mul_le_mul_of_nonneg_left hlog8 hq1]
        have hB : (Nat.sqrt t : вДЭ) * (Nat.log 2 t + 1) * Real.log t
            вЙ§ 136 * (t:вДЭ) ^ ((3/4) : вДЭ) := by
          have hs1 : (Nat.sqrt t : вДЭ) * ((Nat.log 2 t : вДЭ) + 1) * Real.log t
              вЙ§ (t:вДЭ) ^ ((1/2) : вДЭ) * (17 * (t:вДЭ) ^ ((1/8) : вДЭ)) * (8 * (t:вДЭ) ^ ((1/8) : вДЭ)) := by
            apply mul_le_mul
            ¬Ј apply mul_le_mul hsqrt hnlog (by positivity) (by positivity)
            ¬Ј exact hlog8
            ¬Ј exact hlognn
            ¬Ј positivity
          have hcollect : (t:вДЭ) ^ ((1/2) : вДЭ) * (17 * (t:вДЭ) ^ ((1/8) : вДЭ))
                * (8 * (t:вДЭ) ^ ((1/8) : вДЭ))
              = 136 * ((t:вДЭ) ^ ((1/2) : вДЭ) * (t:вДЭ) ^ ((1/8) : вДЭ) * (t:вДЭ) ^ ((1/8) : вДЭ)) := by
            ring
          have hexp : (t:вДЭ) ^ ((1/2) : вДЭ) * (t:вДЭ) ^ ((1/8) : вДЭ) * (t:вДЭ) ^ ((1/8) : вДЭ)
              = (t:вДЭ) ^ ((3/4) : вДЭ) := by
            rw [вЖР Real.rpow_add ht0, вЖР Real.rpow_add ht0]
            norm_num
          rw [hcollect, hexp] at hs1
          exact hs1
        linarith
      -- divide by t and compare exponents
      rw [hf]
      have hdiv : (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n) / (t:вДЭ)
          вЙ§ (8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8) : вДЭ) + 136 * (t:вДЭ) ^ ((3/4) : вДЭ)) / (t:вДЭ) := by
        gcongr
      have hsplit : (8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8) : вДЭ) + 136 * (t:вДЭ) ^ ((3/4) : вДЭ)) / (t:вДЭ)
          = 8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8 - 1) : вДЭ) + 136 * (t:вДЭ) ^ ((3/4 - 1) : вДЭ) := by
        rw [Real.rpow_sub ht0, Real.rpow_sub ht0, Real.rpow_one]
        ring
      have hmono1 : (t:вДЭ) ^ ((1/8 - 1) : вДЭ) вЙ§ (t:вДЭ) ^ (-(1/8) : вДЭ) :=
        Real.rpow_le_rpow_of_exponent_le ht1 (by norm_num)
      have hmono2 : (t:вДЭ) ^ ((3/4 - 1) : вДЭ) вЙ§ (t:вДЭ) ^ (-(1/8) : вДЭ) :=
        Real.rpow_le_rpow_of_exponent_le ht1 (by norm_num)
      have hKnn : (0:вДЭ) вЙ§ (t:вДЭ) ^ (-(1/8) : вДЭ) := by positivity
      calc (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n) / (t:вДЭ)
          вЙ§ 8 * ((q:вДЭ) + 1) * (t:вДЭ) ^ ((1/8 - 1) : вДЭ) + 136 * (t:вДЭ) ^ ((3/4 - 1) : вДЭ) := by
            rw [вЖР hsplit]
            exact hdiv
        _ вЙ§ K * (t:вДЭ) ^ (-(1/8) : вДЭ) := by
            rw [hK]
            have hq1 : (0:вДЭ) вЙ§ 8 * ((q:вДЭ) + 1) := by positivity
            nlinarith [mul_le_mul_of_nonneg_left hmono1 hq1,
              mul_le_mul_of_nonneg_left hmono2 (show (0:вДЭ) вЙ§ 136 by norm_num)]
  have hcast : (fun t : вДХ =>
      (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ)) / (t : вДВ))
      = fun t => ((f t : вДЭ) : вДВ) := by
    funext t
    rw [hf]
    push_cast
    ring
  rw [hcast]
  have hcomp := (Complex.continuous_ofReal.tendsto (0:вДЭ)).comp hreal
  rw [Complex.ofReal_zero] at hcomp
  exact hcomp



open Filter in
/-- **The von Mangoldt window evaluation**, conditional on EXACTLY the `WeakPNT_AP`
    statement shape (verified in PNT+ for every fixed `q`; hypothesis dischargeable at
    link time). Every Farey window evaluation of `вИСќЫ(n)e(nќ±)` against its model, with
    no uniformity in `q`. -/
theorem vonMangoldt_window_eval (q : вДХ) (hq : 0 < q)
    (hAP : вИА r, r < q вЖТ Nat.gcd r q = 1 вЖТ
      Filter.Tendsto (fun t : вДХ =>
        (вИС n вИИ Finset.range t, if n % q = r then ќЫ n else 0) / (t : вДЭ))
        Filter.atTop (nhds (1 / (Nat.totient q : вДЭ))))
    (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ C : вДЭ, 0 вЙ§ C вИІ вИА N : вДХ, вИА a : вД§, вИА ќ≤ : вДЭ,
      вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ((a : вДЭ) / (q : вДЭ) + ќ≤)))
        - (вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
          * вИС n вИИ Finset.range N, e ((n : вДЭ) * ќ≤)вАЦ
      вЙ§ (q : вДЭ) * ((ќµ * N + C) * (1 + 2 * Real.pi * N * |ќ≤|)) := by
  apply major_window_eval (fun n => ((ќЫ n : вДЭ) : вДВ)) q hq (lambdaModel q) _ ќµ hќµ
  intro r hr
  by_cases hu : Nat.gcd r q = 1
  ¬Ј -- unit class: convert WeakPNT_AP's real if-form to the вДВ filter form
    have hAPr := hAP r hr hu
    have hfun : (fun t : вДХ =>
        (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ)) / (t : вДВ))
        = fun t : вДХ =>
          (((вИС n вИИ Finset.range t, if n % q = r then ќЫ n else 0) / (t : вДЭ) : вДЭ) : вДВ) := by
      funext t
      rw [Finset.sum_ite, Finset.sum_const_zero, add_zero]
      push_cast
      ring
    rw [hfun]
    have hmodel : lambdaModel q r = (((1 / (Nat.totient q : вДЭ)) : вДЭ) : вДВ) := by
      rw [lambdaModel, if_pos hu]
      push_cast
      ring
    rw [hmodel]
    exact (Complex.continuous_ofReal.tendsto _).comp hAPr
  ¬Ј -- non-unit class: density zero
    have hd : 1 < Nat.gcd r q := by
      have h0 : 0 < Nat.gcd r q := Nat.gcd_pos_of_pos_right r hq
      omega
    have hmodel : lambdaModel q r = 0 := by
      rw [lambdaModel, if_neg hu]
    rw [hmodel]
    exact nonunit_class_tendsto_zero q r hq hd


open ArithmeticFunction in
/-- **The model coefficient in closed form**: at a reduced fraction `a/q`, the window
    model's coefficient is `ќЉ(q)/ѕЖ(q)` вАФ the HardyвАУLittlewood singular-series local
    factor. -/
lemma lambdaModel_coeff (a : вД§) (q : вДХ) (hq : 0 < q) (ha : Int.gcd a q = 1) :
    вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r
      = (ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ) := by
  calc вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r
      = вИС r вИИ Finset.range q,
          if Nat.gcd r q = 1 then e ((a : вДЭ) * r / q) * (1 / (Nat.totient q : вДВ)) else 0 := by
        apply Finset.sum_congr rfl
        intro r _
        rw [lambdaModel]
        by_cases h : Nat.gcd r q = 1
        ¬Ј rw [if_pos h, if_pos h]
          congr 2
          ring
        ¬Ј rw [if_neg h, if_neg h, mul_zero]
    _ = вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
          e ((a : вДЭ) * r / q) * (1 / (Nat.totient q : вДВ)) := (Finset.sum_filter _ _).symm
    _ = (вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1), e ((a : вДЭ) * r / q))
          * (1 / (Nat.totient q : вДВ)) := by rw [Finset.sum_mul]
    _ = (ArithmeticFunction.moebius q : вДВ) * (1 / (Nat.totient q : вДВ)) := by
        rw [ramanujan_sum_coprime a q hq ha]
    _ = (ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ) := by ring


open ArithmeticFunction in
/-- The singular-series local factor has modulus at most 1. -/
lemma moebius_div_totient_norm_le (q : вДХ) (hq : 0 < q) :
    вАЦ(ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)вАЦ вЙ§ 1 := by
  have hѕЖ : 1 вЙ§ Nat.totient q := (Nat.totient_pos.mpr hq)
  rw [norm_div]
  have h1 : вАЦ(ArithmeticFunction.moebius q : вДВ)вАЦ вЙ§ 1 := by
    have := ArithmeticFunction.abs_moebius_le_one (n := q)
    calc вАЦ(ArithmeticFunction.moebius q : вДВ)вАЦ
        = |(ArithmeticFunction.moebius q : вДЭ)| := by
          rw [show ((ArithmeticFunction.moebius q : вД§) : вДВ)
              = (((ArithmeticFunction.moebius q : вД§) : вДЭ) : вДВ) by push_cast; ring,
            Complex.norm_real, Real.norm_eq_abs]
      _ вЙ§ 1 := by exact_mod_cast this
  have h2 : (1:вДЭ) вЙ§ вАЦ(Nat.totient q : вДВ)вАЦ := by
    rw [Complex.norm_natCast]
    exact_mod_cast hѕЖ
  have h3 : (0:вДЭ) < вАЦ(Nat.totient q : вДВ)вАЦ := lt_of_lt_of_le one_pos h2
  calc вАЦ(ArithmeticFunction.moebius q : вДВ)вАЦ / вАЦ(Nat.totient q : вДВ)вАЦ
      вЙ§ 1 / вАЦ(Nat.totient q : вДВ)вАЦ := by
        gcongr
    _ вЙ§ 1 / 1 := by
        apply one_div_le_one_div_of_le one_pos h2
    _ = 1 := by norm_num

open ArithmeticFunction in
/-- Every model coefficient has modulus at most 1. -/
lemma lambdaModel_norm_le (q r : вДХ) (hq : 0 < q) : вАЦlambdaModel q rвАЦ вЙ§ 1 := by
  rw [lambdaModel]
  by_cases h : Nat.gcd r q = 1
  ¬Ј rw [if_pos h, norm_div, norm_one, Complex.norm_natCast]
    have hѕЖ : (1:вДЭ) вЙ§ (Nat.totient q : вДЭ) := by
      exact_mod_cast Nat.totient_pos.mpr hq
    rw [div_le_one (by linarith)]
    linarith
  ¬Ј rw [if_neg h, norm_zero]
    norm_num


/-- Trivial sup bound for the ќЫ-exponential sum: `вАЦS(ќ±)вАЦ вЙ§ N¬Јlog N` everywhere. -/
lemma vonMangoldt_expsum_sup (N : вДХ) (ќ± : вДЭ) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ (N : вДЭ) * Real.log N := by
  have hlogN : 0 вЙ§ Real.log N := Real.log_natCast_nonneg N
  calc вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ вИС n вИИ Finset.Ioc 0 N, вАЦ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ := norm_sum_le _ _
    _ вЙ§ вИС _n вИИ Finset.Ioc 0 N, Real.log N := by
        apply Finset.sum_le_sum
        intro n hn
        rw [Finset.mem_Ioc] at hn
        rw [norm_mul, e_norm, mul_one, Complex.norm_real, Real.norm_eq_abs,
          abs_of_nonneg ArithmeticFunction.vonMangoldt_nonneg]
        calc ќЫ n вЙ§ Real.log n := ArithmeticFunction.vonMangoldt_le_log
          _ вЙ§ Real.log N := Real.log_le_log (by exact_mod_cast hn.1)
              (by exact_mod_cast hn.2)
    _ = (N : вДЭ) * Real.log N := by
        rw [Finset.sum_const, nsmul_eq_mul, Nat.card_Ioc, Nat.sub_zero]

end VonMangoldtParseval

section ArcDecomposition

/-- **Arc decomposition (Dirichlet approximation, reduced form)**: every real `ќ±` has a
    reduced rational anchor `a/q` with `q вЙ§ Q`, `gcd(a,q) = 1`, and
    `|ќ± вИТ a/q| вЙ§ 1/(q(Q+1)) вЙ§ 1/q¬≤` вАФ assigning each point of the circle to a Farey arc.
    The `1/q¬≤` form is exactly the hypothesis of `MinSum.vinogradov_sup`. -/
lemma arc_decomposition (ќ± : вДЭ) (Q : вДХ) (hQ : 0 < Q) :
    вИГ (a : вД§) (q : вДХ), 0 < q вИІ q вЙ§ Q вИІ Int.gcd a q = 1 вИІ
      |ќ± - a / q| вЙ§ 1 / (q * (Q + 1)) вИІ |ќ± - a / q| вЙ§ 1 / (q : вДЭ) ^ 2 := by
  obtain вЯ®r, hr, hdenвЯ© := Real.exists_rat_abs_sub_le_and_den_le ќ± hQ
  have hqpos : (0 : вДЭ) < r.den := by exact_mod_cast r.pos
  have hbound : |ќ± - (r.num : вДЭ) / (r.den : вДЭ)| вЙ§ 1 / (r.den * (Q + 1)) := by
    calc |ќ± - (r.num : вДЭ) / (r.den : вДЭ)| = |ќ± - (r : вДЭ)| := by rw [Rat.cast_def]
      _ вЙ§ 1 / ((Q + 1) * r.den) := hr
      _ = 1 / (r.den * (Q + 1)) := by ring
  refine вЯ®r.num, r.den, r.pos, hden, by simpa [Int.gcd] using r.reduced, hbound, ?_вЯ©
  refine le_trans hbound ?_
  apply one_div_le_one_div_of_le (by positivity)
  have hle : (r.den : вДЭ) вЙ§ Q := by exact_mod_cast hden
  nlinarith [hqpos]


/-- **Major/minor arc dichotomy**: with cutoffs `P вЙ§ Q`, every `ќ±` is either in a MAJOR
    arc (anchor denominator `q вЙ§ P`, tight `1/(q(Q+1))` window) or a MINOR arc
    (`P < q вЙ§ Q` with `|ќ± вИТ a/q| вЙ§ 1/q¬≤` вАФ the exact input to `MinSum.vinogradov_sup`,
    whose `2 вЙ§ q` hypothesis follows from `P < q` when `1 вЙ§ P`). -/
lemma arc_dichotomy (ќ± : вДЭ) (P Q : вДХ) (hP : 0 < P) (hPQ : P вЙ§ Q) :
    (вИГ (a : вД§) (q : вДХ), 0 < q вИІ q вЙ§ P вИІ Int.gcd a q = 1 вИІ
        |ќ± - a / q| вЙ§ 1 / (q * (Q + 1)))
    вИ® (вИГ (a : вД§) (q : вДХ), P < q вИІ q вЙ§ Q вИІ Int.gcd a q = 1 вИІ
        |ќ± - a / q| вЙ§ 1 / (q : вДЭ) ^ 2) := by
  obtain вЯ®a, q, hq0, hqQ, hgcd, hnear, hsqвЯ© :=
    arc_decomposition ќ± Q (lt_of_lt_of_le hP hPQ)
  by_cases hqP : q вЙ§ P
  ¬Ј exact Or.inl вЯ®a, q, hq0, hqP, hgcd, hnearвЯ©
  ¬Ј exact Or.inr вЯ®a, q, lt_of_not_ge hqP, hqQ, hgcd, hsqвЯ©



lemma measurableSet_majorArcs (P Q : вДХ) : MeasurableSet (MajorArcs P Q) := by
  apply MeasurableSet.biUnion (Set.to_countable _)
  intro q _
  apply MeasurableSet.iUnion
  intro a
  exact measurableSet_closedBall

/-- **The canonical minor set works**: every point of `(0,1] \ MajorArcs` has a reduced
    anchor with `P < q вЙ§ Q` and `|ќ± вИТ a/q| вЙ§ 1/q¬≤` вАФ `vinogradov_sup`'s hypothesis. -/
lemma minorSet_property (P Q : вДХ) (hP : 0 < P) (hPQ : P вЙ§ Q) (ќ± : вДЭ)
    (hќ± : ќ± вИИ Set.Ioc (0:вДЭ) 1 \ MajorArcs P Q) :
    вИГ (a : вД§) (q : вДХ), P < q вИІ q вЙ§ Q вИІ Int.gcd a q = 1 вИІ
      |ќ± - a / q| вЙ§ 1 / (q : вДЭ) ^ 2 := by
  obtain вЯ®_, hnotвЯ© := hќ±
  rcases arc_dichotomy ќ± P Q hP hPQ with вЯ®a, q, hq0, hqP, _, hnearвЯ© | h
  ¬Ј exfalso
    apply hnot
    refine Set.mem_biUnion вЯ®hq0, hqPвЯ© ?_
    refine Set.mem_iUnion.mpr вЯ®a, ?_вЯ©
    rw [Metric.mem_closedBall, Real.dist_eq]
    exact hnear
  ¬Ј exact h

/-- **Minor-arc anchor is a coprime natural**: the Dirichlet anchor `a : вД§` of a point
    `ќ± вИИ (0,1]` with `|ќ± вИТ a/q| вЙ§ 1/q¬≤`, `gcd(a,q)=1`, `q вЙ• 2` is in fact a positive
    integer, so `a.toNat` is a coprime-to-`q` natural with the same approximation вАФ the
    exact `(a q : вДХ)` input `MinSum.vinogradov_sup_tight2` demands (its bound depends only
    on `q`, `U`, `V`, `N`, never on `a`). -/
lemma minor_anchor_nat (ќ± : вДЭ) (a : вД§) (q : вДХ) (hq2 : 2 вЙ§ q) (hpos : 0 < ќ±)
    (hgcd : Int.gcd a q = 1) (hsq : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) :
    Nat.Coprime a.toNat q вИІ |ќ± - (a.toNat : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2 := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by
    have : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq2
    linarith
  have hqne : (q : вДЭ) вЙ† 0 := ne_of_gt hqR
  have hane : a вЙ† 0 := by
    rintro rfl
    simp at hgcd
    omega
  have ha1 : 1 вЙ§ a := by
    rcases lt_or_ge a 1 with h | h
    ¬Ј exfalso
      have hcast : (a : вДЭ) вЙ§ -1 := by exact_mod_cast (by omega : a вЙ§ -1)
      have hq2R : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq2
      have habs := abs_le.mp hsq
      have hm := mul_le_mul_of_nonneg_right habs.2 (sq_nonneg (q : вДЭ))
      rw [one_div_mul_cancel (show (q : вДЭ) ^ 2 вЙ† 0 by positivity)] at hm
      have hlhs : (ќ± - (a : вДЭ) / q) * (q : вДЭ) ^ 2 = ќ± * (q : вДЭ) ^ 2 - (a : вДЭ) * q := by
        field_simp
      rw [hlhs] at hm
      nlinarith [hm, mul_le_mul_of_nonneg_right hcast (le_of_lt hqR),
        mul_pos hpos (by positivity : (0 : вДЭ) < (q : вДЭ) ^ 2), hq2R]
    ¬Ј exact h
  have hcop : Nat.Coprime a.toNat q := by
    have h1 : a.toNat = a.natAbs := by omega
    have h2 : Int.gcd a (q : вД§) = a.natAbs.gcd q := by simp [Int.gcd]
    unfold Nat.Coprime
    rw [h1]
    omega
  refine вЯ®hcop, ?_вЯ©
  have hcast2 : (a.toNat : вДЭ) = (a : вДЭ) := by
    have : ((a.toNat : вД§) : вДЭ) = (a : вДЭ) := by rw [Int.toNat_of_nonneg (by omega)]
    exact_mod_cast this
  rw [hcast2]
  exact hsq

open ArithmeticFunction
open scoped ArithmeticFunction

/-- The explicit RHS of `MinSum.vinogradov_sup_tight2` (the tight minor-arc sup bound),
    packaged as a function of `(q, U, V, N)` вАФ the bound depends on the anchor only through
    its denominator `q`. Written verbatim so the cross-file `vinogradov_sup_tight2` axiom
    below is `rfl`-dischargeable by the real theorem at Phase-F concatenation. -/
noncomputable def tightSupRHS (q U V N : вДХ) : вДЭ :=
  2 * Real.log (N + 1) *
      (((2 * (N : вДЭ) / q) * (1 + Real.log U)
        + ((U / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) + U)
    + Real.log (U * V) *
      ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
        + ((U * V / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))))
    + (V : вДЭ) * Real.log V
    + Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
        + Real.sqrt 32 * N
            * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ) / Real.sqrt q
        + 64 * N * Real.sqrt (1 + Real.log (2 * q)) / Real.sqrt U
        + 6 * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
            * Real.sqrt (N * q * (1 + Real.log (2 * q))))


/-- **Minor-arc uniform sup**: given a `Csup` dominating `tightSupRHS q U V N` for every
    minor modulus `P < q вЙ§ Q` (the envelope bound вАФ the remaining analytic step), the
    exponential sum is `вЙ§ Csup` uniformly on `(0,1] \ MajorArcs P Q`. Combines the arc
    decomposition, the `minor_anchor_nat` bridge, and `vinogradov_sup_tight2`. This is the
    exact `hsup` input to `minor_arc_variance_piece`. -/
lemma minor_sup_uniform (N P Q U V : вДХ) (hP : 0 < P) (hPQ : P вЙ§ Q)
    (hU : U вЙ§ N) (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) (Csup : вДЭ)
    (henv : вИА q, P < q вЖТ q вЙ§ Q вЖТ tightSupRHS q U V N вЙ§ Csup) :
    вИА ќ± вИИ Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q,
      вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ Csup := by
  intro ќ± hќ±
  obtain вЯ®a, q, hPq, hqQ, hgcd, hsqвЯ© := minorSet_property P Q hP hPQ ќ± hќ±
  have hq2 : 2 вЙ§ q := by omega
  have hpos : (0 : вДЭ) < ќ± := hќ±.1.1
  obtain вЯ®hcop, hanchorвЯ© := minor_anchor_nat ќ± a q hq2 hpos hgcd hsq
  have hb := vinogradov_sup_tight2 a.toNat q hq2 hcop ќ± hanchor U V N hU hUV hUV1
  exact le_trans hb (henv q hPq hqQ)

/-- Envelope helper: the Type-I block factor `(U/вМКq/2вМЛ+1)¬Ј(4q(2+log 2q))` telescopes
    (the `q` cancels the `1/(q/2)`) to `вЙ§ (16U+4Q)(2+log 2Q)`, uniform for `2 вЙ§ q вЙ§ Q`. -/
lemma env_natdiv_bound (U q Q : вДХ) (hq2 : 2 вЙ§ q) (hqQ : q вЙ§ Q) :
    ((U / (q / 2) + 1 : вДХ) : вДЭ) * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))
      вЙ§ (16 * U + 4 * Q) * (2 + Real.log (2 * Q)) := by
  have hqRle : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq2
  have hqR : (0 : вДЭ) < (q : вДЭ) := by linarith
  have hQ2 : 2 вЙ§ Q := le_trans hq2 hqQ
  have hQRle : (2 : вДЭ) вЙ§ (Q : вДЭ) := by exact_mod_cast hQ2
  have hqQR : (q : вДЭ) вЙ§ (Q : вДЭ) := by exact_mod_cast hqQ
  have hlogq0 : (0 : вДЭ) вЙ§ Real.log (2 * q) := Real.log_nonneg (by linarith)
  have hlogmono : Real.log (2 * (q : вДЭ)) вЙ§ Real.log (2 * (Q : вДЭ)) :=
    Real.log_le_log (by linarith) (by linarith)
  have hnd : ((U / (q / 2) : вДХ) : вДЭ) вЙ§ 4 * (U : вДЭ) / q := by
    have h2 : q вЙ§ 4 * (q / 2) := by omega
    have h1 : (U / (q / 2)) * (q / 2) вЙ§ U := Nat.div_mul_le_self _ _
    have hnat : q * (U / (q / 2)) вЙ§ 4 * U := by
      calc q * (U / (q / 2)) вЙ§ 4 * (q / 2) * (U / (q / 2)) := Nat.mul_le_mul_right _ h2
        _ = 4 * ((U / (q / 2)) * (q / 2)) := by ring
        _ вЙ§ 4 * U := Nat.mul_le_mul_left _ h1
    rw [le_div_iffвВА hqR]
    calc ((U / (q / 2) : вДХ) : вДЭ) * q = ((q * (U / (q / 2)) : вДХ) : вДЭ) := by push_cast; ring
      _ вЙ§ ((4 * U : вДХ) : вДЭ) := by exact_mod_cast hnat
      _ = 4 * U := by push_cast; ring
  have hfac : (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))
      = 4 * q * (2 + Real.log (2 * q)) := by ring
  rw [hfac]
  have hcast : ((U / (q / 2) + 1 : вДХ) : вДЭ) = ((U / (q / 2) : вДХ) : вДЭ) + 1 := by push_cast; ring
  rw [hcast]
  have hLog2q : (0 : вДЭ) вЙ§ 2 + Real.log (2 * q) := by linarith
  calc (((U / (q / 2) : вДХ) : вДЭ) + 1) * (4 * q * (2 + Real.log (2 * q)))
      вЙ§ (4 * U / q + 1) * (4 * q * (2 + Real.log (2 * q))) := by
        apply mul_le_mul_of_nonneg_right (by linarith [hnd]) (by positivity)
    _ = (16 * U + 4 * q) * (2 + Real.log (2 * q)) := by field_simp; ring
    _ вЙ§ (16 * U + 4 * Q) * (2 + Real.log (2 * Q)) := by
        apply mul_le_mul (by linarith) (by linarith) hLog2q (by positivity)

/-- **The envelope bound** (`henv` for `minor_sup_uniform`): the tight sup RHS is
    dominated, uniformly for `P < q вЙ§ Q`, by an explicit `Csup` in `N,U,V,P,Q` вАФ the
    `q`-decreasing terms bounded via `q вЙ• P`, the `q`-increasing via `q вЙ§ Q`, and the
    Type-I block factors telescoped by `env_natdiv_bound`. This discharges the `henv`
    hypothesis of `minor_sup_uniform` for the canonical `Csup`. -/
lemma tightSupRHS_le (N U V P Q q : вДХ)
    (hN1 : 1 вЙ§ N) (hP1 : 1 вЙ§ P) (hU1 : 1 вЙ§ U) (hV1 : 1 вЙ§ V)
    (hPq : P < q) (hqQ : q вЙ§ Q) :
    tightSupRHS q U V N вЙ§
      2 * Real.log (N + 1) * ((2 * (N : вДЭ) / P) * (1 + Real.log U)
          + (16 * U + 4 * Q) * (2 + Real.log (2 * Q)) + U)
      + Real.log (U * V) * ((2 * (N : вДЭ) / P) * (1 + Real.log (U * V))
          + (16 * (U * V) + 4 * Q) * (2 + Real.log (2 * Q)))
      + (V : вДЭ) * Real.log V
      + Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
          + Real.sqrt 32 * N * ((Nat.log 2 N + 1 : вДХ) : вДЭ) / Real.sqrt P
          + 64 * N * Real.sqrt (1 + Real.log (2 * Q)) / Real.sqrt U
          + 6 * ((Nat.log 2 N + 1 : вДХ) : вДЭ) * Real.sqrt (N * Q * (1 + Real.log (2 * Q)))) := by
  have hq2 : 2 вЙ§ q := by omega
  have hqRle : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq2
  have hPR : (0 : вДЭ) < (P : вДЭ) := by exact_mod_cast hP1
  have hqR : (0 : вДЭ) < (q : вДЭ) := by linarith
  have hQ2 : 2 вЙ§ Q := le_trans hq2 hqQ
  have hQRle : (2 : вДЭ) вЙ§ (Q : вДЭ) := by exact_mod_cast hQ2
  have hPqR : (P : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast le_of_lt hPq
  have hqQR : (q : вДЭ) вЙ§ (Q : вДЭ) := by exact_mod_cast hqQ
  have hUV1 : 1 вЙ§ U * V := Nat.one_le_iff_ne_zero.mpr (by positivity)
  have hlogU0 : (0 : вДЭ) вЙ§ Real.log U := Real.log_nonneg (by exact_mod_cast hU1)
  have hlogUV0 : (0 : вДЭ) вЙ§ Real.log (U * V) := Real.log_nonneg (by exact_mod_cast hUV1)
  have hlogN0 : (0 : вДЭ) вЙ§ Real.log N := Real.log_nonneg (by exact_mod_cast hN1)
  have hlogN10 : (0 : вДЭ) вЙ§ Real.log (вЖСN + 1) := Real.log_nonneg (by
    have : (1 : вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast hN1
    linarith)
  have hlogmono : Real.log (2 * (q : вДЭ)) вЙ§ Real.log (2 * (Q : вДЭ)) :=
    Real.log_le_log (by linarith) (by linarith)
  have hlog2q0 : (0 : вДЭ) вЙ§ Real.log (2 * (q : вДЭ)) := Real.log_nonneg (by linarith)
  have hk : ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
      вЙ§ ((Nat.log 2 N + 1 : вДХ) : вДЭ) := by
    have h := Nat.log_mono_right (b := 2) (Nat.div_le_self N (V + 1))
    exact_mod_cast (by omega :
      Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 вЙ§ Nat.log 2 N + 1)
  have h2NqP : (2 * (N : вДЭ) / q) вЙ§ (2 * (N : вДЭ) / P) := by
    gcongr
  unfold tightSupRHS
  have hB1 : 2 * Real.log (вЖСN + 1) *
        (((2 * (N : вДЭ) / q) * (1 + Real.log U)
          + ((U / (q / 2) + 1 : вДХ) : вДЭ) * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))))
          + U)
      вЙ§ 2 * Real.log (вЖСN + 1) * ((2 * (N : вДЭ) / P) * (1 + Real.log U)
          + (16 * U + 4 * Q) * (2 + Real.log (2 * Q)) + U) := by
    apply mul_le_mul_of_nonneg_left _ (by linarith [hlogN10])
    refine add_le_add (add_le_add ?_ (env_natdiv_bound U q Q hq2 hqQ)) (le_refl _)
    exact mul_le_mul_of_nonneg_right h2NqP (by linarith [hlogU0])
  have hB2 : Real.log (вЖСU * вЖСV) *
        ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
          + ((U * V / (q / 2) + 1 : вДХ) : вДЭ) * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))))
      вЙ§ Real.log (вЖСU * вЖСV) * ((2 * (N : вДЭ) / P) * (1 + Real.log (U * V))
          + (16 * (U * V) + 4 * Q) * (2 + Real.log (2 * Q))) := by
    apply mul_le_mul_of_nonneg_left _ hlogUV0
    have henv2 := env_natdiv_bound (U * V) q Q hq2 hqQ
    rw [Nat.cast_mul] at henv2
    refine add_le_add ?_ henv2
    exact mul_le_mul_of_nonneg_right h2NqP (by linarith [hlogUV0])
  have hB4 : Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
        + Real.sqrt 32 * N * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
            / Real.sqrt q
        + 64 * N * Real.sqrt (1 + Real.log (2 * q)) / Real.sqrt U
        + 6 * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
            * Real.sqrt (N * q * (1 + Real.log (2 * q))))
      вЙ§ Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
          + Real.sqrt 32 * N * ((Nat.log 2 N + 1 : вДХ) : вДЭ) / Real.sqrt P
          + 64 * N * Real.sqrt (1 + Real.log (2 * Q)) / Real.sqrt U
          + 6 * ((Nat.log 2 N + 1 : вДХ) : вДЭ) * Real.sqrt (N * Q * (1 + Real.log (2 * Q)))) := by
    apply mul_le_mul_of_nonneg_left _ hlogN0
    gcongr <;>
      first
      | exact hk
      | exact hPqR
      | exact hqQR
      | exact hqRle
      | exact Real.sqrt_nonneg _
      | exact Real.sqrt_pos.mpr hPR
      | positivity
      | linarith [hlogmono]
      | linarith [hlog2q0]
  linarith [hB1, hB2, hB4]


/-- **D5 вАФ the minor-arc LвБі variance bound**: the mean-square of `S(ќ±)¬≤ вИТ (model)` over the
    minor arcs `(0,1] \ MajorArcs P Q` is `вЙ§ 2¬ЈCsup¬≤¬ЈвИСќЫ(n)¬≤ + 2¬ЈвИСвАЦc(n)вАЦ¬≤`, with the concrete
    `Csup = minorCsup N U V P Q`. Composes `minor_sup_uniform` (uniform sup via the anchor
    bridge + `vinogradov_sup_tight2`) discharged by `tightSupRHS_le` (envelope) into
    `minor_arc_variance_piece`. The remaining smallness (`Csup¬≤¬ЈвИСќЫ¬≤ вЙ§ ќµN¬≥` for `U=V~N^{2/5}`,
    `P=(log N)^B`, `Q=N/P`, `BвЙ•20`) is one numeric instantiation at `hvar` closure. -/
lemma minor_variance_bound (N M P Q U V : вДХ) (hP1 : 1 вЙ§ P) (hPQ : P вЙ§ Q)
    (hN1 : 1 вЙ§ N) (hU1 : 1 вЙ§ U) (hV1 : 1 вЙ§ V) (hU : U вЙ§ N) (hUV : U * V вЙ§ N) (c : вДХ вЖТ вДВ) :
    вИЂ ќ± in (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q),
        вАЦ(вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2
          - вИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ 2 * (minorCsup N U V P Q ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2)
        + 2 * вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
  have hUV1 : 1 вЙ§ U * V := Nat.one_le_iff_ne_zero.mpr (by positivity)
  have hsup : вИА ќ± вИИ Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q,
      вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ minorCsup N U V P Q :=
    minor_sup_uniform N P Q U V (by omega) hPQ hU hUV hUV1 (minorCsup N U V P Q)
      (fun q hPq hqQ => tightSupRHS_le N U V P Q q hN1 hP1 hU1 hV1 hPq hqQ)
  exact minor_arc_variance_piece N M (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q)
    (measurableSet_Ioc.diff (measurableSet_majorArcs P Q)) Set.diff_subset c
    (minorCsup N U V P Q) hsup

/-- **D5 minor LвБі, packaged for the variance assembly**: `вИЂ_{minor} вАЦSвАЦвБі вЙ§ minorCsup¬≤¬ЈвИСќЫ¬≤`
    with the concrete `minorCsup` вАФ the pure-LвБі form (no model subtraction) that feeds the
    first term of `variance_le_bessel`. Composes `minor_arc_L4_bound` with the uniform sup. -/
lemma minor_L4_tight (N P Q U V : вДХ) (hP1 : 1 вЙ§ P) (hPQ : P вЙ§ Q)
    (hN1 : 1 вЙ§ N) (hU1 : 1 вЙ§ U) (hV1 : 1 вЙ§ V) (hU : U вЙ§ N) (hUV : U * V вЙ§ N) :
    вИЂ ќ± in (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q),
        вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ ^ 4
      вЙ§ minorCsup N U V P Q ^ 2 * вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
  have hUV1 : 1 вЙ§ U * V := Nat.one_le_iff_ne_zero.mpr (by positivity)
  have hsup : вИА ќ± вИИ Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q,
      вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ minorCsup N U V P Q :=
    minor_sup_uniform N P Q U V (by omega) hPQ hU hUV hUV1 (minorCsup N U V P Q)
      (fun q hPq hqQ => tightSupRHS_le N U V P Q q hN1 hP1 hU1 hV1 hPq hqQ)
  exact minor_arc_L4_bound N (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q)
    (measurableSet_Ioc.diff (measurableSet_majorArcs P Q)) Set.diff_subset
    (minorCsup N U V P Q) hsup

/-- **D5 minor LвБі in `range N` form** (the shape `variance_le_bessel` / the major-arc chain
    use): `вИЂ_{minor} вАЦ(вИС_{k<N} ќЫ(k)e(kќ±))¬≤вАЦ¬≤ вЙ§ (minorCsup + log N)¬≤¬ЈвИС_{k<N} ќЫ(k)¬≤`. Bridges
    `вИС_{range N} = вИС_{Ioc 0 N} вИТ ќЫ(N)e(Nќ±)` (so the range-sup is `minorCsup + ќЫ(N) вЙ§
    minorCsup + log N`), then applies the general `L4_set_bound`. -/
lemma minor_L4_range (N P Q U V : вДХ) (hP1 : 1 вЙ§ P) (hPQ : P вЙ§ Q)
    (hN1 : 1 вЙ§ N) (hU1 : 1 вЙ§ U) (hV1 : 1 вЙ§ V) (hU : U вЙ§ N) (hUV : U * V вЙ§ N) :
    вИЂ ќ± in (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q),
        вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2
      вЙ§ (minorCsup N U V P Q + Real.log N) ^ 2 * вИС n вИИ Finset.range N, ќЫ n ^ 2 := by
  have hUV1 : 1 вЙ§ U * V := Nat.one_le_iff_ne_zero.mpr (by positivity)
  set f : вДЭ вЖТ вДХ вЖТ вДВ := fun ќ± n => ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±) with hf
  have hbridge : вИА ќ± : вДЭ, вИС n вИИ Finset.range N, f ќ± n
      = (вИС n вИИ Finset.Ioc 0 N, f ќ± n) - f ќ± N := by
    intro ќ±
    have hins : Finset.range (N + 1) = insert 0 (Finset.Ioc 0 N) := by
      ext k; simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Ioc]; omega
    have hf0 : f ќ± 0 = 0 := by
      simp only [hf, ArithmeticFunction.map_zero, Complex.ofReal_zero, zero_mul]
    have e1 : вИС n вИИ Finset.Ioc 0 N, f ќ± n = вИС n вИИ Finset.range (N + 1), f ќ± n := by
      rw [hins, Finset.sum_insert (by simp), hf0, zero_add]
    have e2 : вИС n вИИ Finset.range (N + 1), f ќ± n = вИС n вИИ Finset.range N, f ќ± n + f ќ± N :=
      Finset.sum_range_succ (f ќ±) N
    rw [e1, e2]; ring
  have hsup : вИА ќ± вИИ Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q,
      вАЦвИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ вЙ§ minorCsup N U V P Q + Real.log N := by
    intro ќ± hќ±
    have h1 := minor_sup_uniform N P Q U V (by omega) hPQ hU hUV hUV1 (minorCsup N U V P Q)
      (fun q hPq hqQ => tightSupRHS_le N U V P Q q hN1 hP1 hU1 hV1 hPq hqQ) ќ± hќ±
    have hfN : вАЦf ќ± NвАЦ вЙ§ Real.log N := by
      rw [hf, norm_mul, e_norm, mul_one, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg vonMangoldt_nonneg]
      exact ArithmeticFunction.vonMangoldt_le_log
    calc вАЦвИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
        = вАЦ(вИС n вИИ Finset.Ioc 0 N, f ќ± n) - f ќ± NвАЦ := by rw [hbridge ќ±]
      _ вЙ§ вАЦвИС n вИИ Finset.Ioc 0 N, f ќ± nвАЦ + вАЦf ќ± NвАЦ := norm_sub_le _ _
      _ вЙ§ minorCsup N U V P Q + Real.log N := by
          have := h1
          rw [show (вИС n вИИ Finset.Ioc 0 N, f ќ± n) = вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±) from rfl] at *
          linarith [hfN, h1]
  have hL4 := L4_set_bound (fun n => ((ќЫ n : вДЭ) : вДВ)) N (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q)
    (measurableSet_Ioc.diff (measurableSet_majorArcs P Q)) Set.diff_subset
    (minorCsup N U V P Q + Real.log N) hsup
  have hnorm : вИА n : вДХ, вАЦ((ќЫ n : вДЭ) : вДВ)вАЦ ^ 2 = ќЫ n ^ 2 := by
    intro n
    rw [Complex.norm_real, Real.norm_eq_abs, sq_abs]
  calc вИЂ ќ± in (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q),
        вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2
      вЙ§ (minorCsup N U V P Q + Real.log N) ^ 2 * вИС n вИИ Finset.range N, вАЦ((ќЫ n : вДЭ) : вДВ)вАЦ ^ 2 :=
        hL4
    _ = (minorCsup N U V P Q + Real.log N) ^ 2 * вИС n вИИ Finset.range N, ќЫ n ^ 2 := by
        rw [Finset.sum_congr rfl (fun n _ => hnorm n)]


/-- `вИС_{n<N} ќЫ(n)¬≤ вЙ§ N¬Ј(log N)¬≤` (range form, from the banked `sum_vonMangoldt_sq_le`). -/
lemma sum_vonMangoldt_sq_range_le (N : вДХ) :
    вИС n вИИ Finset.range N, ќЫ n ^ 2 вЙ§ (N : вДЭ) * Real.log N ^ 2 := by
  calc вИС n вИИ Finset.range N, ќЫ n ^ 2
      вЙ§ вИС n вИИ Finset.range (N + 1), ќЫ n ^ 2 := by
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro x hx; simp only [Finset.mem_range] at hx вКҐ; omega
        ¬Ј intro n _ _; exact sq_nonneg _
    _ = вИС n вИИ Finset.Ioc 0 N, ќЫ n ^ 2 := by
        rw [show Finset.range (N + 1) = insert 0 (Finset.Ioc 0 N) from by
          ext k; simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Ioc]; omega,
          Finset.sum_insert (by simp)]
        simp [ArithmeticFunction.map_zero]
    _ вЙ§ (N : вДЭ) * Real.log N ^ 2 := sum_vonMangoldt_sq_le N

/-- `minorCsup` is nonnegative (each of its four groups is a product/sum of nonneg factors,
    the logs being `вЙ• 0` since their arguments are `вЙ• 1`). -/
lemma minorCsup_nonneg (N P Q : вДХ) (hP2 : 2 вЙ§ P) (hN1 : 1 вЙ§ N) (hQ1 : 1 вЙ§ Q) :
    0 вЙ§ minorCsup N P P P Q := by
  have hPR : (1 : вДЭ) вЙ§ (P : вДЭ) := by exact_mod_cast (show 1 вЙ§ P by omega)
  have hQR : (1 : вДЭ) вЙ§ (Q : вДЭ) := by exact_mod_cast hQ1
  have hNR : (1 : вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast hN1
  have hlogP : (0 : вДЭ) вЙ§ Real.log P := Real.log_nonneg hPR
  have hlogN : (0 : вДЭ) вЙ§ Real.log N := Real.log_nonneg hNR
  have hlogN1 : (0 : вДЭ) вЙ§ Real.log (вЖСN + 1) := Real.log_nonneg (by linarith)
  have hlogPP : (0 : вДЭ) вЙ§ Real.log (вЖСP * вЖСP) := Real.log_nonneg (by nlinarith [hPR])
  have hlog2Q : (0 : вДЭ) вЙ§ Real.log (2 * вЖСQ) := Real.log_nonneg (by linarith)
  unfold minorCsup
  have hb1 : (0 : вДЭ) вЙ§ 2 * Real.log (вЖСN + 1) *
      ((2 * вЖСN / вЖСP) * (1 + Real.log вЖСP) + (16 * вЖСP + 4 * вЖСQ) * (2 + Real.log (2 * вЖСQ)) + вЖСP) := by
    apply mul_nonneg (by linarith)
    apply add_nonneg (add_nonneg (mul_nonneg (by positivity) (by linarith))
      (mul_nonneg (by positivity) (by linarith))) (by positivity)
  have hb2 : (0 : вДЭ) вЙ§ Real.log (вЖСP * вЖСP) *
      ((2 * вЖСN / вЖСP) * (1 + Real.log (вЖСP * вЖСP))
        + (16 * (вЖСP * вЖСP) + 4 * вЖСQ) * (2 + Real.log (2 * вЖСQ))) := by
    apply mul_nonneg hlogPP
    apply add_nonneg (mul_nonneg (by positivity) (by linarith))
      (mul_nonneg (by positivity) (by linarith))
  have hb3 : (0 : вДЭ) вЙ§ (вЖСP : вДЭ) * Real.log вЖСP := mul_nonneg (by positivity) hlogP
  have hb4 : (0 : вДЭ) вЙ§ Real.log вЖСN *
      (4 * Real.sqrt 10 * вЖСN / Real.sqrt (вЖСP + 1)
        + Real.sqrt 32 * вЖСN * ((Nat.log 2 N + 1 : вДХ) : вДЭ) / Real.sqrt вЖСP
        + 64 * вЖСN * Real.sqrt (1 + Real.log (2 * вЖСQ)) / Real.sqrt вЖСP
        + 6 * ((Nat.log 2 N + 1 : вДХ) : вДЭ) * Real.sqrt (вЖСN * вЖСQ * (1 + Real.log (2 * вЖСQ)))) := by
    apply mul_nonneg hlogN
    positivity
  linarith [hb1, hb2, hb3, hb4]

/-- **D5 minor LвБі explicit bound** (combining the banked pieces): with `U=V=P`, `PвЙ•2`,
    `P¬≥вЙ§N`, `PвЙ§Q`, `P¬ЈQвЙ§N`, the minor LвБі integral is `вЙ§ (300¬ЈN¬Ј(log N+2)¬≥/вИЪP + log N)¬≤¬ЈN¬Ј(log N)¬≤`.
    Feeds the minor-arc smallness once `P = (log N)^B`. -/
lemma minor_L4_le_explicit (N P Q : вДХ) (hP2 : 2 вЙ§ P) (hPN : P ^ 3 вЙ§ N) (hPQcut : P вЙ§ Q)
    (hPQ : P * Q вЙ§ N) (hN1 : 1 вЙ§ N) (hQ1 : 1 вЙ§ Q) :
    вИЂ ќ± in (Set.Ioc (0 : вДЭ) 1 \ MajorArcs P Q),
        вАЦ(вИС n вИИ Finset.range N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)) ^ 2вАЦ ^ 2
      вЙ§ (300 * (N : вДЭ) * (Real.log N + 2) ^ 3 / Real.sqrt P + Real.log N) ^ 2
          * ((N : вДЭ) * Real.log N ^ 2) := by
  have hP1 : 1 вЙ§ P := by omega
  have hPleN : P вЙ§ N := le_trans (Nat.le_self_pow (by norm_num) P) hPN
  have hPP : P * P вЙ§ N :=
    le_trans (by rw [вЖР pow_two]; exact Nat.pow_le_pow_right hP1 (by norm_num)) hPN
  have hL4 := minor_L4_range N P Q P P hP1 hPQcut hN1 hP1 hP1 hPleN hPP
  have hcsup := minorCsup_bound N P Q hP2 hPN hPQ
  have hcsup0 := minorCsup_nonneg N P Q hP2 hN1 hQ1
  have hsumL := sum_vonMangoldt_sq_range_le N
  have hlogN0 : (0 : вДЭ) вЙ§ Real.log N := Real.log_nonneg (by exact_mod_cast hN1)
  have hsq0 : (0 : вДЭ) вЙ§ вИС n вИИ Finset.range N, ќЫ n ^ 2 := Finset.sum_nonneg (fun _ _ => sq_nonneg _)
  refine le_trans hL4 ?_
  apply mul_le_mul _ hsumL hsq0 (by positivity)
  apply pow_le_pow_leftвВА (by linarith) (by linarith) 2

/-- **Brick (a): minor-arc smallness limit.** With `P = вМК(log N)^9вМЛвВК`, twice the explicit
    minor-LвБі bound `2¬Ј(300 N (logN+2)¬≥/вИЪP + logN)¬≤¬ЈN (logN)¬≤` is `вЙ§ ќµ N¬≥` for all large `N`.
    Route (rpow-free): split into `46080000 N¬≥/L + 4 N LвБі` (L = log N); the first `вЙ§ ќµN¬≥/2`
    once `L вЙ• 92160000/ќµ`, the second `вЙ§ ќµN¬≥/2` once `N вЙ• 32768/ќµ` (via `LвБі вЙ§ 4096вИЪN вЙ§ 4096N`,
    the nested-`вИЪ` log bound `log N вЙ§ 8¬ЈвИЪвИЪвИЪN`). Feeds the variance assembly's minor term. -/
lemma minor_limit (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
      2 * (300 * (N : вДЭ) * (Real.log N + 2) ^ 3 / Real.sqrt (Nat.floor ((Real.log N) ^ 9)) + Real.log N) ^ 2
          * ((N : вДЭ) * Real.log N ^ 2) вЙ§ ќµ * (N : вДЭ) ^ 3 := by
  refine вЯ®max 8 (max (Nat.ceil (Real.exp (92160000 / ќµ))) (Nat.ceil (32768 / ќµ))), fun N hN => ?_вЯ©
  have hN8 : 8 вЙ§ N := le_trans (le_max_left _ _) hN
  have hNexp : Real.exp (92160000 / ќµ) вЙ§ N :=
    le_trans (Nat.le_ceil _) (by exact_mod_cast le_trans (le_max_left _ _) (le_trans (le_max_right _ _) hN))
  have hN32 : (32768 / ќµ) вЙ§ N :=
    le_trans (Nat.le_ceil _) (by exact_mod_cast le_trans (le_max_right _ _) (le_trans (le_max_right _ _) hN))
  have hNR : (8 : вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast hN8
  have hNpos : (0 : вДЭ) < (N : вДЭ) := by linarith
  set L : вДЭ := Real.log N with hLdef
  have hL2 : (2 : вДЭ) вЙ§ L := by
    rw [hLdef]
    calc (2 : вДЭ) вЙ§ Real.log 8 := by
          rw [show (8:вДЭ) = 2^3 by norm_num, Real.log_pow]
          have h2 : (0.6931 : вДЭ) вЙ§ Real.log 2 := by have := Real.log_two_gt_d9; linarith
          push_cast; linarith
      _ вЙ§ Real.log N := Real.log_le_log (by norm_num) hNR
  have hLpos : (0 : вДЭ) < L := by linarith
  have hLne : L вЙ† 0 := ne_of_gt hLpos
  have hLA0 : (0 : вДЭ) вЙ§ L := le_of_lt hLpos
  set P : вДХ := Nat.floor (L ^ 9) with hPdef
  have hL9pos : (0 : вДЭ) < L ^ 9 := by positivity
  have hL9ge2 : (2 : вДЭ) вЙ§ L ^ 9 := by
    have hLL9 : L вЙ§ L ^ 9 := by
      calc L = L ^ 1 := (pow_one L).symm
        _ вЙ§ L ^ 9 := pow_le_pow_rightвВА (by linarith : (1:вДЭ) вЙ§ L) (by norm_num)
    linarith
  have hPR : (L ^ 9 / 2) вЙ§ (P : вДЭ) := by
    have h := Nat.sub_one_lt_floor (L ^ 9)
    rw [вЖР hPdef] at h
    have h2 : L ^ 9 - 1 вЙ§ (P : вДЭ) := le_of_lt h
    linarith
  have hPpos : (0 : вДЭ) < (P : вДЭ) := by
    have : (0:вДЭ) < L ^ 9 / 2 := by positivity
    linarith
  set sP : вДЭ := Real.sqrt (P : вДЭ) with hsPdef
  have hsPpos : (0 : вДЭ) < sP := Real.sqrt_pos.mpr hPpos
  have hsPsq : sP ^ 2 = (P : вДЭ) := Real.sq_sqrt (le_of_lt hPpos)
  set A : вДЭ := 300 * (N : вДЭ) * (L + 2) ^ 3 with hAdef
  have hA0 : (0 : вДЭ) вЙ§ A := by rw [hAdef]; positivity
  have hL2p0 : (0:вДЭ) вЙ§ L + 2 := by linarith
  have hL2p : (L + 2) вЙ§ 2 * L := by linarith
  have hL26 : (L + 2) ^ 6 вЙ§ 64 * L ^ 6 := by
    calc (L + 2) ^ 6 вЙ§ (2 * L) ^ 6 := pow_le_pow_leftвВА hL2p0 hL2p 6
      _ = 64 * L ^ 6 := by ring
  have hA2val : A ^ 2 = 90000 * (N:вДЭ) ^ 2 * (L + 2) ^ 6 := by rw [hAdef]; ring
  have hAsP : (A / sP) ^ 2 = A ^ 2 / (P : вДЭ) := by rw [div_pow, hsPsq]
  have hTsq : (A / sP + L) ^ 2 вЙ§ 2 * (A ^ 2 / (P : вДЭ)) + 2 * L ^ 2 := by
    nlinarith [sq_nonneg (A / sP - L), hAsP]
  have hL3pos : (0:вДЭ) < L ^ 3 := by positivity
  have hfirst : 2 * (A ^ 2 / (P : вДЭ)) вЙ§ 23040000 * (N:вДЭ)^2 / L ^ 3 := by
    rw [show 2 * (A^2/(P:вДЭ)) = 2*A^2/(P:вДЭ) from by ring, div_le_div_iffвВА hPpos hL3pos, hA2val]
    nlinarith [mul_nonneg (sq_nonneg (N:вДЭ)) (show (0:вДЭ) вЙ§ (P:вДЭ) - L^9/2 from by linarith [hPR]),
               mul_nonneg (mul_nonneg (sq_nonneg (N:вДЭ)) (pow_pos hLpos 3).le)
                          (show (0:вДЭ) вЙ§ 64*L^6 - (L+2)^6 from by linarith [hL26])]
  have hTsq2 : (A / sP + L) ^ 2 вЙ§ 23040000 * (N:вДЭ)^2 / L ^ 3 + 2 * L ^ 2 := by
    linarith [hTsq, hfirst]
  have hmain : 2 * (A / sP + L) ^ 2 * ((N:вДЭ) * L ^ 2)
      вЙ§ 46080000 * (N:вДЭ)^3 / L + 4 * (N:вДЭ) * L ^ 4 := by
    have hfac : 2 * (A / sP + L) ^ 2 * ((N:вДЭ) * L ^ 2)
        вЙ§ 2 * (23040000 * (N:вДЭ)^2 / L ^ 3 + 2 * L ^ 2) * ((N:вДЭ) * L ^ 2) := by
      apply mul_le_mul_of_nonneg_right _ (by positivity)
      apply mul_le_mul_of_nonneg_left hTsq2 (by norm_num)
    have hexp : 2 * (23040000 * (N:вДЭ)^2 / L ^ 3 + 2 * L ^ 2) * ((N:вДЭ) * L ^ 2)
        = 46080000 * (N:вДЭ)^3 / L + 4 * (N:вДЭ) * L ^ 4 := by
      field_simp
      ring
    linarith [hfac, hexp.le, hexp.ge]
  have hpart1 : 46080000 * (N:вДЭ)^3 / L вЙ§ ќµ / 2 * (N:вДЭ)^3 := by
    rw [div_le_iffвВА hLpos]
    have hLbig : 92160000 / ќµ вЙ§ L := by
      rw [hLdef]
      calc 92160000 / ќµ вЙ§ Real.log (Real.exp (92160000 / ќµ)) := by rw [Real.log_exp]
        _ вЙ§ Real.log N := Real.log_le_log (Real.exp_pos _) hNexp
    rw [div_le_iffвВА hќµ] at hLbig
    have hќµL : (92160000 : вДЭ) вЙ§ ќµ * L := by linarith [hLbig]
    nlinarith [mul_nonneg (pow_pos hNpos 3).le (show (0:вДЭ) вЙ§ ќµ*L - 92160000 from by linarith [hќµL])]
  have hpart2 : 4 * (N:вДЭ) * L ^ 4 вЙ§ ќµ / 2 * (N:вДЭ)^3 := by
    set s : вДЭ := Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ))) with hsdef
    have hLs : L вЙ§ 8 * s := by
      rw [hLdef, hsdef]
      have e1 : Real.log (Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ)))) = Real.log N / 8 := by
        rw [Real.log_sqrt (Real.sqrt_nonneg _), Real.log_sqrt (Real.sqrt_nonneg _),
            Real.log_sqrt (le_of_lt hNpos)]; ring
      have h4 : Real.log (Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ))))
          вЙ§ Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ))) - 1 :=
        Real.log_le_sub_one_of_pos (by positivity)
      rw [e1] at h4
      linarith [h4, Real.sqrt_nonneg (Real.sqrt (Real.sqrt (N:вДЭ)))]
    have hL4 : L ^ 4 вЙ§ 4096 * (N:вДЭ) := by
      have hs4 : s ^ 4 = Real.sqrt (N:вДЭ) := by
        rw [hsdef, show (Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ))))^4
              = ((Real.sqrt (Real.sqrt (Real.sqrt (N:вДЭ))))^2)^2 by ring,
            Real.sq_sqrt (Real.sqrt_nonneg _), Real.sq_sqrt (Real.sqrt_nonneg _)]
      have hLpow : L ^ 4 вЙ§ (8 * s) ^ 4 := pow_le_pow_leftвВА hLA0 hLs 4
      have hsqrtN : Real.sqrt (N:вДЭ) вЙ§ (N:вДЭ) := by
        have hle : Real.sqrt (N:вДЭ) вЙ§ Real.sqrt ((N:вДЭ)^2) := Real.sqrt_le_sqrt (by nlinarith [hNR])
        rwa [Real.sqrt_sq (le_of_lt hNpos)] at hle
      calc L ^ 4 вЙ§ (8 * s) ^ 4 := hLpow
        _ = 4096 * s ^ 4 := by ring
        _ = 4096 * Real.sqrt (N:вДЭ) := by rw [hs4]
        _ вЙ§ 4096 * (N:вДЭ) := by linarith [hsqrtN]
    have hќµN : (32768 : вДЭ) вЙ§ ќµ * N := by
      rw [div_le_iffвВА hќµ] at hN32; linarith [hN32]
    nlinarith [mul_nonneg hNpos.le (show (0:вДЭ) вЙ§ 4096*(N:вДЭ) - L^4 from by linarith [hL4]),
               mul_nonneg (sq_nonneg (N:вДЭ)) (show (0:вДЭ) вЙ§ ќµ*(N:вДЭ)/2 - 16384 from by linarith [hќµN])]
  calc 2 * (A / sP + L) ^ 2 * ((N:вДЭ) * L ^ 2)
      вЙ§ 46080000 * (N:вДЭ)^3 / L + 4 * (N:вДЭ) * L ^ 4 := hmain
    _ вЙ§ ќµ / 2 * (N:вДЭ)^3 + ќµ / 2 * (N:вДЭ)^3 := by linarith [hpart1, hpart2]
    _ = ќµ * (N:вДЭ)^3 := by ring

/-- **Farey windows are disjoint**: distinct reduced anchors with moduli `вЙ§ P` have
    disjoint windows once `2P¬≤ < Q+1` вАФ the input for splitting the major-arc integral
    into per-window integrals. -/
lemma farey_disjoint (P Q : вДХ) (hPQ : 2 * P ^ 2 < Q + 1) (a a' : вД§) (q q' : вДХ)
    (hq : 0 < q) (hq' : 0 < q') (hqP : q вЙ§ P) (hq'P : q' вЙ§ P)
    (hga : Int.gcd a q = 1) (hga' : Int.gcd a' q' = 1)
    (hne : ¬ђ (a = a' вИІ q = q')) :
    Disjoint (Metric.closedBall ((a : вДЭ) / q) (1 / (q * (Q + 1))))
      (Metric.closedBall ((a' : вДЭ) / q') (1 / (q' * (Q + 1)))) := by
  have hP0 : 0 < P := lt_of_lt_of_le hq hqP
  have hqR : (0:вДЭ) < q := by exact_mod_cast hq
  have hq'R : (0:вДЭ) < q' := by exact_mod_cast hq'
  have hQ1 : (0:вДЭ) < (Q:вДЭ) + 1 := by positivity
  -- the anchors are distinct rationals: |aq' вИТ a'q| вЙ• 1
  have hnum : a * (q' : вД§) вЙ† a' * (q : вД§) := by
    intro hc
    apply hne
    have hdvd1 : (q : вД§) вИ£ (q' : вД§) := by
      have h1 : (q : вД§) вИ£ a * q' := вЯ®a', by linarith [hc]вЯ©
      have hco : IsCoprime (q : вД§) a := by
        rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_comm]
        exact hga
      exact hco.dvd_of_dvd_mul_left h1
    have hdvd2 : (q' : вД§) вИ£ (q : вД§) := by
      have h1 : (q' : вД§) вИ£ a' * q := вЯ®a, by linarith [hc]вЯ©
      have hco : IsCoprime (q' : вД§) a' := by
        rw [Int.isCoprime_iff_gcd_eq_one, Int.gcd_comm]
        exact hga'
      exact hco.dvd_of_dvd_mul_left h1
    have hqq : (q : вД§) = q' := Int.dvd_antisymm (by exact_mod_cast Int.natCast_nonneg q)
      (by exact_mod_cast Int.natCast_nonneg q') hdvd1 hdvd2
    have hqq' : q = q' := by exact_mod_cast hqq
    refine вЯ®?_, hqq'вЯ©
    subst hqq'
    have := mul_right_cancelвВА (show (q:вД§) вЙ† 0 by exact_mod_cast hq.ne') hc
    exact this
  have hdist : 1 / ((q:вДЭ) * q') вЙ§ dist ((a : вДЭ) / q) ((a' : вДЭ) / q') := by
    rw [Real.dist_eq]
    have hval : (a : вДЭ) / q - (a' : вДЭ) / q' = ((a * q' - a' * q : вД§) : вДЭ) / ((q:вДЭ) * q') := by
      push_cast
      field_simp
    rw [hval, abs_div, abs_of_pos (by positivity : (0:вДЭ) < (q:вДЭ) * q')]
    apply div_le_div_of_nonneg_right _ (by positivity)
    have h1 : (1 : вД§) вЙ§ |a * q' - a' * q| :=
      Int.one_le_abs (sub_ne_zero_of_ne hnum)
    exact_mod_cast (by exact_mod_cast h1 : (1:вДЭ) вЙ§ |((a * q' - a' * q : вД§) : вДЭ)|)
  apply Metric.closedBall_disjoint_closedBall
  calc 1 / ((q:вДЭ) * (Q + 1)) + 1 / ((q':вДЭ) * (Q + 1))
      вЙ§ 1 / ((Q:вДЭ) + 1) + 1 / ((Q:вДЭ) + 1) := by
        have hq1 : (1:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq
        have hq'1 : (1:вДЭ) вЙ§ (q':вДЭ) := by exact_mod_cast hq'
        apply add_le_add
        ¬Ј apply one_div_le_one_div_of_le hQ1
          nlinarith [hq1, hQ1]
        ¬Ј apply one_div_le_one_div_of_le hQ1
          nlinarith [hq'1, hQ1]
    _ = 2 / ((Q:вДЭ) + 1) := by ring
    _ < 1 / ((P:вДЭ) ^ 2) := by
        rw [div_lt_div_iffвВА hQ1 (by positivity)]
        have : (2 * P ^ 2 : вДЭ) < (Q:вДЭ) + 1 := by exact_mod_cast hPQ
        nlinarith [this]
    _ вЙ§ 1 / ((q:вДЭ) * q') := by
        apply one_div_le_one_div_of_le (by positivity)
        have h1 : (q:вДЭ) вЙ§ P := by exact_mod_cast hqP
        have h2 : (q':вДЭ) вЙ§ P := by exact_mod_cast hq'P
        nlinarith [hqR, hq'R]
    _ вЙ§ dist ((a : вДЭ) / q) ((a' : вДЭ) / q') := hdist


/-- **Finite anchor localization**: inside `(0,1]` only anchors with `вИТq вЙ§ a вЙ§ 2q`
    can contribute to the major arcs вАФ the вД§-union collapses to a finite one, enabling
    the per-window splitting of the major-arc integral. -/
lemma majorArcs_inter_Ioc_subset (P Q : вДХ) (hP : 0 < P) :
    MajorArcs P Q вИ© Set.Ioc (0:вДЭ) 1
      вКЖ вЛГ q вИИ Set.Icc 1 P, вЛГ a вИИ Set.Icc (-(q:вД§)) (2 * q),
          Metric.closedBall ((a : вДЭ) / q) (1 / (q * (Q + 1))) := by
  rintro x вЯ®hx, hx01вЯ©
  rw [MajorArcs, Set.mem_iUnionвВВ] at hx
  obtain вЯ®q, hq, hxqвЯ© := hx
  rw [Set.mem_iUnion] at hxq
  obtain вЯ®a, haвЯ© := hxq
  rw [Metric.mem_closedBall, Real.dist_eq] at ha
  obtain вЯ®hq1, hqPвЯ© := hq
  have hqR : (1:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq1
  have hQR : (0:вДЭ) вЙ§ (Q:вДЭ) := Nat.cast_nonneg Q
  have hrad : 1 / ((q:вДЭ) * (Q + 1)) вЙ§ 1 := by
    rw [div_le_one (by nlinarith)]
    nlinarith
  have hx0 : (0:вДЭ) < x := hx01.1
  have hx1 : x вЙ§ 1 := hx01.2
  have hlow : -1 вЙ§ (a : вДЭ) / q := by
    have : (a:вДЭ)/q вЙ• x - 1/((q:вДЭ)*(Q+1)) := by
      have := abs_le.mp ha
      linarith [this.2]
    linarith
  have hhigh : (a : вДЭ) / q вЙ§ 2 := by
    have : (a:вДЭ)/q вЙ§ x + 1/((q:вДЭ)*(Q+1)) := by
      have := abs_le.mp ha
      linarith [this.1]
    linarith
  have hqpos : (0:вДЭ) < (q:вДЭ) := by linarith
  have haZ : -(q:вД§) вЙ§ a вИІ a вЙ§ 2 * q := by
    constructor
    ¬Ј have : -(q:вДЭ) вЙ§ (a:вДЭ) := by
        have := mul_le_mul_of_nonneg_right hlow hqpos.le
        rw [div_mul_cancelвВА _ hqpos.ne'] at this
        linarith
      exact_mod_cast this
    ¬Ј have : (a:вДЭ) вЙ§ 2 * q := by
        have := mul_le_mul_of_nonneg_right hhigh hqpos.le
        rw [div_mul_cancelвВА _ hqpos.ne'] at this
        linarith
      exact_mod_cast this
  rw [Set.mem_iUnionвВВ]
  refine вЯ®q, вЯ®hq1, hqPвЯ©, ?_вЯ©
  rw [Set.mem_iUnionвВВ]
  refine вЯ®a, вЯ®haZ.1, haZ.2вЯ©, ?_вЯ©
  rw [Metric.mem_closedBall, Real.dist_eq]
  exact ha



/-- **Reduced coverage**: inside `(0,1]` the major arcs are covered by the windows of the
    finitely many REDUCED anchors вАФ an unreduced `a/q` equals a reduced `a'/q'` with
    `q' вИ£ q`, whose window is wider. The composition splits over `anchors P` with
    `farey_disjoint` and evaluates each window by `vonMangoldt_window_eval`. -/
lemma majorArcs_subset_reduced (P Q : вДХ) (hP : 0 < P) :
    MajorArcs P Q вИ© Set.Ioc (0:вДЭ) 1
      вКЖ вЛГ pq вИИ anchors P,
          Metric.closedBall (((pq.2 : вД§) : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1))) := by
  rintro x вЯ®hx, hx01вЯ©
  rw [MajorArcs, Set.mem_iUnionвВВ] at hx
  obtain вЯ®q, вЯ®hq1, hqPвЯ©, hxqвЯ© := hx
  rw [Set.mem_iUnion] at hxq
  obtain вЯ®a, haвЯ© := hxq
  rw [Metric.mem_closedBall, Real.dist_eq] at ha
  -- bounds on a as before
  have hqR : (1:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq1
  have hQR : (0:вДЭ) вЙ§ (Q:вДЭ) := Nat.cast_nonneg Q
  have hrad : 1 / ((q:вДЭ) * (Q + 1)) вЙ§ 1 := by
    rw [div_le_one (by nlinarith)]
    nlinarith
  have hx0 : (0:вДЭ) < x := hx01.1
