  have hXgT2 : X ^ (1 + g : вДЭ) / T^2 вЙ§ X * Real.exp (-(u/2)) := by
    rw [hexpX g, hT2, mul_div_assoc, вЖР Real.exp_sub]
    apply mul_le_mul_of_nonneg_left _ hX0.le
    apply Real.exp_le_exp.mpr
    nlinarith [hgLu, hu0]
  have hXgT : X ^ (1 + g : вДЭ) / T вЙ§ X * Real.exp (-(u/2)) := by
    rw [hexpX g, hTdef, mul_div_assoc, вЖР Real.exp_sub]
    apply mul_le_mul_of_nonneg_left _ hX0.le
    apply Real.exp_le_exp.mpr
    nlinarith [hgLu, hu0]
  have hu53 : u ^ ((5:вДЭ)/2) вЙ§ u ^ (3:вДЭ) :=
    Real.rpow_le_rpow_of_exponent_le hu1 (by norm_num)
  -- t2
  have ht2 : 2 * (((1 + g) - (1 - g/2)) * (M * X ^ (1 + g : вДЭ) / T^2))
