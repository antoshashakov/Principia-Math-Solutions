/-- **harc brick B5e: the arc-tail RHS is eventually `вЙ§ ќµN¬≥`** at `P = вМК(log N)вБєвМЛвВК`,
    `Q = N/P`: term 1 is `64N¬≥/вИЪP` (needs `вИЪP вЙ• 128/ќµ`), term 2 is `384N¬Ј(log N)вБµвБі`
    (polylog vs `N¬≤`). -/
lemma arc_tail_rhs_small (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
      (((N / Nat.floor ((Real.log N) ^ 9) : вДХ) : вДЭ) + 1) ^ 3
          * (8 * ((Nat.floor ((Real.log N) ^ 9) : вДХ) : вДЭ) ^ ((5 : вДЭ) / 2))
        + 192 * (((N / Nat.floor ((Real.log N) ^ 9) : вДХ) : вДЭ) + 1)
          * ((Nat.floor ((Real.log N) ^ 9) : вДХ) : вДЭ) ^ 7
      вЙ§ ќµ * (N : вДЭ) ^ 3 := by
  set C : вДЭ := max 2 ((128 / ќµ) ^ 2 + 1) with hCdef
  have hC2 : (2:вДЭ) вЙ§ C := le_max_left _ _
  obtain вЯ®NвВБ, hNвВБвЯ© := polylog_le_self 9 1 (by norm_num)
  obtain вЯ®NвВВ, hNвВВвЯ© := polylog_le_self 54 (768 / ќµ) (by positivity)
  refine вЯ®max (Nat.ceil (Real.exp C) + 1) (max 1 (max NвВБ NвВВ)), fun N hN => ?_вЯ©
  have hNe : Nat.ceil (Real.exp C) + 1 вЙ§ N := le_trans (le_max_left _ _) hN
  have hN1nat : 1 вЙ§ N := le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hN
  have hN1' : NвВБ вЙ§ N :=
    le_trans (le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) (le_max_right _ _)) hN
  have hN2' : NвВВ вЙ§ N :=
    le_trans (le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) (le_max_right _ _)) hN
  have hN0R : (0:вДЭ) < (N : вДЭ) := by exact_mod_cast hN1nat
  have hN1R : (1:вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast hN1nat
  set L : вДЭ := Real.log N with hLdef
  -- log N вЙ• C from N вЙ• вМИexp CвМЙ + 1
  have hNR : Real.exp C вЙ§ (N : вДЭ) := by
    calc Real.exp C вЙ§ (Nat.ceil (Real.exp C) : вДЭ) := Nat.le_ceil _
      _ вЙ§ (N : вДЭ) := by exact_mod_cast le_trans (Nat.le_succ _) hNe
  have hLC : C вЙ§ L := (Real.le_log_iff_exp_le hN0R).mpr hNR
  have hL1 : (1:вДЭ) вЙ§ L := le_trans (by linarith) hLC
  have hL9C : C вЙ§ L ^ 9 := hLC.trans (le_self_powвВА hL1 (by norm_num))
  set P : вДХ := Nat.floor (L ^ 9) with hPdef
  have hfloor_gt : L ^ 9 < (P : вДЭ) + 1 := by
    have := Nat.lt_floor_add_one (L ^ 9)
