    (`x = ѕГ'`, `t вИИ (вИТT,T]`). -/
lemma strip_point_M_bound {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (M T rlo rhi : вДЭ)
    (hcc : вИА s : вДВ, |s.im| вЙ§ T вЖТ rlo вЙ§ s.re вЖТ s.re вЙ§ rhi вЖТ
      вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ вЙ§ M)
    (x t : вДЭ) (hx1 : rlo вЙ§ x) (hx2 : x вЙ§ rhi) (ht : |t| вЙ§ T) :
    вАЦ-deriv (DirichletCharacter.LFunction ѕЗ) ((x:вДВ) + t * I) / DirichletCharacter.LFunction ѕЗ ((x:вДВ) + t * I)вАЦ
      вЙ§ M := by
