      вЙ§ вИС' n : вДХ, вАЦif n < x then 0 else ((E n : вДЭ) : вДВ)
        * (((n:вДВ)) ^ (-(ќ≤:вДВ)) - (((n + 1 : вДХ):вДВ)) ^ (-(ќ≤:вДВ)))вАЦ :=
