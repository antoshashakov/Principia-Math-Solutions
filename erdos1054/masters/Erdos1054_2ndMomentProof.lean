            * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi * N * |ќ≤|))
            вЙ§ (3 * C) * ((q:вДЭ) * N ^ 2 * (Real.log N + 1)
            * Real.exp (-c * Real.log N ^ ((1:вДЭ)/10)) * (1 + 2 * Real.pi * N * |ќ≤|)) :=
