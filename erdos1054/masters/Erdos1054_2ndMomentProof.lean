theorem rated_progression_bound (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
    вИА q : вДХ, 0 < q вЖТ (q : вДЭ) вЙ§ Real.log N ^ (B : вДЭ) вЖТ
    вИА r : вДХ, r < q вЖТ Nat.gcd r q = 1 вЖТ
    вИА t : вДХ, t вЙ§ N вЖТ
