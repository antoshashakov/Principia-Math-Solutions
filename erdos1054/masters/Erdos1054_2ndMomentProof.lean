/-- **The completed-zeta ball bound** (SW brick S4a-4b): one absolute `CвВА` with
    `вАЦ(zвИТ1)ќґ(z)вАЦ вЙ§ CвВА¬ЈR¬≤` (as `LFunctionTrivCharвВБ 1`, pole removed) on every ball
    `вАЦzвАЦ < R`, `Re z > 19/20` вАФ via the complex Abel truncation tail. -/
theorem completed_zeta_ball_bound :
    вИГ CвВА : вДЭ, 1 вЙ§ CвВА вИІ вИА R : вДЭ, 2 вЙ§ R вЖТ вИА z : вДВ, 19/20 < z.re вЖТ вАЦzвАЦ < R вЖТ
      вАЦDirichletCharacter.LFunctionTrivCharвВБ 1 zвАЦ вЙ§ CвВА * R^2 := by
  have hmaj : Summable (fun k : вДХ => (((k+1 : вДХ)):вДЭ) ^ (-(39:вДЭ)/20)) := by
    have h1 : Summable (fun n : вДХ => ((n:вДЭ)) ^ (-(39:вДЭ)/20)) :=
      Real.summable_nat_rpow.mpr (by norm_num)
    exact h1.comp_injective (add_left_injective 1)
  obtain вЯ®S, hSdefвЯ© : вИГ S : вДЭ, S = вИС' k : вДХ, (((k+1 : вДХ)):вДЭ) ^ (-(39:вДЭ)/20) := вЯ®_, rflвЯ©
  have hS0 : 0 вЙ§ S := by
    rw [hSdef]
    exact tsum_nonneg (fun k => Real.rpow_nonneg (by positivity) _)
  refine вЯ®1 + 3*S, by linarith, ?_вЯ©
  intro R hR z hzre hznorm
  obtain вЯ®T, hTdefвЯ© : вИГ T : вДВ вЖТ вДВ, T = fun w => вИС' k : вДХ,
      ((w - 1) * ((((k+1 : вДХ)):вДВ)) ^ (-w)
        - (((((k+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w) - ((((k+1+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w))) := вЯ®_, rflвЯ©
  obtain вЯ®U, hUdefвЯ© : вИГ U : Set вДВ, U = {w : вДВ | 19/20 < w.re} вИ© Metric.ball 0 R := вЯ®_, rflвЯ©
  have hUopen : IsOpen U := by
    rw [hUdef]
    exact (isOpen_lt continuous_const Complex.continuous_re).inter Metric.isOpen_ball
  have hterm : вИА (k : вДХ) (w : вДВ), w вИИ U вЖТ
      вАЦ(w - 1) * ((((k+1 : вДХ)):вДВ)) ^ (-w)
        - (((((k+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w) - ((((k+1+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w))вАЦ
        вЙ§ (R+1)*R * (((k+1 : вДХ)):вДЭ) ^ (-(39:вДЭ)/20) := by
    intro k w hw
    rw [hUdef] at hw
    obtain вЯ®hw1, hw2вЯ© := hw
    rw [Set.mem_setOf_eq] at hw1
    rw [Metric.mem_ball, dist_zero_right] at hw2
    have h1 := abel_kernel_bound (k+1) (by omega) w (by linarith)
    have h2 : вАЦw - 1вАЦ вЙ§ R + 1 := by
      calc вАЦw - 1вАЦ вЙ§ вАЦwвАЦ + вАЦ(1:вДВ)вАЦ := norm_sub_le _ _
        _ вЙ§ R + 1 := by rw [norm_one]; linarith
    have h3 : (((k+1 : вДХ)):вДЭ) ^ (-w.re - 1) вЙ§ (((k+1 : вДХ)):вДЭ) ^ (-(39:вДЭ)/20) := by
      apply Real.rpow_le_rpow_of_exponent_le
      ¬Ј exact_mod_cast Nat.one_le_iff_ne_zero.mpr (by omega)
      ¬Ј linarith
    have h4 := mul_le_mul (mul_le_mul h2 hw2.le (norm_nonneg w) (by linarith)) h3
      (Real.rpow_nonneg (by positivity) _) (by positivity)
    linarith [h1, h4]
  have hTnorm : вИА w вИИ U, вАЦT wвАЦ вЙ§ (R+1)*R*S := by
    intro w hw
    have hnsum : Summable (fun k : вДХ => вАЦ(w - 1) * ((((k+1 : вДХ)):вДВ)) ^ (-w)
        - (((((k+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w) - ((((k+1+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w))вАЦ) :=
      Summable.of_nonneg_of_le (fun k => norm_nonneg _) (fun k => hterm k w hw)
        (hmaj.mul_left ((R+1)*R))
    simp only [hTdef]
    calc вАЦвИС' k : вДХ, ((w - 1) * ((((k+1 : вДХ)):вДВ)) ^ (-w)
          - (((((k+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w) - ((((k+1+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w)))вАЦ
        вЙ§ вИС' k : вДХ, вАЦ(w - 1) * ((((k+1 : вДХ)):вДВ)) ^ (-w)
          - (((((k+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w) - ((((k+1+1 : вДХ)):вДВ)) ^ ((1:вДВ) - w))вАЦ :=
          norm_tsum_le_tsum_norm hnsum
