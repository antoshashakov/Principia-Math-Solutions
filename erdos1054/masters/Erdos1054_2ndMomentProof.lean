    exact_mod_cast h1
  have hNR : Real.exp ќЫвВВ вЙ§ (N:вДЭ) := by
    have h1 : (вМИReal.exp ќЫвВВвМЙвВК : вДЭ) вЙ§ (N:вДЭ) := by
