/-- **W1 instantiation skeleton**: with packaged strip bounds `M`, tail constant `B`, and
    zero-freeness as hypotheses, `вАЦѕИ_smooth(X,ѕЗ)вАЦ`-type quantities obey the explicit bound. -/
theorem psi_smooth_bound_skeleton {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N) (hѕЗ : ѕЗ вЙ† 1)
    (S : вДВ) (X : вДЭ) (hX : 1 < X) (ѕГ' ѕГ T M B : вДЭ)
    (hѕГ'34 : 3/4 вЙ§ ѕГ') (hѕГ'ѕГ : ѕГ' вЙ§ ѕГ) (hT : 0 < T) (hM : 0 вЙ§ M)
    (hrep : S = (1 / (2 * (Real.pi : вДВ))) * вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I))
    (htail : вАЦ(вИЂ t : вДЭ, G' ѕЗ X ((ѕГ : вДВ) + t * I))
        - вИЂ t in (-T)..T, G' ѕЗ X ((ѕГ : вДВ) + t * I)вАЦ вЙ§ 2 * (B * X ^ ѕГ) / T)
    (hconnT : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2))
    (hconnB : вАЦвИЂ x in ѕГ'..ѕГ, G' ѕЗ X ((x:вДВ) + ((-T : вДЭ) : вДВ) * I)вАЦ
      вЙ§ (ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2))
    (hline : вАЦвИЂ y in (-T)..T, G' ѕЗ X ((ѕГ':вДВ) + (y:вДВ) * I)вАЦ вЙ§ 6 * M * X ^ ѕГ')
    (hzf : вИА s : вДВ, |s.im| вЙ§ T вЖТ ѕГ' вЙ§ s.re вЖТ DirichletCharacter.LFunction ѕЗ s вЙ† 0) :
    вАЦSвАЦ вЙ§ (6 * M * X ^ ѕГ' + 2 * ((ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2)) + 2 * (B * X ^ ѕГ) / T)
      / (2 * Real.pi) := by
  have hX0 : (0:вДЭ) < X := by linarith
  -- the rectangle: z = ѕГ' вИТ T¬ЈI, w = ѕГ + T¬ЈI
  have hzre : ((ѕГ' : вДВ) + ((-T : вДЭ) : вДВ) * I).re = ѕГ' := by simp
  have hzim : ((ѕГ' : вДВ) + ((-T : вДЭ) : вДВ) * I).im = -T := by simp
  have hwre : ((ѕГ : вДВ) + ((T : вДЭ) : вДВ) * I).re = ѕГ := by simp
  have hwim : ((ѕГ : вДВ) + ((T : вДЭ) : вДВ) * I).im = T := by simp
  have hrect : Complex.reProdIm (Set.uIcc ѕГ' ѕГ) (Set.uIcc (-T) T)
      вКЖ {s : вДВ | 0 < s.re вИІ DirichletCharacter.LFunction ѕЗ s вЙ† 0} := by
    intro s hs
    rw [Complex.mem_reProdIm] at hs
    obtain вЯ®hre, himвЯ© := hs
    rw [Set.uIcc_of_le hѕГ'ѕГ] at hre
    rw [Set.uIcc_of_le (by linarith : -T вЙ§ T)] at him
    have h1 : ѕГ' вЙ§ s.re := hre.1
    have h2 : |s.im| вЙ§ T := abs_le.mpr вЯ®him.1, him.2вЯ©
    exact вЯ®by linarith, hzf s h2 h1вЯ©
  have h3' := smoothed_integrand_rect_zero ѕЗ hѕЗ X hX0
    ((ѕГ' : вДВ) + ((-T : вДЭ) : вДВ) * I) ((ѕГ : вДВ) + ((T : вДЭ) : вДВ) * I)
    (by rw [hzre, hzim, hwre, hwim]; exact hrect)
  rw [hzre, hzim, hwre, hwim] at h3'
  exact rectangle_assembly S (G' ѕЗ X) ѕГ' ѕГ T (2 * (B * X ^ ѕГ) / T)
    ((ѕГ - ѕГ') * (M * X ^ ѕГ / T ^ 2)) (6 * M * X ^ ѕГ') hrep htail h3'
    hconnT hconnB
    hline

