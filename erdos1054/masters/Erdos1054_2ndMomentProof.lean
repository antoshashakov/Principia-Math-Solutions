lemma natlog2_le_two_log (N : вДХ) (hN : 2 вЙ§ N) : ((Nat.log 2 N : вДХ) : вДЭ) вЙ§ 2 * Real.log N := by
  have hself : (2 : вДХ) ^ Nat.log 2 N вЙ§ N := Nat.pow_log_le_self 2 (by omega)
