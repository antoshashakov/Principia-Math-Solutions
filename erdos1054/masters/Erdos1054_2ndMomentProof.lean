  have hrdvd : r вИ£ e * d := (Nat.mem_divisors.mp hrdivs).1
  have hned0 : e * d вЙ† 0 := (Nat.mem_divisors.mp hrdivs).2
  constructor
  ¬Ј exact Nat.mem_divisors.mpr вЯ®Nat.div_dvd_of_dvd hrdvd, hned0вЯ©
  ¬Ј exact Nat.div_le_of_le_mul (by
      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
        using Nat.mul_le_mul_right d her)

theorem countUpTo_mono (P Q : Nat вЖТ Prop)
    (h : вИА n, P n вЖТ Q n) (X : Nat) : countUpTo P X вЙ§ countUpTo Q X := by
  classical
  unfold countUpTo
  exact Finset.card_le_card (by
    intro n hn
    simp only [Finset.mem_filter, Finset.mem_range] at hn вКҐ
    exact вЯ®hn.1, h n hn.2вЯ©)

theorem countUpTo_union_le (P Q : Nat вЖТ Prop)
    (X : Nat) : countUpTo (fun n => P n вИ® Q n) X вЙ§ countUpTo P X + countUpTo Q X := by
  classical
  unfold countUpTo
  refine le_trans (Finset.card_le_card ?_) (Finset.card_union_le
    ((Finset.range (X + 1)).filter P)
    ((Finset.range (X + 1)).filter Q))
  intro n hn
  simp only [Finset.mem_filter, Finset.mem_range, Finset.mem_union] at hn вКҐ
  rcases hn with вЯ®hr, hpqвЯ©
  rcases hpq with hp | hq
  ¬Ј exact Or.inl вЯ®hr, hpвЯ©
  ¬Ј exact Or.inr вЯ®hr, hqвЯ©

theorem densityZero_mono (P Q : Nat вЖТ Prop)
    (hPQ : вИА n, P n вЖТ Q n) (hQ : DensityZero Q) : DensityZero P := by
  classical
  intro ќµ hќµ
  rcases hQ ќµ hќµ with вЯ®XвВА, hXвВАвЯ©
  refine вЯ®XвВА, ?_вЯ©
  intro X hX
  have hnat : countUpTo P X вЙ§ countUpTo Q X := countUpTo_mono P Q hPQ X
  have hrat : (countUpTo P X : Rat) вЙ§ (countUpTo Q X : Rat) := by
    exact_mod_cast hnat
  exact le_trans hrat (hXвВА X hX)

theorem countUpTo_inter_le_left (P Q : Nat вЖТ Prop)
    (X : Nat) : countUpTo (fun n => P n вИІ Q n) X вЙ§ countUpTo P X := by
  classical
  exact countUpTo_mono (fun n => P n вИІ Q n) P (by intro n hn; exact hn.1) X

theorem countUpTo_inter_le_right (P Q : Nat вЖТ Prop)
    (X : Nat) : countUpTo (fun n => P n вИІ Q n) X вЙ§ countUpTo Q X := by
  classical
  exact countUpTo_mono (fun n => P n вИІ Q n) Q (by intro n hn; exact hn.2) X

theorem densityZero_union (P Q : Nat вЖТ Prop)
    (hP : DensityZero P) (hQ : DensityZero Q) : DensityZero (fun n => P n вИ® Q n) := by
  classical
  intro ќµ hќµ
  let ќі : Rat := ќµ / 2
  have hќі : 0 < ќі := by
    dsimp [ќі]
    exact div_pos hќµ (by norm_num)
  rcases hP ќі hќі with вЯ®XP, hXPвЯ©
  rcases hQ ќі hќі with вЯ®XQ, hXQвЯ©
  refine вЯ®max XP XQ, ?_вЯ©
  intro X hX
  have hXPle : X вЙ• XP := le_trans (Nat.le_max_left XP XQ) hX
  have hXQle : X вЙ• XQ := le_trans (Nat.le_max_right XP XQ) hX
  calc
    (countUpTo (fun n => P n вИ® Q n) X : Rat)
        вЙ§ (countUpTo P X : Rat) + (countUpTo Q X : Rat) := by
          exact_mod_cast countUpTo_union_le P Q X
    _ вЙ§ ќі * X + ќі * X := by
          exact add_le_add (hXP X hXPle) (hXQ X hXQle)
    _ = ќµ * X := by
          dsimp [ќі]
          ring

theorem densityZero_inter_left (P Q : Nat вЖТ Prop)
    (hP : DensityZero P) : DensityZero (fun n => P n вИІ Q n) := by
  classical
  exact densityZero_mono (fun n => P n вИІ Q n) P (by intro n hn; exact hn.1) hP

theorem densityZero_inter_right (P Q : Nat вЖТ Prop)
    (hQ : DensityZero Q) : DensityZero (fun n => P n вИІ Q n) := by
