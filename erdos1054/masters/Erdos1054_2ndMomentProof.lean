  intro N hNвВА P hP0 hPB Q n
  have hP0R : (0:вДЭ) < (P:вДЭ) := by exact_mod_cast hP0
  have hterm : вИА pq вИИ anchors P,
      вАЦвИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
          вИ© Set.Ioc (0:вДЭ) 1,
        ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
          - ((вИС r вИИ Finset.range pq.1,
