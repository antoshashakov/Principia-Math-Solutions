  have hsum_erase : вАЦвИС ѕЗ вИИ Finset.univ.erase (1 : DirichletCharacter вДВ q),
      ѕЗ aвБї¬є * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        ѕЗ ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ))вАЦ
      вЙ§ ((q.totient - 1 : вДХ) : вДЭ) * (CвВЕ * X * Real.exp (-(cвВЕ * u))) := by
    calc вАЦ_вАЦ вЙ§ вИС ѕЗ вИИ Finset.univ.erase (1 : DirichletCharacter вДВ q),
          вАЦѕЗ aвБї¬є * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
            ѕЗ ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ))вАЦ := norm_sum_le _ _
