/-!
# Siegel's theorem for Dirichlet L-functions вАФ brick-by-brick (Goldfeld's route)

Target: `siegel_zero_free`: вИА ќµ > 0, вИГ c(ќµ) > 0, every real zero ќ≤ of every L(¬Ј,ѕЗ)
(ѕЗ real nontrivial mod q) satisfies ќ≤ вЙ§ 1 вИТ c(ќµ)/q^ќµ. Ineffective (the dichotomy
case-split is classical); the last missing zero-free input for SiegelвАУWalfisz and
hence for almost-all binary Goldbach (see the approved roadmap plan).

Phase A of the roadmap; every lemma verified 0-error + `#print axioms`-clean
([propext, Classical.choice, Quot.sound]) before banking.
-/

open PowerSeries ArithmeticFunction Finset Filter

/-- The geometric power series `ќ£ xвБњ tвБњ` вАФ the local Euler factor `(1 вИТ xt)вБї¬є`
    of a completely multiplicative function with `g(p) = x`. -/
noncomputable def geomPS (x : вДЭ) : PowerSeries вДЭ := PowerSeries.mk (fun n => x ^ n)

lemma coeff_geomPS (x : вДЭ) (n : вДХ) : (PowerSeries.coeff (R := вДЭ) n) (geomPS x) = x ^ n := by
  rw [geomPS, PowerSeries.coeff_mk]

/-- Products preserve coefficientwise nonnegativity. -/
lemma coeff_mul_nonneg (f g : PowerSeries вДЭ)
    (hf : вИА n, 0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) f) (hg : вИА n, 0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) g)
    (n : вДХ) : 0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) (f * g) := by
  rw [PowerSeries.coeff_mul]
  apply Finset.sum_nonneg
  intro p _
  exact mul_nonneg (hf p.1) (hg p.2)

/-- `(1вИТt)вБї¬є(1вИТxt)вБї¬є` has nonnegative coefficients for `x вИИ {вИТ1,0,1}`
    (the character-value alphabet): `ќ£_{jвЙ§n} x ≤ вЙ• 0`. -/
lemma coeff_one_mul_geomPS_nonneg (x : вДЭ) (hx : x = -1 вИ® x = 0 вИ® x = 1) (n : вДХ) :
    0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) (geomPS 1 * geomPS x) := by
  rw [PowerSeries.coeff_mul]
  have hsum : вИС p вИИ Finset.antidiagonal n,
      (PowerSeries.coeff (R := вДЭ) p.1) (geomPS 1) * (PowerSeries.coeff (R := вДЭ) p.2) (geomPS x)
      = вИС p вИИ Finset.antidiagonal n, x ^ p.2 := by
    apply Finset.sum_congr rfl
    intro p _
    rw [coeff_geomPS, coeff_geomPS, one_pow, one_mul]
  rw [hsum, Finset.Nat.sum_antidiagonal_eq_sum_range_succ_mk]
  simp only
  rcases hx with rfl | rfl | rfl
  ¬Ј -- x = вИТ1: the alternating partial sum is 0 or 1
    have h : вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ (n - i)
        = вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ i := by
      have hr := Finset.sum_range_reflect (fun i => ((-1:вДЭ)) ^ i) (n + 1)
      simp only [Nat.add_sub_cancel] at hr
      exact hr
    rw [h, neg_one_geom_sum]
    split <;> norm_num
  ¬Ј -- x = 0: only the i = n term (0^0 = 1) survives
    apply Finset.sum_nonneg
    intro i _
    rcases Nat.eq_zero_or_pos (n - i) with h0 | h0
    ¬Ј rw [h0]; norm_num
    ¬Ј rw [zero_pow h0.ne']
  ¬Ј -- x = 1: n+1 ones
    simp
    positivity

/-- `(1вИТxt)вБї¬є(1+xt)вБї¬є = (1вИТx¬≤t¬≤)вБї¬є` has nonnegative coefficients for EVERY real `x`:
    the coefficient is `xвБњ` times the alternating sum, nonzero only for even `n`. -/
lemma coeff_geomPS_mul_neg_nonneg (x : вДЭ) (n : вДХ) :
    0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) (geomPS x * geomPS (-x)) := by
  rw [PowerSeries.coeff_mul]
  have hsum : вИС p вИИ Finset.antidiagonal n,
      (PowerSeries.coeff (R := вДЭ) p.1) (geomPS x) * (PowerSeries.coeff (R := вДЭ) p.2) (geomPS (-x))
      = x ^ n * вИС p вИИ Finset.antidiagonal n, (-1:вДЭ) ^ p.2 := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro p hp
    rw [coeff_geomPS, coeff_geomPS, neg_pow]
    have hpn : p.1 + p.2 = n := Finset.mem_antidiagonal.mp hp
    rw [show x ^ p.1 * ((-1:вДЭ) ^ p.2 * x ^ p.2) = (-1:вДЭ) ^ p.2 * (x ^ p.1 * x ^ p.2) by ring,
      вЖР pow_add, hpn]
    ring
  rw [hsum, Finset.Nat.sum_antidiagonal_eq_sum_range_succ_mk]
  simp only
  rcases Nat.even_or_odd n with he | ho
  ¬Ј apply mul_nonneg (he.pow_nonneg x)
    have h : вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ (n - i)
        = вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ i := by
      have hr := Finset.sum_range_reflect (fun i => ((-1:вДЭ)) ^ i) (n + 1)
      simp only [Nat.add_sub_cancel] at hr
      exact hr
    rw [h, neg_one_geom_sum]
    split <;> norm_num
  ¬Ј -- odd n: the alternating sum over n+1 (even count) terms vanishes
    have h : вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ (n - i)
        = вИС i вИИ Finset.range (n + 1), ((-1:вДЭ)) ^ i := by
      have hr := Finset.sum_range_reflect (fun i => ((-1:вДЭ)) ^ i) (n + 1)
      simp only [Nat.add_sub_cancel] at hr
      exact hr
    rw [h, neg_one_geom_sum, if_pos ho.add_one, mul_zero]

/-- **The Goldfeld positivity core** (Siegel brick A1a): for character values
    `x, y вИИ {вИТ1,0,1}`, the local factor product
    `(1вИТt)вБї¬є(1вИТxt)вБї¬є(1вИТyt)вБї¬є(1вИТxyt)вБї¬є` of `ќґ¬ЈL(ѕЗвВБ)¬ЈL(ѕЗвВВ)¬ЈL(ѕЗвВБѕЗвВВ)` has
    nonnegative power-series coefficients вАФ by pairing the four geometric series
    so each pair is nonneg: `y = 1`: `(1¬Јx)(1¬Јx)`; `y = 0`: the `y`-factors are `1`;
    `y = вИТ1`: `(1¬Ј(вИТ1)) вЛЖ (x¬Ј(вИТx))`. -/
lemma coeff_euler_quad_nonneg (x y : вДЭ) (hx : x = -1 вИ® x = 0 вИ® x = 1)
    (hy : y = -1 вИ® y = 0 вИ® y = 1) (n : вДХ) :
    0 вЙ§ (PowerSeries.coeff (R := вДЭ) n) (geomPS 1 * geomPS x * geomPS y * geomPS (x * y)) := by
  rcases hy with rfl | rfl | rfl
  ¬Ј -- y = вИТ1: regroup as (1 вЛЖ (вИТ1)) * (x вЛЖ (вИТx))
    have hre : geomPS 1 * geomPS x * geomPS (-1) * geomPS (x * -1)
        = (geomPS 1 * geomPS (-1)) * (geomPS x * geomPS (-x)) := by
      rw [show x * (-1:вДЭ) = -x by ring]
      ring
    rw [hre]
    apply coeff_mul_nonneg
    ¬Ј exact coeff_one_mul_geomPS_nonneg (-1) (Or.inl rfl)
    ¬Ј exact coeff_geomPS_mul_neg_nonneg x
  ¬Ј -- y = 0: geomPS 0 has coefficients ќівВА; the product bound reduces via nonneg factors
    rw [show x * (0:вДЭ) = 0 by ring]
    apply coeff_mul_nonneg
    ¬Ј apply coeff_mul_nonneg
      ¬Ј exact coeff_one_mul_geomPS_nonneg x hx
      ¬Ј intro m
        rw [coeff_geomPS]
        rcases Nat.eq_zero_or_pos m with rfl | h0
        ¬Ј norm_num
        ¬Ј rw [zero_pow h0.ne']
    ¬Ј intro m
      rw [coeff_geomPS]
      rcases Nat.eq_zero_or_pos m with rfl | h0
      ¬Ј norm_num
      ¬Ј rw [zero_pow h0.ne']
  ¬Ј -- y = 1: regroup as (1 вЛЖ x) * (1 вЛЖ x)
    have hre : geomPS 1 * geomPS x * geomPS 1 * geomPS (x * 1)
        = (geomPS 1 * geomPS x) * (geomPS 1 * geomPS x) := by
      rw [mul_one]
      ring
    rw [hre]
    exact coeff_mul_nonneg _ _
      (coeff_one_mul_geomPS_nonneg x hx) (coeff_one_mul_geomPS_nonneg x hx) n

/-- **Dirichlet convolution at prime powers** (Siegel brick A1b-i):
    `(f вЛЖ g)(pбµР) = ќ£_{iвЙ§m} f(pвБ±)¬Јg(p^{mвИТi})` вАФ the divisor pairs of `pбµР` are exactly
    `(pвБ±, p^{mвИТi})`. -/
lemma mul_apply_prime_pow (f g : ArithmeticFunction вДЭ) {p : вДХ} (hp : p.Prime) (m : вДХ) :
    (f * g) (p ^ m) = вИС i вИИ Finset.range (m + 1), f (p ^ i) * g (p ^ (m - i)) := by
  rw [ArithmeticFunction.mul_apply]
  have hp0 : p вЙ† 0 := hp.ne_zero
  have hp1 : 1 < p := hp.one_lt
  apply Finset.sum_nbij' (fun pr => pr.1.factorization p)
    (fun i => ((p ^ i : вДХ), (p ^ (m - i) : вДХ)))
  ¬Ј -- membership: divisor pair вЖТ range
    intro pr hpr
    rw [Nat.mem_divisorsAntidiagonal] at hpr
    obtain вЯ®hmul, _вЯ© := hpr
    have hdvd : pr.1 вИ£ p ^ m := вЯ®pr.2, hmul.symmвЯ©
    obtain вЯ®k, hk, hk'вЯ© := (Nat.dvd_prime_pow hp).mp hdvd
    rw [Finset.mem_range, hk', Nat.factorization_pow_self hp]
    omega
  ¬Ј -- membership: range вЖТ divisor pair
    intro i hi
    rw [Finset.mem_range] at hi
    rw [Nat.mem_divisorsAntidiagonal]
    constructor
    ¬Ј rw [вЖР pow_add]
      congr 1
      omega
    ¬Ј positivity
  ¬Ј -- left inverse
    intro pr hpr
    rw [Nat.mem_divisorsAntidiagonal] at hpr
    obtain вЯ®hmul, _вЯ© := hpr
    have hdvd : pr.1 вИ£ p ^ m := вЯ®pr.2, hmul.symmвЯ©
    obtain вЯ®k, hk, hk'вЯ© := (Nat.dvd_prime_pow hp).mp hdvd
    have hfact : pr.1.factorization p = k := by
      rw [hk', Nat.factorization_pow_self hp]
    rw [hfact]
    have hb : pr.2 = p ^ (m - k) := by
      have h1 : p ^ k * pr.2 = p ^ k * p ^ (m - k) := by
        rw [вЖР pow_add, show k + (m - k) = m by omega, вЖР hk', hmul]
      exact Nat.eq_of_mul_eq_mul_left (by positivity) h1
    rw [вЖР hk', вЖР hb]
  ¬Ј -- right inverse
    intro i hi
    rw [Nat.factorization_pow_self hp]
  ¬Ј -- summand match
    intro pr hpr
    rw [Nat.mem_divisorsAntidiagonal] at hpr
    obtain вЯ®hmul, _вЯ© := hpr
    have hdvd : pr.1 вИ£ p ^ m := вЯ®pr.2, hmul.symmвЯ©
    obtain вЯ®k, hk, hk'вЯ© := (Nat.dvd_prime_pow hp).mp hdvd
    have hfact : pr.1.factorization p = k := by
      rw [hk', Nat.factorization_pow_self hp]
    have hb : pr.2 = p ^ (m - k) := by
      have h1 : p ^ k * pr.2 = p ^ k * p ^ (m - k) := by
        rw [вЖР pow_add, show k + (m - k) = m by omega, вЖР hk', hmul]
      exact Nat.eq_of_mul_eq_mul_left (by positivity) h1
    rw [hfact, вЖР hk', hb]

/-- The prime-power fiber of an arithmetic function, as a power series in the exponent. -/
noncomputable def primeFiber (f : ArithmeticFunction вДЭ) (p : вДХ) : PowerSeries вДЭ :=
  PowerSeries.mk (fun m => f (p ^ m))

lemma coeff_primeFiber (f : ArithmeticFunction вДЭ) (p m : вДХ) :
    (PowerSeries.coeff (R := вДЭ) m) (primeFiber f p) = f (p ^ m) := by
  rw [primeFiber, PowerSeries.coeff_mk]

/-- **The prime fiber is multiplicative** (Siegel brick A1b-ii): Dirichlet convolution
    restricted to powers of one prime IS power-series multiplication. -/
lemma primeFiber_mul (f g : ArithmeticFunction вДЭ) {p : вДХ} (hp : p.Prime) :
    primeFiber (f * g) p = primeFiber f p * primeFiber g p := by
  ext m
  rw [coeff_primeFiber, PowerSeries.coeff_mul, mul_apply_prime_pow f g hp,
    Finset.Nat.sum_antidiagonal_eq_sum_range_succ_mk]
  apply Finset.sum_congr rfl
  intro i _
  rw [coeff_primeFiber, coeff_primeFiber]

/-- A bare function packaged as an arithmetic function (forcing the value 0 at 0). -/
noncomputable def toArith (g : вДХ вЖТ вДЭ) : ArithmeticFunction вДЭ :=
  вЯ®fun n => if n = 0 then 0 else g n, by simpвЯ©

lemma toArith_apply (g : вДХ вЖТ вДЭ) (n : вДХ) (hn : n вЙ† 0) : toArith g n = g n := by
  simp [toArith, hn]

/-- Completely multiplicative bare functions give multiplicative arithmetic functions. -/
lemma toArith_isMultiplicative (g : вДХ вЖТ вДЭ) (hg : вИА m n, g (m * n) = g m * g n)
    (hg1 : g 1 = 1) : (toArith g).IsMultiplicative := by
  constructor
  ¬Ј rw [toArith_apply g 1 one_ne_zero, hg1]
  ¬Ј intro m n _
    rcases Nat.eq_zero_or_pos m with rfl | hm
    ¬Ј simp [toArith]
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј simp [toArith]
    rw [toArith_apply g _ (by positivity), toArith_apply g _ hm.ne',
      toArith_apply g _ hn.ne', hg]

/-- Completely multiplicative functions turn powers into powers. -/
lemma comp_mult_pow (g : вДХ вЖТ вДЭ) (hg : вИА m n, g (m * n) = g m * g n) (hg1 : g 1 = 1)
    (a : вДХ) : вИА m : вДХ, g (a ^ m) = g a ^ m := by
  intro m
  induction m with
  | zero => simpa using hg1
  | succ k ih =>
    rw [pow_succ, hg, ih, pow_succ]

/-- The prime fiber of a packaged completely multiplicative function is the geometric
    series at its prime value. -/
lemma primeFiber_toArith (g : вДХ вЖТ вДЭ) (hg : вИА m n, g (m * n) = g m * g n) (hg1 : g 1 = 1)
    {p : вДХ} (hp : p.Prime) : primeFiber (toArith g) p = geomPS (g p) := by
  ext m
  rw [coeff_primeFiber, coeff_geomPS, toArith_apply g _ (pow_ne_zero m hp.ne_zero),
    comp_mult_pow g hg hg1 p m]

/-- **Nonnegativity of the Goldfeld convolution** (Siegel brick A1c): for completely
    multiplicative `gвВБ, gвВВ` with values in `{вИТ1,0,1}` (the real-character shape), every
    value of the Dirichlet convolution `1 вЛЖ gвВБ вЛЖ gвВВ вЛЖ gвВБgвВВ` вАФ the coefficient sequence
    of `ќґ(s)L(s,ѕЗвВБ)L(s,ѕЗвВВ)L(s,ѕЗвВБѕЗвВВ)` вАФ is nonnegative, and the value at 1 is 1. -/
theorem quad_conv_nonneg (gвВБ gвВВ : вДХ вЖТ вДЭ)
    (hвВБ : вИА m n, gвВБ (m * n) = gвВБ m * gвВБ n) (hвВВ : вИА m n, gвВВ (m * n) = gвВВ m * gвВВ n)
    (hвВБ1 : gвВБ 1 = 1) (hвВВ1 : gвВВ 1 = 1)
    (hвВБv : вИА n, gвВБ n = -1 вИ® gвВБ n = 0 вИ® gвВБ n = 1)
    (hвВВv : вИА n, gвВВ n = -1 вИ® gвВВ n = 0 вИ® gвВВ n = 1) :
    (вИА n, 0 вЙ§ (toArith (fun _ => 1) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) n)
    вИІ (toArith (fun _ => 1) * toArith gвВБ * toArith gвВВ
        * toArith (fun k => gвВБ k * gвВВ k)) 1 = 1 := by
  set A : ArithmeticFunction вДЭ := toArith (fun _ => 1) * toArith gвВБ * toArith gвВВ
    * toArith (fun k => gвВБ k * gвВВ k) with hA
  have hm0 : (toArith (fun _ => (1:вДЭ))).IsMultiplicative :=
    toArith_isMultiplicative _ (fun _ _ => (one_mul 1).symm) rfl
  have hm1 : (toArith gвВБ).IsMultiplicative := toArith_isMultiplicative gвВБ hвВБ hвВБ1
  have hm2 : (toArith gвВВ).IsMultiplicative := toArith_isMultiplicative gвВВ hвВВ hвВВ1
  have h12 : вИА m n, (fun k => gвВБ k * gвВВ k) (m * n)
      = (fun k => gвВБ k * gвВВ k) m * (fun k => gвВБ k * gвВВ k) n := by
    intro m n
    simp only
    rw [hвВБ, hвВВ]
    ring
  have h121 : (fun k => gвВБ k * gвВВ k) 1 = 1 := by
    simp only
    rw [hвВБ1, hвВВ1, one_mul]
  have hm3 : (toArith (fun k => gвВБ k * gвВВ k)).IsMultiplicative :=
    toArith_isMultiplicative _ h12 h121
  have hmA : A.IsMultiplicative := ((hm0.mul hm1).mul hm2).mul hm3
  -- prime-power nonnegativity via the fiber bridge + the A1a positivity core
  have hpp : вИА p : вДХ, p.Prime вЖТ вИА m : вДХ, 0 вЙ§ A (p ^ m) := by
    intro p hp m
    have hfib : primeFiber A p
        = geomPS 1 * geomPS (gвВБ p) * geomPS (gвВВ p) * geomPS (gвВБ p * gвВВ p) := by
      rw [hA, primeFiber_mul _ _ hp, primeFiber_mul _ _ hp, primeFiber_mul _ _ hp,
        primeFiber_toArith _ (fun _ _ => (one_mul 1).symm) rfl hp,
        primeFiber_toArith gвВБ hвВБ hвВБ1 hp, primeFiber_toArith gвВВ hвВВ hвВВ1 hp,
        primeFiber_toArith _ h12 h121 hp]
    have := coeff_euler_quad_nonneg (gвВБ p) (gвВВ p) (hвВБv p) (hвВВv p) m
    rw [вЖР hfib, coeff_primeFiber] at this
    exact this
  refine вЯ®?_, hmA.map_oneвЯ©
  intro n
  rcases Nat.eq_zero_or_pos n with rfl | hn
  ¬Ј rw [ArithmeticFunction.map_zero]
  have hfac := hmA.multiplicative_factorization A hn.ne'
  rw [hfac, Finsupp.prod]
  apply Finset.prod_nonneg
  intro p hpmem
  have hp : p.Prime := Nat.prime_of_mem_primeFactors
    (by rwa [Nat.support_factorization] at hpmem)
  exact hpp p hp _

/-- The lattice-point index set of the hyperbola method: pairs `(d,e)` with
    `1 вЙ§ d, e` and `d¬Јe вЙ§ N`. -/
def hypSet (N : вДХ) : Finset (вДХ √Ч вДХ) :=
  (Ioc 0 N √ЧЋҐ Ioc 0 N).filter (fun p => p.1 * p.2 вЙ§ N)

/-- **Convolution partial sums are lattice-point sums** (Siegel brick A2a-i). -/
lemma sum_conv_eq_sum_hypSet (f g : ArithmeticFunction вДЭ) (N : вДХ) :
    вИС n вИИ Icc 1 N, (f * g) n = вИС p вИИ hypSet N, f p.1 * g p.2 := by
  have hL : вИС n вИИ Icc 1 N, (f * g) n
      = вИС n вИИ Icc 1 N, вИС p вИИ (Ioc 0 N √ЧЋҐ Ioc 0 N).filter (fun x => x.1 * x.2 = n),
          f p.1 * g p.2 := by
    apply Finset.sum_congr rfl
    intro n hn
    obtain вЯ®hn1, hnNвЯ© := Finset.mem_Icc.mp hn
    rw [ArithmeticFunction.mul_apply,
      Nat.divisorsAntidiagonal_eq_prod_filter_of_le (by omega) hnN]
  rw [hL, Finset.sum_fiberwise_eq_sum_filter]
  apply Finset.sum_congr _ (fun _ _ => rfl)
  rw [hypSet]
  apply Finset.filter_congr
  intro p hp
  rw [Finset.mem_product, Finset.mem_Ioc, Finset.mem_Ioc] at hp
  simp only [Finset.mem_Icc]
  constructor
  ¬Ј intro h
    exact h.2
  ¬Ј intro h
    refine вЯ®?_, hвЯ©
    exact Nat.one_le_iff_ne_zero.mpr (Nat.mul_pos hp.1.1 hp.2.1).ne'

/-- Row fibers of the hyperbola set: for `1 вЙ§ d`, the `e` with `d¬Јe вЙ§ N` form `Icc 1 (N/d)`. -/
lemma row_fiber (N d : вДХ) (hd : 0 < d) :
    (Ioc 0 N).filter (fun e => d * e вЙ§ N) = Icc 1 (N / d) := by
  ext e
  simp only [Finset.mem_filter, Finset.mem_Ioc, Finset.mem_Icc]
  constructor
  ¬Ј intro вЯ®вЯ®he0, _вЯ©, hdeвЯ©
    refine вЯ®he0, (Nat.le_div_iff_mul_le hd).mpr ?_вЯ©
    rw [Nat.mul_comm]
    exact hde
  ¬Ј intro вЯ®he1, heNdвЯ©
    have hde : d * e вЙ§ N := by
      have h := (Nat.le_div_iff_mul_le hd).mp heNd
      rw [Nat.mul_comm e d] at h
      exact h
    have heN : e вЙ§ N := by
      calc e вЙ§ d * e := Nat.le_mul_of_pos_left e hd
        _ вЙ§ N := hde
    exact вЯ®вЯ®by omega, heNвЯ©, hdeвЯ©

/-- Column fibers above the split: for `1 вЙ§ e`, the `d > y` with `d¬Јe вЙ§ N` form
    `Icc (y+1) (N/e)`. -/
lemma col_fiber (N y e : вДХ) (he : 0 < e) :
    (Ioc 0 N).filter (fun d => ¬ђ d вЙ§ y вИІ d * e вЙ§ N) = Icc (y + 1) (N / e) := by
  ext d
  simp only [Finset.mem_filter, Finset.mem_Ioc, Finset.mem_Icc, not_le]
  constructor
  ¬Ј intro вЯ®вЯ®_, _вЯ©, hyd, hdeвЯ©
    exact вЯ®hyd, (Nat.le_div_iff_mul_le he).mpr hdeвЯ©
  ¬Ј intro вЯ®hyd, hdNeвЯ©
    have hde : d * e вЙ§ N := (Nat.le_div_iff_mul_le he).mp hdNe
    have hdN : d вЙ§ N := by
      calc d вЙ§ d * e := Nat.le_mul_of_pos_right d he
        _ вЙ§ N := hde
    exact вЯ®вЯ®by omega, hdNвЯ©, hyd, hdeвЯ©

/-- **The Dirichlet hyperbola identity** (Siegel brick A2a): for any split `y вЙ§ N`,
    `ќ£_{nвЙ§N}(fвЛЖg)(n) = ќ£_{dвЙ§y} f(d)¬ЈG(N/d) + ќ£_{eвЙ§N/(y+1)} g(e)¬Ј(F(N/e) вИТ F(y))` вАФ
    the exact identity behind the coefficient asymptotic `A(x) = ќїx + O(Q^c x^{4/5})`. -/
theorem hyperbola_identity (f g : ArithmeticFunction вДЭ) (N y : вДХ) (hy : y вЙ§ N) :
    вИС n вИИ Icc 1 N, (f * g) n
      = вИС d вИИ Icc 1 y, f d * (вИС e вИИ Icc 1 (N / d), g e)
        + вИС e вИИ Icc 1 (N / (y + 1)),
            g e * ((вИС d вИИ Icc 1 (N / e), f d) - вИС d вИИ Icc 1 y, f d) := by
  rw [sum_conv_eq_sum_hypSet, hypSet,
    вЖР Finset.sum_filter_add_sum_filter_not _ (fun p => p.1 вЙ§ y)]
  congr 1
  ¬Ј -- head: rows d вЙ§ y
    rw [Finset.filter_filter, Finset.sum_filter, Finset.sum_product]
    simp only
    rw [вЖР Finset.sum_filter_add_sum_filter_not (Ioc 0 N) (fun d => d вЙ§ y)]
    have hz : вИС d вИИ (Ioc 0 N).filter (fun d => ¬ђ d вЙ§ y),
        вИС e вИИ Ioc 0 N, (if d * e вЙ§ N вИІ d вЙ§ y then f d * g e else 0) = 0 := by
      apply Finset.sum_eq_zero
      intro d hd
      apply Finset.sum_eq_zero
      intro e _
      rw [Finset.mem_filter] at hd
      rw [if_neg]
      intro hcon
      exact hd.2 hcon.2
    rw [hz, add_zero]
    have hIoc : (Ioc 0 N).filter (fun d => d вЙ§ y) = Icc 1 y := by
      ext d
      simp only [Finset.mem_filter, Finset.mem_Ioc, Finset.mem_Icc]
      omega
    rw [hIoc]
    apply Finset.sum_congr rfl
    intro d hd
    obtain вЯ®hd1, hdyвЯ© := Finset.mem_Icc.mp hd
    rw [Finset.mul_sum, вЖР row_fiber N d (by omega), Finset.sum_filter]
    apply Finset.sum_congr rfl
    intro e _
    by_cases hde : d * e вЙ§ N
    ¬Ј rw [if_pos вЯ®hde, hdyвЯ©, if_pos hde]
    ¬Ј rw [if_neg (fun h => hde h.1), if_neg hde]
  ¬Ј -- tail: columns, d > y
    rw [Finset.filter_filter, Finset.sum_filter, Finset.sum_product_right]
    simp only
    have hsub : Icc 1 (N / (y + 1)) вКЖ Ioc 0 N := by
      intro e he
      obtain вЯ®he1, heNвЯ© := Finset.mem_Icc.mp he
      rw [Finset.mem_Ioc]
      have : N / (y + 1) вЙ§ N := Nat.div_le_self N (y + 1)
      omega
    rw [вЖР Finset.sum_subset hsub]
    ¬Ј apply Finset.sum_congr rfl
      intro e he
      obtain вЯ®he1, heNyвЯ© := Finset.mem_Icc.mp he
      have hy1e : y + 1 вЙ§ N / e + 1 := by
        have h1 : e * (y + 1) вЙ§ N := (Nat.le_div_iff_mul_le (by omega)).mp heNy
        have h2 : y + 1 вЙ§ N / e := by
          apply (Nat.le_div_iff_mul_le (by omega : 0 < e)).mpr
          rw [Nat.mul_comm]
          exact h1
        omega
      have hIcoIcc : вИА a b : вДХ, Ico a (b + 1) = Icc a b := by
        intro a b
        ext x
        simp only [Finset.mem_Ico, Finset.mem_Icc]
        omega
      have hdiff : (вИС d вИИ Icc 1 (N / e), f d) - вИС d вИИ Icc 1 y, f d
          = вИС d вИИ Icc (y + 1) (N / e), f d := by
        rw [вЖР hIcoIcc 1 (N / e),
          вЖР Finset.sum_Ico_consecutive (fun d => f d) (by omega : 1 вЙ§ y + 1) hy1e,
          hIcoIcc 1 y, hIcoIcc (y + 1) (N / e), add_sub_cancel_left]
      rw [hdiff, Finset.mul_sum, вЖР col_fiber N y e (by omega), Finset.sum_filter]
      apply Finset.sum_congr rfl
      intro d _
      by_cases hcase : d * e вЙ§ N вИІ ¬ђ d вЙ§ y
      ¬Ј rw [if_pos hcase, if_pos вЯ®hcase.2, hcase.1вЯ©, mul_comm]
      ¬Ј rw [if_neg hcase, if_neg (fun hcon => hcase вЯ®hcon.2, hcon.1вЯ©)]
    ¬Ј intro e heIoc heNot
      apply Finset.sum_eq_zero
      intro d _
      rw [if_neg]
      intro вЯ®hde, hdyвЯ©
      apply heNot
      rw [Finset.mem_Icc]
      obtain вЯ®he0, _вЯ© := Finset.mem_Ioc.mp heIoc
      refine вЯ®by omega, ?_вЯ©
      rw [Nat.le_div_iff_mul_le (by omega : 0 < y + 1)]
      push_neg at hdy
      calc e * (y + 1) вЙ§ e * d := by
            apply Nat.mul_le_mul_left
            omega
        _ = d * e := Nat.mul_comm e d
        _ вЙ§ N := hde

/-- **Harmonic partial sums** (Siegel brick A2b-i): `ќ£_{cвЙ§z} 1/c вЙ§ 1 + log z`. -/
lemma sum_one_div_le_log (z : вДХ) (hz : 1 вЙ§ z) :
    вИС c вИИ Icc 1 z, (1 : вДЭ) / c вЙ§ 1 + Real.log z := by
  have hh := harmonic_le_one_add_log z
  have hcast : ((harmonic z : вДЪ) : вДЭ) = вИС c вИИ Icc 1 z, (1 : вДЭ) / c := by
    rw [harmonic,
      show Icc 1 z = Ico 1 (z + 1) from by
        ext x
        simp only [Finset.mem_Icc, Finset.mem_Ico]
        omega,
      Finset.sum_Ico_eq_sum_range]
    push_cast
    apply Finset.sum_congr (by norm_num)
    intro i _
    push_cast
    ring
  rw [вЖР hcast]
  exact_mod_cast hh

/-- **Square-root reciprocal partial sums** (Siegel brick A2b-ii): `ќ£_{eвЙ§z} 1/вИЪe вЙ§ 2вИЪz` вАФ
    by the telescoping `1/вИЪe вЙ§ 2(вИЪe вИТ вИЪ(eвИТ1))`. -/
lemma sum_one_div_sqrt_le (z : вДХ) :
    вИС e вИИ Icc 1 z, (1 : вДЭ) / Real.sqrt e вЙ§ 2 * Real.sqrt z := by
  induction z with
  | zero => simp
  | succ n ih =>
    rcases Nat.eq_zero_or_pos n with rfl | hn
    ¬Ј simp
    have hstep : Icc 1 (n + 1) = insert (n + 1) (Icc 1 n) := by
      ext x
      simp only [Finset.mem_insert, Finset.mem_Icc]
      omega
    rw [hstep, Finset.sum_insert (by simp)]
    have hkey : (1 : вДЭ) / Real.sqrt (n + 1) вЙ§ 2 * (Real.sqrt (n + 1) - Real.sqrt n) := by
      have hs1 : 0 < Real.sqrt ((n : вДЭ) + 1) := Real.sqrt_pos.mpr (by positivity)
      have hs0 : 0 вЙ§ Real.sqrt (n : вДЭ) := Real.sqrt_nonneg _
      have hprod : (Real.sqrt ((n : вДЭ) + 1) - Real.sqrt n)
          * (Real.sqrt ((n : вДЭ) + 1) + Real.sqrt n) = 1 := by
        have h1 : Real.sqrt ((n : вДЭ) + 1) ^ 2 = (n : вДЭ) + 1 :=
          Real.sq_sqrt (by positivity)
        have h2 : Real.sqrt (n : вДЭ) ^ 2 = (n : вДЭ) := Real.sq_sqrt (Nat.cast_nonneg n)
        nlinarith [h1, h2]
      have hsumle : Real.sqrt ((n : вДЭ) + 1) + Real.sqrt n
          вЙ§ 2 * Real.sqrt ((n : вДЭ) + 1) := by
        have := Real.sqrt_le_sqrt (show (n : вДЭ) вЙ§ (n : вДЭ) + 1 by linarith)
        linarith
      rw [div_le_iffвВА hs1]
      have hdiffpos : 0 < Real.sqrt ((n : вДЭ) + 1) - Real.sqrt n := by
        rcases lt_or_ge (Real.sqrt n) (Real.sqrt ((n:вДЭ) + 1)) with h | h
        ¬Ј linarith
        ¬Ј exfalso
          nlinarith [hprod]
      nlinarith [hprod, hsumle, hdiffpos, hs1]
    have hcast : ((n + 1 : вДХ) : вДЭ) = (n : вДЭ) + 1 := by push_cast; ring
    rw [hcast] at *
    linarith [ih, hkey]

/-- **Row decomposition of hyperbola-set sums** (Siegel brick A2b-iii):
    `ќ£_{p вИИ hypSet N} F(p) = ќ£_{dвЙ§N} ќ£_{eвЙ§N/d} F(d,e)`. -/
lemma sum_hypSet_eq_rows (N : вДХ) (F : вДХ √Ч вДХ вЖТ вДЭ) :
    вИС p вИИ (Ioc 0 N √ЧЋҐ Ioc 0 N).filter (fun p => p.1 * p.2 вЙ§ N), F p
      = вИС d вИИ Icc 1 N, вИС e вИИ Icc 1 (N / d), F (d, e) := by
  rw [Finset.sum_filter, Finset.sum_product]
  have hIoc : (Ioc 0 N : Finset вДХ) = Icc 1 N := by
    ext x
    simp only [Finset.mem_Ioc, Finset.mem_Icc]
    omega
  rw [hIoc]
  apply Finset.sum_congr rfl
  intro d hd
  obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
  have hrow : Icc 1 (N / d) = (Icc 1 N).filter (fun e => d * e вЙ§ N) := by
    ext e
    simp only [Finset.mem_Icc, Finset.mem_filter]
    constructor
    ¬Ј intro вЯ®he1, heNdвЯ©
      have hde : d * e вЙ§ N := by
        have h := (Nat.le_div_iff_mul_le (by omega : 0 < d)).mp heNd
        rw [Nat.mul_comm e d] at h
        exact h
      have heN : e вЙ§ N := le_trans (Nat.le_mul_of_pos_left e (by omega)) hde
      exact вЯ®вЯ®he1, heNвЯ©, hdeвЯ©
    ¬Ј intro вЯ®вЯ®he1, _вЯ©, hdeвЯ©
      refine вЯ®he1, (Nat.le_div_iff_mul_le (by omega : 0 < d)).mpr ?_вЯ©
      rw [Nat.mul_comm]
      exact hde
  rw [hrow, Finset.sum_filter]

/-- **The divisor-weighted root sum** (Siegel brick A2b-iv):
    `ќ£_{p вИИ hypSet z} 1/вИЪ(pвВБpвВВ) вЙ§ 2вИЪz(1 + log z)` вАФ the error-term workhorse:
    every `ќ£_{eвЙ§z} d(e)/вИЪe` style bound routes through this lattice form. -/
lemma sum_hypSet_inv_sqrt_le (z : вДХ) (hz : 1 вЙ§ z) :
    вИС p вИИ (Ioc 0 z √ЧЋҐ Ioc 0 z).filter (fun p => p.1 * p.2 вЙ§ z),
        (1 : вДЭ) / Real.sqrt (p.1 * p.2)
      вЙ§ 2 * Real.sqrt z * (1 + Real.log z) := by
  rw [sum_hypSet_eq_rows]
  have hrow : вИА d вИИ Icc 1 z, вИС e вИИ Icc 1 (z / d), (1 : вДЭ) / Real.sqrt ((d, e).1 * (d, e).2)
      вЙ§ (1 / (d : вДЭ)) * (2 * Real.sqrt z) := by
    intro d hd
    obtain вЯ®hd1, hdzвЯ© := Finset.mem_Icc.mp hd
    have hd0 : (0:вДЭ) < d := by exact_mod_cast hd1
    have hsplit : вИА e вИИ Icc 1 (z / d), (1 : вДЭ) / Real.sqrt ((d, e).1 * (d, e).2)
        = (1 / Real.sqrt d) * (1 / Real.sqrt e) := by
      intro e he
      obtain вЯ®he1, _вЯ© := Finset.mem_Icc.mp he
      simp only
      rw [Real.sqrt_mul (Nat.cast_nonneg d)]
      ring
    rw [Finset.sum_congr rfl hsplit, вЖР Finset.mul_sum]
    have hsum := sum_one_div_sqrt_le (z / d)
    have hdivle : Real.sqrt ((z / d : вДХ) : вДЭ) вЙ§ Real.sqrt z / Real.sqrt d := by
      calc Real.sqrt ((z / d : вДХ) : вДЭ) вЙ§ Real.sqrt ((z : вДЭ) / d) :=
            Real.sqrt_le_sqrt Nat.cast_div_le
        _ = Real.sqrt z / Real.sqrt d := Real.sqrt_div (Nat.cast_nonneg z) d
    have hsd : (0:вДЭ) < Real.sqrt d := Real.sqrt_pos.mpr hd0
    calc (1 / Real.sqrt d) * вИС e вИИ Icc 1 (z / d), (1:вДЭ) / Real.sqrt e
        вЙ§ (1 / Real.sqrt d) * (2 * Real.sqrt ((z / d : вДХ) : вДЭ)) := by
          apply mul_le_mul_of_nonneg_left hsum (by positivity)
      _ вЙ§ (1 / Real.sqrt d) * (2 * (Real.sqrt z / Real.sqrt d)) := by
          apply mul_le_mul_of_nonneg_left _ (by positivity)
          linarith [hdivle]
      _ = 2 * Real.sqrt z / (Real.sqrt d * Real.sqrt d) := by ring
      _ = (1 / (d : вДЭ)) * (2 * Real.sqrt z) := by
          rw [Real.mul_self_sqrt (Nat.cast_nonneg d)]
          ring
  calc вИС d вИИ Icc 1 z, вИС e вИИ Icc 1 (z / d), (1 : вДЭ) / Real.sqrt ((d, e).1 * (d, e).2)
      вЙ§ вИС d вИИ Icc 1 z, (1 / (d : вДЭ)) * (2 * Real.sqrt z) := Finset.sum_le_sum hrow
    _ = (вИС d вИИ Icc 1 z, (1 : вДЭ) / d) * (2 * Real.sqrt z) := by
        rw [вЖР Finset.sum_mul]
    _ вЙ§ (1 + Real.log z) * (2 * Real.sqrt z) := by
        apply mul_le_mul_of_nonneg_right (sum_one_div_le_log z hz) (by positivity)
    _ = 2 * Real.sqrt z * (1 + Real.log z) := by ring

/-- **Abel rearrangement over a tail window** (Siegel brick A2c-i-a): with
    `G t = ќ£_{nвЙ§t} g n`, for `y вЙ§ z`:
    `ќ£_{y<dвЙ§z} g(d)/d = ќ£_{y<dвЙ§z} G(d)(1/d вИТ 1/(d+1)) + G(z)/(z+1) вИТ G(y)/(y+1)`. -/
lemma abel_window (g : вДХ вЖТ вДЭ) (y : вДХ) :
    вИА z : вДХ, y вЙ§ z вЖТ
    вИС d вИИ Icc (y + 1) z, g d / d
      = вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))
        + (вИС n вИИ Icc 1 z, g n) / (z + 1) - (вИС n вИИ Icc 1 y, g n) / (y + 1) := by
  intro z
  induction z with
  | zero =>
    intro hy0
    interval_cases y
    simp
  | succ m ih =>
    intro hym
    rcases Nat.lt_or_ge m y with hlt | hge
    ¬Ј -- y = m + 1: both windows empty
      have hy : y = m + 1 := by omega
      subst hy
      simp
    ¬Ј -- extend from m to m+1
      have hstepL : Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) := by
        ext x
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      have hstepG : Icc 1 (m + 1) = insert (m + 1) (Icc 1 m) := by
        ext x
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      rw [hstepL, Finset.sum_insert (by simp), Finset.sum_insert (by simp),
        hstepG, Finset.sum_insert (by simp), ih hge]
      have hm1 : ((m : вДЭ) + 1) вЙ† 0 := by positivity
      have hm2 : ((m : вДЭ) + 1 + 1) вЙ† 0 := by positivity
      push_cast
      field_simp
      ring

/-- The telescoping kernel sum: `ќ£_{y<dвЙ§z} (1/d вИТ 1/(d+1)) = 1/(y+1) вИТ 1/(z+1)`. -/
lemma telescope_kernel (y : вДХ) : вИА z : вДХ, y вЙ§ z вЖТ
    вИС d вИИ Icc (y + 1) z, ((1 : вДЭ) / d - 1 / (d + 1)) = 1 / (y + 1) - 1 / (z + 1) := by
  intro z
  induction z with
  | zero =>
    intro hy0
    interval_cases y
    simp
  | succ m ihm =>
    intro hym
    rcases Nat.lt_or_ge m y with hlt | hge
    ¬Ј have hy : y = m + 1 := by omega
      subst hy
      simp
    ¬Ј have hstep : Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) := by
        ext x
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      rw [hstep, Finset.sum_insert (by simp), ihm hge]
      push_cast
      have hm1 : ((m : вДЭ) + 1) вЙ† 0 := by positivity
      have hm2 : ((m : вДЭ) + 1 + 1) вЙ† 0 := by positivity
      field_simp
      ring

/-- **The bounded-sum Abel tail bound** (Siegel brick A2c-i): if all partial sums of `g`
    are bounded by `q`, the tail `ќ£_{y<dвЙ§z} g(d)/d` is at most `2q/(y+1)` вАФ uniformly
    in `z`. The engine of both `ќ£_{dвЙ§y} g(d)/d`'s convergence and its tail rate. -/
lemma abel_tail_bound (g : вДХ вЖТ вДЭ) (q : вДЭ)
    (hG : вИА t : вДХ, |вИС n вИИ Icc 1 t, g n| вЙ§ q) (y z : вДХ) (hyz : y вЙ§ z) :
    |вИС d вИИ Icc (y + 1) z, g d / d| вЙ§ 2 * q / (y + 1) := by
  have hq : 0 вЙ§ q := le_trans (abs_nonneg _) (hG 0)
  rw [abel_window g y z hyz]
  have hterm : вИА d вИИ Icc (y + 1) z,
      |(вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))|
        вЙ§ q * ((1 : вДЭ) / d - 1 / (d + 1)) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hd0 : (0:вДЭ) < d := by
      have : (1:вДХ) вЙ§ d := by omega
      exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_one this
    have hker : (0:вДЭ) вЙ§ 1 / (d : вДЭ) - 1 / (d + 1) := by
      rw [sub_nonneg, div_le_div_iffвВА (by positivity) hd0]
      linarith
    rw [abs_mul, abs_of_nonneg hker]
    exact mul_le_mul_of_nonneg_right (hG d) hker
  have htele := telescope_kernel y z hyz
  calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))
        + (вИС n вИИ Icc 1 z, g n) / (z + 1) - (вИС n вИИ Icc 1 y, g n) / (y + 1)|
      вЙ§ |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))|
        + |(вИС n вИИ Icc 1 z, g n) / (z + 1)| + |(вИС n вИИ Icc 1 y, g n) / (y + 1)| := by
        set A := вИС d вИИ Icc (y + 1) z,
          (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1)) with hA
        set B := (вИС n вИИ Icc 1 z, g n) / ((z:вДЭ) + 1) with hB
        set C := (вИС n вИИ Icc 1 y, g n) / ((y:вДЭ) + 1) with hC
        have h1 : |A + B| вЙ§ |A| + |B| := abs_add_le A B
        have h2 : |A + B - C| вЙ§ |A + B| + |C| := by
          rw [sub_eq_add_neg]
          have := abs_add_le (A + B) (-C)
          rwa [abs_neg] at this
        linarith [h1, h2]
    _ вЙ§ (q * ((1:вДЭ) / (y + 1) - 1 / (z + 1))) + q / (z + 1) + q / (y + 1) := by
        have hs : |вИС d вИИ Icc (y + 1) z,
            (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))|
            вЙ§ q * ((1:вДЭ) / (y + 1) - 1 / (z + 1)) := by
          calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))|
              вЙ§ вИС d вИИ Icc (y + 1) z, |(вИС n вИИ Icc 1 d, g n) * ((1 : вДЭ) / d - 1 / (d + 1))| :=
                Finset.abs_sum_le_sum_abs _ _
            _ вЙ§ вИС d вИИ Icc (y + 1) z, q * ((1 : вДЭ) / d - 1 / (d + 1)) :=
                Finset.sum_le_sum hterm
            _ = q * ((1:вДЭ) / (y + 1) - 1 / (z + 1)) := by
                rw [вЖР Finset.mul_sum, htele]
        have hz1 : |(вИС n вИИ Icc 1 z, g n) / ((z:вДЭ) + 1)| вЙ§ q / (z + 1) := by
          rw [abs_div, abs_of_pos (by positivity : (0:вДЭ) < (z:вДЭ) + 1)]
          apply div_le_div_of_nonneg_right (hG z) (by positivity)
        have hy1 : |(вИС n вИИ Icc 1 y, g n) / ((y:вДЭ) + 1)| вЙ§ q / (y + 1) := by
          rw [abs_div, abs_of_pos (by positivity : (0:вДЭ) < (y:вДЭ) + 1)]
          apply div_le_div_of_nonneg_right (hG y) (by positivity)
        linarith [hs, hz1, hy1]
    _ вЙ§ 2 * q / (y + 1) := by
        have hzq : (0:вДЭ) вЙ§ q / (z + 1) := by positivity
        have h1 : q * ((1:вДЭ) / (y + 1) - 1 / (z + 1)) + q / (z + 1) = q / (y + 1) := by
          field_simp
          ring
        have h2 : q / ((y:вДЭ) + 1) + q / (y + 1) = 2 * q / (y + 1) := by ring
        linarith [h1, h2]

/-- Prefix-sum difference over `Icc 1`: `ќ£_{вЙ§z} вИТ ќ£_{вЙ§y} = ќ£_{y<¬ЈвЙ§z}`. -/
lemma sum_Icc_split (F : вДХ вЖТ вДЭ) (y z : вДХ) (hyz : y вЙ§ z) :
    вИС d вИИ Icc 1 z, F d - вИС d вИИ Icc 1 y, F d = вИС d вИИ Icc (y + 1) z, F d := by
  have hIcoIcc : вИА a b : вДХ, Ico a (b + 1) = Icc a b := by
    intro a b
    ext x
    simp only [Finset.mem_Ico, Finset.mem_Icc]
    omega
  rw [вЖР hIcoIcc 1 z,
    вЖР Finset.sum_Ico_consecutive F (by omega : 1 вЙ§ y + 1) (by omega : y + 1 вЙ§ z + 1),
    hIcoIcc 1 y, hIcoIcc (y + 1) z, add_sub_cancel_left]

/-- **The logarithmic mean exists with a tail rate** (Siegel brick A2c-ii): if every
    partial sum of `g` is bounded by `q`, then `S_y = ќ£_{dвЙ§y} g(d)/d` converges to some
    `L` with `|L вИТ S_y| вЙ§ 2q/(y+1)` for every `y` вАФ the abstract `L(1,ѕЗ)` of the
    hyperbola main term. -/
theorem log_mean_exists (g : вДХ вЖТ вДЭ) (q : вДЭ)
    (hG : вИА t : вДХ, |вИС n вИИ Icc 1 t, g n| вЙ§ q) :
    вИГ L : вДЭ, вИА y : вДХ, |L - вИС d вИИ Icc 1 y, g d / d| вЙ§ 2 * q / (y + 1) := by
  have hq : 0 вЙ§ q := le_trans (abs_nonneg _) (hG 0)
  set S : вДХ вЖТ вДЭ := fun y => вИС d вИИ Icc 1 y, g d / d with hS
  have hdiff : вИА y z : вДХ, y вЙ§ z вЖТ |S z - S y| вЙ§ 2 * q / (y + 1) := by
    intro y z hyz
    rw [hS]
    simp only
    rw [sum_Icc_split (fun d => g d / d) y z hyz]
    exact abel_tail_bound g q hG y z hyz
  have hb0 : Filter.Tendsto (fun N : вДХ => 2 * q / ((N : вДЭ) + 1))
      Filter.atTop (nhds 0) := by
    have h1 : Filter.Tendsto (fun N : вДХ => ((N : вДЭ) + 1)) Filter.atTop Filter.atTop := by
      apply Filter.tendsto_atTop_add_const_right
      exact tendsto_natCast_atTop_atTop
    have h2 := Filter.Tendsto.div_atTop (tendsto_const_nhds (x := 2 * q)) h1
    simpa using h2
  have hcauchy : CauchySeq S := by
    apply cauchySeq_of_le_tendsto_0 (b := fun N : вДХ => 2 * q / ((N : вДЭ) + 1)) _ hb0
    intro n m N hn hm
    rw [Real.dist_eq]
    rcases le_total n m with h | h
    ¬Ј rw [abs_sub_comm]
      calc |S m - S n| вЙ§ 2 * q / ((n : вДЭ) + 1) := hdiff n m h
        _ вЙ§ 2 * q / ((N : вДЭ) + 1) := by
            apply div_le_div_of_nonneg_left (by linarith) (by positivity)
            exact_mod_cast Nat.add_le_add_right hn 1
    ¬Ј calc |S n - S m| вЙ§ 2 * q / ((m : вДЭ) + 1) := hdiff m n h
        _ вЙ§ 2 * q / ((N : вДЭ) + 1) := by
            apply div_le_div_of_nonneg_left (by linarith) (by positivity)
            exact_mod_cast Nat.add_le_add_right hm 1
  obtain вЯ®L, hLвЯ© := cauchySeq_tendsto_of_complete hcauchy
  refine вЯ®L, ?_вЯ©
  intro y
  have htend : Filter.Tendsto (fun z : вДХ => |S z - S y|) Filter.atTop
      (nhds (|L - S y|)) := by
    apply Filter.Tendsto.abs
    exact Filter.Tendsto.sub_const hL (S y)
  apply le_of_tendsto htend
  filter_upwards [Filter.eventually_ge_atTop y] with z hz
  exact hdiff y z hz

/-- Partial sums of the packaged constant-one function count the interval. -/
lemma sum_toArith_one (M : вДХ) :
    вИС e вИИ Icc 1 M, toArith (fun _ => (1:вДЭ)) e = (M : вДЭ) := by
  have hterm : вИА e вИИ Icc 1 M, toArith (fun _ => (1:вДЭ)) e = 1 := by
    intro e he
    obtain вЯ®he1, _вЯ© := Finset.mem_Icc.mp he
    rw [toArith_apply _ _ (by omega)]
  rw [Finset.sum_congr rfl hterm, Finset.sum_const, Nat.card_Icc]
  simp

/-- **The divisor-character asymptotic** (Siegel brick A2c-iii): for `g` with values
    bounded by 1, partial sums bounded by `q`, and logarithmic mean `L`,
    `|ќ£_{nвЙ§N}(gвЛЖ1)(n) вИТ L¬ЈN| вЙ§ (1+4q)¬Ј(вИЪN + 1)` вАФ the `HвВБ(t) = L(1,ѕЗ)t + O(qвИЪt)`
    input of the hyperbola method, with the split at `y = вМКвИЪNвМЛ`. -/
theorem divisor_char_asymptotic (g : вДХ вЖТ вДЭ) (q L : вДЭ)
    (hgb : вИА n, |g n| вЙ§ 1)
    (hG : вИА t : вДХ, |вИС n вИИ Icc 1 t, g n| вЙ§ q)
    (hL : вИА y : вДХ, |L - вИС d вИИ Icc 1 y, g d / d| вЙ§ 2 * q / (y + 1))
    (N : вДХ) (hN : 1 вЙ§ N) :
    |вИС n вИИ Icc 1 N, (toArith g * toArith (fun _ => (1:вДЭ))) n - L * N|
      вЙ§ (1 + 4 * q) * (Real.sqrt N + 1) := by
  have hq : 0 вЙ§ q := le_trans (abs_nonneg _) (hG 0)
  set y : вДХ := Nat.sqrt N with hy
  have hyN : y вЙ§ N := Nat.sqrt_le_self N
  rw [hyperbola_identity _ _ N y hyN]
  -- head with the floor split
  have hhead : вИА d вИИ Icc 1 y, toArith g d * (вИС e вИИ Icc 1 (N / d), toArith (fun _ => (1:вДЭ)) e)
      = g d * ((N / d : вДХ) : вДЭ) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    rw [sum_toArith_one, toArith_apply _ _ (by omega)]
  rw [Finset.sum_congr rfl hhead]
  -- decompose вМКN/dвМЛ = N/d вИТ frac(d)
  have hfloor : вИА d вИИ Icc 1 y, g d * ((N / d : вДХ) : вДЭ)
      = (N : вДЭ) * (g d / d) - g d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ)) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hd0 : ((d:вДЭ)) вЙ† 0 := by
      have : (0:вДЭ) < d := by exact_mod_cast hd1
      linarith
    field_simp
    ring
  rw [Finset.sum_congr rfl hfloor, Finset.sum_sub_distrib, вЖР Finset.mul_sum]
  -- name the pieces
  set S : вДЭ := вИС d вИИ Icc 1 y, g d / d with hS
  set FR : вДЭ := вИС d вИИ Icc 1 y, g d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ)) with hFR
  set T : вДЭ := вИС e вИИ Icc 1 (N / (y + 1)), toArith (fun _ => (1:вДЭ)) e
      * ((вИС d вИИ Icc 1 (N / e), toArith g d) - вИС d вИИ Icc 1 y, toArith g d) with hT
  -- bound the fractional-part sum: |FR| вЙ§ y
  have hFRb : |FR| вЙ§ y := by
    rw [hFR]
    calc |вИС d вИИ Icc 1 y, g d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ))|
        вЙ§ вИС d вИИ Icc 1 y, |g d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ))| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc 1 y, 1 := by
          apply Finset.sum_le_sum
          intro d hd
          obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
          have hd0 : (0:вДЭ) < d := by exact_mod_cast hd1
          rw [abs_mul]
          have hfr0 : (0:вДЭ) вЙ§ (N : вДЭ) / d - ((N / d : вДХ) : вДЭ) := by
            rw [sub_nonneg]
            exact Nat.cast_div_le
          have hfr1 : (N : вДЭ) / d - ((N / d : вДХ) : вДЭ) вЙ§ 1 := by
            have hlt : (N : вДЭ) / d < ((N / d : вДХ) : вДЭ) + 1 := by
              rw [div_lt_iffвВА hd0]
              have hnat : N < (N / d + 1) * d := by
                have hexp : (N / d + 1) * d = d * (N / d) + d := by ring
                rw [hexp]
                have h1 := Nat.div_add_mod N d
                have h2 := Nat.mod_lt N (show 0 < d by omega)
                omega
              exact_mod_cast hnat
            linarith
          rw [abs_of_nonneg hfr0]
          nlinarith [hgb d, hfr0, hfr1, abs_nonneg (g d)]
      _ вЙ§ (y : вДЭ) := by
          rw [Finset.sum_const, Nat.card_Icc, Nat.add_sub_cancel, nsmul_eq_mul, mul_one]
  -- bound the tail: |T| вЙ§ 2q ¬Ј N/(y+1)
  have hTb : |T| вЙ§ 2 * q * ((N / (y + 1) : вДХ) : вДЭ) := by
    rw [hT]
    calc |вИС e вИИ Icc 1 (N / (y + 1)), toArith (fun _ => (1:вДЭ)) e
          * ((вИС d вИИ Icc 1 (N / e), toArith g d) - вИС d вИИ Icc 1 y, toArith g d)|
        вЙ§ вИС e вИИ Icc 1 (N / (y + 1)), |toArith (fun _ => (1:вДЭ)) e
          * ((вИС d вИИ Icc 1 (N / e), toArith g d) - вИС d вИИ Icc 1 y, toArith g d)| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС e вИИ Icc 1 (N / (y + 1)), 2 * q := by
          apply Finset.sum_le_sum
          intro e he
          obtain вЯ®he1, _вЯ© := Finset.mem_Icc.mp he
          have hone : toArith (fun _ => (1:вДЭ)) e = 1 := toArith_apply _ _ (by omega)
          rw [hone, one_mul]
          have hsg : вИА t : вДХ, вИС d вИИ Icc 1 t, toArith g d = вИС d вИИ Icc 1 t, g d := by
            intro t
            apply Finset.sum_congr rfl
            intro d hd
            obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
            exact toArith_apply _ _ (by omega)
          rw [hsg, hsg]
          calc |вИС d вИИ Icc 1 (N / e), g d - вИС d вИИ Icc 1 y, g d|
              вЙ§ |вИС d вИИ Icc 1 (N / e), g d| + |вИС d вИИ Icc 1 y, g d| := by
                have := abs_add_le (вИС d вИИ Icc 1 (N / e), g d) (-(вИС d вИИ Icc 1 y, g d))
                rwa [abs_neg, вЖР sub_eq_add_neg] at this
            _ вЙ§ q + q := add_le_add (hG _) (hG _)
            _ = 2 * q := by ring
      _ = 2 * q * ((N / (y + 1) : вДХ) : вДЭ) := by
          rw [Finset.sum_const, Nat.card_Icc, Nat.add_sub_cancel, nsmul_eq_mul]
          ring
  -- bound the mean deviation: |N¬ЈS вИТ N¬ЈL| вЙ§ 2qN/(y+1)
  have hSL : |(N : вДЭ) * S - L * N| вЙ§ (N : вДЭ) * (2 * q / (y + 1)) := by
    have h := hL y
    calc |(N : вДЭ) * S - L * N| = (N : вДЭ) * |L - S| := by
          rw [show (N : вДЭ) * S - L * N = -((N:вДЭ) * (L - S)) by ring, abs_neg, abs_mul,
            abs_of_nonneg (by positivity : (0:вДЭ) вЙ§ (N:вДЭ))]
      _ вЙ§ (N : вДЭ) * (2 * q / (y + 1)) := by
          apply mul_le_mul_of_nonneg_left h (by positivity)
  -- the вИЪN conversions
  have hyle : (y : вДЭ) вЙ§ Real.sqrt N := by
    rw [hy]
    have h1 : ((Nat.sqrt N : вДЭ)) ^ 2 вЙ§ (N : вДЭ) := by
      exact_mod_cast Nat.sqrt_le' N
    exact Real.le_sqrt_of_sq_le h1
  have hNdiv : ((N / (y + 1) : вДХ) : вДЭ) вЙ§ Real.sqrt N := by
    have h1 : ((N / (y + 1) : вДХ) : вДЭ) вЙ§ (N : вДЭ) / ((y : вДЭ) + 1) := by
      have := Nat.cast_div_le (ќ± := вДЭ) (m := N) (n := y + 1)
      push_cast at this
      exact this
    have h2 : (N : вДЭ) / ((y : вДЭ) + 1) вЙ§ Real.sqrt N := by
      rw [div_le_iffвВА (by positivity)]
      have hsq : Real.sqrt N * Real.sqrt N = (N : вДЭ) :=
        Real.mul_self_sqrt (Nat.cast_nonneg N)
      have hy1 : Real.sqrt N вЙ§ (y : вДЭ) + 1 := by
        rw [hy]
        have := Nat.lt_succ_sqrt' N
        have hcast : (N : вДЭ) < ((Nat.sqrt N : вДЭ) + 1) ^ 2 := by
          push_cast
          exact_mod_cast this
        nlinarith [Real.sqrt_nonneg (N : вДЭ), Real.sq_sqrt (Nat.cast_nonneg N),
          Real.sqrt_nonneg (N:вДЭ), hcast]
      nlinarith [Real.sqrt_nonneg (N : вДЭ)]
    linarith
  have hNy1 : (N : вДЭ) * (2 * q / (y + 1)) вЙ§ 2 * q * Real.sqrt N := by
    rw [mul_div_assoc']
    rw [div_le_iffвВА (by positivity : (0:вДЭ) < (y:вДЭ) + 1)]
    have hy1 : Real.sqrt N вЙ§ (y : вДЭ) + 1 := by
      rw [hy]
      have := Nat.lt_succ_sqrt' N
      have hcast : (N : вДЭ) < ((Nat.sqrt N : вДЭ) + 1) ^ 2 := by
        push_cast
        exact_mod_cast this
      nlinarith [Real.sqrt_nonneg (N : вДЭ), Real.sq_sqrt (Nat.cast_nonneg N), hcast]
    have hsq : Real.sqrt N * Real.sqrt N = (N : вДЭ) :=
      Real.mul_self_sqrt (Nat.cast_nonneg N)
    have hkey : Real.sqrt N * Real.sqrt N вЙ§ Real.sqrt N * ((y:вДЭ) + 1) :=
      mul_le_mul_of_nonneg_left hy1 (Real.sqrt_nonneg _)
    nlinarith [Real.sqrt_nonneg (N : вДЭ), hq, hkey, hsq]
  -- assemble
  have hgoal : |(N : вДЭ) * S - FR + T - L * N| вЙ§ (1 + 4*q) * (Real.sqrt N + 1) := by
    have h1 : |(N : вДЭ) * S - FR + T - L * N|
        вЙ§ |(N : вДЭ) * S - L * N| + |FR| + |T| := by
      have ha := abs_add_le ((N : вДЭ) * S - L * N) (-FR)
      have hb := abs_add_le ((N : вДЭ) * S - L * N + -FR) T
      rw [abs_neg] at ha
      have hrw : (N : вДЭ) * S - FR + T - L * N = ((N : вДЭ) * S - L * N + -FR) + T := by
        ring
      rw [hrw]
      calc |((N : вДЭ) * S - L * N + -FR) + T|
          вЙ§ |(N : вДЭ) * S - L * N + -FR| + |T| := abs_add_le _ _
        _ вЙ§ |(N : вДЭ) * S - L * N| + |FR| + |T| := by linarith [ha]
    calc |(N : вДЭ) * S - FR + T - L * N|
        вЙ§ |(N : вДЭ) * S - L * N| + |FR| + |T| := h1
      _ вЙ§ (N : вДЭ) * (2 * q / (y + 1)) + (y : вДЭ) + 2 * q * ((N / (y + 1) : вДХ) : вДЭ) := by
          linarith [hSL, hFRb, hTb]
      _ вЙ§ 2 * q * Real.sqrt N + Real.sqrt N + 2 * q * Real.sqrt N := by
          have h3 : 2 * q * ((N / (y + 1) : вДХ) : вДЭ) вЙ§ 2 * q * Real.sqrt N :=
            mul_le_mul_of_nonneg_left hNdiv (by linarith)
          linarith [hNy1, hyle, h3]
      _ вЙ§ (1 + 4*q) * (Real.sqrt N + 1) := by
          have hs0 : 0 вЙ§ Real.sqrt N := Real.sqrt_nonneg _
          nlinarith [hq, hs0]
  exact hgoal

/-- **The doubly-bounded convolution has вИЪ-size partial sums** (Siegel brick A2d):
    if `kвВБ, kвВВ` have values bounded by 1 and partial sums bounded by `qвВБ, qвВВ`, then
    `|ќ£_{nвЙ§t}(kвВБвЛЖkвВВ)(n)| вЙ§ (2qвВБ+qвВВ)(вИЪt+1)` вАФ the `K(t) вЙ™ Q¬≤вИЪt` bound for
    `k = ѕЗвВВ вЛЖ (ѕЗвВБѕЗвВВ)`, whose L-series has no pole. -/
theorem bounded_conv_sqrt_bound (kвВБ kвВВ : вДХ вЖТ вДЭ) (qвВБ qвВВ : вДЭ)
    (h1b : вИА n, |kвВБ n| вЙ§ 1) (h2b : вИА n, |kвВВ n| вЙ§ 1)
    (hK1 : вИА t : вДХ, |вИС n вИИ Icc 1 t, kвВБ n| вЙ§ qвВБ)
    (hK2 : вИА t : вДХ, |вИС n вИИ Icc 1 t, kвВВ n| вЙ§ qвВВ)
    (t : вДХ) :
    |вИС n вИИ Icc 1 t, (toArith kвВБ * toArith kвВВ) n| вЙ§ (2 * qвВБ + qвВВ) * (Real.sqrt t + 1) := by
  have hq1 : 0 вЙ§ qвВБ := le_trans (abs_nonneg _) (hK1 0)
  have hq2 : 0 вЙ§ qвВВ := le_trans (abs_nonneg _) (hK2 0)
  set y : вДХ := Nat.sqrt t with hy
  have hyt : y вЙ§ t := Nat.sqrt_le_self t
  rw [hyperbola_identity _ _ t y hyt]
  have hsg : вИА (k : вДХ вЖТ вДЭ) (M : вДХ), вИС d вИИ Icc 1 M, toArith k d = вИС d вИИ Icc 1 M, k d := by
    intro k M
    apply Finset.sum_congr rfl
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    exact toArith_apply _ _ (by omega)
  -- the вИЪ conversions (as in A2c-iii)
  have hyle : (y : вДЭ) вЙ§ Real.sqrt t := by
    rw [hy]
    have h1 : ((Nat.sqrt t : вДЭ)) ^ 2 вЙ§ (t : вДЭ) := by exact_mod_cast Nat.sqrt_le' t
    exact Real.le_sqrt_of_sq_le h1
  have hy1 : Real.sqrt t вЙ§ (y : вДЭ) + 1 := by
    rw [hy]
    have hlt := Nat.lt_succ_sqrt' t
    have hcast : (t : вДЭ) < ((Nat.sqrt t : вДЭ) + 1) ^ 2 := by
      push_cast
      exact_mod_cast hlt
    nlinarith [Real.sqrt_nonneg (t : вДЭ), Real.sq_sqrt (Nat.cast_nonneg t), hcast]
  have hNdiv : ((t / (y + 1) : вДХ) : вДЭ) вЙ§ Real.sqrt t := by
    have h1 : ((t / (y + 1) : вДХ) : вДЭ) вЙ§ (t : вДЭ) / ((y : вДЭ) + 1) := by
      have := Nat.cast_div_le (ќ± := вДЭ) (m := t) (n := y + 1)
      push_cast at this
      exact this
    have h2 : (t : вДЭ) / ((y : вДЭ) + 1) вЙ§ Real.sqrt t := by
      rw [div_le_iffвВА (by positivity)]
      have hsq : Real.sqrt t * Real.sqrt t = (t : вДЭ) :=
        Real.mul_self_sqrt (Nat.cast_nonneg t)
      nlinarith [Real.sqrt_nonneg (t : вДЭ), hy1, hsq]
    linarith
  -- head bound
  have hhead : |вИС d вИИ Icc 1 y, toArith kвВБ d * (вИС e вИИ Icc 1 (t / d), toArith kвВВ e)|
      вЙ§ (y : вДЭ) * qвВВ := by
    calc |вИС d вИИ Icc 1 y, toArith kвВБ d * (вИС e вИИ Icc 1 (t / d), toArith kвВВ e)|
        вЙ§ вИС d вИИ Icc 1 y, |toArith kвВБ d * (вИС e вИИ Icc 1 (t / d), toArith kвВВ e)| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc 1 y, qвВВ := by
          apply Finset.sum_le_sum
          intro d hd
          obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
          rw [abs_mul, toArith_apply _ _ (by omega), hsg]
          calc |kвВБ d| * |вИС e вИИ Icc 1 (t / d), kвВВ e| вЙ§ 1 * qвВВ :=
              mul_le_mul (h1b d) (hK2 _) (abs_nonneg _) zero_le_one
            _ = qвВВ := one_mul qвВВ
      _ = (y : вДЭ) * qвВВ := by
          rw [Finset.sum_const, Nat.card_Icc, Nat.add_sub_cancel, nsmul_eq_mul]
  -- tail bound
  have htail : |вИС e вИИ Icc 1 (t / (y + 1)), toArith kвВВ e
      * ((вИС d вИИ Icc 1 (t / e), toArith kвВБ d) - вИС d вИИ Icc 1 y, toArith kвВБ d)|
      вЙ§ ((t / (y + 1) : вДХ) : вДЭ) * (2 * qвВБ) := by
    calc |вИС e вИИ Icc 1 (t / (y + 1)), toArith kвВВ e
        * ((вИС d вИИ Icc 1 (t / e), toArith kвВБ d) - вИС d вИИ Icc 1 y, toArith kвВБ d)|
        вЙ§ вИС e вИИ Icc 1 (t / (y + 1)), |toArith kвВВ e
          * ((вИС d вИИ Icc 1 (t / e), toArith kвВБ d) - вИС d вИИ Icc 1 y, toArith kвВБ d)| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС e вИИ Icc 1 (t / (y + 1)), 2 * qвВБ := by
          apply Finset.sum_le_sum
          intro e he
          obtain вЯ®he1, _вЯ© := Finset.mem_Icc.mp he
          rw [abs_mul, toArith_apply _ _ (by omega), hsg, hsg]
          have hdiff : |вИС d вИИ Icc 1 (t / e), kвВБ d - вИС d вИИ Icc 1 y, kвВБ d| вЙ§ 2 * qвВБ := by
            have h := abs_add_le (вИС d вИИ Icc 1 (t / e), kвВБ d) (-(вИС d вИИ Icc 1 y, kвВБ d))
            rw [abs_neg, вЖР sub_eq_add_neg] at h
            calc |вИС d вИИ Icc 1 (t / e), kвВБ d - вИС d вИИ Icc 1 y, kвВБ d|
                вЙ§ |вИС d вИИ Icc 1 (t / e), kвВБ d| + |вИС d вИИ Icc 1 y, kвВБ d| := h
              _ вЙ§ qвВБ + qвВБ := add_le_add (hK1 _) (hK1 _)
              _ = 2 * qвВБ := by ring
          calc |kвВВ e| * |вИС d вИИ Icc 1 (t / e), kвВБ d - вИС d вИИ Icc 1 y, kвВБ d|
              вЙ§ 1 * (2 * qвВБ) := mul_le_mul (h2b e) hdiff (abs_nonneg _) zero_le_one
            _ = 2 * qвВБ := one_mul _
      _ = ((t / (y + 1) : вДХ) : вДЭ) * (2 * qвВБ) := by
          rw [Finset.sum_const, Nat.card_Icc, Nat.add_sub_cancel, nsmul_eq_mul]
  -- assemble
  calc |вИС d вИИ Icc 1 y, toArith kвВБ d * (вИС e вИИ Icc 1 (t / d), toArith kвВВ e)
        + вИС e вИИ Icc 1 (t / (y + 1)), toArith kвВВ e
          * ((вИС d вИИ Icc 1 (t / e), toArith kвВБ d) - вИС d вИИ Icc 1 y, toArith kвВБ d)|
      вЙ§ |вИС d вИИ Icc 1 y, toArith kвВБ d * (вИС e вИИ Icc 1 (t / d), toArith kвВВ e)|
        + |вИС e вИИ Icc 1 (t / (y + 1)), toArith kвВВ e
          * ((вИС d вИИ Icc 1 (t / e), toArith kвВБ d) - вИС d вИИ Icc 1 y, toArith kвВБ d)| :=
        abs_add_le _ _
    _ вЙ§ (y : вДЭ) * qвВВ + ((t / (y + 1) : вДХ) : вДЭ) * (2 * qвВБ) := add_le_add hhead htail
    _ вЙ§ Real.sqrt t * qвВВ + Real.sqrt t * (2 * qвВБ) := by
        apply add_le_add
        ¬Ј exact mul_le_mul_of_nonneg_right hyle hq2
        ¬Ј apply mul_le_mul_of_nonneg_right hNdiv (by linarith)
    _ вЙ§ (2 * qвВБ + qвВВ) * (Real.sqrt t + 1) := by
        have hs0 : 0 вЙ§ Real.sqrt t := Real.sqrt_nonneg _
        nlinarith [hq1, hq2, hs0]

/-- Sharp 3/2-power telescoping (Siegel brick A2e-i-a):
    `ќ£_{y<dвЙ§z} 1/(dвИЪd) вЙ§ 2/вИЪy вИТ 2/вИЪz` for `1 вЙ§ y вЙ§ z` вАФ from the previous-interval
    comparison `1/(dвИЪd) вЙ§ 2(1/вИЪ(dвИТ1) вИТ 1/вИЪd)`. -/
lemma sum_three_half_tail_sharp (y : вДХ) (hy1 : 1 вЙ§ y) : вИА z : вДХ, y вЙ§ z вЖТ
    вИС d вИИ Icc (y + 1) z, (1 : вДЭ) / (d * Real.sqrt d)
      вЙ§ 2 / Real.sqrt y - 2 / Real.sqrt z := by
  intro z
  induction z with
  | zero =>
    intro hy0
    omega
  | succ m ihm =>
    intro hym
    rcases Nat.lt_or_ge m y with hlt | hge
    ¬Ј -- y = m + 1: empty window, RHS = 0
      have hy : y = m + 1 := by omega
      subst hy
      simp
    ¬Ј -- extend from m to m+1; m вЙ• y вЙ• 1
      have hm1 : 1 вЙ§ m := le_trans hy1 hge
      have hstep : Icc (y + 1) (m + 1) = insert (m + 1) (Icc (y + 1) m) := by
        ext x
        simp only [Finset.mem_insert, Finset.mem_Icc]
        omega
      rw [hstep, Finset.sum_insert (by simp)]
      have hm0 : (0:вДЭ) < (m : вДЭ) := by exact_mod_cast hm1
      have hm10 : (0:вДЭ) < (m : вДЭ) + 1 := by linarith
      set a : вДЭ := Real.sqrt m with ha
      set b : вДЭ := Real.sqrt ((m : вДЭ) + 1) with hb
      have hs1 : (0:вДЭ) < a := Real.sqrt_pos.mpr hm0
      have hs2 : (0:вДЭ) < b := Real.sqrt_pos.mpr hm10
      have hsq1 : a * a = (m : вДЭ) := Real.mul_self_sqrt hm0.le
      have hsq2 : b * b = (m : вДЭ) + 1 := Real.mul_self_sqrt hm10.le
      have hmono : a вЙ§ b := Real.sqrt_le_sqrt (by linarith)
      have hba : b * b - a * a = 1 := by linarith [hsq1, hsq2]
      have hkey : (1 : вДЭ) / (((m + 1 : вДХ) : вДЭ) * Real.sqrt ((m + 1 : вДХ) : вДЭ))
          вЙ§ 2 / a - 2 / b := by
        have hcast : ((m + 1 : вДХ) : вДЭ) = (m : вДЭ) + 1 := by push_cast; ring
        rw [hcast, вЖР hb]
        rw [div_sub_div _ _ (ne_of_gt hs1) (ne_of_gt hs2),
          div_le_div_iffвВА (by positivity) (by positivity)]
        -- goal: 1¬Ј(a¬Јb) вЙ§ (2b вИТ 2a)¬Ј((m+1)¬Јb); with m+1 = b¬≤, reduces to ab вЙ§ m+2
        have hab : a * b вЙ§ b * b := mul_le_mul_of_nonneg_right hmono hs2.le
        nlinarith [hab, hba, hsq1, hsq2, hs1, hs2, hmono,
          mul_pos hs1 hs2, mul_nonneg (mul_nonneg (sub_nonneg.mpr hmono) hs2.le) hs2.le,
          mul_le_mul_of_nonneg_right hab hs2.le]
      have hih := ihm hge
      have hccast : ((m + 1 : вДХ) : вДЭ) = (m : вДЭ) + 1 := by push_cast; ring
      have hsm : Real.sqrt ((m : вДХ) : вДЭ) = a := rfl
      calc (1 : вДЭ) / (((m + 1 : вДХ) : вДЭ) * Real.sqrt ((m + 1 : вДХ) : вДЭ))
            + вИС d вИИ Icc (y + 1) m, (1 : вДЭ) / (d * Real.sqrt d)
          вЙ§ (2 / a - 2 / b) + (2 / Real.sqrt y - 2 / a) :=
            add_le_add hkey hih
        _ = 2 / Real.sqrt y - 2 / b := by ring
        _ = 2 / Real.sqrt y - 2 / Real.sqrt ((m + 1 : вДХ) : вДЭ) := by
            rw [show Real.sqrt ((m + 1 : вДХ) : вДЭ) = b from by rw [hccast]]

/-- Boundary helper: `(вИЪt+1)/(t+1) вЙ§ 2/вИЪt` for `t вЙ• 1`. -/
lemma sqrt_boundary_le (t : вДХ) (ht : 1 вЙ§ t) :
    (Real.sqrt t + 1) / ((t : вДЭ) + 1) вЙ§ 2 / Real.sqrt t := by
  have ht0 : (0:вДЭ) < t := by exact_mod_cast ht
  have hs : (0:вДЭ) < Real.sqrt t := Real.sqrt_pos.mpr ht0
  have hsq : Real.sqrt t * Real.sqrt t = (t : вДЭ) := Real.mul_self_sqrt ht0.le
  have hs1 : (1:вДЭ) вЙ§ Real.sqrt t :=
    Real.one_le_sqrt.mpr (by exact_mod_cast ht)
  rw [div_le_div_iffвВА (by positivity) hs]
  nlinarith [hsq, hs1, hs]

/-- **The вИЪ-growth Abel tail** (Siegel brick A2e-ii-a): if the partial sums of `k`
    satisfy `|K(t)| вЙ§ B(вИЪt+1)`, then `|ќ£_{y<dвЙ§z} k(d)/d| вЙ§ 7B/вИЪy` for `1 вЙ§ y вЙ§ z` вАФ
    the tail engine for the pole-free convolution side of the Goldfeld product. -/
theorem abel_tail_sqrt (k : вДХ вЖТ вДЭ) (B : вДЭ)
    (hK : вИА t : вДХ, |вИС n вИИ Icc 1 t, k n| вЙ§ B * (Real.sqrt t + 1))
    (y z : вДХ) (hy1 : 1 вЙ§ y) (hyz : y вЙ§ z) :
    |вИС d вИИ Icc (y + 1) z, k d / d| вЙ§ 7 * B / Real.sqrt y := by
  have hB : 0 вЙ§ B := by
    have h0 := hK 0
    simp at h0
    linarith [abs_nonneg (вИС n вИИ Icc 1 0, k n), h0]
  have hy0 : (0:вДЭ) < y := by exact_mod_cast hy1
  have hsy : (0:вДЭ) < Real.sqrt y := Real.sqrt_pos.mpr hy0
  have hsyz : Real.sqrt y вЙ§ Real.sqrt z := Real.sqrt_le_sqrt (by exact_mod_cast hyz)
  have hsz : (0:вДЭ) < Real.sqrt z := lt_of_lt_of_le hsy hsyz
  rw [abel_window k y z hyz]
  -- termwise: |K(d)|¬ЈќЇ_d вЙ§ B/(dвИЪd) + B¬ЈќЇ_d
  have hterm : вИА d вИИ Icc (y + 1) z,
      |(вИС n вИИ Icc 1 d, k n) * ((1 : вДЭ) / d - 1 / (d + 1))|
        вЙ§ B * ((1:вДЭ) / (d * Real.sqrt d)) + B * ((1:вДЭ) / d - 1 / (d + 1)) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hd0 : (0:вДЭ) < d := by
      have : (1:вДХ) вЙ§ d := by omega
      exact_mod_cast this
    have hsd : (0:вДЭ) < Real.sqrt d := Real.sqrt_pos.mpr hd0
    have hsqd : Real.sqrt d * Real.sqrt d = (d : вДЭ) := Real.mul_self_sqrt hd0.le
    have hker : (0:вДЭ) вЙ§ 1 / (d : вДЭ) - 1 / (d + 1) := by
      rw [sub_nonneg, div_le_div_iffвВА (by positivity) hd0]
      linarith
    have hkerid : (1 : вДЭ) / d - 1 / (d + 1) = 1 / ((d : вДЭ) * (d + 1)) := by
      field_simp
      ring
    have hsdker : Real.sqrt d * ((1:вДЭ) / d - 1 / (d + 1)) вЙ§ 1 / ((d:вДЭ) * Real.sqrt d) := by
      rw [hkerid,
        show Real.sqrt d * ((1:вДЭ) / ((d:вДЭ) * (d + 1)))
          = Real.sqrt d / ((d:вДЭ) * (d + 1)) from by ring,
        div_le_div_iffвВА (by positivity) (by positivity)]
      nlinarith [hsqd, hd0, hsd]
    rw [abs_mul, abs_of_nonneg hker]
    calc |вИС n вИИ Icc 1 d, k n| * ((1:вДЭ) / d - 1 / (d + 1))
        вЙ§ (B * (Real.sqrt d + 1)) * ((1:вДЭ) / d - 1 / (d + 1)) :=
          mul_le_mul_of_nonneg_right (hK d) hker
      _ = B * (Real.sqrt d * ((1:вДЭ) / d - 1 / (d + 1)))
          + B * ((1:вДЭ) / d - 1 / (d + 1)) := by ring
      _ вЙ§ B * ((1:вДЭ) / (d * Real.sqrt d)) + B * ((1:вДЭ) / d - 1 / (d + 1)) := by
          have := mul_le_mul_of_nonneg_left hsdker hB
          linarith
  -- the summed middle piece
  have hmid : |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * ((1 : вДЭ) / d - 1 / (d + 1))|
      вЙ§ B * (2 / Real.sqrt y) + B * (1 / ((y:вДЭ) + 1)) := by
    calc |вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * ((1 : вДЭ) / d - 1 / (d + 1))|
        вЙ§ вИС d вИИ Icc (y + 1) z, |(вИС n вИИ Icc 1 d, k n) * ((1 : вДЭ) / d - 1 / (d + 1))| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc (y + 1) z, (B * ((1:вДЭ) / (d * Real.sqrt d))
          + B * ((1:вДЭ) / d - 1 / (d + 1))) := Finset.sum_le_sum hterm
      _ = B * (вИС d вИИ Icc (y + 1) z, (1:вДЭ) / (d * Real.sqrt d))
          + B * (вИС d вИИ Icc (y + 1) z, ((1:вДЭ) / d - 1 / (d + 1))) := by
          rw [Finset.sum_add_distrib, вЖР Finset.mul_sum, вЖР Finset.mul_sum]
      _ вЙ§ B * (2 / Real.sqrt y - 2 / Real.sqrt z)
          + B * (1 / ((y:вДЭ) + 1) - 1 / ((z:вДЭ) + 1)) := by
          apply add_le_add
          ¬Ј exact mul_le_mul_of_nonneg_left (sum_three_half_tail_sharp y hy1 z hyz) hB
          ¬Ј rw [telescope_kernel y z hyz]
      _ вЙ§ B * (2 / Real.sqrt y) + B * (1 / ((y:вДЭ) + 1)) := by
          have h1 : (0:вДЭ) вЙ§ 2 / Real.sqrt z := by positivity
          have h2 : (0:вДЭ) вЙ§ 1 / ((z:вДЭ) + 1) := by positivity
          nlinarith [hB, h1, h2]
  -- boundaries
  have hbz : |(вИС n вИИ Icc 1 z, k n) / ((z:вДЭ) + 1)| вЙ§ 2 * B / Real.sqrt y := by
    rw [abs_div, abs_of_pos (by positivity : (0:вДЭ) < (z:вДЭ) + 1)]
    have h1 : |вИС n вИИ Icc 1 z, k n| / ((z:вДЭ) + 1) вЙ§ B * ((Real.sqrt z + 1) / ((z:вДЭ) + 1)) := by
      rw [mul_div_assoc'] at *
      apply div_le_div_of_nonneg_right (hK z) (by positivity)
    have h2 : (Real.sqrt z + 1) / ((z:вДЭ) + 1) вЙ§ 2 / Real.sqrt z :=
      sqrt_boundary_le z (by omega)
    have h3 : (2:вДЭ) / Real.sqrt z вЙ§ 2 / Real.sqrt y := by
      apply div_le_div_of_nonneg_left (by norm_num) hsy hsyz
    calc |вИС n вИИ Icc 1 z, k n| / ((z:вДЭ) + 1)
        вЙ§ B * ((Real.sqrt z + 1) / ((z:вДЭ) + 1)) := h1
      _ вЙ§ B * (2 / Real.sqrt y) := by
          apply mul_le_mul_of_nonneg_left _ hB
          linarith
      _ = 2 * B / Real.sqrt y := by ring
  have hby : |(вИС n вИИ Icc 1 y, k n) / ((y:вДЭ) + 1)| вЙ§ 2 * B / Real.sqrt y := by
    rw [abs_div, abs_of_pos (by positivity : (0:вДЭ) < (y:вДЭ) + 1)]
    have h1 : |вИС n вИИ Icc 1 y, k n| / ((y:вДЭ) + 1) вЙ§ B * ((Real.sqrt y + 1) / ((y:вДЭ) + 1)) := by
      rw [mul_div_assoc'] at *
      apply div_le_div_of_nonneg_right (hK y) (by positivity)
    have h2 : (Real.sqrt y + 1) / ((y:вДЭ) + 1) вЙ§ 2 / Real.sqrt y :=
      sqrt_boundary_le y hy1
    calc |вИС n вИИ Icc 1 y, k n| / ((y:вДЭ) + 1)
        вЙ§ B * ((Real.sqrt y + 1) / ((y:вДЭ) + 1)) := h1
      _ вЙ§ B * (2 / Real.sqrt y) := mul_le_mul_of_nonneg_left h2 hB
      _ = 2 * B / Real.sqrt y := by ring
  -- assemble: mid + boundaries, with 1/(y+1) вЙ§ 1/вИЪy
  have hy1r : (1:вДЭ) / ((y:вДЭ) + 1) вЙ§ 1 / Real.sqrt y := by
    apply div_le_div_of_nonneg_left one_pos.le hsy
    nlinarith [Real.mul_self_sqrt hy0.le,
      Real.one_le_sqrt.mpr (by exact_mod_cast hy1 : (1:вДЭ) вЙ§ (y:вДЭ)), hsy]
  set M := вИС d вИИ Icc (y + 1) z, (вИС n вИИ Icc 1 d, k n) * ((1 : вДЭ) / d - 1 / (d + 1)) with hM
  set Bz := (вИС n вИИ Icc 1 z, k n) / ((z:вДЭ) + 1) with hBz
  set By := (вИС n вИИ Icc 1 y, k n) / ((y:вДЭ) + 1) with hBy
  have htri : |M + Bz - By| вЙ§ |M| + |Bz| + |By| := by
    have h1 := abs_add_le M Bz
    have h2 := abs_add_le (M + Bz) (-By)
    rw [abs_neg, вЖР sub_eq_add_neg] at h2
    linarith
  calc |M + Bz - By| вЙ§ |M| + |Bz| + |By| := htri
    _ вЙ§ (B * (2 / Real.sqrt y) + B * (1 / ((y:вДЭ) + 1)))
        + 2 * B / Real.sqrt y + 2 * B / Real.sqrt y := by
        linarith [hmid, hbz, hby]
    _ вЙ§ 7 * B / Real.sqrt y := by
        have hstep : B * (1 / ((y:вДЭ) + 1)) вЙ§ B * (1 / Real.sqrt y) :=
          mul_le_mul_of_nonneg_left hy1r hB
        have hexp : B * (2 / Real.sqrt y) = 2 * B / Real.sqrt y := by ring
        have hexp2 : B * (1 / Real.sqrt y) = B / Real.sqrt y := by ring
        have hexp3 : 7 * B / Real.sqrt y = 7 * (B / Real.sqrt y) := by ring
        have hexp4 : 2 * B / Real.sqrt y = 2 * (B / Real.sqrt y) := by ring
        linarith [hstep, hexp, hexp2, hexp3, hexp4]

/-- **The k-side mean exists with вИЪ-rate** (Siegel brick A2e-ii): with `|K(t)| вЙ§ B(вИЪt+1)`,
    `S_y = ќ£_{dвЙ§y} k(d)/d` converges to some `Lk` with `|Lk вИТ S_y| вЙ§ 7B/вИЪy` for `y вЙ• 1` вАФ
    the abstract `L(1,ѕЗвВВ)L(1,ѕЗвВБѕЗвВВ)` of the hyperbola main term. -/
theorem sqrt_mean_exists (k : вДХ вЖТ вДЭ) (B : вДЭ)
    (hK : вИА t : вДХ, |вИС n вИИ Icc 1 t, k n| вЙ§ B * (Real.sqrt t + 1)) :
    вИГ Lk : вДЭ, вИА y : вДХ, 1 вЙ§ y вЖТ
      |Lk - вИС d вИИ Icc 1 y, k d / d| вЙ§ 7 * B / Real.sqrt y := by
  have hB : 0 вЙ§ B := by
    have h0 := hK 0
    simp at h0
    linarith [abs_nonneg (вИС n вИИ Icc 1 0, k n), h0]
  set S : вДХ вЖТ вДЭ := fun y => вИС d вИИ Icc 1 y, k d / d with hS
  have hIcoIcc : вИА a b : вДХ, Ico a (b + 1) = Icc a b := by
    intro a b
    ext x
    simp only [Finset.mem_Ico, Finset.mem_Icc]
    omega
  have hdiff : вИА y z : вДХ, 1 вЙ§ y вЖТ y вЙ§ z вЖТ |S z - S y| вЙ§ 7 * B / Real.sqrt y := by
    intro y z hy1 hyz
    have hsplit : S z - S y = вИС d вИИ Icc (y + 1) z, k d / d := by
      rw [hS]
      simp only
      rw [вЖР hIcoIcc 1 z,
        вЖР Finset.sum_Ico_consecutive (fun d => k d / d)
          (by omega : 1 вЙ§ y + 1) (by omega : y + 1 вЙ§ z + 1),
        hIcoIcc 1 y, hIcoIcc (y + 1) z, add_sub_cancel_left]
    rw [hsplit]
    exact abel_tail_sqrt k B hK y z hy1 hyz
  -- work with the shifted sequence T n = S (n+1): indices always вЙ• 1
  set T : вДХ вЖТ вДЭ := fun n => S (n + 1) with hT
  have hb0 : Filter.Tendsto (fun N : вДХ => 7 * B / Real.sqrt ((N:вДЭ) + 1))
      Filter.atTop (nhds 0) := by
    have h1 : Filter.Tendsto (fun N : вДХ => Real.sqrt ((N:вДЭ) + 1))
        Filter.atTop Filter.atTop := by
      apply Filter.Tendsto.comp Real.tendsto_sqrt_atTop
      apply Filter.tendsto_atTop_add_const_right
      exact tendsto_natCast_atTop_atTop
    have h2 := Filter.Tendsto.div_atTop (tendsto_const_nhds (x := 7 * B)) h1
    simpa using h2
  have hcauchy : CauchySeq T := by
    apply cauchySeq_of_le_tendsto_0 (b := fun N : вДХ => 7 * B / Real.sqrt ((N:вДЭ) + 1)) _ hb0
    intro n m N hn hm
    rw [Real.dist_eq]
    have hkey : вИА u v : вДХ, u вЙ§ v вЖТ N вЙ§ u вЖТ
        |T v - T u| вЙ§ 7 * B / Real.sqrt ((N:вДЭ) + 1) := by
      intro u v huv hNu
      calc |T v - T u| = |S (v + 1) - S (u + 1)| := by rw [hT]
        _ вЙ§ 7 * B / Real.sqrt ((u:вДЭ) + 1) := by
            have h := hdiff (u + 1) (v + 1) (by omega) (by omega)
            have hc : ((u + 1 : вДХ) : вДЭ) = (u : вДЭ) + 1 := by push_cast; ring
            rwa [hc] at h
        _ вЙ§ 7 * B / Real.sqrt ((N:вДЭ) + 1) := by
            apply div_le_div_of_nonneg_left (by linarith) (by positivity)
            apply Real.sqrt_le_sqrt
            have : (N:вДЭ) вЙ§ (u:вДЭ) := by exact_mod_cast hNu
            linarith
    rcases le_total n m with h | h
    ¬Ј rw [abs_sub_comm]
      exact hkey n m h hn
    ¬Ј exact hkey m n h hm
  obtain вЯ®Lk, hLkвЯ© := cauchySeq_tendsto_of_complete hcauchy
  refine вЯ®Lk, ?_вЯ©
  intro y hy1
  have htend : Filter.Tendsto (fun z : вДХ => |T z - S y|) Filter.atTop
      (nhds (|Lk - S y|)) := by
    apply Filter.Tendsto.abs
    exact Filter.Tendsto.sub_const hLk (S y)
  apply le_of_tendsto htend
  filter_upwards [Filter.eventually_ge_atTop y] with z hz
  calc |T z - S y| = |S (z + 1) - S y| := by rw [hT]
    _ вЙ§ 7 * B / Real.sqrt y := hdiff y (z + 1) hy1 (by omega)

/-- Convolution values are divisor-counted (Siegel brick A2e-iii-a1): for 1-bounded
    inputs, `|(kвВБвЛЖkвВВ)(n)| вЙ§ ѕД(n)` where `ѕД(n) = #divisorsAntidiagonal(n)`. -/
lemma conv_value_le_tau (kвВБ kвВВ : вДХ вЖТ вДЭ) (h1b : вИА n, |kвВБ n| вЙ§ 1) (h2b : вИА n, |kвВВ n| вЙ§ 1)
    (n : вДХ) :
    |(toArith kвВБ * toArith kвВВ) n| вЙ§ ((n.divisorsAntidiagonal).card : вДЭ) := by
  rw [ArithmeticFunction.mul_apply]
  calc |вИС p вИИ n.divisorsAntidiagonal, toArith kвВБ p.1 * toArith kвВВ p.2|
      вЙ§ вИС p вИИ n.divisorsAntidiagonal, |toArith kвВБ p.1 * toArith kвВВ p.2| :=
        Finset.abs_sum_le_sum_abs _ _
    _ вЙ§ вИС p вИИ n.divisorsAntidiagonal, 1 := by
        apply Finset.sum_le_sum
        intro p hp
        rw [abs_mul]
        have h1 : |toArith kвВБ p.1| вЙ§ 1 := by
          rcases Nat.eq_zero_or_pos p.1 with h0 | h0
          ¬Ј simp [toArith, h0]
          ¬Ј rw [show toArith kвВБ p.1 = kвВБ p.1 from by simp [toArith, h0.ne']]
            exact h1b p.1
        have h2 : |toArith kвВВ p.2| вЙ§ 1 := by
          rcases Nat.eq_zero_or_pos p.2 with h0 | h0
          ¬Ј simp [toArith, h0]
          ¬Ј rw [show toArith kвВВ p.2 = kвВВ p.2 from by simp [toArith, h0.ne']]
            exact h2b p.2
        calc |toArith kвВБ p.1| * |toArith kвВВ p.2| вЙ§ 1 * 1 :=
            mul_le_mul h1 h2 (abs_nonneg _) zero_le_one
          _ = 1 := one_mul 1
    _ = ((n.divisorsAntidiagonal).card : вДЭ) := by
        rw [Finset.sum_const, nsmul_eq_mul, mul_one]

/-- Fiberwise unfolding: divisor-pair sums over `d вЙ§ y` are hyperbola-set sums
    (Siegel brick A2e-iii-a2). -/
lemma sum_divA_eq_hypSet (y : вДХ) (F : вДХ √Ч вДХ вЖТ вДЭ) :
    вИС d вИИ Icc 1 y, вИС p вИИ d.divisorsAntidiagonal, F p
      = вИС p вИИ (Ioc 0 y √ЧЋҐ Ioc 0 y).filter (fun p => p.1 * p.2 вЙ§ y), F p := by
  have hL : вИС d вИИ Icc 1 y, вИС p вИИ d.divisorsAntidiagonal, F p
      = вИС d вИИ Icc 1 y, вИС p вИИ (Ioc 0 y √ЧЋҐ Ioc 0 y).filter (fun x => x.1 * x.2 = d), F p := by
    apply Finset.sum_congr rfl
    intro d hd
    obtain вЯ®hd1, hdyвЯ© := Finset.mem_Icc.mp hd
    rw [Nat.divisorsAntidiagonal_eq_prod_filter_of_le (by omega) hdy]
  rw [hL, Finset.sum_fiberwise_eq_sum_filter]
  apply Finset.sum_congr _ (fun _ _ => rfl)
  apply Finset.filter_congr
  intro p hp
  rw [Finset.mem_product, Finset.mem_Ioc, Finset.mem_Ioc] at hp
  simp only [Finset.mem_Icc]
  constructor
  ¬Ј intro h
    exact h.2
  ¬Ј intro h
    exact вЯ®Nat.one_le_iff_ne_zero.mpr (Nat.mul_pos hp.1.1 hp.2.1).ne', hвЯ©

/-- **ѕД partial sums** (Siegel brick A2e-iii-a3): `ќ£_{dвЙ§y} ѕД(d) вЙ§ y(1 + log y)`. -/
lemma sum_tau_le (y : вДХ) (hy : 1 вЙ§ y) :
    вИС d вИИ Icc 1 y, ((d.divisorsAntidiagonal).card : вДЭ) вЙ§ (y : вДЭ) * (1 + Real.log y) := by
  have hcard : вИА d вИИ Icc 1 y, ((d.divisorsAntidiagonal).card : вДЭ)
      = вИС p вИИ d.divisorsAntidiagonal, (1 : вДЭ) := by
    intro d _
    rw [Finset.sum_const, nsmul_eq_mul, mul_one]
  rw [Finset.sum_congr rfl hcard, sum_divA_eq_hypSet, sum_hypSet_eq_rows]
  have hrow : вИА d вИИ Icc 1 y, вИС e вИИ Icc 1 (y / d), (1:вДЭ) вЙ§ (y : вДЭ) * (1 / d) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hd0 : (0:вДЭ) < d := by exact_mod_cast hd1
    rw [Finset.sum_const, nsmul_eq_mul, mul_one, Nat.card_Icc, Nat.add_sub_cancel]
    have h1 : ((y / d : вДХ) : вДЭ) вЙ§ (y : вДЭ) / d := Nat.cast_div_le
    rw [mul_one_div]
    exact h1
  calc вИС d вИИ Icc 1 y, вИС e вИИ Icc 1 (y / d), (1:вДЭ)
      вЙ§ вИС d вИИ Icc 1 y, (y : вДЭ) * (1 / d) := Finset.sum_le_sum hrow
    _ = (y : вДЭ) * вИС d вИИ Icc 1 y, (1 : вДЭ) / d := by rw [вЖР Finset.mul_sum]
    _ вЙ§ (y : вДЭ) * (1 + Real.log y) := by
        apply mul_le_mul_of_nonneg_left (sum_one_div_le_log y hy) (by positivity)

/-- **ѕД/вИЪ partial sums** (Siegel brick A2e-iii-a4):
    `ќ£_{dвЙ§y} ѕД(d)/вИЪd вЙ§ 2вИЪy(1 + log y)` вАФ on each antidiagonal `pвВБpвВВ = d`. -/
lemma sum_tau_div_sqrt_le (y : вДХ) (hy : 1 вЙ§ y) :
    вИС d вИИ Icc 1 y, ((d.divisorsAntidiagonal).card : вДЭ) / Real.sqrt d
      вЙ§ 2 * Real.sqrt y * (1 + Real.log y) := by
  have hstep : вИА d вИИ Icc 1 y, ((d.divisorsAntidiagonal).card : вДЭ) / Real.sqrt d
      = вИС p вИИ d.divisorsAntidiagonal, (1 : вДЭ) / Real.sqrt (p.1 * p.2) := by
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hterm : вИА p вИИ d.divisorsAntidiagonal, (1 : вДЭ) / Real.sqrt (p.1 * p.2)
        = (1 : вДЭ) / Real.sqrt d := by
      intro p hp
      rw [Nat.mem_divisorsAntidiagonal] at hp
      rw [show ((p.1 : вДЭ) * (p.2 : вДЭ)) = ((d : вДХ) : вДЭ) from by exact_mod_cast hp.1]
    rw [Finset.sum_congr rfl hterm, Finset.sum_const, nsmul_eq_mul, mul_one_div]
  rw [Finset.sum_congr rfl hstep, sum_divA_eq_hypSet]
  exact sum_hypSet_inv_sqrt_le y hy

/-- **The Goldfeld coefficient asymptotic** (Siegel brick A2e-iii, the analytic capstone
    of A2): with `h := 1вЛЖgвВБ` carrying the mean `LвВБ` and `k := gвВВвЛЖ(gвВБgвВВ)` carrying the
    mean `Lk` (вИЪ-bounded partial sums `вЙ§ B(вИЪt+1)`),
    `|ќ£_{nвЙ§N} a(n) вИТ LвВБ¬ЈLk¬ЈN| вЙ§ 30(1+qвВБ)(1+B)¬ЈвИЪN¬ЈвИЪвИЪN¬Ј(1+log N)` for `N вЙ• 4` вАФ
    the `A(x) = ќїx + O(Q^c x^{3/4+ќµ})` input of Goldfeld's lemma, with
    `ќї = LвВБ¬ЈLk` and the split at `y = вМКвИЪNвМЛ`. -/
theorem quad_coeff_asymptotic (gвВБ gвВВ : вДХ вЖТ вДЭ) (qвВБ B LвВБ Lk : вДЭ)
    (h1b : вИА n, |gвВБ n| вЙ§ 1) (h2b : вИА n, |gвВВ n| вЙ§ 1)
    (hLвВБ : вИА y : вДХ, |LвВБ - вИС d вИИ Icc 1 y, gвВБ d / d| вЙ§ 2 * qвВБ / (y + 1))
    (hqвВБ : 0 вЙ§ qвВБ)
    (hH : вИА M : вДХ, 1 вЙ§ M вЖТ
      |вИС n вИИ Icc 1 M, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ) n - LвВБ * M|
        вЙ§ (1 + 4 * qвВБ) * (Real.sqrt M + 1))
    (hKb : вИА t : вДХ, |вИС n вИИ Icc 1 t, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) n|
        вЙ§ B * (Real.sqrt t + 1))
    (hLk : вИА y : вДХ, 1 вЙ§ y вЖТ
      |Lk - вИС d вИИ Icc 1 y, (toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m)) d / d|
        вЙ§ 7 * B / Real.sqrt y)
    (N : вДХ) (hN : 4 вЙ§ N) :
    |вИС n вИИ Icc 1 N, (toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
        * toArith (fun m => gвВБ m * gвВВ m)) n - LвВБ * Lk * N|
      вЙ§ 30 * (1 + qвВБ) * (1 + B)
        * (Real.sqrt N * Real.sqrt (Real.sqrt N) * (1 + Real.log N)) := by
  have hB : 0 вЙ§ B := by
    have h0 := hKb 0
    rw [show (Icc 1 0 : Finset вДХ) = вИЕ from Finset.Icc_eq_empty (by omega),
      Finset.sum_empty, abs_zero, Nat.cast_zero, Real.sqrt_zero] at h0
    linarith
  have hN1 : 1 вЙ§ N := by omega
  have hNr : (4:вДЭ) вЙ§ (N:вДЭ) := by exact_mod_cast hN
  -- names
  set h : ArithmeticFunction вДЭ := toArith (fun _ => (1:вДЭ)) * toArith gвВБ with hh
  set k : ArithmeticFunction вДЭ := toArith gвВВ * toArith (fun m => gвВБ m * gвВВ m) with hk
  have hregroup : toArith (fun _ => (1:вДЭ)) * toArith gвВБ * toArith gвВВ
      * toArith (fun m => gвВБ m * gвВВ m) = k * h := by
    rw [hh, hk, mul_assoc]
    exact mul_comm _ _
  rw [hregroup]
  set y : вДХ := Nat.sqrt N with hy
  have hy2 : 2 вЙ§ y := by
    rw [hy]
    exact Nat.le_sqrt.mpr (by omega)
  have hy1 : 1 вЙ§ y := by omega
  have hyN : y вЙ§ N := Nat.sqrt_le_self N
  rw [hyperbola_identity k h N y hyN]
  -- ===== вИЪ-conversions =====
  have hsN : (0:вДЭ) < Real.sqrt N := Real.sqrt_pos.mpr (by linarith)
  have hsqN : Real.sqrt N * Real.sqrt N = (N:вДЭ) := Real.mul_self_sqrt (by linarith)
  have hssN : (0:вДЭ) < Real.sqrt (Real.sqrt N) := Real.sqrt_pos.mpr hsN
  have hsqsN : Real.sqrt (Real.sqrt N) * Real.sqrt (Real.sqrt N) = Real.sqrt N :=
    Real.mul_self_sqrt hsN.le
  have hyle : (y : вДЭ) вЙ§ Real.sqrt N := by
    rw [hy]
    exact Real.le_sqrt_of_sq_le (by exact_mod_cast Nat.sqrt_le' N)
  have hsyle : Real.sqrt y вЙ§ Real.sqrt (Real.sqrt N) := Real.sqrt_le_sqrt hyle
  have hy1r : (1:вДЭ) вЙ§ (y:вДЭ) := by exact_mod_cast hy1
  have hsy : (0:вДЭ) < Real.sqrt y := Real.sqrt_pos.mpr (by linarith)
  -- вИЪN вЙ§ 2y (from вМКвИЪNвМЛ вЙ• вИЪN вИТ 1 вЙ• вИЪN/2 for N вЙ• 4)
  have h2y : Real.sqrt N вЙ§ 2 * (y : вДЭ) := by
    have hlt := Nat.lt_succ_sqrt' N
    have hcast : (N : вДЭ) < ((y : вДЭ) + 1) ^ 2 := by
      rw [hy]
      push_cast
      exact_mod_cast hlt
    have hsylt : Real.sqrt N < (y:вДЭ) + 1 := by
      nlinarith [hcast, hsqN, hsN]
    linarith [hy1r]
  -- N/вИЪy вЙ§ вИЪ2¬ЈвИЪN¬ЈвИЪвИЪN вАФ via вИЪy вЙ• вИЪвИЪN/вИЪ2, i.e. 2y вЙ• вИЪN вЖТ вИЪ(2y) вЙ• вИЪвИЪN
  have hNdivsy : (N:вДЭ) / Real.sqrt y вЙ§ 2 * (Real.sqrt N * Real.sqrt (Real.sqrt N)) := by
    rw [div_le_iffвВА hsy]
    -- вИЪвИЪN вЙ§ вИЪ(2y) = вИЪ2¬ЈвИЪy, then N = (вИЪNвИЪвИЪN)¬ЈвИЪвИЪN вЙ§ (вИЪNвИЪвИЪN)¬ЈвИЪ2вИЪy вЙ§ 2(вИЪNвИЪвИЪN)вИЪy
    have h1 : Real.sqrt (Real.sqrt N) вЙ§ Real.sqrt 2 * Real.sqrt y := by
      calc Real.sqrt (Real.sqrt N) вЙ§ Real.sqrt (2 * y) := Real.sqrt_le_sqrt (by
            push_cast
            linarith [h2y])
        _ = Real.sqrt 2 * Real.sqrt y := Real.sqrt_mul (by norm_num) _
    have hs2le : Real.sqrt 2 вЙ§ 2 := by
      have : (Real.sqrt 2) * (Real.sqrt 2) = 2 := Real.mul_self_sqrt (by norm_num)
      nlinarith [Real.sqrt_nonneg 2]
    have hss1 : (1:вДЭ) вЙ§ Real.sqrt (Real.sqrt N) := by
      apply Real.one_le_sqrt.mpr
      have h2s : (2:вДЭ) вЙ§ Real.sqrt N := by
        apply Real.le_sqrt_of_sq_le
        nlinarith
      linarith
    have hmul := mul_le_mul_of_nonneg_left h1 (mul_nonneg hsN.le hssN.le)
    nlinarith [hmul, hsqN, hsqsN, hs2le,
      mul_nonneg (mul_nonneg hsN.le hssN.le) hsy.le]
  -- ===== value bounds =====
  have hg12b : вИА n, |gвВБ n * gвВВ n| вЙ§ 1 := by
    intro n
    rw [abs_mul]
    calc |gвВБ n| * |gвВВ n| вЙ§ 1 * 1 := mul_le_mul (h1b n) (h2b n) (abs_nonneg _) zero_le_one
      _ = 1 := one_mul 1
  have honeb : вИА n : вДХ, |(fun _ : вДХ => (1:вДЭ)) n| вЙ§ 1 := fun n => by norm_num
  have hkѕД : вИА n, |k n| вЙ§ ((n.divisorsAntidiagonal).card : вДЭ) := by
    intro n
    rw [hk]
    exact conv_value_le_tau gвВВ (fun m => gвВБ m * gвВВ m) h2b hg12b n
  have hhѕД : вИА n, |h n| вЙ§ ((n.divisorsAntidiagonal).card : вДЭ) := by
    intro n
    rw [hh]
    exact conv_value_le_tau (fun _ => (1:вДЭ)) gвВБ honeb h1b n
  have hL1b : |LвВБ| вЙ§ 1 + qвВБ := by
    have h1 := hLвВБ 1
    have hS1 : вИС d вИИ Icc 1 1, gвВБ d / d = gвВБ 1 := by
      rw [show (Icc 1 1 : Finset вДХ) = {1} from rfl, Finset.sum_singleton]
      norm_num
    rw [hS1] at h1
    have habs := abs_add_le (LвВБ - gвВБ 1) (gвВБ 1)
    simp only [sub_add_cancel] at habs
    have hc : ((1:вДХ):вДЭ) + 1 = 2 := by norm_num
    rw [hc] at h1
    have hq2 : 2 * qвВБ / 2 = qвВБ := by ring
    linarith [habs, h1, h1b 1, hq2.le, hq2.ge]
  -- ===== M' facts =====
  set M' : вДХ := N / (y + 1) with hM'
  have hyy : y * y вЙ§ N := by
    have h := Nat.sqrt_le' N
    rw [pow_two] at h
    rw [hy]
    exact h
  have hyN2 : y + 1 вЙ§ N := by nlinarith [hy2, hyy]
  have hM'1 : 1 вЙ§ M' := by
    rw [hM', Nat.le_div_iff_mul_le (by omega : 0 < y + 1)]
    omega
  have hM'le : (M' : вДЭ) вЙ§ Real.sqrt N := by
    have h1 : ((M' : вДХ) : вДЭ) вЙ§ (N : вДЭ) / ((y:вДЭ) + 1) := by
      rw [hM']
      have := Nat.cast_div_le (ќ± := вДЭ) (m := N) (n := y + 1)
      push_cast at this
      exact this
    have hylt : Real.sqrt N < (y:вДЭ) + 1 := by
      have hlt := Nat.lt_succ_sqrt' N
      have hcast : (N : вДЭ) < ((y : вДЭ) + 1) ^ 2 := by
        rw [hy]
        push_cast
        exact_mod_cast hlt
      nlinarith [hsqN, hsN]
    have h2 : (N : вДЭ) / ((y:вДЭ) + 1) вЙ§ Real.sqrt N := by
      rw [div_le_iffвВА (by positivity)]
      nlinarith [hsqN, hylt, hsN]
    linarith
  have hsM'le : Real.sqrt M' вЙ§ Real.sqrt (Real.sqrt N) := Real.sqrt_le_sqrt hM'le
  have hlogy : Real.log y вЙ§ Real.log N := by
    apply Real.log_le_log (by exact_mod_cast hy1 : (0:вДЭ) < (y:вДЭ))
    exact_mod_cast hyN
  have hlogM' : Real.log M' вЙ§ Real.log N := by
    apply Real.log_le_log (by exact_mod_cast hM'1 : (0:вДЭ) < (M':вДЭ))
    have : M' вЙ§ N := Nat.div_le_self N (y + 1)
    exact_mod_cast this
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := Real.log_nonneg (by linarith)
  have hlogy1 : 1 + Real.log y вЙ§ 1 + Real.log N := by linarith
  have hlogy0 : (0:вДЭ) вЙ§ 1 + Real.log y := by
    have := Real.log_nonneg (by exact_mod_cast hy1 : (1:вДЭ) вЙ§ (y:вДЭ))
    linarith
  have hlogM'0 : (0:вДЭ) вЙ§ 1 + Real.log M' := by
    have := Real.log_nonneg (by exact_mod_cast hM'1 : (1:вДЭ) вЙ§ (M':вДЭ))
    linarith
  have hlogM'1 : 1 + Real.log M' вЙ§ 1 + Real.log N := by linarith
  have hsqrtdiv : вИА d : вДХ, 1 вЙ§ d вЖТ Real.sqrt ((N / d : вДХ) : вДЭ) вЙ§ Real.sqrt N / Real.sqrt d := by
    intro d hd1
    calc Real.sqrt ((N / d : вДХ) : вДЭ) вЙ§ Real.sqrt ((N : вДЭ) / d) :=
          Real.sqrt_le_sqrt Nat.cast_div_le
      _ = Real.sqrt N / Real.sqrt d := Real.sqrt_div (Nat.cast_nonneg N) d
  -- ===== HEAD =====
  set Sk : вДЭ := вИС d вИИ Icc 1 y, k d / d with hSk
  have hSkLk : |Lk - Sk| вЙ§ 7 * B / Real.sqrt y := by
    rw [hSk, hk]
    exact hLk y hy1
  have hhead_eq : вИС d вИИ Icc 1 y, k d * (вИС e вИИ Icc 1 (N / d), h e)
      = LвВБ * (вИС d вИИ Icc 1 y, k d * ((N / d : вДХ) : вДЭ))
        + вИС d вИИ Icc 1 y, k d * ((вИС e вИИ Icc 1 (N / d), h e) - LвВБ * ((N / d : вДХ) : вДЭ)) := by
    rw [Finset.mul_sum, вЖР Finset.sum_add_distrib]
    apply Finset.sum_congr rfl
    intro d _
    ring
  have hfloor_eq : вИС d вИИ Icc 1 y, k d * ((N / d : вДХ) : вДЭ)
      = (N : вДЭ) * Sk - вИС d вИИ Icc 1 y, k d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ)) := by
    rw [hSk, Finset.mul_sum, вЖР Finset.sum_sub_distrib]
    apply Finset.sum_congr rfl
    intro d hd
    obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
    have hd0 : ((d:вДЭ)) вЙ† 0 := by
      have : (0:вДЭ) < d := by exact_mod_cast hd1
      linarith
    field_simp
    ring
  have hfrac_le : |вИС d вИИ Icc 1 y, k d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ))|
      вЙ§ (y:вДЭ) * (1 + Real.log y) := by
    calc |вИС d вИИ Icc 1 y, k d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ))|
        вЙ§ вИС d вИИ Icc 1 y, |k d * ((N : вДЭ) / d - ((N / d : вДХ) : вДЭ))| :=
          Finset.abs_sum_le_sum_abs _ _
      _ вЙ§ вИС d вИИ Icc 1 y, ((d.divisorsAntidiagonal).card : вДЭ) := by
          apply Finset.sum_le_sum
          intro d hd
          obtain вЯ®hd1, _вЯ© := Finset.mem_Icc.mp hd
          have hd0 : (0:вДЭ) < d := by exact_mod_cast hd1
          rw [abs_mul]
          have hfr0 : (0:вДЭ) вЙ§ (N : вДЭ) / d - ((N / d : вДХ) : вДЭ) := by
            rw [sub_nonneg]
            exact Nat.cast_div_le
          have hfr1 : (N : вДЭ) / d - ((N / d : вДХ) : вДЭ) вЙ§ 1 := by
            have hlt : (N : вДЭ) / d < ((N / d : вДХ) : вДЭ) + 1 := by
              rw [div_lt_iffвВА hd0]
              have hnat : N < (N / d + 1) * d := by
                have hexp : (N / d + 1) * d = d * (N / d) + d := by ring
                rw [hexp]
                have h1 := Nat.div_add_mod N d
                have h2 := Nat.mod_lt N (show 0 < d by omega)
                omega
              exact_mod_cast hnat
            linarith
          rw [abs_of_nonneg hfr0]
          have hѕД1 : (1:вДЭ) вЙ§ ((d.divisorsAntidiagonal).card : вДЭ) := by
            have hmem : ((1:вДХ), d) вИИ d.divisorsAntidiagonal := by
              rw [Nat.mem_divisorsAntidiagonal]
              exact вЯ®one_mul d, by omegaвЯ©
            have hpos : 0 < (d.divisorsAntidiagonal).card := Finset.card_pos.mpr вЯ®_, hmemвЯ©
            exact_mod_cast hpos
          nlinarith [hkѕД d, hfr0, hfr1, abs_nonneg (k d), hѕД1]
      _ вЙ§ (y:вДЭ) * (1 + Real.log y) := sum_tau_le y hy1
  have hќµ_le : |вИС d вИИ Icc 1 y, k d * ((вИС e вИИ Icc 1 (N / d), h e) - LвВБ * ((N / d : вДХ) : вДЭ))|
      вЙ§ (1 + 4 * qвВБ) * (2 * Real.sqrt N * Real.sqrt y * (1 + Real.log y)
          + 2 * (y:вДЭ) * (1 + Real.log y)) := by
    have hterm : вИА d вИИ Icc 1 y, |k d * ((вИС e вИИ Icc 1 (N / d), h e) - LвВБ * ((N / d : вДХ) : вДЭ))|
        вЙ§ (1 + 4 * qвВБ) * (((d.divisorsAntidiagonal).card : вДЭ) * (Real.sqrt N / Real.sqrt d)
