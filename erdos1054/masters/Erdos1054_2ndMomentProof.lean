    calc Real.log ((N:вДЭ)*(2*|ќ≥|+7)*(1+d)/d)
        вЙ§ Real.log (((N:вДЭ)*(4*|ќ≥|+7)) * (1/d)) := by
          apply Real.log_le_log _ h1
