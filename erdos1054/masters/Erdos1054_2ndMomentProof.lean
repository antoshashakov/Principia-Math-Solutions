          (вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * (tailSet P Q x.1 x.2).indicator
              (fun ќ≤ => вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ) ќ±)
          * (вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
            * (tailSet P Q y.1 y.2).indicator
              (fun ќ≤ => вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ) ќ±) := by
        rw [sq, Finset.sum_mul_sum]
    _ = вИС x вИИ canonAnchors P, вИС y вИИ canonAnchors P,
          вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
            * (tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2).indicator
                (fun ќ≤ =>
                  вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                    * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ) ќ± := by
        refine Finset.sum_congr rfl (fun x _ => Finset.sum_congr rfl (fun y _ => ?_))
        rw [Set.inter_indicator_mul]
        ring

/-- **harc brick B5b: canonical fractions are injective.** Two reduced canonical residues
    with equal real fractions coincide: `aвВА/q = aвВА'/q'` with `aвВА вИИ redRes q`, `aвВА' вИИ redRes q'`
    forces `q = q'` and `aвВА = aвВА'`. -/
lemma canon_fraction_injective (q q' aвВА aвВА' : вДХ) (hq : 1 вЙ§ q) (hq' : 1 вЙ§ q')
    (ha : aвВА вИИ redRes q) (ha' : aвВА' вИИ redRes q')
    (heq : (aвВА : вДЭ) / (q : вДЭ) = (aвВА' : вДЭ) / (q' : вДЭ)) : q = q' вИІ aвВА = aвВА' := by
  have hgcd : Nat.gcd aвВА q = 1 := (Finset.mem_filter.mp ha).2
  have hgcd' : Nat.gcd aвВА' q' = 1 := (Finset.mem_filter.mp ha').2
  have hq0R : ((q : вДЭ)) вЙ† 0 := by positivity
  have hq'0R : ((q' : вДЭ)) вЙ† 0 := by positivity
  have hcross : aвВА * q' = aвВА' * q := by
    have h := (div_eq_div_iff hq0R hq'0R).mp heq
    exact_mod_cast h
  have hdvd : q вИ£ q' := by
    have h1 : q вИ£ aвВА * q' := by rw [hcross]; exact dvd_mul_left q aвВА'
    exact (Nat.coprime_comm.mp hgcd).dvd_of_dvd_mul_left h1
  have hdvd' : q' вИ£ q := by
    have h1 : q' вИ£ aвВА' * q := by rw [вЖР hcross]; exact dvd_mul_left q' aвВА
    exact (Nat.coprime_comm.mp hgcd').dvd_of_dvd_mul_left h1
  have hqq : q = q' := Nat.dvd_antisymm hdvd hdvd'
  refine вЯ®hqq, ?_вЯ©
  subst hqq
  exact Nat.eq_of_mul_eq_mul_right (by omega) hcross

