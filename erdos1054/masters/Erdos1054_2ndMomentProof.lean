  have hUconv : Convex вДЭ U := by
    rw [hUdef]
    exact (convex_halfSpace_re_gt _).inter (convex_ball 0 R)
  have hg1diff : Differentiable вДВ (DirichletCharacter.LFunctionTrivCharвВБ 1) :=
