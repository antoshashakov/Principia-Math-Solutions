/-- **rpow partial-sum bound**: `вИС_{q=1}^{X} q^{-4/5} вЙ§ 5¬ЈX^{1/5}`. The analytic estimate that,
    combined with the crude totient bound `ѕЖ(q) вЙ• q^{3/5}` (so `q/ѕЖ(q)¬≥ вЙ§ q^{-4/5}`), makes the
    `q вЙ§ X` diagonal truncation error `вИС_{qвЙ§X} q(1+log q)/ѕЖ¬≥ = O(X^{1/5} log X) = o(X)`. Proved by
    induction; the step rests on concavity of `t вЖ¶ t^{1/5}` (`aвБµвИТbвБµ вЙ§ 5aвБі(aвИТb)` for `0вЙ§bвЙ§a`). -/
lemma sum_rpow_partial (X : вДХ) :
    вИС q вИИ Finset.Icc 1 X, (q : вДЭ) ^ (-(4:вДЭ)/5) вЙ§ 5 * (X : вДЭ) ^ ((1:вДЭ)/5) := by
  induction X with
  | zero => simp
  | succ X ih =>
    rw [Finset.sum_Icc_succ_top (by omega : 1 вЙ§ X + 1)]
    have hcast : ((X + 1 : вДХ) : вДЭ) = (X:вДЭ) + 1 := by push_cast; ring
    rw [hcast]
    have hbase : (0:вДЭ) < (X:вДЭ) + 1 := by positivity
    set a := ((X:вДЭ)+1) ^ ((1:вДЭ)/5) with ha_def
    set b := (X:вДЭ) ^ ((1:вДЭ)/5) with hb_def
    have ha_pos : 0 < a := by rw [ha_def]; exact Real.rpow_pos_of_pos hbase _
    have hb0 : 0 вЙ§ b := by rw [hb_def]; exact Real.rpow_nonneg (by positivity) _
    have ha5 : a^5 = (X:вДЭ)+1 := by
      rw [ha_def, вЖР Real.rpow_natCast (((X:вДЭ)+1)^((1:вДЭ)/5)) 5, вЖР Real.rpow_mul hbase.le]
      rw [show (1:вДЭ)/5*(5:вДХ) = 1 by push_cast; ring, Real.rpow_one]
    have hb5 : b^5 = (X:вДЭ) := by
      rw [hb_def, вЖР Real.rpow_natCast ((X:вДЭ)^((1:вДЭ)/5)) 5,
        вЖР Real.rpow_mul (by positivity : (0:вДЭ) вЙ§ (X:вДЭ))]
      rw [show (1:вДЭ)/5*(5:вДХ) = 1 by push_cast; ring, Real.rpow_one]
    have hab : b вЙ§ a := by
      rw [ha_def, hb_def]
      exact Real.rpow_le_rpow (by positivity) (by linarith) (by norm_num)
    have ha4 : a^4 = ((X:вДЭ)+1)^((4:вДЭ)/5) := by
      rw [ha_def, вЖР Real.rpow_natCast (((X:вДЭ)+1)^((1:вДЭ)/5)) 4, вЖР Real.rpow_mul hbase.le]
      norm_num
    have hterm_eq : ((X:вДЭ)+1)^(-(4:вДЭ)/5) = 1/a^4 := by
      rw [ha4, one_div, show (-(4:вДЭ)/5) = -((4:вДЭ)/5) by ring, Real.rpow_neg hbase.le]
    have h1 : 0 вЙ§ a := ha_pos.le
    have hcub : (0:вДЭ) вЙ§ 4*a^3+3*a^2*b+2*a*b^2+b^3 := by
      nlinarith [pow_nonneg h1 3, mul_nonneg (pow_nonneg h1 2) hb0,
        mul_nonneg h1 (pow_nonneg hb0 2), pow_nonneg hb0 3]
    have hpoly : a^5 - b^5 вЙ§ 5*a^4*(a-b) := by
      nlinarith [mul_nonneg (mul_nonneg (sub_nonneg.mpr hab) (sub_nonneg.mpr hab)) hcub]
    have hone : a^5 - b^5 = 1 := by rw [ha5, hb5]; ring
    have ha4pos : 0 < a^4 := pow_pos ha_pos 4
    have hkey : (1:вДЭ) вЙ§ 5*a^4*(a-b) := by linarith [hpoly, hone]
    have hterm_le : ((X:вДЭ)+1)^(-(4:вДЭ)/5) вЙ§ 5*(a-b) := by
      rw [hterm_eq, div_le_iffвВА ha4pos]
      nlinarith [hkey]
    linarith [ih, hterm_le]

/-- **Full interval boundary bound**: `вИС_{rвИИU_q} вИС_{r'вИИU_q\{r}} 2/вАЦe((rвИТr')/q)вИТ1вАЦ вЙ§ ѕЖ(q)¬Јq(1+log q)`.
    Sums the per-`r` bound over the `ѕЖ(q)` reduced residues. -/
lemma full_boundary_le (q : вДХ) (hq2 : 2 вЙ§ q) :
    вИС r вИИ (Finset.range q).filter (fun r => Nat.gcd r q = 1),
        вИС r' вИИ ((Finset.range q).filter (fun r => Nat.gcd r q = 1)).erase r,
          2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ
      вЙ§ (Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q)) := by
  set U := (Finset.range q).filter (fun r => Nat.gcd r q = 1) with hU
  have hcard : U.card = Nat.totient q := by
    rw [hU, Nat.totient]
    apply Finset.card_nbij' id id <;> intro x hx <;>
      simp_all [Finset.mem_filter, Nat.Coprime, Nat.gcd_comm]
  calc вИС r вИИ U, вИС r' вИИ U.erase r, 2 / вАЦe ((((r : вД§) - (r' : вД§) : вД§) : вДЭ) / (q : вДЭ)) - 1вАЦ
      вЙ§ вИС _r вИИ U, (q : вДЭ) * (1 + Real.log q) := by
        apply Finset.sum_le_sum; intro r hr
        have hrq : r < q := Finset.mem_range.mp (Finset.mem_filter.mp hr).1
        exact erase_boundary_le q r hq2 hrq
    _ = (Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q)) := by
        rw [Finset.sum_const, hcard, nsmul_eq_mul]

/-- **Interval single-modulus mean square, explicit boundary**: `|вИС_{n<N}вАЦc_q(n)вАЦ¬≤ вИТ N¬ЈѕЖ(q)| вЙ§
    ѕЖ(q)¬Јq(1+log q)`. The interval Ramanujan mean value with a clean `O(q¬≤ log q)` error вАФ the
    off-diagonal boundary is now bounded in closed form. -/
lemma interval_meansq_bound (q N : вДХ) (hq2 : 2 вЙ§ q) :
    |(вИС n вИИ Finset.range N, вАЦramSum q nвАЦ ^ 2) - (N : вДЭ) * (Nat.totient q)|
      вЙ§ (Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q)) :=
  le_trans (ramSum_sq_interval_bound q N (by omega)) (full_boundary_le q hq2)

/-- **Dyadic-block mean square**: `|вИС_{nвИИ(X/2,X]}вАЦc_q(n)вАЦ¬≤ вИТ (XвИТX/2)¬ЈѕЖ(q)| вЙ§ 2¬ЈѕЖ(q)¬Јq(1+log q)`,
    from `interval_meansq_bound` at `N=X+1` and `N=X/2+1` via `range(X+1) = range(X/2+1) вКФ (X/2,X]`
    and the triangle inequality. This is the diagonal term of the truncation over the dyadic block. -/
lemma interval_meansq_Ioc (q X : вДХ) (hq2 : 2 вЙ§ q) :
    |(вИС n вИИ Finset.Ioc (X / 2) X, вАЦramSum q nвАЦ ^ 2) - ((X - X / 2 : вДХ) : вДЭ) * (Nat.totient q)|
      вЙ§ 2 * ((Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q))) := by
  have hb1 := interval_meansq_bound q (X + 1) hq2
  have hb2 := interval_meansq_bound q (X / 2 + 1) hq2
  have hunion : Finset.range (X + 1) = Finset.range (X / 2 + 1) вИ™ Finset.Ioc (X / 2) X := by
    ext n; simp only [Finset.mem_range, Finset.mem_union, Finset.mem_Ioc]; omega
  have hdisj : Disjoint (Finset.range (X / 2 + 1)) (Finset.Ioc (X / 2) X) := by
    rw [Finset.disjoint_left]; intro n; simp only [Finset.mem_range, Finset.mem_Ioc]; omega
  have hsplit : вИС n вИИ Finset.Ioc (X / 2) X, вАЦramSum q nвАЦ ^ 2
      = (вИС n вИИ Finset.range (X + 1), вАЦramSum q nвАЦ ^ 2)
        - вИС n вИИ Finset.range (X / 2 + 1), вАЦramSum q nвАЦ ^ 2 := by
    rw [hunion, Finset.sum_union hdisj]; ring
  have hcast : ((X - X / 2 : вДХ) : вДЭ) = ((X + 1 : вДХ) : вДЭ) - ((X / 2 + 1 : вДХ) : вДЭ) := by
    rw [Nat.cast_sub (by omega : X / 2 вЙ§ X)]; push_cast; ring
  rw [hsplit, hcast]
  calc |(вИС n вИИ Finset.range (X + 1), вАЦramSum q nвАЦ ^ 2
          - вИС n вИИ Finset.range (X / 2 + 1), вАЦramSum q nвАЦ ^ 2)
        - (((X + 1 : вДХ) : вДЭ) - ((X / 2 + 1 : вДХ) : вДЭ)) * (Nat.totient q)|
      = |(вИС n вИИ Finset.range (X + 1), вАЦramSum q nвАЦ ^ 2 - ((X + 1 : вДХ) : вДЭ) * (Nat.totient q))
          + (-(вИС n вИИ Finset.range (X / 2 + 1), вАЦramSum q nвАЦ ^ 2
              - ((X / 2 + 1 : вДХ) : вДЭ) * (Nat.totient q)))| := by congr 1; ring
    _ вЙ§ |вИС n вИИ Finset.range (X + 1), вАЦramSum q nвАЦ ^ 2 - ((X + 1 : вДХ) : вДЭ) * (Nat.totient q)|
          + |-(вИС n вИИ Finset.range (X / 2 + 1), вАЦramSum q nвАЦ ^ 2
              - ((X / 2 + 1 : вДХ) : вДЭ) * (Nat.totient q))| := abs_add_le _ _
    _ вЙ§ (Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q))
          + (Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q)) := by
        rw [abs_neg]; exact add_le_add hb1 hb2
    _ = 2 * ((Nat.totient q : вДЭ) * ((q : вДЭ) * (1 + Real.log q))) := by ring

/-- **Length-capped interval mean square** (`q > N` regime): `вИС_{n<N} вАЦc_q(n)вАЦ¬≤ вЙ§ N¬ЈѕЖ(q)¬≤`, from the
    pointwise `вАЦc_q(n)вАЦ вЙ§ ѕЖ(q)`. The `N`-independent boundary of `interval_meansq_bound` is loose when
    `q > N`; this trivial cap suffices for the `q > X` diagonal because the coefficient `ќЉ¬≤/ѕЖвБі` makes
    `вИС_{q>X} ќЉ¬≤/ѕЖвБі¬ЈNѕЖ¬≤ = N¬ЈвИС_{q>X} ќЉ¬≤/ѕЖ¬≤` converge with an `X^{-1/5}` tail вЗТ `O(X^{4/5}) = o(X)`. -/
lemma interval_meansq_pointwise (q N : вДХ) :
    вИС n вИИ Finset.range N, вАЦramSum q nвАЦ ^ 2 вЙ§ (N : вДЭ) * (Nat.totient q : вДЭ) ^ 2 := by
  calc вИС n вИИ Finset.range N, вАЦramSum q nвАЦ ^ 2
      вЙ§ вИС n вИИ Finset.range N, (Nat.totient q : вДЭ) ^ 2 := by
        apply Finset.sum_le_sum; intro n _
        have h := ramSum_norm_le q n
        have h0 := norm_nonneg (ramSum q n)
        nlinarith [h, h0]
    _ = (N : вДЭ) * (Nat.totient q : вДЭ) ^ 2 := by
        rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul]

/-- **Length-capped dyadic-block mean square**: `вИС_{nвИИ(X/2,X]} вАЦc_q(n)вАЦ¬≤ вЙ§ (X+1)¬ЈѕЖ(q)¬≤`. The
    `q > X` diagonal input, matching `interval_meansq_Ioc`'s block shape. -/
lemma interval_meansq_pointwise_Ioc (q X : вДХ) :
    вИС n вИИ Finset.Ioc (X / 2) X, вАЦramSum q nвАЦ ^ 2 вЙ§ ((X + 1 : вДХ) : вДЭ) * (Nat.totient q : вДЭ) ^ 2 := by
  calc вИС n вИИ Finset.Ioc (X / 2) X, вАЦramSum q nвАЦ ^ 2
      вЙ§ вИС n вИИ Finset.range (X + 1), вАЦramSum q nвАЦ ^ 2 := by
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro n hn; simp only [Finset.mem_Ioc, Finset.mem_range] at *; omega
        ¬Ј intro n _ _; positivity
    _ вЙ§ ((X + 1 : вДХ) : вДЭ) * (Nat.totient q : вДЭ) ^ 2 := interval_meansq_pointwise q (X + 1)

/-- **Finite Minkowski (вДУ¬≤ triangle) for sums**: `вИС_{nвИИI}(вИС_{qвИИS} f q n)¬≤ вЙ§ (вИС_{qвИИS}вИЪ(вИС_{nвИИI}(f q n)¬≤))¬≤`.
    Induction on `S` with CauchyвАУSchwarz (`Finset.sum_mul_sq_le_sq_mul_sq`). The core of the harc
    truncation Minkowski assembly: it converts the interval L¬≤ of a sum-of-`q` into a sum of per-`q`
    interval L¬≤ norms, dodging the divergent signed off-diagonal (a self-contained real-analysis lemma). -/
lemma l2_sum_sq_le (I S : Finset вДХ) (f : вДХ вЖТ вДХ вЖТ вДЭ) :
    вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2 вЙ§ (вИС q вИИ S, Real.sqrt (вИС n вИИ I, (f q n) ^ 2)) ^ 2 := by
  have key : Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2)
      вЙ§ вИС q вИИ S, Real.sqrt (вИС n вИИ I, (f q n) ^ 2) := by
    induction S using Finset.induction with
    | empty => simp
    | insert qвВА S hqвВА IH =>
      have hins : вИА n, (вИС q вИИ insert qвВА S, f q n) = f qвВА n + вИС q вИИ S, f q n :=
        fun n => Finset.sum_insert hqвВА
      have htri : Real.sqrt (вИС n вИИ I, (f qвВА n + вИС q вИИ S, f q n) ^ 2)
          вЙ§ Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2)
            + Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) := by
        have hsa : (0 : вДЭ) вЙ§ вИС n вИИ I, (f qвВА n) ^ 2 := by positivity
        have hsb : (0 : вДЭ) вЙ§ вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2 := by positivity
        have hCS := Finset.sum_mul_sq_le_sq_mul_sq I (f qвВА) (fun n => вИС q вИИ S, f q n)
        have hab : вИС n вИИ I, f qвВА n * (вИС q вИИ S, f q n)
            вЙ§ Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2) * Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) := by
          calc вИС n вИИ I, f qвВА n * (вИС q вИИ S, f q n)
              вЙ§ |вИС n вИИ I, f qвВА n * (вИС q вИИ S, f q n)| := le_abs_self _
            _ = Real.sqrt ((вИС n вИИ I, f qвВА n * (вИС q вИИ S, f q n)) ^ 2) := (Real.sqrt_sq_eq_abs _).symm
            _ вЙ§ Real.sqrt ((вИС n вИИ I, (f qвВА n) ^ 2) * (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2)) :=
                Real.sqrt_le_sqrt hCS
            _ = Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2) * Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) :=
                Real.sqrt_mul hsa _
        rw [вЖР Real.sqrt_sq (by positivity :
          (0:вДЭ) вЙ§ Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2) + Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2))]
        apply Real.sqrt_le_sqrt
        have hexp : вИС n вИИ I, (f qвВА n + вИС q вИИ S, f q n) ^ 2
            = (вИС n вИИ I, (f qвВА n) ^ 2) + 2 * (вИС n вИИ I, f qвВА n * (вИС q вИИ S, f q n))
              + (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) := by
          rw [Finset.mul_sum, вЖР Finset.sum_add_distrib, вЖР Finset.sum_add_distrib]
          apply Finset.sum_congr rfl; intro n _; ring
        rw [hexp, add_sq, Real.sq_sqrt hsa, Real.sq_sqrt hsb]
        nlinarith [hab]
      calc Real.sqrt (вИС n вИИ I, (вИС q вИИ insert qвВА S, f q n) ^ 2)
          = Real.sqrt (вИС n вИИ I, (f qвВА n + вИС q вИИ S, f q n) ^ 2) := by
            rw [Finset.sum_congr rfl (fun n _ => by rw [hins n])]
        _ вЙ§ Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2)
              + Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) := htri
        _ вЙ§ Real.sqrt (вИС n вИИ I, (f qвВА n) ^ 2) + вИС q вИИ S, Real.sqrt (вИС n вИИ I, (f q n) ^ 2) := by
            linarith [IH]
        _ = вИС q вИИ insert qвВА S, Real.sqrt (вИС n вИИ I, (f q n) ^ 2) := by
            rw [Finset.sum_insert hqвВА]
  calc вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2
      = Real.sqrt (вИС n вИИ I, (вИС q вИИ S, f q n) ^ 2) ^ 2 := (Real.sq_sqrt (by positivity)).symm
    _ вЙ§ (вИС q вИИ S, Real.sqrt (вИС n вИИ I, (f q n) ^ 2)) ^ 2 :=
        pow_le_pow_leftвВА (Real.sqrt_nonneg _) key 2

section TruncationMinkowski





/-- **Uniform finite bound вЗТ tsum bound** (the Minkowski `MвЖТвИЮ` limit): finite Minkowski passed to the
    infinite tail via `HasSum.tendsto_sum_nat` (partial sums вЖТ tsum) + `le_of_tendsto'`. -/
lemma l2_tsum_le (I : Finset вДХ) (v : вДХ вЖТ вДХ вЖТ вДЭ) (b : вДХ вЖТ вДЭ) (C : вДЭ) (hC : 0 вЙ§ C)
    (hvsum : вИА n вИИ I, Summable (fun q => v q n))
    (hbsum : Summable b) (hbnn : вИА q, 0 вЙ§ b q)
    (hfin : вИА S : Finset вДХ, вИС n вИИ I, (вИС q вИИ S, v q n) ^ 2 вЙ§ C * (вИС q вИИ S, b q) ^ 2) :
    вИС n вИИ I, (вИС' q, v q n) ^ 2 вЙ§ C * (вИС' q, b q) ^ 2 := by
  have htend : Filter.Tendsto (fun M => вИС n вИИ I, (вИС q вИИ Finset.range M, v q n) ^ 2)
      Filter.atTop (nhds (вИС n вИИ I, (вИС' q, v q n) ^ 2)) := by
    apply tendsto_finset_sum
    intro n hn
    exact ((hvsum n hn).hasSum.tendsto_sum_nat).pow 2
  apply le_of_tendsto' htend
  intro M
  calc вИС n вИИ I, (вИС q вИИ Finset.range M, v q n) ^ 2
      вЙ§ C * (вИС q вИИ Finset.range M, b q) ^ 2 := hfin _
    _ вЙ§ C * (вИС' q, b q) ^ 2 := by
        apply mul_le_mul_of_nonneg_left _ hC
        apply pow_le_pow_leftвВА (Finset.sum_nonneg (fun q _ => hbnn q)) _ 2
        exact hbsum.sum_le_tsum (Finset.range M) (fun q _ => hbnn q)

/-- **Finite-S truncation bound**: `вИС_{nвИИ(X/2,X]}(вИС_{qвИИS}T)¬≤ вЙ§ eX¬Ј(вИС_{qвИИS}ќЉ¬≤/ѕЖ^{3/2})¬≤`, via the
    finite Minkowski `l2_sum_sq_le` + the per-q bound `tarith_l2_le_all`. Uniform in `S`. -/
lemma tarith_finite_S_le (S : Finset вДХ) (X : вДХ) :
    вИС n вИИ Finset.Ioc (X / 2) X, (вИС q вИИ S, Tarithv n q) ^ 2
      вЙ§ Real.exp 1 * (X : вДЭ)
        * (вИС q вИИ S, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2 := by
  calc вИС n вИИ Finset.Ioc (X / 2) X, (вИС q вИИ S, Tarithv n q) ^ 2
      вЙ§ (вИС q вИИ S, Real.sqrt (вИС n вИИ Finset.Ioc (X / 2) X, (Tarithv n q) ^ 2)) ^ 2 :=
        l2_sum_sq_le _ _ (fun q n => Tarithv n q)
    _ вЙ§ (вИС q вИИ S, Real.sqrt (Real.exp 1 * (X : вДЭ))
          * ((ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2))) ^ 2 := by
        apply pow_le_pow_leftвВА (by positivity) _ 2
        exact Finset.sum_le_sum (fun q _ => tarith_l2_le_all q X)
    _ = Real.exp 1 * (X : вДЭ)
          * (вИС q вИИ S, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) ^ 2 := by
        rw [вЖР Finset.mul_sum, mul_pow, Real.sq_sqrt (by positivity)]

/-- **вШЕ Truncation Minkowski assembly (complete)**: `вИС_{nвИИ(X/2,X]}(вИС'_{q>P}T(q))¬≤
    вЙ§ eX¬Ј(вИС'_{q>P}ќЉ¬≤/ѕЖ^{3/2})¬≤`. Instantiates `l2_tsum_le` (finite Minkowski + `MвЖТвИЮ`) with the
    `P<q`-restricted family. The RHS tail `вИС'_{q>P}ќЉ¬≤/ѕЖ^{3/2} вЖТ 0` as `PвЖТвИЮ` makes it `o(X)` вАФ the
    truncation sub-error of `harc`. -/
lemma tarith_tail_l2_le (P X : вДХ) :
    вИС n вИИ Finset.Ioc (X / 2) X, (вИС' q, (if P < q then Tarithv n q else 0)) ^ 2
      вЙ§ Real.exp 1 * (X : вДЭ)
        * (вИС' q, (if P < q then
            (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)) ^ 2 := by
  apply l2_tsum_le (Finset.Ioc (X / 2) X)
    (fun q n => if P < q then Tarithv n q else 0)
    (fun q => if P < q then
      (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)
    (Real.exp 1 * (X : вДЭ)) (by positivity)
  ¬Ј intro n hn
    have hn1 : 1 вЙ§ n := by rw [Finset.mem_Ioc] at hn; omega
    have hs : Summable (fun q => Tarithv n q) := summable_norm_iff.mp (Tarith_summable_v n hn1)
    refine (hs.indicator {q | P < q}).congr (fun q => ?_)
    simp [Set.indicator_apply, Set.mem_setOf_eq]
  ¬Ј refine Summable.of_nonneg_of_le (fun q => ?_) (fun q => ?_) phi_pow32_summable
    ¬Ј split <;> positivity
    ¬Ј split
      ¬Ј exact le_refl _
      ¬Ј positivity
  ¬Ј intro q; split <;> positivity
  ¬Ј intro S
    have hv : вИА n, (вИС q вИИ S, if P < q then Tarithv n q else 0)
        = вИС q вИИ S.filter (fun q => P < q), Tarithv n q := fun n => by rw [Finset.sum_filter]
    have hb : (вИС q вИИ S, if P < q then
        (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)
        = вИС q вИИ S.filter (fun q => P < q),
            (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) := by
      rw [Finset.sum_filter]
    simp_rw [hv]
    rw [hb]
    exact tarith_finite_S_le (S.filter (fun q => P < q)) X

end TruncationMinkowski

section EpsSmall
open Filter Topology

/-- Tail-as-difference: `вИС'_q (if P<q then g q else 0) = вИС'g вИТ вИС_{q<P+1} g`. -/
lemma tail_eq_tsum_sub (g : вДХ вЖТ вДЭ) (hg : Summable g) (P : вДХ) :
    вИС' q, (if P < q then g q else 0) = (вИС' q, g q) - вИС q вИИ Finset.range (P + 1), g q := by
  have h := hg.sum_add_tsum_compl (s := Finset.range (P + 1))
  have hcompl : (вЖС(Finset.range (P + 1)) : Set вДХ)бґЬ = {q : вДХ | P < q} := by
    ext q; simp only [Finset.coe_range, Set.mem_compl_iff, Set.mem_Iio, Set.mem_setOf_eq, not_lt]
    omega
  rw [hcompl] at h
  have heq : вИС' q, (if P < q then g q else 0) = вИС' i : {q : вДХ | P < q}, g i := by
    rw [_root_.tsum_subtype]
    apply tsum_congr
    intro q
    rw [Set.indicator_apply]
    simp only [Set.mem_setOf_eq]
  rw [heq]; linarith [h]

/-- **Tail вЖТ 0**: `вИС'_{q>P} ќЉ¬≤/ѕЖ^{3/2} вЖТ 0` as `P вЖТ вИЮ` (tail of a convergent series). -/
lemma tail_pow32_tendsto_zero :
    Tendsto (fun P => вИС' q, (if P < q then
        (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0))
      atTop (рЭУЭ 0) := by
  have hg : Summable (fun q : вДХ => (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) :=
    phi_pow32_summable
  have hpart : Tendsto (fun P => вИС q вИИ Finset.range (P + 1),
      (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) atTop
      (рЭУЭ (вИС' q, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2))) :=
    (hg.hasSum.tendsto_sum_nat).comp (tendsto_add_atTop_nat 1)
  have hfun : (fun P => вИС' q, (if P < q then
        (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0))
      = (fun P => (вИС' q, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2))
          - вИС q вИИ Finset.range (P + 1), (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) := by
    funext P; exact tail_eq_tsum_sub _ hg P
  rw [hfun]
  have hz : (вИС' q, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2))
      - (вИС' q, (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2)) = 0 := by ring
  rw [вЖР hz]
  exact Tendsto.sub tendsto_const_nhds hpart

/-- **ќµ-smallness**: for every `ќµ>0`, eventually in `P`, `e¬Ј(вИС'_{q>P}ќЉ¬≤/ѕЖ^{3/2})¬≤ вЙ§ ќµ`. The tail
    `вЖТ0` drives the harc truncation sub-error to `o(X)` once `P = P(X) вЖТ вИЮ`. -/
lemma tarith_trunc_eps_small (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ PвВА : вДХ, вИА P вЙ• PвВА, Real.exp 1 * (вИС' q, (if P < q then
        (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)) ^ 2 вЙ§ ќµ := by
  have hcont : Tendsto (fun P => Real.exp 1 * (вИС' q, (if P < q then
      (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)) ^ 2)
      atTop (рЭУЭ (Real.exp 1 * (0 : вДЭ) ^ 2)) :=
    Tendsto.const_mul _ (tail_pow32_tendsto_zero.pow 2)
  rw [show Real.exp 1 * (0 : вДЭ) ^ 2 = 0 by ring] at hcont
  rw [Metric.tendsto_atTop] at hcont
  obtain вЯ®PвВА, hPвВАвЯ© := hcont ќµ hќµ
  refine вЯ®PвВА, fun P hP => ?_вЯ©
  have hd := hPвВА P hP
  rw [Real.dist_eq, sub_zero] at hd
  have hnn : (0 : вДЭ) вЙ§ Real.exp 1 * (вИС' q, (if P < q then
      (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)) ^ 2 := by
    positivity
  rw [abs_of_nonneg hnn] at hd
  linarith

end EpsSmall

section TruncFinal
open Filter Topology

/-- **Truncation sub-error** (the `l2_error_triangle` input `h2`, in tail form): for a bounded weight
    `rN` (`|rN| вЙ§ X+1`) and a cutoff `Pf вЖТ вИЮ`, `вИС_{nвИИ(X/2,X]}((вИС'_{q>Pf X}T)¬ЈrN)¬≤ вЙ§ ќµX¬≥` eventually.
    Combines the Minkowski bound (`tarith_tail_l2_le`) + ќµ-smallness (`tarith_trunc_eps_small`) +
    `rN¬≤ вЙ§ (X+1)¬≤ вЙ§ 4X¬≤`. The truncation half of `harc` is now a single, fully-proven inequality. -/
lemma trunc_sub_error (rN : вДХ вЖТ вДХ вЖТ вДЭ) (Pf : вДХ вЖТ вДХ)
    (hrN : вИА X : вДХ, вИА n вИИ Finset.Ioc (X / 2) X, (rN X n) ^ 2 вЙ§ ((X : вДЭ) + 1) ^ 2)
    (hPf : Tendsto Pf atTop atTop) :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X, ((вИС' q, (if Pf X < q then Tarithv n q else 0)) * rN X n) ^ 2
        вЙ§ ќµ * (X : вДЭ) ^ 3 := by
  intro ќµ hќµ
  obtain вЯ®PвВА, hPвВАвЯ© := tarith_trunc_eps_small (ќµ / 8) (by positivity)
  obtain вЯ®XвВБ, hXвВБвЯ© := eventually_atTop.mp (tendsto_atTop.mp hPf PвВА)
  refine вЯ®max XвВБ 1, fun X hX => ?_вЯ©
  have hX1 : XвВБ вЙ§ X := le_trans (le_max_left _ _) hX
  have hXpos : 1 вЙ§ X := le_trans (le_max_right _ _) hX
  have hXR : (1 : вДЭ) вЙ§ (X : вДЭ) := by exact_mod_cast hXpos
  have hPfP : PвВА вЙ§ Pf X := hXвВБ X hX1
  have heps := hPвВА (Pf X) hPfP
  have htail := tarith_tail_l2_le (Pf X) X
  set T2 := (вИС' q, (if Pf X < q then
    (ArithmeticFunction.moebius q : вДЭ) ^ 2 / (Nat.totient q : вДЭ) ^ ((3 : вДЭ) / 2) else 0)) ^ 2 with hT2def
  have hstep : вИС n вИИ Finset.Ioc (X / 2) X, ((вИС' q, if Pf X < q then Tarithv n q else 0) * rN X n) ^ 2
      вЙ§ ((X : вДЭ) + 1) ^ 2 * вИС n вИИ Finset.Ioc (X / 2) X, (вИС' q, if Pf X < q then Tarithv n q else 0) ^ 2 := by
    rw [Finset.mul_sum]
    apply Finset.sum_le_sum; intro n hn
    rw [mul_pow]
    nlinarith [hrN X n hn, sq_nonneg (вИС' q, if Pf X < q then Tarithv n q else 0)]
  calc вИС n вИИ Finset.Ioc (X / 2) X, ((вИС' q, if Pf X < q then Tarithv n q else 0) * rN X n) ^ 2
      вЙ§ ((X : вДЭ) + 1) ^ 2 * вИС n вИИ Finset.Ioc (X / 2) X, (вИС' q, if Pf X < q then Tarithv n q else 0) ^ 2 :=
        hstep
    _ вЙ§ ((X : вДЭ) + 1) ^ 2 * (Real.exp 1 * (X : вДЭ) * T2) :=
        mul_le_mul_of_nonneg_left htail (by positivity)
    _ вЙ§ ќµ * (X : вДЭ) ^ 3 := by
        have hstep2 : Real.exp 1 * (X : вДЭ) * T2 вЙ§ (X : вДЭ) * (ќµ / 8) := by
          rw [show Real.exp 1 * (X : вДЭ) * T2 = (X : вДЭ) * (Real.exp 1 * T2) by ring]
          exact mul_le_mul_of_nonneg_left heps (by positivity)
        have hstep3 : ((X : вДЭ) + 1) ^ 2 * (Real.exp 1 * (X : вДЭ) * T2)
            вЙ§ ((X : вДЭ) + 1) ^ 2 * ((X : вДЭ) * (ќµ / 8)) :=
          mul_le_mul_of_nonneg_left hstep2 (by positivity)
        have hstep4 : ((X : вДЭ) + 1) ^ 2 * ((X : вДЭ) * (ќµ / 8)) вЙ§ ќµ * (X : вДЭ) ^ 3 := by
          have hk : (0 : вДЭ) вЙ§ 7 * (X : вДЭ) ^ 3 - 2 * (X : вДЭ) ^ 2 - (X : вДЭ) := by
            nlinarith [mul_nonneg (sub_nonneg.mpr hXR) (sq_nonneg (X : вДЭ)),
              mul_nonneg (sub_nonneg.mpr hXR) (show (0:вДЭ) вЙ§ (X:вДЭ) by linarith), hXR]
          nlinarith [mul_nonneg hќµ.le hk]
        linarith [hstep3, hstep4]

end TruncFinal

section SingSeriesBridge




/-- **Singular-series tail bridge**: `вИС'_q (if P<q then T(q) else 0) = рЭФЦ(n) вИТ рЭФЦ_P(n)` for `n вЙ• 1`.
    Connects `trunc_sub_error`'s tail form to `g вИТ h = (рЭФЦ_P вИТ рЭФЦ)¬ЈrN` of `l2_error_triangle` (since
    `(рЭФЦ_P вИТ рЭФЦ)¬≤ = (вИС'_{q>P}T)¬≤`). Via `singSeries_eq_sum_Tarithv` + `tail_eq_tsum_sub`
    (`вИС_{range(P+1)} = вИС_{Icc 1 P}` as `T(0)=0`). -/
lemma singSeries_tail (P n : вДХ) (hn : 1 вЙ§ n) :
    вИС' q, (if P < q then Tarithv n q else 0) = (вИС' q, Tarithv n q) - singSeries P n := by
  have hsummable : Summable (fun q => Tarithv n q) := summable_norm_iff.mp (Tarith_summable_v n hn)
  have hrange : Finset.range (P + 1) = insert 0 (Finset.Icc 1 P) := by
    ext q; simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]; omega
  have h0notin : (0 : вДХ) вИЙ Finset.Icc 1 P := by simp
  have hsplit : вИС q вИИ Finset.range (P + 1), Tarithv n q = вИС q вИИ Finset.Icc 1 P, Tarithv n q := by
    rw [hrange, Finset.sum_insert h0notin, Tarithv_zero, zero_add]
  rw [singSeries_eq_sum_Tarithv, tail_eq_tsum_sub (fun q => Tarithv n q) hsummable P, hsplit]

end SingSeriesBridge

/-- The tail bridge in the `Icc`-sum form `harc_proven` consumes. -/
theorem singSeries_tail' (P n : вДХ) (hn : 1 вЙ§ n) :
    вИС' q, (if P < q then Tarithv n q else 0)
      = (вИС' q, Tarithv n q) - вИС q вИИ Finset.Icc 1 P, Tarithv n q := by
  rw [вЖР singSeries_eq_sum_Tarithv]
  exact singSeries_tail P n hn

section HabB
open MeasureTheory Finset

/-- **harc brick 85: the arc-tail leg of `l2_error_triangle`.** With `P = вМК(log(X+1))вБєвМЛвВК`,
    `Q = (X+1)/P`: `вИС_{nвИИ(X/2,X]} (Re coeffModel(n) вИТ r_{X+1}(n)¬ЈRe рЭФЦ_P^вДВ(n))¬≤ вЙ§ ќµX¬≥`
    eventually. Bessel + the B5 chain + the polylog numerics. -/
lemma h1_arcTail (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    вИГ XвВА : вДХ, вИА X : вДХ, XвВА вЙ§ X вЖТ
      вИС n вИИ Finset.Ioc (X / 2) X,
        ((coeffModel (X + 1) (Nat.floor ((Real.log (X + 1 : вДХ)) ^ 9))
