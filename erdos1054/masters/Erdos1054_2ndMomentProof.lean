            вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
              вИ© Set.Ioc (0:вДЭ) 1,
            ((вИС r вИИ Finset.range pq.1,
                e ((r : вДЭ) * (pq.2 : вДЭ) / (pq.1 : вДЭ)) * lambdaModel pq.1 r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±)))вАЦ ^ 2
      вЙ§ C * P ^ 4 * (2 * (N:вДЭ)) * ((N:вДЭ) ^ 2 / (Q + 1)) ^ 2 * (Real.log N + 1) ^ 2
        * (1 + (N:вДЭ) / (Q + 1)) ^ 2
