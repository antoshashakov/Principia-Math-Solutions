      _ вЙ§ вАЦs - ѕБвАЦ := Complex.abs_re_le_norm _
  linarith [h1, hgap, hre, hsre]

set_option maxHeartbeats 2000000 in
/-- **The contour `LвА≤/L` bound** (SW brick B1c): with `c(ќµ)` from the zero-free
    region and `L_T := log(N(4(T+1)+7))+20`, every `s` in the strip
    `1 вИТ g/2 вЙ§ Re s вЙ§ 1 + g`, `|Im s| вЙ§ T` (`g := c¬ЈN^{вИТќµ}/L_T`) has
    `вАЦLвА≤/L(s,ѕЗ)вАЦ вЙ§ C(ќµ)¬ЈN^ќµ¬ЈL_T¬≤` вАФ Landau partial fractions at `1+g+i¬ЈIm s`,
    every zero at distance `вЙ• g/2`, at most `2¬Јlog` zeros. -/
theorem contour_logDeriv_bound (ќµ : вДЭ) (hќµ0 : 0 < ќµ) :
    вИГ c C : вДЭ, 0 < c вИІ c вЙ§ 1/2 вИІ 1 вЙ§ C вИІ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    вИА T : вДЭ, 0 вЙ§ T вЖТ вИА s : вДВ, |s.im| вЙ§ T вЖТ
    1 - c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ s.re вЖТ
    s.re вЙ§ 1 + c * ((N:вДЭ))^(-ќµ) / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) вЖТ
    вАЦlogDeriv (DirichletCharacter.LFunction ѕЗ) sвАЦ
      вЙ§ C * ((N:вДЭ))^ќµ * (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20)^2 := by
  obtain вЯ®cвВА, hcвВА0, hcвВАвЯ© := contour_zero_distance ќµ hќµ0
  obtain вЯ®c, hcdefвЯ© : вИГ x : вДЭ, x = min cвВА (1/2) := вЯ®_, rflвЯ©
  have hc0 : 0 < c := by
    rw [hcdef]
    exact lt_min hcвВА0 (by norm_num)
  have hc12 : c вЙ§ 1/2 := by rw [hcdef]; exact min_le_right _ _
  have hccвВА : c вЙ§ cвВА := by rw [hcdef]; exact min_le_left _ _
  have hlogc0 : 0 вЙ§ Real.log (1/c) := by
    apply Real.log_nonneg
    rw [le_div_iffвВА hc0]
    linarith
  obtain вЯ®Kc, hKcdefвЯ© : вИГ x : вДЭ, x = 3 + ќµ + Real.log (1/c) := вЯ®_, rflвЯ©
  have hKc3 : 3 вЙ§ Kc := by rw [hKcdef]; linarith
  obtain вЯ®C, hCdefвЯ© : вИГ x : вДЭ, x = 4*Kc/c + 80*Kc := вЯ®_, rflвЯ©
  have hC1 : 1 вЙ§ C := by
    rw [hCdef]
    have h1 : (0:вДЭ) вЙ§ 4*Kc/c := by positivity
    linarith [hKc3]
  refine вЯ®c, C, hc0, hc12, hC1, ?_вЯ©
  intro N _ ѕЗ hѕЗ1 T hT0 s hsim hsre1 hsre2
  have hN1r : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  have hNe0 : (0:вДЭ) < ((N:вДЭ))^(-ќµ) := Real.rpow_pos_of_pos (by linarith) _
  have hNe1 : ((N:вДЭ))^(-ќµ) вЙ§ 1 :=
    Real.rpow_le_one_of_one_le_of_nonpos hN1r (by linarith)
  have hNp1 : (1:вДЭ) вЙ§ ((N:вДЭ))^ќµ :=
    Real.one_le_rpow hN1r (by linarith)
  have hNcancel : ((N:вДЭ))^(-ќµ) * ((N:вДЭ))^ќµ = 1 := by
    rw [вЖР Real.rpow_add (by linarith : (0:вДЭ) < (N:вДЭ))]
    simp
  obtain вЯ®LT, hLTdefвЯ© : вИГ x : вДЭ, x = Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20 := вЯ®_, rflвЯ©
  rw [вЖР hLTdef] at hsre1 hsre2 вКҐ
  have hargT1 : (1:вДЭ) вЙ§ (N:вДЭ)*(4*(T+1)+7) := by nlinarith
  have hLT20 : 20 вЙ§ LT := by
    rw [hLTdef]
    have := Real.log_nonneg hargT1
    linarith
  obtain вЯ®g, hgdefвЯ© : вИГ x : вДЭ, x = c * ((N:вДЭ))^(-ќµ) / LT := вЯ®_, rflвЯ©
  rw [вЖР hgdef] at hsre1 hsre2
  have hg0 : 0 < g := by
    rw [hgdef]
    positivity
  have hg40 : g вЙ§ 1/40 := by
    rw [hgdef, div_le_iffвВА (by linarith : (0:вДЭ) < LT)]
    nlinarith [hNe1, hNe0.le, hc12, hLT20, hc0]
  -- Landau at the center 1+g + i¬ЈIm s
  obtain вЯ®S, m, hSz, hm, hcomp, hmpos, hcount, hboundвЯ© :=
    landau_LFunction_count N ѕЗ hѕЗ1 (1+g) s.im (by linarith) (by linarith)
  have hs1g : (1 + g) - 1 = g := by ring
  rw [hs1g] at hcount hbound
  -- s is in the evaluation ball
  have hsc : вАЦs - (((1+g : вДЭ) : вДВ) + s.im * Complex.I)вАЦ = |s.re - (1+g)| := by
    have h1 : s - (((1+g : вДЭ) : вДВ) + s.im * Complex.I)
        = ((s.re - (1+g) : вДЭ) : вДВ) := by
      apply Complex.ext
      ¬Ј simp [Complex.sub_re, Complex.add_re, Complex.mul_re]
      ¬Ј simp [Complex.sub_im, Complex.add_im, Complex.mul_im]
    rw [h1, Complex.norm_real, Real.norm_eq_abs]
  have hsc20 : вАЦs - (((1+g : вДЭ) : вДВ) + s.im * Complex.I)вАЦ вЙ§ 3/80 := by
    rw [hsc, abs_le]
    constructor <;> nlinarith [hsre1, hsre2, hg0, hg40]
  have hsball : s вИИ ball (((1+g : вДЭ) : вДВ) + s.im * Complex.I) (1/20) := by
    rw [mem_ball, dist_eq_norm]
    calc вАЦs - (((1+g : вДЭ) : вДВ) + s.im * Complex.I)вАЦ вЙ§ 3/80 := hsc20
      _ < 1/20 := by norm_num
  -- every Landau zero keeps distance вЙ• g/2
  have hsre1' : 1 - cвВА * ((N:вДЭ))^(-ќµ)
      / (Real.log ((N:вДЭ)*(4*(T+1)+7)) + 20) / 2 вЙ§ s.re := by
    rw [вЖР hLTdef]
    have h3 : c * ((N:вДЭ))^(-ќµ) / LT вЙ§ cвВА * ((N:вДЭ))^(-ќµ) / LT := by
      rw [div_le_div_iffвВА (by linarith : (0:вДЭ) < LT) (by linarith : (0:вДЭ) < LT)]
      have h4 := mul_le_mul_of_nonneg_right hccвВА hNe0.le
      nlinarith [h4, hLT20]
    linarith [hsre1, h3, hgdef.le, hgdef.ge]
  have hdist : вИА ѕБ вИИ S, g/2 вЙ§ вАЦs - ѕБвАЦ := by
    intro ѕБ hѕБ
    obtain вЯ®hѕБball, hѕБzeroвЯ© := hSz ѕБ hѕБ
    rw [mem_closedBall, dist_eq_norm] at hѕБball
    have h1 : вАЦs - ѕБвАЦ вЙ§ 1 := by
      have h1b : вАЦ(((1+g : вДЭ) : вДВ) + s.im * Complex.I) - ѕБвАЦ вЙ§ 1/5 := by
        rw [norm_sub_rev]
        exact hѕБball
      calc вАЦs - ѕБвАЦ = вАЦ(s - (((1+g : вДЭ) : вДВ) + s.im * Complex.I))
            + ((((1+g : вДЭ) : вДВ) + s.im * Complex.I) - ѕБ)вАЦ := by ring_nf
        _ вЙ§ вАЦs - (((1+g : вДЭ) : вДВ) + s.im * Complex.I)вАЦ
            + вАЦ(((1+g : вДЭ) : вДВ) + s.im * Complex.I) - ѕБвАЦ := norm_add_le _ _
        _ вЙ§ 3/80 + 1/5 := by linarith [hsc20, h1b]
        _ вЙ§ 1 := by norm_num
    have h2 := hcвВА N ѕЗ hѕЗ1 T hT0 s hsim hsre1' ѕБ hѕБzero h1
    rw [вЖР hLTdef] at h2
    have h3 : c * ((N:вДЭ))^(-ќµ) / LT вЙ§ cвВА * ((N:вДЭ))^(-ќµ) / LT := by
      rw [div_le_div_iffвВА (by linarith : (0:вДЭ) < LT) (by linarith : (0:вДЭ) < LT)]
      have h4 := mul_le_mul_of_nonneg_right hccвВА hNe0.le
      nlinarith [h4, hLT20]
    rw [hgdef]
    linarith [h2, h3]
  have hzS : вИА ѕБ вИИ S, s вЙ† ѕБ := by
    intro ѕБ hѕБ heq
    have h5 := hdist ѕБ hѕБ
    rw [heq, sub_self, norm_zero] at h5
    linarith [hg0]
  have hb := hbound s hsball hzS
  -- the partial-fraction sum
  have hsum : вАЦвИС ѕБ вИИ S, ((m ѕБ : вДВ)) / (s - ѕБ)вАЦ вЙ§ (вИС ѕБ вИИ S, (m ѕБ : вДЭ)) * (2/g) := by
    calc вАЦвИС ѕБ вИИ S, ((m ѕБ : вДВ)) / (s - ѕБ)вАЦ вЙ§ вИС ѕБ вИИ S, вАЦ((m ѕБ : вДВ)) / (s - ѕБ)вАЦ :=
        norm_sum_le _ _
      _ вЙ§ вИС ѕБ вИИ S, (m ѕБ : вДЭ) * (2/g) := by
          apply Finset.sum_le_sum
          intro ѕБ hѕБ
          rw [norm_div, Complex.norm_natCast]
          have h5 := hdist ѕБ hѕБ
          have h6 : (0:вДЭ) < вАЦs - ѕБвАЦ := by linarith [hg0]
          rw [div_le_iffвВА h6]
          have h7 := mul_le_mul_of_nonneg_left h5
            (by positivity : (0:вДЭ) вЙ§ (m ѕБ : вДЭ) * (2/g))
          have h8 : (m ѕБ : вДЭ) * (2/g) * (g/2) = (m ѕБ : вДЭ) := by
            field_simp
          linarith [h7, h8.le, h8.ge]
      _ = (вИС ѕБ вИИ S, (m ѕБ : вДЭ)) * (2/g) := by
          rw [вЖР Finset.sum_mul]
  -- the log-argument bound
  have hg1 : (1:вДЭ)/g = LT * ((N:вДЭ))^ќµ / c := by
    have h9 : g * (LT * ((N:вДЭ))^ќµ / c) = 1 := by
      rw [hgdef]
      calc c * ((N:вДЭ))^(-ќµ) / LT * (LT * ((N:вДЭ))^ќµ / c)
          = (((N:вДЭ))^(-ќµ) * ((N:вДЭ))^ќµ) * ((c/c) * (LT/LT)) := by ring
        _ = 1 := by
            rw [hNcancel, div_self (ne_of_gt hc0),
              div_self (by linarith : LT вЙ† 0)]
