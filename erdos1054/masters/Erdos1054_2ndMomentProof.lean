      ¬Ј have hhalf : X / 2 < X := Nat.div_lt_self hXpos (by norm_num)
        rw [cnt_split Bad X]
        have hIH := IH (X / 2) hhalf
        have hb := hblk X hX
        have hhcast : (2 : вДЭ) * ((X / 2 : вДХ) : вДЭ) вЙ§ (X : вДЭ) := by
          have : 2 * (X / 2) вЙ§ X := by omega
          exact_mod_cast this
        push_cast; push_cast at hIH; nlinarith [hIH, hb, hќµ, hhcast]
    ¬Ј have hle : (((range (X + 1)).filter Bad).card : вДЭ) вЙ§ (X : вДЭ) + 1 := by
        have h := Finset.card_filter_le (range (X + 1)) Bad
        simp only [Finset.card_range] at h; exact_mod_cast h
      have hXX0 : (X : вДЭ) + 1 вЙ§ (XвВА : вДЭ) + 1 := by
        have : X + 1 вЙ§ XвВА + 1 := by omega
        exact_mod_cast this
      have : (0 : вДЭ) вЙ§ 2 * ќµ * X := by positivity
      linarith

theorem densityZero_of_block
    (h : вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА, вИА X, XвВА вЙ§ X вЖТ
        (((Ioc (X / 2) X).filter Bad).card : вДЭ) вЙ§ ќµ * X) :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ вИГ XвВА, вИА X, XвВА вЙ§ X вЖТ
        (((range (X + 1)).filter Bad).card : вДЭ) вЙ§ ќµ * X := by
  intro ќµ hќµ
  obtain вЯ®XвВА, hXвВАвЯ© := h (ќµ / 4) (by positivity)
  obtain вЯ®XвВБ, hXвВБвЯ© := exists_nat_gt (2 * (XвВА + 1) / ќµ)
  refine вЯ®max XвВА XвВБ, fun X hX => ?_вЯ©
  have hXXвВБ : XвВБ вЙ§ X := le_trans (le_max_right _ _) hX
  have hbound := cnt_bound Bad (ќµ / 4) (by positivity) XвВА hXвВА X
  have hXpos : (0 : вДЭ) < X := by
    have : (0 : вДЭ) < XвВБ := lt_of_le_of_lt (by positivity) hXвВБ
    exact lt_of_lt_of_le this (by exact_mod_cast hXXвВБ)
  have hconst : ((XвВА : вДЭ) + 1) вЙ§ ќµ / 2 * X := by
    have h2 : (XвВБ : вДЭ) вЙ§ X := by exact_mod_cast hXXвВБ
    have hle : 2 * ((XвВА : вДЭ) + 1) / ќµ вЙ§ X := le_trans (le_of_lt hXвВБ) h2
    rw [div_le_iffвВА hќµ] at hle
    nlinarith [hle, hXpos, hќµ]
  calc (((range (X + 1)).filter Bad).card : вДЭ)
      вЙ§ 2 * (ќµ / 4) * X + ((XвВА : вДЭ) + 1) := hbound
    _ вЙ§ ќµ / 2 * X + ќµ / 2 * X := by rw [show 2 * (ќµ / 4) = ќµ / 2 by ring]; linarith [hconst]
    _ = ќµ * X := by ring

