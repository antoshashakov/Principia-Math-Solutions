section MertensThirdProof

open Finset ArithmeticFunction Real
open scoped BigOperators

set_option maxHeartbeats 800000
set_option maxRecDepth 4000

noncomputable section

/-- ѕИ(n) = ќ£_{m=1}^{n} ќЫ(m), the first Chebyshev function. -/
def chebyshevPsi (n : вДХ) : вДЭ :=
  вИС m вИИ Finset.range (n + 1), vonMangoldt m

/-- L_n = lcm(1, 2, ..., n). -/
def lcmRange (n : вДХ) : вДХ :=
  (Finset.Icc 1 n).lcm _root_.id

/-- S(n) = ќ£_{m=2}^{n} ќЫ(m)/m. -/
def sumS (n : вДХ) : вДЭ :=
  вИС m вИИ Finset.Icc 2 n, vonMangoldt m / m

/-- T(n) = ќ£_{m=2}^{n} ќЫ(m)/(m * log m). -/
def sumT (n : вДХ) : вДЭ :=
  вИС m вИИ Finset.Icc 2 n, vonMangoldt m / (m * Real.log m)

/-- P(n) = вИП_{p вЙ§ n, p prime} (1 - 1/p). -/
def prodP (n : вДХ) : вДЭ :=
  вИП p вИИ (Finset.range (n + 1)).filter Nat.Prime, (1 - 1 / (p : вДЭ))

end

noncomputable section

/-! # Lemma: Central Binomial Coefficient Bounds -/

lemma centralBinom_le_four_pow (r : вДХ) (hr : 1 вЙ§ r) :
    Nat.choose (2 * r) r вЙ§ 4 ^ r := by
  rw [show 4 ^ r = (2 : вДХ) ^ (2 * r) by norm_num [pow_mul]]
  rw [вЖР Nat.sum_range_choose]
  exact Finset.single_le_sum (fun x _ => Nat.zero_le _)
    (Finset.mem_range.mpr (by linarith))

lemma choose_odd_le_four_pow (r : вДХ) (_hr : 1 вЙ§ r) :
    Nat.choose (2 * r + 1) r вЙ§ 4 ^ r := by
  exact Nat.choose_middle_le_pow r

/-! # LCM helpers -/

lemma lcmRange_pos (n : вДХ) (_hn : 1 вЙ§ n) : 0 < lcmRange n := by
  exact Nat.pos_of_ne_zero ( mt Finset.lcm_eq_zero_iff.mp ( by aesop ) )

lemma lcmRange_dvd_of_le {m n : вДХ} (hm : 1 вЙ§ m) (hmn : m вЙ§ n) :
    m вИ£ lcmRange n := by
  exact Finset.dvd_lcm ( Finset.mem_Icc.mpr вЯ® hm, hmn вЯ© )

/-! # LCM Divisibility Lemmas -/

lemma lcmRange_dvd_even (r : вДХ) (hr : 1 вЙ§ r) :
    lcmRange (2 * r) вИ£ lcmRange r * Nat.choose (2 * r) r := by
  -- By definition of lcmRange, we need to show that for every prime power $p^a$ dividing $m \in (1, 2r]$, $p^a$ divides $lcmRange(r) * \binom{2r}{r}$.
  have h_div : вИА m вИИ Finset.Icc 1 (2 * r), вИА p вИИ Nat.primeFactors m, p ^ Nat.factorization m p вИ£ lcmRange r * Nat.choose (2 * r) r := by
    intro m hm p hp
    by_cases hpa : p ^ Nat.factorization m p вЙ§ r;
    ¬Ј exact dvd_mul_of_dvd_left ( Finset.dvd_lcm ( Finset.mem_Icc.mpr вЯ® Nat.one_le_pow _ _ ( Nat.pos_of_mem_primeFactors hp ), hpa вЯ© ) ) _;
    ¬Ј -- Since $p^a > r$, we have $p^{a-1} \leq r$.
      have hpa_minus_one : p ^ (Nat.factorization m p - 1) вЙ§ r := by
        rcases k : Nat.factorization m p with ( _ | k ) <;> simp_all +decide [ pow_succ' ];
        nlinarith [ hp.1.two_le, Nat.le_of_dvd hm.1 ( Nat.ordProj_dvd m p ), Nat.le_of_dvd hm.1 ( Nat.ordProj_dvd m p ), show m вЙ• p ^ ( Nat.factorization m p ) from Nat.le_of_dvd hm.1 ( Nat.ordProj_dvd m p ), show p ^ ( Nat.factorization m p ) = p * p ^ вАє_вАЇ from by rw [ вЖР pow_succ', k ] ];
      -- Since $p^{a-1} \leq r$, we have $p^{a-1} \mid lcmRange(r)$.
      have hpa_minus_one_div : p ^ (Nat.factorization m p - 1) вИ£ lcmRange r := by
        exact lcmRange_dvd_of_le ( pow_pos ( Nat.pos_of_mem_primeFactors hp ) _ ) hpa_minus_one;
      -- Since $p^a > r$, we have $p \mid \binom{2r}{r}$.
      have hpa_div_choose : p вИ£ Nat.choose (2 * r) r := by
        have hpa_div_choose : Nat.factorization (Nat.choose (2 * r) r) p вЙ• 1 := by
          have hpa_div_choose : Nat.factorization (Nat.choose (2 * r) r) p = (вИС k вИИ Finset.Ico 1 (Nat.log p (2 * r) + 1), (Nat.floor ((2 * r) / p ^ k) - 2 * Nat.floor (r / p ^ k))) := by
            haveI := Fact.mk ( Nat.prime_of_mem_primeFactors hp ) ; rw [ Nat.factorization_def ];
            ¬Ј rw [ padicValNat_choose ];
              any_goals exact Nat.lt_succ_self _;
              ¬Ј norm_num [ two_mul, Nat.add_div ];
                rw [ Finset.card_filter ];
                refine' Finset.sum_congr rfl fun x hx => _;
                rw [ Nat.add_div ( pow_pos ( Nat.Prime.pos ( Nat.prime_of_mem_primeFactors hp ) ) _ ) ] ; aesop;
              ¬Ј linarith;
            ¬Ј exact Nat.prime_of_mem_primeFactors hp;
          rw [hpa_div_choose];
          refine' le_trans _ ( Finset.single_le_sum ( fun x hx => Nat.zero_le _ ) ( Finset.mem_Ico.mpr вЯ® Nat.succ_le_of_lt ( Nat.pos_of_ne_zero ( show m.factorization p вЙ† 0 from Finsupp.mem_support_iff.mp hp ) ), Nat.lt_succ_of_le ( Nat.le_log_of_pow_le ( Nat.Prime.one_lt ( Nat.prime_of_mem_primeFactors hp ) ) ( show p ^ m.factorization p вЙ§ 2 * r from _ ) ) вЯ© ) );
          ¬Ј norm_num [ Nat.div_eq_of_lt ( show r < p ^ m.factorization p from lt_of_not_ge hpa ) ];
            exact Nat.div_pos ( by linarith [ Finset.mem_Icc.mp hm, Nat.le_of_dvd ( by linarith [ Finset.mem_Icc.mp hm ] ) ( Nat.ordProj_dvd m p ) ] ) ( pow_pos ( Nat.pos_of_mem_primeFactors hp ) _ );
          ¬Ј exact le_trans ( Nat.le_of_dvd ( by linarith [ Finset.mem_Icc.mp hm ] ) ( Nat.ordProj_dvd _ _ ) ) ( by linarith [ Finset.mem_Icc.mp hm ] );
        exact Nat.dvd_trans ( dvd_pow_self _ ( by linarith ) ) ( Nat.ordProj_dvd _ _ );
      convert Nat.mul_dvd_mul hpa_minus_one_div hpa_div_choose using 1 ; rw [ вЖР pow_succ, Nat.sub_add_cancel ( Nat.succ_le_of_lt ( Nat.pos_of_ne_zero ( Finsupp.mem_support_iff.mp hp ) ) ) ];
  -- Since every prime power in the lcm divides the product, the lcm itself must divide the product.
  have h_lcm_div : вИА m вИИ Finset.Icc 1 (2 * r), m вИ£ lcmRange r * Nat.choose (2 * r) r := by
    intro m hm
    have h_prod_div : вИП p вИИ Nat.primeFactors m, p ^ Nat.factorization m p вИ£ lcmRange r * Nat.choose (2 * r) r := by
      convert Finset.lcm_dvd fun p hp => h_div m hm p hp using 1 <;> try rfl;
      -- The least common multiple of a set of numbers is equal to their product divided by their greatest common divisor.
      have h_lcm_prod : вИА {S : Finset вДХ} {f : вДХ вЖТ вДХ}, (вИА p вИИ S, Nat.Prime p) вЖТ (вИА p q : вДХ, p вИИ S вЖТ q вИИ S вЖТ p вЙ† q вЖТ Nat.gcd (p ^ f p) (q ^ f q) = 1) вЖТ Finset.lcm S (fun p => p ^ f p) = вИП p вИИ S, p ^ f p := by
        intros S f hprime hgcd; induction S using Finset.induction <;> simp_all +decide ;
        exact Nat.Coprime.lcm_eq_mul <| Nat.Coprime.prod_right fun p hp => hgcd _ _ ( Or.inl rfl ) ( Or.inr hp ) <| by aesop;
      rw [ h_lcm_prod ( fun p hp => Nat.prime_of_mem_primeFactors hp ) ( fun p q hp hq hpq => by simpa [ hpq ] using Nat.coprime_pow_primes _ _ ( Nat.prime_of_mem_primeFactors hp ) ( Nat.prime_of_mem_primeFactors hq ) ) ];
    rwa [ вЖР Nat.factorization_prod_pow_eq_self ( by linarith [ Finset.mem_Icc.mp hm ] : m вЙ† 0 ) ];
  exact Finset.lcm_dvd h_lcm_div

lemma lcmRange_dvd_odd (r : вДХ) (hr : 1 вЙ§ r) :
    lcmRange (2 * r + 1) вИ£ lcmRange (r + 1) * Nat.choose (2 * r + 1) r := by
  -- For any prime power $p^a \leq 2r+1$, we need to show that $p^a$ divides $lcmRange(r+1) * (2r+1 choose r)$.
  have h_prime_power : вИА p a : вДХ, Nat.Prime p вЖТ p^a вЙ§ 2 * r + 1 вЖТ p^a вИ£ lcmRange (r + 1) * Nat.choose (2 * r + 1) r := by
    intro p a hp ha
    by_cases hpa : p^a вЙ§ r + 1;
    ¬Ј refine' dvd_mul_of_dvd_left _ _;
      exact Finset.dvd_lcm ( Finset.mem_Icc.mpr вЯ® Nat.one_le_pow _ _ hp.pos, hpa вЯ© );
    ¬Ј -- Since $p^a > r + 1$, we have $p^{a-1} \leq r$.
      have hpa_minus_one : p^(a-1) вЙ§ r := by
        rcases a <;> simp_all +decide [ pow_succ' ];
        nlinarith [ hp.two_le ];
      -- Since $p^{a-1} \leq r$, we have $p^a \mid \binom{2r+1}{r}$.
      have hpa_div_choose : p^a вИ£ Nat.choose (2 * r + 1) r * p^(a-1) := by
        have hpa_div_choose : padicValNat p (Nat.choose (2 * r + 1) r) вЙ• 1 := by
          haveI := Fact.mk hp; rw [ padicValNat_choose ];
          any_goals exact Nat.lt_succ_self _;
          ¬Ј refine' Finset.card_pos.mpr вЯ® a, _ вЯ© ; norm_num;
            exact вЯ® вЯ® Nat.pos_of_ne_zero ( by rintro rfl; linarith ), Nat.le_log_of_pow_le hp.one_lt ha вЯ©, by rw [ Nat.mod_eq_of_lt, Nat.mod_eq_of_lt ] <;> omega вЯ©;
          ¬Ј linarith;
        have hpa_div_choose : p вИ£ Nat.choose (2 * r + 1) r := by
          contrapose! hpa_div_choose; simp_all +decide ;
        rcases a with ( _ | a ) <;> simp_all +decide [ pow_succ', mul_dvd_mul ];
      -- Since $p^{a-1} \leq r$, we have $p^{a-1} \mid lcmRange(r+1)$.
      have hpa_minus_one_div_lcm : p^(a-1) вИ£ lcmRange (r + 1) := by
        have hpa_minus_one_div_lcm : p^(a-1) вИИ Finset.Icc 1 (r + 1) := by
          exact Finset.mem_Icc.mpr вЯ® Nat.one_le_pow _ _ hp.pos, by linarith вЯ©;
        exact Finset.dvd_lcm hpa_minus_one_div_lcm;
      exact dvd_trans hpa_div_choose ( by rw [ mul_comm ] ; exact mul_dvd_mul hpa_minus_one_div_lcm dvd_rfl );
  -- By definition of lcmRange, lcmRange (2 * r + 1) divides the product of all numbers in the range 1 to 2r+1.
  have h_lcm_div : вИА m вИИ Finset.Icc 1 (2 * r + 1), m вИ£ lcmRange (r + 1) * Nat.choose (2 * r + 1) r := by
    intro m hm; rw [ вЖР Nat.factorization_le_iff_dvd ] <;> norm_num;
    ¬Ј intro p; by_cases hp : Nat.Prime p <;> by_cases hp' : p вИ£ m <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ] ;
      have := h_prime_power p ( Nat.factorization m p ) hp ( Nat.le_trans ( Nat.le_of_dvd hm.1 ( Nat.ordProj_dvd _ _ ) ) hm.2 ) ; rw [ вЖР Nat.factorization_le_iff_dvd ] at this <;> simp_all +decide ;
      exact вЯ® Nat.ne_of_gt <| Nat.pos_of_ne_zero <| mt Finset.lcm_eq_zero_iff.mp <| by aesop, Nat.ne_of_gt <| Nat.choose_pos <| by linarith вЯ©;
    ¬Ј linarith [ Finset.mem_Icc.mp hm ];
    ¬Ј exact вЯ® Nat.ne_of_gt <| Nat.pos_of_ne_zero <| mt Finset.lcm_eq_zero_iff.mp <| by aesop, Nat.ne_of_gt <| Nat.choose_pos <| by linarith вЯ©;
  exact Finset.lcm_dvd fun x hx => h_lcm_div x hx

/-! # LCM Bound: L_n вЙ§ 4^n -/

lemma lcmRange_le_four_pow (n : вДХ) (hn : 1 вЙ§ n) :
    lcmRange n вЙ§ 4 ^ n := by
  induction' n using Nat.strong_induction_on with n ih;
  by_cases hвВВ : n вЙ§ 4;
  ¬Ј interval_cases n <;> decide;
  ¬Ј rcases Nat.even_or_odd' n with вЯ® k, rfl | rfl вЯ©;
    ¬Ј -- By lcmRange_dvd_even, lcmRange(2k) | lcmRange(k) * choose(2k,k).
      have h_div : lcmRange (2 * k) вИ£ lcmRange k * Nat.choose (2 * k) k := by
        exact lcmRange_dvd_even k ( by linarith );
      -- Since $\binom{2k}{k} \leq 4^k$, we have $lcmRange (2 * k) \leq lcmRange k * 4^k$.
      have h_bound : lcmRange (2 * k) вЙ§ lcmRange k * 4 ^ k := by
        refine' le_trans ( Nat.le_of_dvd ( Nat.mul_pos ( lcmRange_pos k ( by linarith ) ) ( Nat.choose_pos ( by linarith ) ) ) h_div ) _;
        exact Nat.mul_le_mul_left _ ( centralBinom_le_four_pow k ( by linarith ) );
      exact h_bound.trans ( by rw [ pow_mul' ] ; exact Nat.mul_le_mul_right _ ( ih k ( by linarith ) ( by linarith ) ) |> le_trans <| by ring_nf; norm_num );
    ¬Ј -- By lcmRange_dvd_odd, lcmRange(2k+1) | lcmRange(k+1) * choose(2k+1,k).
      have h_div : lcmRange (2 * k + 1) вИ£ lcmRange (k + 1) * Nat.choose (2 * k + 1) k := by
        convert lcmRange_dvd_odd k ( by linarith ) using 1;
      -- By choose_odd_le_four_pow, choose(2k+1,k) вЙ§ 4^k.
      have h_choose : Nat.choose (2 * k + 1) k вЙ§ 4 ^ k := by
        convert choose_odd_le_four_pow k ( by linarith ) using 1;
      refine' le_trans ( Nat.le_of_dvd _ h_div ) _;
      ¬Ј exact mul_pos ( lcmRange_pos _ ( by linarith ) ) ( Nat.choose_pos ( by linarith ) );
      ¬Ј exact le_trans ( Nat.mul_le_mul ( ih _ ( by linarith ) ( by linarith ) ) h_choose ) ( by ring_nf; norm_num )

/-! # Chebyshev ѕИ bound -/

lemma chebyshevPsi_eq_log_lcmRange (n : вДХ) (hn : 1 вЙ§ n) :
    chebyshevPsi n = Real.log (lcmRange n) := by
  -- By definition of ѕИ, we know that ѕИ(n) = ќ£_{m=0}^n ќЫ(m)
  have h_psi_def : chebyshevPsi n = вИС p вИИ Finset.filter Nat.Prime (Finset.range (n + 1)), Nat.log p n * Real.log p := by
    have h_psi_def : chebyshevPsi n = вИС p вИИ Finset.filter Nat.Prime (Finset.range (n + 1)), (вИС k вИИ Finset.Icc 1 (Nat.log p n), Real.log p) := by
      unfold chebyshevPsi;
      have h_sum_floor : вИС m вИИ Finset.range (n + 1), (ArithmeticFunction.vonMangoldt m) = вИС p вИИ Finset.filter Nat.Prime (Finset.range (n + 1)), вИС k вИИ Finset.Icc 1 (Nat.log p n), (ArithmeticFunction.vonMangoldt (p ^ k)) := by
        have h_sum_floor : Finset.filter (fun m => ArithmeticFunction.vonMangoldt m вЙ† 0) (Finset.range (n + 1)) = Finset.biUnion (Finset.filter Nat.Prime (Finset.range (n + 1))) (fun p => Finset.image (fun k => p ^ k) (Finset.Icc 1 (Nat.log p n))) := by
          ext m;
          simp [ArithmeticFunction.vonMangoldt];
          constructor;
          ¬Ј intro hm;
            obtain вЯ® p, k, hp, hk, rfl вЯ© := hm.2.1;
            exact вЯ® p, вЯ® by linarith [ Nat.le_self_pow hk.ne' p ], hp.nat_prime вЯ©, k, вЯ® hk, Nat.le_log_of_pow_le hp.nat_prime.one_lt hm.1 вЯ©, rfl вЯ©;
          ¬Ј rintro вЯ® p, вЯ® hpвВБ, hpвВВ вЯ©, k, вЯ® hkвВБ, hkвВВ вЯ©, rfl вЯ©;
            exact вЯ® Nat.pow_le_of_le_log ( by linarith ) hkвВВ, hpвВВ.isPrimePow.pow ( by linarith ), Nat.ne_of_gt ( Nat.minFac_pos _ ), ne_of_gt ( one_lt_powвВА hpвВВ.one_lt ( by linarith ) ), by linarith вЯ©;
        rw [ вЖР Finset.sum_filter_ne_zero, h_sum_floor, Finset.sum_biUnion ];
        ¬Ј exact Finset.sum_congr rfl fun p hp => Finset.sum_image <| fun a ha b hb h => Nat.pow_right_injective ( Nat.Prime.one_lt <| Finset.mem_filter.mp hp |>.2 ) h;
        ¬Ј intros p hp q hq hpq; simp_all +decide [ Finset.disjoint_left ];
          intro a x hxвВБ hxвВВ hxвВГ y hyвВБ hyвВВ hyвВГ; subst_vars; have := Nat.Prime.dvd_of_dvd_pow hp.2 ( hyвВГ.symm вЦЄ dvd_pow_self _ ( by linarith ) ) ; simp_all +decide [ Nat.prime_dvd_prime_iff_eq ] ;
      convert h_sum_floor using 3;
      rw [ ArithmeticFunction.vonMangoldt_apply ];
      rw [ if_pos ];
      ¬Ј rw [ Nat.Prime.pow_minFac ] <;> aesop;
      ¬Ј exact Nat.Prime.isPrimePow ( Finset.mem_filter.mp вАє_вАЇ |>.2 ) |> fun h => h.pow ( by linarith [ Finset.mem_Icc.mp вАє_вАЇ ] );
    aesop;
  -- By definition of $lcmRange$, we know that $lcmRange n = \prod_{p \leq n} p^{e_p(n)}$ where $e_p(n) = \lfloor \log_p n \rfloor$.
  have h_lcm_def : lcmRange n = вИП p вИИ Finset.filter Nat.Prime (Finset.range (n + 1)), p ^ (Nat.log p n) := by
    clear h_psi_def;
