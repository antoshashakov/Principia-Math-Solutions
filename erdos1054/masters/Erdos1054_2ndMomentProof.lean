    вАЦвИЂ ќ± in Metric.closedBall ((a : вДЭ) / q) (1 / (q * (Q + 1))) вИ© Set.Ioc (0:вДЭ) 1,
        ((вИС k вИИ Finset.range N, ((ќЫ k : вДЭ) : вДВ) * e ((k : вДЭ) * ќ±)) ^ 2
          - ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
              * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±))вАЦ
