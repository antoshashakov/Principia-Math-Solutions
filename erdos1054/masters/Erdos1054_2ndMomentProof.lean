      Real.log_le_rpow_div hx0.le (by norm_num)
    have h2 : ((x:вДЭ)) ^ ((1:вДЭ)/8) / (1/8) = 8 * ((x:вДЭ)) ^ ((1:вДЭ)/8) := by ring
    have h3 : (1:вДЭ) вЙ§ ((x:вДЭ)) ^ ((1:вДЭ)/8) := Real.one_le_rpow hx1r (by norm_num)
