/-- **harc brick B5c: the integral expansion.** The period L¬≤ of ќ®вИТќ¶ splits into the
    coefficient-weighted tail-intersection integrals of kernel-norm products. -/
lemma psi_sub_phi_L2_expand (N P Q : вДХ) (hP : 1 вЙ§ P) (hPQ : 2 * P ^ 2 < Q + 1) :
    вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦPsiIdeal N P ќ± - PhiArc N P Q ќ±вАЦ ^ 2
      вЙ§ вИС x вИИ canonAnchors P, вИС y вИИ canonAnchors P,
          вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
            * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
                вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                  * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ := by
  classical
  -- the summand functions and their integrability on the period
  set F : (ќ£ _ : вДХ, вДХ) вЖТ (ќ£ _ : вДХ, вДХ) вЖТ вДЭ вЖТ вДЭ := fun x y ќ± =>
    вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
      * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
      * (tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2).indicator
          (fun ќ≤ =>
            вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
              * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ) ќ±
    with hFdef
  have hmeasI : вИА x y : (ќ£ _ : вДХ, вДХ),
      MeasurableSet (tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2) := fun x y =>
    (tailSet_measurable P Q x.1 x.2).inter (tailSet_measurable P Q y.1 y.2)
  have hFint : вИА x y : (ќ£ _ : вДХ, вДХ), IntegrableOn (F x y) (Set.Ioc (0:вДЭ) 1) := by
    intro x y
    apply Integrable.const_mul
    apply Integrable.indicator _ (hmeasI x y)
    exact ((kernel_norm_continuous N _).mul (kernel_norm_continuous N _)).integrableOn_Ioc
  -- integrability of the double sum
  have hsum_int : IntegrableOn
      (fun ќ± => вИС x вИИ canonAnchors P, вИС y вИИ canonAnchors P, F x y ќ±) (Set.Ioc (0:вДЭ) 1) := by
    apply integrable_finset_sum
    intro x _
    exact integrable_finset_sum _ (fun y _ => hFint x y)
  -- the LHS integrand is a.e.-measurable and dominated by the double sum
  have hterm_cont : вИА pq : вДХ √Ч вД§, Continuous (fun ќ± : вДЭ =>
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) := by
    intro pq
    apply Continuous.mul continuous_const
    apply Continuous.pow
    apply continuous_finset_sum
    intro k _
    exact continuous_e.comp (by fun_prop)
  have hphi_meas : AEStronglyMeasurable (fun ќ± => PhiArc N P Q ќ±)
      (volume.restrict (Set.Ioc (0:вДЭ) 1)) := by
    have hsm : StronglyMeasurable (fun ќ± => PhiArc N P Q ќ±) := by
      have hrw : (fun ќ± => PhiArc N P Q ќ±)
          = вИС pq вИИ anchors P, (arc Q pq).indicator
              (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
                * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) := by
        funext ќ±
        rw [Finset.sum_apply]
        rfl
      rw [hrw]
      apply Finset.stronglyMeasurable_sum
      intro pq _
      exact ((hterm_cont pq).stronglyMeasurable).indicator
        ((Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc)
    exact hsm.aestronglyMeasurable
  have hpsi_cont : Continuous (fun ќ± => PsiIdeal N P ќ±) := by
    apply continuous_finset_sum
    intro q _
    apply Continuous.mul continuous_const
    apply continuous_finset_sum
    intro a _
    apply Continuous.pow
    apply continuous_finset_sum
    intro k _
    exact continuous_e.comp (by fun_prop)
  have hlhs_meas : AEStronglyMeasurable
      (fun ќ± => вАЦPsiIdeal N P ќ± - PhiArc N P Q ќ±вАЦ ^ 2)
      (volume.restrict (Set.Ioc (0:вДЭ) 1)) :=
    ((hpsi_cont.aestronglyMeasurable.sub hphi_meas).norm.pow 2)
  have hlhs_int : IntegrableOn
      (fun ќ± => вАЦPsiIdeal N P ќ± - PhiArc N P Q ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1) := by
    apply Integrable.mono' hsum_int hlhs_meas
    rw [ae_restrict_iff' measurableSet_Ioc]
    filter_upwards with ќ± hќ±
    rw [Real.norm_eq_abs, abs_of_nonneg (by positivity)]
    exact psi_sub_phi_sq_pointwise N P Q hP hPQ ќ± hќ±
  -- monotone step
  have hmono : вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦPsiIdeal N P ќ± - PhiArc N P Q ќ±вАЦ ^ 2
      вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вИС x вИИ canonAnchors P, вИС y вИИ canonAnchors P, F x y ќ± := by
    apply setIntegral_mono_on hlhs_int hsum_int measurableSet_Ioc
    intro ќ± hќ±
    exact psi_sub_phi_sq_pointwise N P Q hP hPQ ќ± hќ±
  refine hmono.trans (le_of_eq ?_)
  -- swap sum and integral
  rw [integral_finset_sum _ (fun x _ => integrable_finset_sum _ (fun y _ => hFint x y))]
  refine Finset.sum_congr rfl (fun x _ => ?_)
  rw [integral_finset_sum _ (fun y _ => hFint x y)]
  refine Finset.sum_congr rfl (fun y _ => ?_)
  -- per-term: pull the constant, collapse the indicator to a set integral
  rw [hFdef]
  simp only
  rw [integral_const_mul, MeasureTheory.integral_indicator (hmeasI x y),
    Measure.restrict_restrict (hmeasI x y),
    Set.inter_eq_self_of_subset_left
      ((Set.inter_subset_left).trans (tailSet_subset_Ioc P Q x.1 x.2))]

/-- The M√ґbius-totient coefficient is `вЙ§ 4/q` (zero off squarefree; B0 on squarefree). -/
lemma coef_le (q : вДХ) (hq : 1 вЙ§ q) :
    вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ вЙ§ 4 / (q : вДЭ) := by
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  by_cases hsq : Squarefree q
  ¬Ј have hѕЖ1 : 1 вЙ§ q.totient := Nat.totient_pos.mpr (by omega)
    have hѕЖ0R : (0:вДЭ) < (q.totient : вДЭ) := by exact_mod_cast hѕЖ1
    have hќЉ1 : |(ArithmeticFunction.moebius q : вД§)| вЙ§ 1 :=
      ArithmeticFunction.abs_moebius_le_one
    have hnorm : вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ
        вЙ§ 1 / (q.totient : вДЭ) ^ 2 := by
      rw [norm_pow, norm_div, Complex.norm_intCast, Complex.norm_natCast]
      have hќЉ1R : |((ArithmeticFunction.moebius q : вД§) : вДЭ)| вЙ§ 1 := by
        rw [вЖР Int.cast_abs]
        exact_mod_cast hќЉ1
      calc (|((ArithmeticFunction.moebius q : вД§) : вДЭ)| / (q.totient : вДЭ)) ^ 2
          вЙ§ (1 / (q.totient : вДЭ)) ^ 2 := by
            apply pow_le_pow_leftвВА (by positivity)
            apply div_le_div_of_nonneg_right hќЉ1R hѕЖ0R.le
        _ = 1 / (q.totient : вДЭ) ^ 2 := by rw [div_pow, one_pow]
    refine hnorm.trans ?_
    rw [div_le_div_iffвВА (by positivity) hq0R]
    have := sqfree_totient_linear q hsq
    nlinarith [this]
  ¬Ј have hќЉ0 : ArithmeticFunction.moebius q = 0 :=
      ArithmeticFunction.moebius_eq_zero_of_not_squarefree hsq
    rw [hќЉ0]
    simp
    positivity

/-- The canonical anchor count is at most `P¬≤`. -/
lemma canonAnchors_card_le (P : вДХ) : (canonAnchors P).card вЙ§ P ^ 2 := by
  rw [canonAnchors, Finset.card_sigma]
  calc вИС q вИИ Finset.Icc 1 P, (redRes q).card
      вЙ§ вИС _q вИИ Finset.Icc 1 P, P := by
        apply Finset.sum_le_sum
        intro q hq
        have h1 : (redRes q).card вЙ§ q := by
          calc (redRes q).card вЙ§ (Finset.range q).card := Finset.card_filter_le _ _
            _ = q := Finset.card_range q
        exact h1.trans (Finset.mem_Icc.mp hq).2
    _ = P * P := by rw [Finset.sum_const, Nat.card_Icc]; simp [Nat.smul_one_eq_cast]
    _ = P ^ 2 := (sq P).symm

/-- **harc brick B5d: the total arc-tail L¬≤ bound.**
    `вИЂ_{(0,1]} вАЦќ®вИТќ¶вАЦ¬≤ вЙ§ 8(Q+1)¬≥P^{5/2} + 192(Q+1)PвБЈ`. -/
lemma psi_sub_phi_L2_total (N P Q : вДХ) (hP : 1 вЙ§ P) (hQ2 : 2 вЙ§ Q)
    (hPQ : 2 * P ^ 2 < Q + 1) :
    вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦPsiIdeal N P ќ± - PhiArc N P Q ќ±вАЦ ^ 2
      вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2))
        + 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 7 := by
  classical
  refine (psi_sub_phi_L2_expand N P Q hP hPQ).trans ?_
  have hPR : (0:вДЭ) < (P : вДЭ) := by exact_mod_cast hP
  -- split every inner sum at y = x
  have hsplit : вИС x вИИ canonAnchors P, вИС y вИИ canonAnchors P,
      вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
        * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
        * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
            вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
              * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ
      = (вИС x вИИ canonAnchors P,
          вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q x.1 x.2,
                вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                  * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ)
        + вИС x вИИ canonAnchors P, вИС y вИИ (canonAnchors P).erase x,
            вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
              * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
              * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
                  вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                    * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ := by
    rw [вЖР Finset.sum_add_distrib]
    refine Finset.sum_congr rfl (fun x hx => ?_)
    exact (Finset.add_sum_erase _ _ hx).symm
  rw [hsplit]
  have hmemfacts : вИА x вИИ canonAnchors P, x.1 вИИ Finset.Icc 1 P вИІ x.2 вИИ redRes x.1 := by
    intro x hx
    exact вЯ®(Finset.mem_sigma.mp hx).1, (Finset.mem_sigma.mp hx).2вЯ©
  -- diagonal part
  have hdiag : вИС x вИИ canonAnchors P,
      вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
        * вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
        * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q x.1 x.2,
            вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
              * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
      вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2)) := by
    have hper : вИА x вИИ canonAnchors P,
        вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
          * вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
          * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q x.1 x.2,
              вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
        вЙ§ вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ ^ 2
            * (((x.1 : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8) := by
      intro x hx
      obtain вЯ®hx1, hx2вЯ© := hmemfacts x hx
      have hint : вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q x.1 x.2,
          вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
            * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
          вЙ§ ((x.1 : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8 := by
        rw [Set.inter_self]
        have h := tail_L4_bound N P Q x.1 x.2 hx1 hx2 hQ2
        refine le_trans (le_of_eq ?_) h
        apply setIntegral_congr_fun (by
          apply MeasurableSet.diff measurableSet_Ioc
          apply MeasurableSet.biUnion (Set.to_countable _)
          intro pq _
          exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc)
        intro ќ± _
        dsimp only
        exact (pow_two _).symm
      rw [вЖР pow_two]
      apply mul_le_mul_of_nonneg_left hint (by positivity)
    refine (Finset.sum_le_sum hper).trans ?_
    rw [canonAnchors, Finset.sum_sigma]
    exact diagonal_bound P Q hP
  -- cross part
  have hcross : вИС x вИИ canonAnchors P, вИС y вИИ (canonAnchors P).erase x,
      вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
        * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
        * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
            вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
              * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ
      вЙ§ 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 7 := by
    have hterm : вИА x вИИ canonAnchors P, вИА y вИИ (canonAnchors P).erase x,
        вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
          * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
          * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
              вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ
        вЙ§ 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3 := by
      intro x hx y hy
      obtain вЯ®hx1, hx2вЯ© := hmemfacts x hx
      obtain вЯ®hy1, hy2вЯ© := hmemfacts y ((Finset.erase_subset _ _) hy)
      obtain вЯ®hxq1, hxqPвЯ© := Finset.mem_Icc.mp hx1
      obtain вЯ®hyq1, hyqPвЯ© := Finset.mem_Icc.mp hy1
      have hxy : x вЙ† y := fun h => (Finset.ne_of_mem_erase hy) h.symm
      have hne : (x.2 : вДЭ) / (x.1 : вДЭ) вЙ† (y.2 : вДЭ) / (y.1 : вДЭ) := by
        intro heq
        obtain вЯ®hq, haвЯ© := canon_fraction_injective x.1 y.1 x.2 y.2 hxq1 hyq1 hx2 hy2 heq
        apply hxy
        cases x with | mk xq xa => cases y with | mk yq ya =>
          simp only at hq ha
          subst hq
          subst ha
          rfl
      have hI := cross_pair_bound N P Q x.1 y.1 x.2 y.2 hx1 hy1 hx2 hy2 hQ2 hne
      have hI0 : (0:вДЭ) вЙ§ вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
          вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
            * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ :=
        integral_nonneg (fun ќ± => mul_nonneg (norm_nonneg _) (norm_nonneg _))
      have hcx := coef_le x.1 hxq1
      have hcy := coef_le y.1 hyq1
      have hqx0 : (0:вДЭ) < (x.1 : вДЭ) := by exact_mod_cast hxq1
      have hqy0 : (0:вДЭ) < (y.1 : вДЭ) := by exact_mod_cast hyq1
      have hqxP : (x.1 : вДЭ) вЙ§ (P : вДЭ) := by exact_mod_cast hxqP
      have hqyP : (y.1 : вДЭ) вЙ§ (P : вДЭ) := by exact_mod_cast hyqP
      calc вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
            * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
                вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                  * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ
          вЙ§ (4 / (x.1 : вДЭ)) * (4 / (y.1 : вДЭ))
              * (6 * ((x.1 : вДЭ) * (y.1 : вДЭ)) ^ 2 * (((Q : вДЭ) + 1) * ((x.1 : вДЭ) + (y.1 : вДЭ)))) := by
            apply mul_le_mul
            ¬Ј exact mul_le_mul hcx hcy (norm_nonneg _) (by positivity)
            ¬Ј exact hI
            ¬Ј exact hI0
            ¬Ј positivity
        _ = 96 * ((x.1 : вДЭ) * (y.1 : вДЭ) * (((x.1 : вДЭ) + (y.1 : вДЭ)) * ((Q : вДЭ) + 1))) := by
            field_simp
            ring
        _ вЙ§ 96 * ((P : вДЭ) * (P : вДЭ) * ((2 * (P : вДЭ)) * ((Q : вДЭ) + 1))) := by
            apply mul_le_mul_of_nonneg_left _ (by norm_num)
            have hQ0 : (0:вДЭ) вЙ§ (Q : вДЭ) + 1 := by positivity
            apply mul_le_mul (mul_le_mul hqxP hqyP hqy0.le hPR.le)
            ¬Ј apply mul_le_mul _ le_rfl hQ0 (by positivity)
              linarith
            ¬Ј positivity
            ¬Ј positivity
        _ = 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3 := by ring
    have hcount : ((canonAnchors P).card : вДЭ) вЙ§ (P : вДЭ) ^ 2 := by
      calc ((canonAnchors P).card : вДЭ) вЙ§ ((P ^ 2 : вДХ) : вДЭ) := by
            exact_mod_cast canonAnchors_card_le P
        _ = (P : вДЭ) ^ 2 := by push_cast; rfl
    have hQ0 : (0:вДЭ) вЙ§ 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3 := by positivity
    calc вИС x вИИ canonAnchors P, вИС y вИИ (canonAnchors P).erase x,
        вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
          * вАЦ((ArithmeticFunction.moebius y.1 : вДВ) / (Nat.totient y.1 : вДВ)) ^ 2вАЦ
          * вИЂ ќ± in tailSet P Q x.1 x.2 вИ© tailSet P Q y.1 y.2,
              вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ
                * вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (y.2 : вДЭ) / (y.1 : вДЭ)))) ^ 2вАЦ
        вЙ§ вИС x вИИ canonAnchors P, ((canonAnchors P).card : вДЭ)
            * (192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3) := by
          apply Finset.sum_le_sum
          intro x hx
          calc вИС y вИИ (canonAnchors P).erase x, _
              вЙ§ вИС _y вИИ (canonAnchors P).erase x, 192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3 :=
                Finset.sum_le_sum (hterm x hx)
            _ = ((canonAnchors P).erase x).card * (192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3) := by
                rw [Finset.sum_const, nsmul_eq_mul]
            _ вЙ§ ((canonAnchors P).card : вДЭ) * (192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3) := by
                apply mul_le_mul_of_nonneg_right _ hQ0
                exact_mod_cast Finset.card_le_card (Finset.erase_subset _ _)
      _ = ((canonAnchors P).card : вДЭ) * ((canonAnchors P).card : вДЭ)
            * (192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3) := by
          rw [Finset.sum_const, nsmul_eq_mul]
          ring
      _ вЙ§ (P : вДЭ) ^ 2 * (P : вДЭ) ^ 2 * (192 * ((Q : вДЭ) + 1) * (P : вДЭ) ^ 3) := by
