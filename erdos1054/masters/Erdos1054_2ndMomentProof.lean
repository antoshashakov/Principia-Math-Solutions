/-- A positive-lower-density set is inhabited (indeed unbounded).  Standard
    consequence of the density lower bound; proof of the `density вЗТ nonempty`
    step deferred. -/
theorem exists_of_positiveLowerDensity (P : Nat вЖТ Prop)
    (hP : PositiveLowerDensity P) : вИГ N, P N := by
  classical
  obtain вЯ®c, hc, XвВА, hXвВАвЯ© := hP
  obtain вЯ®X, hX0le, hXbigвЯ© : вИГ X : Nat, XвВА вЙ§ X вИІ (1 : вДЪ) вЙ§ c * X := by
    obtain вЯ®n, hnвЯ© := exists_nat_ge (1 / c)          -- (1/c) вЙ§ (n : вДЪ)
    refine вЯ®max XвВА n, le_max_left _ _, ?_вЯ©
    have hnle : (1 / c) вЙ§ ((max XвВА n : Nat) : вДЪ) :=
      le_trans hn (by exact_mod_cast le_max_right XвВА n)
    have hmul := mul_le_mul_of_nonneg_left hnle hc.le    -- c*(1/c) вЙ§ c*(max вА¶)
    rwa [mul_one_div, div_self (ne_of_gt hc)] at hmul
  have hcard := hXвВА X hX0le
  have hpos : (0 : вДЪ) < (countUpTo P X : вДЪ) :=
    lt_of_lt_of_le zero_lt_one (le_trans hXbig hcard)
  have hpos' : 0 < countUpTo P X := by exact_mod_cast hpos
  unfold countUpTo at hpos'
  obtain вЯ®N, hNвЯ© := Finset.card_pos.mp hpos'
  exact вЯ®N, (Finset.mem_filter.mp hN).2вЯ©

/-- Consequently `f(N)/N` is unbounded on the represented integers: for every
    `A` there is a represented `N` with `f(N) > A¬ЈN`. -/
theorem erdos1054_ratio_unbounded (A : Nat) (hA : 1 вЙ§ A) :
    вИГ N, Represented N вИІ A * N < f N :=
  exists_of_positiveLowerDensity _ (erdos1054_second_moment_full_proof A hA)

