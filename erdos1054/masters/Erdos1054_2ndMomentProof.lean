open Finset in
set_option maxHeartbeats 4000000 in
/-- **Rated progression bound, non-unit residues** (brick C1b): for `gcd(r,q) вЙ† 1`
    the progression ќЫ-mass sits on prime powers `p^k` with `p вИ£ q`; per prime it
    telescopes to `вЙ§ log N`, so every initial segment is `вЙ§ q¬Јlog N` вАФ no
    SiegelвАУWalfisz needed. -/
theorem nonunit_progression_bound (q : вДХ) (hq0 : 0 < q) (r : вДХ)
    (hgcd : Nat.gcd r q вЙ† 1) (N : вДХ) (hN : 3 вЙ§ N) (t : вДХ) (ht : t вЙ§ N) :
    вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n
      вЙ§ (q:вДЭ) * Real.log N := by
  classical
  have hN0 : (0:вДЭ) < (N:вДЭ) := by
    have h1 : 0 < N := by omega
    exact_mod_cast h1
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := by
    apply Real.log_nonneg
    have h1 : 1 вЙ§ N := by omega
    exact_mod_cast h1
  -- restrict to prime powers
  have hstep : вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n
      = вИС n вИИ (Finset.range t).filter
          (fun n : вДХ => n % q = r вИІ IsPrimePow n), ќЫ n := by
    rw [Finset.sum_filter, Finset.sum_filter]
    apply Finset.sum_congr rfl
    intro n _
    by_cases h1 : n % q = r
    ¬Ј by_cases h2 : IsPrimePow n
      ¬Ј simp [h1, h2]
      ¬Ј have h3 : ќЫ n = 0 := by
          rw [ArithmeticFunction.vonMangoldt_apply, if_neg h2]
        simp [h1, h2, h3]
    ¬Ј simp [h1]
  rw [hstep]
  -- membership facts
  have hEmem : вИА n вИИ (Finset.range t).filter
      (fun n : вДХ => n % q = r вИІ IsPrimePow n),
      n.minFac вИИ q.primeFactors вИІ 1 вЙ§ n.factorization n.minFac вИІ
      n.minFac ^ n.factorization n.minFac = n вИІ
      n.factorization n.minFac вЙ§ N := by
    intro n hn
    rw [Finset.mem_filter, Finset.mem_range] at hn
    obtain вЯ®hnt, hnr, hppвЯ© := hn
    have hrec := hpp.minFac_pow_factorization_eq
    have hn1 : n вЙ† 1 := hpp.ne_one
    have hn0 : 0 < n := hpp.pos
    have hpmin : n.minFac.Prime := Nat.minFac_prime hn1
    -- the common prime of gcd(r,q) divides n, hence equals minFac n, hence вИ£ q
    have hg0 : Nat.gcd r q вЙ† 0 := by
      intro h
      exact hq0.ne' (Nat.eq_zero_of_gcd_eq_zero_right h)
    have hpвВА : (Nat.gcd r q).minFac.Prime := Nat.minFac_prime hgcd
    have hpвВАr : (Nat.gcd r q).minFac вИ£ r :=
      (Nat.minFac_dvd _).trans (Nat.gcd_dvd_left r q)
    have hpвВАq : (Nat.gcd r q).minFac вИ£ q :=
      (Nat.minFac_dvd _).trans (Nat.gcd_dvd_right r q)
    have hpвВАn : (Nat.gcd r q).minFac вИ£ n := by
      have h1 : n = q * (n / q) + r := by
        rw [вЖР hnr]
        exact (Nat.div_add_mod n q).symm
      rw [h1]
      exact Nat.dvd_add (Dvd.dvd.mul_right hpвВАq _) hpвВАr
    have hrp : (Nat.gcd r q).minFac = n.minFac := by
      have h4 : (Nat.gcd r q).minFac вИ£ n.minFac ^ n.factorization n.minFac := by
        rw [hrec]
        exact hpвВАn
      have h5 : (Nat.gcd r q).minFac вИ£ n.minFac := hpвВА.dvd_of_dvd_pow h4
      exact (Nat.prime_dvd_prime_iff_eq hpвВА hpmin).mp h5
    have hpq : n.minFac вИ£ q := hrp вЦЄ hpвВАq
    have hk1 : 1 вЙ§ n.factorization n.minFac := by
      by_contra hcon
      push_neg at hcon
      have h0 : n.factorization n.minFac = 0 := by omega
      rw [h0, pow_zero] at hrec
      exact hn1 hrec.symm
    have hkN : n.factorization n.minFac вЙ§ N := by
      have h6 : n.factorization n.minFac вЙ§ n := by
        calc n.factorization n.minFac вЙ§ n.minFac ^ n.factorization n.minFac :=
              (Nat.lt_pow_self hpmin.one_lt).le
          _ = n := hrec
      omega
    exact вЯ®Nat.mem_primeFactors.mpr вЯ®hpmin, hpq, hq0.ne'вЯ©, hk1, hrec, hkNвЯ©
  -- inject into (prime factor, exponent) pairs
  have hinj : Set.InjOn (fun n : вДХ => (n.minFac, n.factorization n.minFac))
      ((Finset.range t).filter (fun n : вДХ => n % q = r вИІ IsPrimePow n)) := by
    intro a ha b hb hab
    obtain вЯ®-, -, hreca, -вЯ© := hEmem a (Finset.mem_coe.mp ha)
    obtain вЯ®-, -, hrecb, -вЯ© := hEmem b (Finset.mem_coe.mp hb)
    simp only [Prod.mk.injEq] at hab
    calc a = a.minFac ^ a.factorization a.minFac := hreca.symm
      _ = b.minFac ^ b.factorization b.minFac := by rw [hab.2, hab.1]
      _ = b := hrecb
  have hval : вИА n вИИ (Finset.range t).filter
      (fun n : вДХ => n % q = r вИІ IsPrimePow n),
      ќЫ n = Real.log n.minFac := by
    intro n hn
    rw [Finset.mem_filter] at hn
    rw [ArithmeticFunction.vonMangoldt_apply, if_pos hn.2.2]
  obtain вЯ®IMG, hIMGdefвЯ© : вИГ s : Finset (вДХ √Ч вДХ),
      s = ((Finset.range t).filter
        (fun n : вДХ => n % q = r вИІ IsPrimePow n)).image
          (fun n => (n.minFac, n.factorization n.minFac)) := вЯ®_, rflвЯ©
  have hsub : IMG вКЖ (q.primeFactors √ЧЋҐ Finset.Icc 1 N).filter
      (fun pk => (pk.1 : вДЭ) ^ pk.2 вЙ§ (N:вДЭ)) := by
    rw [hIMGdef]
    intro pk hpk
    rw [Finset.mem_image] at hpk
    obtain вЯ®n, hn, henвЯ© := hpk
    obtain вЯ®hp, hk1, hrec, hkNвЯ© := hEmem n hn
    rw [Finset.mem_filter, Finset.mem_product, вЖР hen]
    have hnN : (n : вДЭ) вЙ§ (N:вДЭ) := by
      rw [Finset.mem_filter, Finset.mem_range] at hn
      have h7 : n вЙ§ N := by omega
      exact_mod_cast h7
    refine вЯ®вЯ®hp, Finset.mem_Icc.mpr вЯ®hk1, hkNвЯ©вЯ©, ?_вЯ©
    have h8 : ((n.minFac ^ n.factorization n.minFac : вДХ) : вДЭ) = (n : вДЭ) := by
      exact_mod_cast congrArg (Nat.cast : вДХ вЖТ вДЭ) hrec
    push_cast at h8
    rw [h8]
    exact hnN
  calc вИС n вИИ (Finset.range t).filter
        (fun n : вДХ => n % q = r вИІ IsPrimePow n), ќЫ n
      = вИС n вИИ (Finset.range t).filter
          (fun n : вДХ => n % q = r вИІ IsPrimePow n),
          Real.log n.minFac := Finset.sum_congr rfl hval
    _ = вИС pk вИИ IMG, Real.log pk.1 := by
        rw [hIMGdef]
        exact (Finset.sum_image (f := fun pk => Real.log pk.1) hinj).symm
    _ вЙ§ вИС pk вИИ (q.primeFactors √ЧЋҐ Finset.Icc 1 N).filter
          (fun pk => (pk.1 : вДЭ) ^ pk.2 вЙ§ (N:вДЭ)), Real.log pk.1 := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsub
        intro pk hpk _
        rw [Finset.mem_filter, Finset.mem_product, Nat.mem_primeFactors] at hpk
        exact Real.log_nonneg (by exact_mod_cast hpk.1.1.1.one_lt.le)
    _ = вИС p вИИ q.primeFactors, вИС k вИИ (Finset.Icc 1 N).filter
          (fun k => (p : вДЭ) ^ k вЙ§ (N:вДЭ)), Real.log p := by
        rw [Finset.sum_filter, Finset.sum_product]
        apply Finset.sum_congr rfl
        intro p _
        rw [Finset.sum_filter]
    _ вЙ§ вИС _p вИИ q.primeFactors, Real.log N := by
        apply Finset.sum_le_sum
        intro p hp
        have hpprime : p.Prime := Nat.prime_of_mem_primeFactors hp
        have hlogp0 : (0:вДЭ) < Real.log p := by
          apply Real.log_pos
          exact_mod_cast hpprime.one_lt
        rw [Finset.sum_const, nsmul_eq_mul]
        obtain вЯ®K, hKdefвЯ© : вИГ m : вДХ, m = вМКReal.log N / Real.log pвМЛвВК := вЯ®_, rflвЯ©
        have hsubK : (Finset.Icc 1 N).filter (fun k => (p : вДЭ) ^ k вЙ§ (N:вДЭ))
            вКЖ Finset.Icc 1 K := by
          intro k hk
          rw [Finset.mem_filter, Finset.mem_Icc] at hk
          rw [Finset.mem_Icc]
          refine вЯ®hk.1.1, ?_вЯ©
          rw [hKdef]
          apply Nat.le_floor
          rw [le_div_iffвВА hlogp0]
          calc (k : вДЭ) * Real.log p = Real.log ((p : вДЭ) ^ k) := by
                rw [Real.log_pow]
            _ вЙ§ Real.log N := Real.log_le_log
                (pow_pos (by exact_mod_cast hpprime.pos) k) hk.2
        have hcard2 : ((Finset.Icc 1 N).filter
            (fun k => (p : вДЭ) ^ k вЙ§ (N:вДЭ))).card вЙ§ K := by
          calc ((Finset.Icc 1 N).filter
              (fun k => (p : вДЭ) ^ k вЙ§ (N:вДЭ))).card вЙ§ (Finset.Icc 1 K).card :=
                Finset.card_le_card hsubK
            _ = K := by rw [Nat.card_Icc]; omega
        have hK : (K : вДЭ) * Real.log p вЙ§ Real.log N := by
          rw [hKdef]
          have h9 : ((вМКReal.log N / Real.log pвМЛвВК : вДЭ)) вЙ§ Real.log N / Real.log p :=
            Nat.floor_le (by positivity)
          calc ((вМКReal.log N / Real.log pвМЛвВК : вДЭ)) * Real.log p
              вЙ§ (Real.log N / Real.log p) * Real.log p :=
                mul_le_mul_of_nonneg_right h9 hlogp0.le
            _ = Real.log N := by field_simp
        calc (((Finset.Icc 1 N).filter
            (fun k => (p : вДЭ) ^ k вЙ§ (N:вДЭ))).card : вДЭ) * Real.log p
            вЙ§ (K : вДЭ) * Real.log p := by
              apply mul_le_mul_of_nonneg_right ?_ hlogp0.le
              exact_mod_cast hcard2
          _ вЙ§ Real.log N := hK
    _ = (q.primeFactors.card : вДЭ) * Real.log N := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ вЙ§ (q : вДЭ) * Real.log N := by
        apply mul_le_mul_of_nonneg_right ?_ hlogN0
        have h10 : q.primeFactors вКЖ Finset.Icc 2 q := by
          intro p hp
          rw [Nat.mem_primeFactors] at hp
          rw [Finset.mem_Icc]
          exact вЯ®hp.1.two_le, Nat.le_of_dvd hq0 hp.2.1вЯ©
        calc (q.primeFactors.card : вДЭ) вЙ§ ((Finset.Icc 2 q).card : вДЭ) := by
              exact_mod_cast Finset.card_le_card h10
          _ вЙ§ (q : вДЭ) := by
              rw [Nat.card_Icc]
              have h11 : q + 1 - 2 вЙ§ q := by omega
              exact_mod_cast h11

