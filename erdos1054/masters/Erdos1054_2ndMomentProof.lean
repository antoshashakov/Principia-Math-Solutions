/-- **harc brick B0: the squarefree totient seed for the arc-tail diagonal** вАФ
    `(q:вДЭ) вЙ§ 4¬ЈѕЖ(q)¬≤` for squarefree `q` (from `sqfree_totient` via `q вЙ§ q^{6/5}`). -/
lemma sqfree_totient_linear (q : вДХ) (hq : Squarefree q) :
    (q : вДЭ) вЙ§ 4 * (Nat.totient q : вДЭ) ^ 2 := by
  have hq1 : 1 вЙ§ q := Nat.one_le_iff_ne_zero.mpr hq.ne_zero
  have hq1R : (1 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq1
  calc (q : вДЭ) = (q : вДЭ) ^ (1 : вДЭ) := (Real.rpow_one _).symm
    _ вЙ§ (q : вДЭ) ^ ((6 : вДЭ) / 5) :=
        Real.rpow_le_rpow_of_exponent_le hq1R (by norm_num)
    _ вЙ§ 4 * (Nat.totient q : вДЭ) ^ 2 := sqfree_totient q hq

