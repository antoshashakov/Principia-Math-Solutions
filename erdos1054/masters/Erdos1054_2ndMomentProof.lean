        вЙ§ CвВГ * X * Real.exp (-cвВГ * Real.log X ^ ((1:вДЭ)/10))
          + (Real.log X / Real.log 2 + 1) * Real.log q := hѕЗвВАX
      _ вЙ§ CвВГ * X * Real.exp (-(cвВГ * u)) + X * Real.exp (-((1:вДЭ)/2 * u)) := by
          apply add_le_add _ hpolylog
          rw [вЖР hudef, neg_mul]
  -- exponent comparisons to the common rate c
  have hecвВГ : Real.exp (-(cвВГ * u)) вЙ§ Real.exp (-(c * u)) := by
    apply Real.exp_le_exp.mpr
    have hcc : c вЙ§ cвВГ := le_trans (min_le_left _ _) (min_le_left _ _)
    have := mul_le_mul_of_nonneg_right hcc hu0.le
    linarith
  have hecвВЕ : Real.exp (-((cвВЕ/2) * u)) вЙ§ Real.exp (-(c * u)) := by
    apply Real.exp_le_exp.mpr
    have hcc : c вЙ§ cвВЕ/2 := le_trans (min_le_left _ _) (min_le_right _ _)
    have := mul_le_mul_of_nonneg_right hcc hu0.le
    linarith
  have heh : Real.exp (-((1:вДЭ)/2 * u)) вЙ§ Real.exp (-(c * u)) := by
    apply Real.exp_le_exp.mpr
    have hcc : c вЙ§ 1/2 := min_le_right _ _
    have := mul_le_mul_of_nonneg_right hcc hu0.le
    linarith
  -- deviation identity from orthogonality
  have hdev : ((q.totient : вДХ) : вДВ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        if a = ((n : ZMod q)) then ((vonMangoldt n : вДЭ) : вДВ) else 0) - ((X:вДЭ) : вДВ)
      = (((((вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0) : вДЭ)) : вДВ) - ((X:вДЭ) : вДВ))
        + вИС ѕЗ вИИ Finset.univ.erase (1 : DirichletCharacter вДВ q),
            ѕЗ aвБї¬є * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
              ѕЗ ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ)) := by
    linear_combination hAP
  -- complex-side master bound
  have hnorm : вАЦ((q.totient : вДХ) : вДВ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        if a = ((n : ZMod q)) then ((vonMangoldt n : вДЭ) : вДВ) else 0) - ((X:вДЭ) : вДВ)вАЦ
      вЙ§ (CвВГ + CвВЕ + 1) * (X * Real.exp (-(c * u))) := by
    rw [hdev]
    have hstep : вАЦ(((((вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if IsUnit ((n : вДХ) : ZMod q) then vonMangoldt n else 0) : вДЭ)) : вДВ) - ((X:вДЭ) : вДВ))
        + вИС ѕЗ вИИ Finset.univ.erase (1 : DirichletCharacter вДВ q),
            ѕЗ aвБї¬є * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
              ѕЗ ((n : ZMod q)) * ((vonMangoldt n : вДЭ) : вДВ))вАЦ
        вЙ§ (CвВГ * X * Real.exp (-(cвВГ * u)) + X * Real.exp (-((1:вДЭ)/2 * u)))
          + CвВЕ * X * Real.exp (-((cвВЕ/2) * u)) :=
      le_trans (norm_add_le _ _) (add_le_add hѕИвВАdev (le_trans hsum_erase hcount))
    have bвВБ : CвВГ * X * Real.exp (-(cвВГ * u)) вЙ§ CвВГ * X * Real.exp (-(c * u)) :=
      mul_le_mul_of_nonneg_left hecвВГ (mul_nonneg hCвВГ0.le hX0.le)
    have bвВВ : X * Real.exp (-((1:вДЭ)/2 * u)) вЙ§ X * Real.exp (-(c * u)) :=
      mul_le_mul_of_nonneg_left heh hX0.le
    have bвВГ : CвВЕ * X * Real.exp (-((cвВЕ/2) * u)) вЙ§ CвВЕ * X * Real.exp (-(c * u)) :=
      mul_le_mul_of_nonneg_left hecвВЕ (mul_nonneg hCвВЕ0.le hX0.le)
    have hfold : CвВГ * X * Real.exp (-(c * u)) + X * Real.exp (-(c * u))
        + CвВЕ * X * Real.exp (-(c * u)) = (CвВГ + CвВЕ + 1) * (X * Real.exp (-(c * u))) := by
      ring
    linarith
  -- real bridge
  have hreal : |(q.totient : вДЭ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        if a = ((n : ZMod q)) then vonMangoldt n else 0) - X|
      вЙ§ (CвВГ + CвВЕ + 1) * (X * Real.exp (-(c * u))) := by
    have hcast : ((q.totient : вДХ) : вДВ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if a = ((n : ZMod q)) then ((vonMangoldt n : вДЭ) : вДВ) else 0) - ((X:вДЭ) : вДВ)
        = ((((q.totient : вДЭ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
            if a = ((n : ZMod q)) then vonMangoldt n else 0) - X) : вДЭ) : вДВ) := by
      rw [hSreal]
