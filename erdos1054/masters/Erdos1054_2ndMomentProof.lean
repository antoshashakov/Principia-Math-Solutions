  have hA0 : (0:вДЭ) < (N:вДЭ)*(|t|+3)/(ѕГ-1) := by linarith
  have hlogA0 : (1:вДЭ) вЙ§ Real.log ((N:вДЭ)*(|t|+3)/(ѕГ-1)) := by
    calc (1:вДЭ) вЙ§ Real.log 3 := by
          rw [show (1:вДЭ) = Real.log (Real.exp 1) by rw [Real.log_exp]]
          apply Real.log_le_log (Real.exp_pos 1)
