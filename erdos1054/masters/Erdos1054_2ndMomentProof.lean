    exact Set.indicator_nonneg (fun ќ≤ _ => norm_nonneg _) ќ±
  calc вАЦвИС x вИИ canonAnchors P,
      ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2
        * (tailSet P Q x.1 x.2).indicator
          (fun ќ≤ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2) ќ±вАЦ ^ 2
      вЙ§ (вИС x вИИ canonAnchors P,
          вАЦ((ArithmeticFunction.moebius x.1 : вДВ) / (Nat.totient x.1 : вДВ)) ^ 2вАЦ
            * (tailSet P Q x.1 x.2).indicator
              (fun ќ≤ => вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (x.2 : вДЭ) / (x.1 : вДЭ)))) ^ 2вАЦ) ќ±) ^ 2 := by
