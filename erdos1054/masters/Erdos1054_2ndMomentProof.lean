  have hsqrtN : Real.sqrt N вЙ§ N := by
    have h : Real.sqrt (N : вДЭ) вЙ§ Real.sqrt ((N : вДЭ) ^ 2) := Real.sqrt_le_sqrt (by nlinarith [hNR])
    rwa [Real.sqrt_sq (by positivity)] at h
  have hPsP : (P : вДЭ) * Real.sqrt P вЙ§ N := by
    have h : (P : вДЭ) * Real.sqrt P = Real.sqrt ((P : вДЭ) ^ 3) := by
      rw [show (P : вДЭ) ^ 3 = (P : вДЭ) ^ 2 * P by ring, Real.sqrt_mul (by positivity),
        Real.sqrt_sq (by positivity)]
    rw [h]
    exact le_trans (Real.sqrt_le_sqrt hPcubeR) hsqrtN
  have hP2sP : (P : вДЭ) ^ 2 * Real.sqrt P вЙ§ N := by
    have h : (P : вДЭ) ^ 2 * Real.sqrt P = Real.sqrt ((P : вДЭ) ^ 5) := by
      rw [show (P : вДЭ) ^ 5 = ((P : вДЭ) ^ 2) ^ 2 * P by ring, Real.sqrt_mul (by positivity),
        Real.sqrt_sq (by positivity)]
    rw [h]
    have hP5 : (P : вДЭ) ^ 5 вЙ§ (N : вДЭ) ^ 2 := by
      have h6 : ((P : вДЭ) ^ 3) ^ 2 вЙ§ (N : вДЭ) ^ 2 := pow_le_pow_leftвВА (by positivity) hPcubeR 2
      nlinarith [h6, mul_nonneg (pow_nonneg (show (0:вДЭ) вЙ§ (P:вДЭ) by linarith) 5)
        (show (0:вДЭ) вЙ§ (P:вДЭ) - 1 by linarith)]
