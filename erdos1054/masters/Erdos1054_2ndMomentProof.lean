/-- **Anchor-sum error, general window level** (brick D2b-Q). -/
theorem anchor_sum_error_q (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ c C : вДЭ, 0 < c вИІ 0 < C вИІ вИГ NвВА : вДХ, вИА N : вДХ, NвВА вЙ§ N вЖТ
