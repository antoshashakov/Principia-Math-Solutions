/-- Integer shift invariance of the kernel character (proven, not stubbed:
    generalizes HarcArcTail's `e_shift_one` to arbitrary integer shifts). -/
lemma e_int_shift (k : вДХ) (ќ≤ : вДЭ) (m : вД§) :
    e ((k : вДЭ) * (ќ≤ + (m : вДЭ))) = e ((k : вДЭ) * ќ≤) := by
  have h : (k:вДЭ) * (ќ≤ + (m:вДЭ)) = (k:вДЭ) * ќ≤ + (((k : вД§) * m : вД§) : вДЭ) := by
    push_cast
    ring
  rw [h, e, e, Complex.ofReal_add, mul_add, Complex.exp_add]
  have h2 : Complex.exp (2 * Real.pi * Complex.I * ((((k : вД§) * m : вД§) : вДЭ) : вДВ)) = 1 := by
    rw [show (2 * Real.pi * Complex.I * ((((k : вД§) * m : вД§) : вДЭ) : вДВ))
        = ((k : вД§) * m : вД§) * (2 * Real.pi * Complex.I) by push_cast; ring]
    exact Complex.exp_int_mul_two_pi_mul_I _
  rw [h2, mul_one]

-- ==== B1: the matched-arc set and the decomposition ====

/-- The anchors matching canonical residue `(q, aвВА)`: same modulus, congruent numerator. -/
noncomputable def matchedAnchors (P q aвВА : вДХ) : Finset (вДХ √Ч вД§) :=
  (anchors P).filter (fun pq => pq.1 = q вИІ (pq.2 : вД§) % (q : вД§) = (aвВА : вД§))

/-- The tail domain of `(q, aвВА)`: the period minus its matched arcs. -/
noncomputable def tailSet (P Q q aвВА : вДХ) : Set вДЭ :=
  Set.Ioc (0:вДЭ) 1 \ вЛГ pq вИИ matchedAnchors P q aвВА, arc Q pq


/-- Disjoint indicator collapse: for a finset of pairwise-disjoint sets, the sum of
    indicators of a fixed function is the indicator of the union. -/
lemma sum_indicator_disjoint {ќє : Type*} (s : Finset ќє) (t : ќє вЖТ Set вДЭ) (g : вДЭ вЖТ вДВ)
    (hdis : (s : Set ќє).Pairwise (Function.onFun Disjoint t)) (ќ± : вДЭ) :
    вИС i вИИ s, (t i).indicator g ќ± = (вЛГ i вИИ s, t i).indicator g ќ± := by
  by_cases hmem : ќ± вИИ вЛГ i вИИ s, t i
  ¬Ј obtain вЯ®i, hi, hќ±iвЯ© := Set.mem_iUnionвВВ.mp hmem
    rw [Set.indicator_of_mem hmem]
    rw [Finset.sum_eq_single i]
    ¬Ј rw [Set.indicator_of_mem hќ±i]
    ¬Ј intro j hj hji
      apply Set.indicator_of_notMem
      intro hќ±j
      exact (Set.disjoint_left.mp (hdis hj hi hji)) hќ±j hќ±i
    ¬Ј intro hni
      exact absurd hi hni
  ¬Ј rw [Set.indicator_of_notMem hmem]
    apply Finset.sum_eq_zero
    intro i hi
    apply Set.indicator_of_notMem
    intro hќ±i
    exact hmem (Set.mem_iUnionвВВ.mpr вЯ®i, hi, hќ±iвЯ©)

/-- Same-class arcs are pairwise disjoint (centers >= 1 apart, radii sum < 1). -/
lemma matched_arcs_disjoint (P Q q aвВА : вДХ) (hq : 1 вЙ§ q) (hQ : 2 вЙ§ Q) :
    ((matchedAnchors P q aвВА : Finset (вДХ √Ч вД§)) : Set (вДХ √Ч вД§)).Pairwise
      (Function.onFun Disjoint (arc Q)) := by
  intro pq hpq pq' hpq' hne
  simp only [matchedAnchors, Finset.coe_filter, Set.mem_setOf_eq] at hpq hpq'
  obtain вЯ®_, hq1, hm1вЯ© := hpq
  obtain вЯ®_, hq1', hm1'вЯ© := hpq'
  have hqq : pq.1 = pq'.1 := by rw [hq1, hq1']
  have hane : pq.2 вЙ† pq'.2 := fun h => hne (Prod.ext hqq h)
  have hcong : (pq.2 - pq'.2) % (q : вД§) = 0 := by
    rw [Int.sub_emod, hm1, hm1', sub_self, Int.zero_emod]
  have hdvd : (q : вД§) вИ£ (pq.2 - pq'.2) := Int.dvd_of_emod_eq_zero hcong
  have hne0 : pq.2 - pq'.2 вЙ† 0 := sub_ne_zero.mpr hane
  have hdiff : (q : вД§) вЙ§ |pq.2 - pq'.2| :=
    Int.le_of_dvd (abs_pos.mpr hne0) ((dvd_abs _ _).mpr hdvd)
  have hq0R : (0:вДЭ) < (q:вДЭ) := by exact_mod_cast hq
  have hQ1R : (0:вДЭ) < (Q:вДЭ) + 1 := by positivity
  -- center distance >= 1
  have hcdist : (1:вДЭ) вЙ§ |((pq.2 : вДЭ) / (pq.1 : вДХ)) - ((pq'.2 : вДЭ) / (pq'.1 : вДХ))| := by
    rw [hq1, hq1']
    have h1 : ((pq.2 : вДЭ) / (q : вДЭ)) - ((pq'.2 : вДЭ) / (q : вДЭ))
        = ((pq.2 - pq'.2 : вД§) : вДЭ) / (q : вДЭ) := by
      push_cast
      ring
    rw [h1, abs_div, abs_of_pos hq0R, le_div_iffвВА hq0R, one_mul]
    calc (q:вДЭ) вЙ§ ((|pq.2 - pq'.2| : вД§) : вДЭ) := by exact_mod_cast hdiff
      _ = |((pq.2 - pq'.2 : вД§) : вДЭ)| := by rw [Int.cast_abs]
  -- radii sum < 1
  have hrad : 1 / ((pq.1:вДЭ) * (Q + 1)) + 1 / ((pq'.1:вДЭ) * (Q + 1)) < 1 := by
    rw [hq1, hq1']
    have h3 : (3:вДЭ) вЙ§ (q:вДЭ) * ((Q:вДЭ) + 1) := by
      have hq1R : (1:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq
      have hQ2R : (2:вДЭ) вЙ§ (Q:вДЭ) := by exact_mod_cast hQ
      nlinarith
    have h2 : 1 / ((q:вДЭ) * ((Q:вДЭ) + 1)) вЙ§ 1 / 3 :=
      one_div_le_one_div_of_le (by norm_num) h3
    have h5 : (0:вДЭ) < (q:вДЭ) * ((Q:вДЭ) + 1) := by positivity
    push_cast
    linarith
  -- disjoint closed balls => disjoint arcs
  apply Set.disjoint_of_subset Set.inter_subset_left Set.inter_subset_left
  apply Metric.closedBall_disjoint_closedBall
  rw [Real.dist_eq]
  linarith [hcdist, hrad]

/-- **harc brick B1 (skeleton): the ќ®вИТќ¶ tail decomposition.** On the period, the ideal-minus-arc
    difference is the sum of tail-restricted full kernels over canonical residues. -/
lemma psi_sub_phi_eq (N P Q : вДХ) (hP : 1 вЙ§ P) (hPQ : 2 * P ^ 2 < Q + 1)
    (ќ± : вДЭ) (hќ± : ќ± вИИ Set.Ioc (0:вДЭ) 1) :
    PsiIdeal N P ќ± - PhiArc N P Q ќ±
      = вИС q вИИ Finset.Icc 1 P, ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
          * вИС aвВА вИИ redRes q,
            (tailSet P Q q aвВА).indicator
              (fun ќ≤ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2) ќ± := by
  classical
  -- Step 1: within a residue fiber, every anchor's kernel equals the canonical one (everywhere)
  have hker : вИА pq вИИ anchors P,
      (fun ќ≤ => (вИС k вИИ Finset.range N, e ((k:вДЭ) * (ќ≤ - (pq.2:вДЭ) / (pq.1:вДХ)))) ^ 2)
      = (fun ќ≤ => (вИС k вИИ Finset.range N,
          e ((k:вДЭ) * (ќ≤ - (((pq.2 % (pq.1:вД§)).toNat : вДХ):вДЭ) / ((pq.1:вДХ):вДЭ)))) ^ 2) := by
    intro pq hpq
    have hq0 : 0 < pq.1 := by
      simp only [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc] at hpq
      omega
    have hq0Z : (0:вД§) < (pq.1:вД§) := by exact_mod_cast hq0
    have hq0R : ((pq.1:вДХ):вДЭ) вЙ† 0 := by
      exact_mod_cast hq0.ne'
    have hres : ((pq.2 % (pq.1:вД§)).toNat : вД§) = pq.2 % (pq.1:вД§) :=
      Int.toNat_of_nonneg (Int.emod_nonneg _ hq0Z.ne')
    have hsplitZ : pq.2 = ((pq.2 % (pq.1:вД§)).toNat : вД§) + (pq.1:вД§) * (pq.2 / (pq.1:вД§)) := by
      rw [hres]
      exact (Int.emod_add_ediv pq.2 _).symm
    have hsplit : (pq.2 : вДЭ)
        = (((pq.2 % (pq.1:вД§)).toNat : вДХ) : вДЭ) + ((pq.1:вДХ):вДЭ) * ((pq.2 / (pq.1:вД§) : вД§):вДЭ) := by
      exact_mod_cast congrArg (Int.cast : вД§ вЖТ вДЭ) hsplitZ
    funext ќ≤
    congr 1
    apply Finset.sum_congr rfl
    intro k _
    have hdiv : (pq.2:вДЭ) / ((pq.1:вДХ):вДЭ)
        = (((pq.2 % (pq.1:вД§)).toNat : вДХ):вДЭ) / ((pq.1:вДХ):вДЭ) + ((pq.2 / (pq.1:вД§) : вД§):вДЭ) := by
      rw [hsplit]
      field_simp
    have harg : (k:вДЭ) * (ќ≤ - (pq.2:вДЭ) / ((pq.1:вДХ):вДЭ))
        = (k:вДЭ) * ((ќ≤ - (((pq.2 % (pq.1:вД§)).toNat : вДХ):вДЭ) / ((pq.1:вДХ):вДЭ))
            + ((-(pq.2 / (pq.1:вД§)) : вД§):вДЭ)) := by
      rw [hdiv]
      push_cast
      ring
    rw [harg, e_int_shift k _ (-(pq.2 / (pq.1:вД§)))]
  -- Step 2: hypotheses distilled
  have hQ2 : 2 вЙ§ Q := by nlinarith [hPQ, hP]
  -- the fiber map into (q, canonical residue)
  have hmapsto : вИА pq вИИ anchors P,
      (вЯ®pq.1, (pq.2 % (pq.1 : вД§)).toNatвЯ© : (_ : вДХ) √Ч вДХ)
        вИИ (Finset.Icc 1 P).sigma (fun q => redRes q) := by
    intro pq hpq
    have hmem := hpq
    simp only [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc] at hmem
    obtain вЯ®вЯ®вЯ®hq1, hqPвЯ©, -вЯ©, hgcdвЯ© := hmem
    have hq0Z : (0:вД§) < (pq.1 : вД§) := by exact_mod_cast hq1
    rw [Finset.mem_sigma]
    dsimp only
    constructor
    ¬Ј exact Finset.mem_Icc.mpr вЯ®hq1, hqPвЯ©
    ¬Ј rw [redRes, Finset.mem_filter, Finset.mem_range]
      constructor
      ¬Ј have h1 : pq.2 % (pq.1 : вД§) < (pq.1 : вД§) := Int.emod_lt_of_pos _ hq0Z
        have h2 : (0:вД§) вЙ§ pq.2 % (pq.1 : вД§) := Int.emod_nonneg _ hq0Z.ne'
        omega
      ¬Ј -- gcd of the residue with q equals gcd of the numerator with q, = 1
        have h3 : Int.gcd (pq.2 % (pq.1 : вД§)) (pq.1 : вД§) = Int.gcd pq.2 (pq.1 : вД§) := by
          have h : pq.2 % (pq.1 : вД§) = pq.2 + (-(pq.2 / (pq.1 : вД§))) * (pq.1 : вД§) := by
            rw [Int.emod_def]
            ring
          rw [h, Int.gcd_add_mul_right_left]
        have h4 : ((pq.2 % (pq.1 : вД§)).toNat : вД§) = pq.2 % (pq.1 : вД§) :=
          Int.toNat_of_nonneg (Int.emod_nonneg _ hq0Z.ne')
        have h5 : Nat.gcd (pq.2 % (pq.1 : вД§)).toNat pq.1
            = Int.gcd (pq.2 % (pq.1 : вД§)) (pq.1 : вД§) := by
          have e1 : (pq.2 % (pq.1 : вД§)).toNat = (pq.2 % (pq.1 : вД§)).natAbs := by omega
          have e2 : pq.1 = ((pq.1 : вД§)).natAbs := by simp
          show Nat.gcd (pq.2 % (pq.1 : вД§)).toNat pq.1
            = Nat.gcd (pq.2 % (pq.1 : вД§)).natAbs ((pq.1 : вД§)).natAbs
          rw [e1, вЖР e2]
        rw [h5, h3, hgcd]
  -- Step 3: PhiArc regrouped fiberwise, kernels canonicalized, indicators collapsed
  have hphi : PhiArc N P Q ќ±
      = вИС q вИИ Finset.Icc 1 P, вИС aвВА вИИ redRes q,
          ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
            * (вЛГ pq вИИ matchedAnchors P q aвВА, arc Q pq).indicator
                (fun ќ≤ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2) ќ± := by
    rw [PhiArc, вЖР Finset.sum_fiberwise_of_maps_to
      (g := fun pq : вДХ √Ч вД§ => (вЯ®pq.1, (pq.2 % (pq.1 : вД§)).toNatвЯ© : (_ : вДХ) √Ч вДХ)) hmapsto,
      Finset.sum_sigma]
    apply Finset.sum_congr rfl
    intro q hq
    apply Finset.sum_congr rfl
    intro aвВА haвВА
    -- the fiber over вЯ®q, aвВАвЯ© is matchedAnchors
    have hq1 : 1 вЙ§ q := (Finset.mem_Icc.mp hq).1
    have haвВАq : aвВА < q := by
      have := (Finset.mem_filter.mp haвВА).1
      exact Finset.mem_range.mp this
    have hfiber : (anchors P).filter
        (fun pq => (вЯ®pq.1, (pq.2 % (pq.1 : вД§)).toNatвЯ© : (_ : вДХ) √Ч вДХ) = вЯ®q, aвВАвЯ©)
        = matchedAnchors P q aвВА := by
      rw [matchedAnchors]
      apply Finset.filter_congr
      intro pq hpq
      have hq0 : 0 < pq.1 := by
        simp only [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc] at hpq
        omega
      have hq0Z : (0:вД§) < (pq.1 : вД§) := by exact_mod_cast hq0
      constructor
      ¬Ј intro h
        obtain вЯ®h1, h2вЯ© := Sigma.mk.inj_iff.mp h
        have h3 : (pq.2 % (pq.1 : вД§)).toNat = aвВА := eq_of_heq h2
        have h4 : ((pq.2 % (pq.1 : вД§)).toNat : вД§) = pq.2 % (pq.1 : вД§) :=
          Int.toNat_of_nonneg (Int.emod_nonneg _ hq0Z.ne')
        rw [h1] at h3 h4
        exact вЯ®h1, by omegaвЯ©
      ¬Ј rintro вЯ®h1, h2вЯ©
        subst h1
        have h4 : (pq.2 % (pq.1 : вД§)).toNat = aвВА := by
          have h5 : (0:вД§) вЙ§ pq.2 % (pq.1 : вД§) := Int.emod_nonneg _ hq0Z.ne'
          omega
        show (вЯ®pq.1, (pq.2 % (pq.1 : вД§)).toNatвЯ© : (_ : вДХ) √Ч вДХ) = вЯ®pq.1, aвВАвЯ©
        rw [h4]
    rw [hfiber]
    -- canonicalize kernels + collapse indicators over the disjoint matched arcs
    have hterm : вИА pq вИИ matchedAnchors P q aвВА,
        (arc Q pq).indicator
          (fun ќ≤ => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (pq.2 : вДЭ) / (pq.1 : вДХ)))) ^ 2) ќ±
        = (arc Q pq).indicator
            (fun ќ≤ => ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
              * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2) ќ± := by
      intro pq hpq
      obtain вЯ®hpqA, hpq1, hpq2вЯ© := Finset.mem_filter.mp hpq
      have hq0Z : (0:вД§) < (q : вД§) := by exact_mod_cast hq1
      have haвВА' : (pq.2 % (pq.1 : вД§)).toNat = aвВА := by
        rw [hpq1]
        omega
      have hkerpq := hker pq hpqA
      rw [haвВА'] at hkerpq
      congr 1
      funext ќ≤
      rw [hpq1]
      have := congrFun hkerpq ќ≤
      rw [hpq1] at this
      rw [this]
    rw [Finset.sum_congr rfl hterm,
      sum_indicator_disjoint (matchedAnchors P q aвВА) (arc Q)
        (fun ќ≤ => ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
          * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2)
        (matched_arcs_disjoint P Q q aвВА hq1 hQ2) ќ±,
      Set.indicator_const_mul]
  -- Step 4: subtract and convert 1 вИТ 1_вЛГ into the tail indicator, pointwise at ќ± вИИ Ioc
  rw [hphi, PsiIdeal, вЖР Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro q hq
  rw [Finset.mul_sum, вЖР Finset.sum_sub_distrib, Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro aвВА haвВА
  rw [вЖР mul_sub]
  congr 1
  -- pointwise: D¬≤(ќ±) вИТ 1_вЛГ(ќ±)¬ЈD¬≤(ќ±) = 1_{IocвИЦвЛГ}(ќ±)¬ЈD¬≤(ќ±)
  have hsub : (вЛГ pq вИИ matchedAnchors P q aвВА, arc Q pq) вКЖ Set.Ioc (0:вДЭ) 1 := by
    intro x hx
    obtain вЯ®pq, _, hxpqвЯ© := Set.mem_iUnionвВВ.mp hx
    exact hxpq.2
  by_cases hmem : ќ± вИИ вЛГ pq вИИ matchedAnchors P q aвВА, arc Q pq
  ¬Ј rw [Set.indicator_of_mem hmem, Set.indicator_of_notMem (by
      rw [tailSet]
      exact fun h => h.2 hmem)]
    ring
  ¬Ј rw [Set.indicator_of_notMem hmem, Set.indicator_of_mem (by
      rw [tailSet]
      exact вЯ®hќ±, hmemвЯ©)]
    ring

end B1

section B2
open MeasureTheory


/-- The two in-period integer translates of the canonical fraction are matched anchors. -/
lemma translate_mem_matched (P q aвВА : вДХ) (hqP : q вИИ Finset.Icc 1 P) (haвВА : aвВА вИИ redRes q)
    (m : вДХ) (hm : m вЙ§ 1) :
    ((q, (aвВА : вД§) + m * q) : вДХ √Ч вД§) вИИ matchedAnchors P q aвВА := by
  obtain вЯ®hq1, hqP'вЯ© := Finset.mem_Icc.mp hqP
  obtain вЯ®ha_rng, ha_gcdвЯ© := Finset.mem_filter.mp haвВА
  have ha_lt : aвВА < q := Finset.mem_range.mp ha_rng
  have hq0Z : (0:вД§) < (q : вД§) := by exact_mod_cast hq1
  rw [matchedAnchors, Finset.mem_filter]
  refine вЯ®?_, rfl, ?_вЯ©
  ¬Ј rw [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc, Finset.mem_Icc]
    refine вЯ®вЯ®вЯ®hq1, hqP'вЯ©, ?_, ?_вЯ©, ?_вЯ©
    ¬Ј -- вИТP вЙ§ aвВА + mq
      have : (0:вД§) вЙ§ (aвВА : вД§) + m * q := by positivity
      omega
    ¬Ј -- aвВА + mq вЙ§ 2P
      have h1 : (aвВА : вД§) + m * q вЙ§ (q - 1) + 1 * q := by
        have : (aвВА : вД§) вЙ§ (q : вД§) - 1 := by exact_mod_cast Nat.le_sub_one_of_lt ha_lt
        have hm' : (m : вД§) вЙ§ 1 := by exact_mod_cast hm
        nlinarith [hq0Z]
      have h2 : (q : вД§) - 1 + 1 * q вЙ§ 2 * P := by
        have : (q : вД§) вЙ§ (P : вД§) := by exact_mod_cast hqP'
        omega
      omega
    ¬Ј -- gcd(aвВА + mq, q) = gcd(aвВА, q) = 1
      have h3 : Int.gcd ((aвВА : вД§) + m * q) (q : вД§) = Int.gcd (aвВА : вД§) (q : вД§) := by
        rw [show (aвВА : вД§) + m * q = (aвВА : вД§) + (m : вД§) * (q : вД§) by push_cast; ring,
          Int.gcd_add_mul_right_left]
      rw [h3]
      exact_mod_cast ha_gcd
  ¬Ј -- residue: (aвВА + mq) % q = aвВА
    have h4 : ((aвВА : вД§) + (m : вД§) * (q : вД§)) % (q : вД§) = (aвВА : вД§) % (q : вД§) := by
      rw [Int.add_mul_emod_self_right]
    have h5 : ((aвВА : вД§) + m * q) = ((aвВА : вД§) + (m : вД§) * (q : вД§)) := by push_cast; ring
    rw [h5, h4, Int.emod_eq_of_lt (by positivity) (by exact_mod_cast ha_lt)]

/-- **B2a: tail distance** вАФ on the tail set, the kernel argument `x = ќ± вИТ aвВА/q` is at
    circle distance `> ќі_q = 1/(q(Q+1))` from every integer. -/
lemma tail_dist (P Q q aвВА : вДХ) (hqP : q вИИ Finset.Icc 1 P) (haвВА : aвВА вИИ redRes q)
    (hQ2 : 2 вЙ§ Q) (ќ± : вДЭ) (hќ± : ќ± вИИ tailSet P Q q aвВА) :
    1 / ((q : вДЭ) * ((Q : вДЭ) + 1))
      < |(ќ± - (aвВА : вДЭ) / (q : вДЭ)) - round (ќ± - (aвВА : вДЭ) / (q : вДЭ))| := by
  obtain вЯ®hq1, hqP'вЯ© := Finset.mem_Icc.mp hqP
  have ha_lt : aвВА < q := Finset.mem_range.mp (Finset.mem_filter.mp haвВА).1
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
  have hQ0R : (0:вДЭ) < (Q : вДЭ) + 1 := by positivity
  set ќі : вДЭ := 1 / ((q : вДЭ) * ((Q : вДЭ) + 1)) with hќіdef
  have hќі0 : 0 < ќі := by positivity
  have hќіq : ќі < 1 / (q : вДЭ) := by
    rw [hќіdef, div_lt_div_iffвВА (by positivity) hq0R]
    have hQ0 : (0:вДЭ) < (Q : вДЭ) := by exact_mod_cast (by omega : 0 < Q)
    nlinarith [mul_pos hq0R hQ0]
  obtain вЯ®hќ±Ioc, hќ±arcвЯ© := hќ±
  set x : вДЭ := ќ± - (aвВА : вДЭ) / (q : вДЭ) with hxdef
  by_contra hcon
  push_neg at hcon
  set m : вД§ := round x with hmdef
  -- x вИИ (вИТ1, 1], so m вИИ {вИТ1, 0, 1} вАФ actually m вИИ {0, 1} since m = вИТ1 forces ќ± < 0
  have hc01 : 0 вЙ§ (aвВА : вДЭ) / (q : вДЭ) вИІ (aвВА : вДЭ) / (q : вДЭ) вЙ§ 1 - 1 / (q : вДЭ) := by
    constructor
    ¬Ј positivity
    ¬Ј rw [div_le_iffвВА hq0R]
      have h6 : (aвВА : вДЭ) вЙ§ (q : вДЭ) - 1 := by exact_mod_cast Nat.le_sub_one_of_lt ha_lt
      have h7 : (1 - 1 / (q:вДЭ)) * (q:вДЭ) = (q:вДЭ) - 1 := by field_simp
      linarith
  have hxrange : -1 + 1 / (q : вДЭ) вЙ§ x вИІ x вЙ§ 1 := by
    constructor
    ¬Ј rw [hxdef]
      have := hќ±Ioc.1
      linarith [hc01.2]
    ¬Ј rw [hxdef]
      have := hќ±Ioc.2
      linarith [hc01.1]
  have hmge : (0 : вД§) вЙ§ m := by
    by_contra hneg
    push_neg at hneg
    have hm1 : (m : вДЭ) вЙ§ -1 := by exact_mod_cast (by omega : m вЙ§ -1)
    have habs := abs_le.mp hcon
    have hx_le : x вЙ§ (m : вДЭ) + ќі := by linarith [habs.2]
    linarith [hxrange.1, hќіq, hx_le, hm1]
  have hmle : m вЙ§ 1 := by
    rw [hmdef]
    by_contra hbig
    push_neg at hbig
    have hm2 : (2 : вДЭ) вЙ§ (m : вДЭ) := by exact_mod_cast hbig
    have habs := abs_le.mp hcon
    have : (m : вДЭ) - ќі вЙ§ x := by linarith [habs.1]
    have : (2:вДЭ) - ќі вЙ§ x := by linarith
    linarith [hxrange.2, hќі0, hќіq, (by positivity : (0:вДЭ) < 1 / (q:вДЭ))]
  -- so ќ± lies in the ball around the matched translate (aвВА + mq)/q вАФ a matched arc
  have hmem : ќ± вИИ arc Q ((q, (aвВА : вД§) + m.toNat * q)) := by
    constructor
    ¬Ј rw [Metric.mem_closedBall, Real.dist_eq]
      have hcenter : (((aвВА : вД§) + m.toNat * q : вД§) : вДЭ) / ((q : вДХ) : вДЭ)
          = (aвВА : вДЭ) / (q : вДЭ) + (m : вДЭ) := by
        have hmt : (m.toNat : вД§) = m := Int.toNat_of_nonneg hmge
        have hmtR : ((m.toNat : вДХ) : вДЭ) = (m : вДЭ) := by exact_mod_cast hmt
        have h1 : (((aвВА : вД§) + m.toNat * q : вД§) : вДЭ) = (aвВА : вДЭ) + (m : вДЭ) * (q : вДЭ) := by
          push_cast
          rw [hmtR]
        rw [h1]
        field_simp
      rw [hcenter]
      have habs := abs_le.mp hcon
      rw [abs_le]
      constructor
      ¬Ј have := habs.1
        rw [hxdef] at this
        push_cast
        linarith
      ¬Ј have := habs.2
        rw [hxdef] at this
        push_cast
        linarith
    ¬Ј exact hќ±Ioc
  exact hќ±arc (Set.mem_iUnionвВВ.mpr
    вЯ®(q, (aвВА : вД§) + m.toNat * q),
     translate_mem_matched P q aвВА hqP haвВА m.toNat (by omega), hmemвЯ©)

/-- **harc brick B2 (statement): the per-tail LвБі bound** with the 3-center constant. -/
lemma tail_L4_bound (N P Q q aвВА : вДХ) (hqP : q вИИ Finset.Icc 1 P) (haвВА : aвВА вИИ redRes q)
    (hQ2 : 2 вЙ§ Q) :
    вИЂ ќ± in tailSet P Q q aвВА,
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2вАЦ ^ 2
      вЙ§ ((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8 := by
  classical
  obtain вЯ®hq1, hqP'вЯ© := Finset.mem_Icc.mp hqP
  have ha_lt : aвВА < q := Finset.mem_range.mp (Finset.mem_filter.mp haвВА).1
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
  set c : вДЭ := (aвВА : вДЭ) / (q : вДЭ) with hcdef
  set ќі : вДЭ := 1 / ((q : вДЭ) * ((Q : вДЭ) + 1)) with hќіdef
  have hќі0 : (0:вДЭ) < ќі := by positivity
  -- the even one-center tail majorant
  set h : вДЭ вЖТ вДЭ := fun u => Set.indicator {u : вДЭ | ќі < |u|} (fun u => 1 / (16 * u ^ 4)) u
    with hhdef
  have hh_nonneg : вИА u, 0 вЙ§ h u := by
    intro u
    rw [hhdef]
    apply Set.indicator_nonneg
    intro v _
    positivity
  -- tail is measurable and inside the period
  have htail_meas : MeasurableSet (tailSet P Q q aвВА) := by
    apply MeasurableSet.diff measurableSet_Ioc
    apply MeasurableSet.biUnion (Set.to_countable _)
    intro pq _
    exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  have htail_sub : tailSet P Q q aвВА вКЖ Set.Ioc (0:вДЭ) 1 := fun ќ± hќ± => hќ±.1
  -- pointwise domination on the tail by the three shifted majorants
  have hpt : вИА ќ± вИИ tailSet P Q q aвВА,
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ ^ 2
        вЙ§ h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1)) := by
    intro ќ± hќ±
    have hd := tail_dist P Q q aвВА hqP haвВА hQ2 ќ± hќ±
    rw [вЖР hcdef, вЖР hќіdef] at hd
    set x : вДЭ := ќ± - c with hxdef
    set m : вД§ := round x with hmdef
    have hsin : Real.sin (Real.pi * x) вЙ† 0 := by
      intro hzero
      obtain вЯ®n, hnвЯ© := Real.sin_eq_zero_iff.mp hzero
      have hxn : x = (n : вДЭ) := by
        have h2 : Real.pi * (x - (n : вДЭ)) = 0 := by ring_nf; linarith [hn]
        rcases mul_eq_zero.mp h2 with h | h
        ¬Ј exact absurd h Real.pi_ne_zero
        ¬Ј linarith
      have hzero' : |x - (round x : вДЭ)| = 0 := by
        rw [hxn, round_intCast]
        simp
      rw [hzero'] at hd
      linarith [hќі0]
    have hbound := dirichlet_pow4_pt N x hsin
    -- round x вИИ {вИТ1, 0, 1} from x вИИ (вИТ1, 1]
    have hќ±Ioc := htail_sub hќ±
    have hc0 : 0 вЙ§ c := by rw [hcdef]; positivity
    have hc1 : c вЙ§ 1 := by
      rw [hcdef, div_le_one hq0R]
      exact_mod_cast ha_lt.le
    have hx_lb : -1 < x := by rw [hxdef]; linarith [hќ±Ioc.1]
    have hx_ub : x вЙ§ 1 := by rw [hxdef]; linarith [hќ±Ioc.2, hc0]
    have hm_lb : -1 вЙ§ m := by
      rw [hmdef, round_eq]
      have : (-1 : вДЭ) вЙ§ x + 1/2 := by linarith
      exact_mod_cast Int.le_floor.mpr (by push_cast; linarith)
    have hm_ub : m вЙ§ 1 := by
      rw [hmdef, round_eq]
      have : x + 1/2 < 2 := by linarith
      have h2 : вМКx + 1/2вМЛ < 2 := Int.floor_lt.mpr (by push_cast; linarith)
      omega
    -- the m-th majorant equals the Dirichlet bound; the others are вЙ• 0
    have hmain : h (x - (m : вДЭ)) = 1 / (16 * (x - (m : вДЭ)) ^ 4) := by
      rw [hhdef]
      apply Set.indicator_of_mem
      rw [Set.mem_setOf_eq]
      calc ќі < |x - round x| := hd
        _ = |x - (m : вДЭ)| := by rw [hmdef]
    have habs4 : |x - round x| ^ 4 = (x - (m : вДЭ)) ^ 4 := by
      rw [hmdef, вЖР abs_pow, abs_of_nonneg (by positivity)]
    have hle : вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ ^ 2 вЙ§ h (x - (m : вДЭ)) := by
      rw [hmain]
      calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ ^ 2
          вЙ§ 1 / (16 * |x - round x| ^ 4) := hbound
        _ = 1 / (16 * (x - (m : вДЭ)) ^ 4) := by rw [habs4]
    -- x вИТ m appears among the three shifts ќ± вИТ (c + j), j вИИ {вИТ1,0,1}
    have hxm : x - (m : вДЭ) = ќ± - (c + (m : вДЭ)) := by rw [hxdef]; ring
    interval_cases m
    ¬Ј calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ ^ 2
          вЙ§ h (x - ((-1 : вД§) : вДЭ)) := hle
        _ = h (ќ± - (c + (-1))) := by rw [hxm]; norm_num
        _ вЙ§ h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1)) := by
            have := hh_nonneg (ќ± - (c + 0))
            have := hh_nonneg (ќ± - (c + 1))
            linarith
    ¬Ј calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ ^ 2
          вЙ§ h (x - ((0 : вД§) : вДЭ)) := hle
        _ = h (ќ± - (c + 0)) := by rw [hxm]; norm_num
        _ вЙ§ h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1)) := by
            have := hh_nonneg (ќ± - (c + (-1)))
            have := hh_nonneg (ќ± - (c + 1))
            linarith
    ¬Ј calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ ^ 2
          вЙ§ h (x - ((1 : вД§) : вДЭ)) := hle
        _ = h (ќ± - (c + 1)) := by rw [hxm]; norm_num
        _ вЙ§ h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1)) := by
            have := hh_nonneg (ќ± - (c + (-1)))
            have := hh_nonneg (ќ± - (c + 0))
            linarith
  -- ==== integral assembly ====
  -- the integrand is continuous, hence integrable on the (measurable, bounded) tail
  have hcont : Continuous (fun ќ± : вДЭ =>
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ ^ 2) := by
    simp only [e]
    fun_prop
  have hint1 : IntegrableOn (fun ќ± : вДЭ =>
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ ^ 2) (tailSet P Q q aвВА) :=
    (hcont.integrableOn_Ioc (a := 0) (b := 1)).mono_set htail_sub
  -- h is measurable and globally integrable (two rpow tails)
  have hSeq : {u : вДЭ | ќі < |u|} = Set.Iio (-ќі) вИ™ Set.Ioi ќі := by
    ext u
    simp only [Set.mem_setOf_eq, Set.mem_union, Set.mem_Iio, Set.mem_Ioi]
    rw [lt_abs]
    constructor
    ¬Ј rintro (h | h)
      ¬Ј right; exact h
      ¬Ј left; linarith
    ¬Ј rintro (h | h)
      ¬Ј right; linarith
      ¬Ј left; exact h
  have hSmeas : MeasurableSet {u : вДЭ | ќі < |u|} := by
    rw [hSeq]
    exact measurableSet_Iio.union measurableSet_Ioi
  have hIoi_int : IntegrableOn (fun u : вДЭ => 1 / (16 * u ^ 4)) (Set.Ioi ќі) := by
    have h1 : IntegrableOn (fun u : вДЭ => u ^ (-4 : вДЭ)) (Set.Ioi ќі) :=
      integrableOn_Ioi_rpow_of_lt (by norm_num) hќі0
    have h2 : IntegrableOn (fun u : вДЭ => (1/16) * u ^ (-4 : вДЭ)) (Set.Ioi ќі) := h1.const_mul _
    apply h2.congr_fun _ measurableSet_Ioi
    intro u hu
    have hu0 : (0:вДЭ) < u := lt_trans hќі0 hu
    show (1:вДЭ)/16 * u ^ (-4 : вДЭ) = 1 / (16 * u ^ 4)
    rw [Real.rpow_neg hu0.le, show (4:вДЭ) = ((4:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
    field_simp
  have hIio_int : IntegrableOn (fun u : вДЭ => 1 / (16 * u ^ 4)) (Set.Iio (-ќі)) := by
    have h1 : IntegrableOn (fun u : вДЭ => 1 / (16 * (-u) ^ 4)) (-(Set.Ioi ќі)) :=
      hIoi_int.comp_neg
    rw [Set.neg_Ioi] at h1
    apply h1.congr_fun _ measurableSet_Iio
    intro u _
    show (1:вДЭ) / (16 * (-u) ^ 4) = 1 / (16 * u ^ 4)
    ring_nf
  have hh_int : Integrable h := by
    rw [hhdef, integrable_indicator_iff hSmeas]
    rw [hSeq, integrableOn_union]
    exact вЯ®hIio_int, hIoi_intвЯ©
  -- each shifted majorant is integrable, with вИЂ_tail вЙ§ вИЂ_вДЭ = вИЂ h
  have hshift : вИА s : вДЭ, вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - s) вЙ§ вИЂ u, h u := by
    intro s
    have hInt : Integrable (fun ќ± : вДЭ => h (ќ± - s)) := by
      have := hh_int.comp_sub_right s
      exact this
    calc вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - s)
        вЙ§ вИЂ ќ±, h (ќ± - s) := by
          apply setIntegral_le_integral hInt
          filter_upwards with ќ± using hh_nonneg _
      _ = вИЂ u, h u := integral_sub_right_eq_self h s
  have hshift_int : вИА s : вДЭ, IntegrableOn (fun ќ± : вДЭ => h (ќ± - s)) (tailSet P Q q aвВА) :=
    fun s => (hh_int.comp_sub_right s).integrableOn
  -- the master chain
  have hќіcube : (0:вДЭ) < ќі ^ 3 := by positivity
  have hIval : вИЂ u, h u вЙ§ 1 / (24 * ќі ^ 3) := by
    have hdisj : Disjoint (Set.Iio (-ќі)) (Set.Ioi ќі) := by
      apply Set.disjoint_left.mpr
      intro u hu1 hu2
      rw [Set.mem_Iio] at hu1
      rw [Set.mem_Ioi] at hu2
      linarith
    have hIoi_val : вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * u ^ 4) = 1 / (48 * ќі ^ 3) := by
      have hcongr : вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * u ^ 4)
          = вИЂ u in Set.Ioi ќі, (1/16 : вДЭ) * u ^ (-4 : вДЭ) := by
        apply setIntegral_congr_fun measurableSet_Ioi
        intro u hu
        have hu0 : (0:вДЭ) < u := lt_trans hќі0 hu
        show (1:вДЭ) / (16 * u ^ 4) = 1/16 * u ^ (-4 : вДЭ)
        rw [Real.rpow_neg hu0.le, show (4:вДЭ) = ((4:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
        field_simp
      rw [hcongr, MeasureTheory.integral_const_mul,
        integral_Ioi_rpow_of_lt (by norm_num : (-4:вДЭ) < -1) hќі0]
      have hќі3 : ќі ^ ((-4 : вДЭ) + 1) = 1 / ќі ^ 3 := by
        rw [show (-4 : вДЭ) + 1 = -((3:вДХ) : вДЭ) by norm_num, Real.rpow_neg hќі0.le,
          Real.rpow_natCast]
        rw [one_div]
      rw [hќі3]
      have hќіne : ќі вЙ† 0 := hќі0.ne'
      field_simp
      try ring
    have hIio_val : вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (16 * u ^ 4) = 1 / (48 * ќі ^ 3) := by
      have hrefl : вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (16 * u ^ 4)
          = вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * (-u) ^ 4) := by
        rw [show (вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (16 * u ^ 4))
            = вИЂ u in Set.Iic (-ќі), (1 : вДЭ) / (16 * u ^ 4) from
          MeasureTheory.integral_Iic_eq_integral_Iio.symm]
        rw [вЖР integral_comp_neg_Ioi]
      rw [hrefl]
      have hcongr2 : вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * (-u) ^ 4)
          = вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * u ^ 4) := by
        apply setIntegral_congr_fun measurableSet_Ioi
        intro u _
        show (1:вДЭ) / (16 * (-u) ^ 4) = 1 / (16 * u ^ 4)
        ring_nf
      rw [hcongr2, hIoi_val]
    calc вИЂ u, h u
        = вИЂ u in {u : вДЭ | ќі < |u|}, (1 : вДЭ) / (16 * u ^ 4) := by
          rw [hhdef, MeasureTheory.integral_indicator hSmeas]
      _ = вИЂ u in Set.Iio (-ќі) вИ™ Set.Ioi ќі, (1 : вДЭ) / (16 * u ^ 4) := by
          rw [hSeq]
      _ = (вИЂ u in Set.Iio (-ќі), (1 : вДЭ) / (16 * u ^ 4))
          + вИЂ u in Set.Ioi ќі, (1 : вДЭ) / (16 * u ^ 4) := by
          rw [MeasureTheory.setIntegral_union hdisj measurableSet_Ioi hIio_int hIoi_int]
      _ = 1 / (48 * ќі ^ 3) + 1 / (48 * ќі ^ 3) := by rw [hIio_val, hIoi_val]
      _ вЙ§ 1 / (24 * ќі ^ 3) := by
          apply le_of_eq
          have hќіne : ќі вЙ† 0 := hќі0.ne'
          field_simp
          try ring
  calc вИЂ ќ± in tailSet P Q q aвВА,
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ ^ 2
      вЙ§ вИЂ ќ± in tailSet P Q q aвВА,
          (h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1))) := by
        apply setIntegral_mono_on hint1 _ htail_meas hpt
        exact ((hshift_int _).add (hshift_int _)).add (hshift_int _)
    _ = (вИЂ ќ± in tailSet P Q q aвВА, (h (ќ± - (c + (-1))) + h (ќ± - (c + 0))))
        + (вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - (c + 1))) :=
        integral_add ((hshift_int _).add (hshift_int _)) (hshift_int _)
    _ = (вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - (c + (-1))))
        + (вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - (c + 0)))
        + (вИЂ ќ± in tailSet P Q q aвВА, h (ќ± - (c + 1))) := by
        rw [integral_add (hshift_int _) (hshift_int _)]
    _ вЙ§ (вИЂ u, h u) + (вИЂ u, h u) + (вИЂ u, h u) :=
        add_le_add (add_le_add (hshift _) (hshift _)) (hshift _)
    _ = 3 * вИЂ u, h u := by ring
    _ вЙ§ 3 * (1 / (24 * ќі ^ 3)) := by
        apply mul_le_mul_of_nonneg_left hIval (by norm_num)
    _ = 1 / (8 * ќі ^ 3) := by ring
    _ = ((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8 := by
        rw [hќіdef]
        have hqQ : (0:вДЭ) < (q : вДЭ) * ((Q : вДЭ) + 1) := by positivity
        field_simp
        try ring

end B2

section B3

/-- `q¬≥/ѕЖ(q)¬≥ вЙ§ 8¬Јq^{3/2}` for squarefree `q` (B0 squared-and-cubed, no rpow gymnastics:
    `q¬≥ вЙ§ 8¬Јq^{3/2}¬ЈѕЖ¬≥` вЯЄ `(q^{3/2})¬≤ = q¬≥ вЙ§ (4ѕЖ¬≤)¬≥ = (8ѕЖ¬≥)¬≤`). -/
lemma cube_totient_ratio (q : вДХ) (hq1 : 1 вЙ§ q) (hsq : Squarefree q) :
    (q : вДЭ) ^ 3 / (Nat.totient q : вДЭ) ^ 3 вЙ§ 8 * (q : вДЭ) ^ ((3 : вДЭ) / 2) := by
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
  have hѕЖ1 : 1 вЙ§ q.totient := Nat.totient_pos.mpr (by omega)
  have hѕЖ0R : (0:вДЭ) < (q.totient : вДЭ) := by exact_mod_cast hѕЖ1
  have hB0 := sqfree_totient_linear q hsq
  set x : вДЭ := (q : вДЭ) ^ ((3 : вДЭ) / 2) with hxdef
  have hx0 : 0 вЙ§ x := Real.rpow_nonneg hq0R.le _
  have hxsq : x ^ 2 = (q : вДЭ) ^ 3 := by
    rw [hxdef, вЖР Real.rpow_natCast ((q:вДЭ) ^ ((3:вДЭ)/2)) 2, вЖР Real.rpow_mul hq0R.le]
    norm_num
    try rw [show (3:вДЭ) = ((3:вДХ):вДЭ) by norm_num, Real.rpow_natCast]
  have hy0 : (0:вДЭ) вЙ§ 8 * (q.totient : вДЭ) ^ 3 := by positivity
  have hsq_le : x ^ 2 вЙ§ (8 * (q.totient : вДЭ) ^ 3) ^ 2 := by
    rw [hxsq]
    have h1 : (q : вДЭ) ^ 3 вЙ§ (4 * (q.totient : вДЭ) ^ 2) ^ 3 := by
      apply pow_le_pow_leftвВА hq0R.le hB0
    calc (q : вДЭ) ^ 3 вЙ§ (4 * (q.totient : вДЭ) ^ 2) ^ 3 := h1
      _ = (8 * (q.totient : вДЭ) ^ 3) ^ 2 := by ring
  have hxle : x вЙ§ 8 * (q.totient : вДЭ) ^ 3 := by
    by_contra hcon
    push_neg at hcon
    have : (8 * (q.totient : вДЭ) ^ 3) ^ 2 < x ^ 2 := by
      apply pow_lt_pow_leftвВА hcon hy0
      norm_num
    linarith
  rw [div_le_iffвВА (by positivity : (0:вДЭ) < (q.totient : вДЭ) ^ 3)]
  calc (q : вДЭ) ^ 3 = x ^ 2 := hxsq.symm
    _ = x * x := by ring
    _ вЙ§ x * (8 * (q.totient : вДЭ) ^ 3) := by
        apply mul_le_mul_of_nonneg_left hxle hx0
    _ = 8 * x * (q.totient : вДЭ) ^ 3 := by ring

/-- **harc brick B3: the diagonal sum** вЙ§ (Q+1)¬≥¬Ј8¬ЈP^{5/2}. -/
lemma diagonal_bound (P Q : вДХ) (hP : 1 вЙ§ P) :
    вИС q вИИ Finset.Icc 1 P, вИС _aвВА вИИ redRes q,
      вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
        * (((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8)
      вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2)) := by
  classical
  have hper : вИА q вИИ Finset.Icc 1 P,
      (вИС _aвВА вИИ redRes q,
        вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
          * (((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8))
      вЙ§ ((Q : вДЭ) + 1) ^ 3 * (q : вДЭ) ^ ((3 : вДЭ) / 2) := by
    intro q hq
    obtain вЯ®hq1, hqPвЯ© := Finset.mem_Icc.mp hq
    have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
    rw [Finset.sum_const, nsmul_eq_mul]
    by_cases hsq : Squarefree q
    ¬Ј have hѕЖ1 : 1 вЙ§ q.totient := Nat.totient_pos.mpr (by omega)
      have hѕЖ0R : (0:вДЭ) < (q.totient : вДЭ) := by exact_mod_cast hѕЖ1
      -- coefficient: вАЦ(ќЉ/ѕЖ)¬≤вАЦ¬≤ вЙ§ 1/ѕЖвБі
      have hќЉ : вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
          вЙ§ 1 / (q.totient : вДЭ) ^ 4 := by
        have h0 : вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
            = вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ))вАЦ ^ 4 := by
          rw [norm_pow]
          ring
        rw [h0, norm_div, Complex.norm_intCast, Complex.norm_natCast]
        have hќЉ1 : |(ArithmeticFunction.moebius q : вД§)| вЙ§ 1 :=
          ArithmeticFunction.abs_moebius_le_one
        have hќЉ1R : |((ArithmeticFunction.moebius q : вД§) : вДЭ)| вЙ§ 1 := by
          rw [вЖР Int.cast_abs]
          exact_mod_cast hќЉ1
        have h2 : |((ArithmeticFunction.moebius q : вД§) : вДЭ)| / (q.totient : вДЭ)
            вЙ§ 1 / (q.totient : вДЭ) := by
          apply div_le_div_of_nonneg_right hќЉ1R hѕЖ0R.le
        calc (|((ArithmeticFunction.moebius q : вД§) : вДЭ)| / (q.totient : вДЭ)) ^ 4
            вЙ§ (1 / (q.totient : вДЭ)) ^ 4 := by
              apply pow_le_pow_leftвВА (by positivity) h2
          _ = 1 / (q.totient : вДЭ) ^ 4 := by
              rw [div_pow, one_pow]
      -- count: |redRes q| = ѕЖ(q)
      have hcard : ((redRes q).card : вДЭ) = (q.totient : вДЭ) := by
        have h1 : (redRes q).card = q.totient := by
          rw [redRes, Nat.totient]
          congr 1
          apply Finset.filter_congr
          intro a _
          simp [Nat.Coprime, Nat.gcd_comm]
        rw [h1]
      have hratio := cube_totient_ratio q hq1 hsq
      calc ((redRes q).card : вДЭ)
            * (вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
              * (((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8))
          вЙ§ (q.totient : вДЭ) * ((1 / (q.totient : вДЭ) ^ 4) * (((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8)) := by
            rw [hcard]
            apply mul_le_mul_of_nonneg_left _ hѕЖ0R.le
            apply mul_le_mul_of_nonneg_right hќЉ (by positivity)
        _ = ((Q : вДЭ) + 1) ^ 3 * ((q : вДЭ) ^ 3 / (q.totient : вДЭ) ^ 3) / 8 := by
            field_simp
            try ring
        _ вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (q : вДЭ) ^ ((3:вДЭ)/2)) / 8 := by
            apply div_le_div_of_nonneg_right _ (by norm_num)
            apply mul_le_mul_of_nonneg_left hratio (by positivity)
        _ = ((Q : вДЭ) + 1) ^ 3 * (q : вДЭ) ^ ((3:вДЭ)/2) := by ring
    ¬Ј have hќЉ0 : ArithmeticFunction.moebius q = 0 :=
        ArithmeticFunction.moebius_eq_zero_of_not_squarefree hsq
      rw [hќЉ0]
      simp
      positivity
  calc вИС q вИИ Finset.Icc 1 P, вИС _aвВА вИИ redRes q,
        вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ ^ 2
          * (((q : вДЭ) * ((Q : вДЭ) + 1)) ^ 3 / 8)
      вЙ§ вИС q вИИ Finset.Icc 1 P, ((Q : вДЭ) + 1) ^ 3 * (q : вДЭ) ^ ((3 : вДЭ) / 2) :=
        Finset.sum_le_sum hper
    _ вЙ§ вИС _q вИИ Finset.Icc 1 P, ((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ ((3 : вДЭ) / 2) := by
        apply Finset.sum_le_sum
        intro q hq
        obtain вЯ®hq1, hqPвЯ© := Finset.mem_Icc.mp hq
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        apply Real.rpow_le_rpow (by positivity) (by exact_mod_cast hqP) (by norm_num)
    _ вЙ§ (P : вДЭ) * (((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ ((3 : вДЭ) / 2)) := by
        rw [Finset.sum_const, nsmul_eq_mul, Nat.card_Icc]
        apply mul_le_mul_of_nonneg_right _ (by positivity)
        have h1 : P + 1 - 1 = P := by omega
        rw [h1]
    _ вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2)) := by
        have hP0 : (0:вДЭ) < (P : вДЭ) := by exact_mod_cast hP
        have h1 : (P : вДЭ) * (P : вДЭ) ^ ((3 : вДЭ) / 2) = (P : вДЭ) ^ ((5 : вДЭ) / 2) := by
          nth_rewrite 1 [show (P : вДЭ) = (P : вДЭ) ^ (1 : вДЭ) from (Real.rpow_one _).symm]
          rw [вЖР Real.rpow_add hP0]
          norm_num
        calc (P : вДЭ) * (((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ ((3 : вДЭ) / 2))
            = ((Q : вДЭ) + 1) ^ 3 * ((P : вДЭ) * (P : вДЭ) ^ ((3 : вДЭ) / 2)) := by ring
          _ = ((Q : вДЭ) + 1) ^ 3 * (P : вДЭ) ^ ((5 : вДЭ) / 2) := by rw [h1]
          _ вЙ§ ((Q : вДЭ) + 1) ^ 3 * (8 * (P : вДЭ) ^ ((5 : вДЭ) / 2)) := by
              apply mul_le_mul_of_nonneg_left _ (by positivity)
              nlinarith [Real.rpow_nonneg hP0.le ((5:вДЭ)/2)]

end B3

section B4
open MeasureTheory

/-- **B4a: Farey separation for distinct canonical fractions** вАФ distinct reduced fractions
    `aвВА/q вЙ† aвВА'/q'` are at distance `вЙ• 1/(qq')` (integer numerator `|aвВАq' вИТ aвВА'q| вЙ• 1`). -/
lemma redRes_sep (q q' aвВА aвВА' : вДХ) (hq : 1 вЙ§ q) (hq' : 1 вЙ§ q')
    (hne : (aвВА : вДЭ) / (q : вДЭ) вЙ† (aвВА' : вДЭ) / (q' : вДЭ)) :
    1 / ((q : вДЭ) * (q' : вДЭ)) вЙ§ |(aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ)| := by
  have hq0 : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  have hq'0 : (0:вДЭ) < (q' : вДЭ) := by exact_mod_cast hq'
  have hval : (aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ)
      = (((aвВА : вД§) * q' - (aвВА' : вД§) * q : вД§) : вДЭ) / ((q : вДЭ) * (q' : вДЭ)) := by
    push_cast
    field_simp
  have hnum : (aвВА : вД§) * q' - (aвВА' : вД§) * q вЙ† 0 := by
    intro h0
    apply hne
    rw [div_eq_div_iff hq0.ne' hq'0.ne']
    have h1 : (aвВА : вД§) * q' = (aвВА' : вД§) * q := by omega
    exact_mod_cast h1
  rw [hval, abs_div, abs_of_pos (by positivity : (0:вДЭ) < (q : вДЭ) * (q' : вДЭ))]
  apply div_le_div_of_nonneg_right _ (by positivity)
  have h1 : (1 : вД§) вЙ§ |(aвВА : вД§) * q' - (aвВА' : вД§) * q| := Int.one_le_abs hnum
  calc (1:вДЭ) = ((1:вД§) : вДЭ) := by norm_num
    _ вЙ§ ((|(aвВА : вД§) * q' - (aвВА' : вД§) * q| : вД§) : вДЭ) := by exact_mod_cast h1
    _ = |(((aвВА : вД§) * q' - (aвВА' : вД§) * q : вД§) : вДЭ)| := by rw [Int.cast_abs]

/-- **B4aвА≤: circle separation** вАФ distinct canonical fractions in `[0,1)` separate by
    `вЙ• 1/(qq')` from every integer translate `m вИИ {вИТ1,0,1}` of each other (the same
    integer-numerator argument per translate). -/
lemma redRes_sep_circle (q q' aвВА aвВА' : вДХ) (hq : 1 вЙ§ q) (hq' : 1 вЙ§ q')
    (ha : aвВА < q) (ha' : aвВА' < q')
    (hne : (aвВА : вДЭ) / (q : вДЭ) вЙ† (aвВА' : вДЭ) / (q' : вДЭ)) (m : вД§) (hm : m.natAbs вЙ§ 1) :
    1 / ((q : вДЭ) * (q' : вДЭ)) вЙ§ |(aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ) - (m : вДЭ)| := by
  have hq0 : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  have hq'0 : (0:вДЭ) < (q' : вДЭ) := by exact_mod_cast hq'
  have hval : (aвВА : вДЭ) / (q : вДЭ) - (aвВА' : вДЭ) / (q' : вДЭ) - (m : вДЭ)
      = (((aвВА : вД§) * q' - (aвВА' : вД§) * q - m * (q * q') : вД§) : вДЭ) / ((q : вДЭ) * (q' : вДЭ)) := by
    push_cast
    field_simp
  have hnum : (aвВА : вД§) * q' - (aвВА' : вД§) * q - m * (q * q') вЙ† 0 := by
    intro h0
    have hm1 : -1 вЙ§ m := by omega
    have hm2 : m вЙ§ 1 := by omega
    interval_cases m
    ¬Ј -- m = вИТ1: aвВАq' вИТ aвВА'q = вИТqq' вЖТ aвВА/q вИТ aвВА'/q' = вИТ1, impossible since both вИИ [0,1)
      have h1 : (aвВА : вД§) * q' + q * q' = (aвВА' : вД§) * q := by omega
      have h2 : (aвВА' : вД§) * q < q * q' := by
        have : (aвВА' : вД§) < q' := by exact_mod_cast ha'
        have hqZ : (0:вД§) < (q:вД§) := by exact_mod_cast hq
        nlinarith
      have h3 : (0:вД§) вЙ§ (aвВА : вД§) * q' := by positivity
      omega
    ¬Ј -- m = 0: the plain separation numerator
      apply absurd _ hne
      rw [div_eq_div_iff hq0.ne' hq'0.ne']
      have h1 : (aвВА : вД§) * q' = (aвВА' : вД§) * q := by omega
      exact_mod_cast h1
    ¬Ј -- m = 1: symmetric to m = вИТ1
      have h1 : (aвВА : вД§) * q' = (aвВА' : вД§) * q + q * q' := by omega
      have h2 : (aвВА : вД§) * q' < q * q' := by
        have : (aвВА : вД§) < q := by exact_mod_cast ha
        have hq'Z : (0:вД§) < (q':вД§) := by exact_mod_cast hq'
        nlinarith
      have h3 : (0:вД§) вЙ§ (aвВА' : вД§) * q := by positivity
      omega
  rw [hval, abs_div, abs_of_pos (by positivity : (0:вДЭ) < (q : вДЭ) * (q' : вДЭ))]
  apply div_le_div_of_nonneg_right _ (by positivity)
  have h1 : (1 : вД§) вЙ§ |(aвВА : вД§) * q' - (aвВА' : вД§) * q - m * (q * q')| := Int.one_le_abs hnum
  calc (1:вДЭ) = ((1:вД§) : вДЭ) := by norm_num
    _ вЙ§ ((|(aвВА : вД§) * q' - (aвВА' : вД§) * q - m * (q * q')| : вД§) : вДЭ) := by exact_mod_cast h1
    _ = |(((aвВА : вД§) * q' - (aвВА' : вД§) * q - m * (q * q') : вД§) : вДЭ)| := by rw [Int.cast_abs]


/-- **B4c: the near-kernel L¬є tail integral** вАФ over its own tail, the single kernel
    integrates (in L¬є) to `вЙ§ (3/2)¬Јq(Q+1)`: the B2 3-center domination at exponent 2. -/
lemma tail_L1_bound (N P Q q aвВА : вДХ) (hqP : q вИИ Finset.Icc 1 P) (haвВА : aвВА вИИ redRes q)
    (hQ2 : 2 вЙ§ Q) :
    вИЂ ќ± in tailSet P Q q aвВА,
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (aвВА : вДЭ) / (q : вДЭ)))) ^ 2вАЦ
      вЙ§ (3 / 2) * ((q : вДЭ) * ((Q : вДЭ) + 1)) := by
  classical
  obtain вЯ®hq1, hqP'вЯ© := Finset.mem_Icc.mp hqP
  have ha_lt : aвВА < q := Finset.mem_range.mp (Finset.mem_filter.mp haвВА).1
  have hq0R : (0:вДЭ) < (q : вДЭ) := by exact_mod_cast hq1
  set c : вДЭ := (aвВА : вДЭ) / (q : вДЭ) with hcdef
  set ќі : вДЭ := 1 / ((q : вДЭ) * ((Q : вДЭ) + 1)) with hќіdef
  have hќі0 : (0:вДЭ) < ќі := by positivity
  set h : вДЭ вЖТ вДЭ := fun u => Set.indicator {u : вДЭ | ќі < |u|} (fun u => 1 / (4 * u ^ 2)) u
    with hhdef
  have hh_nonneg : вИА u, 0 вЙ§ h u := by
    intro u
    rw [hhdef]
    apply Set.indicator_nonneg
    intro v _
    positivity
  have htail_meas : MeasurableSet (tailSet P Q q aвВА) := by
    apply MeasurableSet.diff measurableSet_Ioc
    apply MeasurableSet.biUnion (Set.to_countable _)
    intro pq _
    exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  have htail_sub : tailSet P Q q aвВА вКЖ Set.Ioc (0:вДЭ) 1 := fun ќ± hќ± => hќ±.1
  -- pointwise domination by the three shifted majorants (exponent 2)
  have hpt : вИА ќ± вИИ tailSet P Q q aвВА,
      вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ
        вЙ§ h (ќ± - (c + (-1))) + h (ќ± - (c + 0)) + h (ќ± - (c + 1)) := by
    intro ќ± hќ±
    have hd := tail_dist P Q q aвВА hqP haвВА hQ2 ќ± hќ±
    rw [вЖР hcdef, вЖР hќіdef] at hd
    set x : вДЭ := ќ± - c with hxdef
    set m : вД§ := round x with hmdef
    have hsin : Real.sin (Real.pi * x) вЙ† 0 := by
      intro hzero
      obtain вЯ®n, hnвЯ© := Real.sin_eq_zero_iff.mp hzero
      have hxn : x = (n : вДЭ) := by
        have h2 : Real.pi * (x - (n : вДЭ)) = 0 := by ring_nf; linarith [hn]
        rcases mul_eq_zero.mp h2 with h | h
        ¬Ј exact absurd h Real.pi_ne_zero
        ¬Ј linarith
      have hzero' : |x - (round x : вДЭ)| = 0 := by
        rw [hxn, round_intCast]
        simp
      rw [hzero'] at hd
      linarith [hќі0]
    have hbound : вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ
        вЙ§ 1 / (4 * |x - round x| ^ 2) := by
      rw [norm_pow]
      have hb := exp_sum_bound x hsin N
      calc вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * x)вАЦ ^ 2
          вЙ§ (1 / (2 * |x - round x|)) ^ 2 := by
            apply pow_le_pow_leftвВА (norm_nonneg _) hb
        _ = 1 / (4 * |x - round x| ^ 2) := by
            rw [div_pow, one_pow, mul_pow]
            norm_num
    have hќ±Ioc := htail_sub hќ±
    have hc0 : 0 вЙ§ c := by rw [hcdef]; positivity
    have hc1 : c вЙ§ 1 := by
      rw [hcdef, div_le_one hq0R]
      exact_mod_cast ha_lt.le
    have hx_lb : -1 < x := by rw [hxdef]; linarith [hќ±Ioc.1]
    have hx_ub : x вЙ§ 1 := by rw [hxdef]; linarith [hќ±Ioc.2, hc0]
    have hm_lb : -1 вЙ§ m := by
      rw [hmdef, round_eq]
      exact_mod_cast Int.le_floor.mpr (by push_cast; linarith)
    have hm_ub : m вЙ§ 1 := by
      rw [hmdef, round_eq]
      have h2 : вМКx + 1/2вМЛ < 2 := Int.floor_lt.mpr (by push_cast; linarith)
      omega
    have hmain : h (x - (m : вДЭ)) = 1 / (4 * (x - (m : вДЭ)) ^ 2) := by
      rw [hhdef]
      apply Set.indicator_of_mem
      rw [Set.mem_setOf_eq]
      calc ќі < |x - round x| := hd
        _ = |x - (m : вДЭ)| := by rw [hmdef]
    have habs2 : |x - round x| ^ 2 = (x - (m : вДЭ)) ^ 2 := by
      rw [hmdef, вЖР abs_pow, abs_of_nonneg (by positivity)]
    have hle : вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ вЙ§ h (x - (m : вДЭ)) := by
      rw [hmain]
      calc вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * x)) ^ 2вАЦ
          вЙ§ 1 / (4 * |x - round x| ^ 2) := hbound
        _ = 1 / (4 * (x - (m : вДЭ)) ^ 2) := by rw [habs2]
    have hxm : x - (m : вДЭ) = ќ± - (c + (m : вДЭ)) := by rw [hxdef]; ring
    interval_cases m
