        if a = ((n : ZMod q)) then vonMangoldt n else 0) - X / q.totient|
      вЙ§ (CвВГ + CвВЕ + 1) * (X * Real.exp (-(c * u))) := by
    have hdiv : (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
          if a = ((n : ZMod q)) then vonMangoldt n else 0) - X / q.totient
        = ((q.totient : вДЭ) * (вИС n вИИ Finset.range (вМКXвМЛвВК + 1),
