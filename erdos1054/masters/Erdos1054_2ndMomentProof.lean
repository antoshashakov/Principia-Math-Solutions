  have hextra : CвВЙ * (2*LвВА + Real.log (1/d)) вЙ§ (1/400) * (W*LвВА) := by
    have h1 : Real.log (1/d) вЙ§ 2*sW + LвВА := by linarith [hlogd, hlogW]
