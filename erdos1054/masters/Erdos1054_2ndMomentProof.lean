namespace MinSum

open Finset

/-- Any `q` consecutive naturals cast onto `ZMod q` bijectively (as a Finset image). -/
lemma image_natCast_Ico (q : вДХ) [NeZero q] (M : вДХ) :
    Finset.image (fun h : вДХ => (h : ZMod q)) (Finset.Ico M (M + q)) = Finset.univ := by
  have hq : 0 < q := Nat.pos_of_ne_zero (NeZero.ne q)
  have hinj : Set.InjOn (fun h : вДХ => (h : ZMod q)) (Finset.Ico M (M + q)) := by
    intro x hx y hy hxy
    simp only [Finset.coe_Ico, Set.mem_Ico] at hx hy
    have hmod : x вЙ° y [MOD q] := (ZMod.natCast_eq_natCast_iff x y q).mp hxy
    have hdvd : (q : вД§) вИ£ (y : вД§) - x := hmod.dvd
    have hlt : |(y : вД§) - x| < q := by
      rw [abs_lt]
      constructor <;> [skip; skip] <;> omega
    have : (y : вД§) - x = 0 := Int.eq_zero_of_abs_lt_dvd hdvd hlt
    omega
  have hcard : (Finset.image (fun h : вДХ => (h : ZMod q)) (Finset.Ico M (M + q))).card
      = Finset.univ.card (ќ± := ZMod q) := by
    rw [Finset.card_image_of_injOn hinj, Nat.card_Ico]
    simp [ZMod.card q]
  exact Finset.eq_univ_of_card _ hcard

/-- With `gcd(a,q) = 1`, the map `h вЖ¶ h¬Јa` on any `q` consecutive naturals covers `ZMod q`. -/
lemma image_mul_natCast_Ico (q : вДХ) [NeZero q] (a : вДХ) (ha : Nat.Coprime a q) (M : вДХ) :
    Finset.image (fun h : вДХ => (h : ZMod q) * a) (Finset.Ico M (M + q)) = Finset.univ := by
  have h1 : Finset.image (fun h : вДХ => (h : ZMod q) * a) (Finset.Ico M (M + q))
      = Finset.image (fun x : ZMod q => x * a)
          (Finset.image (fun h : вДХ => (h : ZMod q)) (Finset.Ico M (M + q))) := by
    rw [Finset.image_image]; rfl
  rw [h1, image_natCast_Ico q M]
  have hunit : IsUnit ((a : ZMod q)) := (ZMod.isUnit_iff_coprime a q).mpr ha
  obtain вЯ®u, huвЯ© := hunit
  apply Finset.image_univ_of_surjective
  intro x
  refine вЯ®x * вЖСuвБї¬є, ?_вЯ©
  show x * вЖСuвБї¬є * (a : ZMod q) = x
  rw [вЖР hu, mul_assoc, Units.inv_mul, mul_one]

/-- `dist(¬Ј,вД§)` is 1-Lipschitz: `вАЦxвАЦ вЙ§ |xвИТy| + вАЦyвАЦ` (round minimizes over вД§).
    This is the perturbation step: for `|ќ± вИТ a/q| вЙ§ 1/q¬≤` it transfers the `вАЦh¬Јa/qвАЦ`
    block counting to `вАЦhќ±вАЦ` at the cost of `h/q¬≤ вЙ§ 1/q` per block. -/
lemma dist_round_le (x y : вДЭ) :
    |x - round x| вЙ§ |x - y| + |y - round y| := by
  calc |x - round x| вЙ§ |x - round y| := round_le x (round y)
    _ = |(x - y) + (y - round y)| := by ring_nf
    _ вЙ§ |x - y| + |y - round y| := abs_add_le _ _

/-- A rational `m/q` with `q вИ§ m` is at distance `вЙ• 1/q` from every integer.
    (Feeds the block-spacing fact: `(hвВБвИТhвВВ)¬Јa/q` is `1/q`-separated from вД§ when
    `q вИ§ (hвВБвИТhвВВ)a`, which the coprime block bijection guarantees.) -/
lemma dist_int_div_ge (m : вД§) (q : вДХ) (hq : 0 < q) (hnd : ¬ђ (q : вД§) вИ£ m) :
    1 / (q : вДЭ) вЙ§ |(m : вДЭ) / q - round ((m : вДЭ) / q)| := by
  set r : вД§ := m - q * round ((m : вДЭ) / q) with hr
  have hrne : r вЙ† 0 := by
    intro h
    apply hnd
    refine вЯ®round ((m : вДЭ) / q), ?_вЯ©
    omega
  have h1 : (1 : вД§) вЙ§ |r| := Int.one_le_abs hrne
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  have heq : (m : вДЭ) / q - round ((m : вДЭ) / q) = (r : вДЭ) / q := by
    rw [hr]
    push_cast
    field_simp
  rw [heq, abs_div, abs_of_nonneg hqR.le]
  gcongr
  ¬Ј exact_mod_cast h1

/-- Reflection: `вИС_{k=1}^{q-1} f(q-k) = вИС_{k=1}^{q-1} f(k)`. -/
lemma sum_Icc_reflect (q : вДХ) (f : вДХ вЖТ вДЭ) :
    вИС k вИИ Finset.Icc 1 (q - 1), f (q - k) = вИС k вИИ Finset.Icc 1 (q - 1), f k := by
  apply Finset.sum_nbij' (i := fun k => q - k) (j := fun k => q - k)
  ¬Ј intro k hk; simp only [Finset.mem_Icc] at *; omega
  ¬Ј intro k hk; simp only [Finset.mem_Icc] at *; omega
  ¬Ј intro k hk; simp only [Finset.mem_Icc] at hk; omega
  ¬Ј intro k hk; simp only [Finset.mem_Icc] at hk; omega
  ¬Ј intro k hk; rfl

/-- Harmonic-sum form: `вИС_{k=1}^{n} 1/k вЙ§ 1 + log n`. -/
lemma sum_one_div_le (n : вДХ) :
    вИС k вИИ Finset.Icc 1 n, (1 : вДЭ) / k вЙ§ 1 + Real.log n := by
  have h1 : вИС k вИИ Finset.Icc 1 n, (1 : вДЭ) / k = ((harmonic n : вДЪ) : вДЭ) := by
    rw [harmonic_eq_sum_Icc]
    push_cast
    simp [one_div]
  rw [h1]
  exact harmonic_le_one_add_log n

/-- **The harmonic core of the min-sum workhorse**:
    `вИС_{k=1}^{q-1} q / min(k, q-k) вЙ§ 2q(1 + log q)`. Since `вАЦk/qвАЦ = min(k, q-k)/q`,
    this is exactly `вИС_{kвЙ†0 mod q} 1/(2вАЦk/qвАЦ) вЙ§ 4q(1+log q)`-strength вАФ the per-block
    contribution of the non-exceptional residues. -/
lemma sum_q_div_min_le (q : вДХ) (hq : 1 вЙ§ q) :
    вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / ((min k (q - k) : вДХ) : вДЭ)
      вЙ§ 2 * q * (1 + Real.log q) := by
  have hlogq : 0 вЙ§ Real.log q := by
    rcases Nat.eq_or_lt_of_le hq with h | h
    ¬Ј rw [вЖР h]; simp
    ¬Ј exact Real.log_nonneg (by exact_mod_cast h.le)
  have step1 : вИА k вИИ Finset.Icc 1 (q - 1),
      (q : вДЭ) / ((min k (q - k) : вДХ) : вДЭ) вЙ§ (q : вДЭ) / k + (q : вДЭ) / ((q - k : вДХ) : вДЭ) := by
    intro k hk
    simp only [Finset.mem_Icc] at hk
    have hk1 : (1 : вДЭ) вЙ§ (k : вДЭ) := by exact_mod_cast hk.1
    have hqk : 1 вЙ§ q - k := by omega
    have hqk1 : (1 : вДЭ) вЙ§ ((q - k : вДХ) : вДЭ) := by exact_mod_cast hqk
    have hposk : (0 : вДЭ) < (k : вДЭ) := by linarith
    have hposqk : (0 : вДЭ) < ((q - k : вДХ) : вДЭ) := by linarith
    rcases min_choice k (q - k) with h | h <;> rw [h]
    ¬Ј have h2 : (0 : вДЭ) вЙ§ (q : вДЭ) / ((q - k : вДХ) : вДЭ) := by positivity
      linarith
    ¬Ј have h2 : (0 : вДЭ) вЙ§ (q : вДЭ) / (k : вДЭ) := by positivity
      linarith
  have hrefl : вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / ((q - k : вДХ) : вДЭ)
      = вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / (k : вДЭ) :=
    sum_Icc_reflect q (fun k => (q : вДЭ) / (k : вДЭ))
  have hharm : вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / (k : вДЭ)
      вЙ§ (q : вДЭ) * (1 + Real.log q) := by
    have h1 : вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / (k : вДЭ)
        = (q : вДЭ) * вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / k := by
      rw [Finset.mul_sum]
      exact Finset.sum_congr rfl (fun k _ => by rw [div_eq_mul_inv, one_div])
    rw [h1]
    have h2 : вИС k вИИ Finset.Icc 1 (q - 1), (1 : вДЭ) / k вЙ§ 1 + Real.log (q - 1 : вДХ) :=
      sum_one_div_le (q - 1)
    have h3 : Real.log ((q - 1 : вДХ) : вДЭ) вЙ§ Real.log q := by
      rcases Nat.eq_or_lt_of_le hq with h | h
      ¬Ј rw [вЖР h]; simp
      ¬Ј apply Real.log_le_log (by exact_mod_cast Nat.sub_pos_of_lt h)
        have : q - 1 вЙ§ q := Nat.sub_le q 1
        exact_mod_cast this
    have hq0 : (0 : вДЭ) вЙ§ (q : вДЭ) := by positivity
    nlinarith [h2, h3]
  calc вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / ((min k (q - k) : вДХ) : вДЭ)
      вЙ§ вИС k вИИ Finset.Icc 1 (q - 1), ((q : вДЭ) / k + (q : вДЭ) / ((q - k : вДХ) : вДЭ)) :=
        Finset.sum_le_sum step1
    _ = вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / (k : вДЭ)
        + вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / ((q - k : вДХ) : вДЭ) := Finset.sum_add_distrib
    _ = 2 * вИС k вИИ Finset.Icc 1 (q - 1), (q : вДЭ) / (k : вДЭ) := by rw [hrefl]; ring
    _ вЙ§ 2 * ((q : вДЭ) * (1 + Real.log q)) := by linarith [hharm]
    _ = 2 * q * (1 + Real.log q) := by ring

/-- **Spacing injection** (the counting core of the min-sum workhorse / baby large sieve):
    if the points `x i` are pairwise `ќі`-spaced mod 1, then the map
    `i вЖ¶ (вМК2¬Јdist(xбµҐ,вД§)/ќівМЛ, sign of the signed distance)` is injective вАФ i.e. each
    distance-annulus `[kќі/2, (k+1)ќі/2)` holds at most one point on each side of вД§. -/
lemma spaced_floor_sign_injOn {ќє : Type*} (s : Finset ќє) (x : ќє вЖТ вДЭ) (ќі : вДЭ) (hќі : 0 < ќі)
    (hspace : вИА i вИИ s, вИА j вИИ s, i вЙ† j вЖТ ќі вЙ§ |(x i - x j) - round (x i - x j)|) :
    Set.InjOn (fun i =>
      ((вМК2 * |x i - round (x i)| / ќівМЛвВК, decide (0 вЙ§ x i - round (x i))) : вДХ √Ч Bool))
      (s : Set ќє) := by
  intro i hi j hj hij
  by_contra hne
  have hsp := hspace i hi j hj hne
  set fi : вДЭ := x i - round (x i) with hfi
  set fj : вДЭ := x j - round (x j) with hfj
  have hk : вМК2 * |fi| / ќівМЛвВК = вМК2 * |fj| / ќівМЛвВК := by
    have := congrArg Prod.fst hij; simpa using this
  have hb : (0 вЙ§ fi) вЖФ (0 вЙ§ fj) := by
    have := congrArg Prod.snd hij
    simp only [decide_eq_decide] at this
    exact this
  -- floor equality вЗТ ||fi| вИТ |fj|| < ќі/2
  have ha0 : 0 вЙ§ 2 * |fi| / ќі := by positivity
  have hb0 : 0 вЙ§ 2 * |fj| / ќі := by positivity
  have habs : |(|fi| - |fj|)| < ќі / 2 := by
    have h1 : 2 * |fi| / ќі < вМК2 * |fi| / ќівМЛвВК + 1 := Nat.lt_floor_add_one _
    have h2 : (вМК2 * |fj| / ќівМЛвВК : вДЭ) вЙ§ 2 * |fj| / ќі := Nat.floor_le hb0
    have h3 : 2 * |fj| / ќі < вМК2 * |fj| / ќівМЛвВК + 1 := Nat.lt_floor_add_one _
    have h4 : (вМК2 * |fi| / ќівМЛвВК : вДЭ) вЙ§ 2 * |fi| / ќі := Nat.floor_le ha0
    rw [hk] at h1 h4
    have hd1 : 2 * |fi| / ќі - 2 * |fj| / ќі < 1 := by linarith
    have hd2 : 2 * |fj| / ќі - 2 * |fi| / ќі < 1 := by linarith
    have hd1' : 2 * |fi| - 2 * |fj| < ќі :=
      (div_lt_one hќі).mp (by rw [sub_div]; linarith [hd1])
    have hd2' : 2 * |fj| - 2 * |fi| < ќі :=
      (div_lt_one hќі).mp (by rw [sub_div]; linarith [hd2])
    rw [abs_lt]
    constructor <;> linarith
  -- same sign вЗТ |fi вИТ fj| = ||fi| вИТ |fj|| < ќі
  have hsame : |fi - fj| < ќі := by
    by_cases hpos : 0 вЙ§ fi
    ¬Ј have hpj : 0 вЙ§ fj := hb.mp hpos
      calc |fi - fj| = |(|fi| - |fj|)| := by rw [abs_of_nonneg hpos, abs_of_nonneg hpj]
        _ < ќі / 2 := habs
        _ < ќі := by linarith
    ¬Ј have hneg : fi < 0 := not_le.mp hpos
      have hnj : fj < 0 := by
        by_contra hc
        exact absurd (hb.mpr (not_lt.mp hc)) hpos
      calc |fi - fj| = |(|fi| - |fj|)| := by
            rw [abs_of_neg hneg, abs_of_neg hnj, вЖР abs_neg]; ring_nf
        _ < ќі / 2 := habs
        _ < ќі := by linarith
  -- dist(xбµҐвИТxв±Љ, вД§) вЙ§ |fi вИТ fj| (round minimizes), contradicting the spacing
  have hmin : |(x i - x j) - round (x i - x j)| вЙ§ |fi - fj| := by
    have heq : fi - fj = (x i - x j) - ((round (x i) - round (x j) : вД§) : вДЭ) := by
      push_cast; rw [hfi, hfj]; ring
    calc |(x i - x j) - round (x i - x j)|
        вЙ§ |(x i - x j) - ((round (x i) - round (x j) : вД§) : вДЭ)| :=
          round_le (x i - x j) (round (x i) - round (x j))
      _ = |fi - fj| := by rw [heq]
  linarith

/-- **Spaced-points min-sum bound** (the workhorse's per-block estimate): pairwise
    ќі-spaced points contribute at most `2V + (2/ќі)(1 + log(1/ќі))` to the capped
    reciprocal-distance sum. Combines the spacing injection with the harmonic bound. -/
lemma spaced_min_sum_le {ќє : Type*} (s : Finset ќє) (x : ќє вЖТ вДЭ) (ќі V : вДЭ)
    (hќі : 0 < ќі) (hќі1 : ќі вЙ§ 1) (hV : 0 вЙ§ V)
    (hspace : вИА i вИИ s, вИА j вИИ s, i вЙ† j вЖТ ќі вЙ§ |(x i - x j) - round (x i - x j)|) :
    вИС i вИИ s, (if x i - round (x i) = 0 then V
              else min V (1 / (2 * |x i - round (x i)|)))
      вЙ§ 2 * V + (2 / ќі) * (1 + Real.log (1 / ќі)) := by
  classical
  set K : вДХ := вМК1 / ќівМЛвВК with hK
  set ѕЖ : ќє вЖТ вДХ √Ч Bool := fun i =>
    (вМК2 * |x i - round (x i)| / ќівМЛвВК, decide (0 вЙ§ x i - round (x i))) with hѕЖ
  set W : вДХ √Ч Bool вЖТ вДЭ := fun p => if p.1 = 0 then V else 1 / (p.1 * ќі) with hW
  have hW0 : вИА p, 0 вЙ§ W p := by
    intro p
    rw [hW]
    dsimp only
    split
    ¬Ј exact hV
    ¬Ј rename_i h
      have hp : (0 : вДЭ) < p.1 := by exact_mod_cast Nat.pos_of_ne_zero h
      positivity
  -- termwise: each term is at most W (ѕЖ i)
  have hterm : вИА i вИИ s, (if x i - round (x i) = 0 then V
      else min V (1 / (2 * |x i - round (x i)|))) вЙ§ W (ѕЖ i) := by
    intro i _
    by_cases hf0 : x i - round (x i) = 0
    ¬Ј rw [if_pos hf0, hW, hѕЖ]
      dsimp only
      rw [hf0]
      simp
    ¬Ј rw [if_neg hf0]
      by_cases hk : вМК2 * |x i - round (x i)| / ќівМЛвВК = 0
      ¬Ј have : W (ѕЖ i) = V := by rw [hW, hѕЖ]; dsimp only; rw [if_pos hk]
        rw [this]
        exact min_le_left _ _
      ¬Ј have habs : 0 < |x i - round (x i)| := abs_pos.mpr hf0
        have hkle : (вМК2 * |x i - round (x i)| / ќівМЛвВК : вДЭ)
            вЙ§ 2 * |x i - round (x i)| / ќі := Nat.floor_le (by positivity)
        have h1 : (вМК2 * |x i - round (x i)| / ќівМЛвВК : вДЭ) * ќі вЙ§ 2 * |x i - round (x i)| := by
          have := mul_le_mul_of_nonneg_right hkle hќі.le
          rwa [div_mul_cancelвВА _ (ne_of_gt hќі)] at this
        have hkpos : (0 : вДЭ) < (вМК2 * |x i - round (x i)| / ќівМЛвВК : вДЭ) := by
          exact_mod_cast Nat.pos_of_ne_zero hk
        have h2 : 1 / (2 * |x i - round (x i)|)
            вЙ§ 1 / ((вМК2 * |x i - round (x i)| / ќівМЛвВК : вДЭ) * ќі) :=
          one_div_le_one_div_of_le (by positivity) h1
        have h3 : W (ѕЖ i) = 1 / ((вМК2 * |x i - round (x i)| / ќівМЛвВК : вДЭ) * ќі) := by
          rw [hW, hѕЖ]; dsimp only; rw [if_neg hk]
        rw [h3]
        exact le_trans (min_le_right _ _) h2
  -- image is inside range (K+1) √ЧЋҐ Bool
  have himg : s.image ѕЖ вКЖ (Finset.range (K + 1)) √ЧЋҐ (Finset.univ : Finset Bool) := by
    intro p hp
    simp only [Finset.mem_image] at hp
    obtain вЯ®i, _, rflвЯ© := hp
    rw [Finset.mem_product]
    refine вЯ®?_, Finset.mem_univ _вЯ©
    rw [Finset.mem_range, Nat.lt_succ_iff, hK]
    apply Nat.floor_mono
    have hhalf : |x i - round (x i)| вЙ§ 1 / 2 := abs_sub_round (x i)
    have : 2 * |x i - round (x i)| вЙ§ 1 := by linarith
    exact div_le_div_of_nonneg_right this hќі.le
  -- assemble
  calc вИС i вИИ s, (if x i - round (x i) = 0 then V
        else min V (1 / (2 * |x i - round (x i)|)))
      вЙ§ вИС i вИИ s, W (ѕЖ i) := Finset.sum_le_sum hterm
    _ = вИС p вИИ s.image ѕЖ, W p := by
        rw [Finset.sum_image]
        intro a ha b hb hab
        exact spaced_floor_sign_injOn s x ќі hќі hspace ha hb hab
    _ вЙ§ вИС p вИИ (Finset.range (K + 1)) √ЧЋҐ (Finset.univ : Finset Bool), W p :=
        Finset.sum_le_sum_of_subset_of_nonneg himg (fun p _ _ => hW0 p)
    _ = вИС k вИИ Finset.range (K + 1), вИС b : Bool, W (k, b) := by rw [Finset.sum_product]
    _ = вИС k вИИ Finset.range (K + 1), 2 * (if k = 0 then V else 1 / (k * ќі)) := by
        apply Finset.sum_congr rfl
        intro k _
        rw [Fintype.sum_bool, hW]
        dsimp only
        ring
    _ = 2 * V + 2 * вИС k вИИ Finset.Icc 1 K, 1 / ((k : вДЭ) * ќі) := by
        have hsplit : Finset.range (K + 1) = insert 0 (Finset.Icc 1 K) := by
          ext k
          simp only [Finset.mem_range, Finset.mem_insert, Finset.mem_Icc]
          omega
        rw [hsplit, Finset.sum_insert (by simp)]
        rw [if_pos rfl]
        congr 1
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro k hk
        simp only [Finset.mem_Icc] at hk
        rw [if_neg (by omega)]
    _ вЙ§ 2 * V + (2 / ќі) * (1 + Real.log (1 / ќі)) := by
        have hќіinv : (0 : вДЭ) < 1 / ќі := by positivity
        have hKle : (K : вДЭ) вЙ§ 1 / ќі := by
          rw [hK]; exact Nat.floor_le hќіinv.le
        have hK1 : 1 вЙ§ K := by
          rw [hK]
          apply Nat.le_floor
          rw [Nat.cast_one]
          rw [le_div_iffвВА hќі]
          linarith
        have h1 : вИС k вИИ Finset.Icc 1 K, 1 / ((k : вДЭ) * ќі)
            = (1 / ќі) * вИС k вИИ Finset.Icc 1 K, (1 : вДЭ) / k := by
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro k hk
          simp only [Finset.mem_Icc] at hk
          have : (0 : вДЭ) < (k : вДЭ) := by exact_mod_cast hk.1
          field_simp
        have h2 := sum_one_div_le K
        have h3 : Real.log K вЙ§ Real.log (1 / ќі) := by
          apply Real.log_le_log (by exact_mod_cast hK1) hKle
        have hlog0 : 0 вЙ§ Real.log (1 / ќі) := by
          apply Real.log_nonneg
          rw [le_div_iffвВА hќі]
          linarith
        rw [h1]
        have h4 : вИС k вИИ Finset.Icc 1 K, (1 : вДЭ) / k вЙ§ 1 + Real.log (1 / ќі) := by linarith
        have h5 : (1 / ќі) * вИС k вИИ Finset.Icc 1 K, (1 : вДЭ) / k
            вЙ§ (1 / ќі) * (1 + Real.log (1 / ќі)) := by
          apply mul_le_mul_of_nonneg_left h4 hќіinv.le
        have h6 : (2 : вДЭ) / ќі = 2 * (1 / ќі) := by ring
        rw [h6]
        linarith

/-- **Block spacing**: for `gcd(a,q)=1` and `|ќ± вИТ a/q| вЙ§ 1/q¬≤`, the points `hќ±` for `h`
    in a run of `L вЙ§ q/2` consecutive integers are pairwise `1/(2q)`-spaced mod 1.
    (So each such block feeds `spaced_min_sum_le` with `ќі = 1/(2q)`.) -/
lemma block_spaced (a q : вДХ) (hq : 0 < q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (M L : вДХ) (hL : 2 * L вЙ§ q) :
    вИА i вИИ Finset.Ico M (M + L), вИА j вИИ Finset.Ico M (M + L), i вЙ† j вЖТ
      1 / (2 * (q : вДЭ)) вЙ§
        |((i : вДЭ) * ќ± - (j : вДЭ) * ќ±) - round ((i : вДЭ) * ќ± - (j : вДЭ) * ќ±)| := by
  intro i hi j hj hij
  simp only [Finset.mem_Ico] at hi hj
  set d : вД§ := (i : вД§) - j with hd
  have hdne : d вЙ† 0 := by rw [hd]; omega
  have hdabs : |d| вЙ§ (L : вД§) := abs_le.mpr вЯ®by omega, by omegaвЯ©
  -- q вИ§ d¬Јa (coprimality + |d| < q)
  have hnd : ¬ђ (q : вД§) вИ£ d * a := by
    intro hdvd
    have hu : IsUnit ((a : ZMod q)) := (ZMod.isUnit_iff_coprime a q).mpr ha
    have h0 : ((d * (a : вД§) : вД§) : ZMod q) = 0 :=
      (ZMod.intCast_zmod_eq_zero_iff_dvd _ q).mpr hdvd
    push_cast at h0
    have hd0 : ((d : вД§) : ZMod q) = 0 := (hu.mul_left_eq_zero).mp h0
    have hqd : (q : вД§) вИ£ d := (ZMod.intCast_zmod_eq_zero_iff_dvd _ q).mp hd0
    have hqle : (q : вД§) вЙ§ |d| := Int.le_of_dvd (abs_pos.mpr hdne) ((dvd_abs _ _).mpr hqd)
    have : (q : вД§) вЙ§ (L : вД§) := le_trans hqle hdabs
    omega
  -- the rational point d¬Јa/q is 1/q-separated from вД§
  have hsep : 1 / (q : вДЭ) вЙ§ |((d * a : вД§) : вДЭ) / q - round (((d * a : вД§) : вДЭ) / q)| :=
    dist_int_div_ge (d * a) q hq hnd
  -- the perturbation |(iќ±вИТjќ±) вИТ d¬Јa/q| = |d|¬Ј|ќ±вИТa/q| вЙ§ L/q¬≤ вЙ§ 1/(2q)
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast hq
  have hpert : |((i : вДЭ) * ќ± - (j : вДЭ) * ќ±) - ((d * a : вД§) : вДЭ) / q| вЙ§ 1 / (2 * (q : вДЭ)) := by
    have h1 : (i : вДЭ) * ќ± - (j : вДЭ) * ќ± = (d : вДЭ) * ќ± := by
      rw [hd]; push_cast; ring
    have h2 : ((d * a : вД§) : вДЭ) / q = (d : вДЭ) * ((a : вДЭ) / q) := by
      push_cast; ring
    rw [h1, h2, вЖР mul_sub, abs_mul]
    have h3 : |(d : вДЭ)| вЙ§ (L : вДЭ) := by
      rw [вЖР Int.cast_abs]
      exact_mod_cast hdabs
    have hL' : (2 : вДЭ) * L вЙ§ q := by exact_mod_cast hL
    calc |(d : вДЭ)| * |ќ± - (a : вДЭ) / q| вЙ§ (L : вДЭ) * (1 / (q : вДЭ) ^ 2) := by
          apply mul_le_mul h3 hќ± (abs_nonneg _) (by positivity)
      _ вЙ§ 1 / (2 * (q : вДЭ)) := by
          rw [mul_one_div, div_le_div_iffвВА (by positivity) (by positivity)]
          nlinarith
  -- combine: dist(iќ±вИТjќ±) вЙ• dist(d¬Јa/q) вИТ perturbation вЙ• 1/q вИТ 1/(2q) = 1/(2q)
  have hcomb := dist_round_le (((d * a : вД§) : вДЭ) / q) ((i : вДЭ) * ќ± - (j : вДЭ) * ќ±)
  rw [abs_sub_comm (((d * a : вД§) : вДЭ) / q) ((i : вДЭ) * ќ± - (j : вДЭ) * ќ±)] at hcomb
  have hq2R : 1 / (q : вДЭ) - 1 / (2 * (q : вДЭ)) = 1 / (2 * (q : вДЭ)) := by
    field_simp
    ring
  linarith [hsep, hpert, hcomb, hq2R]

/-- **The min-sum workhorse, uniform-cap form**: for `gcd(a,q) = 1`, `|ќ± вИТ a/q| вЙ§ 1/q¬≤`,
    `q вЙ• 2`, and ANY `R` consecutive integers with a uniform cap `V`,

      `вИС_h min(V, 1/(2вАЦhќ±вАЦ)) вЙ§ (R/(q/2) + 1) ¬Ј (2V + 4q(1 + log 2q))`.

    (Terms with `hќ± вИИ вД§` get the `V` cap.) This is the block-summed engine of the
    Type-I/II minor-arc estimates; the classical `N/h`-cap form (Vaughan Lemma 2.2)
    follows by applying this on dyadic `h`-ranges with `V = N/2бµЧ`. -/
lemma range_min_sum_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (V : вДЭ) (hV : 0 вЙ§ V) (M R : вДХ) :
    вИС h вИИ Finset.Ico M (M + R),
      (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then V
       else min V (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)))
      вЙ§ ((R / (q / 2) + 1 : вДХ) : вДЭ) * (2 * V + 4 * q * (1 + Real.log (2 * q))) := by
  set L : вДХ := q / 2 with hLdef
  have hL0 : 0 < L := Nat.div_pos hq (by norm_num)
  have h2L : 2 * L вЙ§ q := by
    have := Nat.div_mul_le_self q 2
    omega
  set T : вДХ := R / L + 1 with hT
  set w : вДХ вЖТ вДЭ := fun h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then V
     else min V (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hw
  have hw0 : вИА h, 0 вЙ§ w h := by
    intro h
    rw [hw]
    dsimp only
    split
    ¬Ј exact hV
    ¬Ј exact le_min hV (by positivity)
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  -- covering by T blocks of length L
  have hcover : Finset.Ico M (M + R) вКЖ
      (Finset.range T).biUnion (fun t => Finset.Ico (M + t * L) (M + t * L + L)) := by
    intro h hh
    simp only [Finset.mem_Ico] at hh
    obtain вЯ®n, rflвЯ© := Nat.exists_eq_add_of_le hh.1
    have hnR : n < R := by omega
    rw [Finset.mem_biUnion]
    refine вЯ®n / L, ?_, ?_вЯ©
    ¬Ј rw [Finset.mem_range, hT]
      exact Nat.lt_succ_of_le (Nat.div_le_div_right hnR.le)
    ¬Ј obtain вЯ®P, hPвЯ© : вИГ P, P = n / L * L := вЯ®_, rflвЯ©
      obtain вЯ®m, hmвЯ© : вИГ m, m = n % L := вЯ®_, rflвЯ©
      have h1 : P вЙ§ n := hP вЦЄ Nat.div_mul_le_self n L
      have hdm : P + m = n := by rw [hP, hm]; exact Nat.div_add_mod' n L
      have hmod : m < L := hm вЦЄ Nat.mod_lt n hL0
      rw [Finset.mem_Ico, вЖР hP]
      omega
  -- blocks are pairwise disjoint
  have hdisj : (вЖС(Finset.range T) : Set вДХ).PairwiseDisjoint
      (fun t => Finset.Ico (M + t * L) (M + t * L + L)) := by
    intro tвВБ _ tвВВ _ hne
    apply Finset.disjoint_left.mpr
    intro h h1 h2
    simp only [Finset.mem_Ico] at h1 h2
    obtain вЯ®PвВБ, hPвВБвЯ© : вИГ P, P = tвВБ * L := вЯ®_, rflвЯ©
    obtain вЯ®PвВВ, hPвВВвЯ© : вИГ P, P = tвВВ * L := вЯ®_, rflвЯ©
    rw [вЖР hPвВБ] at h1
    rw [вЖР hPвВВ] at h2
    rcases Nat.lt_or_ge tвВБ tвВВ with hlt | hge
    ¬Ј have h5 : PвВБ + L вЙ§ PвВВ := by
        rw [hPвВБ, hPвВВ, вЖР Nat.succ_mul]
        exact Nat.mul_le_mul_right L (Nat.succ_le_of_lt hlt)
      omega
    ¬Ј have hlt2 : tвВВ < tвВБ := lt_of_le_of_ne hge (Ne.symm hne)
      have h5 : PвВВ + L вЙ§ PвВБ := by
        rw [hPвВБ, hPвВВ, вЖР Nat.succ_mul]
        exact Nat.mul_le_mul_right L (Nat.succ_le_of_lt hlt2)
      omega
  -- per-block bound via spaced_min_sum_le with ќі = 1/(2q)
  have hblock : вИА t : вДХ, вИС h вИИ Finset.Ico (M + t * L) (M + t * L + L), w h
      вЙ§ 2 * V + 4 * (q : вДЭ) * (1 + Real.log (2 * q)) := by
    intro t
    have hќіpos : (0 : вДЭ) < 1 / (2 * (q : вДЭ)) := by positivity
    have hќі1 : 1 / (2 * (q : вДЭ)) вЙ§ 1 := by
      rw [div_le_one (by positivity)]
      have hq2 : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
      linarith
    have hsp := block_spaced a q (by omega) ha ќ± hќ± (M + t * L) L h2L
    have happ := spaced_min_sum_le (Finset.Ico (M + t * L) (M + t * L + L))
      (fun h : вДХ => (h : вДЭ) * ќ±) (1 / (2 * (q : вДЭ))) V hќіpos hќі1 hV hsp
    have e1 : (2 : вДЭ) / (1 / (2 * (q : вДЭ))) = 4 * q := by
      field_simp
      ring
    have e2 : (1 : вДЭ) / (1 / (2 * (q : вДЭ))) = 2 * q := by
      field_simp
    rw [e1, e2] at happ
    exact happ
  -- assemble
  calc вИС h вИИ Finset.Ico M (M + R), w h
      вЙ§ вИС h вИИ (Finset.range T).biUnion
          (fun t => Finset.Ico (M + t * L) (M + t * L + L)), w h :=
        Finset.sum_le_sum_of_subset_of_nonneg hcover (fun h _ _ => hw0 h)
    _ = вИС t вИИ Finset.range T, вИС h вИИ Finset.Ico (M + t * L) (M + t * L + L), w h :=
        Finset.sum_biUnion hdisj
    _ вЙ§ вИС _t вИИ Finset.range T, (2 * V + 4 * (q : вДЭ) * (1 + Real.log (2 * q))) :=
        Finset.sum_le_sum (fun t _ => hblock t)
    _ = (T : вДЭ) * (2 * V + 4 * (q : вДЭ) * (1 + Real.log (2 * q))) := by
        rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul]
    _ = ((R / (q / 2) + 1 : вДХ) : вДЭ) * (2 * V + 4 * q * (1 + Real.log (2 * q))) := by
        rw [hT, hLdef]

/-! ### The exponential-sum chain (self-contained copy of the `MinorArcExpSum.lean` core,
    re-verified here so this file stays standalone for the warm-REPL daemon) -/












/-! ### Type I: the workhorse applied to the inner geometric sums -/


/-- Interval form: `вАЦвИС_{dвИИ[A,B)} e(dќ≤)вАЦ` obeys the same capped bound with `M = BвИТA`
    (shift out the unit-modulus prefactor `e(Aќ≤)`). Type II's inner `d`-sums need this. -/
lemma exp_sum_Ico_min_bound (ќ≤ : вДЭ) (A B : вДХ) :
    вАЦвИС d вИИ Finset.Ico A B, e (d * ќ≤)вАЦ
      вЙ§ (if ќ≤ - round ќ≤ = 0 then ((B - A : вДХ) : вДЭ)
         else min ((B - A : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
  have hshift : вИС d вИИ Finset.Ico A B, e (d * ќ≤)
      = e (A * ќ≤) * вИС k вИИ Finset.range (B - A), e (k * ќ≤) := by
    rw [Finset.sum_Ico_eq_sum_range, Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro k _
    rw [e_add]
    congr 1
    push_cast
    ring
  rw [hshift, norm_mul, e_norm, one_mul]
  exact exp_sum_min_bound ќ≤ (B - A)

/-- **The Type I estimate**: the `d`-sum of inner geometric sums over `[1, D]` is
    controlled by the workhorse вАФ for `gcd(a,q)=1`, `|ќ± вИТ a/q| вЙ§ 1/q¬≤`, `q вЙ• 2`:

      `вИС_{d=1}^{D} вАЦвИС_{n<M} e(ndќ±)вАЦ вЙ§ (D/(q/2) + 1)¬Ј(2M + 4q(1 + log 2q))`. -/
lemma typeI_sum_bound (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (D M : вДХ) :
    вИС d вИИ Finset.Ico 1 (1 + D), вАЦвИС n вИИ Finset.range M, e (n * ((d : вДЭ) * ќ±))вАЦ
      вЙ§ ((D / (q / 2) + 1 : вДХ) : вДЭ) * (2 * M + 4 * q * (1 + Real.log (2 * q))) := by
  have hterm : вИА d вИИ Finset.Ico 1 (1 + D),
      вАЦвИС n вИИ Finset.range M, e (n * ((d : вДЭ) * ќ±))вАЦ
      вЙ§ (if (d : вДЭ) * ќ± - round ((d : вДЭ) * ќ±) = 0 then ((M : вДХ) : вДЭ)
         else min ((M : вДХ) : вДЭ) (1 / (2 * |(d : вДЭ) * ќ± - round ((d : вДЭ) * ќ±)|))) :=
    fun d _ => exp_sum_min_bound ((d : вДЭ) * ќ±) M
  calc вИС d вИИ Finset.Ico 1 (1 + D), вАЦвИС n вИИ Finset.range M, e (n * ((d : вДЭ) * ќ±))вАЦ
      вЙ§ вИС d вИИ Finset.Ico 1 (1 + D),
        (if (d : вДЭ) * ќ± - round ((d : вДЭ) * ќ±) = 0 then ((M : вДХ) : вДЭ)
         else min ((M : вДХ) : вДЭ) (1 / (2 * |(d : вДЭ) * ќ± - round ((d : вДЭ) * ќ±)|))) :=
        Finset.sum_le_sum hterm
    _ вЙ§ ((D / (q / 2) + 1 : вДХ) : вДЭ) * (2 * (M : вДЭ) + 4 * q * (1 + Real.log (2 * q))) :=
        range_min_sum_le a q hq ha ќ± hќ± (M : вДЭ) (by positivity) 1 D

/-- dist(¬Ј,вД§) is even: `|(-ќ≤) вИТ round(-ќ≤)| = |ќ≤ вИТ round ќ≤|` (round minimizes both ways). -/
lemma dist_round_neg (ќ≤ : вДЭ) : |(-ќ≤) - round (-ќ≤)| = |ќ≤ - round ќ≤| := by
  apply le_antisymm
  ¬Ј calc |(-ќ≤) - round (-ќ≤)| вЙ§ |(-ќ≤) - ((-(round ќ≤) : вД§) : вДЭ)| := round_le (-ќ≤) (-(round ќ≤))
      _ = |ќ≤ - round ќ≤| := by push_cast; rw [вЖР abs_neg]; ring_nf
  ¬Ј calc |ќ≤ - round ќ≤| вЙ§ |ќ≤ - ((-(round (-ќ≤)) : вД§) : вДЭ)| := round_le ќ≤ (-(round (-ќ≤)))
      _ = |(-ќ≤) - round (-ќ≤)| := by push_cast; rw [вЖР abs_neg]; ring_nf

/-- **Difference-count bound**: each difference `h = mвВБ вИТ mвВВ` occurs for at most `M`
    pairs, so a nonneg function of the difference sums to at most `M` times its
    `h`-sum over `(-M, M)`. -/
lemma diff_count_le (F : вД§ вЖТ вДЭ) (hF : вИА h, 0 вЙ§ F h) (M : вДХ) :
    вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M, F ((mвВБ : вД§) - mвВВ)
      вЙ§ (M : вДЭ) * вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), F h := by
  classical
  have h1 : вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M, F ((mвВБ : вД§) - mвВВ)
      = вИС p вИИ Finset.range M √ЧЋҐ Finset.range M, F ((p.1 : вД§) - p.2) := by
    rw [Finset.sum_product]
  rw [h1]
  calc вИС p вИИ Finset.range M √ЧЋҐ Finset.range M, F ((p.1 : вД§) - p.2)
      = вИС h вИИ (Finset.range M √ЧЋҐ Finset.range M).image (fun p : вДХ √Ч вДХ => (p.1 : вД§) - p.2),
          ((Finset.range M √ЧЋҐ Finset.range M).filter
            (fun p : вДХ √Ч вДХ => (p.1 : вД§) - p.2 = h)).card вАҐ F h :=
        Finset.sum_comp _ _
    _ вЙ§ вИС h вИИ (Finset.range M √ЧЋҐ Finset.range M).image (fun p : вДХ √Ч вДХ => (p.1 : вД§) - p.2),
          (M : вДЭ) * F h := by
        apply Finset.sum_le_sum
        intro h _
        rw [nsmul_eq_mul]
        apply mul_le_mul_of_nonneg_right _ (hF h)
        have hcard : ((Finset.range M √ЧЋҐ Finset.range M).filter
            (fun p : вДХ √Ч вДХ => (p.1 : вД§) - p.2 = h)).card вЙ§ (Finset.range M).card := by
          apply Finset.card_le_card_of_injOn (fun p => p.1)
          ¬Ј intro p hp
            simp only [Finset.mem_coe, Finset.mem_filter, Finset.mem_product] at hp
            exact hp.1.1
          ¬Ј intro p hp p' hp' hpp
            rw [Finset.mem_coe, Finset.mem_filter] at hp hp'
            have hpp' : p.1 = p'.1 := hpp
            have e1 := hp.2
            have e2 := hp'.2
            have h2 : (p.2 : вД§) = (p'.2 : вД§) := by omega
            exact Prod.ext hpp' (by exact_mod_cast h2)
        rw [Finset.card_range] at hcard
        exact_mod_cast hcard
    _ вЙ§ вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), (M : вДЭ) * F h := by
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro h hh
          simp only [Finset.mem_image, Finset.mem_product, Finset.mem_range] at hh
          obtain вЯ®p, вЯ®hp1, hp2вЯ©, rflвЯ© := hh
          rw [Finset.mem_Icc]
          omega
        ¬Ј intro h _ _
          exact mul_nonneg (by positivity) (hF h)
    _ = (M : вДЭ) * вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), F h :=
        (Finset.mul_sum _ _ _).symm

/-- **Discrete second moment** (Type II opening move): the `d`-averaged square of a
    linear exponential sum is bounded by the bilinear difference sums. -/
lemma typeII_second_moment_le (b : вДХ вЖТ вДВ) (M : вДХ) (ќ± : вДЭ) (s : Finset вДХ) :
    вИС d вИИ s, вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
          вАЦb mвВБвАЦ * вАЦb mвВВвАЦ * вАЦвИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := by
  -- complex identity: вИС_d S_d¬Јconj(S_d) = вИС_{mвВБ,mвВВ} b mвВБ conj(b mвВВ) вИС_d e(d(mвВБвИТmвВВ)ќ±)
  have hid : вИС d вИИ s, ((вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
        (starRingEnd вДВ) (вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)))
      = вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
          (b mвВБ * (starRingEnd вДВ) (b mвВВ)) *
            вИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
    have hpt : вИА d вИИ s,
        (вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
          (starRingEnd вДВ) (вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±))
        = вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
            (b mвВБ * (starRingEnd вДВ) (b mвВВ)) * e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
      intro d _
      rw [map_sum, Finset.sum_mul_sum]
      apply Finset.sum_congr rfl; intro mвВБ _
      apply Finset.sum_congr rfl; intro mвВВ _
      rw [map_mul, e_conj]
      have h1 : e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±))
          = e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
        rw [e_add]; congr 1; ring
      calc b mвВБ * e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±)
            * ((starRingEnd вДВ) (b mвВВ) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±)))
          = (b mвВБ * (starRingEnd вДВ) (b mвВВ))
            * (e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±))) := by ring
        _ = (b mвВБ * (starRingEnd вДВ) (b mвВВ)) * e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
            rw [h1]
    rw [Finset.sum_congr rfl hpt]
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro mвВБ _
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro mвВВ _
    rw [Finset.mul_sum]
  -- take real parts and bound
  have hre : вИС d вИИ s, вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      = (вИС d вИИ s, ((вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
          (starRingEnd вДВ) (вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)))).re := by
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro d _
    rw [Complex.mul_conj, Complex.normSq_eq_norm_sq]
    exact (Complex.ofReal_re _).symm
  rw [hre, hid]
  calc (вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
        (b mвВБ * (starRingEnd вДВ) (b mвВВ)) * вИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))).re
      вЙ§ вАЦвИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
        (b mвВБ * (starRingEnd вДВ) (b mвВВ)) * вИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        Complex.re_le_norm _
    _ вЙ§ вИС mвВБ вИИ Finset.range M, вАЦвИС mвВВ вИИ Finset.range M,
        (b mвВБ * (starRingEnd вДВ) (b mвВВ)) * вИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
        вАЦ(b mвВБ * (starRingEnd вДВ) (b mвВВ)) * вИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        Finset.sum_le_sum (fun mвВБ _ => norm_sum_le _ _)
    _ = вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
        вАЦb mвВБвАЦ * вАЦb mвВВвАЦ * вАЦвИС d вИИ s, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := by
        apply Finset.sum_congr rfl; intro mвВБ _
        apply Finset.sum_congr rfl; intro mвВВ _
        rw [norm_mul, norm_mul, RCLike.norm_conj]

/-- **The Type II h-sum estimate**: the symmetric difference-sum of interval exponential
    sums is one diagonal term plus twice the workhorse. -/
lemma typeII_h_sum_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (A B M : вДХ) :
    вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1),
        вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ
      вЙ§ ((B - A : вДХ) : вДЭ)
        + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))) := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  have hlog0 : (0 : вДЭ) вЙ§ Real.log (2 * q) := by
    apply Real.log_nonneg
    have : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
    linarith
  set V : вДЭ := ((B - A : вДХ) : вДЭ) with hV
  have hV0 : 0 вЙ§ V := by rw [hV]; positivity
  set w : вД§ вЖТ вДЭ := fun h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then V
     else min V (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hw
  have hw0 : вИА h, 0 вЙ§ w h := by
    intro h
    rw [hw]
    dsimp only
    split
    ¬Ј exact hV0
    ¬Ј exact le_min hV0 (by positivity)
  have hG : вИА h : вД§, вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ вЙ§ w h := by
    intro h
    rw [hw]
    exact exp_sum_Ico_min_bound ((h : вДЭ) * ќ±) A B
  have hweven : вИА h : вД§, w (-h) = w h := by
    intro h
    rw [hw]
    dsimp only
    have hcast : ((-h : вД§) : вДЭ) * ќ± = -((h : вДЭ) * ќ±) := by push_cast; ring
    rw [hcast]
    have hd := dist_round_neg ((h : вДЭ) * ќ±)
    by_cases h0 : (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0
    ¬Ј have h0' : -((h : вДЭ) * ќ±) - round (-((h : вДЭ) * ќ±)) = 0 := by
        have := hd
        rw [abs_eq_zero.mpr h0] at this
        exact abs_eq_zero.mp this
      rw [if_pos h0, if_pos h0']
    ¬Ј have h0' : ¬ђ (-((h : вДЭ) * ќ±) - round (-((h : вДЭ) * ќ±)) = 0) := by
        intro hc
        apply h0
        have := hd
        rw [abs_eq_zero.mpr hc] at this
        exact abs_eq_zero.mp this.symm
      rw [if_neg h0, if_neg h0', hd]
  have hstep1 : вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1),
        вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ
      вЙ§ вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), w h :=
    Finset.sum_le_sum (fun h _ => hG h)
  rcases Nat.eq_zero_or_pos M with hM0 | hM1
  ¬Ј subst hM0
    simp only [Nat.cast_zero, neg_zero, zero_add, zero_sub] at hstep1 вКҐ
    rw [show Finset.Icc (1 : вД§) (-1) = вИЕ from Finset.Icc_eq_empty (by omega)] at hstep1 вКҐ
    simp only [Finset.sum_empty] at hstep1 вКҐ
    positivity
  have hK : (0 : вД§) вЙ§ (M : вД§) - 1 := by omega
  have hsplit : Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1)
      = (Finset.Icc (-(M : вД§) + 1) (-1)) вИ™ insert 0 (Finset.Icc 1 ((M : вД§) - 1)) := by
    ext h
    simp only [Finset.mem_Icc, Finset.mem_union, Finset.mem_insert]
    omega
  have hdisj : Disjoint (Finset.Icc (-(M : вД§) + 1) (-1))
      (insert 0 (Finset.Icc 1 ((M : вД§) - 1))) := by
    rw [Finset.disjoint_left]
    intro h h1 h2
    simp only [Finset.mem_Icc] at h1
    simp only [Finset.mem_insert, Finset.mem_Icc] at h2
    omega
  have h0notin : (0 : вД§) вИЙ Finset.Icc 1 ((M : вД§) - 1) := by
    simp only [Finset.mem_Icc]
    omega
  have hrefl : вИС h вИИ Finset.Icc (-(M : вД§) + 1) (-1), w h
      = вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h := by
    apply Finset.sum_nbij' (i := fun h => -h) (j := fun h => -h)
    ¬Ј intro h hh; simp only [Finset.mem_Icc] at *; omega
    ¬Ј intro h hh; simp only [Finset.mem_Icc] at *; omega
    ¬Ј intro h _; ring
    ¬Ј intro h _; ring
    ¬Ј intro h _
      rw [вЖР hweven h]
  have hw0val : w 0 = V := by
    rw [hw]
    dsimp only
    rw [if_pos (by simp)]
  have hpos : вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h
      вЙ§ ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * V + 4 * q * (1 + Real.log (2 * q))) := by
    have hreidx : вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h
        = вИС n вИИ Finset.Ico 1 (1 + (M - 1)),
            (if (n : вДЭ) * ќ± - round ((n : вДЭ) * ќ±) = 0 then V
             else min V (1 / (2 * |(n : вДЭ) * ќ± - round ((n : вДЭ) * ќ±)|))) := by
      apply Finset.sum_nbij' (i := fun h : вД§ => h.toNat) (j := fun n : вДХ => (n : вД§))
      ¬Ј intro h hh; simp only [Finset.mem_Icc] at hh; simp only [Finset.mem_Ico]; omega
      ¬Ј intro n hn; simp only [Finset.mem_Ico] at hn; simp only [Finset.mem_Icc]; omega
      ¬Ј intro h hh; simp only [Finset.mem_Icc] at hh; omega
      ¬Ј intro n hn; simp only [Finset.mem_Ico] at hn; omega
      ¬Ј intro h hh
        simp only [Finset.mem_Icc] at hh
        rw [hw]
        dsimp only
        have hcast : ((h.toNat : вДХ) : вДЭ) = (h : вДЭ) := by
          have := Int.toNat_of_nonneg (by omega : (0 : вД§) вЙ§ h)
          exact_mod_cast congrArg (fun z : вД§ => (z : вДЭ)) this
        rw [hcast]
    rw [hreidx]
    exact range_min_sum_le a q hq ha ќ± hќ± V hV0 1 (M - 1)
  calc вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1),
        вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ
      вЙ§ вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), w h := hstep1
    _ = вИС h вИИ Finset.Icc (-(M : вД§) + 1) (-1), w h
        + (w 0 + вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h) := by
        rw [hsplit, Finset.sum_union hdisj, Finset.sum_insert h0notin]
    _ = V + 2 * вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h := by
        rw [hrefl, hw0val]; ring
    _ вЙ§ V + 2 * (((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * V + 4 * q * (1 + Real.log (2 * q)))) := by
        have := hpos
        linarith
    _ = ((B - A : вДХ) : вДЭ)
        + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))) := by
        rw [hV]; ring

/-- **Abel-summation exponential-sum bound**: a monotone nonneg weight `w вЙ§ W` costs only
    a factor `2W` over the unweighted capped bound. (Feeds the log-weighted Type I sums
    in the Vaughan combine.) -/
lemma abel_exp_sum (w : вДХ вЖТ вДЭ) (hw0 : вИА m, 0 вЙ§ w m) (hwmono : Monotone w)
    (W : вДЭ) (hW : вИА m, w m вЙ§ W) (ќ≤ : вДЭ) (M : вДХ) :
    вАЦвИС m вИИ Finset.range M, (w m : вДВ) * e (m * ќ≤)вАЦ
      вЙ§ 2 * W * (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
                 else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
  have hW0 : 0 вЙ§ W := le_trans (hw0 0) (hW 0)
  set cap : вДЭ := (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
                  else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) with hcap
  have hcap0 : 0 вЙ§ cap := by
    rw [hcap]
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  have hZ : вИА k, k вЙ§ M вЖТ вАЦвИС j вИИ Finset.range k, e (j * ќ≤)вАЦ вЙ§ cap := by
    intro k hk
    have h1 := exp_sum_min_bound ќ≤ k
    rw [hcap]
    have hkM : ((k : вДХ) : вДЭ) вЙ§ (M : вДЭ) := by exact_mod_cast hk
    split
    ¬Ј rename_i h0
      rw [if_pos h0] at h1
      linarith
    ¬Ј rename_i h0
      rw [if_neg h0] at h1
      exact le_trans h1 (min_le_min hkM le_rfl)
  rcases Nat.eq_zero_or_pos M with hM0 | hM1
  ¬Ј subst hM0
    simp only [Finset.range_zero, Finset.sum_empty, norm_zero]
    positivity
  have habel : вИС m вИИ Finset.range M, (w m : вДВ) * e (m * ќ≤)
      = (w (M - 1) : вДВ) * вИС j вИИ Finset.range M, e (j * ќ≤)
        - вИС i вИИ Finset.range (M - 1),
            ((w (i + 1) : вДВ) - w i) * вИС j вИИ Finset.range (i + 1), e (j * ќ≤) := by
    have := Finset.sum_range_by_parts (f := fun m => ((w m : вДЭ) : вДВ))
      (g := fun m => e (m * ќ≤)) (n := M)
    simpa only [smul_eq_mul] using this
  rw [habel]
  calc вАЦ(w (M - 1) : вДВ) * вИС j вИИ Finset.range M, e (j * ќ≤)
        - вИС i вИИ Finset.range (M - 1),
            ((w (i + 1) : вДВ) - w i) * вИС j вИИ Finset.range (i + 1), e (j * ќ≤)вАЦ
      вЙ§ вАЦ(w (M - 1) : вДВ) * вИС j вИИ Finset.range M, e (j * ќ≤)вАЦ
        + вАЦвИС i вИИ Finset.range (M - 1),
            ((w (i + 1) : вДВ) - w i) * вИС j вИИ Finset.range (i + 1), e (j * ќ≤)вАЦ :=
        norm_sub_le _ _
    _ вЙ§ W * cap + вИС i вИИ Finset.range (M - 1),
          (w (i + 1) - w i) * cap := by
        apply add_le_add
        ¬Ј rw [norm_mul, Complex.norm_real]
          have h1 : |w (M - 1)| вЙ§ W := by rw [abs_of_nonneg (hw0 _)]; exact hW _
          exact mul_le_mul h1 (hZ M le_rfl) (norm_nonneg _) hW0
        ¬Ј calc вАЦвИС i вИИ Finset.range (M - 1),
                ((w (i + 1) : вДВ) - w i) * вИС j вИИ Finset.range (i + 1), e (j * ќ≤)вАЦ
              вЙ§ вИС i вИИ Finset.range (M - 1),
                вАЦ((w (i + 1) : вДВ) - w i) * вИС j вИИ Finset.range (i + 1), e (j * ќ≤)вАЦ :=
                norm_sum_le _ _
            _ вЙ§ вИС i вИИ Finset.range (M - 1), (w (i + 1) - w i) * cap := by
                apply Finset.sum_le_sum
                intro i hi
                simp only [Finset.mem_range] at hi
                rw [norm_mul]
                have hcast : ((w (i + 1) : вДВ) - w i) = ((w (i + 1) - w i : вДЭ) : вДВ) := by
                  push_cast; ring
                rw [hcast, Complex.norm_real, Real.norm_eq_abs,
                  abs_of_nonneg (by linarith [hwmono (Nat.le_succ i)] : (0:вДЭ) вЙ§ w (i+1) - w i)]
                apply mul_le_mul_of_nonneg_left _ (by linarith [hwmono (Nat.le_succ i)])
                exact hZ (i + 1) (by omega)
    _ = W * cap + (w (M - 1) - w 0) * cap := by
        congr 1
        rw [вЖР Finset.sum_mul]
        congr 1
        exact Finset.sum_range_sub (fun i => w i) (M - 1)
    _ вЙ§ W * cap + W * cap := by
        have h4 : w (M - 1) - w 0 вЙ§ W := by linarith [hW (M - 1), hw0 0]
        have h5 := mul_le_mul_of_nonneg_right h4 hcap0
        linarith
    _ = 2 * W * cap := by ring

/-- (A) The Type II second moment through the workhorse chain. -/
lemma typeII_second_moment_workhorse (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (b : вДХ вЖТ вДВ) (Binf : вДЭ) (hb : вИА m, вАЦb mвАЦ вЙ§ Binf)
    (A B M : вДХ) :
    вИС d вИИ Finset.Ico A B, вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ Binf ^ 2 * (M : вДЭ) *
          (((B - A : вДХ) : вДЭ)
            + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q)))) := by
  have hB0 : 0 вЙ§ Binf := le_trans (norm_nonneg _) (hb 0)
  have h3a := typeII_second_moment_le b M ќ± (Finset.Ico A B)
  have h3b : вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
      вАЦb mвВБвАЦ * вАЦb mвВВвАЦ * вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ
      вЙ§ Binf ^ 2 * вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
          вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((((mвВБ : вД§) - mвВВ) : вД§) : вДЭ) * ќ±))вАЦ := by
    rw [Finset.mul_sum]
    apply Finset.sum_le_sum
    intro mвВБ _
    rw [Finset.mul_sum]
    apply Finset.sum_le_sum
    intro mвВВ _
    have hsum_eq : вИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))
        = вИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((((mвВБ : вД§) - mвВВ) : вД§) : вДЭ) * ќ±)) :=
      Finset.sum_congr rfl (fun d _ => congrArg e (by push_cast; ring))
    rw [hsum_eq, pow_two]
    apply mul_le_mul_of_nonneg_right _ (norm_nonneg _)
    exact mul_le_mul (hb mвВБ) (hb mвВВ) (norm_nonneg _) hB0
  have h3c := diff_count_le
    (fun h => вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ)
    (fun h => norm_nonneg _) M
  have h3d := typeII_h_sum_le a q hq ha ќ± hќ± A B M
  have hM0 : (0 : вДЭ) вЙ§ (M : вДЭ) := by positivity
  have hB2 : (0 : вДЭ) вЙ§ Binf ^ 2 := by positivity
  calc вИС d вИИ Finset.Ico A B, вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
          вАЦb mвВБвАЦ * вАЦb mвВВвАЦ * вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        h3a
    _ вЙ§ Binf ^ 2 * вИС mвВБ вИИ Finset.range M, вИС mвВВ вИИ Finset.range M,
          вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * (((((mвВБ : вД§) - mвВВ) : вД§) : вДЭ) * ќ±))вАЦ := h3b
    _ вЙ§ Binf ^ 2 * ((M : вДЭ) * вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1),
          вАЦвИС d вИИ Finset.Ico A B, e ((d : вДЭ) * ((h : вДЭ) * ќ±))вАЦ) :=
        mul_le_mul_of_nonneg_left h3c hB2
    _ вЙ§ Binf ^ 2 * ((M : вДЭ) * (((B - A : вДХ) : вДЭ)
          + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))) := by
        apply mul_le_mul_of_nonneg_left _ hB2
        exact mul_le_mul_of_nonneg_left h3d hM0
    _ = Binf ^ 2 * (M : вДЭ) *
        (((B - A : вДХ) : вДЭ)
          + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q)))) := by ring

/-- **THE TYPE II (BILINEAR) ESTIMATE**: squared, with sup-bounded coefficients вАФ for
    `gcd(a,q)=1`, `|ќ± вИТ a/q| вЙ§ 1/q¬≤`, `q вЙ• 2`:

      `вАЦвИС_{dвИИ[A,B)} c_d вИС_{m<M} b_m e(dmќ±)вАЦ¬≤ вЙ§ AвИЮ¬≤(BвИТA) ¬Ј BвИЮ¬≤M ¬Ј [workhorse bound]`. -/
lemma typeII_bilinear_sq_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (c b : вДХ вЖТ вДВ) (Ainf Binf : вДЭ)
    (hc : вИА d, вАЦc dвАЦ вЙ§ Ainf) (hb : вИА m, вАЦb mвАЦ вЙ§ Binf)
    (A B M : вДХ) :
    вАЦвИС d вИИ Finset.Ico A B, c d * вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ Ainf ^ 2 * ((B - A : вДХ) : вДЭ) * (Binf ^ 2 * (M : вДЭ) *
          (((B - A : вДХ) : вДЭ)
            + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))) := by
  have hA0 : 0 вЙ§ Ainf := le_trans (norm_nonneg _) (hc 0)
  have h1 : вАЦвИС d вИИ Finset.Ico A B, c d * вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
      вЙ§ Ainf * вИС d вИИ Finset.Ico A B,
          вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
    calc вАЦвИС d вИИ Finset.Ico A B, c d * вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
        вЙ§ вИС d вИИ Finset.Ico A B, вАЦc d * вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
          norm_sum_le _ _
      _ = вИС d вИИ Finset.Ico A B,
            вАЦc dвАЦ * вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
          apply Finset.sum_congr rfl; intro d _; rw [norm_mul]
      _ вЙ§ вИС d вИИ Finset.Ico A B,
            Ainf * вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
          Finset.sum_le_sum (fun d _ => mul_le_mul_of_nonneg_right (hc d) (norm_nonneg _))
      _ = Ainf * вИС d вИИ Finset.Ico A B,
            вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
          (Finset.mul_sum _ _ _).symm
  have h2 : (вИС d вИИ Finset.Ico A B, вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2
      вЙ§ ((B - A : вДХ) : вДЭ) * вИС d вИИ Finset.Ico A B,
          вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2 := by
    have hcs := sq_sum_le_card_mul_sum_sq (s := Finset.Ico A B)
      (f := fun d => вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ)
    rw [Nat.card_Ico] at hcs
    exact_mod_cast hcs
  have h3 := typeII_second_moment_workhorse a q hq ha ќ± hќ± b Binf hb A B M
  calc вАЦвИС d вИИ Finset.Ico A B, c d * вИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ (Ainf * вИС d вИИ Finset.Ico A B,
          вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2 :=
        pow_le_pow_leftвВА (norm_nonneg _) h1 2
    _ = Ainf ^ 2 * (вИС d вИИ Finset.Ico A B,
          вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2 := by ring
    _ вЙ§ Ainf ^ 2 * (((B - A : вДХ) : вДЭ) * вИС d вИИ Finset.Ico A B,
          вАЦвИС m вИИ Finset.range M, b m * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2) :=
        mul_le_mul_of_nonneg_left h2 (by positivity)
    _ вЙ§ Ainf ^ 2 * (((B - A : вДХ) : вДЭ) * (Binf ^ 2 * (M : вДЭ) *
          (((B - A : вДХ) : вДЭ)
            + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q)))))) := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        exact mul_le_mul_of_nonneg_left h3 (by positivity)
    _ = Ainf ^ 2 * ((B - A : вДХ) : вДЭ) * (Binf ^ 2 * (M : вДЭ) *
          (((B - A : вДХ) : вДЭ)
            + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))) := by ring

open ArithmeticFunction in
/-- **Weighted hyperbola unfolding** (the convolution вЖТ double-sum bridge of the
    Vaughan combine): for any weight `w : вДХ вЖТ вДВ`,
    `вИС_{nвЙ§N} (fвИЧg)(n)¬Јw(n) = вИС_{d¬ЈmвЙ§N} f(d)g(m)¬Јw(dm)`. Applying this with
    `w n = e(nќ±)` to the four terms of `Vaughan.vaughan_identity` yields the
    SвВБвАУSвВД decomposition that Type I / Abel / Type II bound. -/
lemma sum_Ioc_mul_weight (f g : ArithmeticFunction вДЭ) (w : вДХ вЖТ вДВ) (N : вДХ) :
    вИС n вИИ Finset.Ioc 0 N, ((f * g) n : вДВ) * w n
      = вИС x вИИ (Finset.Ioc 0 N √ЧЋҐ Finset.Ioc 0 N).filter (fun x => x.1 * x.2 вЙ§ N),
          (f x.1 : вДВ) * (g x.2 : вДВ) * w (x.1 * x.2) := by
  have step1 : вИС n вИИ Finset.Ioc 0 N, ((f * g) n : вДВ) * w n
      = вИС n вИИ Finset.Ioc 0 N,
          вИС x вИИ (Finset.Ioc 0 N √ЧЋҐ Finset.Ioc 0 N).filter (fun x => x.1 * x.2 = n),
            (f x.1 : вДВ) * (g x.2 : вДВ) * w (x.1 * x.2) := by
    apply Finset.sum_congr rfl
    intro n hn
    simp only [Finset.mem_Ioc] at hn
    have hexp : ((f * g) n : вДВ) * w n
        = вИС x вИИ n.divisorsAntidiagonal, (f x.1 : вДВ) * (g x.2 : вДВ) * w n := by
      rw [ArithmeticFunction.mul_apply]
      push_cast
      rw [Finset.sum_mul]
    rw [hexp, Nat.divisorsAntidiagonal_eq_prod_filter_of_le hn.1.ne' hn.2]
    apply Finset.sum_congr rfl
    intro x hx
    simp only [Finset.mem_filter] at hx
    rw [hx.2]
  rw [step1]
  simp_rw [Finset.sum_filter]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro x hx
  simp only [Finset.mem_product, Finset.mem_Ioc] at hx
  have hpos : 0 < x.1 * x.2 := Nat.mul_pos hx.1.1 hx.2.1
  rw [Finset.sum_ite_eq (Finset.Ioc 0 N) (x.1 * x.2)
    (fun _ => (f x.1 : вДВ) * (g x.2 : вДВ) * w (x.1 * x.2))]
  simp only [Finset.mem_Ioc]
  congr 1
  simp only [eq_iff_iff]
  constructor
  ¬Ј intro h; exact h.2
  ¬Ј intro h; exact вЯ®hpos, hвЯ©

/-- **The symmetric cap-sum**: `вИС_{|h|<M} cap(hќ±, W) вЙ§ W + 2((MвИТ1)/(q/2)+1)(2W + 4q(1+log 2q))`
    for any nonneg cap size `W` вАФ the pure-cap form of the Type II h-sum. -/
lemma cap_symmetric_sum_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (W : вДЭ) (hW : 0 вЙ§ W) (M : вДХ) :
    вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1),
      (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then W
       else min W (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)))
      вЙ§ W + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * W + 4 * q * (1 + Real.log (2 * q))) := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  have hlog0 : (0 : вДЭ) вЙ§ Real.log (2 * q) := by
    apply Real.log_nonneg
    have : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
    linarith
  set w : вД§ вЖТ вДЭ := fun h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then W
     else min W (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hw
  have hw0 : вИА h, 0 вЙ§ w h := by
    intro h
    rw [hw]
    dsimp only
    split
    ¬Ј exact hW
    ¬Ј exact le_min hW (by positivity)
  have hweven : вИА h : вД§, w (-h) = w h := by
    intro h
    rw [hw]
    dsimp only
    have hcast : ((-h : вД§) : вДЭ) * ќ± = -((h : вДЭ) * ќ±) := by push_cast; ring
    rw [hcast]
    have hd := dist_round_neg ((h : вДЭ) * ќ±)
    by_cases h0 : (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0
    ¬Ј have h0' : -((h : вДЭ) * ќ±) - round (-((h : вДЭ) * ќ±)) = 0 := by
        have := hd
        rw [abs_eq_zero.mpr h0] at this
        exact abs_eq_zero.mp this
      rw [if_pos h0, if_pos h0']
    ¬Ј have h0' : ¬ђ (-((h : вДЭ) * ќ±) - round (-((h : вДЭ) * ќ±)) = 0) := by
        intro hc
        apply h0
        have := hd
        rw [abs_eq_zero.mpr hc] at this
        exact abs_eq_zero.mp this.symm
      rw [if_neg h0, if_neg h0', hd]
  rcases Nat.eq_zero_or_pos M with hM0 | hM1
  ¬Ј subst hM0
    simp only [Nat.cast_zero, neg_zero, zero_add, zero_sub]
    rw [show Finset.Icc (1 : вД§) (-1) = вИЕ from Finset.Icc_eq_empty (by omega)]
    simp only [Finset.sum_empty]
    have h1 : (0 : вДЭ) вЙ§ 2 * W + 4 * q * (1 + Real.log (2 * q)) := by
      have : (0 : вДЭ) вЙ§ 4 * q * (1 + Real.log (2 * q)) :=
        mul_nonneg (by positivity) (by linarith)
      linarith
    have h2 : (0 : вДЭ) вЙ§ 2 * ((((0 - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
        * (2 * W + 4 * q * (1 + Real.log (2 * q))) := by
      apply mul_nonneg (by positivity) h1
    linarith
  have hsplit : Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1)
      = (Finset.Icc (-(M : вД§) + 1) (-1)) вИ™ insert 0 (Finset.Icc 1 ((M : вД§) - 1)) := by
    ext h
    simp only [Finset.mem_Icc, Finset.mem_union, Finset.mem_insert]
    omega
  have hdisj : Disjoint (Finset.Icc (-(M : вД§) + 1) (-1))
      (insert 0 (Finset.Icc 1 ((M : вД§) - 1))) := by
    rw [Finset.disjoint_left]
    intro h h1 h2
    simp only [Finset.mem_Icc] at h1
    simp only [Finset.mem_insert, Finset.mem_Icc] at h2
    omega
  have h0notin : (0 : вД§) вИЙ Finset.Icc 1 ((M : вД§) - 1) := by
    simp only [Finset.mem_Icc]
    omega
  have hrefl : вИС h вИИ Finset.Icc (-(M : вД§) + 1) (-1), w h
      = вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h := by
    apply Finset.sum_nbij' (i := fun h => -h) (j := fun h => -h)
    ¬Ј intro h hh; simp only [Finset.mem_Icc] at *; omega
    ¬Ј intro h hh; simp only [Finset.mem_Icc] at *; omega
    ¬Ј intro h _; ring
    ¬Ј intro h _; ring
    ¬Ј intro h _
      rw [вЖР hweven h]
  have hw0val : w 0 = W := by
    rw [hw]
    dsimp only
    rw [if_pos (by simp)]
  have hpos : вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h
      вЙ§ ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * W + 4 * q * (1 + Real.log (2 * q))) := by
    have hreidx : вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h
        = вИС n вИИ Finset.Ico 1 (1 + (M - 1)),
            (if (n : вДЭ) * ќ± - round ((n : вДЭ) * ќ±) = 0 then W
             else min W (1 / (2 * |(n : вДЭ) * ќ± - round ((n : вДЭ) * ќ±)|))) := by
      apply Finset.sum_nbij' (i := fun h : вД§ => h.toNat) (j := fun n : вДХ => (n : вД§))
      ¬Ј intro h hh; simp only [Finset.mem_Icc] at hh; simp only [Finset.mem_Ico]; omega
      ¬Ј intro n hn; simp only [Finset.mem_Ico] at hn; simp only [Finset.mem_Icc]; omega
      ¬Ј intro h hh; simp only [Finset.mem_Icc] at hh; omega
      ¬Ј intro n hn; simp only [Finset.mem_Ico] at hn; omega
      ¬Ј intro h hh
        simp only [Finset.mem_Icc] at hh
        rw [hw]
        dsimp only
        have hcast : ((h.toNat : вДХ) : вДЭ) = (h : вДЭ) := by
          have := Int.toNat_of_nonneg (by omega : (0 : вД§) вЙ§ h)
          exact_mod_cast congrArg (fun z : вД§ => (z : вДЭ)) this
        rw [hcast]
    rw [hreidx]
    exact range_min_sum_le a q hq ha ќ± hќ± W hW 1 (M - 1)
  calc вИС h вИИ Finset.Icc (-(M : вД§) + 1) ((M : вД§) - 1), w h
      = вИС h вИИ Finset.Icc (-(M : вД§) + 1) (-1), w h
        + (w 0 + вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h) := by
        rw [hsplit, Finset.sum_union hdisj, Finset.sum_insert h0notin]
    _ = W + 2 * вИС h вИИ Finset.Icc 1 ((M : вД§) - 1), w h := by
        rw [hrefl, hw0val]; ring
    _ вЙ§ W + 2 * (((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * W + 4 * q * (1 + Real.log (2 * q)))) := by
        linarith [hpos]
    _ = W + 2 * ((((M - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
          * (2 * W + 4 * q * (1 + Real.log (2 * q))) := by ring

/-- **The hyperbola-restricted interval cap**: the doubly-constrained d-sum is still an
    interval, and its cap is uniform in `B вИТ A`. -/
lemma filtered_exp_sum_cap (ќ≤ : вДЭ) (N A B mвВБ mвВВ : вДХ) (hmвВБ : 0 < mвВБ) (hmвВВ : 0 < mвВВ) :
    вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N), e (d * ќ≤)вАЦ
      вЙ§ (if ќ≤ - round ќ≤ = 0 then ((B - A : вДХ) : вДЭ)
         else min ((B - A : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
  have hset : (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N)
      = Finset.Ico A (min B (min (N / mвВБ) (N / mвВВ) + 1)) := by
    ext d
    simp only [Finset.mem_filter, Finset.mem_Ico, lt_min_iff]
    constructor
    ¬Ј rintro вЯ®вЯ®h1, h2вЯ©, h3, h4вЯ©
      refine вЯ®h1, h2, ?_вЯ©
      have e1 : d вЙ§ N / mвВБ := Nat.le_div_iff_mul_le hmвВБ |>.mpr h3
      have e2 : d вЙ§ N / mвВВ := Nat.le_div_iff_mul_le hmвВВ |>.mpr h4
      omega
    ¬Ј rintro вЯ®h1, h2, h3вЯ©
      have e1 : d вЙ§ N / mвВБ := by omega
      have e2 : d вЙ§ N / mвВВ := by omega
      exact вЯ®вЯ®h1, h2вЯ©, (Nat.le_div_iff_mul_le hmвВБ).mp e1, (Nat.le_div_iff_mul_le hmвВВ).mp e2вЯ©
  rw [hset]
  have h1 := exp_sum_Ico_min_bound ќ≤ A (min B (min (N / mвВБ) (N / mвВВ) + 1))
  have hsize : ((min B (min (N / mвВБ) (N / mвВВ) + 1) - A : вДХ) : вДЭ) вЙ§ ((B - A : вДХ) : вДЭ) := by
    have : (min B (min (N / mвВБ) (N / mвВВ) + 1) - A : вДХ) вЙ§ (B - A : вДХ) := by omega
    exact_mod_cast this
  split at h1 <;> rename_i hcase
  ¬Ј rw [if_pos hcase]
    linarith
  ¬Ј rw [if_neg hcase]
    exact le_trans h1 (min_le_min hsize le_rfl)

/-- **The hyperbola second-moment expansion** (SвВД's centerpiece): the varying `m`-ranges
    `(V, N/d]` are absorbed into interval-restricted `d`-sums. -/
lemma hyperbola_second_moment_expand (g : вДХ вЖТ вДЭ) (ќ± : вДЭ) (N A B V : вДХ) (hA : 0 < A) :
    вИС d вИИ Finset.Ico A B,
      вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          |g mвВБ| * |g mвВВ| *
            вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := by
  -- extend each inner sum to the fixed range with indicator coefficients
  have hext : вИА d вИИ Finset.Ico A B,
      вИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)
      = вИС m вИИ Finset.Ioc V (N / A),
          ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
    intro d hd
    simp only [Finset.mem_Ico] at hd
    have hd0 : 0 < d := lt_of_lt_of_le hA hd.1
    have hstep : вИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)
        = вИС m вИИ Finset.Ioc V (N / d),
            ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_Ioc] at hm
      rw [if_pos (by rw [mul_comm]; exact (Nat.le_div_iff_mul_le hd0).mp hm.2)]
    rw [hstep]
    apply Finset.sum_subset
    ¬Ј intro m hm
      simp only [Finset.mem_Ioc] at hm вКҐ
      exact вЯ®hm.1, le_trans hm.2 (Nat.div_le_div_left hd.1 hA)вЯ©
    ¬Ј intro m hm hnot
      simp only [Finset.mem_Ioc] at hm hnot
      have hgt : N / d < m := by omega
      have hz : ¬ђ d * m вЙ§ N := by
        intro hc
        have : m вЙ§ N / d := (Nat.le_div_iff_mul_le hd0).mpr (by rwa [mul_comm] at hc)
        omega
      rw [if_neg hz]
      simp
  -- the complex identity with indicator coefficients
  have hid : вИС d вИИ Finset.Ico A B,
      ((вИС m вИИ Finset.Ioc V (N / A),
          ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
        (starRingEnd вДВ) (вИС m вИИ Finset.Ioc V (N / A),
          ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)))
      = вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          ((g mвВБ * g mвВВ : вДЭ) : вДВ) *
            вИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
    have hpt : вИА d вИИ Finset.Ico A B,
        (вИС m вИИ Finset.Ioc V (N / A),
            ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
          (starRingEnd вДВ) (вИС m вИИ Finset.Ioc V (N / A),
            ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±))
        = вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
            (if d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N then ((g mвВБ * g mвВВ : вДЭ) : вДВ)
              * e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) else 0) := by
      intro d _
      rw [map_sum, Finset.sum_mul_sum]
      apply Finset.sum_congr rfl; intro mвВБ _
      apply Finset.sum_congr rfl; intro mвВВ _
      rw [map_mul, e_conj, Complex.conj_ofReal]
      have h1 : e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±))
          = e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by
        rw [e_add]; congr 1; ring
      by_cases hc1 : d * mвВБ вЙ§ N
      ¬Ј by_cases hc2 : d * mвВВ вЙ§ N
        ¬Ј rw [if_pos hc1, if_pos hc2, if_pos вЯ®hc1, hc2вЯ©]
          push_cast
          calc (g mвВБ : вДВ) * e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±)
                * ((g mвВВ : вДВ) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±)))
              = ((g mвВБ : вДВ) * g mвВВ)
                * (e ((d : вДЭ) * (mвВБ : вДЭ) * ќ±) * e (-((d : вДЭ) * (mвВВ : вДЭ) * ќ±))) := by ring
            _ = ((g mвВБ : вДВ) * g mвВВ) * e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±)) := by rw [h1]
        ¬Ј have hcon : ¬ђ (d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N) := fun h => hc2 h.2
          rw [if_pos hc1, if_neg hc2, if_neg hcon]
          push_cast
          ring
      ¬Ј have hcon : ¬ђ (d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N) := fun h => hc1 h.1
        rw [if_neg hc1, if_neg hcon]
        push_cast
        ring
    rw [Finset.sum_congr rfl hpt]
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro mвВБ _
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro mвВВ _
    rw [Finset.mul_sum, Finset.sum_filter]
  -- assemble: real parts + triangle
  have hre : вИС d вИИ Finset.Ico A B,
      вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      = (вИС d вИИ Finset.Ico A B,
          ((вИС m вИИ Finset.Ioc V (N / A),
              ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)) *
            (starRingEnd вДВ) (вИС m вИИ Finset.Ioc V (N / A),
              ((if d * m вЙ§ N then g m else 0 : вДЭ) : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)))).re := by
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro d hd
    rw [вЖР hext d hd, Complex.mul_conj, Complex.normSq_eq_norm_sq]
    exact (Complex.ofReal_re _).symm
  rw [hre, hid]
  calc (вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
        ((g mвВБ * g mвВВ : вДЭ) : вДВ) *
          вИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
            e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))).re
      вЙ§ вАЦвИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          ((g mвВБ * g mвВВ : вДЭ) : вДВ) *
            вИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := Complex.re_le_norm _
    _ вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вАЦвИС mвВВ вИИ Finset.Ioc V (N / A),
          ((g mвВБ * g mвВВ : вДЭ) : вДВ) *
            вИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := norm_sum_le _ _
    _ вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          вАЦ((g mвВБ * g mвВВ : вДЭ) : вДВ) *
            вИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        Finset.sum_le_sum (fun mвВБ _ => norm_sum_le _ _)
    _ = вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          |g mвВБ| * |g mвВВ| *
            вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ := by
        apply Finset.sum_congr rfl; intro mвВБ _
        apply Finset.sum_congr rfl; intro mвВВ _
        rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, abs_mul]

/-- **The SвВД-block second moment**: the full hyperbola-restricted second moment through
    the workhorse chain. -/
lemma S4_block_second_moment (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (g : вДХ вЖТ вДЭ) (G : вДЭ) (hg0 : вИА m, 0 вЙ§ g m) (hgG : вИА m, g m вЙ§ G)
    (N A B V : вДХ) (hA : 0 < A) :
    вИС d вИИ Finset.Ico A B,
      вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ G ^ 2 * (((N / A : вДХ) : вДЭ) + 1) *
          (((B - A : вДХ) : вДЭ) + 2 * ((((N / A : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q)))) := by
  have hG0 : 0 вЙ§ G := le_trans (hg0 0) (hgG 0)
  set F : вД§ вЖТ вДЭ := fun h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((B - A : вДХ) : вДЭ)
     else min ((B - A : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hF
  have hF0 : вИА h, 0 вЙ§ F h := by
    intro h
    rw [hF]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  -- per-pair bound
  have hpair : вИА mвВБ вИИ Finset.Ioc V (N / A), вИА mвВВ вИИ Finset.Ioc V (N / A),
      |g mвВБ| * |g mвВВ| *
        вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
          e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ
      вЙ§ G * G * F ((mвВБ : вД§) - mвВВ) := by
    intro mвВБ hmвВБ mвВВ hmвВВ
    simp only [Finset.mem_Ioc] at hmвВБ hmвВВ
    have hcapF : вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
        e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ вЙ§ F ((mвВБ : вД§) - mвВВ) := by
      have h1 := filtered_exp_sum_cap (((mвВБ : вДЭ) - mвВВ) * ќ±) N A B mвВБ mвВВ
        (by omega) (by omega)
      have hcast : ((((mвВБ : вД§) - mвВВ) : вД§) : вДЭ) * ќ± = ((mвВБ : вДЭ) - mвВВ) * ќ± := by
        push_cast
        ring
      rw [hF]
      dsimp only
      rw [hcast]
      exact h1
    have hg1 : |g mвВБ| вЙ§ G := by rw [abs_of_nonneg (hg0 mвВБ)]; exact hgG mвВБ
    have hg2 : |g mвВВ| вЙ§ G := by rw [abs_of_nonneg (hg0 mвВВ)]; exact hgG mвВВ
    apply mul_le_mul _ hcapF (norm_nonneg _) (by positivity)
    exact mul_le_mul hg1 hg2 (abs_nonneg _) hG0
  -- extend the double sum to squares of ranges
  have hIoc_sub : Finset.Ioc V (N / A) вКЖ Finset.range (N / A + 1) := by
    intro m hm
    simp only [Finset.mem_Ioc] at hm
    simp only [Finset.mem_range]
    omega
  calc вИС d вИИ Finset.Ico A B,
      вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2
      вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          |g mвВБ| * |g mвВВ| *
            вАЦвИС d вИИ (Finset.Ico A B).filter (fun d => d * mвВБ вЙ§ N вИІ d * mвВВ вЙ§ N),
              e ((d : вДЭ) * (((mвВБ : вДЭ) - mвВВ) * ќ±))вАЦ :=
        hyperbola_second_moment_expand g ќ± N A B V hA
    _ вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.Ioc V (N / A),
          G * G * F ((mвВБ : вД§) - mвВВ) := by
        apply Finset.sum_le_sum
        intro mвВБ hmвВБ
        exact Finset.sum_le_sum (fun mвВВ hmвВВ => hpair mвВБ hmвВБ mвВВ hmвВВ)
    _ вЙ§ вИС mвВБ вИИ Finset.Ioc V (N / A), вИС mвВВ вИИ Finset.range (N / A + 1),
          G * G * F ((mвВБ : вД§) - mвВВ) := by
        apply Finset.sum_le_sum
        intro mвВБ _
        apply Finset.sum_le_sum_of_subset_of_nonneg hIoc_sub
        intro mвВВ _ _
        positivity
    _ вЙ§ вИС mвВБ вИИ Finset.range (N / A + 1), вИС mвВВ вИИ Finset.range (N / A + 1),
          G * G * F ((mвВБ : вД§) - mвВВ) := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hIoc_sub
        intro mвВБ _ _
        exact Finset.sum_nonneg (fun mвВВ _ => by positivity)
    _ = G * G * вИС mвВБ вИИ Finset.range (N / A + 1), вИС mвВВ вИИ Finset.range (N / A + 1),
          F ((mвВБ : вД§) - mвВВ) := by
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro mвВБ _
        rw [Finset.mul_sum]
    _ вЙ§ G * G * (((N / A + 1 : вДХ) : вДЭ) *
          вИС h вИИ Finset.Icc (-(N / A + 1 : вДХ) + 1 : вД§) ((N / A + 1 : вДХ) - 1 : вД§), F h) := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        exact_mod_cast diff_count_le F hF0 (N / A + 1)
    _ вЙ§ G * G * (((N / A + 1 : вДХ) : вДЭ) *
          (((B - A : вДХ) : вДЭ) + 2 * ((((N / A + 1 - 1 : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))) := by
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        apply mul_le_mul_of_nonneg_left _ (by positivity)
        have h5 := cap_symmetric_sum_le a q hq ha ќ± hќ± ((B - A : вДХ) : вДЭ)
          (by positivity) (N / A + 1)
        rw [hF]
        exact_mod_cast h5
    _ = G ^ 2 * (((N / A : вДХ) : вДЭ) + 1) *
          (((B - A : вДХ) : вДЭ) + 2 * ((((N / A : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * ((B - A : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q)))) := by
        rw [Nat.add_sub_cancel]
        push_cast
        ring

/-- **The variance quartic step**: on any interval where `вАЦSвАЦ вЙ§ C`, the fourth moment is
    controlled by `C¬≤` times the second moment. (The per-arc core of
    `вИЂ_рЭФ™ |S|вБі вЙ§ (sup_рЭФ™|S|)¬≤¬ЈвИЂ|S|¬≤`; the arc decomposition supplies the intervals.) -/
lemma quartic_le_sq_mul_sq (S : вДЭ вЖТ вДВ) (C : вДЭ) (a b : вДЭ) (hab : a вЙ§ b)
    (hbound : вИА ќ± вИИ Set.Icc a b, вАЦS ќ±вАЦ вЙ§ C)
    (hint2 : IntervalIntegrable (fun ќ± => вАЦS ќ±вАЦ ^ 2) MeasureTheory.volume a b)
    (hint4 : IntervalIntegrable (fun ќ± => вАЦS ќ±вАЦ ^ 4) MeasureTheory.volume a b) :
    вИЂ ќ± in a..b, вАЦS ќ±вАЦ ^ 4 вЙ§ C ^ 2 * вИЂ ќ± in a..b, вАЦS ќ±вАЦ ^ 2 := by
  have hC0 : 0 вЙ§ C := by
    rcases eq_or_lt_of_le hab with h | h
    ¬Ј -- degenerate interval: both integrals vanish; C вЙ• 0 not needed, handle below
      exact le_trans (norm_nonneg (S a)) (hbound a (by constructor <;> simp [h.le]))
    ¬Ј exact le_trans (norm_nonneg (S a)) (hbound a вЯ®le_refl a, habвЯ©)
  have hpt : вИА ќ± вИИ Set.Icc a b, вАЦS ќ±вАЦ ^ 4 вЙ§ C ^ 2 * вАЦS ќ±вАЦ ^ 2 := by
    intro ќ± hќ±
    have h1 : вАЦS ќ±вАЦ вЙ§ C := hbound ќ± hќ±
    have h2 : вАЦS ќ±вАЦ ^ 2 вЙ§ C ^ 2 := by
      apply pow_le_pow_leftвВА (norm_nonneg _) h1
    calc вАЦS ќ±вАЦ ^ 4 = вАЦS ќ±вАЦ ^ 2 * вАЦS ќ±вАЦ ^ 2 := by ring
      _ вЙ§ C ^ 2 * вАЦS ќ±вАЦ ^ 2 :=
        mul_le_mul_of_nonneg_right h2 (by positivity)
  calc вИЂ ќ± in a..b, вАЦS ќ±вАЦ ^ 4
      вЙ§ вИЂ ќ± in a..b, C ^ 2 * вАЦS ќ±вАЦ ^ 2 := by
        apply intervalIntegral.integral_mono_on hab hint4 (hint2.const_mul (C ^ 2))
        exact hpt
    _ = C ^ 2 * вИЂ ќ± in a..b, вАЦS ќ±вАЦ ^ 2 := intervalIntegral.integral_const_mul _ _

section VaughanDecomposition

open ArithmeticFunction
open scoped ArithmeticFunction ArithmeticFunction.Moebius ArithmeticFunction.zeta

/-- Vaughan's identity (self-contained copy of `Vaughan.vaughan_identity` from
    `VaughanIdentity.lean`, re-verified here so this file stays standalone). -/
lemma vaughan_identity (a b : ArithmeticFunction вДЭ) :
    ќЫ = a * ArithmeticFunction.log - a * b * (ќґ : ArithmeticFunction вДЭ) + b
      + ((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ) := by
  have hlog : (ќґ : ArithmeticFunction вДЭ) * ќЫ = ArithmeticFunction.log := zeta_mul_vonMangoldt
  have hќЉќґ : ((ќЉ : ArithmeticFunction вДЭ) * (ќґ : ArithmeticFunction вДЭ)) = 1 :=
    coe_moebius_mul_coe_zeta
  rw [вЖР hlog]
  linear_combination (b - ќЫ) * hќЉќґ

/-- **The Vaughan sum decomposition**: `вИС_{nвЙ§N} ќЫ(n)¬Јw(n) = SвВБ вИТ SвВВ + SвВГ + SвВД`,
    each `SбµҐ` a convolution sum ready for the hyperbola unfolding
    (`sum_Ioc_mul_weight`) and then Type I / Abel / Type II. -/
lemma vaughan_sum_decomposition (a b : ArithmeticFunction вДЭ) (w : вДХ вЖТ вДВ) (N : вДХ) :
    вИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * w n
      = (вИС n вИИ Finset.Ioc 0 N, (((a * ArithmeticFunction.log) n : вДЭ) : вДВ) * w n)
        - (вИС n вИИ Finset.Ioc 0 N, (((a * b * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * w n)
        + (вИС n вИИ Finset.Ioc 0 N, ((b n : вДЭ) : вДВ) * w n)
        + (вИС n вИИ Finset.Ioc 0 N,
            (((((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ)
              * w n) := by
  have hpt : вИА n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * w n
      = (((a * ArithmeticFunction.log) n : вДЭ) : вДВ) * w n
        - (((a * b * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * w n
        + ((b n : вДЭ) : вДВ) * w n
        + (((((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ)
            * w n := by
    intro n _
    have h1 : (ќЫ : ArithmeticFunction вДЭ) n
        = (a * ArithmeticFunction.log) n - (a * b * (ќґ : ArithmeticFunction вДЭ)) n + b n
          + (((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ)) n := by
      conv_lhs => rw [vaughan_identity a b]
      have e1 : (a * ArithmeticFunction.log - a * b * (ќґ : ArithmeticFunction вДЭ) + b
          + ((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ))
          = ((a * ArithmeticFunction.log + -(a * b * (ќґ : ArithmeticFunction вДЭ))) + b)
            + ((ќЉ : ArithmeticFunction вДЭ) - a) * (ќЫ - b) * (ќґ : ArithmeticFunction вДЭ) := by
        ring
      rw [e1, ArithmeticFunction.add_apply, ArithmeticFunction.add_apply,
        ArithmeticFunction.add_apply, ArithmeticFunction.neg_apply]
      ring
    rw [h1]
    push_cast
    ring
  rw [Finset.sum_congr rfl hpt]
  rw [Finset.sum_add_distrib, Finset.sum_add_distrib, Finset.sum_sub_distrib]

/-- Truncation of an arithmetic function to `n вЙ§ U` (the Vaughan `a`, `b` pieces). -/
noncomputable def truncate (f : ArithmeticFunction вДЭ) (U : вДХ) : ArithmeticFunction вДЭ :=
  вЯ®fun n => if n вЙ§ U then f n else 0, by
    split
    ¬Ј exact f.map_zero
    ¬Ј rflвЯ©

@[simp] lemma truncate_apply (f : ArithmeticFunction вДЭ) (U n : вДХ) :
    truncate f U n = if n вЙ§ U then f n else 0 := rfl

/-- The truncated M√ґbius is sup-bounded by 1. -/
lemma abs_truncate_moebius_le_one (U n : вДХ) :
    |truncate (ќЉ : ArithmeticFunction вДЭ) U n| вЙ§ 1 := by
  rw [truncate_apply]
  split
  ¬Ј have h := abs_moebius_le_one (n := n)
    rw [ArithmeticFunction.intCoe_apply]
    calc |((ќЉ n : вД§) : вДЭ)| = ((|ќЉ n| : вД§) : вДЭ) := by rw [Int.cast_abs]
      _ вЙ§ 1 := by exact_mod_cast h
  ¬Ј simp

lemma truncate_vonMangoldt_nonneg (V n : вДХ) : 0 вЙ§ truncate ќЫ V n := by
  rw [truncate_apply]
  split
  ¬Ј exact vonMangoldt_nonneg
  ¬Ј exact le_refl 0

lemma truncate_vonMangoldt_le (V n : вДХ) : truncate ќЫ V n вЙ§ ќЫ n := by
  rw [truncate_apply]
  split
  ¬Ј exact le_refl _
  ¬Ј exact vonMangoldt_nonneg

/-- **The SвВВ coefficient bound**: the Vaughan `a¬Јb` coefficients are log-bounded,
    `|(aвИЧb)(t)| вЙ§ log t` (via `|ќЉ| вЙ§ 1`, `0 вЙ§ ќЫ_trunc вЙ§ ќЫ`, and `вИС_{dвИ£t} ќЫ(d) = log t`). -/
lemma abs_truncate_mul_le_log (U V t : вДХ) :
    |(truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V) t| вЙ§ Real.log t := by
  rw [ArithmeticFunction.mul_apply]
  calc |вИС x вИИ t.divisorsAntidiagonal,
        truncate (ќЉ : ArithmeticFunction вДЭ) U x.1 * truncate ќЫ V x.2|
      вЙ§ вИС x вИИ t.divisorsAntidiagonal,
        |truncate (ќЉ : ArithmeticFunction вДЭ) U x.1 * truncate ќЫ V x.2| :=
        Finset.abs_sum_le_sum_abs _ _
    _ вЙ§ вИС x вИИ t.divisorsAntidiagonal, ќЫ x.2 := by
        apply Finset.sum_le_sum
        intro x _
        rw [abs_mul]
        have h1 := abs_truncate_moebius_le_one U x.1
        have h2 : |truncate ќЫ V x.2| = truncate ќЫ V x.2 :=
          abs_of_nonneg (truncate_vonMangoldt_nonneg V x.2)
        calc |truncate (ќЉ : ArithmeticFunction вДЭ) U x.1| * |truncate ќЫ V x.2|
            вЙ§ 1 * |truncate ќЫ V x.2| := mul_le_mul_of_nonneg_right h1 (abs_nonneg _)
          _ = truncate ќЫ V x.2 := by rw [one_mul, h2]
          _ вЙ§ ќЫ x.2 := truncate_vonMangoldt_le V x.2
    _ = вИС d вИИ t.divisors, ќЫ d := Nat.sum_divisorsAntidiagonal' (f := fun _ e => ќЫ e)
    _ = Real.log t := vonMangoldt_sum

/-- **The regrouping**: `вИС_{nвЙ§N} (fвИЧg)(n)w(n) = вИС_{dвЙ§N} f(d)¬ЈвИС_{mвЙ§N/d} g(m)w(dm)` вАФ
    each Vaughan piece becomes per-`d` inner sums in exp-sum shape
    (with `w n = e(nќ±)` the inner sum is `вИС_{mвЙ§N/d} g(m)e(m¬Ј(dќ±))`). -/
lemma sum_Ioc_mul_weight_eq_sum_sum (f g : ArithmeticFunction вДЭ) (w : вДХ вЖТ вДВ) (N : вДХ) :
    вИС n вИИ Finset.Ioc 0 N, ((f * g) n : вДВ) * w n
      = вИС d вИИ Finset.Ioc 0 N, (f d : вДВ) *
          вИС m вИИ Finset.Ioc 0 (N / d), (g m : вДВ) * w (d * m) := by
  rw [sum_Ioc_mul_weight, Finset.sum_filter, Finset.sum_product]
  apply Finset.sum_congr rfl
  intro d hd
  simp only [Finset.mem_Ioc] at hd
  have hset : (Finset.Ioc 0 N).filter (fun m => d * m вЙ§ N) = Finset.Ioc 0 (N / d) := by
    ext m
    simp only [Finset.mem_filter, Finset.mem_Ioc]
    constructor
    ¬Ј rintro вЯ®вЯ®h1, _вЯ©, h3вЯ©
      refine вЯ®h1, ?_вЯ©
      rw [Nat.le_div_iff_mul_le hd.1]
      rwa [mul_comm]
    ¬Ј rintro вЯ®h1, h2вЯ©
      have h3 : m * d вЙ§ N := (Nat.le_div_iff_mul_le hd.1).mp h2
      refine вЯ®вЯ®h1, ?_вЯ©, by rwa [mul_comm] at h3вЯ©
      calc m вЙ§ N / d := h2
        _ вЙ§ N := Nat.div_le_self N d
  calc вИС m вИИ Finset.Ioc 0 N,
        (if d * m вЙ§ N then (f d : вДВ) * (g m : вДВ) * w (d * m) else 0)
      = вИС m вИИ (Finset.Ioc 0 N).filter (fun m => d * m вЙ§ N),
          (f d : вДВ) * (g m : вДВ) * w (d * m) := (Finset.sum_filter _ _).symm
    _ = вИС m вИИ Finset.Ioc 0 (N / d), (f d : вДВ) * (g m : вДВ) * w (d * m) := by rw [hset]
    _ = (f d : вДВ) * вИС m вИИ Finset.Ioc 0 (N / d), (g m : вДВ) * w (d * m) := by
        rw [Finset.mul_sum]
        exact Finset.sum_congr rfl (fun m _ => by ring)

/-- **The dyadic N/h-cap workhorse (Vaughan Lemma 2.2 final form)**. -/
lemma dyadic_cap_sum_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (N H : вДХ) :
    вИС h вИИ Finset.Ioc 0 H,
      (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / h : вДХ) : вДЭ)
       else min ((N / h : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)))
      вЙ§ ((Nat.log 2 H + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
        + 32 * H * (1 + Real.log (2 * q)) + 4 * N := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  have hq2 : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
  have hL0 : (0 : вДЭ) вЙ§ 1 + Real.log (2 * q) := by
    have : (0 : вДЭ) вЙ§ Real.log (2 * q) := Real.log_nonneg (by linarith)
    linarith
  set L : вДЭ := 1 + Real.log (2 * q) with hLdef
  rcases Nat.eq_zero_or_pos H with hH0 | hH1
  ¬Ј subst hH0
    simp only [Finset.Ioc_self, Finset.sum_empty]
    push_cast
    have h2 : (0 : вДЭ) вЙ§ 4 * q * L := mul_nonneg (by positivity) hL0
    have h4 : (0 : вДЭ) вЙ§ 8 * N / q := by positivity
    have h6 : (0 : вДЭ) вЙ§ ((Nat.log 2 0 : вДЭ) + 1) * (8 * N / q + 4 * q * L) :=
      mul_nonneg (by positivity) (by linarith)
    linarith
  set T : вДХ := Nat.log 2 H + 1 with hT
  have h2T : (2 : вДХ) ^ T вЙ§ 2 * H := by
    rw [hT, pow_succ, mul_comm]
    have := Nat.pow_log_le_self 2 (by omega : H вЙ† 0)
    omega
  set w : вДХ вЖТ вДЭ := fun h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / h : вДХ) : вДЭ)
     else min ((N / h : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hw
  set wt : вДХ вЖТ вДХ вЖТ вДЭ := fun t h =>
    (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / 2 ^ t : вДХ) : вДЭ)
     else min ((N / 2 ^ t : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) with hwt
  have hwt0 : вИА t h, 0 вЙ§ wt t h := by
    intro t h
    rw [hwt]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  have hww : вИА h вИИ Finset.Ioc 0 H, w h вЙ§ wt (Nat.log 2 h) h := by
    intro h hh
    simp only [Finset.mem_Ioc] at hh
    have hple : 2 ^ Nat.log 2 h вЙ§ h := Nat.pow_log_le_self 2 (by omega)
    have hdivle : (N / h : вДХ) вЙ§ N / 2 ^ Nat.log 2 h := Nat.div_le_div_left hple (by positivity)
    have hcast : ((N / h : вДХ) : вДЭ) вЙ§ ((N / 2 ^ Nat.log 2 h : вДХ) : вДЭ) := by exact_mod_cast hdivle
    rw [hw, hwt]
    dsimp only
    split
    ¬Ј exact hcast
    ¬Ј exact min_le_min hcast le_rfl
  have hsum1 : вИС h вИИ Finset.Ioc 0 H, w h
      вЙ§ вИС t вИИ Finset.range T, вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t), wt t h := by
    have hcover : Finset.Ioc 0 H вКЖ
        (Finset.range T).biUnion (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
      intro h hh
      simp only [Finset.mem_Ioc] at hh
      rw [Finset.mem_biUnion]
      refine вЯ®Nat.log 2 h, ?_, ?_вЯ©
      ¬Ј rw [Finset.mem_range, hT]
        have hlog : Nat.log 2 h вЙ§ Nat.log 2 H := Nat.log_mono_right hh.2
        omega
      ¬Ј rw [Finset.mem_Ico]
        constructor
        ¬Ј exact Nat.pow_log_le_self 2 (by omega)
        ¬Ј have := Nat.lt_pow_succ_log_self (by norm_num : 1 < 2) h
          rw [pow_succ] at this
          omega
    have hdisj : (вЖС(Finset.range T) : Set вДХ).PairwiseDisjoint
        (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
      intro tвВБ _ tвВВ _ hne
      apply Finset.disjoint_left.mpr
      intro h h1 h2
      simp only [Finset.mem_Ico] at h1 h2
      rcases Nat.lt_or_ge tвВБ tвВВ with hlt | hge
      ¬Ј have : (2 : вДХ) ^ (tвВБ + 1) вЙ§ 2 ^ tвВВ := Nat.pow_le_pow_right (by norm_num) hlt
        rw [pow_succ] at this
        omega
      ¬Ј have hlt2 : tвВВ < tвВБ := lt_of_le_of_ne hge (Ne.symm hne)
        have : (2 : вДХ) ^ (tвВВ + 1) вЙ§ 2 ^ tвВБ := Nat.pow_le_pow_right (by norm_num) hlt2
        rw [pow_succ] at this
        omega
    calc вИС h вИИ Finset.Ioc 0 H, w h
        вЙ§ вИС h вИИ Finset.Ioc 0 H, wt (Nat.log 2 h) h := Finset.sum_le_sum hww
      _ вЙ§ вИС h вИИ (Finset.range T).biUnion (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)),
            wt (Nat.log 2 h) h :=
          Finset.sum_le_sum_of_subset_of_nonneg hcover (fun h _ _ => hwt0 _ h)
      _ = вИС t вИИ Finset.range T, вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
            wt (Nat.log 2 h) h := Finset.sum_biUnion hdisj
      _ = вИС t вИИ Finset.range T, вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t), wt t h := by
          apply Finset.sum_congr rfl
          intro t _
          apply Finset.sum_congr rfl
          intro h hh
          simp only [Finset.mem_Ico] at hh
          have hlog : Nat.log 2 h = t := by
            apply Nat.log_eq_of_pow_le_of_lt_pow hh.1
            rw [pow_succ]
            omega
          rw [hlog]
  have hblock : вИА t : вДХ, вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t), wt t h
      вЙ§ 8 * N / q + 16 * L * (2 : вДЭ) ^ t + 2 * N / (2 : вДЭ) ^ t + 4 * q * L := by
    intro t
    have happ := range_min_sum_le a q hq ha ќ± hќ± ((N / 2 ^ t : вДХ) : вДЭ) (by positivity)
      (2 ^ t) (2 ^ t)
    have hq2pos : (0 : вДЭ) < ((q / 2 : вДХ) : вДЭ) := by exact_mod_cast (by omega : 0 < q / 2)
    have hcast1 : (((2 ^ t) / (q / 2) + 1 : вДХ) : вДЭ) вЙ§ (2 : вДЭ) ^ t * (4 / q) + 1 := by
      have h3 : (q : вДЭ) вЙ§ 4 * ((q / 2 : вДХ) : вДЭ) := by exact_mod_cast (by omega : q вЙ§ 4 * (q / 2))
      have hinv : 1 / ((q / 2 : вДХ) : вДЭ) вЙ§ 4 / (q : вДЭ) := by
        rw [div_le_div_iffвВА hq2pos hqR]
        linarith
      have h1 : (((2 ^ t) / (q / 2) : вДХ) : вДЭ) вЙ§ ((2 ^ t : вДХ) : вДЭ) / ((q / 2 : вДХ) : вДЭ) :=
        Nat.cast_div_le
      have h5 : ((2 ^ t : вДХ) : вДЭ) / ((q / 2 : вДХ) : вДЭ)
          = ((2 ^ t : вДХ) : вДЭ) * (1 / ((q / 2 : вДХ) : вДЭ)) := by ring
      have h6 : ((2 ^ t : вДХ) : вДЭ) * (1 / ((q / 2 : вДХ) : вДЭ)) вЙ§ ((2 ^ t : вДХ) : вДЭ) * (4 / q) :=
        mul_le_mul_of_nonneg_left hinv (by positivity)
      have h7 : (((2 ^ t) / (q / 2) + 1 : вДХ) : вДЭ) = (((2 ^ t) / (q / 2) : вДХ) : вДЭ) + 1 := by
        push_cast
        ring
      have h8 : ((2 ^ t : вДХ) : вДЭ) = (2 : вДЭ) ^ t := by push_cast; ring
      rw [h7]
      rw [h8] at h5 h6
      rw [h8] at h1
      linarith [h1, h5, h6]
    have hcast2 : ((N / 2 ^ t : вДХ) : вДЭ) вЙ§ (N : вДЭ) / (2 : вДЭ) ^ t := by
      have h9 := Nat.cast_div_le (m := N) (n := 2 ^ t) (ќ± := вДЭ)
      push_cast at h9
      exact h9
    have hnn2 : (0 : вДЭ) вЙ§ 2 * ((N / 2 ^ t : вДХ) : вДЭ) + 4 * q * L := by
      have : (0 : вДЭ) вЙ§ 4 * q * L := mul_nonneg (by positivity) hL0
      positivity
    have h2t : ((2 : вДЭ) ^ t) вЙ† 0 := by positivity
    have hqne : (q : вДЭ) вЙ† 0 := ne_of_gt hqR
    calc вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t), wt t h
        вЙ§ (((2 ^ t) / (q / 2) + 1 : вДХ) : вДЭ) * (2 * ((N / 2 ^ t : вДХ) : вДЭ) + 4 * q * L) := happ
      _ вЙ§ ((2 : вДЭ) ^ t * (4 / q) + 1) * (2 * ((N : вДЭ) / (2 : вДЭ) ^ t) + 4 * q * L) := by
          apply mul_le_mul hcast1 _ hnn2 (by positivity)
          have h10 : 2 * ((N / 2 ^ t : вДХ) : вДЭ) вЙ§ 2 * ((N : вДЭ) / (2 : вДЭ) ^ t) := by linarith
          linarith
      _ = 8 * N / q + 16 * L * (2 : вДЭ) ^ t + 2 * N / (2 : вДЭ) ^ t + 4 * q * L := by
          field_simp
          ring
  have hgeo1 : вИС t вИИ Finset.range T, (2 : вДЭ) ^ t вЙ§ (2 : вДЭ) ^ T := by
    have heq : ((2 : вДЭ) ^ T - 1) / (2 - 1) = (2 : вДЭ) ^ T - 1 := by norm_num
    rw [geom_sum_eq (by norm_num : (2 : вДЭ) вЙ† 1), heq]
    have : (0 : вДЭ) < (2 : вДЭ) ^ T := by positivity
    linarith
  have hgeo2 : вИС t вИИ Finset.range T, (1 / (2 : вДЭ)) ^ t вЙ§ 2 := by
    have heq : ((1 / 2 : вДЭ) ^ T - 1) / (1 / 2 - 1) = 2 * (1 - (1 / 2 : вДЭ) ^ T) := by ring
    rw [geom_sum_eq (by norm_num : (1 / 2 : вДЭ) вЙ† 1), heq]
    have : (0 : вДЭ) вЙ§ (1 / 2 : вДЭ) ^ T := by positivity
    linarith
  have hsum2 : вИС t вИИ Finset.range T,
      (8 * (N : вДЭ) / q + 16 * L * (2 : вДЭ) ^ t + 2 * N / (2 : вДЭ) ^ t + 4 * q * L)
      вЙ§ (T : вДЭ) * (8 * N / q + 4 * q * L) + 16 * L * (2 : вДЭ) ^ T + 4 * N := by
    have hsplit : вИА t вИИ Finset.range T,
        8 * (N : вДЭ) / q + 16 * L * (2 : вДЭ) ^ t + 2 * N / (2 : вДЭ) ^ t + 4 * q * L
        = (8 * (N : вДЭ) / q + 4 * q * L)
          + (16 * L * (2 : вДЭ) ^ t + 2 * N * (1 / (2 : вДЭ)) ^ t) := by
      intro t _
      have hp : (1 / (2 : вДЭ)) ^ t = 1 / (2 : вДЭ) ^ t := by
        rw [div_pow, one_pow]
      rw [hp]
      ring
    rw [Finset.sum_congr rfl hsplit, Finset.sum_add_distrib, Finset.sum_const,
      Finset.card_range, Finset.sum_add_distrib, вЖР Finset.mul_sum, вЖР Finset.mul_sum,
      nsmul_eq_mul]
    have h1 : 16 * L * вИС t вИИ Finset.range T, (2 : вДЭ) ^ t вЙ§ 16 * L * (2 : вДЭ) ^ T :=
      mul_le_mul_of_nonneg_left hgeo1 (by linarith)
    have h2 : 2 * (N : вДЭ) * вИС t вИИ Finset.range T, (1 / (2 : вДЭ)) ^ t вЙ§ 2 * N * 2 :=
      mul_le_mul_of_nonneg_left hgeo2 (by positivity)
    linarith
  have h2TR : (2 : вДЭ) ^ T вЙ§ 2 * H := by exact_mod_cast h2T
  calc вИС h вИИ Finset.Ioc 0 H, w h
      вЙ§ вИС t вИИ Finset.range T, вИС h вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t), wt t h := hsum1
    _ вЙ§ вИС t вИИ Finset.range T,
        (8 * (N : вДЭ) / q + 16 * L * (2 : вДЭ) ^ t + 2 * N / (2 : вДЭ) ^ t + 4 * q * L) :=
        Finset.sum_le_sum (fun t _ => hblock t)
    _ вЙ§ (T : вДЭ) * (8 * N / q + 4 * q * L) + 16 * L * (2 : вДЭ) ^ T + 4 * N := hsum2
    _ вЙ§ (T : вДЭ) * (8 * N / q + 4 * q * L) + 16 * L * (2 * H) + 4 * N := by
        have h11 : 16 * L * (2 : вДЭ) ^ T вЙ§ 16 * L * (2 * H) :=
          mul_le_mul_of_nonneg_left h2TR (by linarith)
        linarith
    _ = ((Nat.log 2 H + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
        + 32 * H * (1 + Real.log (2 * q)) + 4 * N := by
        rw [hT, hLdef]
        push_cast
        ring

/-- The SвВВ support bound: the convolution of truncations vanishes past `U¬ЈV`. -/
lemma truncate_mul_eq_zero_of_gt (f g : ArithmeticFunction вДЭ) (U V t : вДХ) (ht : U * V < t) :
    (truncate f U * truncate g V) t = 0 := by
  rw [ArithmeticFunction.mul_apply]
  apply Finset.sum_eq_zero
  intro x hx
  rw [Nat.mem_divisorsAntidiagonal] at hx
  by_cases h1 : x.1 вЙ§ U
  ¬Ј have h2 : ¬ђ x.2 вЙ§ V := by
      intro h2
      have hle : x.1 * x.2 вЙ§ U * V := Nat.mul_le_mul h1 h2
      obtain вЯ®P, hPвЯ© : вИГ P, P = x.1 * x.2 := вЯ®_, rflвЯ©
      obtain вЯ®Q, hQвЯ© : вИГ Q, Q = U * V := вЯ®_, rflвЯ©
      rw [вЖР hP] at hle
      rw [вЖР hP] at hx
      rw [вЖР hQ] at hle ht
      omega
    rw [truncate_apply, truncate_apply, if_neg h2, mul_zero]
  ¬Ј rw [truncate_apply, if_neg h1, zero_mul]

/-- The SвВГ trivial bound: `вИС_{nвЙ§V} ќЫ(n) вЙ§ V¬Јlog V`. -/
lemma sum_vonMangoldt_le (V : вДХ) :
    вИС n вИИ Finset.Ioc 0 V, ќЫ n вЙ§ (V : вДЭ) * Real.log V := by
  calc вИС n вИИ Finset.Ioc 0 V, ќЫ n
      вЙ§ вИС _n вИИ Finset.Ioc 0 V, Real.log V := by
        apply Finset.sum_le_sum
        intro n hn
        simp only [Finset.mem_Ioc] at hn
        calc ќЫ n вЙ§ Real.log n := vonMangoldt_le_log
          _ вЙ§ Real.log V := by
            apply Real.log_le_log (by exact_mod_cast hn.1)
            exact_mod_cast hn.2
    _ = (V : вДЭ) * Real.log V := by
        rw [Finset.sum_const, Nat.card_Ioc, nsmul_eq_mul]
        norm_num

/-- ќґ collapses on positive ranges: `вИС_{0<mвЙ§M} ќґ(m)¬Јz(m) = вИС_{0<mвЙ§M} z(m)`. -/
lemma sum_Ioc_zeta_mul (z : вДХ вЖТ вДВ) (M : вДХ) :
    вИС m вИИ Finset.Ioc 0 M, (((ќґ : ArithmeticFunction вДЭ) m : вДЭ) : вДВ) * z m
      = вИС m вИИ Finset.Ioc 0 M, z m := by
  apply Finset.sum_congr rfl
  intro m hm
  simp only [Finset.mem_Ioc] at hm
  have h1 : ((ќґ : ArithmeticFunction вДЭ) m : вДЭ) = 1 := by
    rw [ArithmeticFunction.natCoe_apply, ArithmeticFunction.zeta_apply,
      if_neg (by omega : ¬ђ m = 0)]
    norm_num
  rw [h1]
  norm_num

/-- The Ioc exp-sum cap: `вАЦвИС_{0<mвЙ§M} e(mќ≤)вАЦ вЙ§ [ќ≤вИИвД§ ? M : min(M, 1/(2вАЦќ≤вАЦ))]`. -/
lemma exp_sum_Ioc_min_bound (ќ≤ : вДЭ) (M : вДХ) :
    вАЦвИС m вИИ Finset.Ioc 0 M, e (m * ќ≤)вАЦ
      вЙ§ (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
         else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
  have hset : Finset.Ioc 0 M = Finset.Ico 1 (M + 1) := by
    ext m
    simp only [Finset.mem_Ioc, Finset.mem_Ico]
    omega
  rw [hset]
  have := exp_sum_Ico_min_bound ќ≤ 1 (M + 1)
  have hM : (M + 1 - 1 : вДХ) = M := by omega
  rwa [hM] at this

/-- **Near-integer points are large** (tight min-sum keystone): if `hќ±` is within
    `1/(2q)` of an integer then `2h > q`. Contrapositive: for `0 < h вЙ§ q/2`,
    `q вИ§ ha` forces `вАЦha/qвАЦ вЙ• 1/q`, and the `вЙ§ 1/(2q)` perturbation from
    `|ќ±вИТa/q| вЙ§ 1/q¬≤` leaves `вАЦhќ±вАЦ вЙ• 1/(2q)`. -/
lemma nearint_h_lower (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (h : вДХ) (hh0 : 0 < h) (hhq : 2 * h вЙ§ q) :
    1 / (2 * (q : вДЭ)) вЙ§ |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| := by
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  -- q вИ§ h*a (in вДХ, via coprimality)
  have hnd : ¬ђ (q : вД§) вИ£ ((h * a : вДХ) : вД§) := by
    rw [Int.natCast_dvd_natCast]
    intro hdvd
    have hqh : q вИ£ h := (ha.symm).dvd_of_dvd_mul_right hdvd
    exact absurd (Nat.le_of_dvd hh0 hqh) (by omega)
  -- вАЦha/qвАЦ вЙ• 1/q
  have hbase : 1 / (q : вДЭ) вЙ§ |((h * a : вДХ) : вДЭ) / q - round (((h * a : вДХ) : вДЭ) / q)| :=
    dist_int_div_ge ((h * a : вДХ) : вД§) q (by omega) hnd
  have hcast : (((h * a : вДХ) : вДЭ) / q) = (h : вДЭ) * ((a : вДЭ) / q) := by
    push_cast
    ring
  rw [hcast] at hbase
  -- perturbation: |h(a/q) вИТ hќ±| вЙ§ h/q¬≤ вЙ§ 1/(2q)
  have hpert : |(h : вДЭ) * ((a : вДЭ) / q) - (h : вДЭ) * ќ±| вЙ§ 1 / (2 * (q : вДЭ)) := by
    rw [вЖР mul_sub, abs_mul, abs_of_nonneg (by positivity : (0:вДЭ) вЙ§ (h:вДЭ))]
    rw [abs_sub_comm]
    have h1 : (h : вДЭ) * |ќ± - (a : вДЭ) / q| вЙ§ (h : вДЭ) * (1 / (q : вДЭ) ^ 2) :=
      mul_le_mul_of_nonneg_left hќ± (by positivity)
    have h2 : (h : вДЭ) * (1 / (q : вДЭ) ^ 2) вЙ§ 1 / (2 * (q : вДЭ)) := by
      rw [mul_one_div, div_le_div_iffвВА (by positivity) (by positivity)]
      have h3 : (2 : вДЭ) * h вЙ§ q := by exact_mod_cast hhq
      nlinarith [hqR]
    linarith
  -- combine via 1-Lipschitz dist: вАЦh(a/q)вАЦ вЙ§ |h(a/q) вИТ hќ±| + вАЦhќ±вАЦ
  have hlip := dist_round_le ((h : вДЭ) * ((a : вДЭ) / q)) ((h : вДЭ) * ќ±)
  have hbridge : 1 / (2 * (q : вДЭ)) = (1 / (q : вДЭ)) - 1 / (2 * (q : вДЭ)) := by
    field_simp
    ring
  linarith [hbase, hpert, hlip, hbridge]

/-- Distance to вД§ is subadditive under subtraction. -/
lemma dist_round_sub_le (x y : вДЭ) :
    |(x - y) - round (x - y)| вЙ§ |x - round x| + |y - round y| := by
  calc |(x - y) - round (x - y)|
      вЙ§ |(x - y) - ((round x : вД§) - (round y : вД§) : вД§)| :=
        round_le (x - y) ((round x : вД§) - (round y : вД§))
    _ = |(x - round x) + (-(y - round y))| := by push_cast; ring_nf
    _ вЙ§ |x - round x| + |-(y - round y)| := abs_add_le _ _
    _ = |x - round x| + |y - round y| := by rw [abs_neg]

/-- **Resonant points are `q/2`-separated**: two distinct near-integer (`< 1/(4q)`)
    points `h' < h` differ by more than `q/2`, so `вМК2h/qвМЛ вЙ† вМК2h'/qвМЛ`. -/
lemma resonant_spaced (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2)
    (h h' : вДХ) (hh'0 : 0 < h') (hlt : h' < h)
    (hres : |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ)))
    (hres' : |(h' : вДЭ) * ќ± - round ((h' : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ))) :
    q < 2 * (h - h') := by
  by_contra hcon
  push_neg at hcon
  set d : вДХ := h - h' with hd
  have hd0 : 0 < d := by omega
  have hdq : 2 * d вЙ§ q := hcon
  have hdcast : (d : вДЭ) * ќ± = (h : вДЭ) * ќ± - (h' : вДЭ) * ќ± := by
    rw [hd, Nat.cast_sub hlt.le]
    ring
  have hsub := dist_round_sub_le ((h : вДЭ) * ќ±) ((h' : вДЭ) * ќ±)
  rw [вЖР hdcast] at hsub
  have hlow := nearint_h_lower a q hq ha ќ± hќ± d hd0 hdq
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  have hbridge : 1 / (2 * (q : вДЭ)) = 1 / (4 * (q : вДЭ)) + 1 / (4 * (q : вДЭ)) := by
    field_simp
    ring
  linarith [hlow, hsub, hres, hres', hbridge]

/-- **The resonant floor sum has no bare `N`** (the key to killing the spurious `4N`):
    the near-integer `h` (bin `ѕЖ h = 2h/q вЙ• 1`, `ѕЖ` injective by `resonant_spaced`)
    satisfy `вМКN/hвМЛ вЙ§ 2N/(q¬ЈѕЖ h)`, so their sum telescopes to `(2N/q)¬Јharmonic`. -/
lemma resonant_floor_sum_le (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (N H : вДХ) :
    вИС h вИИ (Finset.Ioc 0 H).filter
        (fun h : вДХ => |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ))),
        ((N / h : вДХ) : вДЭ)
      вЙ§ (2 * (N : вДЭ) / q) * (1 + Real.log H) := by
  classical
  have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
  set R := (Finset.Ioc 0 H).filter
      (fun h : вДХ => |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ))) with hR
  set ѕЖ : вДХ вЖТ вДХ := fun h => 2 * h / q with hѕЖ
  have hѕЖe : вИА x : вДХ, ѕЖ x = 2 * x / q := fun _ => rfl
  -- membership + resonance facts
  have hmem : вИА h вИИ R, 0 < h вИІ h вЙ§ H вИІ
      |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ)) := by
    intro h hh
    rw [hR, Finset.mem_filter, Finset.mem_Ioc] at hh
    exact вЯ®hh.1.1, hh.1.2, hh.2вЯ©
  have hbig : вИА h вИИ R, q < 2 * h := by
    intro h hh
    obtain вЯ®hh0, _, hresвЯ© := hmem h hh
    by_contra hc
    push_neg at hc
    have hlow := nearint_h_lower a q hq ha ќ± hќ± h hh0 hc
    have : (1 : вДЭ) / (2 * q) вЙ§ 1 / (4 * q) := le_trans hlow hres.le
    rw [div_le_div_iffвВА (by positivity) (by positivity)] at this
    linarith
  have hѕЖpos : вИА h вИИ R, 1 вЙ§ ѕЖ h := by
    intro h hh
    have hh2 := hbig h hh
    rw [hѕЖe]
    exact (Nat.one_le_div_iff (show 0 < q by omega)).mpr (by omega)
  -- ѕЖ is injective on R (resonant_spaced вЯє bins strictly increase)
  have hinj : Set.InjOn ѕЖ (R : Set вДХ) := by
    intro hвВБ hhвВБ hвВВ hhвВВ hfe
    rcases lt_trichotomy hвВБ hвВВ with hlt | heq | hgt
    ¬Ј exfalso
      obtain вЯ®hhвВБ0, _, hrвВБвЯ© := hmem hвВБ (Finset.mem_coe.mp hhвВБ)
      obtain вЯ®_, _, hrвВВвЯ© := hmem hвВВ (Finset.mem_coe.mp hhвВВ)
      have hsp := resonant_spaced a q hq ha ќ± hќ± hвВВ hвВБ hhвВБ0 hlt hrвВВ hrвВБ
      have hge : 2 * hвВБ + q вЙ§ 2 * hвВВ := by omega
      have hk : 2 * hвВБ / q + 1 = (2 * hвВБ + q) / q :=
        (Nat.add_div_right (2 * hвВБ) (show 0 < q by omega)).symm
      have hle : (2 * hвВБ + q) / q вЙ§ 2 * hвВВ / q := Nat.div_le_div_right hge
      have hbin : ѕЖ hвВБ < ѕЖ hвВВ := by rw [hѕЖe, hѕЖe]; omega
      omega
    ¬Ј exact heq
    ¬Ј exfalso
      obtain вЯ®_, _, hrвВБвЯ© := hmem hвВБ (Finset.mem_coe.mp hhвВБ)
      obtain вЯ®hhвВВ0, _, hrвВВвЯ© := hmem hвВВ (Finset.mem_coe.mp hhвВВ)
      have hsp := resonant_spaced a q hq ha ќ± hќ± hвВБ hвВВ hhвВВ0 hgt hrвВБ hrвВВ
      have hge : 2 * hвВВ + q вЙ§ 2 * hвВБ := by omega
      have hk : 2 * hвВВ / q + 1 = (2 * hвВВ + q) / q :=
        (Nat.add_div_right (2 * hвВВ) (show 0 < q by omega)).symm
      have hle : (2 * hвВВ + q) / q вЙ§ 2 * hвВБ / q := Nat.div_le_div_right hge
      have hbin : ѕЖ hвВВ < ѕЖ hвВБ := by rw [hѕЖe, hѕЖe]; omega
      omega
  -- termwise: вМКN/hвМЛ вЙ§ 2N/(q¬ЈѕЖ h)
  have hterm : вИА h вИИ R, ((N / h : вДХ) : вДЭ) вЙ§ (2 * (N : вДЭ) / q) * (1 / (ѕЖ h : вДЭ)) := by
    intro h hh
    obtain вЯ®hh0, _, _вЯ© := hmem h hh
    have hѕЖ1 := hѕЖpos h hh
    have hѕЖ0 : (0 : вДЭ) < (ѕЖ h : вДЭ) := by exact_mod_cast hѕЖ1
    have hqѕЖ : (q : вДЭ) * (ѕЖ h : вДЭ) вЙ§ 2 * (h : вДЭ) := by
      have := Nat.div_mul_le_self (2 * h) q
      rw [hѕЖe]
      have hcast : ((2 * h / q : вДХ) * q : вДХ) вЙ§ 2 * h := this
      have : ((2 * h / q : вДХ) : вДЭ) * (q : вДЭ) вЙ§ 2 * (h : вДЭ) := by exact_mod_cast hcast
      nlinarith [this]
    have hNh : ((N / h : вДХ) : вДЭ) вЙ§ (N : вДЭ) / (h : вДЭ) := by
      rw [le_div_iffвВА (by exact_mod_cast hh0)]
      have := Nat.div_mul_le_self N h
      have : ((N / h : вДХ) * h : вДХ) вЙ§ N := this
      exact_mod_cast this
    have hhpos : (0 : вДЭ) < (h : вДЭ) := by exact_mod_cast hh0
    have hNn : (0:вДЭ) вЙ§ (N:вДЭ) := by positivity
    have hbound : (N : вДЭ) / (h : вДЭ) вЙ§ (2 * (N : вДЭ) / q) * (1 / (ѕЖ h : вДЭ)) := by
      rw [show (2 * (N : вДЭ) / q) * (1 / (ѕЖ h : вДЭ)) = (2 * (N:вДЭ)) / (q * (ѕЖ h : вДЭ)) from by
        field_simp, div_le_div_iffвВА hhpos (by positivity)]
      nlinarith [hqѕЖ, hNn, hhpos, hqR, hѕЖ0]
    linarith
  calc вИС h вИИ R, ((N / h : вДХ) : вДЭ)
      вЙ§ вИС h вИИ R, (2 * (N : вДЭ) / q) * (1 / (ѕЖ h : вДЭ)) := Finset.sum_le_sum hterm
    _ = (2 * (N : вДЭ) / q) * вИС h вИИ R, (1 / (ѕЖ h : вДЭ)) := by rw [Finset.mul_sum]
    _ = (2 * (N : вДЭ) / q) * вИС b вИИ R.image ѕЖ, (1 / (b : вДЭ)) := by
        rw [Finset.sum_image (fun x hx y hy => hinj (Finset.mem_coe.mpr hx)
          (Finset.mem_coe.mpr hy))]
    _ вЙ§ (2 * (N : вДЭ) / q) * вИС b вИИ Finset.Icc 1 H, (1 / (b : вДЭ)) := by
        apply mul_le_mul_of_nonneg_left ?_ (by positivity)
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro b hb
          rw [Finset.mem_image] at hb
          obtain вЯ®h, hhR, rflвЯ© := hb
          obtain вЯ®hh0, hhH, _вЯ© := hmem h hhR
          rw [Finset.mem_Icc]
          refine вЯ®hѕЖpos h hhR, ?_вЯ©
          rw [hѕЖe]
          have hhle : 2 * h / q вЙ§ h :=
            Nat.div_le_of_le_mul (by nlinarith [hq])
          omega
        ¬Ј intro b _ _
          positivity
    _ вЙ§ (2 * (N : вДЭ) / q) * (1 + Real.log H) := by
        apply mul_le_mul_of_nonneg_left ?_ (by positivity)
        calc вИС b вИИ Finset.Icc 1 H, (1 / (b : вДЭ)) вЙ§ 1 + Real.log H := sum_one_div_le H

/-- **The tight min-sum bound** (replaces `dyadic_cap_sum_le`, NO bare `N`):
    `вИС_{hвЙ§H} min(вМКN/hвМЛ, 1/2вАЦhќ±вАЦ) вЙ§ (2N/q)(1+log H) + (2H/q+1)(4q + 4q(1+log 2q))`.
    Resonant `h` (near-integer) contribute `(2N/q)¬Јharmonic` (via
    `resonant_floor_sum_le`); non-resonant `h` route through `range_min_sum_le`
    with cap `V = 2q` (since `1/2вАЦhќ±вАЦ вЙ§ 2q` there). -/
lemma min_sum_tight (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (N H : вДХ) :
    вИС h вИИ Finset.Ioc 0 H,
      (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / h : вДХ) : вДЭ)
       else min ((N / h : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)))
      вЙ§ (2 * (N : вДЭ) / q) * (1 + Real.log H)
        + ((H / (q / 2) + 1 : вДХ) : вДЭ) * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))) := by
  classical
  set res : вДХ вЖТ Prop := fun h => |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| < 1 / (4 * (q : вДЭ))
    with hres
  rw [вЖР Finset.sum_filter_add_sum_filter_not (Finset.Ioc 0 H) res]
  apply add_le_add
  ¬Ј -- resonant half: each term вЙ§ вМКN/hвМЛ
    refine le_trans (Finset.sum_le_sum ?_)
      (resonant_floor_sum_le a q hq ha ќ± hќ± N H)
    intro h _
    split
    ¬Ј exact le_refl _
    ¬Ј exact min_le_left _ _
  ¬Ј -- non-resonant half: route through range_min_sum_le at V = 2q
    have hqR : (0 : вДЭ) < (q : вДЭ) := by exact_mod_cast (by omega : 0 < q)
    have hIoc : Finset.Ioc 0 H = Finset.Ico 1 (1 + H) := by
      ext x; simp only [Finset.mem_Ioc, Finset.mem_Ico]; omega
    have hrange := range_min_sum_le a q hq ha ќ± hќ± (2 * (q : вДЭ)) (by positivity) 1 H
    rw [show (1 : вДХ) + H = 1 + H from rfl] at hrange
    -- termwise: non-res term вЙ§ range-term (V = 2q); then superset + Ioc=Ico
    calc вИС h вИИ (Finset.Ioc 0 H).filter (fun h => ¬ђ res h),
          (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / h : вДХ) : вДЭ)
           else min ((N / h : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)))
        вЙ§ вИС h вИИ (Finset.Ioc 0 H).filter (fun h => ¬ђ res h),
            (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then 2 * (q : вДЭ)
             else min (2 * (q : вДЭ)) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) := by
          apply Finset.sum_le_sum
          intro h hh
          rw [Finset.mem_filter] at hh
          have hnr : ¬ђ res h := hh.2
          rw [hres] at hnr
          push_neg at hnr
          -- вАЦhќ±вАЦ вЙ• 1/(4q) > 0 so the `= 0` branch is false; cap вЙ§ 2q
          have habs : 1 / (4 * (q : вДЭ)) вЙ§ |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| := hnr
          have hne : (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) вЙ† 0 := by
            intro h0
            rw [h0, abs_zero] at habs
            have : (0:вДЭ) < 1 / (4 * (q : вДЭ)) := by positivity
            linarith
          rw [if_neg hne, if_neg hne]
          have hcaple : 1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|) вЙ§ 2 * (q : вДЭ) := by
            rw [div_le_iffвВА (by positivity)]
            have habspos : 0 < |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)| := by
              rw [abs_pos]; exact hne
            rw [div_le_iffвВА (by positivity)] at habs
            nlinarith [habs, hqR]
          calc min ((N / h : вДХ) : вДЭ) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))
              вЙ§ 1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|) := min_le_right _ _
            _ = min (2 * (q : вДЭ)) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|)) := by
                rw [min_eq_right hcaple]
      _ вЙ§ вИС h вИИ Finset.Ioc 0 H,
            (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then 2 * (q : вДЭ)
             else min (2 * (q : вДЭ)) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg (Finset.filter_subset _ _)
          intro h _ _
          split
          ¬Ј positivity
          ¬Ј exact le_min (by positivity) (by positivity)
      _ = вИС h вИИ Finset.Ico 1 (1 + H),
            (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then 2 * (q : вДЭ)
             else min (2 * (q : вДЭ)) (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) := by
          rw [hIoc]
      _ вЙ§ ((H / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q))) := hrange


lemma S2_bound (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V
            * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ Real.log (U * V) *
          (((Nat.log 2 (U * V) + 1 : вДХ) : вДЭ)
              * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
            + 32 * (U * V) * (1 + Real.log (2 * q)) + 4 * N) := by
  set c : ArithmeticFunction вДЭ := truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V with hc
  have hlogUV0 : (0 : вДЭ) вЙ§ Real.log (U * V) := by
    apply Real.log_nonneg
    exact_mod_cast hUV1
  -- regroup + collapse ќґ + normalize the e-argument
  have hre : вИС n вИИ Finset.Ioc 0 N,
      ((c * (ќґ : ArithmeticFunction вДЭ)) n : вДВ) * e ((n : вДЭ) * ќ±)
      = вИС t вИИ Finset.Ioc 0 N, (c t : вДВ) *
          вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±)) := by
    rw [sum_Ioc_mul_weight_eq_sum_sum c (ќґ : ArithmeticFunction вДЭ)
      (fun n => e ((n : вДЭ) * ќ±)) N]
    apply Finset.sum_congr rfl
    intro t _
    congr 1
    rw [sum_Ioc_zeta_mul (fun m => e (((t * m : вДХ) : вДЭ) * ќ±)) (N / t)]
    apply Finset.sum_congr rfl
    intro m _
    exact congrArg e (by push_cast; ring)
  rw [hre]
  -- cap the sum over the support
  set cap : вДХ вЖТ вДЭ := fun t =>
    (if (t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±) = 0 then ((N / t : вДХ) : вДЭ)
     else min ((N / t : вДХ) : вДЭ) (1 / (2 * |(t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±)|))) with hcap
  have hcap0 : вИА t, 0 вЙ§ cap t := by
    intro t
    rw [hcap]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  have hterm : вИА t вИИ Finset.Ioc 0 N,
      вАЦ(c t : вДВ) * вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ
      вЙ§ (if t вЙ§ U * V then Real.log (U * V) * cap t else 0) := by
    intro t ht
    simp only [Finset.mem_Ioc] at ht
    by_cases htuv : t вЙ§ U * V
    ¬Ј rw [if_pos htuv, norm_mul, Complex.norm_real, Real.norm_eq_abs]
      have h1 : |c t| вЙ§ Real.log (U * V) := by
        calc |c t| вЙ§ Real.log t := abs_truncate_mul_le_log U V t
          _ вЙ§ Real.log (U * V) := by
            apply Real.log_le_log (by exact_mod_cast ht.1)
            exact_mod_cast htuv
      have h2 : вАЦвИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ вЙ§ cap t := by
        rw [hcap]
        exact exp_sum_Ioc_min_bound ((t : вДЭ) * ќ±) (N / t)
      exact mul_le_mul h1 h2 (norm_nonneg _) hlogUV0
    ¬Ј rw [if_neg htuv]
      push_neg at htuv
      have hz : c t = 0 := truncate_mul_eq_zero_of_gt _ _ U V t htuv
      rw [hz]
      simp
  calc вАЦвИС t вИИ Finset.Ioc 0 N, (c t : вДВ) *
        вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ
      вЙ§ вИС t вИИ Finset.Ioc 0 N,
          вАЦ(c t : вДВ) * вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС t вИИ Finset.Ioc 0 N, (if t вЙ§ U * V then Real.log (U * V) * cap t else 0) :=
        Finset.sum_le_sum hterm
    _ = вИС t вИИ Finset.Ioc 0 (U * V), Real.log (U * V) * cap t := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_congr _ (fun t _ => rfl)
        ext t
        simp only [Finset.mem_filter, Finset.mem_Ioc]
        constructor
        ¬Ј rintro вЯ®вЯ®h1, _вЯ©, h3вЯ©
          exact вЯ®h1, h3вЯ©
        ¬Ј rintro вЯ®h1, h2вЯ©
          exact вЯ®вЯ®h1, le_trans h2 hUVвЯ©, h2вЯ©
    _ = Real.log (U * V) * вИС t вИИ Finset.Ioc 0 (U * V), cap t := (Finset.mul_sum _ _ _).symm
    _ вЙ§ Real.log (U * V) *
        (((Nat.log 2 (U * V) + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
          + 32 * (U * V) * (1 + Real.log (2 * q)) + 4 * N) := by
        apply mul_le_mul_of_nonneg_left _ hlogUV0
        have := dyadic_cap_sum_le a q hq ha ќ± hќ± N (U * V)
        rw [hcap]
        push_cast at this вКҐ
        exact this

/-- `log` of a natural cast is nonneg (`log 0 = 0`). -/
lemma log_natCast_nonneg (m : вДХ) : 0 вЙ§ Real.log m := by
  rcases Nat.eq_zero_or_pos m with h | h
  ¬Ј subst h; simp
  ¬Ј rcases Nat.eq_or_lt_of_le h with h1 | h1
    ¬Ј rw [вЖР h1]; simp
    ¬Ј exact Real.log_nonneg (by exact_mod_cast h1.le)

/-- `log вИШ (вЖС¬Ј)` is monotone on вДХ. -/
lemma log_natCast_monotone : Monotone (fun m : вДХ => Real.log m) := by
  intro mвВБ mвВВ h
  rcases Nat.eq_zero_or_pos mвВБ with h1 | h1
  ¬Ј subst h1
    simp only [Nat.cast_zero, Real.log_zero]
    exact log_natCast_nonneg mвВВ
  ¬Ј exact Real.log_le_log (by exact_mod_cast h1) (by exact_mod_cast h)

/-- The min-cap grows by at most 1 when the size cap grows by 1. -/
lemma cap_succ_le (ќ≤ : вДЭ) (M : вДХ) :
    (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
     else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|)))
    вЙ§ (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
       else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) + 1 := by
  split
  ¬Ј push_cast; linarith
  ¬Ј have h1 : min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))
        вЙ§ min ((M : вДЭ) + 1) (1 / (2 * |ќ≤ - round ќ≤|) + 1) := by
      apply min_le_min _ (by linarith)
      push_cast
      linarith
    calc min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))
        вЙ§ min ((M : вДЭ) + 1) (1 / (2 * |ќ≤ - round ќ≤|) + 1) := h1
      _ = min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|)) + 1 := by
          rw [вЖР min_add_add_right]

/-- **THE SвВБ BOUND**: the log-weighted Vaughan piece. -/
lemma S1_bound (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U N : вДХ) (hU : U вЙ§ N) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((truncate (ќЉ : ArithmeticFunction вДЭ) U * ArithmeticFunction.log) n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) *
          ((((Nat.log 2 U + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
            + 32 * U * (1 + Real.log (2 * q)) + 4 * N) + U) := by
  have hlogN0 : (0 : вДЭ) вЙ§ Real.log (N + 1) := by
    apply Real.log_nonneg
    push_cast
    linarith
  set cap : вДХ вЖТ вДЭ := fun t =>
    (if (t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±) = 0 then ((N / t : вДХ) : вДЭ)
     else min ((N / t : вДХ) : вДЭ) (1 / (2 * |(t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±)|))) with hcap
  have hcap0 : вИА t, 0 вЙ§ cap t := by
    intro t
    rw [hcap]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  -- regroup
  rw [sum_Ioc_mul_weight_eq_sum_sum (truncate (ќЉ : ArithmeticFunction вДЭ) U)
    ArithmeticFunction.log (fun n => e ((n : вДЭ) * ќ±)) N]
  -- per-d inner bound
  have hinner : вИА d вИИ Finset.Ioc 0 N,
      вАЦвИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) * (cap d + 1) := by
    intro d hd
    simp only [Finset.mem_Ioc] at hd
    set M : вДХ := N / d with hM
    set ќ≤ : вДЭ := (d : вДЭ) * ќ± with hќ≤
    -- normalize the argument and the log
    have hstep1 : вИС m вИИ Finset.Ioc 0 M, ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)
        = вИС m вИИ Finset.Ioc 0 M, ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_congr rfl
      intro m _
      rw [ArithmeticFunction.log_apply]
      congr 1
      exact congrArg e (by rw [hќ≤]; push_cast; ring)
    -- extend Ioc 0 M to range (M+1) (the m = 0 term vanishes)
    have hstep2 : вИС m вИИ Finset.Ioc 0 M, ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)
        = вИС m вИИ Finset.range (M + 1), ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_subset
      ¬Ј intro m hm
        simp only [Finset.mem_Ioc] at hm
        simp only [Finset.mem_range]
        omega
      ¬Ј intro m hm hnotm
        simp only [Finset.mem_range] at hm
        simp only [Finset.mem_Ioc] at hnotm
        have hm0 : m = 0 := by omega
        subst hm0
        simp
    -- the capped weight agrees with log on the range
    have hstep3 : вИС m вИИ Finset.range (M + 1), ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)
        = вИС m вИИ Finset.range (M + 1),
            ((Real.log ((min m (M + 1) : вДХ) : вДЭ) : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_range] at hm
      rw [min_eq_left (by omega : m вЙ§ M + 1)]
    have habel := abel_exp_sum (fun m => Real.log ((min m (M + 1) : вДХ) : вДЭ))
      (fun m => log_natCast_nonneg _)
      (by
        intro x y h
        exact log_natCast_monotone (by omega : min x (M + 1) вЙ§ min y (M + 1)))
      (Real.log ((M + 1 : вДХ) : вДЭ))
      (fun m => by exact log_natCast_monotone (min_le_right m (M + 1)))
      ќ≤ (M + 1)
    have hlogM : Real.log ((M + 1 : вДХ) : вДЭ) вЙ§ Real.log (N + 1) := by
      have h1 : (M : вДХ) + 1 вЙ§ N + 1 := by
        have : M вЙ§ N := hM вЦЄ Nat.div_le_self N d
        omega
      have := log_natCast_monotone (show (M + 1 : вДХ) вЙ§ (N + 1 : вДХ) from h1)
      push_cast at this вКҐ
      exact this
    have hcapd : (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
        else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) вЙ§ cap d + 1 := by
      have h1 := cap_succ_le ќ≤ M
      have h2 : (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
          else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) = cap d := by
        rw [hcap, hќ≤, hM]
      rw [h2] at h1
      exact h1
    have hcapnn : (0 : вДЭ) вЙ§ (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
        else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
      split
      ¬Ј positivity
      ¬Ј exact le_min (by positivity) (by positivity)
    calc вАЦвИС m вИИ Finset.Ioc 0 M, ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
        = вАЦвИС m вИИ Finset.range (M + 1),
            ((Real.log ((min m (M + 1) : вДХ) : вДЭ) : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)вАЦ := by
          rw [hstep1, hstep2, hstep3]
      _ вЙ§ 2 * Real.log ((M + 1 : вДХ) : вДЭ)
            * (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
               else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
          have := habel
          push_cast at this вКҐ
          exact this
      _ вЙ§ 2 * Real.log (N + 1) * (cap d + 1) := by
          apply mul_le_mul
          ¬Ј have : (0:вДЭ) вЙ§ 2 := by norm_num
            nlinarith [hlogM]
          ¬Ј exact hcapd
          ¬Ј exact hcapnn
          ¬Ј positivity
  -- support + assembly
  have hterm : вИА d вИИ Finset.Ioc 0 N,
      вАЦ(truncate (ќЉ : ArithmeticFunction вДЭ) U d : вДВ) *
        вИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
      вЙ§ (if d вЙ§ U then 2 * Real.log (N + 1) * (cap d + 1) else 0) := by
    intro d hd
    by_cases hdU : d вЙ§ U
    ¬Ј rw [if_pos hdU, norm_mul, Complex.norm_real, Real.norm_eq_abs]
      calc |truncate (ќЉ : ArithmeticFunction вДЭ) U d| *
            вАЦвИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
              * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
          вЙ§ 1 * (2 * Real.log (N + 1) * (cap d + 1)) := by
            apply mul_le_mul (abs_truncate_moebius_le_one U d) (hinner d hd)
              (norm_nonneg _) (by norm_num)
        _ = 2 * Real.log (N + 1) * (cap d + 1) := one_mul _
    ¬Ј rw [if_neg hdU]
      have hz : truncate (ќЉ : ArithmeticFunction вДЭ) U d = 0 := by
        rw [truncate_apply, if_neg hdU]
      rw [hz]
      simp
  calc вАЦвИС d вИИ Finset.Ioc 0 N, (truncate (ќЉ : ArithmeticFunction вДЭ) U d : вДВ) *
        вИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
      вЙ§ вИС d вИИ Finset.Ioc 0 N,
          вАЦ(truncate (ќЉ : ArithmeticFunction вДЭ) U d : вДВ) *
            вИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
              * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ := norm_sum_le _ _
    _ вЙ§ вИС d вИИ Finset.Ioc 0 N, (if d вЙ§ U then 2 * Real.log (N + 1) * (cap d + 1) else 0) :=
        Finset.sum_le_sum hterm
    _ = вИС d вИИ Finset.Ioc 0 U, 2 * Real.log (N + 1) * (cap d + 1) := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_congr _ (fun t _ => rfl)
        ext t
        simp only [Finset.mem_filter, Finset.mem_Ioc]
        constructor
        ¬Ј rintro вЯ®вЯ®h1, _вЯ©, h3вЯ©
          exact вЯ®h1, h3вЯ©
        ¬Ј rintro вЯ®h1, h2вЯ©
          exact вЯ®вЯ®h1, le_trans h2 hUвЯ©, h2вЯ©
    _ = 2 * Real.log (N + 1) * (вИС d вИИ Finset.Ioc 0 U, cap d + U) := by
        have hsplit : вИА d вИИ Finset.Ioc 0 U,
            2 * Real.log (N + 1) * (cap d + 1)
            = 2 * Real.log (N + 1) * cap d + 2 * Real.log (N + 1) := fun d _ => by ring
        rw [Finset.sum_congr rfl hsplit, Finset.sum_add_distrib, вЖР Finset.mul_sum,
          Finset.sum_const, Nat.card_Ioc, Nat.sub_zero, nsmul_eq_mul]
        push_cast
        ring
    _ вЙ§ 2 * Real.log (N + 1) *
        ((((Nat.log 2 U + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
          + 32 * U * (1 + Real.log (2 * q)) + 4 * N) + U) := by
        apply mul_le_mul_of_nonneg_left _ (by linarith)
        have hd := dyadic_cap_sum_le a q hq ha ќ± hќ± N U
        have hsum : вИС d вИИ Finset.Ioc 0 U, cap d
            вЙ§ ((Nat.log 2 U + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
              + 32 * U * (1 + Real.log (2 * q)) + 4 * N := by
          calc вИС d вИИ Finset.Ioc 0 U, cap d
              = вИС h вИИ Finset.Ioc 0 U,
                  (if (h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±) = 0 then ((N / h : вДХ) : вДЭ)
                   else min ((N / h : вДХ) : вДЭ)
                     (1 / (2 * |(h : вДЭ) * ќ± - round ((h : вДЭ) * ќ±)|))) := by
                apply Finset.sum_congr rfl
                intro h _
                rw [hcap]
            _ вЙ§ _ := hd
        linarith

/-- Pointwise subtraction for arithmetic functions (no `sub_apply` in Mathlib). -/
lemma sub_apply' (f g : ArithmeticFunction вДЭ) (n : вДХ) : (f - g) n = f n - g n := by
  have h : f - g = f + -g := sub_eq_add_neg f g
  rw [h, ArithmeticFunction.add_apply, ArithmeticFunction.neg_apply]
  ring

/-- The SвВД inner factor `g = (ќЫ вИТ ќЫ_{вЙ§V}) вИЧ ќґ` is nonneg. -/
lemma tail_conv_nonneg (V m : вДХ) :
    0 вЙ§ ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ)) m := by
  rw [ArithmeticFunction.mul_apply]
  apply Finset.sum_nonneg
  intro x _
  apply mul_nonneg
  ¬Ј rw [sub_apply']
    have h1 : truncate ќЫ V x.1 вЙ§ ќЫ x.1 := by
      rw [truncate_apply]
      split
      ¬Ј exact le_refl _
      ¬Ј exact vonMangoldt_nonneg
    linarith
  ¬Ј rw [ArithmeticFunction.natCoe_apply, ArithmeticFunction.zeta_apply]
    split
    ¬Ј norm_num
    ¬Ј norm_num

/-- The SвВД inner factor is log-bounded: `g(m) вЙ§ log m`. -/
lemma tail_conv_le_log (V m : вДХ) :
    ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ)) m вЙ§ Real.log m := by
  rw [ArithmeticFunction.mul_apply]
  calc вИС x вИИ m.divisorsAntidiagonal, (ќЫ - truncate ќЫ V) x.1 * (ќґ : ArithmeticFunction вДЭ) x.2
      вЙ§ вИС x вИИ m.divisorsAntidiagonal, ќЫ x.1 := by
        apply Finset.sum_le_sum
        intro x hx
        rw [Nat.mem_divisorsAntidiagonal] at hx
        have hz : ((ќґ : ArithmeticFunction вДЭ) x.2) = 1 := by
          rw [ArithmeticFunction.natCoe_apply, ArithmeticFunction.zeta_apply,
            if_neg (by
              intro hc
              apply hx.2
              rw [вЖР hx.1, hc, mul_zero])]
          norm_num
        rw [hz, mul_one, sub_apply']
        have h1 : 0 вЙ§ truncate ќЫ V x.1 := by
          rw [truncate_apply]
          split
          ¬Ј exact vonMangoldt_nonneg
          ¬Ј exact le_refl 0
        linarith
    _ = вИС d вИИ m.divisors, ќЫ d := Nat.sum_divisorsAntidiagonal (f := fun d _ => ќЫ d)
    _ = Real.log m := vonMangoldt_sum

/-- The SвВД inner factor vanishes below the truncation: `g(m) = 0` for `m вЙ§ V`. -/
lemma tail_conv_eq_zero_of_le (V m : вДХ) (hm : m вЙ§ V) :
    ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ)) m = 0 := by
  rw [ArithmeticFunction.mul_apply]
  apply Finset.sum_eq_zero
  intro x hx
  rw [Nat.mem_divisorsAntidiagonal] at hx
  have hle : x.1 вЙ§ V := by
    have h1 : x.1 вИ£ m := вЯ®x.2, hx.1.symmвЯ©
    have h2 : x.1 вЙ§ m := Nat.le_of_dvd (by omega) h1
    omega
  rw [sub_apply', truncate_apply, if_pos hle, sub_self, zero_mul]

/-- The M√ґbius tail vanishes below the truncation. -/
lemma moebius_tail_eq_zero_of_le (U d : вДХ) (hd : d вЙ§ U) :
    ((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U) d = 0 := by
  rw [sub_apply', truncate_apply, if_pos hd, sub_self]

/-- The M√ґbius tail is sup-bounded by 1. -/
lemma abs_moebius_tail_le_one (U d : вДХ) :
    |((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U) d| вЙ§ 1 := by
  rw [sub_apply', truncate_apply]
  split
  ¬Ј rw [sub_self]
    norm_num
  ¬Ј rw [sub_zero]
    have h := abs_moebius_le_one (n := d)
    rw [ArithmeticFunction.intCoe_apply]
    calc |((ќЉ d : вД§) : вДЭ)| = ((|ќЉ d| : вД§) : вДЭ) := by rw [Int.cast_abs]
      _ вЙ§ 1 := by exact_mod_cast h

/-- **Increasing geometric sum**: `вИС_{t=tвВА}^{T} (вИЪ2)^t вЙ§ 4¬Ј(вИЪ2)^T`. -/
lemma geom_sqrt2_up (tвВА T : вДХ) :
    вИС t вИИ Finset.Icc tвВА T, (Real.sqrt 2) ^ t вЙ§ 4 * (Real.sqrt 2) ^ T := by
  have hr1 : (1 : вДЭ) < Real.sqrt 2 := by
    rw [show (1 : вДЭ) = Real.sqrt 1 from (Real.sqrt_one).symm]
    exact Real.sqrt_lt_sqrt (by norm_num) (by norm_num)
  have hr0 : (0 : вДЭ) < Real.sqrt 2 := by linarith
  -- вИС_{Icc tвВА T} вЙ§ вИС_{range (T+1)}
  have hsub : вИС t вИИ Finset.Icc tвВА T, (Real.sqrt 2) ^ t
      вЙ§ вИС t вИИ Finset.range (T + 1), (Real.sqrt 2) ^ t := by
    apply Finset.sum_le_sum_of_subset_of_nonneg
    ¬Ј intro t ht
      rw [Finset.mem_Icc] at ht
      rw [Finset.mem_range]
      omega
    ¬Ј intro t _ _
      positivity
  have hgeom : вИС t вИИ Finset.range (T + 1), (Real.sqrt 2) ^ t
      = ((Real.sqrt 2) ^ (T + 1) - 1) / (Real.sqrt 2 - 1) :=
    geom_sum_eq (by linarith) (T + 1)
  rw [hgeom] at hsub
  refine hsub.trans ?_
  rw [div_le_iffвВА (by linarith)]
  have hpow : (Real.sqrt 2) ^ (T + 1) = Real.sqrt 2 * (Real.sqrt 2) ^ T := by
    rw [pow_succ]; ring
  -- need вИЪ2 вЙ• 4/3 so that 3вИЪ2 - 4 вЙ• 0
  have hsqrt2ge : (4 / 3 : вДЭ) вЙ§ Real.sqrt 2 := by
    rw [show (4 / 3 : вДЭ) = Real.sqrt ((4/3)^2) from by
      rw [Real.sqrt_sq (by norm_num)]]
    apply Real.sqrt_le_sqrt
    norm_num
  have hpowpos : (0 : вДЭ) < (Real.sqrt 2) ^ T := by positivity
  rw [hpow]
  nlinarith [hpowpos, hsqrt2ge,
    mul_nonneg hpowpos.le (show (0:вДЭ) вЙ§ 3 * Real.sqrt 2 - 4 by nlinarith [hsqrt2ge])]

/-- **Decreasing geometric sum**: `вИС_{t=tвВА}^{T} (вИЪ2)вБїбµЧ вЙ§ 4¬Ј(вИЪ2)^(-tвВА)`
    (stated as `(1/вИЪ2)^t`). -/
lemma geom_sqrt2_down (tвВА T : вДХ) :
    вИС t вИИ Finset.Icc tвВА T, (1 / Real.sqrt 2) ^ t вЙ§ 4 * (1 / Real.sqrt 2) ^ tвВА := by
  have hr1 : (1 : вДЭ) < Real.sqrt 2 := by
    rw [show (1 : вДЭ) = Real.sqrt 1 from (Real.sqrt_one).symm]
    exact Real.sqrt_lt_sqrt (by norm_num) (by norm_num)
  have hr0 : (0 : вДЭ) < Real.sqrt 2 := by linarith
  have hlt1 : (1 / Real.sqrt 2) < 1 := by
    rw [div_lt_one hr0]; exact hr1
  have hnn : (0 : вДЭ) вЙ§ 1 / Real.sqrt 2 := by positivity
  -- shift index: вИС_{t=tвВА}^{T} r^t = r^{tвВА} вИС_{k=0}^{T-tвВА} r^k вЙ§ r^{tвВА} ¬Ј (1/(1-r))
  by_cases hle : tвВА вЙ§ T
  ¬Ј have hIccIco : Finset.Icc tвВА T = Finset.Ico tвВА (T + 1) := by
      ext x; simp only [Finset.mem_Icc, Finset.mem_Ico]; omega
    have hshift : вИС t вИИ Finset.Icc tвВА T, (1 / Real.sqrt 2) ^ t
        = (1 / Real.sqrt 2) ^ tвВА * вИС k вИИ Finset.range (T + 1 - tвВА), (1 / Real.sqrt 2) ^ k := by
      rw [hIccIco, Finset.sum_Ico_eq_sum_range, Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k _
      rw [pow_add]
    rw [hshift]
    have hsqrt2ge : (4 / 3 : вДЭ) вЙ§ Real.sqrt 2 := by
      rw [show (4 / 3 : вДЭ) = Real.sqrt ((4/3)^2) from by
        rw [Real.sqrt_sq (by norm_num)]]
      apply Real.sqrt_le_sqrt
      norm_num
    have hinvle : 1 / Real.sqrt 2 вЙ§ 3 / 4 := by
      rw [div_le_div_iffвВА hr0 (by norm_num)]
      linarith
    have hgeomle : вИС k вИИ Finset.range (T + 1 - tвВА), (1 / Real.sqrt 2) ^ k вЙ§ 4 := by
      have heq := geom_sum_eq (show (1 / Real.sqrt 2) вЙ† 1 from ne_of_lt hlt1) (T + 1 - tвВА)
      rw [heq]
      -- (r^n - 1)/(r - 1) = (1 - r^n)/(1 - r) вЙ§ 1/(1-r) вЙ§ 4
      have hden : (0:вДЭ) < 1 - 1 / Real.sqrt 2 := by linarith
      have hrw : ((1 / Real.sqrt 2) ^ (T + 1 - tвВА) - 1) / (1 / Real.sqrt 2 - 1)
          = (1 - (1 / Real.sqrt 2) ^ (T + 1 - tвВА)) / (1 - 1 / Real.sqrt 2) := by
        rw [div_eq_div_iff (ne_of_lt (by linarith : 1 / Real.sqrt 2 - 1 < 0))
          (ne_of_gt hden)]; ring
      rw [hrw, div_le_iffвВА hden]
      have hp : (0:вДЭ) вЙ§ (1 / Real.sqrt 2) ^ (T + 1 - tвВА) := by positivity
      linarith
    calc (1 / Real.sqrt 2) ^ tвВА * вИС k вИИ Finset.range (T + 1 - tвВА), (1 / Real.sqrt 2) ^ k
        вЙ§ (1 / Real.sqrt 2) ^ tвВА * 4 :=
          mul_le_mul_of_nonneg_left hgeomle (by positivity)
      _ = 4 * (1 / Real.sqrt 2) ^ tвВА := by ring
  ¬Ј rw [Finset.Icc_eq_empty (by omega), Finset.sum_empty]
    positivity

/-- `вИЪ(a+b) вЙ§ вИЪa + вИЪb`. -/
lemma sqrt_add_le' (a b : вДЭ) : Real.sqrt (a + b) вЙ§ Real.sqrt a + Real.sqrt b := by
  have h : Real.sqrt (a + b) вЙ§ Real.sqrt (Real.sqrt a ^ 2 + Real.sqrt b ^ 2 + 2 * (Real.sqrt a * Real.sqrt b)) := by
    apply Real.sqrt_le_sqrt
    by_cases ha : 0 вЙ§ a
    ¬Ј by_cases hb : 0 вЙ§ b
      ¬Ј rw [Real.sq_sqrt ha, Real.sq_sqrt hb]
        nlinarith [Real.sqrt_nonneg a, Real.sqrt_nonneg b, mul_nonneg (Real.sqrt_nonneg a) (Real.sqrt_nonneg b)]
      ¬Ј rw [Real.sqrt_eq_zero_of_nonpos (le_of_lt (not_le.mp hb))]
        rw [Real.sq_sqrt ha]
        simp only [Real.sqrt_zero, mul_zero, add_zero, zero_pow, ne_eq, OfNat.ofNat_ne_zero,
          not_false_eq_true]
        nlinarith [Real.sqrt_nonneg a]
    ¬Ј have : Real.sqrt a = 0 := Real.sqrt_eq_zero_of_nonpos (le_of_lt (not_le.mp ha))
      rw [this]
      simp only [ne_eq, OfNat.ofNat_ne_zero, not_false_eq_true, zero_pow, zero_add, mul_zero,
        add_zero, zero_mul]
      by_cases hb : 0 вЙ§ b
      ¬Ј rw [Real.sq_sqrt hb]; nlinarith [Real.sqrt_nonneg b]
      ¬Ј rw [Real.sqrt_eq_zero_of_nonpos (le_of_lt (not_le.mp hb))]; simp; linarith
  refine h.trans (le_of_eq ?_)
  rw [show Real.sqrt a ^ 2 + Real.sqrt b ^ 2 + 2 * (Real.sqrt a * Real.sqrt b)
      = (Real.sqrt a + Real.sqrt b) ^ 2 from by ring,
    Real.sqrt_sq (by positivity)]

/-- `вИЪ(a+b+c+d) вЙ§ вИЪa+вИЪb+вИЪc+вИЪd`. -/
lemma sqrt_add4_le (a b c d : вДЭ) :
    Real.sqrt (a + b + c + d) вЙ§ Real.sqrt a + Real.sqrt b + Real.sqrt c + Real.sqrt d := by
  calc Real.sqrt (a + b + c + d)
      вЙ§ Real.sqrt (a + b + c) + Real.sqrt d := sqrt_add_le' _ _
    _ вЙ§ (Real.sqrt (a + b) + Real.sqrt c) + Real.sqrt d := by
        gcongr; exact sqrt_add_le' _ _
    _ вЙ§ ((Real.sqrt a + Real.sqrt b) + Real.sqrt c) + Real.sqrt d := by
        gcongr; exact sqrt_add_le' _ _
    _ = Real.sqrt a + Real.sqrt b + Real.sqrt c + Real.sqrt d := by ring

/-- `вИЪ(2^t) = (вИЪ2)^t`. -/
lemma sqrt_two_pow (t : вДХ) : Real.sqrt ((2 : вДЭ) ^ t) = (Real.sqrt 2) ^ t := by
  rw [show ((2 : вДЭ) ^ t) = ((Real.sqrt 2) ^ t) ^ 2 from by
    rw [вЖР pow_mul, mul_comm, pow_mul, Real.sq_sqrt (by norm_num)],
    Real.sqrt_sq (by positivity)]

/-- `(1/вИЪ2)^t = вИЪ(1/2^t)`. -/
lemma sqrt_two_pow_inv (t : вДХ) : (1 / Real.sqrt 2) ^ t = Real.sqrt (1 / (2 : вДЭ) ^ t) := by
  rw [div_pow, one_pow, вЖР sqrt_two_pow, one_div, вЖР Real.sqrt_inv, one_div]

/-- `вИЪ(c¬ЈN¬≤) = вИЪc¬ЈN` for `N вЙ• 0`, `c вЙ• 0`. -/
lemma sqrt_const_mul_sq (c : вДЭ) (hc : 0 вЙ§ c) (N : вДХ) :
    Real.sqrt (c * (N:вДЭ)^2) = Real.sqrt c * N := by
  rw [Real.sqrt_mul hc, Real.sqrt_sq (by positivity)]

/-- **The tight dyadic assembly** (Type-II core): sum the per-block second-moment bounds
    across the dyadic range `[tвВА, Tmax]` via `вИЪ¬Ј` splitting and geometric summation.
    Each of the four terms in the per-block bound sums to a geometric series (the `2^t`
    term increasing, the `1/2^t` term decreasing, the `q` and `N¬≤/q` terms constant),
    giving the four-term envelope on the right. This replaces the lossy `S4_bound`
    dyadic assembly (which over-charged the `2^t` cap to `N`). -/
lemma s4_dyadic_assembly (N q V U tвВА Tmax : вДХ) (hq : 2 вЙ§ q) (hN1 : 1 вЙ§ N) (hU1 : 1 вЙ§ U)
    (ht0T : tвВА вЙ§ Tmax)
    (hUt0 : (U : вДЭ) вЙ§ 2 * (2 : вДЭ) ^ tвВА)
    (hTmaxN : (2 : вДЭ) ^ Tmax вЙ§ (N : вДЭ) / (V + 1))
    (blk : вДХ вЖТ вДЭ) (hblk0 : вИА t, 0 вЙ§ blk t)
    (hbnd : вИА t вИИ Finset.Icc tвВА Tmax,
        blk t ^ 2 вЙ§ (Real.log N) ^ 2 *
          (10 * N * (2:вДЭ)^t + 32 * N^2 / q + 64 * N^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t
            + 36 * N * q * (1 + Real.log (2*q)))) :
    вИС t вИИ Finset.Icc tвВА Tmax, blk t
      вЙ§ Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
          + Real.sqrt 32 * N * ((Tmax - tвВА + 1 : вДХ) : вДЭ) / Real.sqrt q
          + 64 * N * Real.sqrt (1 + Real.log (2*q)) / Real.sqrt U
          + 6 * ((Tmax - tвВА + 1 : вДХ) : вДЭ) * Real.sqrt (N * q * (1 + Real.log (2*q)))) := by
  have hqR : (0:вДЭ) < q := by exact_mod_cast (by omega : 0 < q)
  have hNR : (0:вДЭ) < N := by exact_mod_cast (by omega : 0 < N)
  have hUR : (0:вДЭ) < U := by exact_mod_cast (by omega : 0 < U)
  have hlogN0 : (0:вДЭ) вЙ§ Real.log N := Real.log_nonneg (by exact_mod_cast hN1)
  have hL0 : (0:вДЭ) вЙ§ 1 + Real.log (2*q) := by
    have : (0:вДЭ) вЙ§ Real.log (2*q) := Real.log_nonneg (by
      have : (2:вДЭ) вЙ§ (q:вДЭ) := by exact_mod_cast hq
      linarith)
    linarith
  -- per-block bound
  have hper : вИА t вИИ Finset.Icc tвВА Tmax,
      blk t вЙ§ Real.log N * (Real.sqrt (10 * N) * (Real.sqrt 2)^t
        + Real.sqrt (32 * N^2 / q)
        + Real.sqrt (64 * N^2 * (1 + Real.log (2*q))) * (1 / Real.sqrt 2)^t
        + Real.sqrt (36 * N * q * (1 + Real.log (2*q)))) := by
    intro t ht
    have hb := hbnd t ht
    have hsq : blk t вЙ§ Real.sqrt ((Real.log N) ^ 2 *
        (10 * N * (2:вДЭ)^t + 32 * N^2 / q + 64 * N^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t
          + 36 * N * q * (1 + Real.log (2*q)))) := by
      rw [вЖР Real.sqrt_sq (hblk0 t)]
      exact Real.sqrt_le_sqrt hb
    refine hsq.trans ?_
    rw [Real.sqrt_mul (by positivity), Real.sqrt_sq hlogN0]
    apply mul_le_mul_of_nonneg_left ?_ hlogN0
    have e1 : Real.sqrt (10 * N * (2:вДЭ)^t) = Real.sqrt (10 * N) * (Real.sqrt 2)^t := by
      rw [show (10 * (N:вДЭ) * (2:вДЭ)^t) = (10 * N) * (2:вДЭ)^t from by ring,
        Real.sqrt_mul (by positivity), sqrt_two_pow]
    have e3 : Real.sqrt (64 * N^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t)
        = Real.sqrt (64 * N^2 * (1 + Real.log (2*q))) * (1 / Real.sqrt 2)^t := by
      rw [show (64 * (N:вДЭ)^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t)
          = (64 * N^2 * (1 + Real.log (2*q))) * (1 / (2:вДЭ)^t) from by ring,
        Real.sqrt_mul (by positivity), вЖР sqrt_two_pow_inv]
    calc Real.sqrt (10 * N * (2:вДЭ)^t + 32 * N^2 / q
          + 64 * N^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t + 36 * N * q * (1 + Real.log (2*q)))
        вЙ§ Real.sqrt (10 * N * (2:вДЭ)^t) + Real.sqrt (32 * N^2 / q)
          + Real.sqrt (64 * N^2 * (1 + Real.log (2*q)) / (2:вДЭ)^t)
          + Real.sqrt (36 * N * q * (1 + Real.log (2*q))) := sqrt_add4_le _ _ _ _
      _ = Real.sqrt (10 * N) * (Real.sqrt 2)^t + Real.sqrt (32 * N^2 / q)
          + Real.sqrt (64 * N^2 * (1 + Real.log (2*q))) * (1 / Real.sqrt 2)^t
          + Real.sqrt (36 * N * q * (1 + Real.log (2*q))) := by rw [e1, e3]
  refine (Finset.sum_le_sum hper).trans ?_
  rw [вЖР Finset.mul_sum]
  apply mul_le_mul_of_nonneg_left ?_ hlogN0
  rw [Finset.sum_add_distrib, Finset.sum_add_distrib, Finset.sum_add_distrib,
    вЖР Finset.mul_sum, вЖР Finset.mul_sum, Finset.sum_const, Finset.sum_const,
    Nat.card_Icc, nsmul_eq_mul, nsmul_eq_mul]
  have hcard : ((Tmax + 1 - tвВА : вДХ) : вДЭ) = ((Tmax - tвВА + 1 : вДХ) : вДЭ) := by
    congr 1; omega
  rw [hcard]
  -- P1
  have hP1 : Real.sqrt (10 * N) * (вИС t вИИ Finset.Icc tвВА Tmax, (Real.sqrt 2)^t)
      вЙ§ 4 * Real.sqrt 10 * N / Real.sqrt (V + 1) := by
    refine (mul_le_mul_of_nonneg_left (geom_sqrt2_up tвВА Tmax) (Real.sqrt_nonneg _)).trans ?_
    rw [вЖР sqrt_two_pow]
    have h2 : Real.sqrt ((2:вДЭ)^Tmax) вЙ§ Real.sqrt ((N:вДЭ)/(V+1)) := Real.sqrt_le_sqrt hTmaxN
    have hVpos : (0:вДЭ) < (V:вДЭ) + 1 := by positivity
    calc Real.sqrt (10 * N) * (4 * Real.sqrt ((2:вДЭ)^Tmax))
        вЙ§ Real.sqrt (10 * N) * (4 * Real.sqrt ((N:вДЭ)/(V+1))) := by
          apply mul_le_mul_of_nonneg_left (mul_le_mul_of_nonneg_left h2 (by norm_num))
            (Real.sqrt_nonneg _)
      _ = 4 * Real.sqrt (10 * N * ((N:вДЭ)/(V+1))) := by
          rw [show Real.sqrt (10 * N) * (4 * Real.sqrt ((N:вДЭ)/(V+1)))
              = 4 * (Real.sqrt (10 * N) * Real.sqrt ((N:вДЭ)/(V+1))) from by ring,
            вЖР Real.sqrt_mul (by positivity)]
      _ = 4 * Real.sqrt 10 * N / Real.sqrt (V + 1) := by
          rw [show (10 * (N:вДЭ) * ((N:вДЭ)/(V+1))) = (10 * N^2) / (V+1) from by ring,
            Real.sqrt_div (by positivity), sqrt_const_mul_sq 10 (by norm_num) N]
          ring
  -- P3
  have hP3 : Real.sqrt (64 * N^2 * (1 + Real.log (2*q))) * (вИС t вИИ Finset.Icc tвВА Tmax, (1/Real.sqrt 2)^t)
      вЙ§ 64 * N * Real.sqrt (1 + Real.log (2*q)) / Real.sqrt U := by
    have hs64 : Real.sqrt (64 * N^2 * (1 + Real.log (2*q)))
        = 8 * N * Real.sqrt (1 + Real.log (2*q)) := by
      rw [show (64 * (N:вДЭ)^2 * (1 + Real.log (2*q))) = (8 * N)^2 * (1 + Real.log (2*q)) from by ring,
        Real.sqrt_mul (by positivity), Real.sqrt_sq (by positivity)]
    rw [hs64]
    refine (mul_le_mul_of_nonneg_left (geom_sqrt2_down tвВА Tmax) (by positivity)).trans ?_
    rw [sqrt_two_pow_inv]
    have hkey : Real.sqrt (1 / (2:вДЭ)^tвВА) вЙ§ 2 / Real.sqrt U := by
      have hle : (1:вДЭ) / (2:вДЭ)^tвВА вЙ§ 4 / U := by
        rw [div_le_div_iffвВА (by positivity) hUR]
        nlinarith [hUt0]
      have h4U : Real.sqrt (4 / U) = 2 / Real.sqrt U := by
        rw [Real.sqrt_div (by norm_num), show Real.sqrt 4 = 2 from by
          rw [show (4:вДЭ) = 2^2 from by norm_num, Real.sqrt_sq (by norm_num)]]
      calc Real.sqrt (1 / (2:вДЭ)^tвВА) вЙ§ Real.sqrt (4 / U) := Real.sqrt_le_sqrt hle
        _ = 2 / Real.sqrt U := h4U
    calc 8 * N * Real.sqrt (1 + Real.log (2*q)) * (4 * Real.sqrt (1 / (2:вДЭ)^tвВА))
        = (32 * N * Real.sqrt (1 + Real.log (2*q))) * Real.sqrt (1 / (2:вДЭ)^tвВА) := by ring
      _ вЙ§ (32 * N * Real.sqrt (1 + Real.log (2*q))) * (2 / Real.sqrt U) :=
          mul_le_mul_of_nonneg_left hkey (by positivity)
      _ = 64 * N * Real.sqrt (1 + Real.log (2*q)) / Real.sqrt U := by ring
  -- T2, T4 (equalities)
  have hT2 : ((Tmax - tвВА + 1 : вДХ) : вДЭ) * Real.sqrt (32 * N^2 / q)
      = Real.sqrt 32 * N * ((Tmax - tвВА + 1 : вДХ) : вДЭ) / Real.sqrt q := by
    rw [show (32 * (N:вДЭ)^2 / q) = (32 * N^2) / q from by ring,
      Real.sqrt_div (by positivity), sqrt_const_mul_sq 32 (by norm_num) N]
    ring
  have hT4 : ((Tmax - tвВА + 1 : вДХ) : вДЭ) * Real.sqrt (36 * N * q * (1 + Real.log (2*q)))
      = 6 * ((Tmax - tвВА + 1 : вДХ) : вДЭ) * Real.sqrt (N * q * (1 + Real.log (2*q))) := by
    rw [show (36 * (N:вДЭ) * q * (1 + Real.log (2*q)))
        = 36 * (N * q * (1 + Real.log (2*q))) from by ring,
      Real.sqrt_mul (by norm_num), show Real.sqrt 36 = 6 from by
        rw [show (36:вДЭ) = 6^2 from by norm_num, Real.sqrt_sq (by norm_num)]]
    ring
  rw [hT2, hT4]
  exact add_le_add (add_le_add (add_le_add hP1 (le_of_eq rfl)) hP3) (le_of_eq rfl)

/-- **Per-block absorption** (Type-II core algebra): the dyadic block second-moment
    envelope `D¬Ј(x+1)¬Ј(D + 2(y+1)(2D+4qL))` (with `D=2^t`, `x=вМКN/DвМЛ`, `y=вМКx/вМКq/2вМЛвМЛ`)
    is dominated by the four clean geometric terms consumed by `s4_dyadic_assembly`. -/
lemma s4_block_absorb (D x y q L N : вДЭ)
    (hD1 : 1 вЙ§ D) (hq2 : 2 вЙ§ q) (hL0 : 0 вЙ§ L) (hx0 : 0 вЙ§ x) (hy0 : 0 вЙ§ y) (hN0 : 0 вЙ§ N)
    (hDx : D * x вЙ§ N) (hDN : D вЙ§ N) (hyx : y вЙ§ x) (hqy : q * y вЙ§ 4 * x) :
    D * (x + 1) * (D + 2 * (y + 1) * (2 * D + 4 * q * L))
      вЙ§ 10 * N * D + 32 * N ^ 2 / q + 64 * N ^ 2 * L / D + 36 * N * q * L := by
  have hD0 : (0:вДЭ) вЙ§ D := by linarith
  have hq0 : (0:вДЭ) < q := by linarith
  have hDpos : (0:вДЭ) < D := by linarith
  have hDDx : D * (D * x) вЙ§ D * N := mul_le_mul_of_nonneg_left hDx hD0
  have hDD : D * D вЙ§ D * N := mul_le_mul_of_nonneg_left hDN hD0
  have hDy : D * y вЙ§ N := le_trans (mul_le_mul_of_nonneg_left hyx hD0) hDx
  have hG_ND : 5 * D ^ 2 * x + 5 * D ^ 2 вЙ§ 10 * N * D := by nlinarith [hDDx, hDD]
  have hG_Nq : 4 * D ^ 2 * x * y + 4 * D ^ 2 * y вЙ§ 32 * N ^ 2 / q := by
    rw [le_div_iffвВА hq0]
    have e1 : (4 * D ^ 2 * x * y + 4 * D ^ 2 * y) * q
        = 4 * D ^ 2 * x * (q * y) + 4 * D ^ 2 * (q * y) := by ring
    rw [e1]
    have h1 : 4 * D ^ 2 * x * (q * y) вЙ§ 4 * D ^ 2 * x * (4 * x) :=
      mul_le_mul_of_nonneg_left hqy (by positivity)
    have h2 : 4 * D ^ 2 * (q * y) вЙ§ 4 * D ^ 2 * (4 * x) :=
      mul_le_mul_of_nonneg_left hqy (by positivity)
    have hDx2 : (D * x) ^ 2 вЙ§ N ^ 2 := by nlinarith [hDx, mul_nonneg hD0 hx0, hN0]
    have hDxN : D * (D * x) вЙ§ N ^ 2 := le_trans hDDx (by nlinarith [hDN, hN0])
    nlinarith [h1, h2, hDx2, hDxN, mul_nonneg (mul_nonneg hD0 hD0) hx0, hN0]
  have hG_ND2 : 8 * D * q * L * x * y вЙ§ 64 * N ^ 2 * L / D := by
    rw [le_div_iffвВА hDpos]
    have e1 : 8 * D * q * L * x * y * D = L * (8 * D ^ 2 * x * (q * y)) := by ring
    rw [e1]
    have h1 : 8 * D ^ 2 * x * (q * y) вЙ§ 8 * D ^ 2 * x * (4 * x) :=
      mul_le_mul_of_nonneg_left hqy (by positivity)
    have hDx2 : (D * x) ^ 2 вЙ§ N ^ 2 := by nlinarith [hDx, mul_nonneg hD0 hx0, hN0]
    have h2 : 8 * D ^ 2 * x * (4 * x) вЙ§ 64 * N ^ 2 := by nlinarith [hDx2]
    have h3 : 8 * D ^ 2 * x * (q * y) вЙ§ 64 * N ^ 2 := le_trans h1 h2
    calc L * (8 * D ^ 2 * x * (q * y)) вЙ§ L * (64 * N ^ 2) :=
          mul_le_mul_of_nonneg_left h3 hL0
      _ = 64 * N ^ 2 * L := by ring
  have hG_NqL : 8 * D * q * L * x + 8 * D * q * L * y + 8 * D * q * L
      вЙ§ 36 * N * q * L := by
    have hqL0 : (0:вДЭ) вЙ§ q * L := mul_nonneg (le_of_lt hq0) hL0
    have t1 : 8 * D * q * L * x = 8 * (q * L) * (D * x) := by ring
    have t2 : 8 * D * q * L * y = 8 * (q * L) * (D * y) := by ring
    have t3 : 8 * D * q * L = 8 * (q * L) * D := by ring
    have b1 : 8 * (q * L) * (D * x) вЙ§ 8 * (q * L) * N :=
      mul_le_mul_of_nonneg_left hDx (by positivity)
    have b2 : 8 * (q * L) * (D * y) вЙ§ 8 * (q * L) * N :=
      mul_le_mul_of_nonneg_left hDy (by positivity)
    have b3 : 8 * (q * L) * D вЙ§ 8 * (q * L) * N :=
      mul_le_mul_of_nonneg_left hDN (by positivity)
    nlinarith [b1, b2, b3, t1, t2, t3, mul_nonneg hqL0 hN0]
  have hEexp : D * (x + 1) * (D + 2 * (y + 1) * (2 * D + 4 * q * L))
      = (5 * D ^ 2 * x + 5 * D ^ 2) + (4 * D ^ 2 * x * y + 4 * D ^ 2 * y)
        + (8 * D * q * L * x * y)
        + (8 * D * q * L * x + 8 * D * q * L * y + 8 * D * q * L) := by ring
  rw [hEexp]
  linarith [hG_ND, hG_Nq, hG_ND2, hG_NqL]

/-- **Per-block `hbnd`** for `s4_dyadic_assembly`: the dyadic-block sum-of-norms squared
    is dominated by the four-term geometric envelope (CauchyвАУSchwarz on the block, then
    `S4_block_second_moment`, then `s4_block_absorb`). -/
lemma s4_block_hbnd (a q N V t : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (g : вДХ вЖТ вДЭ) (G : вДЭ)
    (hg0 : вИА m, 0 вЙ§ g m) (hgG : вИА m, g m вЙ§ G)
    (hN1 : 1 вЙ§ N) (h2tN : (2:вДХ) ^ t вЙ§ N) :
    (вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
        вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2
      вЙ§ G ^ 2 * (10 * N * (2:вДЭ) ^ t + 32 * N ^ 2 / q
          + 64 * N ^ 2 * (1 + Real.log (2 * q)) / (2:вДЭ) ^ t
          + 36 * N * q * (1 + Real.log (2 * q))) := by
  have hq2 : (2:вДЭ) вЙ§ q := by exact_mod_cast hq
  have hcs := sq_sum_le_card_mul_sum_sq (s := Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t))
    (f := fun d => вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ)
  rw [Nat.card_Ico] at hcs
  have hmom := S4_block_second_moment a q hq ha ќ± hќ± g G hg0 hgG N (2 ^ t) (2 ^ t + 2 ^ t) V
    (by positivity)
  have hcard : ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) = (2:вДЭ) ^ t := by
    have h : (2 ^ t + 2 ^ t - 2 ^ t : вДХ) = 2 ^ t := Nat.add_sub_cancel _ _
    rw [h]; push_cast; ring
  have hL0 : (0:вДЭ) вЙ§ 1 + Real.log (2 * q) := by
    have : (0:вДЭ) вЙ§ Real.log (2 * q) := Real.log_nonneg (by nlinarith [hq2])
    linarith
  have hx0 : (0:вДЭ) вЙ§ ((N / 2 ^ t : вДХ) : вДЭ) := by positivity
  have hy0 : (0:вДЭ) вЙ§ (((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) := by positivity
  have hN0 : (0:вДЭ) вЙ§ (N:вДЭ) := by positivity
  have hD1 : (1:вДЭ) вЙ§ (2:вДЭ) ^ t := one_le_powвВА (by norm_num)
  have hDx : (2:вДЭ) ^ t * ((N / 2 ^ t : вДХ) : вДЭ) вЙ§ N := by
    have hnat : (N / 2 ^ t) * 2 ^ t вЙ§ N := Nat.div_mul_le_self N (2 ^ t)
    calc (2:вДЭ) ^ t * ((N / 2 ^ t : вДХ) : вДЭ)
        = (((N / 2 ^ t) * 2 ^ t : вДХ) : вДЭ) := by push_cast; ring
      _ вЙ§ (N:вДЭ) := by exact_mod_cast hnat
  have hDN : (2:вДЭ) ^ t вЙ§ N := by exact_mod_cast h2tN
  have hyx : (((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) вЙ§ ((N / 2 ^ t : вДХ) : вДЭ) := by
    exact_mod_cast Nat.div_le_self _ _
  have hqy : (q:вДЭ) * (((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) вЙ§ 4 * ((N / 2 ^ t : вДХ) : вДЭ) := by
    have h2 : q вЙ§ 4 * (q / 2) := by omega
    have h1 : ((N / 2 ^ t) / (q / 2)) * (q / 2) вЙ§ N / 2 ^ t := Nat.div_mul_le_self _ _
    have hnat : q * ((N / 2 ^ t) / (q / 2)) вЙ§ 4 * (N / 2 ^ t) := by
      calc q * ((N / 2 ^ t) / (q / 2))
          вЙ§ 4 * (q / 2) * ((N / 2 ^ t) / (q / 2)) := Nat.mul_le_mul_right _ h2
        _ = 4 * (((N / 2 ^ t) / (q / 2)) * (q / 2)) := by ring
        _ вЙ§ 4 * (N / 2 ^ t) := Nat.mul_le_mul_left _ h1
    exact_mod_cast hnat
  have habs := s4_block_absorb ((2:вДЭ) ^ t) ((N / 2 ^ t : вДХ) : вДЭ)
    (((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) q (1 + Real.log (2 * q)) N
    hD1 hq2 hL0 hx0 hy0 hN0 hDx hDN hyx hqy
  have hmomeq : G ^ 2 * (((N / 2 ^ t : вДХ) : вДЭ) + 1) *
      (((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) + 2 * ((((N / 2 ^ t) / (q / 2) + 1 : вДХ) : вДЭ))
        * (2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))
      = G ^ 2 * ((((N / 2 ^ t : вДХ) : вДЭ) + 1) * ((2:вДЭ) ^ t
          + 2 * ((((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) + 1)
            * (2 * (2:вДЭ) ^ t + 4 * q * (1 + Real.log (2 * q))))) := by
    rw [hcard]; push_cast; ring
  calc (вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
          вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2
      вЙ§ ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) *
          вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
            вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2 := by
        exact_mod_cast hcs
    _ = (2:вДЭ) ^ t *
          вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
            вАЦвИС m вИИ Finset.Ioc V (N / d), (g m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2 := by
        rw [hcard]
    _ вЙ§ (2:вДЭ) ^ t * (G ^ 2 * ((((N / 2 ^ t : вДХ) : вДЭ) + 1) * ((2:вДЭ) ^ t
          + 2 * ((((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) + 1)
            * (2 * (2:вДЭ) ^ t + 4 * q * (1 + Real.log (2 * q)))))) :=
        mul_le_mul_of_nonneg_left (hmom.trans_eq hmomeq) (by positivity)
    _ = G ^ 2 * ((2:вДЭ) ^ t * (((N / 2 ^ t : вДХ) : вДЭ) + 1) * ((2:вДЭ) ^ t
          + 2 * ((((N / 2 ^ t) / (q / 2) : вДХ) : вДЭ) + 1)
            * (2 * (2:вДЭ) ^ t + 4 * q * (1 + Real.log (2 * q))))) := by ring
    _ вЙ§ G ^ 2 * (10 * N * (2:вДЭ) ^ t + 32 * N ^ 2 / q
          + 64 * N ^ 2 * (1 + Real.log (2 * q)) / (2:вДЭ) ^ t
          + 36 * N * q * (1 + Real.log (2 * q))) :=
        mul_le_mul_of_nonneg_left habs (by positivity)


lemma S4_bound (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
            * ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ))) n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ ((Nat.log 2 N + 1 : вДХ) : вДЭ) *
          Real.sqrt ((N : вДЭ) * (Real.log N ^ 2
            * (((N / 2 ^ Nat.log 2 (U + 1) : вДХ) : вДЭ) + 1)
            * ((N : вДЭ) + 2 * ((((N / 2 ^ Nat.log 2 (U + 1) : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * N + 4 * q * (1 + Real.log (2 * q)))))) := by
  set c : ArithmeticFunction вДЭ :=
    (ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U with hc
  set gAF : ArithmeticFunction вДЭ := (ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ) with hgAF
  set ghat : вДХ вЖТ вДЭ := fun m => if m вЙ§ N then gAF m else 0 with hghat
  set tвВА : вДХ := Nat.log 2 (U + 1) with htвВА
  set Tmax : вДХ := Nat.log 2 N with hTmax
  set Mom : вДЭ := Real.log N ^ 2 * (((N / 2 ^ tвВА : вДХ) : вДЭ) + 1)
      * ((N : вДЭ) + 2 * ((((N / 2 ^ tвВА : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
        * (2 * N + 4 * q * (1 + Real.log (2 * q)))) with hMom
  have hL0 : (0 : вДЭ) вЙ§ 1 + Real.log (2 * q) := by
    have hq2 : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
    have : (0 : вДЭ) вЙ§ Real.log (2 * q) := Real.log_nonneg (by linarith)
    linarith
  rcases Nat.eq_zero_or_pos N with hN0 | hN0
  ¬Ј subst hN0
    simp only [Finset.Ioc_self, Finset.sum_empty, norm_zero]
    positivity
  have hMom0 : 0 вЙ§ Mom := by
    rw [hMom]
    have h1 : (0 : вДЭ) вЙ§ (N : вДЭ) + 2 * ((((N / 2 ^ tвВА : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
        * (2 * N + 4 * q * (1 + Real.log (2 * q))) := by
      have h2 : (0 : вДЭ) вЙ§ 2 * N + 4 * q * (1 + Real.log (2 * q)) := by
        have := mul_nonneg (by positivity : (0:вДЭ) вЙ§ 4 * q) hL0
        positivity
      positivity
    positivity
  have hghat0 : вИА m, 0 вЙ§ ghat m := by
    intro m
    rw [hghat]
    dsimp only
    split
    ¬Ј exact tail_conv_nonneg V m
    ¬Ј exact le_refl 0
  have hghatG : вИА m, ghat m вЙ§ Real.log N := by
    intro m
    rw [hghat]
    dsimp only
    split
    ¬Ј rename_i hm
      calc gAF m вЙ§ Real.log m := tail_conv_le_log V m
        _ вЙ§ Real.log N := log_natCast_monotone hm
    ¬Ј exact log_natCast_nonneg N
  -- regroup and restrict the inner sums
  rw [show c * gAF = c * gAF from rfl,
    sum_Ioc_mul_weight_eq_sum_sum c gAF (fun n => e ((n : вДЭ) * ќ±)) N]
  have hinner : вИА d вИИ Finset.Ioc 0 N,
      вИС m вИИ Finset.Ioc 0 (N / d), (gAF m : вДВ) * e (((d * m : вДХ) : вДЭ) * ќ±)
      = вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
    intro d hd
    simp only [Finset.mem_Ioc] at hd
    have step1 : вИС m вИИ Finset.Ioc 0 (N / d), (gAF m : вДВ) * e (((d * m : вДХ) : вДЭ) * ќ±)
        = вИС m вИИ Finset.Ioc 0 (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_Ioc] at hm
      have hmN : m вЙ§ N := le_trans hm.2 (Nat.div_le_self N d)
      rw [hghat]
      dsimp only
      rw [if_pos hmN]
      congr 1
      exact congrArg e (by push_cast; ring)
    rw [step1]
    symm
    apply Finset.sum_subset
    ¬Ј intro m hm
      simp only [Finset.mem_Ioc] at hm вКҐ
      omega
    ¬Ј intro m hm hnot
      simp only [Finset.mem_Ioc] at hm hnot
      have hmV : m вЙ§ V := by omega
      have hz : ghat m = 0 := by
        rw [hghat]
        dsimp only
        split
        ¬Ј exact tail_conv_eq_zero_of_le V m hmV
        ¬Ј rfl
      rw [hz]
      simp
  rw [Finset.sum_congr rfl (fun d hd => by rw [hinner d hd])]
  -- support restriction + triangle
  have hterm : вИА d вИИ Finset.Ioc 0 N,
      вАЦ(c d : вДВ) * вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
      вЙ§ (if U < d then
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ else 0) := by
    intro d _
    by_cases hdU : U < d
    ¬Ј rw [if_pos hdU, norm_mul, Complex.norm_real, Real.norm_eq_abs]
      have := abs_moebius_tail_le_one U d
      rw [hc]
      calc |(((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U) d)| *
            вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
          вЙ§ 1 * вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
            mul_le_mul_of_nonneg_right this (norm_nonneg _)
        _ = _ := one_mul _
    ¬Ј rw [if_neg hdU]
      have hz : c d = 0 := by
        rw [hc]
        exact moebius_tail_eq_zero_of_le U d (by omega)
      rw [hz]
      simp
  calc вАЦвИС d вИИ Finset.Ioc 0 N, (c d : вДВ) *
        вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
      вЙ§ вИС d вИИ Finset.Ioc 0 N,
          вАЦ(c d : вДВ) * вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС d вИИ Finset.Ioc 0 N, (if U < d then
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ else 0) :=
        Finset.sum_le_sum hterm
    _ = вИС d вИИ Finset.Ioc U N,
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_congr _ (fun d _ => rfl)
        ext d
        simp only [Finset.mem_filter, Finset.mem_Ioc]
        omega
    _ вЙ§ вИС t вИИ Finset.Icc tвВА Tmax, вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
        have hcover : Finset.Ioc U N вКЖ
            (Finset.Icc tвВА Tmax).biUnion (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
          intro d hd
          simp only [Finset.mem_Ioc] at hd
          rw [Finset.mem_biUnion]
          refine вЯ®Nat.log 2 d, ?_, ?_вЯ©
          ¬Ј rw [Finset.mem_Icc, htвВА, hTmax]
            constructor
            ¬Ј exact Nat.log_mono_right (by omega)
            ¬Ј exact Nat.log_mono_right hd.2
          ¬Ј rw [Finset.mem_Ico]
            constructor
            ¬Ј exact Nat.pow_log_le_self 2 (by omega)
            ¬Ј have := Nat.lt_pow_succ_log_self (by norm_num : 1 < 2) d
              rw [pow_succ] at this
              omega
        have hdisj : (вЖС(Finset.Icc tвВА Tmax) : Set вДХ).PairwiseDisjoint
            (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
          intro tвВБ _ tвВВ _ hne
          apply Finset.disjoint_left.mpr
          intro h h1 h2
          simp only [Finset.mem_Ico] at h1 h2
          rcases Nat.lt_or_ge tвВБ tвВВ with hlt | hge
          ¬Ј have : (2 : вДХ) ^ (tвВБ + 1) вЙ§ 2 ^ tвВВ := Nat.pow_le_pow_right (by norm_num) hlt
            rw [pow_succ] at this
            omega
          ¬Ј have hlt2 : tвВВ < tвВБ := lt_of_le_of_ne hge (Ne.symm hne)
            have : (2 : вДХ) ^ (tвВВ + 1) вЙ§ 2 ^ tвВБ := Nat.pow_le_pow_right (by norm_num) hlt2
            rw [pow_succ] at this
            omega
        calc вИС d вИИ Finset.Ioc U N,
            вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
            вЙ§ вИС d вИИ (Finset.Icc tвВА Tmax).biUnion
                (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)),
                вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
              Finset.sum_le_sum_of_subset_of_nonneg hcover (fun d _ _ => norm_nonneg _)
          _ = _ := Finset.sum_biUnion hdisj
    _ вЙ§ вИС _t вИИ Finset.Icc tвВА Tmax, Real.sqrt ((N : вДЭ) * Mom) := by
        apply Finset.sum_le_sum
        intro t ht
        simp only [Finset.mem_Icc] at ht
        apply Real.le_sqrt_of_sq_le
        have hcs := sq_sum_le_card_mul_sum_sq (s := Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t))
          (f := fun d => вАЦвИС m вИИ Finset.Ioc V (N / d),
            (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ)
        rw [Nat.card_Ico] at hcs
        have hcard : ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) = ((2 : вДЭ) ^ t) := by
          have hnat : (2 ^ t + 2 ^ t - 2 ^ t : вДХ) = 2 ^ t := Nat.add_sub_cancel _ _
          rw [hnat]
          push_cast
          ring
        have hmom := S4_block_second_moment a q hq ha ќ± hќ± ghat (Real.log N)
          hghat0 hghatG N (2 ^ t) (2 ^ t + 2 ^ t) V (by positivity)
        -- monotone-in-t bounds
        have h2tN : (2 : вДХ) ^ t вЙ§ N := by
          calc (2 : вДХ) ^ t вЙ§ 2 ^ Tmax := Nat.pow_le_pow_right (by norm_num) ht.2
            _ вЙ§ N := by
              rw [hTmax]
              exact Nat.pow_log_le_self 2 (by omega)
        have hdivmono : (N / 2 ^ t : вДХ) вЙ§ (N / 2 ^ tвВА : вДХ) :=
          Nat.div_le_div_left (Nat.pow_le_pow_right (by norm_num) ht.1) (by positivity)
        have hBA : ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) вЙ§ (N : вДЭ) := by
          rw [hcard]
          exact_mod_cast h2tN
        have hdiv2 : ((((N / 2 ^ t : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
            вЙ§ ((((N / 2 ^ tвВА : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ) := by
          have : ((N / 2 ^ t : вДХ)) / (q / 2) вЙ§ ((N / 2 ^ tвВА : вДХ)) / (q / 2) :=
            Nat.div_le_div_right hdivmono
          exact_mod_cast Nat.add_le_add_right this 1
        have hmono : Real.log N ^ 2 * (((N / 2 ^ t : вДХ) : вДЭ) + 1)
            * (((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
              + 2 * ((((N / 2 ^ t : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                  + 4 * q * (1 + Real.log (2 * q))))
            вЙ§ Mom := by
          rw [hMom]
          have hf1 : (((N / 2 ^ t : вДХ) : вДЭ) + 1) вЙ§ (((N / 2 ^ tвВА : вДХ) : вДЭ) + 1) := by
            have : ((N / 2 ^ t : вДХ) : вДЭ) вЙ§ ((N / 2 ^ tвВА : вДХ) : вДЭ) := by exact_mod_cast hdivmono
            linarith
          have hf2 : (((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
              + 2 * ((((N / 2 ^ t : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) + 4 * q * (1 + Real.log (2 * q))))
              вЙ§ ((N : вДЭ) + 2 * ((((N / 2 ^ tвВА : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * N + 4 * q * (1 + Real.log (2 * q)))) := by
            have hq4 : (0 : вДЭ) вЙ§ 4 * q * (1 + Real.log (2 * q)) :=
              mul_nonneg (by positivity) hL0
            have hinner2 : 2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                + 4 * q * (1 + Real.log (2 * q))
                вЙ§ 2 * (N : вДЭ) + 4 * q * (1 + Real.log (2 * q)) := by linarith
            have h2a : (0 : вДЭ) вЙ§ 2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                + 4 * q * (1 + Real.log (2 * q)) := by positivity
            have := mul_le_mul hdiv2 hinner2 h2a (by positivity)
            nlinarith [hBA]
          have h0a : (0 : вДЭ) вЙ§ Real.log N ^ 2 := by positivity
          have h0b : (0 : вДЭ) вЙ§ (((N / 2 ^ t : вДХ) : вДЭ) + 1) := by positivity
          have h0c : (0 : вДЭ) вЙ§ (((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
              + 2 * ((((N / 2 ^ t : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                * (2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                  + 4 * q * (1 + Real.log (2 * q)))) := by
            have : (0 : вДЭ) вЙ§ 4 * q * (1 + Real.log (2 * q)) :=
              mul_nonneg (by positivity) hL0
            positivity
          exact mul_le_mul (mul_le_mul_of_nonneg_left hf1 h0a) hf2 h0c (by positivity)
        calc (вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
              вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ) ^ 2
            вЙ§ ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) *
                вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
                  вАЦвИС m вИИ Finset.Ioc V (N / d),
                    (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ ^ 2 := by
              exact_mod_cast hcs
          _ вЙ§ ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ) *
                (Real.log N ^ 2 * (((N / 2 ^ t : вДХ) : вДЭ) + 1)
                  * (((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                    + 2 * ((((N / 2 ^ t : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
                      * (2 * ((2 ^ t + 2 ^ t - 2 ^ t : вДХ) : вДЭ)
                        + 4 * q * (1 + Real.log (2 * q))))) :=
              mul_le_mul_of_nonneg_left hmom (by positivity)
          _ вЙ§ (N : вДЭ) * Mom := by
              apply mul_le_mul hBA hmono _ (by positivity)
              have h0a : (0 : вДЭ) вЙ§ Real.log N ^ 2 := by positivity
              have : (0 : вДЭ) вЙ§ 4 * q * (1 + Real.log (2 * q)) :=
                mul_nonneg (by positivity) hL0
              positivity
    _ = ((Finset.Icc tвВА Tmax).card : вДЭ) * Real.sqrt ((N : вДЭ) * Mom) := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ вЙ§ ((Nat.log 2 N + 1 : вДХ) : вДЭ) * Real.sqrt ((N : вДЭ) * Mom) := by
        apply mul_le_mul_of_nonneg_right _ (Real.sqrt_nonneg _)
        have : (Finset.Icc tвВА Tmax).card вЙ§ Nat.log 2 N + 1 := by
          rw [Nat.card_Icc, hTmax]
          omega
        exact_mod_cast this

/-- **THE TIGHT SвВД BOUND** (Type-II, large-sieve strength): replaces the vacuous
    `S4_bound` (whose dyadic-boundary over-charge made the innermost factor `вЙ• N`,
    hence `вАЦSвВДвАЦ вЙ• N¬Јlog¬≤N`, weaker than the trivial `ѕИ(N) вЙИ N`) with the four-term
    geometric envelope from `s4_dyadic_assembly`. On a minor arc `P < q вЙ§ N/P` this is
    `вЙ™ N¬Јlog¬≤N/вИЪP`, small enough to close the variance bound. -/
lemma S4_bound_tight (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hU1 : 1 вЙ§ U) (hN1 : 1 вЙ§ N) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
            * ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ))) n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
          + Real.sqrt 32 * N
              * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ) / Real.sqrt q
          + 64 * N * Real.sqrt (1 + Real.log (2 * q)) / Real.sqrt U
          + 6 * ((Nat.log 2 (N / (V + 1)) - Nat.log 2 (U + 1) + 1 : вДХ) : вДЭ)
              * Real.sqrt (N * q * (1 + Real.log (2 * q)))) := by
  set c : ArithmeticFunction вДЭ :=
    (ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U with hc
  set gAF : ArithmeticFunction вДЭ := (ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ) with hgAF
  set ghat : вДХ вЖТ вДЭ := fun m => if m вЙ§ N then gAF m else 0 with hghat
  set tвВА : вДХ := Nat.log 2 (U + 1) with htвВА
  set Nmax : вДХ := N / (V + 1) with hNmax
  set Tmax : вДХ := Nat.log 2 Nmax with hTmax
  have hL0 : (0 : вДЭ) вЙ§ 1 + Real.log (2 * q) := by
    have hq2 : (2 : вДЭ) вЙ§ (q : вДЭ) := by exact_mod_cast hq
    have : (0 : вДЭ) вЙ§ Real.log (2 * q) := Real.log_nonneg (by linarith)
    linarith
  have hN0 : 0 < N := hN1
  have hghat0 : вИА m, 0 вЙ§ ghat m := by
    intro m
    rw [hghat]
    dsimp only
    split
    ¬Ј exact tail_conv_nonneg V m
    ¬Ј exact le_refl 0
  have hghatG : вИА m, ghat m вЙ§ Real.log N := by
    intro m
    rw [hghat]
    dsimp only
    split
    ¬Ј rename_i hm
      calc gAF m вЙ§ Real.log m := tail_conv_le_log V m
        _ вЙ§ Real.log N := log_natCast_monotone hm
    ¬Ј exact log_natCast_nonneg N
  rw [show c * gAF = c * gAF from rfl,
    sum_Ioc_mul_weight_eq_sum_sum c gAF (fun n => e ((n : вДЭ) * ќ±)) N]
  have hinner : вИА d вИИ Finset.Ioc 0 N,
      вИС m вИИ Finset.Ioc 0 (N / d), (gAF m : вДВ) * e (((d * m : вДХ) : вДЭ) * ќ±)
      = вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
    intro d hd
    simp only [Finset.mem_Ioc] at hd
    have step1 : вИС m вИИ Finset.Ioc 0 (N / d), (gAF m : вДВ) * e (((d * m : вДХ) : вДЭ) * ќ±)
        = вИС m вИИ Finset.Ioc 0 (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±) := by
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_Ioc] at hm
      have hmN : m вЙ§ N := le_trans hm.2 (Nat.div_le_self N d)
      rw [hghat]
      dsimp only
      rw [if_pos hmN]
      congr 1
      exact congrArg e (by push_cast; ring)
    rw [step1]
    symm
    apply Finset.sum_subset
    ¬Ј intro m hm
      simp only [Finset.mem_Ioc] at hm вКҐ
      omega
    ¬Ј intro m hm hnot
      simp only [Finset.mem_Ioc] at hm hnot
      have hmV : m вЙ§ V := by omega
      have hz : ghat m = 0 := by
        rw [hghat]
        dsimp only
        split
        ¬Ј exact tail_conv_eq_zero_of_le V m hmV
        ¬Ј rfl
      rw [hz]
      simp
  rw [Finset.sum_congr rfl (fun d hd => by rw [hinner d hd])]
  have hterm : вИА d вИИ Finset.Ioc 0 N,
      вАЦ(c d : вДВ) * вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
      вЙ§ (if U < d then
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ else 0) := by
    intro d _
    by_cases hdU : U < d
    ¬Ј rw [if_pos hdU, norm_mul, Complex.norm_real, Real.norm_eq_abs]
      have := abs_moebius_tail_le_one U d
      rw [hc]
      calc |(((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U) d)| *
            вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
          вЙ§ 1 * вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
            mul_le_mul_of_nonneg_right this (norm_nonneg _)
        _ = _ := one_mul _
    ¬Ј rw [if_neg hdU]
      have hz : c d = 0 := by
        rw [hc]
        exact moebius_tail_eq_zero_of_le U d (by omega)
      rw [hz]
      simp
  calc вАЦвИС d вИИ Finset.Ioc 0 N, (c d : вДВ) *
        вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
      вЙ§ вИС d вИИ Finset.Ioc 0 N,
          вАЦ(c d : вДВ) * вИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС d вИИ Finset.Ioc 0 N, (if U < d then
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ else 0) :=
        Finset.sum_le_sum hterm
    _ = вИС d вИИ Finset.Ioc U N,
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_congr _ (fun d _ => rfl)
        ext d
        simp only [Finset.mem_filter, Finset.mem_Ioc]
        omega
    _ = вИС d вИИ Finset.Ioc U Nmax,
          вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ := by
        refine (Finset.sum_subset
          (Finset.Ioc_subset_Ioc_right (Nat.div_le_self N (V + 1))) ?_).symm
        intro d hd hnotin
        simp only [Finset.mem_Ioc] at hd hnotin
        have hdNmax : Nmax < d := by
          by_contra hcon
          push_neg at hcon
          exact hnotin вЯ®hd.1, hconвЯ©
        have hd0 : 0 < d := by omega
        have hNlt : N < d * (V + 1) :=
          (Nat.div_lt_iff_lt_mul (by omega : 0 < V + 1)).mp hdNmax
        have hNdV : N / d вЙ§ V := by
          have : N / d < V + 1 :=
            (Nat.div_lt_iff_lt_mul hd0).mpr (by rw [Nat.mul_comm]; exact hNlt)
          omega
        have hempty : Finset.Ioc V (N / d) = вИЕ := Finset.Ioc_eq_empty (by omega)
        rw [hempty, Finset.sum_empty, norm_zero]
    _ вЙ§ Real.log N * (4 * Real.sqrt 10 * N / Real.sqrt (V + 1)
          + Real.sqrt 32 * N * ((Tmax - tвВА + 1 : вДХ) : вДЭ) / Real.sqrt q
          + 64 * N * Real.sqrt (1 + Real.log (2 * q)) / Real.sqrt U
          + 6 * ((Tmax - tвВА + 1 : вДХ) : вДЭ) * Real.sqrt (N * q * (1 + Real.log (2 * q)))) := by
        by_cases hcase : tвВА вЙ§ Tmax
        ¬Ј have ht0pos : 1 вЙ§ tвВА := by
            rw [htвВА]
            exact Nat.log_pos (by norm_num) (by omega)
          have hNmaxpos : 0 < Nmax := by
            rcases Nat.eq_zero_or_pos Nmax with h0 | h0
            ¬Ј exfalso
              have hT0 : Tmax = 0 := by rw [hTmax, h0]; simp
              omega
            ¬Ј exact h0
          have hUt0 : (U : вДЭ) вЙ§ 2 * (2 : вДЭ) ^ tвВА := by
            have h := Nat.lt_pow_succ_log_self (b := 2) (by norm_num) (U + 1)
            rw [вЖР htвВА] at h
            have hUle : U вЙ§ 2 ^ (tвВА + 1) := by omega
            calc (U : вДЭ) вЙ§ ((2 ^ (tвВА + 1) : вДХ) : вДЭ) := by exact_mod_cast hUle
              _ = 2 * (2 : вДЭ) ^ tвВА := by push_cast; ring
          have hTmaxN : (2 : вДЭ) ^ Tmax вЙ§ (N : вДЭ) / (V + 1) := by
            have h1 : (2 : вДХ) ^ Tmax вЙ§ Nmax := by
              rw [hTmax]; exact Nat.pow_log_le_self 2 (by omega)
            have hVR : (0 : вДЭ) < (V : вДЭ) + 1 := by positivity
            rw [le_div_iffвВА hVR]
            have h3 : Nmax * (V + 1) вЙ§ N := by rw [hNmax]; exact Nat.div_mul_le_self N (V + 1)
            calc (2 : вДЭ) ^ Tmax * ((V : вДЭ) + 1)
                вЙ§ (Nmax : вДЭ) * ((V : вДЭ) + 1) := by
                  apply mul_le_mul_of_nonneg_right _ (by positivity)
                  calc (2 : вДЭ) ^ Tmax = ((2 ^ Tmax : вДХ) : вДЭ) := by push_cast; ring
                    _ вЙ§ (Nmax : вДЭ) := by exact_mod_cast h1
              _ = (((Nmax * (V + 1) : вДХ)) : вДЭ) := by push_cast; ring
              _ вЙ§ (N : вДЭ) := by exact_mod_cast h3
          have hcover : Finset.Ioc U Nmax вКЖ
              (Finset.Icc tвВА Tmax).biUnion (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
            intro d hd
            simp only [Finset.mem_Ioc] at hd
            rw [Finset.mem_biUnion]
            refine вЯ®Nat.log 2 d, ?_, ?_вЯ©
            ¬Ј rw [Finset.mem_Icc, htвВА, hTmax]
              exact вЯ®Nat.log_mono_right (by omega), Nat.log_mono_right hd.2вЯ©
            ¬Ј rw [Finset.mem_Ico]
              refine вЯ®Nat.pow_log_le_self 2 (by omega), ?_вЯ©
              have := Nat.lt_pow_succ_log_self (by norm_num : 1 < 2) d
              rw [pow_succ] at this
              omega
          have hdisj : (вЖС(Finset.Icc tвВА Tmax) : Set вДХ).PairwiseDisjoint
              (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)) := by
            intro tвВБ _ tвВВ _ hne
            apply Finset.disjoint_left.mpr
            intro h h1 h2
            simp only [Finset.mem_Ico] at h1 h2
            rcases Nat.lt_or_ge tвВБ tвВВ with hlt | hge
            ¬Ј have : (2 : вДХ) ^ (tвВБ + 1) вЙ§ 2 ^ tвВВ := Nat.pow_le_pow_right (by norm_num) hlt
              rw [pow_succ] at this; omega
            ¬Ј have hlt2 : tвВВ < tвВБ := lt_of_le_of_ne hge (Ne.symm hne)
              have : (2 : вДХ) ^ (tвВВ + 1) вЙ§ 2 ^ tвВБ := Nat.pow_le_pow_right (by norm_num) hlt2
              rw [pow_succ] at this; omega
          calc вИС d вИИ Finset.Ioc U Nmax,
                вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ
              вЙ§ вИС d вИИ (Finset.Icc tвВА Tmax).biUnion
                  (fun t => Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t)),
                  вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
                Finset.sum_le_sum_of_subset_of_nonneg hcover (fun d _ _ => norm_nonneg _)
            _ = вИС t вИИ Finset.Icc tвВА Tmax, вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
                  вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ :=
                Finset.sum_biUnion hdisj
            _ вЙ§ _ :=
                s4_dyadic_assembly N q V U tвВА Tmax hq hN1 hU1 hcase hUt0 hTmaxN
                  (fun t => вИС d вИИ Finset.Ico (2 ^ t) (2 ^ t + 2 ^ t),
                    вАЦвИС m вИИ Finset.Ioc V (N / d), (ghat m : вДВ) * e ((d : вДЭ) * (m : вДЭ) * ќ±)вАЦ)
                  (fun t => Finset.sum_nonneg (fun d _ => norm_nonneg _))
                  (fun t ht => by
                    simp only [Finset.mem_Icc] at ht
                    have h2tN : (2 : вДХ) ^ t вЙ§ N := by
                      calc (2 : вДХ) ^ t вЙ§ 2 ^ Tmax := Nat.pow_le_pow_right (by norm_num) ht.2
                        _ вЙ§ Nmax := by rw [hTmax]; exact Nat.pow_log_le_self 2 (by omega)
                        _ вЙ§ N := Nat.div_le_self N (V + 1)
                    exact s4_block_hbnd a q N V t hq ha ќ± hќ± ghat (Real.log N)
                      hghat0 hghatG hN1 h2tN)
        ¬Ј have hle : Nmax вЙ§ U := by
            by_contra hcon
            push_neg at hcon
            exact hcase (by rw [htвВА, hTmax]; exact Nat.log_mono_right (by omega))
          rw [Finset.Ioc_eq_empty (by omega), Finset.sum_empty]
          apply mul_nonneg (Real.log_nonneg (by exact_mod_cast hN1))
          positivity

/-- **The SвВГ bound**: the small Vaughan piece is at most `V¬Јlog V`. -/
lemma S3_bound (V N : вДХ) (ќ± : вДЭ) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((truncate ќЫ V n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ (V : вДЭ) * Real.log V := by
  calc вАЦвИС n вИИ Finset.Ioc 0 N, ((truncate ќЫ V n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ вИС n вИИ Finset.Ioc 0 N, вАЦ((truncate ќЫ V n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС n вИИ Finset.Ioc 0 N, (if n вЙ§ V then ќЫ n else 0) := by
        apply Finset.sum_le_sum
        intro n _
        rw [norm_mul, Complex.norm_real, Real.norm_eq_abs,
          abs_of_nonneg (truncate_vonMangoldt_nonneg V n)]
        have he : вАЦe ((n : вДЭ) * ќ±)вАЦ = 1 := by
          rw [e, Complex.norm_exp]
          have : (2 * (Real.pi : вДВ) * Complex.I * (((n : вДЭ) * ќ± : вДЭ) : вДВ)).re = 0 := by
            simp [Complex.mul_re, Complex.mul_im]
          rw [this, Real.exp_zero]
        rw [he, mul_one, truncate_apply]
    _ вЙ§ вИС n вИИ Finset.Ioc 0 V, ќЫ n := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_le_sum_of_subset_of_nonneg
        ¬Ј intro n hn
          simp only [Finset.mem_filter, Finset.mem_Ioc] at hn вКҐ
          omega
        ¬Ј intro n _ _
          exact vonMangoldt_nonneg
    _ вЙ§ (V : вДЭ) * Real.log V := sum_vonMangoldt_le V

/-- **THE VINOGRADOV SUP SKELETON**: `вАЦвИСќЫ(n)e(nќ±)вАЦ вЙ§ вАЦSвВБвАЦ + вАЦSвВВвАЦ + вАЦSвВГвАЦ + вАЦSвВДвАЦ`
    for the truncated Vaughan pieces (each `вАЦSбµҐвАЦ` separately bounded by
    `S1_bound`/`S2_bound`/`S3_bound`/`S4_bound`). -/
lemma vinogradov_sup_skeleton (U V N : вДХ) (ќ± : вДЭ) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ вАЦвИС n вИИ Finset.Ioc 0 N,
            (((truncate (ќЉ : ArithmeticFunction вДЭ) U * ArithmeticFunction.log) n : вДЭ) : вДВ)
              * e ((n : вДЭ) * ќ±)вАЦ
        + вАЦвИС n вИИ Finset.Ioc 0 N,
            (((truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V
                * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
        + вАЦвИС n вИИ Finset.Ioc 0 N, ((truncate ќЫ V n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
        + вАЦвИС n вИИ Finset.Ioc 0 N,
            (((((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
                * ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ))) n : вДЭ) : вДВ)
              * e ((n : вДЭ) * ќ±)вАЦ := by
  rw [vaughan_sum_decomposition (truncate (ќЉ : ArithmeticFunction вДЭ) U) (truncate ќЫ V)
    (fun n => e ((n : вДЭ) * ќ±)) N]
  have hassoc : ((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
      * (ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ)
      = ((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
      * ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ)) := mul_assoc _ _ _
  rw [hassoc]
  set S1 : вДВ := вИС n вИИ Finset.Ioc 0 N,
      (((truncate (ќЉ : ArithmeticFunction вДЭ) U * ArithmeticFunction.log) n : вДЭ) : вДВ)
        * e ((n : вДЭ) * ќ±) with hS1
  set S2 : вДВ := вИС n вИИ Finset.Ioc 0 N,
      (((truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V
          * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±) with hS2
  set S3 : вДВ := вИС n вИИ Finset.Ioc 0 N, ((truncate ќЫ V n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±) with hS3
  set S4 : вДВ := вИС n вИИ Finset.Ioc 0 N,
      (((((ќЉ : ArithmeticFunction вДЭ) - truncate (ќЉ : ArithmeticFunction вДЭ) U)
          * ((ќЫ - truncate ќЫ V) * (ќґ : ArithmeticFunction вДЭ))) n : вДЭ) : вДВ)
        * e ((n : вДЭ) * ќ±) with hS4
  calc вАЦS1 - S2 + S3 + S4вАЦ
      вЙ§ вАЦS1 - S2 + S3вАЦ + вАЦS4вАЦ := norm_add_le _ _
    _ вЙ§ (вАЦS1 - S2вАЦ + вАЦS3вАЦ) + вАЦS4вАЦ := by
        have := norm_add_le (S1 - S2) S3
        linarith
    _ вЙ§ ((вАЦS1вАЦ + вАЦS2вАЦ) + вАЦS3вАЦ) + вАЦS4вАЦ := by
        have := norm_sub_le S1 S2
        linarith
    _ = вАЦS1вАЦ + вАЦS2вАЦ + вАЦS3вАЦ + вАЦS4вАЦ := by ring

/-- **THE VINOGRADOV MINOR-ARC SUP BOUND** вАФ explicit, for any truncations `U, V`. -/
theorem vinogradov_sup (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hU : U вЙ§ N) (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) :
    вАЦвИС n вИИ Finset.Ioc 0 N, ((ќЫ n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) *
          ((((Nat.log 2 U + 1 : вДХ) : вДЭ) * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
            + 32 * U * (1 + Real.log (2 * q)) + 4 * N) + U)
        + Real.log (U * V) *
          (((Nat.log 2 (U * V) + 1 : вДХ) : вДЭ)
              * (8 * N / q + 4 * q * (1 + Real.log (2 * q)))
            + 32 * (U * V) * (1 + Real.log (2 * q)) + 4 * N)
        + (V : вДЭ) * Real.log V
        + ((Nat.log 2 N + 1 : вДХ) : вДЭ) *
          Real.sqrt ((N : вДЭ) * (Real.log N ^ 2
            * (((N / 2 ^ Nat.log 2 (U + 1) : вДХ) : вДЭ) + 1)
            * ((N : вДЭ) + 2 * ((((N / 2 ^ Nat.log 2 (U + 1) : вДХ)) / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * N + 4 * q * (1 + Real.log (2 * q)))))) := by
  refine le_trans (vinogradov_sup_skeleton U V N ќ±) ?_
  have h1 := S1_bound a q hq ha ќ± hќ± U N hU
  have h2 := S2_bound a q hq ha ќ± hќ± U V N hUV hUV1
  have h3 := S3_bound V N ќ±
  have h4 := S4_bound a q hq ha ќ± hќ± U V N
  linarith


lemma S2_bound_tight (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U V N : вДХ)
    (hUV : U * V вЙ§ N) (hUV1 : 1 вЙ§ U * V) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V
            * (ќґ : ArithmeticFunction вДЭ)) n : вДЭ) : вДВ) * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ Real.log (U * V) *
          ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
            + ((U * V / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) := by
  set c : ArithmeticFunction вДЭ := truncate (ќЉ : ArithmeticFunction вДЭ) U * truncate ќЫ V with hc
  have hlogUV0 : (0 : вДЭ) вЙ§ Real.log (U * V) := by
    apply Real.log_nonneg
    exact_mod_cast hUV1
  -- regroup + collapse ќґ + normalize the e-argument
  have hre : вИС n вИИ Finset.Ioc 0 N,
      ((c * (ќґ : ArithmeticFunction вДЭ)) n : вДВ) * e ((n : вДЭ) * ќ±)
      = вИС t вИИ Finset.Ioc 0 N, (c t : вДВ) *
          вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±)) := by
    rw [sum_Ioc_mul_weight_eq_sum_sum c (ќґ : ArithmeticFunction вДЭ)
      (fun n => e ((n : вДЭ) * ќ±)) N]
    apply Finset.sum_congr rfl
    intro t _
    congr 1
    rw [sum_Ioc_zeta_mul (fun m => e (((t * m : вДХ) : вДЭ) * ќ±)) (N / t)]
    apply Finset.sum_congr rfl
    intro m _
    exact congrArg e (by push_cast; ring)
  rw [hre]
  -- cap the sum over the support
  set cap : вДХ вЖТ вДЭ := fun t =>
    (if (t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±) = 0 then ((N / t : вДХ) : вДЭ)
     else min ((N / t : вДХ) : вДЭ) (1 / (2 * |(t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±)|))) with hcap
  have hcap0 : вИА t, 0 вЙ§ cap t := by
    intro t
    rw [hcap]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  have hterm : вИА t вИИ Finset.Ioc 0 N,
      вАЦ(c t : вДВ) * вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ
      вЙ§ (if t вЙ§ U * V then Real.log (U * V) * cap t else 0) := by
    intro t ht
    simp only [Finset.mem_Ioc] at ht
    by_cases htuv : t вЙ§ U * V
    ¬Ј rw [if_pos htuv, norm_mul, Complex.norm_real, Real.norm_eq_abs]
      have h1 : |c t| вЙ§ Real.log (U * V) := by
        calc |c t| вЙ§ Real.log t := abs_truncate_mul_le_log U V t
          _ вЙ§ Real.log (U * V) := by
            apply Real.log_le_log (by exact_mod_cast ht.1)
            exact_mod_cast htuv
      have h2 : вАЦвИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ вЙ§ cap t := by
        rw [hcap]
        exact exp_sum_Ioc_min_bound ((t : вДЭ) * ќ±) (N / t)
      exact mul_le_mul h1 h2 (norm_nonneg _) hlogUV0
    ¬Ј rw [if_neg htuv]
      push_neg at htuv
      have hz : c t = 0 := truncate_mul_eq_zero_of_gt _ _ U V t htuv
      rw [hz]
      simp
  calc вАЦвИС t вИИ Finset.Ioc 0 N, (c t : вДВ) *
        вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ
      вЙ§ вИС t вИИ Finset.Ioc 0 N,
          вАЦ(c t : вДВ) * вИС m вИИ Finset.Ioc 0 (N / t), e ((m : вДЭ) * ((t : вДЭ) * ќ±))вАЦ :=
        norm_sum_le _ _
    _ вЙ§ вИС t вИИ Finset.Ioc 0 N, (if t вЙ§ U * V then Real.log (U * V) * cap t else 0) :=
        Finset.sum_le_sum hterm
    _ = вИС t вИИ Finset.Ioc 0 (U * V), Real.log (U * V) * cap t := by
        rw [вЖР Finset.sum_filter]
        apply Finset.sum_congr _ (fun t _ => rfl)
        ext t
        simp only [Finset.mem_filter, Finset.mem_Ioc]
        constructor
        ¬Ј rintro вЯ®вЯ®h1, _вЯ©, h3вЯ©
          exact вЯ®h1, h3вЯ©
        ¬Ј rintro вЯ®h1, h2вЯ©
          exact вЯ®вЯ®h1, le_trans h2 hUVвЯ©, h2вЯ©
    _ = Real.log (U * V) * вИС t вИИ Finset.Ioc 0 (U * V), cap t := (Finset.mul_sum _ _ _).symm
    _ вЙ§ Real.log (U * V) *
        ((2 * (N : вДЭ) / q) * (1 + Real.log (U * V))
          + ((U * V / (q / 2) + 1 : вДХ) : вДЭ)
            * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) := by
        apply mul_le_mul_of_nonneg_left _ hlogUV0
        have := min_sum_tight a q hq ha ќ± hќ± N (U * V)
        rw [hcap]
        push_cast at this вКҐ
        exact this

/-- `log` of a natural cast is nonneg (`log 0 = 0`). -/

lemma S1_bound_tight (a q : вДХ) (hq : 2 вЙ§ q) (ha : Nat.Coprime a q) (ќ± : вДЭ)
    (hќ± : |ќ± - (a : вДЭ) / q| вЙ§ 1 / (q : вДЭ) ^ 2) (U N : вДХ) (hU : U вЙ§ N) :
    вАЦвИС n вИИ Finset.Ioc 0 N,
        (((truncate (ќЉ : ArithmeticFunction вДЭ) U * ArithmeticFunction.log) n : вДЭ) : вДВ)
          * e ((n : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) *
          (((2 * (N : вДЭ) / q) * (1 + Real.log U)
            + ((U / (q / 2) + 1 : вДХ) : вДЭ)
              * (2 * (2 * (q : вДЭ)) + 4 * q * (1 + Real.log (2 * q)))) + U) := by
  have hlogN0 : (0 : вДЭ) вЙ§ Real.log (N + 1) := by
    apply Real.log_nonneg
    push_cast
    linarith
  set cap : вДХ вЖТ вДЭ := fun t =>
    (if (t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±) = 0 then ((N / t : вДХ) : вДЭ)
     else min ((N / t : вДХ) : вДЭ) (1 / (2 * |(t : вДЭ) * ќ± - round ((t : вДЭ) * ќ±)|))) with hcap
  have hcap0 : вИА t, 0 вЙ§ cap t := by
    intro t
    rw [hcap]
    dsimp only
    split
    ¬Ј positivity
    ¬Ј exact le_min (by positivity) (by positivity)
  -- regroup
  rw [sum_Ioc_mul_weight_eq_sum_sum (truncate (ќЉ : ArithmeticFunction вДЭ) U)
    ArithmeticFunction.log (fun n => e ((n : вДЭ) * ќ±)) N]
  -- per-d inner bound
  have hinner : вИА d вИИ Finset.Ioc 0 N,
      вАЦвИС m вИИ Finset.Ioc 0 (N / d), ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
      вЙ§ 2 * Real.log (N + 1) * (cap d + 1) := by
    intro d hd
    simp only [Finset.mem_Ioc] at hd
    set M : вДХ := N / d with hM
    set ќ≤ : вДЭ := (d : вДЭ) * ќ± with hќ≤
    -- normalize the argument and the log
    have hstep1 : вИС m вИИ Finset.Ioc 0 M, ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)
        = вИС m вИИ Finset.Ioc 0 M, ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_congr rfl
      intro m _
      rw [ArithmeticFunction.log_apply]
      congr 1
      exact congrArg e (by rw [hќ≤]; push_cast; ring)
    -- extend Ioc 0 M to range (M+1) (the m = 0 term vanishes)
    have hstep2 : вИС m вИИ Finset.Ioc 0 M, ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)
        = вИС m вИИ Finset.range (M + 1), ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_subset
      ¬Ј intro m hm
        simp only [Finset.mem_Ioc] at hm
        simp only [Finset.mem_range]
        omega
      ¬Ј intro m hm hnotm
        simp only [Finset.mem_range] at hm
        simp only [Finset.mem_Ioc] at hnotm
        have hm0 : m = 0 := by omega
        subst hm0
        simp
    -- the capped weight agrees with log on the range
    have hstep3 : вИС m вИИ Finset.range (M + 1), ((Real.log m : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)
        = вИС m вИИ Finset.range (M + 1),
            ((Real.log ((min m (M + 1) : вДХ) : вДЭ) : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤) := by
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_range] at hm
      rw [min_eq_left (by omega : m вЙ§ M + 1)]
    have habel := abel_exp_sum (fun m => Real.log ((min m (M + 1) : вДХ) : вДЭ))
      (fun m => log_natCast_nonneg _)
      (by
        intro x y h
        exact log_natCast_monotone (by omega : min x (M + 1) вЙ§ min y (M + 1)))
      (Real.log ((M + 1 : вДХ) : вДЭ))
      (fun m => by exact log_natCast_monotone (min_le_right m (M + 1)))
      ќ≤ (M + 1)
    have hlogM : Real.log ((M + 1 : вДХ) : вДЭ) вЙ§ Real.log (N + 1) := by
      have h1 : (M : вДХ) + 1 вЙ§ N + 1 := by
        have : M вЙ§ N := hM вЦЄ Nat.div_le_self N d
        omega
      have := log_natCast_monotone (show (M + 1 : вДХ) вЙ§ (N + 1 : вДХ) from h1)
      push_cast at this вКҐ
      exact this
    have hcapd : (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
        else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) вЙ§ cap d + 1 := by
      have h1 := cap_succ_le ќ≤ M
      have h2 : (if ќ≤ - round ќ≤ = 0 then (M : вДЭ)
          else min (M : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) = cap d := by
        rw [hcap, hќ≤, hM]
      rw [h2] at h1
      exact h1
    have hcapnn : (0 : вДЭ) вЙ§ (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
        else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
      split
      ¬Ј positivity
      ¬Ј exact le_min (by positivity) (by positivity)
    calc вАЦвИС m вИИ Finset.Ioc 0 M, ((ArithmeticFunction.log m : вДЭ) : вДВ)
          * e (((d * m : вДХ) : вДЭ) * ќ±)вАЦ
        = вАЦвИС m вИИ Finset.range (M + 1),
            ((Real.log ((min m (M + 1) : вДХ) : вДЭ) : вДЭ) : вДВ) * e ((m : вДЭ) * ќ≤)вАЦ := by
          rw [hstep1, hstep2, hstep3]
      _ вЙ§ 2 * Real.log ((M + 1 : вДХ) : вДЭ)
            * (if ќ≤ - round ќ≤ = 0 then ((M + 1 : вДХ) : вДЭ)
               else min ((M + 1 : вДХ) : вДЭ) (1 / (2 * |ќ≤ - round ќ≤|))) := by
          have := habel
          push_cast at this вКҐ
          exact this
      _ вЙ§ 2 * Real.log (N + 1) * (cap d + 1) := by
          apply mul_le_mul
          ¬Ј have : (0:вДЭ) вЙ§ 2 := by norm_num
            nlinarith [hlogM]
          ¬Ј exact hcapd
          ¬Ј exact hcapnn
          ¬Ј positivity
  -- support + assembly
  have hterm : вИА d вИИ Finset.Ioc 0 N,
