lemma tsum_cpow_telescope_summable (x : вДХ) (hx : 1 вЙ§ x) {s : вДВ} (hs : 1 < s.re) :
    Summable (fun n : вДХ => (if n < x then (0:вДВ)
      else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n + 1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))) := by
  have hs1 : (0:вДЭ) < s.re - 1 := by linarith
  have hC0 : (0:вДЭ) вЙ§ вАЦs - 1вАЦ / (s.re - 1) := div_nonneg (norm_nonneg _) hs1.le
  have hgmono : вИА n : вДХ, 1 вЙ§ n вЖТ
      (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)) вЙ§ ((n : вДЭ)) ^ (-(s.re - 1)) := by
    intro n hn1
    apply Real.rpow_le_rpow_of_nonpos
      (by exact_mod_cast Nat.lt_of_lt_of_le Nat.zero_lt_one hn1)
      (by push_cast; linarith)
