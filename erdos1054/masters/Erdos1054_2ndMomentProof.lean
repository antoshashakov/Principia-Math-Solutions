section ConjSymmetry
open Finset Filter Metric Topology

/-- Values of a quadratic character lie in `{вИТ1, 0, 1}` (copy of the SiegelTheorem
    brick, needed here for conjugation symmetry). -/
lemma dvp_real_char_repr {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1)
    (a : ZMod q) : ѕЗ a = -1 вИ® ѕЗ a = 0 вИ® ѕЗ a = 1 := by
  by_cases hu : IsUnit a
  ¬Ј have hsq : ѕЗ a * ѕЗ a = 1 := by
      have h1 : (ѕЗ ^ 2) a = 1 := by
        rw [hѕЗ2]
        exact MulChar.one_apply hu
      rw [pow_two, MulChar.mul_apply] at h1
      exact h1
    have hfactor : (ѕЗ a - 1) * (ѕЗ a + 1) = 0 := by
      linear_combination hsq
    rcases mul_eq_zero.mp hfactor with h | h
    ¬Ј right; right
      exact sub_eq_zero.mp h
    ¬Ј left
      exact eq_neg_of_add_eq_zero_left h
  ¬Ј right; left
    exact MulChar.map_nonunit ѕЗ hu

/-- Quadratic characters are real-valued: conjugation fixes every value. -/
lemma conj_char_val {q : вДХ} (ѕЗ : DirichletCharacter вДВ q) (hѕЗ2 : ѕЗ ^ 2 = 1)
    (a : ZMod q) : (starRingEnd вДВ) (ѕЗ a) = ѕЗ a := by
  rcases dvp_real_char_repr ѕЗ hѕЗ2 a with h | h | h <;> rw [h] <;> simp

/-- The antiholomorphic square: if `f` is complex-differentiable at `conj z`, then
    `s вЖ¶ conj (f (conj s))` is complex-differentiable at `z` with the conjugated
    derivative. -/
lemma hasDerivAt_conj_conj {f : вДВ вЖТ вДВ} {f' z : вДВ}
    (hf : HasDerivAt f f' ((starRingEnd вДВ) z)) :
    HasDerivAt (fun s => (starRingEnd вДВ) (f ((starRingEnd вДВ) s)))
      ((starRingEnd вДВ) f') z := by
  rw [hasDerivAt_iff_isLittleO] at hf вКҐ
  have hct : Tendsto (starRingEnd вДВ) (рЭУЭ z) (рЭУЭ ((starRingEnd вДВ) z)) :=
    Complex.continuous_conj.continuousAt
  have h1 := hf.comp_tendsto hct
  simp only [Function.comp_def] at h1
  rw [Asymptotics.isLittleO_iff] at h1 вКҐ
  intro c hc
  filter_upwards [h1 hc] with x hx
  have he : (starRingEnd вДВ) (f ((starRingEnd вДВ) x)) - (starRingEnd вДВ) (f ((starRingEnd вДВ) z))
      - (x - z) вАҐ (starRingEnd вДВ) f'
      = (starRingEnd вДВ) (f ((starRingEnd вДВ) x) - f ((starRingEnd вДВ) z)
          - ((starRingEnd вДВ) x - (starRingEnd вДВ) z) вАҐ f') := by
    simp only [map_sub, map_mul, smul_eq_mul, Complex.conj_conj]
  have hn : вАЦ(starRingEnd вДВ) x - (starRingEnd вДВ) zвАЦ = вАЦx - zвАЦ := by
    rw [вЖР map_sub, Complex.norm_conj]
  calc вАЦ(starRingEnd вДВ) (f ((starRingEnd вДВ) x)) - (starRingEnd вДВ) (f ((starRingEnd вДВ) z))
        - (x - z) вАҐ (starRingEnd вДВ) f'вАЦ
      = вАЦf ((starRingEnd вДВ) x) - f ((starRingEnd вДВ) z)
          - ((starRingEnd вДВ) x - (starRingEnd вДВ) z) вАҐ f'вАЦ := by
        rw [he, Complex.norm_conj]
    _ вЙ§ c * вАЦ(starRingEnd вДВ) x - (starRingEnd вДВ) zвАЦ := hx
    _ = c * вАЦx - zвАЦ := by rw [hn]

/-- On `Re > 1` the conjugation symmetry holds by the Dirichlet series. -/
lemma LFunction_conj_series {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ2 : ѕЗ ^ 2 = 1) {w : вДВ} (hw : 1 < w.re) :
    (starRingEnd вДВ) (DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) w))
      = DirichletCharacter.LFunction ѕЗ w := by
  have hwc : 1 < ((starRingEnd вДВ) w).re := by
    rw [Complex.conj_re]
    exact hw
  rw [DirichletCharacter.LFunction_eq_LSeries _ hwc,
    DirichletCharacter.LFunction_eq_LSeries _ hw]
  have hsum : LSeriesSummable (fun n : вДХ => ѕЗ ((n : ZMod N))) ((starRingEnd вДВ) w) :=
    DirichletCharacter.LSeriesSummable_of_one_lt_re ѕЗ hwc
  have h1 : HasSum (fun n : вДХ => LSeries.term (fun n : вДХ => ѕЗ ((n : ZMod N)))
      ((starRingEnd вДВ) w) n)
      (LSeries (fun n : вДХ => ѕЗ ((n : ZMod N))) ((starRingEnd вДВ) w)) := hsum.hasSum
  have h2 := h1.star
  simp only [Complex.star_def] at h2
  have h3 : (fun n : вДХ => (starRingEnd вДВ)
      (LSeries.term (fun n : вДХ => ѕЗ ((n : ZMod N))) ((starRingEnd вДВ) w) n))
      = fun n : вДХ => LSeries.term (fun n : вДХ => ѕЗ ((n : ZMod N))) w n := by
    funext n
    rcases Nat.eq_zero_or_pos n with h0 | hpos
    ¬Ј subst h0
      simp [LSeries.term]
    ¬Ј have hn0 : n вЙ† 0 := hpos.ne'
      rw [LSeries.term_of_ne_zero hn0, LSeries.term_of_ne_zero hn0,
        map_divвВА, conj_char_val ѕЗ hѕЗ2]
      congr 1
      have harg : ((n : вДВ)).arg вЙ† Real.pi := by
        rw [Complex.natCast_arg]
        exact Real.pi_ne_zero.symm
      have hcp := Complex.cpow_conj ((n : вДВ)) w harg
      rw [map_natCast] at hcp
      rw [hcp, Complex.conj_conj]
  rw [h3] at h2
  rw [LSeries]
  exact h2.tsum_eq.symm

/-- **Conjugation symmetry of quadratic L-functions** (SW brick S4a-1): for `ѕЗ¬≤ = 1`,
    `ѕЗ вЙ† 1`, `L(ѕЗ, conj s) = conj (L(ѕЗ, s))` everywhere вАФ the coefficients are real,
    and both sides are entire. -/
theorem LFunction_conj_quadratic {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1) (s : вДВ) :
    DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) s)
      = (starRingEnd вДВ) (DirichletCharacter.LFunction ѕЗ s) := by
  have hLd : Differentiable вДВ (DirichletCharacter.LFunction ѕЗ) :=
    DirichletCharacter.differentiable_LFunction hѕЗ1
  have hgd : Differentiable вДВ (fun w => (starRingEnd вДВ)
      (DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) w))) := by
    intro z
    exact (hasDerivAt_conj_conj (hLd ((starRingEnd вДВ) z)).hasDerivAt).differentiableAt
  have hU : IsOpen {w : вДВ | 1 < w.re} := isOpen_lt continuous_const Complex.continuous_re
  have h2U : (2:вДВ) вИИ {w : вДВ | 1 < w.re} := by
    simp only [Set.mem_setOf_eq]
    norm_num
  have hseed : (fun w => (starRingEnd вДВ)
      (DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) w)))
      =бґ†[рЭУЭ 2] DirichletCharacter.LFunction ѕЗ := by
    filter_upwards [hU.mem_nhds h2U] with w hw
    exact LFunction_conj_series ѕЗ hѕЗ2 hw
  have heq : Set.EqOn (fun w => (starRingEnd вДВ)
      (DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) w)))
      (DirichletCharacter.LFunction ѕЗ) Set.univ :=
    ((hgd.differentiableOn).analyticOnNhd isOpen_univ).eqOn_of_preconnected_of_eventuallyEq
      ((hLd.differentiableOn).analyticOnNhd isOpen_univ)
      isPreconnected_univ (Set.mem_univ 2) hseed
  have hs := heq (Set.mem_univ s)
  simp only at hs
  calc DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) s)
      = (starRingEnd вДВ) ((starRingEnd вДВ)
          (DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) s))) := (Complex.conj_conj _).symm
    _ = (starRingEnd вДВ) (DirichletCharacter.LFunction ѕЗ s) := by rw [hs]

/-- **Zeros of quadratic L-functions pair by conjugation** (SW brick S4a-1вА≤). -/
theorem conj_zero_quadratic {N : вДХ} [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ2 : ѕЗ ^ 2 = 1) (hѕЗ1 : ѕЗ вЙ† 1) {ѕБ : вДВ}
    (hz : DirichletCharacter.LFunction ѕЗ ѕБ = 0) :
    DirichletCharacter.LFunction ѕЗ ((starRingEnd вДВ) ѕБ) = 0 := by
  rw [LFunction_conj_quadratic ѕЗ hѕЗ2 hѕЗ1 ѕБ, hz, map_zero]

end ConjSymmetry

open Metric ArithmeticFunction in
open scoped LSeries.notation ArithmeticFunction in
/-- **The conjugate-pair zero bound at the real point** (SW brick S4a-2): if BOTH
    `ќ≤ ¬± iќ≥` are zeros of `L(¬Ј,ѕЗ)` (ќ≥ вЙ† 0) close to the real point `ѕГ`, peeling the
    PAIR from Landau's partial fractions doubles the repulsion:
    `Re L(ѕЗќЫ, ѕГ) вЙ§ 40(log(7NѕГ/(ѕГвИТ1)) + 1) вИТ 2(ѕГвИТќ≤)/((ѕГвИТќ≤)¬≤ + ќ≥¬≤)`. -/
theorem zero_pair_bound_uniform (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N)
    (hѕЗ : ѕЗ вЙ† 1) (ќ≤ ќ≥ : вДЭ) (hќ≥ : ќ≥ вЙ† 0)
    (hzero : DirichletCharacter.LFunction ѕЗ ((ќ≤ : вДВ) + ќ≥ * Complex.I) = 0)
    (hzero' : DirichletCharacter.LFunction ѕЗ ((ќ≤ : вДВ) - ќ≥ * Complex.I) = 0)
    (ѕГ : вДЭ) (hѕГ1 : 1 < ѕГ) (hѕГ2 : ѕГ вЙ§ 2) (hnear : (ѕГ - ќ≤)^2 + ќ≥^2 вЙ§ 1/25) :
    (LSeries (вЖЧѕЗ * вЖЧќЫ) ((ѕГ : вДВ))).re
      вЙ§ 40 * (Real.log ((N : вДЭ) * 7 * ѕГ / (ѕГ - 1)) + 1)
        - 2 * (ѕГ - ќ≤) / ((ѕГ - ќ≤)^2 + ќ≥^2) := by
  set c : вДВ := (ѕГ : вДВ) + (0:вДЭ) * Complex.I with hc
  have hceq : c = (ѕГ : вДВ) := by rw [hc]; push_cast; ring
  have hcre : c.re = ѕГ := by rw [hceq]; simp
  set ѕБвВА : вДВ := (ќ≤ : вДВ) + ќ≥ * Complex.I with hѕБвВАdef
  set ѕБвВБ : вДВ := (ќ≤ : вДВ) - ќ≥ * Complex.I with hѕБвВБdef
  have hѕБвВАre : ѕБвВА.re = ќ≤ := by rw [hѕБвВАdef]; simp
  have hѕБвВБre : ѕБвВБ.re = ќ≤ := by rw [hѕБвВБdef]; simp
  have hѕБвВАim : ѕБвВА.im = ќ≥ := by rw [hѕБвВАdef]; simp
  have hѕБвВБim : ѕБвВБ.im = -ќ≥ := by rw [hѕБвВБdef]; simp
