    have hrate : Real.exp (-c * Real.log ((t:вДЭ) - 1) ^ ((1:вДЭ)/10))
        вЙ§ Real.exp (-(c/2) * L) := by
      apply Real.exp_le_exp.mpr
      have h1 : (Real.log N / 2) ^ ((1:вДЭ)/10) вЙ§ Real.log ((t:вДЭ) - 1) ^ ((1:вДЭ)/10) :=
