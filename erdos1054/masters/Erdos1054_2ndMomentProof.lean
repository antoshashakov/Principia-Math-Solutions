            else (вАЦs - 1вАЦ / (s.re - 1)) * (((n : вДЭ)) ^ (-(s.re - 1))
              - (((n + 1 : вДХ)) : вДЭ) ^ (-(s.re - 1)))) = 0 := by
          intro n hn
