/-- **Pointwise Dirichlet-LвБі bound**: `вАЦD_N(ќ≤)¬≤вАЦ¬≤ = вАЦD_N(ќ≤)вАЦвБі вЙ§ 1/(16|ќ≤вИТround ќ≤|вБі)` for `ќ≤ вИЙ вД§`
    (`sin ѕАќ≤ вЙ† 0`). From `exp_sum_bound`. The integrand of the arc-tail LвБі integral `вИЂ_{tail}|D_N|вБі`
    (`rho_bessel`); on the tail `вАЦќ±вИТcвАЦ > ќі_q`, giving `вИЂ_{|ќ≤|>ќі_q}|D_N|вБі вЙ≤ 1/ќі_q¬≥`. -/
lemma dirichlet_pow4_pt (N : вДХ) (ќ≤ : вДЭ) (hќ≤ : Real.sin (Real.pi * ќ≤) вЙ† 0) :
    вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)) ^ 2вАЦ ^ 2 вЙ§ 1 / (16 * |ќ≤ - round ќ≤| ^ 4) := by
  have hb := exp_sum_bound ќ≤ hќ≤ N
  have hnorm : вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)) ^ 2вАЦ ^ 2
      = вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)вАЦ ^ 4 := by
    rw [norm_pow]; ring
  rw [hnorm]
  have h4 : вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)вАЦ ^ 4 вЙ§ (1 / (2 * |ќ≤ - round ќ≤|)) ^ 4 :=
    pow_le_pow_leftвВА (norm_nonneg _) hb 4
  refine le_trans h4 (le_of_eq ?_)
  rw [div_pow, one_pow, mul_pow]
  norm_num

