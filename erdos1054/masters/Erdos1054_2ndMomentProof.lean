            - (t:вДЭ) * (1 / (q.totient : вДЭ))| := by
      rw [show (вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ((ќЫ n : вДЭ) : вДВ))
          - (t : вДВ) * (1 / (q.totient : вДВ))
          = ((((вИС n вИИ (Finset.range t).filter (fun n => n % q = r), ќЫ n)
              - (t:вДЭ) * (1 / (q.totient : вДЭ)) : вДЭ)) : вДВ) from by push_cast; ring,
