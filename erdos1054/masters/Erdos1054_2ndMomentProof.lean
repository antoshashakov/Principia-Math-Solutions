        nlinarith [hќ≥4d, hd0, hg0, h3a]
      have h5 : (2*|ќ≥|+7)*(1+d) вЙ§ 4*|ќ≥|+7 := by nlinarith [h3]
      have h2 : (N:вДЭ)*((2*|ќ≥|+7)*(1+d)) вЙ§ (N:вДЭ)*(4*|ќ≥|+7) :=
        mul_le_mul_of_nonneg_left h5 (by linarith)
      have h4 : (1/d) * d = 1 := by field_simp
      calc (N:вДЭ)*(2*|ќ≥|+7)*(1+d) = (N:вДЭ)*((2*|ќ≥|+7)*(1+d)) := by ring
        _ вЙ§ (N:вДЭ)*(4*|ќ≥|+7) := h2
