-- abstract group bounds (over abstract reals вАФ light to elaborate, instantiated below)
lemma csup_g1 (a b c d p q Z L : вДЭ)
    (ha : a вЙ§ L) (ha0 : 0 вЙ§ a) (hb : b вЙ§ 2 * Z) (hc : 1 + c вЙ§ L) (hc0 : 0 вЙ§ 1 + c)
    (hpq : 16 * p + 4 * q вЙ§ 20 * Z) (hd : 2 + d вЙ§ 2 * L) (hd0 : 0 вЙ§ 2 + d) (hp : p вЙ§ Z * L)
