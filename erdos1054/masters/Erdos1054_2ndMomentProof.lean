theorem mertens_third_theorem (n : вДХ) (hn : 3 вЙ§ n) :
    1 / (3 * Real.log n) вЙ§ вИП p вИИ (Finset.range (n + 1)).filter Nat.Prime, (1 - 1 / (p : вДЭ)) := by
  by_cases hn2 : n вЙ• 200;
  ¬Ј have := neg_log_prodP_bound n hn2;
    -- Exponentiating both sides, we get $prodP n > \frac{1}{3 \log n}$.
    have h_exp : prodP n > 1 / (3 * Real.log n) := by
      have h_exp : Real.log (prodP n) > -Real.log (3 * Real.log n) := by
        rw [ Real.log_mul ] <;> norm_num;
        ¬Ј have h_log3 : Real.log 3 > 1.095 := by
            norm_num [ Real.log_lt_log ];
            rw [ div_lt_iffвВА' ] <;> norm_num [ вЖР Real.log_rpow, Real.lt_log_iff_exp_lt ];
            have := Real.exp_one_lt_d9.le ; norm_num1 at * ; rw [ show Real.exp 219 = ( Real.exp 1 ) ^ 219 by rw [ вЖР Real.exp_nat_mul ] ; norm_num ] ; exact lt_of_le_of_lt ( pow_le_pow_leftвВА ( by positivity ) this _ ) ( by norm_num );
          linarith;
        ¬Ј grind;
      rw [ gt_iff_lt, Real.lt_log_iff_exp_lt ] at h_exp;
      ¬Ј simpa [ Real.exp_neg, Real.exp_log ( show 0 < 3 * Real.log n by exact mul_pos zero_lt_three ( Real.log_pos ( by norm_cast; linarith ) ) ) ] using h_exp;
      ¬Ј exact Finset.prod_pos fun p hp => sub_pos.mpr <| by rw [ div_lt_iffвВА ] <;> norm_cast <;> linarith [ Finset.mem_filter.mp hp, Nat.Prime.two_le <| Finset.mem_filter.mp hp |>.2 ] ;
    exact h_exp.le;
  ¬Ј -- Apply the finite check lemma to conclude the proof.
    apply mertens_finite_check n hn (by linarith)


end

end MertensThirdProof

/-- (A2) **Mertens' third theorem** (lower-bound form used by the paper) вАФ
    now a THEOREM, derived from `mertens_third_theorem` above with `cвВА = 1/3`:
    the `y = 2` case is a direct computation (`вИП = 1/2`, `log 4 > 2/3`), and
    `y вЙ• 3` follows from the main bound plus `log y вЙ§ log (2y)`. -/
theorem mertens_third_lower :
    вИГ cвВА : вДЭ, 0 < cвВА вИІ вИА y : вДХ, 2 вЙ§ y вЖТ
      cвВА / Real.log (2 * (y : вДЭ)) вЙ§
        вИП p вИИ (Finset.range (y + 1)).filter Nat.Prime, (1 - 1 / (p : вДЭ)) := by
  refine вЯ®1/3, by norm_num, fun y hy => ?_вЯ©
  have hy2r : (2 : вДЭ) вЙ§ (y : вДЭ) := by exact_mod_cast hy
  have hlog2y : (0 : вДЭ) < Real.log (2 * (y : вДЭ)) := by
    apply Real.log_pos; nlinarith
  rcases Nat.lt_or_ge y 3 with h3 | h3
  ¬Ј -- y = 2: the product over primes вЙ§ 2 is 1/2 and log 4 > 2/3
    have hy2 : y = 2 := le_antisymm (Nat.lt_succ_iff.mp h3) hy
    subst hy2
    have hprod : вИП p вИИ (Finset.range 3).filter Nat.Prime, (1 - 1 / (p : вДЭ)) = 1/2 := by
      norm_num [Finset.prod_filter, Finset.prod_range_succ]
    rw [hprod]
    have hlog4 : Real.log (2 * ((2 : вДХ) : вДЭ)) вЙ• 2/3 := by
      have h24 : (2 * ((2 : вДХ) : вДЭ)) = 4 := by norm_num
      rw [h24, show (4 : вДЭ) = 2 ^ 2 by norm_num, Real.log_pow]
      have hl2 := Real.log_two_gt_d9
      push_cast; nlinarith
    rw [div_le_iffвВА hlog2y]
    nlinarith [hlog4]
  ¬Ј -- y вЙ• 3: Woett's bound + log monotonicity
    have h1 := mertens_third_theorem y h3
    have hy1 : (1 : вДЭ) < (y : вДЭ) := by exact_mod_cast (by linarith : 1 < y)
    have hlogy : (0 : вДЭ) < Real.log (y : вДЭ) := Real.log_pos hy1
    have hmono : Real.log (y : вДЭ) вЙ§ Real.log (2 * (y : вДЭ)) :=
      Real.log_le_log (by linarith) (by linarith)
    have step : (1 : вДЭ)/3 / Real.log (2 * (y : вДЭ)) вЙ§ 1 / (3 * Real.log (y : вДЭ)) := by
      rw [show (1 : вДЭ)/3 / Real.log (2 * (y : вДЭ)) = 1 / (3 * Real.log (2 * (y : вДЭ))) by ring]
      apply one_div_le_one_div_of_le
      ¬Ј linarith
      ¬Ј linarith
    exact le_trans step h1


