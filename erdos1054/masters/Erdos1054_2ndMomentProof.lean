  have hNR : (8 : вДЭ) вЙ§ (N : вДЭ) := by exact_mod_cast hN8
  have hPcube : (P : вДЭ) вЙ§ (P : вДЭ) ^ 3 := by
    have h1 : (1 : вДЭ) вЙ§ (P : вДЭ) ^ 2 := by nlinarith [hPR]
    calc (P : вДЭ) = P * 1 := by ring
      _ вЙ§ P * P ^ 2 := by apply mul_le_mul_of_nonneg_left h1 (by linarith)
      _ = P ^ 3 := by ring
  have hPNR : (P : вДЭ) вЙ§ (N : вДЭ) := le_trans hPcube (by exact_mod_cast hPN)
  have hPQR : (P : вДЭ) * Q вЙ§ N := by exact_mod_cast hPQ
  have hQ0R : (0:вДЭ) вЙ§ (Q:вДЭ) := by positivity
  have hQR : (Q : вДЭ) вЙ§ N := by
    nlinarith [hPQR, hPR, hQ0R, mul_nonneg (show (0:вДЭ) вЙ§ (P:вДЭ) - 1 by linarith) hQ0R]
  have hsP1 : (1 : вДЭ) вЙ§ Real.sqrt P := by
    rw [show (1:вДЭ) = Real.sqrt 1 from (Real.sqrt_one).symm]
