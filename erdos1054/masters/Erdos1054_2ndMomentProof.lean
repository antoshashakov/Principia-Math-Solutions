        вЙ§ X * ((24*C + (6*C + 48/c^2)) * Real.exp (-((c/8) * u ^ ((1:вДЭ)/2)))) := by
      apply mul_le_mul_of_nonneg_left hR4a hX0.le
    calc 6 * M * X ^ (1 - g/2 : вДЭ)
