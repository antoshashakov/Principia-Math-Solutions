          apply mul_le_mul_of_nonneg_right _ (by positivity)
          apply mul_le_mul_of_nonneg_left hMle (by norm_num)
      _ вЙ§ 6 * (4*C * u ^ ((5:вДЭ)/2)) * (X * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))) := by
          apply mul_le_mul_of_nonneg_left _ (by positivity)
          apply mul_le_mul_of_nonneg_left h1 hX0.le
      _ = 24*C * u ^ ((5:вДЭ)/2) * (X * Real.exp (-((c/4) * u ^ ((1:вДЭ)/2)))) := by ring
  have hgle : g вЙ§ 1/2 := by
    rw [hgdef]
    have h1 : c * Ne вЙ§ 1/2 := by nlinarith
    have h2 : c * Ne / LTv вЙ§ c * Ne / 1 := by
      apply div_le_div_of_nonneg_left (by positivity) one_pos (by linarith)
