  вИС q вИИ Finset.Icc 1 P, ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2 * cRamC q n




lemma e_neg_conj (x : вДЭ) : e (-x) = starRingEnd вДВ (e x) := by
  rw [e, e, вЖР Complex.exp_conj]
  congr 1
  simp only [map_mul, Complex.conj_I, Complex.conj_ofReal, map_ofNat]
  push_cast
  ring

/-- **harc brick 84a: `cRamC` is the integer Ramanujan sum.** The `e(вИТna/q)` form is the
    conjugate of `ramSum`, which is real (`ramSum_eq_cRam`). -/
lemma cRamC_eq_cRam (q n : вДХ) (hq : 0 < q) : cRamC q n = (cRam q n : вДВ) := by
  have hconj : cRamC q n = starRingEnd вДВ (ramSum q n) := by
    rw [cRamC, ramSum, map_sum]
    apply Finset.sum_congr rfl
    intro a _
    rw [вЖР e_neg_conj]
    congr 1
    ring
  rw [hconj, ramSum_eq_cRam q n hq]
  simp

/-- **harc brick 84b: the real part of the truncated singular series** is the real
    `вИС_{qвЙ§P} ќЉ(q)¬≤¬Јc_q(n)/ѕЖ(q)¬≤` (the `Tarith` partial sum of the truncation half). -/
lemma singSeriesC_re (P n : вДХ) :
    (singSeriesC P n).re
      = вИС q вИИ Finset.Icc 1 P,
          (ArithmeticFunction.moebius q : вДЭ) ^ 2 * (cRam q n : вДЭ) / (Nat.totient q : вДЭ) ^ 2 := by
  rw [singSeriesC, Complex.re_sum]
  apply Finset.sum_congr rfl
  intro q hq
  have hq1 : 1 вЙ§ q := (Finset.mem_Icc.mp hq).1
  rw [cRamC_eq_cRam q n hq1]
  have hcast : ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2 * (cRam q n : вДВ)
      = (((ArithmeticFunction.moebius q : вДЭ) ^ 2 * (cRam q n : вДЭ) / (Nat.totient q : вДЭ) ^ 2 : вДЭ) : вДВ) := by
    push_cast
    ring
  rw [hcast, Complex.ofReal_re]

















lemma e_zero : e 0 = 1 := by
  rw [e]
  simp

lemma continuous_e' : Continuous e := by
  unfold e
  fun_prop

/-- **Bessel on `(0,1]` for `f` with integrable square** вАФ no continuity and no
    measurability hypothesis (a non-measurable `f` yields junk-zero coefficients and the
    bound holds trivially). Discharges HarcArcTail's `bessel_Ioc` axiom verbatim. -/
lemma bessel_Ioc_proven (f : вДЭ вЖТ вДВ)
    (hf : IntegrableOn (fun ќ± => вАЦf ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1)) (M : вДХ) :
    вИС n вИИ Finset.range M, вАЦвИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
      вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2 := by
  classical
  have hRHS0 : (0:вДЭ) вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2 :=
    integral_nonneg (fun ќ± => sq_nonneg _)
  have hecont : вИА n : вДХ, Continuous fun ќ± : вДЭ => e (-((n : вДЭ) * ќ±)) := by
    intro n
    exact continuous_e'.comp (by fun_prop)
  by_cases hmeas : AEStronglyMeasurable f (volume.restrict (Set.Ioc (0:вДЭ) 1))
  swap
  ¬Ј -- non-measurable: every coefficient integral is the junk value 0
    have hczero : вИА n : вДХ,
        (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±))) = 0 := by
      intro n
      apply integral_undef
      intro hInt
      apply hmeas
      have h2 : AEStronglyMeasurable
          (fun ќ± => (f ќ± * e (-((n : вДЭ) * ќ±))) * e ((n : вДЭ) * ќ±))
          (volume.restrict (Set.Ioc (0:вДЭ) 1)) :=
        hInt.aestronglyMeasurable.mul
          (continuous_e'.comp (by fun_prop : Continuous fun ќ± : вДЭ => (n : вДЭ) * ќ±)).aestronglyMeasurable
      have hid : (fun ќ± => (f ќ± * e (-((n : вДЭ) * ќ±))) * e ((n : вДЭ) * ќ±)) = f := by
        funext ќ±
        rw [mul_assoc, e_add]
        simp [e_zero]
      rwa [hid] at h2
    calc вИС n вИИ Finset.range M, вАЦвИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
        = вИС n вИИ Finset.range M, (0:вДЭ) := by
          apply Finset.sum_congr rfl
          intro n _
          rw [hczero n]
          simp
      _ = 0 := Finset.sum_const_zero
      _ вЙ§ _ := hRHS0
  -- measurable case: f is integrable, then the projection trick
  have hfint : IntegrableOn f (Set.Ioc (0:вДЭ) 1) := by
    apply Integrable.mono'
      (g := fun ќ± => (1 + вАЦf ќ±вАЦ ^ 2) / 2)
      ((((integrable_const (1:вДЭ)).add hf).div_const 2)) hmeas
    apply Filter.Eventually.of_forall
    intro ќ±
    nlinarith [sq_nonneg (вАЦf ќ±вАЦ - 1), norm_nonneg (f ќ±)]
  set c : вДХ вЖТ вДВ := fun n => вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±)) with hc
  set T : вДЭ вЖТ вДВ := fun ќ± => вИС n вИИ Finset.range M, c n * e ((n : вДЭ) * ќ±) with hT
  have hTcont : Continuous T := by
    rw [hT]
    apply continuous_finset_sum
    intro n _
    exact continuous_const.mul (continuous_e'.comp (by fun_prop))
  -- integrability workhorses (f integrable √Ч bounded measurable factor)
  have hInt_fe : вИА n : вДХ, IntegrableOn (fun ќ± => f ќ± * e (-((n : вДЭ) * ќ±)))
      (Set.Ioc (0:вДЭ) 1) := by
    intro n
    have hm1 : AEStronglyMeasurable (fun ќ± => f ќ± * e (-((n : вДЭ) * ќ±)))
        (volume.restrict (Set.Ioc (0:вДЭ) 1)) :=
      hmeas.mul (hecont n).aestronglyMeasurable
    apply Integrable.mono' hfint.norm hm1
    apply Filter.Eventually.of_forall
    intro ќ±
    rw [norm_mul, e_norm, mul_one]
  have hTbound : вИА ќ± : вДЭ, вАЦT ќ±вАЦ вЙ§ вИС n вИИ Finset.range M, вАЦc nвАЦ := by
    intro ќ±
    rw [hT]
    refine le_trans (norm_sum_le _ _) (le_of_eq ?_)
    apply Finset.sum_congr rfl
    intro n _
    rw [norm_mul, e_norm, mul_one]
  have hInt_fT : IntegrableOn (fun ќ± => f ќ± * (starRingEnd вДВ) (T ќ±))
      (Set.Ioc (0:вДЭ) 1) := by
    have hm2 : AEStronglyMeasurable (fun ќ± => f ќ± * (starRingEnd вДВ) (T ќ±))
        (volume.restrict (Set.Ioc (0:вДЭ) 1)) :=
      hmeas.mul (Complex.continuous_conj.comp hTcont).aestronglyMeasurable
    apply Integrable.mono' (hfint.norm.mul_const (вИС n вИИ Finset.range M, вАЦc nвАЦ)) hm2
    apply Filter.Eventually.of_forall
    intro ќ±
    rw [norm_mul]
    apply mul_le_mul_of_nonneg_left _ (norm_nonneg _)
    rw [RCLike.norm_conj]
    exact hTbound ќ±
  -- Key 1: вИЂ f¬Јconj T = вИС c n ¬Ј conj (c n)
  have hkey1 : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±))
      = вИС n вИИ Finset.range M, c n * (starRingEnd вДВ) (c n) := by
    have hexp : вИА ќ± : вДЭ, f ќ± * (starRingEnd вДВ) (T ќ±)
        = вИС n вИИ Finset.range M, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
      intro ќ±
      rw [hT]
      dsimp only
      rw [map_sum, Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro n _
      rw [map_mul, e_conj]
      ring
    calc (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±))
        = вИЂ ќ± in Set.Ioc (0:вДЭ) 1,
            вИС n вИИ Finset.range M, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
          apply setIntegral_congr_fun measurableSet_Ioc
          intro ќ± _
          exact hexp ќ±
      _ = вИС n вИИ Finset.range M,
            вИЂ ќ± in Set.Ioc (0:вДЭ) 1, (starRingEnd вДВ) (c n) * (f ќ± * e (-((n : вДЭ) * ќ±))) := by
          apply integral_finset_sum
          intro n _
          exact (hInt_fe n).const_mul _
      _ = вИС n вИИ Finset.range M,
            (starRingEnd вДВ) (c n) * вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±)) := by
          apply Finset.sum_congr rfl
          intro n _
          exact integral_const_mul _ _
      _ = вИС n вИИ Finset.range M, c n * (starRingEnd вДВ) (c n) := by
          apply Finset.sum_congr rfl
          intro n _
          have hfold : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±))) = c n := rfl
          rw [hfold]
          ring
  -- Key 2: the expansion of вИЂ вАЦf вИТ TвАЦ¬≤
  have hptwise : вИА ќ± : вДЭ, вАЦf ќ± - T ќ±вАЦ ^ 2
      = вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re + вАЦT ќ±вАЦ ^ 2 := by
    intro ќ±
    have h1 : (вАЦf ќ± - T ќ±вАЦ : вДЭ) ^ 2 = ((f ќ± - T ќ±) * (starRingEnd вДВ) (f ќ± - T ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have h2 : (вАЦf ќ±вАЦ : вДЭ) ^ 2 = (f ќ± * (starRingEnd вДВ) (f ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have h3 : (вАЦT ќ±вАЦ : вДЭ) ^ 2 = (T ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
    have hconjswap : (T ќ± * (starRingEnd вДВ) (f ќ±)).re = (f ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      have : T ќ± * (starRingEnd вДВ) (f ќ±) = (starRingEnd вДВ) (f ќ± * (starRingEnd вДВ) (T ќ±)) := by
        rw [map_mul, Complex.conj_conj]
        ring
      rw [this, Complex.conj_re]
    rw [h1, h2, h3]
    have hexpand : (f ќ± - T ќ±) * (starRingEnd вДВ) (f ќ± - T ќ±)
        = f ќ± * (starRingEnd вДВ) (f ќ±) - f ќ± * (starRingEnd вДВ) (T ќ±)
          - T ќ± * (starRingEnd вДВ) (f ќ±) + T ќ± * (starRingEnd вДВ) (T ќ±) := by
      rw [map_sub]
      ring
    rw [hexpand]
    simp only [Complex.add_re, Complex.sub_re]
    rw [hconjswap]
    ring
  have hIfT : IntegrableOn (fun ќ± => (f ќ± * (starRingEnd вДВ) (T ќ±)).re)
      (Set.Ioc (0:вДЭ) 1) volume := hInt_fT.re
  have hIT2 : IntegrableOn (fun ќ± => вАЦT ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1) volume :=
    (hTcont.norm.pow 2).integrableOn_Ioc
  have hkey2 : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ± - T ќ±вАЦ ^ 2)
      = (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2)
        - 2 * (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±)).re
        + вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦT ќ±вАЦ ^ 2 := by
    have hre : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, (f ќ± * (starRingEnd вДВ) (T ќ±)).re)
        = (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±)).re := by
      have h := integral_re hInt_fT
      simpa [RCLike.re_to_complex] using h
    calc (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ± - T ќ±вАЦ ^ 2)
        = вИЂ ќ± in Set.Ioc (0:вДЭ) 1,
            (вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re + вАЦT ќ±вАЦ ^ 2) := by
          apply setIntegral_congr_fun measurableSet_Ioc
          intro ќ± _
          exact hptwise ќ±
      _ = (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, (вАЦf ќ±вАЦ ^ 2 - 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re))
          + вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦT ќ±вАЦ ^ 2 := by
          apply integral_add _ hIT2
          exact hf.sub (hIfT.const_mul 2)
      _ = (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2)
          - (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, 2 * (f ќ± * (starRingEnd вДВ) (T ќ±)).re)
          + вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦT ќ±вАЦ ^ 2 := by
          rw [integral_sub hf (hIfT.const_mul 2)]
      _ = (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2)
          - 2 * (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±)).re
          + вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦT ќ±вАЦ ^ 2 := by
          rw [integral_const_mul, hre]
  -- Key 3: вИЂ_{(0,1]} вАЦTвАЦ¬≤ = вИС вАЦc nвАЦ¬≤ (Parseval вАФ the sub-arc is the whole period)
  have hkey3 : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦT ќ±вАЦ ^ 2) = вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
    rw [hT]
    rw [вЖР intervalIntegral.integral_of_le zero_le_one]
    exact parseval c M
  -- the cross term is the coefficient mass
  have hcross : (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * (starRingEnd вДВ) (T ќ±)).re
      = вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 := by
    rw [hkey1, Complex.re_sum]
    apply Finset.sum_congr rfl
    intro n _
    rw [Complex.mul_conj, Complex.ofReal_re, Complex.normSq_eq_norm_sq]
  have hnonneg : (0:вДЭ) вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ± - T ќ±вАЦ ^ 2 := by
    apply integral_nonneg
    intro ќ±
    positivity
  rw [hkey2, hcross, hkey3] at hnonneg
  have hfinal : вИС n вИИ Finset.range M, вАЦc nвАЦ ^ 2 вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2 := by
    linarith
  exact hfinal

end B4

-- ==== harc-chain shims (v3) ====

/-- `bessel_Ioc` discharge: the integrable-`f` Bessel proven in HarcArcTailBound. -/
theorem bessel_Ioc (f : вДЭ вЖТ вДВ)
    (hf : MeasureTheory.IntegrableOn (fun ќ± => вАЦf ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1)) (M : вДХ) :
    вИС n вИИ Finset.range M, вАЦвИЂ ќ± in Set.Ioc (0:вДЭ) 1, f ќ± * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
      вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦf ќ±вАЦ ^ 2 := bessel_Ioc_proven f hf M

/-- `arcs_disjoint` discharge from the pairwise `farey_disjoint`. -/
theorem arcs_disjoint (P Q : вДХ) (hPQ : 2 * P ^ 2 < Q + 1) :
    ((anchors P : Finset (вДХ √Ч вД§)) : Set (вДХ √Ч вД§)).Pairwise (Function.onFun Disjoint (arc Q)) := by
  intro pq hpq pq' hpq' hne
  have hmem := Finset.mem_filter.mp (Finset.mem_coe.mp hpq)
  have hmem' := Finset.mem_filter.mp (Finset.mem_coe.mp hpq')
  have hq := (Finset.mem_Icc.mp (Finset.mem_product.mp hmem.1).1)
  have hq' := (Finset.mem_Icc.mp (Finset.mem_product.mp hmem'.1).1)
  have hball := farey_disjoint P Q hPQ pq.2 pq'.2 pq.1 pq'.1
    (by omega) (by omega) hq.2 hq'.2 hmem.2 hmem'.2
    (by
      intro вЯ®ha, hqeqвЯ©
      exact hne (Prod.ext hqeq ha))
  exact Disjoint.mono Set.inter_subset_left Set.inter_subset_left hball

/-!
# harc ARC-TAIL half (major-arc model evaluation вЖТ singular-series √Ч kernel)

The second (deepest) half of `harc`, split out to check fast. The arc-tail sub-error is
`l2_error_triangle`'s input `h1 = f вИТ g` with `f = Re coeffModel`, `g = рЭФЦ_P¬Јr_N`:
`вИС_{nвИИ(X/2,X]}(Re coeffModel вИТ рЭФЦ_P¬Јr_N)¬≤ вЙ§ ќµX¬≥`. It evaluates the anchor-window model integral.

Route: per anchor, factor `вИС_r e(ra/q)ќї = ќЉ(q)/ѕЖ(q)` out (`anchor_integrand_eq`), leaving the pure
Dirichlet-kernel arc integral `вИЂ_arc D_N(ќ±вИТa/q)¬≤e(-nќ±)`; change variables `ќ≤ = ќ±вИТa/q`, giving
`e(-na/q)¬Ј(вИЂ_full D_N¬≤e(-nќ≤) вИТ arc-tail)` = `e(-na/q)¬Ј(r_N(n) вИТ ѕБ_q(n))` [`dirichlet_full`]; sum over
`a` gives the Ramanujan sum `вИС_a e(-na/q) = c_q(n)`, so `coeffModel = рЭФЦ_P¬Јr_N вИТ вИС_q(ќЉ/ѕЖ)¬≤вИС_a e(-na/q)ѕБ_q`;
the error `вИС_n(вЛѓѕБ_q)¬≤ вЙ§ ќµX¬≥` via `вИЂ|D_N|вБі` Bessel + Farey almost-orthogonality.

`e`, `lambdaModel`, `anchors`, `coeffModel` are the identical top-level definitions from
`RatedWindow.lean`; `lambdaModel_coeff` / `dirichlet_full` enter as labeled cross-file inputs
(PROVEN in `MinorArcExpSum.lean` / `MajorArcMainTerm.lean`), discharged at Phase-F concatenation.
-/

open MeasureTheory





section Inputs


end Inputs

/-- **Anchor integrand simplification** (arc-tail entry): the singular-series coefficient
    `вИС_r e(ra/q)ќї = ќЉ(q)/ѕЖ(q)` factors out of the anchor integral. -/
lemma anchor_integrand_eq (N n q : вДХ) (a : вД§) (s : Set вДЭ) (hq : 0 < q) (ha : Int.gcd a q = 1) :
    (вИЂ ќ± in s, ((вИС r вИИ Finset.range q, e ((r : вДЭ) * (a : вДЭ) / (q : вДЭ)) * lambdaModel q r)
        * вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      = ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
        * вИЂ ќ± in s, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±)) := by
  rw [lambdaModel_coeff a q hq ha, вЖР integral_const_mul]
  congr 1
  funext ќ±
  ring

/-- **coeffModel factored form**: `coeffModel N P Q n = вИС_{pqвИИanchors} (ќЉ(q)/ѕЖ(q))¬≤¬ЈвИЂ_arc D_N(ќ±вИТa/q)¬≤¬Ј
    e(-nќ±)`. Pulls the ќЉ/ѕЖ singular-series coefficient out of every anchor integral (via
    `anchor_integrand_eq`, `gcd(a,q)=1` and `q вЙ• 1` from `anchors` membership). The starting point for
    the arc-integral evaluation `вИЂ_arc D_N¬≤ e = e(-na/q)(r_N вИТ ѕБ_q)`. -/
lemma coeffModel_eq (N P Q n : вДХ) :
    coeffModel N P Q n = вИС pq вИИ anchors P,
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
            вИ© Set.Ioc (0:вДЭ) 1,
          (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±)) := by
  rw [coeffModel]
  apply Finset.sum_congr rfl
  intro pq hpq
  rw [anchors, Finset.mem_filter, Finset.mem_product, Finset.mem_Icc] at hpq
  have hq : 0 < pq.1 := by omega
  have ha : Int.gcd pq.2 pq.1 = 1 := hpq.2
  exact anchor_integrand_eq N n pq.1 pq.2 _ hq ha


/-- **Arc-integral change of variables** `ќ≤ = ќ± вИТ c` (`c = a/q`): translation-invariance of the arc
    integral, `вИЂ_s D_N(ќ±вИТc)¬≤e(-nќ±) = e(-nc)¬ЈвИЂ_{sвИТc} D_N(ќ≤)¬≤e(-nќ≤)`. Shifts each anchor arc to be
    centred at 0, exposing the full-period Dirichlet kernel (`dirichlet_full`). Via `integral_indicator`
    + `integral_add_right_eq_self` (Lebesgue translation-invariance) + `e_add` pulling `e(-nc)` out. -/
lemma arc_change_of_var (N n : вДХ) (c : вДЭ) (s : Set вДЭ) (hs : MeasurableSet s) :
    (вИЂ ќ± in s, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      = e (-((n : вДЭ) * c))
        * вИЂ ќ≤ in {ќ≤ : вДЭ | ќ≤ + c вИИ s}, (вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)) ^ 2 * e (-((n : вДЭ) * ќ≤)) := by
  set g := fun ќ± : вДЭ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)) with hg
  have hs' : MeasurableSet {ќ≤ : вДЭ | ќ≤ + c вИИ s} := hs.preimage (by fun_prop)
  rw [вЖР integral_indicator hs, вЖР integral_add_right_eq_self (fun ќ± => Set.indicator s g ќ±) c]
  have hpt : (fun ќ≤ => Set.indicator s g (ќ≤ + c))
      = fun ќ≤ => Set.indicator {ќ≤ : вДЭ | ќ≤ + c вИИ s} (fun ќ≤ => g (ќ≤ + c)) ќ≤ := by
    funext ќ≤
    classical
    rw [Set.indicator_apply, Set.indicator_apply]
    exact if_congr Iff.rfl rfl rfl
  rw [hpt, integral_indicator hs', вЖР integral_const_mul]
  apply setIntegral_congr_fun hs'
  intro ќ≤ _
  simp only [hg]
  rw [show (ќ≤ + c - c) = ќ≤ by ring,
    show -((n : вДЭ) * (ќ≤ + c)) = -((n : вДЭ) * ќ≤) + -((n : вДЭ) * c) by ring, вЖР e_add]
  ring


/-- `e(k(ќ≤+1)) = e(kќ≤)` for `k : вДХ` вАФ the additive character is 1-periodic. -/
lemma e_shift_one (k : вДХ) (ќ≤ : вДЭ) : e ((k : вДЭ) * (ќ≤ + 1)) = e ((k : вДЭ) * ќ≤) := by
  rw [show (k : вДЭ) * (ќ≤ + 1) = (k : вДЭ) * ќ≤ + (k : вДЭ) by ring, вЖР e_add, e_natCast_eq_one, mul_one]

/-- `e(-(n:вДЭ)) = 1` for `n : вДХ`. -/
lemma e_neg_natCast_eq_one (n : вДХ) : e (-(n : вДЭ)) = 1 := by
  have h2 := e_add (-(n : вДЭ)) (n : вДЭ)
  rw [e_natCast_eq_one, mul_one, show (-(n : вДЭ)) + (n : вДЭ) = 0 by ring,
    show e (0 : вДЭ) = 1 by simp [e]] at h2
  exact h2

/-- **Integrand 1-periodicity**: `D_N(ќ≤+1)¬≤¬Јe(-n(ќ≤+1)) = D_N(ќ≤)¬≤¬Јe(-nќ≤)`. The arc integral near `0`
    (after `arc_change_of_var`) relates to the full-period `вИЂвВА¬є` (`dirichlet_full`); the arc-tail is
    the complement within one period. -/
lemma arc_integrand_periodic (N n : вДХ) (ќ≤ : вДЭ) :
    (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ + 1))) ^ 2 * e (-((n : вДЭ) * (ќ≤ + 1)))
      = (вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)) ^ 2 * e (-((n : вДЭ) * ќ≤)) := by
  have hD : (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ≤ + 1)))
      = вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤) :=
    Finset.sum_congr rfl (fun k _ => e_shift_one k ќ≤)
  have he : e (-((n : вДЭ) * (ќ≤ + 1))) = e (-((n : вДЭ) * ќ≤)) := by
    rw [show -((n : вДЭ) * (ќ≤ + 1)) = -((n : вДЭ) * ќ≤) + -(n : вДЭ) by ring, вЖР e_add,
      e_neg_natCast_eq_one, mul_one]
  rw [hD, he]

/-- **Arc = full вИТ tail**: for a measurable arc `A вКЖ B` (`B = Ioc(0,1)`, the full period) and an
    integrable integrand, `вИЂ_A F = вИЂ_B F вИТ вИЂ_{BвИЦA} F`. The arc integral is the full-period value
    (`dirichlet_full`, `= e(-nc)¬Јr_N`) minus the arc-tail `ѕБ_q = вИЂ_{BвИЦA} F` (whose L¬≤ is bounded by the
    Dirichlet `вИЂ|D_N|вБі` on the complement). Via `setIntegral_union` on `B = A вИ™ (BвИЦA)`. -/
lemma arc_split (F : вДЭ вЖТ вДВ) (A B : Set вДЭ) (hA : MeasurableSet A) (hB : MeasurableSet B)
    (hAB : A вКЖ B) (hint : IntegrableOn F B) :
    (вИЂ ќ± in A, F ќ±) = (вИЂ ќ± in B, F ќ±) - вИЂ ќ± in B \ A, F ќ± := by
  have hunion : B = A вИ™ (B \ A) := (Set.union_diff_cancel hAB).symm
  have hkey : (вИЂ ќ± in B, F ќ±) = (вИЂ ќ± in A, F ќ±) + вИЂ ќ± in B \ A, F ќ± := by
    conv_lhs => rw [hunion]
    exact setIntegral_union Set.disjoint_sdiff_right (hB.diff hA)
      (hint.mono_set hAB) (hint.mono_set Set.diff_subset)
  rw [hkey]; ring


/-- **Full-period arc value**: `вИЂ_{Ioc(0,1)} D_N(ќ±вИТc)¬≤e(-nќ±) = e(-nc)¬Јr_N(n)`. Change of variables
    (`arc_change_of_var`) + periodicity (`вИЂ` over any length-1 interval `= вИЂвВА¬є`, via
    `Function.Periodic.intervalIntegral_add_eq`) + `dirichlet_full`. Combined with `arc_split`, the
    anchor integral is `e(-nc)¬Јr_N вИТ ѕБ_q(n)`. -/
lemma full_arc_eq (N n : вДХ) (c : вДЭ) :
    (вИЂ ќ± in Set.Ioc (0:вДЭ) 1, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      = e (-((n : вДЭ) * c))
        * (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) := by
  rw [arc_change_of_var N n c (Set.Ioc 0 1) measurableSet_Ioc]
  congr 1
  have hs'eq : {ќ≤ : вДЭ | ќ≤ + c вИИ Set.Ioc (0:вДЭ) 1} = Set.Ioc (-c) (1 - c) := by
    ext ќ≤; simp only [Set.mem_setOf_eq, Set.mem_Ioc]; constructor <;> intro h <;>
      exact вЯ®by linarith [h.1], by linarith [h.2]вЯ©
  rw [hs'eq, вЖР intervalIntegral.integral_of_le (by linarith : (-c) вЙ§ 1 - c)]
  have hper : Function.Periodic
      (fun ќ≤ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * ќ≤)) ^ 2 * e (-((n : вДЭ) * ќ≤))) 1 :=
    fun ќ≤ => arc_integrand_periodic N n ќ≤
  rw [show (1:вДЭ) - c = -c + 1 by ring, hper.intervalIntegral_add_eq (-c) 0, zero_add]
  have := dirichlet_full N n
  simp only [neg_mul] at this вКҐ
  exact this

/-- **Per-anchor arc value**: `вИЂ_A D_N(ќ±вИТc)¬≤e(-nќ±) = e(-nc)¬Јr_N(n) вИТ ѕБ_q(n)` for an arc `A вКЖ Ioc(0,1)`,
    where `ѕБ_q(n) = вИЂ_{Ioc(0,1)вИЦA} D_N(ќ±вИТc)¬≤e(-nќ±)` is the arc-tail. Combines `arc_split` + `full_arc_eq`
    (integrand continuous вЗТ integrable on the bounded `Ioc`). The clean form fed to `coeffModel_eq`:
    `coeffModel = вИС_pq(ќЉ/ѕЖ)¬≤(e(-na/q)¬Јr_N вИТ ѕБ_q) = рЭФЦ_P¬Јr_N вИТ E` after the Ramanujan-sum step. -/
lemma anchor_arc_eq (N n : вДХ) (c : вДЭ) (A : Set вДЭ) (hA : MeasurableSet A)
    (hAsub : A вКЖ Set.Ioc (0:вДЭ) 1) :
    (вИЂ ќ± in A, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      = e (-((n : вДЭ) * c))
          * (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ)
        - вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ A,
            (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)) := by
  have hint : IntegrableOn
      (fun ќ± => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      (Set.Ioc (0:вДЭ) 1) := by
    apply Continuous.integrableOn_Ioc
    simp only [e]; fun_prop
  rw [arc_split _ A (Set.Ioc 0 1) hA measurableSet_Ioc hAsub hint, full_arc_eq]


/-- **Arc-tail Bessel**: `вИС_{n<M} вАЦѕБ_q(n)вАЦ¬≤ вЙ§ вИЂ_{Ioc(0,1)вИЦA} |D_N(ќ±вИТc)|вБі`, where
    `ѕБ_q(n) = вИЂ_{Ioc(0,1)вИЦA} D_N(ќ±вИТc)¬≤e(-nќ±)` (the arc-tail, `anchor_arc_eq`). Direct `bessel_minor`
    with `f = D_N(¬ЈвИТc)¬≤`. The Dirichlet-LвБі tail `вИЂ_{|ќ≤|>ќі_q}|D_N|вБі вЙ≤ (q(Q+1))¬≥` then bounds it; summing
    over the DISJOINT Farey arcs (`farey_disjoint`) gives the harc arc-tail L¬≤ error `вИС(Re E)¬≤ вЙ§ ќµX¬≥`. -/
lemma rho_bessel (N : вДХ) (c : вДЭ) (A : Set вДЭ) (hA : MeasurableSet A) (M : вДХ) :
    вИС n вИИ Finset.range M,
        вАЦвИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ A,
            (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±))вАЦ ^ 2
      вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ A,
          вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2вАЦ ^ 2 := by
  apply bessel_minor (fun ќ± => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2) ?_
    (Set.Ioc (0:вДЭ) 1 \ A) (measurableSet_Ioc.diff hA) Set.diff_subset M
  simp only [e]
  fun_prop



/-- **Disjoint arcs вЖТ single integral**: `вИС_{iвИИs} вИЂ_{A i} g i = вИЂ_{вЛГ_{iвИИs} A i} вИС_{iвИИs} 1_{A i}¬Ј(g i)`
    for pairwise-disjoint measurable `A i`. Expresses the anchor-sum `coeffModel` (via `coeffModel_eq`)
    as ONE integral over the disjoint (`farey_disjoint`) major-arc union вАФ the single-Bessel
    reformulation: the L¬≤ error `вИС_n|coeffModel вИТ рЭФЦ_P¬Јr_N|¬≤` becomes ONE `bessel_minor` on `вЛГarcs`,
    with the LвБі tail integrated once (dodging the divergent per-arc/overlapping-complement route). -/
lemma sum_setIntegral_disjoint {ќє : Type*} (s : Finset ќє) (A : ќє вЖТ Set вДЭ) (g : ќє вЖТ вДЭ вЖТ вДВ)
    (hmeas : вИА i вИИ s, MeasurableSet (A i))
    (hdisj : (s : Set ќє).Pairwise (Function.onFun Disjoint A))
    (hint : вИА i вИИ s, IntegrableOn (g i) (A i)) :
    вИС i вИИ s, вИЂ ќ± in A i, g i ќ±
      = вИЂ ќ± in вЛГ i вИИ s, A i, вИС i вИИ s, (A i).indicator (g i) ќ± := by
  have hpt : вИА i вИИ s, вИА ќ± вИИ A i, (вИС j вИИ s, (A j).indicator (g j) ќ±) = g i ќ± := by
    intro i hi ќ± hќ±
    rw [Finset.sum_eq_single i]
    ¬Ј rw [Set.indicator_of_mem hќ±]
    ¬Ј intro j hj hji
      rw [Set.indicator_of_notMem]
      intro hќ±j
      exact Set.disjoint_left.mp (hdisj hj hi hji) hќ±j hќ±
    ¬Ј intro hi'; exact absurd hi hi'
  rw [integral_biUnion_finset s hmeas hdisj ?_]
  ¬Ј apply Finset.sum_congr rfl
    intro i hi
    exact (setIntegral_congr_fun (hmeas i hi) (fun ќ± hќ± => hpt i hi ќ± hќ±)).symm
  ¬Ј intro i hi
    exact (hint i hi).congr_fun (fun ќ± hќ± => (hpt i hi ќ± hќ±).symm) (hmeas i hi)



/-- **coeffModel as a single integral** over the disjoint major-arc union `вЛГarc` (the single-Bessel
    reformulation): `coeffModel N P Q n = вИЂ_{вЛГarc} вИС_pq 1_{arc}¬Ј(ќЉ/ѕЖ)¬≤D_N(ќ±вИТa/q)¬≤¬Јe(-nќ±)`. From
    `coeffModel_eq` (move `(ќЉ/ѕЖ)¬≤` inside via `integral_const_mul`) + `sum_setIntegral_disjoint`
    (`arcs_disjoint`). The L¬≤ error is now ONE `bessel_minor` on `вЛГarc`. -/
lemma coeffModel_as_integral (N P Q n : вДХ) (hPQ : 2 * P ^ 2 < Q + 1) :
    coeffModel N P Q n
      = вИЂ ќ± in вЛГ pq вИИ anchors P, arc Q pq,
        вИС pq вИИ anchors P, (arc Q pq).indicator
          (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±))) ќ± := by
  rw [coeffModel_eq]
  have hmove : вИА pq вИИ anchors P,
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
            вИ© Set.Ioc (0:вДЭ) 1,
          (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±))
      = вИЂ ќ± in Metric.closedBall ((pq.2 : вДЭ) / (pq.1 : вДХ)) (1 / (pq.1 * (Q + 1)))
            вИ© Set.Ioc (0:вДЭ) 1,
          ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±)) := by
    intro pq _
    rw [вЖР integral_const_mul]
    apply setIntegral_congr_fun ?_ (fun ќ± _ => by ring)
    exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  rw [Finset.sum_congr rfl hmove]
  refine sum_setIntegral_disjoint (anchors P) (arc Q) _ ?_ (arcs_disjoint P Q hPQ) ?_
  ¬Ј intro pq _; exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  ¬Ј intro pq _
    have hcont : Continuous (fun ќ± : вДЭ =>
        ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
          * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
          * e (-((n : вДЭ) * ќ±))) := by
      simp only [e]; fun_prop
    exact (hcont.integrableOn_Ioc (a := (0:вДЭ)) (b := 1)).mono_set Set.inter_subset_right

/-- The arc-tail integral `ѕБ_q(n) = вИЂ_{Ioc(0,1)вИЦarc} D_N(ќ±вИТa/q)¬≤¬Јe(-nќ±)` at anchor `pq=(q,a)`. -/
noncomputable def rhoTail (N Q n : вДХ) (pq : вДХ √Ч вД§) : вДВ :=
  вИЂ ќ± in Set.Ioc (0:вДЭ) 1 \ arc Q pq,
    (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±))

/-- `coeffModel_eq` restated with the arc integrals folded into `arc Q pq` (defeq, via `rfl`). -/
lemma coeffModel_eq_arc (N P Q n : вДХ) :
    coeffModel N P Q n = вИС pq вИИ anchors P,
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * вИЂ ќ± in arc Q pq,
          (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±)) := by
  rw [coeffModel_eq]; rfl

/-- **coeffModel = main вИТ error** (the arc-tail split): `coeffModel(n) = r_N¬ЈA(n) вИТ E(n)`, where
    `r_N = #{(k,k'): k+k'=n}` (kernel count), `A(n) = вИС_pq (ќЉ/ѕЖ)¬≤¬Јe(-na/q)` (Ramanujan main term,
    reconciled to `рЭФЦ_P¬Ј` by `ramanujan_main`), and `E(n) = вИС_pq (ќЉ/ѕЖ)¬≤¬ЈѕБ_q(n)` (the arc-tail error,
    bounded by the per-q `rho_bessel` + вДУ¬≤ Minkowski route). From `вИС_pq (ќЉ/ѕЖ)¬≤¬Јanchor_arc_eq`. -/
lemma coeffModel_main_minus_error (N P Q n : вДХ) :
    coeffModel N P Q n
      = (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ)
          * (вИС pq вИИ anchors P,
              ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
                * e (-((n : вДЭ) * ((pq.2 : вДЭ) / (pq.1 : вДЭ)))))
        - вИС pq вИИ anchors P,
            ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2 * rhoTail N Q n pq := by
  rw [coeffModel_eq_arc, Finset.mul_sum, вЖР Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro pq _
  rw [anchor_arc_eq N n ((pq.2 : вДЭ) / (pq.1 : вДЭ)) (arc Q pq)
      ((Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc) Set.inter_subset_right]
  unfold rhoTail
  ring

open scoped Classical in
/-- Anchors whose Farey arc actually meets `(0,1]` (`a/q вИИ [0,1]`); the `[-P,2P]` anchors with
    `a/q вИЙ [0,1]` have empty arcs and contribute `0` to `coeffModel`. -/
noncomputable def neAnchors (P Q : вДХ) : Finset (вДХ √Ч вД§) :=
  (anchors P).filter (fun pq => (arc Q pq).Nonempty)

open scoped Classical in
/-- **Nonempty-arc split** of the arc-tail: `coeffModel(n) = r_N¬Ј(вИС_{ne}(ќЉ/ѕЖ)¬≤e(-na/q)) вИТ
    вИС_{ne}(ќЉ/ѕЖ)¬≤ѕБ_q(n)`, summing only over anchors whose arc meets `(0,1]` (empty arcs give `вИЂ_вИЕ=0`,
    dropped via `sum_subset`). The main sum `вИС_{ne}(ќЉ/ѕЖ)¬≤e(-na/q)` over each fixed `q` runs over a
    reduced residue system mod `q` (`a вИИ [1,qвИТ1]`, `(a,q)=1`) вЖТ `c_q(n)`, so it reconciles to
    `singSeries_C P n` (Ramanujan, `main_sum_eq_singSeries`); then `h1 = вИТRe E`. -/
lemma coeffModel_ne_split (N P Q n : вДХ) :
    coeffModel N P Q n
      = (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ)
          * (вИС pq вИИ neAnchors P Q,
              ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
                * e (-((n : вДЭ) * ((pq.2 : вДЭ) / (pq.1 : вДЭ)))))
        - вИС pq вИИ neAnchors P Q,
            ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2 * rhoTail N Q n pq := by
  have hzero : вИА pq вИИ anchors P, pq вИЙ neAnchors P Q вЖТ
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * вИЂ ќ± in arc Q pq,
          (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±))
        = 0 := by
    intro pq hpq hnf
    rw [neAnchors, Finset.mem_filter, not_and] at hnf
    have hempty : arc Q pq = вИЕ := Set.not_nonempty_iff_eq_empty.mp (hnf hpq)
    rw [hempty, Measure.restrict_empty, integral_zero_measure, mul_zero]
  rw [coeffModel_eq_arc, вЖР Finset.sum_subset (Finset.filter_subset _ _) hzero,
    Finset.mul_sum, вЖР Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro pq _
  rw [anchor_arc_eq N n ((pq.2 : вДЭ) / (pq.1 : вДЭ)) (arc Q pq)
      ((Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc) Set.inter_subset_right]
  unfold rhoTail
  ring





/-- **Ideal main term as a single integral**: `r_N¬ЈрЭФЦ_P(n) = вИЂ_{(0,1]} ќ®_ideal¬Јe(-nќ±)`. Via
    `full_arc_eq` per canonical Farey fraction (`вИЂ_{(0,1]}D_N(ќ±вИТa/q)¬≤e = e(-na/q)¬Јr_N`) + nested
    integral linearity (`integral_finset_sum` √Ч 2, `integral_const_mul`). The `вИЂ_{(0,1]}`-form ideal
    main term вАФ pairs with `coeffModel_as_integral` so the arc-tail error `coeffModel вИТ r_NрЭФЦ_P` is a
    SINGLE Fourier coefficient of `1_{вЛГarc}ќ¶ вИТ ќ®_ideal`, bounded by ONE `bessel_minor`. -/
lemma mainInt_eq (N P n : вДХ) :
    (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) * singSeriesC P n
      = вИЂ ќ± in Set.Ioc (0:вДЭ) 1, PsiIdeal N P ќ± * e (-((n : вДЭ) * ќ±)) := by
  have hcont : вИА (c : вДЭ), Continuous
      (fun ќ± : вДЭ => (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - c))) ^ 2 * e (-((n : вДЭ) * ќ±))) := by
    intro c; simp only [e]; fun_prop
  have hinner : вИА q : вДХ,
      (вИЂ ќ± in Set.Ioc (0:вДЭ) 1,
        (вИС a вИИ redRes q, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
          * e (-((n : вДЭ) * ќ±)))
      = (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) * cRamC q n := by
    intro q
    simp only [Finset.sum_mul]
    rw [integral_finset_sum (redRes q)
      (f := fun (a : вДХ) (ќ± : вДЭ) =>
        (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±)))
      (fun a _ => (hcont ((a : вДЭ) / (q : вДЭ))).integrableOn_Ioc)]
    rw [cRamC, Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro a _
    rw [full_arc_eq N n ((a : вДЭ) / (q : вДЭ)), mul_comm]
  rw [singSeriesC, Finset.mul_sum]
  simp only [PsiIdeal, Finset.sum_mul]
  rw [integral_finset_sum (Finset.Icc 1 P)
    (f := fun (q : вДХ) (ќ± : вДЭ) =>
      ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2
        * (вИС a вИИ redRes q, (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2)
        * e (-((n : вДЭ) * ќ±)))
    (fun q _ => by apply Continuous.integrableOn_Ioc; simp only [e]; fun_prop)]
  apply Finset.sum_congr rfl
  intro q _
  simp only [mul_assoc]
  rw [integral_const_mul, hinner q]
  ring


/-- **coeffModel as a single `(0,1]`-integral of an `n`-independent kernel**:
    `coeffModel(n) = вИЂ_{(0,1]} ќ¶(ќ±)¬Јe(-nќ±)`. Each anchor arc integral extends to `(0,1]` via its
    indicator (`integral_indicator`, `arc вКЖ (0,1]`), then linearity (`integral_finset_sum`) pulls the
    finite sum out and factors `e` (`Finset.sum_mul`). With `mainInt_eq`, the arc-tail error
    `coeffModel вИТ r_NрЭФЦ_P = вИЂ_{(0,1]}(ќ¶ вИТ ќ®_ideal)¬Јe(-nќ±)` is a single Fourier coefficient of the
    `n`-independent `ќ¶ вИТ ќ®_ideal` вЖТ one Bessel inequality. -/
lemma coeffModel_eq_intPhi (N P Q n : вДХ) :
    coeffModel N P Q n = вИЂ ќ± in Set.Ioc (0:вДЭ) 1, PhiArc N P Q ќ± * e (-((n : вДЭ) * ќ±)) := by
  rw [coeffModel_eq_arc]
  have hmeas : вИА pq : вДХ √Ч вД§, MeasurableSet (arc Q pq) :=
    fun pq => (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  have hsub : вИА pq : вДХ √Ч вД§, arc Q pq вКЖ Set.Ioc (0:вДЭ) 1 := fun pq => Set.inter_subset_right
  have hterm : вИА pq : вДХ √Ч вД§,
      ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * вИЂ ќ± in arc Q pq,
          (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2 * e (-((n : вДЭ) * ќ±))
      = вИЂ ќ± in Set.Ioc (0:вДЭ) 1,
          (arc Q pq).indicator (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±
            * e (-((n : вДЭ) * ќ±)) := by
    intro pq
    rw [вЖР integral_const_mul, вЖР MeasureTheory.integral_indicator (hmeas pq),
        вЖР MeasureTheory.integral_indicator measurableSet_Ioc]
    apply integral_congr_ae
    apply Filter.Eventually.of_forall
    intro ќ±
    by_cases hќ± : ќ± вИИ arc Q pq
    ¬Ј rw [Set.indicator_of_mem hќ±, Set.indicator_of_mem (hsub pq hќ±),
        Set.indicator_of_mem hќ±]; ring
    ¬Ј by_cases hќ±I : ќ± вИИ Set.Ioc (0:вДЭ) 1
      ¬Ј rw [Set.indicator_of_notMem hќ±, Set.indicator_of_mem hќ±I,
          Set.indicator_of_notMem hќ±, zero_mul]
      ¬Ј rw [Set.indicator_of_notMem hќ±, Set.indicator_of_notMem hќ±I]
  have hintegr : вИА pq вИИ anchors P, IntegrableOn (fun ќ± =>
      (arc Q pq).indicator (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±
        * e (-((n : вДЭ) * ќ±))) (Set.Ioc (0:вДЭ) 1) := by
    intro pq _
    have hrw : (fun ќ± => (arc Q pq).indicator
        (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
          * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±
          * e (-((n : вДЭ) * ќ±)))
        = (arc Q pq).indicator (fun ќ± =>
            ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
              * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
              * e (-((n : вДЭ) * ќ±))) := by
      funext ќ±
      by_cases hќ± : ќ± вИИ arc Q pq
      ¬Ј rw [Set.indicator_of_mem hќ±, Set.indicator_of_mem hќ±]
      ¬Ј rw [Set.indicator_of_notMem hќ±, Set.indicator_of_notMem hќ±, zero_mul]
    rw [hrw]
    apply MeasureTheory.IntegrableOn.indicator ?_ (hmeas pq)
    apply Continuous.integrableOn_Ioc; simp only [e]; fun_prop
  rw [Finset.sum_congr rfl (fun pq _ => hterm pq), вЖР MeasureTheory.integral_finset_sum _ hintegr]
  apply integral_congr_ae
  apply Filter.Eventually.of_forall
  intro ќ±
  simp only [PhiArc]
  rw [Finset.sum_mul]

/-- `ќ¶¬Јe(-nќ±)` is integrable on `(0,1]` (finite sum of indicator¬Јcontinuous terms). -/
lemma PhiArc_integrableOn (N P Q n : вДХ) :
    IntegrableOn (fun ќ± => PhiArc N P Q ќ± * e (-((n : вДЭ) * ќ±))) (Set.Ioc (0:вДЭ) 1) := by
  have hmeas : вИА pq : вДХ √Ч вД§, MeasurableSet (arc Q pq) :=
    fun pq => (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  have hrw : (fun ќ± => PhiArc N P Q ќ± * e (-((n : вДЭ) * ќ±)))
      = fun ќ± => вИС pq вИИ anchors P,
          ((arc Q pq).indicator (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±
            * e (-((n : вДЭ) * ќ±))) := by
    funext ќ±; simp only [PhiArc]; rw [Finset.sum_mul]
  rw [IntegrableOn, hrw]
  apply MeasureTheory.integrable_finset_sum
  intro pq _
  have hrw2 : (fun ќ± => (arc Q pq).indicator
      (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
        * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) ќ±
        * e (-((n : вДЭ) * ќ±)))
      = (arc Q pq).indicator (fun ќ± =>
          ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
            * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2
            * e (-((n : вДЭ) * ќ±))) := by
    funext ќ±
    by_cases hќ± : ќ± вИИ arc Q pq
    ¬Ј rw [Set.indicator_of_mem hќ±, Set.indicator_of_mem hќ±]
    ¬Ј rw [Set.indicator_of_notMem hќ±, Set.indicator_of_notMem hќ±, zero_mul]
  rw [hrw2]
  exact (MeasureTheory.IntegrableOn.indicator
    (by apply Continuous.integrableOn_Ioc; simp only [e]; fun_prop) (hmeas pq))

/-- **Arc-tail error as a single Fourier coefficient**: `coeffModel(n) вИТ r_N¬ЈрЭФЦ_P(n) =
    вИЂ_{(0,1]} (ќ¶ вИТ ќ®_ideal)¬Јe(-nќ±)`. Combines `coeffModel_eq_intPhi` + `mainInt_eq` + `integral_sub`
    (both `ќ¶¬Јe`, `ќ®_ideal¬Јe` integrable) + factoring `e`. The arc-tail L¬≤ error is now
    `вИС_n |вИЂ(ќ¶вИТќ®_ideal)e(-nќ±)|¬≤`, bounded by ONE Bessel inequality by `вИЂ|ќ¶вИТќ®_ideal|¬≤`. -/
lemma arcTailError_eq_int (N P Q n : вДХ) :
    coeffModel N P Q n
        - (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) * singSeriesC P n
      = вИЂ ќ± in Set.Ioc (0:вДЭ) 1, (PhiArc N P Q ќ± - PsiIdeal N P ќ±) * e (-((n : вДЭ) * ќ±)) := by
  rw [coeffModel_eq_intPhi, mainInt_eq, вЖР integral_sub (PhiArc_integrableOn N P Q n) ?_]
  ¬Ј apply integral_congr_ae
    apply Filter.Eventually.of_forall
    intro ќ±; ring
  ¬Ј apply Continuous.integrableOn_Ioc; simp only [PsiIdeal, e]; fun_prop

/-- `вАЦe xвАЦ = 1` (unit character). -/
lemma norm_e (x : вДЭ) : вАЦe xвАЦ = 1 := by
  rw [e, Complex.norm_exp]
  have : (2 * (Real.pi : вДВ) * Complex.I * (x : вДЭ)).re = 0 := by
    simp [Complex.mul_re, Complex.mul_im]
  rw [this, Real.exp_zero]

/-- `вАЦD_N(x)вАЦ = вАЦвИС_{k<N} e(kx)вАЦ вЙ§ N`. -/
lemma dirichlet_norm_le (N : вДХ) (x : вДЭ) :
    вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * x)вАЦ вЙ§ (N : вДЭ) := by
  calc вАЦвИС k вИИ Finset.range N, e ((k : вДЭ) * x)вАЦ
      вЙ§ вИС k вИИ Finset.range N, вАЦe ((k : вДЭ) * x)вАЦ := norm_sum_le _ _
    _ = вИС k вИИ Finset.range N, (1 : вДЭ) := by
        apply Finset.sum_congr rfl; intro k _; exact norm_e _
    _ = (N : вДЭ) := by simp

/-- `ќ¶ вИТ ќ®_ideal` is uniformly bounded (`вАЦD_NвАЦвЙ§N`, `вАЦ(ќЉ/ѕЖ)¬≤вАЦ`-weighted finite sums). -/
lemma PhiSubPsi_bdd (N P Q : вДХ) :
    вИГ C : вДЭ, вИА ќ± : вДЭ, вАЦPhiArc N P Q ќ± - PsiIdeal N P ќ±вАЦ вЙ§ C := by
  have hD2 : вИА c : вДЭ, вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (c))) ^ 2вАЦ вЙ§ (N : вДЭ) ^ 2 := by
    intro c
    rw [norm_pow]
    exact pow_le_pow_leftвВА (norm_nonneg _) (dirichlet_norm_le N c) 2
  refine вЯ®(вИС pq вИИ anchors P, вАЦ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2вАЦ * (N : вДЭ) ^ 2)
        + (вИС q вИИ Finset.Icc 1 P, вАЦ((ArithmeticFunction.moebius q : вДВ) / (Nat.totient q : вДВ)) ^ 2вАЦ
            * ((redRes q).card * (N : вДЭ) ^ 2)), fun ќ± => ?_вЯ©
  refine le_trans (norm_sub_le _ _) (add_le_add ?_ ?_)
  ¬Ј simp only [PhiArc]
    refine le_trans (norm_sum_le _ _) (Finset.sum_le_sum ?_)
    intro pq _
    refine le_trans (norm_indicator_le_norm_self _ _) ?_
    rw [norm_mul]
    exact mul_le_mul_of_nonneg_left (hD2 _) (norm_nonneg _)
  ¬Ј simp only [PsiIdeal]
    refine le_trans (norm_sum_le _ _) (Finset.sum_le_sum ?_)
    intro q _
    rw [norm_mul]
    refine mul_le_mul_of_nonneg_left ?_ (norm_nonneg _)
    refine le_trans (norm_sum_le _ _) ?_
    calc вИС a вИИ redRes q, вАЦ(вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (a : вДЭ) / (q : вДЭ)))) ^ 2вАЦ
        вЙ§ вИС a вИИ redRes q, (N : вДЭ) ^ 2 := Finset.sum_le_sum (fun a _ => hD2 _)
      _ = ((redRes q).card : вДЭ) * (N : вДЭ) ^ 2 := by rw [Finset.sum_const, nsmul_eq_mul]

/-- `вАЦќ¶ вИТ ќ®_idealвАЦ¬≤` is integrable on `(0,1]` (bounded √Ч finite measure) вАФ the finite RHS of the
    arc-tail Bessel bound. -/
lemma PhiSubPsi_sq_integrableOn (N P Q : вДХ) :
    IntegrableOn (fun ќ± => вАЦPhiArc N P Q ќ± - PsiIdeal N P ќ±вАЦ ^ 2) (Set.Ioc (0:вДЭ) 1) := by
  obtain вЯ®C, hCвЯ© := PhiSubPsi_bdd N P Q
  have hphi : AEStronglyMeasurable (fun ќ± => PhiArc N P Q ќ±)
      (volume.restrict (Set.Ioc (0:вДЭ) 1)) := by
    have heq : (fun ќ± => PhiArc N P Q ќ±)
        = вИС pq вИИ anchors P, (arc Q pq).indicator
            (fun ќ± => ((ArithmeticFunction.moebius pq.1 : вДВ) / (Nat.totient pq.1 : вДВ)) ^ 2
              * (вИС k вИИ Finset.range N, e ((k : вДЭ) * (ќ± - (pq.2 : вДЭ) / (pq.1 : вДЭ)))) ^ 2) := by
      funext ќ±; simp only [PhiArc, Finset.sum_apply]
    rw [heq]
    apply Finset.aestronglyMeasurable_sum
    intro pq _
    apply AEStronglyMeasurable.indicator
    ¬Ј apply Continuous.aestronglyMeasurable; simp only [e]; fun_prop
    ¬Ј exact (Metric.isClosed_closedBall.measurableSet).inter measurableSet_Ioc
  have hpsi : AEStronglyMeasurable (fun ќ± => PsiIdeal N P ќ±)
      (volume.restrict (Set.Ioc (0:вДЭ) 1)) := by
    apply Continuous.aestronglyMeasurable; simp only [PsiIdeal, e]; fun_prop
  have hf : AEStronglyMeasurable (fun ќ± => вАЦPhiArc N P Q ќ± - PsiIdeal N P ќ±вАЦ ^ 2)
      (volume.restrict (Set.Ioc (0:вДЭ) 1)) :=
    (continuous_norm.pow 2).comp_aestronglyMeasurable (hphi.sub hpsi)
  apply MeasureTheory.Integrable.mono' (g := fun _ => C ^ 2)
    (continuous_const.integrableOn_Ioc) hf
  apply Filter.Eventually.of_forall
  intro ќ±
  rw [Real.norm_of_nonneg (sq_nonneg _)]
  exact pow_le_pow_leftвВА (norm_nonneg _) (hC ќ±) 2


/-- **Arc-tail L¬≤ error вЙ§ вИЂвАЦќ¶вИТќ®_idealвАЦ¬≤** вАФ the single Bessel bound. `вИС_{n<M}вАЦcoeffModel(n) вИТ
    r_NрЭФЦ_P(n)вАЦ¬≤ вЙ§ вИЂ_{(0,1]}вАЦќ¶вИТќ®_idealвАЦ¬≤`: rewrite each summand by `arcTailError_eq_int` (making it a
    Fourier coefficient of the `n`-independent `ќ¶вИТќ®_ideal`), then ONE `bessel_Ioc` (L¬≤-integrability
    from `PhiSubPsi_sq_integrableOn`). The arc-tail L¬≤ error is now controlled by a single integral вАФ
    remaining: `вИЂ_{(0,1]}вАЦќ¶вИТќ®_idealвАЦ¬≤ вЙ§ ќµX¬≥` (the Dirichlet-LвБі major-arc estimate). -/
lemma arcTailError_bessel (N P Q M : вДХ) :
    вИС n вИИ Finset.range M,
        вАЦcoeffModel N P Q n
          - (((Finset.range N √ЧЋҐ Finset.range N).filter (fun p => p.1 + p.2 = n)).card : вДВ) * singSeriesC P nвАЦ ^ 2
      вЙ§ вИЂ ќ± in Set.Ioc (0:вДЭ) 1, вАЦPhiArc N P Q ќ± - PsiIdeal N P ќ±вАЦ ^ 2 := by
  simp_rw [arcTailError_eq_int]
  exact bessel_Ioc (fun ќ± => PhiArc N P Q ќ± - PsiIdeal N P ќ±) (PhiSubPsi_sq_integrableOn N P Q) M

-- ==== Tarithv discharge (= MajorArcMainTerm.Tarith evaluated) ====

noncomputable def Tarithv : вДХ вЖТ вДХ вЖТ вДЭ := fun n q => Tarith n q

theorem Tarithv_apply (n q : вДХ) :
    Tarithv n q = (ArithmeticFunction.moebius q : вДЭ) ^ 2 * (cRam q n : вДЭ)
      / (Nat.totient q : вДЭ) ^ 2 := Tarith_apply n q

theorem Tarithv_zero (n : вДХ) : Tarithv n 0 = 0 := ArithmeticFunction.map_zero

theorem Tarith_summable_v (n : вДХ) (hn : 1 вЙ§ n) :
    Summable (fun q => вАЦTarithv n qвАЦ) := Tarith_summable n hn

theorem singSeries_eq_sum_Tarithv (P n : вДХ) :
    singSeries P n = вИС q вИИ Finset.Icc 1 P, Tarithv n q := singSeries_eq_sum_Tarith P n

