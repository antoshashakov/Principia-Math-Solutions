/-- **R4b: THE PER-CHARACTER SIEGELвАУWALFISZ BOUND** вАФ for every `B вЙ• 1` there are `cвВВ, CвВВ, XвВА > 0`
    with: for all `X вЙ• XвВА`, moduli `q вЙ§ (log X)^B`, and nontrivial `ѕЗ mod q`,
    `вАЦѕИ_smooth(X,ѕЗ)вАЦ вЙ§ CвВВ¬ЈX¬Јexp(вИТcвВВ¬Ј(log X)^{1/10})`. Instantiates
    `psi_smooth_bound_quantitative` at `ќµ = 1/(4B)`, `T = exp(вИЪ(log X))` and collapses via
    R1 (`LT_bounds_at_exp`), R2/R3 (`rate_g_bounds`), R4b-pre (`N_eps_bounds`),
    `rpow_shift_as_exp`, and R4a (`poly_exp_absorption`). -/
theorem psi_smooth_SW_rate (B : вДЭ) (hB : 1 вЙ§ B) :
    вИГ cвВВ CвВВ XвВА : вДЭ, 0 < cвВВ вИІ 0 < CвВВ вИІ вИА X : вДЭ, XвВА вЙ§ X вЖТ
    вИА (N : вДХ) [NeZero N] (ѕЗ : DirichletCharacter вДВ N), ѕЗ вЙ† 1 вЖТ
    (N:вДЭ) вЙ§ Real.log X ^ (B : вДЭ) вЖТ
    вАЦвИС n вИИ Finset.range (вМКXвМЛвВК + 1),
        ѕЗ (n : ZMod N) * ((vonMangoldt n : вДЭ) : вДВ) * (1 - (n : вДЭ) / X)вАЦ
      вЙ§ CвВВ * X * Real.exp (-(cвВВ * Real.log X ^ ((1:вДЭ)/10))) := by
  obtain вЯ®c, C, hc0, hc12, hC1, hmainвЯ© := psi_smooth_bound_quantitative (1/(4*B)) (by positivity)
  set MвВА := max ((4*B+23)^2) (max ((80/c)^4) 256) with hMвВАdef
  have hMвВА256 : (256:вДЭ) вЙ§ MвВА := le_trans (le_max_right _ _) (le_max_right _ _)
  have hMвВА1 : (1:вДЭ) вЙ§ MвВА := by linarith
  have hMвВА0 : (0:вДЭ) вЙ§ MвВА := by linarith
  refine вЯ®c/8, 30*C + 48/c^2, Real.exp (MвВА^2), by positivity, by positivity, ?_вЯ©
  intro X hX N _ ѕЗ hѕЗ hNB
  -- basic scales
  have hL : MвВА^2 вЙ§ Real.log X := by
    have h1 : Real.log (Real.exp (MвВА^2)) вЙ§ Real.log X :=
      Real.log_le_log (Real.exp_pos _) hX
    rwa [Real.log_exp] at h1
  have hL1 : (1:вДЭ) вЙ§ Real.log X := by nlinarith
  have hL0 : (0:вДЭ) < Real.log X := by linarith
  have hX1 : (1:вДЭ) < X := by
    have h1 : Real.exp 1 вЙ§ Real.exp (MвВА^2) := Real.exp_le_exp.mpr (by nlinarith)
    have h2 := Real.add_one_le_exp 1
    linarith
  have hX0 : (0:вДЭ) < X := by linarith
  set L := Real.log X with hLdef
  set u := L ^ ((1:вДЭ)/2) with hudef
  have hu0 : (0:вДЭ) < u := Real.rpow_pos_of_pos hL0 _
  have huM : MвВА вЙ§ u := by
    have h1 : (MвВА^2) ^ ((1:вДЭ)/2) вЙ§ L ^ ((1:вДЭ)/2) :=
      Real.rpow_le_rpow (by positivity) hL (by norm_num)
    rwa [show (MвВА:вДЭ)^2 = MвВА * MвВА by ring, вЖР Real.sqrt_eq_rpow,
      Real.sqrt_mul_self hMвВА0] at h1
  have hu1 : (1:вДЭ) вЙ§ u := le_trans hMвВА1 huM
  have hLuu : u * u = L := by
    rw [hudef, вЖР Real.rpow_add hL0]
    norm_num
  set T := Real.exp u with hTdef
  have hT0 : (0:вДЭ) < T := Real.exp_pos _
  have hN1 : (1:вДЭ) вЙ§ (N:вДЭ) := by
    exact_mod_cast Nat.one_le_iff_ne_zero.mpr (NeZero.ne N)
  -- N вЙ§ u^{2B}
  have hNru : (N:вДЭ) вЙ§ u ^ (2*B : вДЭ) := by
    have h1 : L ^ (B:вДЭ) = u ^ (2*B : вДЭ) := by
      rw [вЖР hLuu, show u * u = u ^ ((2:вДХ):вДЭ) from by rw [Real.rpow_natCast]; ring,
        вЖР Real.rpow_mul hu0.le]
      norm_num
    rwa [h1] at hNB
  -- R1
  obtain вЯ®hLTlo, hLThiвЯ© := LT_bounds_at_exp B hB u
    (le_trans (le_max_left _ _) huM) (N:вДЭ) hN1 hNru
  set LTv := Real.log ((N:вДЭ) * (4*(T+1)+7)) + 20 with hLTvdef
  -- R4b-pre
  obtain вЯ®hNup, hNe_lo, hNe_hiвЯ© := N_eps_bounds B hB u (N:вДЭ) hu1 hN1 hNru
  set Ne := (N:вДЭ) ^ (-((1:вДЭ)/(4*B))) with hNedef
  set g := c * Ne / LTv with hgdef
  have hLT0 : (0:вДЭ) < LTv := by linarith
  have hNe0 : (0:вДЭ) < Ne := Real.rpow_pos_of_pos (by linarith) _
  have hg0 : (0:вДЭ) < g := by rw [hgdef]; positivity
  -- R2/R3
  obtain вЯ®hR2, hR3вЯ© := rate_g_bounds c u LTv Ne hc0 hc12 hu1 hLTlo hLThi hNe_lo hNe_hi
  set M := C * (N:вДЭ) ^ ((1:вДЭ)/(4*B)) * LTv^2 with hMdef
  have hM0 : (0:вДЭ) вЙ§ M := by rw [hMdef]; positivity
  -- M вЙ§ 4C¬Јu^{5/2}
  have hMle : M вЙ§ 4*C * u ^ ((5:вДЭ)/2) := by
    have h1 : LTv^2 вЙ§ 4 * (u*u) := by nlinarith
    have h2 : (N:вДЭ) ^ ((1:вДЭ)/(4*B)) * LTv^2 вЙ§ u ^ ((1:вДЭ)/2) * (4*(u*u)) := by
      apply mul_le_mul hNup h1 (by positivity) (by positivity)
    have h3 : u ^ ((1:вДЭ)/2) * (4*(u*u)) = 4 * u ^ ((5:вДЭ)/2) := by
      rw [show u * u = u ^ ((2:вДХ):вДЭ) from by rw [Real.rpow_natCast]; ring,
        show u ^ ((1:вДЭ)/2) * (4 * u ^ (((2:вДХ):вДЭ))) = 4 * (u ^ ((1:вДЭ)/2) * u ^ (((2:вДХ):вДЭ))) from by ring,
        вЖР Real.rpow_add hu0]
      norm_num
    calc M = C * ((N:вДЭ) ^ ((1:вДЭ)/(4*B)) * LTv^2) := by rw [hMdef]; ring
      _ вЙ§ C * (u ^ ((1:вДЭ)/2) * (4*(u*u))) := by
          apply mul_le_mul_of_nonneg_left h2 (by linarith)
      _ = 4*C * u ^ ((5:вДЭ)/2) := by rw [h3]; ring
  -- the main bound
  have hbound := hmain N ѕЗ hѕЗ X hX1 T hT0
  -- identify: the main's terms with our abbreviations (they are literally the same after `set`)
  -- term bounds
  have hXg : X ^ (g : вДЭ) = Real.exp (g * L) := by
    rw [Real.rpow_def_of_pos hX0, mul_comm]
  have hgL2 : (c/4) * u ^ ((1:вДЭ)/2) вЙ§ (g/2) * L := by
    have := hR2
    rw [вЖР hLuu]
    nlinarith
  have hgLu : g * L вЙ§ u/2 := by rw [вЖР hLuu]; exact hR3
  -- fold the abbreviations into hbound
  rw [вЖР hLTvdef] at hbound
  rw [вЖР hNedef] at hbound
  rw [вЖР hgdef] at hbound
  rw [вЖР hMdef] at hbound
  -- exponentials
