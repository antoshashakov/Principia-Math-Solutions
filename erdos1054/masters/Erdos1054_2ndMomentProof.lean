        (differentiable_id.neg.const_cpow (Or.inl hb1))).sub
      ((((differentiable_const (1:вДВ)).sub differentiable_id).const_cpow (Or.inl hb1)).sub
        (((differentiable_const (1:вДВ)).sub differentiable_id).const_cpow (Or.inl hb2)))
  have hidentity : вИА s : вДВ, 1 < s.re вЖТ
      DirichletCharacter.LFunctionTrivCharвВБ 1 s = 1 + T s := by
    intro s hs1
    have hsne : s вЙ† 1 := fun h => by
      rw [h, Complex.one_re] at hs1
      exact lt_irrefl _ hs1
    have hs0 : s вЙ† 0 := fun h => by
      rw [h, Complex.zero_re] at hs1
      linarith
    have hL : DirichletCharacter.LFunctionTrivCharвВБ 1 s = (s - 1) * riemannZeta s := by
      rw [DirichletCharacter.LFunctionTrivCharвВБ, Function.update_of_ne hsne,
        DirichletCharacter.LFunctionTrivChar_eq_mul_riemannZeta hsne,
        Nat.primeFactors_one, Finset.prod_empty, one_mul]
    have hќґ := zeta_eq_tsum_one_div_nat_cpow hs1
    have hA : Summable (fun n : вДХ => (1:вДВ)/((n:вДВ))^s) :=
      Complex.summable_one_div_nat_cpow.mpr hs1
    have hB := tsum_cpow_telescope_summable 1 (le_refl 1) hs1
    have hAeq : (fun n : вДХ => (if n < 1 then (0:вДВ) else (s - 1) * ((n:вДВ)) ^ (-s)))
        = fun n : вДХ => (s - 1) * ((1:вДВ)/((n:вДВ))^s) := by
      funext n
      rcases Nat.eq_zero_or_pos n with h0 | hpos
      ¬Ј subst h0
        simp [Complex.zero_cpow hs0]
      ¬Ј rw [if_neg (by omega), Complex.cpow_neg, one_div]
    have hAsum : Summable (fun n : вДХ =>
        (if n < 1 then (0:вДВ) else (s - 1) * ((n:вДВ)) ^ (-s))) := by
      rw [hAeq]
      exact hA.mul_left _
    have hGeq : (fun n : вДХ =>
        (if n < 1 then (0:вДВ) else ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))))
        = fun n : вДХ => ((if n < 1 then (0:вДВ) else (s - 1) * ((n:вДВ)) ^ (-s))
          - (if n < 1 then (0:вДВ)
            else (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))) := by
      funext n
      split_ifs
      ¬Ј ring
      ¬Ј ring
    have hGsum : Summable (fun n : вДХ =>
        (if n < 1 then (0:вДВ) else ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))) := by
      rw [hGeq]
      exact hAsum.sub hB
    have hGtsum : вИС' n : вДХ, (if n < 1 then (0:вДВ) else ((s - 1) * ((n:вДВ)) ^ (-s)
          - (((n:вДВ)) ^ ((1:вДВ) - s) - (((n+1 : вДХ):вДВ)) ^ ((1:вДВ) - s))))
        = (s - 1) * riemannZeta s - 1 := by
      rw [hGeq, hAsum.tsum_sub hB, tsum_cpow_telescope 1 (le_refl 1) hs1, hAeq,
        tsum_mul_left, вЖР hќґ]
      norm_num
    have hshift := hGsum.tsum_eq_zero_add
    have hTG : T s = вИС' k : вДХ, (if k+1 < 1 then (0:вДВ)
        else ((s - 1) * (((k+1 : вДХ):вДВ)) ^ (-s)
          - ((((k+1 : вДХ):вДВ)) ^ ((1:вДВ) - s) - ((((k+1)+1 : вДХ):вДВ)) ^ ((1:вДВ) - s)))) := by
      simp only [hTdef]
