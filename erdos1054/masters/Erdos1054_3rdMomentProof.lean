/-- `Nat.log 2 N ≤ 2·log N`. -/
lemma natlog2_le_two_log (N : ℕ) (hN : 2 ≤ N) : ((Nat.log 2 N : ℕ) : ℝ) ≤ 2 * Real.log N := by
  have hself : (2 : ℕ) ^ Nat.log 2 N ≤ N := Nat.pow_log_le_self 2 (by omega)
