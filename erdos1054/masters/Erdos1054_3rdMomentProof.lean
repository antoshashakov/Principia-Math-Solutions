  have hC0 : (0:ℝ) ≤ ‖s - 1‖ / (s.re - 1) := div_nonneg (norm_nonneg _) hs1.le
  have hgmono : ∀ n : ℕ, 1 ≤ n →
      (((n + 1 : ℕ)) : ℝ) ^ (-(s.re - 1)) ≤ ((n : ℝ)) ^ (-(s.re - 1)) := by
