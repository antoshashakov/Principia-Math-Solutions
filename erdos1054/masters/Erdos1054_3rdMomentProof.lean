/-- Reflection identity (Lemma 3.1): `F e d = (e·d)·g_e(e·d)` in `ℚ`, via the
    divisor-reflection bijection `q ↦ (e·d)/q` between the prefix divisors
    `{q ≤ d}` and the suffix divisors `{r ≥ e}` of `e·d`. -/
theorem reflection_identity (e d : Nat) (he : 0 < e) (hd : 0 < d) :
    (F e d : ℚ) = (e * d : ℚ) * g e (e * d) := by
  have hn : 0 < e * d := Nat.mul_pos he hd
  unfold F g
  push_cast
  rw [Finset.mul_sum]
  refine Finset.sum_bij'
    (fun q _ => (e * d) / q) (fun r _ => (e * d) / r)
    (fun q hq => reflect_mem_right e d q he hd hq)
    (fun r hr => reflect_mem_left e d r he hd hr)
    (fun q hq => prefix_reflect_involutive e d q he hd hq)
    (fun r hr => suffix_reflect_involutive e d r he hd hr)
    ?_
  intro q hq
  have hqmem := Finset.mem_filter.mp hq
  have hqdvd : q ∣ e * d := (Nat.mem_divisors.mp hqmem.1).1
  have hqpos : 0 < q := Nat.pos_of_dvd_of_pos hqdvd hn
  have hqne : (q : ℚ) ≠ 0 := by exact_mod_cast hqpos.ne'
  have hnne : (e * d : ℚ) ≠ 0 := by exact_mod_cast hn.ne'
  have hcast : (((e * d) / q : Nat) : ℚ) = (e * d : ℚ) / (q : ℚ) := by
    rw [Nat.cast_div hqdvd hqne] <;> push_cast <;> ring
  rw [hcast]
  field_simp <;> push_cast <;> ring



theorem positiveLowerDensity_mono (P Q : Nat → Prop) (h : ∀ n, P n → Q n)
    (hP : PositiveLowerDensity P) : PositiveLowerDensity Q := by
  obtain ⟨c, hc, X₀, hX₀⟩ := hP
  refine ⟨c, hc, X₀, ?_⟩
  intro X hX
  have hmono : (countUpTo P X : ℚ) ≤ (countUpTo Q X : ℚ) := by
    exact_mod_cast countUpTo_mono P Q h X
  exact le_trans (hX₀ X hX) hmono

/-- **Erdős Problem 1054 — third-moment full proof.**
    For every fixed `A ≥ 1`, the represented integers `N` with `f(N) > A·N`
    have positive lower density. -/
theorem erdos1054_third_moment_full_proof (A : Nat) (hA : 1 ≤ A) :
    PositiveLowerDensity (fun N => Represented N ∧ A * N < f N) := by
  -- feed the §8 assembly the three standard analytic inputs, so this theorem's
  -- verified dependency chain genuinely includes Mertens' third theorem (A2)
  obtain ⟨P, hPdens, hPimp⟩ :=
    section8_positive_density_witness A hA
      dirichlet_ap_reciprocal_diverges mertens_third_lower almost_all_binary_goldbach
  exact positiveLowerDensity_mono P _ hPimp hPdens

/-- A positive-lower-density set is inhabited (indeed unbounded).  Standard
    consequence of the density lower bound; proof of the `density ⇒ nonempty`
    step deferred. -/
theorem exists_of_positiveLowerDensity (P : Nat → Prop)
    (hP : PositiveLowerDensity P) : ∃ N, P N := by
  classical
  obtain ⟨c, hc, X₀, hX₀⟩ := hP
  obtain ⟨X, hX0le, hXbig⟩ : ∃ X : Nat, X₀ ≤ X ∧ (1 : ℚ) ≤ c * X := by
    obtain ⟨n, hn⟩ := exists_nat_ge (1 / c)          -- (1/c) ≤ (n : ℚ)
    refine ⟨max X₀ n, le_max_left _ _, ?_⟩
    have hnle : (1 / c) ≤ ((max X₀ n : Nat) : ℚ) :=
      le_trans hn (by exact_mod_cast le_max_right X₀ n)
    have hmul := mul_le_mul_of_nonneg_left hnle hc.le    -- c*(1/c) ≤ c*(max …)
    rwa [mul_one_div, div_self (ne_of_gt hc)] at hmul
  have hcard := hX₀ X hX0le
  have hpos : (0 : ℚ) < (countUpTo P X : ℚ) :=
    lt_of_lt_of_le zero_lt_one (le_trans hXbig hcard)
  have hpos' : 0 < countUpTo P X := by exact_mod_cast hpos
  unfold countUpTo at hpos'
  obtain ⟨N, hN⟩ := Finset.card_pos.mp hpos'
  exact ⟨N, (Finset.mem_filter.mp hN).2⟩

/-- Consequently `f(N)/N` is unbounded on the represented integers: for every
    `A` there is a represented `N` with `f(N) > A·N`. -/
theorem erdos1054_ratio_unbounded (A : Nat) (hA : 1 ≤ A) :
    ∃ N, Represented N ∧ A * N < f N :=
  exists_of_positiveLowerDensity _ (erdos1054_third_moment_full_proof A hA)

