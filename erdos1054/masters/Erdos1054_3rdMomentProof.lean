    positivity
  calc ∑ n ∈ Finset.range (2 * N),
      ‖(∫ α in ⋃ pq ∈ anchors P,
            (Metric.closedBall ((pq.2 : ℝ) / (pq.1 : ℕ)) (1 / (pq.1 * (Q + 1)))
              ∩ Set.Ioc (0:ℝ) 1),
          (∑ k ∈ Finset.range N, ((Λ k : ℝ) : ℂ) * e ((k : ℝ) * α)) ^ 2
            * e (-((n : ℝ) * α)))
        - (∑ pq ∈ anchors P,
            ∫ α in Metric.closedBall ((pq.2 : ℝ) / (pq.1 : ℕ)) (1 / (pq.1 * (Q + 1)))
              ∩ Set.Ioc (0:ℝ) 1,
            ((∑ r ∈ Finset.range pq.1,
