    have hsub : ∀ pq ∈ anchors P,
        (∫ α in Metric.closedBall ((pq.2 : ℝ) / (pq.1 : ℕ)) (1 / (pq.1 * (Q + 1)))
            ∩ Set.Ioc (0:ℝ) 1,
          (∑ k ∈ Finset.range N, ((Λ k : ℝ) : ℂ) * e ((k : ℝ) * α)) ^ 2
            * e (-((n : ℝ) * α)))
        - (∫ α in Metric.closedBall ((pq.2 : ℝ) / (pq.1 : ℕ)) (1 / (pq.1 * (Q + 1)))
            ∩ Set.Ioc (0:ℝ) 1,
          ((∑ r ∈ Finset.range pq.1,
              e ((r : ℝ) * (pq.2 : ℝ) / (pq.1 : ℝ)) * lambdaModel pq.1 r)
            * ∑ k ∈ Finset.range N, e ((k : ℝ) * (α - (pq.2 : ℝ) / (pq.1 : ℝ)))) ^ 2
