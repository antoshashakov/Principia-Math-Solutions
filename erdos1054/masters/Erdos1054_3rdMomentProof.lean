theorem represented_iff_isRep (N : Nat) : Represented N ↔ ∃ m, IsRep m N := by
  constructor
  · rintro ⟨e, d, he, hd, hN⟩; exact ⟨e * d, e, d, he, hd, rfl, hN⟩
  · rintro ⟨m, e, d, he, hd, _, hN⟩; exact ⟨e, d, he, hd, hN⟩

