      split
      · positivity
      · exact le_min (by positivity) (by positivity)
    calc ‖∑ m ∈ Finset.Ioc 0 M, ((ArithmeticFunction.log m : ℝ) : ℂ)
          * e (((d * m : ℕ) : ℝ) * α)‖
        = ‖∑ m ∈ Finset.range (M + 1),
            ((Real.log ((min m (M + 1) : ℕ) : ℝ) : ℝ) : ℂ) * e ((m : ℝ) * β)‖ := by
          rw [hstep1, hstep2, hstep3]
