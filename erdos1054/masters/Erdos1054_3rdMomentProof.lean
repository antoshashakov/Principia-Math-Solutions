def IsRep (m N : Nat) : Prop := ∃ e d, 0 < e ∧ 0 < d ∧ m = e * d ∧ N = F e d
def Represented (N : Nat) : Prop := ∃ e d, 0 < e ∧ 0 < d ∧ N = F e d
noncomputable def f (N : Nat) : Nat := sInf {m | 0 < m ∧ IsRep m N}
noncomputable def countUpTo (P : Nat → Prop) (X : Nat) : Nat := by
  classical
  exact ((Finset.range (X + 1)).filter P).card
def DensityZero (P : Nat → Prop) : Prop :=
  ∀ ε : Rat, 0 < ε → ∃ X₀ : Nat, ∀ X : Nat, X ≥ X₀ → (countUpTo P X : Rat) ≤ ε * X
def PositiveLowerDensity (P : Nat → Prop) : Prop :=
  ∃ c : Rat, 0 < c ∧ ∃ X₀ : Nat, ∀ X : Nat, X ≥ X₀ → c * X ≤ (countUpTo P X : Rat)
def notSumOfTwoPrimes (n : Nat) : Prop :=
  Even n ∧ ¬ ∃ p q, Nat.Prime p ∧ Nat.Prime q ∧ n = p + q

/-- `Erdos1054.F` and `Represented.F` have identical bodies. -/
theorem F_eq (e d : Nat) : F e d = Represented.F e d := rfl

/-- Bridge 1 (verified in btest): the two `countUpTo` definitions agree. -/
theorem countUpTo_eq (P : Nat → Prop) (X : Nat) :
    countUpTo P X = Represented.countUpTo P X := by
  classical
  have hset : Represented.setUpTo P X
      = (((Finset.range (X + 1)).filter P : Finset Nat) : Set Nat) := by
    ext n
    simp only [Represented.setUpTo, Set.mem_setOf_eq, Finset.mem_coe, Finset.mem_filter,
      Finset.mem_range, Nat.lt_succ_iff]
  have htf : (((Finset.range (X + 1)).filter P : Finset Nat) : Set Nat).toFinset
      = (Finset.range (X + 1)).filter P := by ext a; simp
  rw [Represented.countUpTo, hset, Set.ncard_eq_toFinset_card', htf]
  simp only [countUpTo]

/-- Bridge 2 (verified): `DensityZero` (ε-form) → `CountIsLittleO`. -/
theorem densityZero_to_littleO (P : Nat → Prop) (h : DensityZero P) :
    Represented.CountIsLittleO P := by
  rw [Represented.CountIsLittleO, isLittleO_iff]
  intro ε hε
  obtain ⟨q, hq0, hqε⟩ := exists_rat_btwn hε
  have hq0' : (0 : ℚ) < q := by exact_mod_cast hq0
  obtain ⟨X₀, hX₀⟩ := h q hq0'
  rw [eventually_atTop]
  refine ⟨X₀, fun X hX => ?_⟩
  have hle := hX₀ X hX
  have hcast : (countUpTo P X : ℝ) ≤ (q : ℝ) * X := by exact_mod_cast hle
  rw [← countUpTo_eq]
  simp only [Real.norm_eq_abs]
  rw [abs_of_nonneg (by positivity), abs_of_nonneg (by positivity)]
  calc (countUpTo P X : ℝ) ≤ (q : ℝ) * X := hcast
    _ ≤ ε * X := mul_le_mul_of_nonneg_right hqε.le (by positivity)

/-- Bridge 3 (verified): `(∃ c>0, c ≤ lowerDensity P) → PositiveLowerDensity`. -/
theorem lowerDensity_to_PLD (P : Nat → Prop)
    (h : ∃ c : ℝ, 0 < c ∧ c ≤ Represented.lowerDensity P) :
    PositiveLowerDensity P := by
  obtain ⟨c, hc0, hc⟩ := h
  obtain ⟨q, hq0, hqc⟩ := exists_rat_btwn hc0
  have hq0' : (0 : ℚ) < q := by exact_mod_cast hq0
  have hqc' : (q : ℝ) < Represented.lowerDensity P := lt_of_lt_of_le hqc hc
  have hbdd : IsBoundedUnder (· ≥ ·) atTop
      (fun X : Nat => (Represented.countUpTo P X : ℝ) / (X : ℝ)) :=
    ⟨0, Filter.eventually_map.2 (Filter.Eventually.of_forall (fun X => by positivity))⟩
  have hev : ∀ᶠ X : Nat in atTop, (q : ℝ) < (Represented.countUpTo P X : ℝ) / (X : ℝ) :=
    eventually_lt_of_lt_liminf hqc' hbdd
  rw [eventually_atTop] at hev
  obtain ⟨X₀, hX₀⟩ := hev
  refine ⟨q, hq0', max X₀ 1, fun X hX => ?_⟩
  have hX1 : 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXpos : (0 : ℝ) < X := by exact_mod_cast hX1
  have hlt := hX₀ X hXX₀
  rw [lt_div_iff₀ hXpos, ← countUpTo_eq] at hlt
  exact_mod_cast hlt.le

/-- `Represented` (proof.lean form) coincides with `N ∈ Represented.R`. -/
theorem represented_iff_memR (N : Nat) : Represented N ↔ N ∈ Represented.R := by
  rw [Represented.mem_R_iff_exists_F]
  constructor
  · rintro ⟨e, d, he, hd, hN⟩; exact ⟨e, d, he, hd, by rw [hN, F_eq]⟩
  · rintro ⟨e, d, he, hd, hN⟩; exact ⟨e, d, he, hd, by rw [hN, ← F_eq]⟩

/-- The two `f`-minimisers coincide. -/
theorem f_eq (N : Nat) : f N = Represented.f N := by
  unfold f Represented.f
  congr 1
  rw [Represented.f_set_eq]
  ext m
  simp only [IsRep, Set.mem_setOf_eq]
  constructor
  · rintro ⟨hm, e, d, he, hd, hme, hN⟩
    exact ⟨e, d, he, hd, hme, by rw [hN, F_eq]⟩
  · rintro ⟨e, d, he, hd, hme, hN⟩
    refine ⟨by rw [hme]; exact Nat.mul_pos he hd, e, d, he, hd, hme, by rw [hN, ← F_eq]⟩

/-- **Erdős 1054 §8 — the positive-density witness, PROVEN** (was an axiom in
    proof.lean). Discharged via the verified `Represented.main`; the analytic
    inputs A2 (`hA2`) and A3 (`hA3`) supply `Represented.DeepInputs`. `hA1` is
    unused (A1 is proven internally in the `Represented` development). -/
theorem section8_positive_density_witness (A : Nat) (hA : 1 ≤ A)
    (hA1 : ∀ q, 1 < q →
      ¬ Summable (fun p : {p : Nat // p.Prime ∧ p % q = q - 1} => (1 / (p.1 : ℝ))))
    (hA2 : ∃ c₀ : ℝ, 0 < c₀ ∧ ∀ y : ℕ, 2 ≤ y →
      c₀ / Real.log (2 * (y : ℝ)) ≤
        ∏ p ∈ (Finset.range (y + 1)).filter Nat.Prime, (1 - 1 / (p : ℝ)))
    (hA3 : DensityZero notSumOfTwoPrimes) :
    ∃ P : Nat → Prop, PositiveLowerDensity P ∧
      (∀ N, P N → (Represented N ∧ A * N < f N)) := by
  -- Build the DeepInputs hypothesis from A2 (Mertens) and A3 (Goldbach).
  have hDeep : Represented.DeepInputs :=
    { mertens_lb := hA2
      goldbach_ae := densityZero_to_littleO _ hA3 }
  obtain ⟨c, hc0, hc⟩ := Represented.main hDeep (A : ℝ) (by exact_mod_cast hA)
  refine ⟨fun N => Represented N ∧ A * N < f N, ?_, fun N h => h⟩
  -- Positive lower density, via Bridge 3.
  apply lowerDensity_to_PLD
  refine ⟨c, hc0, ?_⟩
  -- The two survivor-predicates coincide, so their lower densities are equal.
  have hpred : (fun N => Represented N ∧ A * N < f N)
      = (fun N => N ∈ Represented.R ∧ (A : ℝ) * (N : ℝ) < (Represented.f N : ℝ)) := by
    funext N
    apply propext
    rw [represented_iff_memR]
    constructor
    · rintro ⟨hR, hlt⟩
      refine ⟨hR, ?_⟩
      have : ((A * N : ℕ) : ℝ) < ((f N : ℕ) : ℝ) := by exact_mod_cast hlt
      rw [f_eq] at this; push_cast at this ⊢; linarith
    · rintro ⟨hR, hlt⟩
      refine ⟨hR, ?_⟩
      rw [f_eq]
      have : ((A : ℝ) * (N : ℝ)) < (Represented.f N : ℝ) := hlt
      push_cast at this
      exact_mod_cast this
  rw [hpred]
  exact hc

end Erdos1054






end Section8Development

namespace A1proof
open scoped BigOperators LSeries.notation
open ArithmeticFunction ArithmeticFunction.vonMangoldt MeasureTheory intervalIntegral
variable {q : ℕ} {a : ZMod q}

noncomputable def prc (a : ZMod q) (n : ℕ) : ℝ := if (n.Prime ∧ (n:ZMod q) = a) then 1 else 0
noncomputable def Vf (a : ZMod q) (x : ℝ) : ℝ := ∑' n : ℕ, prc a n * (n:ℝ)^(-x)
noncomputable def Wf (a : ZMod q) (x : ℝ) : ℝ := ∑' n : ℕ, prc a n * Real.log n * (n:ℝ)^(-x)

theorem prc_nonneg (a : ZMod q) (n : ℕ) : 0 ≤ prc a n := by unfold prc; split_ifs <;> norm_num
theorem prc_le_one (a : ZMod q) (n : ℕ) : prc a n ≤ 1 := by unfold prc; split_ifs <;> norm_num
theorem coef_nonneg (a : ZMod q) (n : ℕ) : 0 ≤ prc a n * Real.log n := by
  rcases Nat.eq_zero_or_pos n with rfl | hn
  · simp [prc, Nat.not_prime_zero]
  · exact mul_nonneg (prc_nonneg a n) (Real.log_nonneg (by exact_mod_cast hn))

theorem ftc_rpow (p : ℝ) (hp : 0 < p) (x : ℝ) :
    (∫ t in x..2, Real.log p * p^(-t)) = p^(-x) - p^(-(2:ℝ)) := by
  have hcont : Continuous (fun t : ℝ => Real.log p * p^(-t)) :=
    continuous_const.mul ((Real.continuous_const_rpow (ne_of_gt hp)).comp continuous_neg)
  have hd : ∀ t ∈ Set.uIcc x (2:ℝ),
      HasDerivAt (fun t => -(p^(-t))) (Real.log p * p^(-t)) t := by
    intro t _
    have hf : HasDerivAt (fun t : ℝ => -t) (-1) t := (hasDerivAt_id t).neg
    have h1 := (hf.const_rpow hp).neg
    have heq : -(Real.log p * (-1) * p^(-t)) = Real.log p * p^(-t) := by ring
    rw [heq] at h1; exact h1
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt hd (hcont.intervalIntegrable _ _)]; ring

theorem gcont (a : ZMod q) (n : ℕ) : Continuous (fun t : ℝ => prc a n * Real.log n * (n:ℝ)^(-t)) := by
  rcases Nat.eq_zero_or_pos n with rfl | hn
  · simp only [prc, Nat.not_prime_zero, false_and, if_false, Nat.cast_zero, Real.log_zero,
      mul_zero, zero_mul]; exact continuous_const
  · exact continuous_const.mul ((Real.continuous_const_rpow (by exact_mod_cast hn.ne')).comp continuous_neg)

noncomputable def gcm (a : ZMod q) (n : ℕ) : C(ℝ, ℝ) := ⟨fun t => prc a n * Real.log n * (n:ℝ)^(-t), gcont a n⟩

theorem gnorm_le (x : ℝ) (hx1 : 1 < x) (hx2 : x ≤ 2) (n : ℕ) :
    ‖(gcm a n).restrict (⟨Set.uIcc x 2, isCompact_uIcc⟩ : TopologicalSpace.Compacts ℝ)‖
      ≤ prc a n * Real.log n * (n:ℝ)^(-x) := by
  have hval : 0 ≤ prc a n * Real.log n * (n:ℝ)^(-x) :=
    mul_nonneg (coef_nonneg a n) (Real.rpow_nonneg (Nat.cast_nonneg n) _)
  rw [ContinuousMap.norm_le _ hval]
  rintro ⟨t, ht⟩
  have ht' : x ≤ t ∧ t ≤ 2 := by simpa [Set.uIcc_of_le hx2] using ht
  simp only [ContinuousMap.restrict_apply, gcm, ContinuousMap.coe_mk]
  rw [Real.norm_of_nonneg (mul_nonneg (coef_nonneg a n) (Real.rpow_nonneg (Nat.cast_nonneg n) _))]
  have hrp : (n:ℝ)^(-t) ≤ (n:ℝ)^(-x) := by
    rcases Nat.eq_zero_or_pos n with rfl | hn
    · rw [Nat.cast_zero, Real.zero_rpow (by linarith [ht'.1] : -t ≠ 0), Real.zero_rpow (by linarith : -x ≠ 0)]
    · exact Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast hn) (by linarith [ht'.1])
  exact mul_le_mul_of_nonneg_left hrp (coef_nonneg a n)

theorem Rsum (x : ℝ) (hx : 1 < x) : Summable (fun n : ℕ => residueClass a n / (n:ℝ)^x) := by
  have h : LSeriesSummable (↗(residueClass a)) (x:ℂ) :=
    LSeriesSummable_of_abscissaOfAbsConv_lt_re <|
      (abscissaOfAbsConv_residueClass_le_one a).trans_lt (by exact_mod_cast hx)
  refine (h.norm).congr (fun n => ?_)
  rw [LSeries.norm_term_eq]
  rcases eq_or_ne n 0 with rfl | hn
  · simp
  · simp only [hn, if_false, Complex.ofReal_re]
    rw [Complex.norm_real, Real.norm_of_nonneg (residueClass_nonneg a n)]

theorem Wf_summand (x : ℝ) (n : ℕ) :
    prc a n * Real.log n * (n:ℝ)^(-x) = (if n.Prime then residueClass a n else 0) / (n:ℝ)^x := by
  rw [Real.rpow_neg (Nat.cast_nonneg n)]
  unfold prc residueClass
  by_cases hp : n.Prime
  · simp only [hp, if_true, Set.indicator_apply, Set.mem_setOf_eq]
    by_cases hc : (n:ZMod q) = a
    · simp only [hc, and_self, if_true, vonMangoldt_apply_prime hp]; ring
    · simp only [hc, and_false, if_false]; ring
  · simp only [hp, if_false, false_and, if_false]; ring

theorem Wsummable (x : ℝ) (hx : 1 < x) : Summable (fun n : ℕ => prc a n * Real.log n * (n:ℝ)^(-x)) := by
  apply (Rsum (a := a) x hx).of_nonneg_of_le
    (fun n => by rw [Wf_summand]; positivity [residueClass_nonneg a n])
    (fun n => ?_)
  rw [Wf_summand]
  by_cases hp : n.Prime <;> simp [hp] <;> exact div_nonneg (residueClass_nonneg a n) (by positivity)

theorem Vfsummable (x : ℝ) (hx : 1 < x) : Summable (fun n : ℕ => prc a n * (n:ℝ)^(-x)) := by
  apply Summable.of_nonneg_of_le
    (fun n => mul_nonneg (prc_nonneg a n) (Real.rpow_nonneg (Nat.cast_nonneg n) _))
    (fun n => ?_) (Real.summable_nat_rpow_inv.mpr hx)
  rw [Real.rpow_neg (Nat.cast_nonneg n)]
  calc prc a n * ((n:ℝ)^x)⁻¹ ≤ 1 * ((n:ℝ)^x)⁻¹ :=
        mul_le_mul_of_nonneg_right (prc_le_one a n) (by positivity)
    _ = ((n:ℝ)^x)⁻¹ := one_mul _

theorem intterm (x : ℝ) (n : ℕ) :
    (∫ t in x..2, gcm a n t) = prc a n * ((n:ℝ)^(-x) - (n:ℝ)^(-(2:ℝ))) := by
  simp only [gcm, ContinuousMap.coe_mk]
  rcases Nat.eq_zero_or_pos n with rfl | hn
  · simp [prc, Nat.not_prime_zero]
  · have hfac : (∫ t in x..2, prc a n * Real.log n * (n:ℝ)^(-t))
        = prc a n * ∫ t in x..2, Real.log (n:ℝ) * (n:ℝ)^(-t) := by
      rw [← intervalIntegral.integral_const_mul]; congr 1; funext t; ring
    rw [hfac, ftc_rpow (n:ℝ) (by exact_mod_cast hn) x]

theorem VW (ha : IsUnit a) {x : ℝ} (hx : x ∈ Set.Ioc 1 2) :
    Vf a x = Vf a 2 + ∫ t in x..2, Wf a t := by
  have hx1 : 1 < x := hx.1
  have hx2 : x ≤ 2 := hx.2
  set K : TopologicalSpace.Compacts ℝ := ⟨Set.uIcc x 2, isCompact_uIcc⟩ with hK
  have hnormsum : Summable (fun n : ℕ => ‖(gcm a n).restrict K‖) :=
    (Wsummable (a := a) x hx1).of_nonneg_of_le (fun n => norm_nonneg _) (fun n => gnorm_le x hx1 hx2 n)
  have hton := tsum_intervalIntegral_eq_of_summable_norm (a := x) (b := 2) hnormsum
  have hL : (∑' n : ℕ, ∫ t in x..2, gcm a n t) = Vf a x - Vf a 2 := by
    have hcong : (fun n : ℕ => ∫ t in x..2, gcm a n t)
        = (fun n : ℕ => prc a n * (n:ℝ)^(-x) - prc a n * (n:ℝ)^(-(2:ℝ))) := by
      funext n; rw [intterm]; ring
    rw [hcong, Summable.tsum_sub (Vfsummable (a := a) x hx1) (Vfsummable (a := a) 2 (by norm_num))]
    rfl
  have hR : (∫ t in x..2, ∑' n : ℕ, gcm a n t) = ∫ t in x..2, Wf a t := by
    simp only [Wf, gcm, ContinuousMap.coe_mk]
  rw [hL] at hton; rw [hR] at hton
  linarith [hton]

theorem Wint (ha : IsUnit a) {x : ℝ} (hx : x ∈ Set.Ioc 1 2) :
    IntervalIntegrable (Wf a) MeasureTheory.volume x 2 := by
  have hx1 : 1 < x := hx.1
  have hx2 : x ≤ 2 := hx.2
  set K : TopologicalSpace.Compacts ℝ := ⟨Set.uIcc x 2, isCompact_uIcc⟩ with hK
  have hnormsum : Summable (fun n : ℕ => ‖(gcm a n).restrict K‖) :=
    (Wsummable (a := a) x hx1).of_nonneg_of_le (fun n => norm_nonneg _) (fun n => gnorm_le x hx1 hx2 n)
  have hFsum : Summable (fun n : ℕ => (gcm a n).restrict K) := hnormsum.of_norm
  set S : C(K, ℝ) := ∑' n, (gcm a n).restrict K with hS
  have hSapp : ∀ p : K, S p = Wf a p.1 := by
    intro p
    have hmap := ContinuousLinearMap.map_tsum (ContinuousMap.evalCLM ℝ p) hFsum
    simp only [ContinuousMap.evalCLM_apply, hS] at hmap ⊢
    rw [hmap, Wf]
    exact tsum_congr (fun n => rfl)
  have hcont : ContinuousOn (Wf a) (Set.uIcc x 2) := by
    rw [continuousOn_iff_continuous_restrict]
    have heq : (Set.uIcc x 2).restrict (Wf a) = fun p : K => S p := by
      funext p; rw [hSapp]; rfl
    rw [heq]; exact S.continuous.comp continuous_id
  exact hcont.intervalIntegrable

theorem int_pole (c C : ℝ) (x : ℝ) (hx : 1 < x) (hx2 : x ≤ 2) :
    (∫ t in x..2, (c / (t - 1) - C)) = c * (- Real.log (x - 1)) - C * (2 - x) := by
  have hxpos : (0:ℝ) < x - 1 := by linarith
  have h1 : (∫ t in x..2, c / (t - 1)) = c * (- Real.log (x - 1)) := by
    simp only [div_eq_mul_inv]
    rw [intervalIntegral.integral_const_mul, integral_comp_sub_right (fun u => u⁻¹) 1,
        integral_inv_of_pos hxpos (by norm_num : (0:ℝ) < 2 - 1),
        show (2:ℝ) - 1 = 1 by norm_num, Real.log_div one_ne_zero (ne_of_gt hxpos), Real.log_one]
    ring
  have hint : IntervalIntegrable (fun t => c / (t - 1)) MeasureTheory.volume x 2 := by
    apply (continuousOn_const.div (by fun_prop) ?_).intervalIntegrable
    intro t ht; simp only [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
    exact ne_of_gt (by linarith [ht.1])
  rw [intervalIntegral.integral_sub hint (intervalIntegral.intervalIntegrable_const),
      h1, intervalIntegral.integral_const, smul_eq_mul]; ring

theorem int_pole_intble (c C : ℝ) (x : ℝ) (hx : 1 < x) (hx2 : x ≤ 2) :
    IntervalIntegrable (fun t => c / (t - 1) - C) MeasureTheory.volume x 2 := by
  apply IntervalIntegrable.sub _ (intervalIntegral.intervalIntegrable_const)
  apply (continuousOn_const.div (by fun_prop) ?_).intervalIntegrable
  intro t ht; simp only [Set.uIcc_of_le hx2, Set.mem_Icc] at ht
  exact ne_of_gt (by linarith [ht.1])

variable [NeZero q]

theorem Vmono (ha : IsUnit a) {x : ℝ} (hx : 1 ≤ x)
    (hsum : Summable (fun n : ℕ => prc a n / n)) : Vf a x ≤ Vf a 1 := by
  have hV1 : (fun n : ℕ => prc a n / n) = (fun n : ℕ => prc a n * (n:ℝ)^(-(1:ℝ))) := by
    funext n; rw [Real.rpow_neg_one]; ring
  have hle : ∀ n : ℕ, prc a n * (n:ℝ)^(-x) ≤ prc a n * (n:ℝ)^(-(1:ℝ)) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    · simp [prc, Nat.not_prime_zero]
    · refine mul_le_mul_of_nonneg_left ?_ (prc_nonneg a n)
      exact Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast hn) (by linarith)
  have hsum' : Summable (fun n : ℕ => prc a n * (n:ℝ)^(-(1:ℝ))) := hV1 ▸ hsum
  have hnn : ∀ n : ℕ, 0 ≤ prc a n * (n:ℝ)^(-x) :=
    fun n => mul_nonneg (prc_nonneg a n) (Real.rpow_nonneg (by positivity) _)
  unfold Vf
  exact Summable.tsum_le_tsum hle (hsum'.of_nonneg_of_le hnn hle) hsum'

theorem bridge (hq : 1 < q) (ha : a = ((q - 1 : ℕ) : ZMod q))
    (H : Summable (fun p : {p : Nat // p.Prime ∧ p % q = q - 1} => (1 / (p.1 : ℝ)))) :
    Summable (fun n : ℕ => prc a n / n) := by
  have H2 : Summable ({p : ℕ | p.Prime ∧ p % q = q - 1}.indicator (fun p : ℕ => 1 / (p:ℝ))) :=
    (summable_subtype_iff_indicator (s := {p : ℕ | p.Prime ∧ p % q = q - 1})
      (f := fun n : ℕ => 1 / (n:ℝ))).mp H
  refine H2.congr (fun n => ?_)
  have hiff : ((n:ZMod q) = a) ↔ (n % q = q - 1) := by
    rw [ha, ZMod.natCast_eq_natCast_iff]; unfold Nat.ModEq
    rw [Nat.mod_eq_of_lt (show q - 1 < q by omega)]
  unfold prc
  rw [Set.indicator_apply]; simp only [Set.mem_setOf_eq]
  by_cases hp : n.Prime ∧ n % q = q - 1
  · rw [if_pos hp, if_pos ⟨hp.1, hiff.mpr hp.2⟩]
  · rw [if_neg hp, if_neg (fun h => hp ⟨h.1, hiff.mp h.2⟩)]; simp

theorem Wpole (ha : IsUnit a) :
    ∃ C : ℝ, ∀ {x : ℝ}, x ∈ Set.Ioc 1 2 → (q.totient : ℝ)⁻¹ / (x - 1) - C ≤ Wf a x := by
  obtain ⟨C, hC⟩ := LSeries_residueClass_lower_bound ha
  have hBsum : Summable (fun n : ℕ => (if n.Prime then 0 else residueClass a n) / n) :=
    summable_residueClass_non_primes_div a
  set B : ℝ := ∑' n : ℕ, (if n.Prime then 0 else residueClass a n) / (n:ℝ) with hBdef
  refine ⟨C + B, fun {x} hx => ?_⟩
  have hx1 : 1 < x := hx.1
  have hRs := Rsum (a := a) x hx1
  have hnp : ∀ n : ℕ, 1 ≤ n → (n:ℝ) ≤ (n:ℝ)^x := by
    intro n hn
    have h1n : (1:ℝ) ≤ (n:ℝ) := by exact_mod_cast hn
    calc (n:ℝ) = (n:ℝ)^(1:ℝ) := (Real.rpow_one _).symm
    _ ≤ (n:ℝ)^x := Real.rpow_le_rpow_of_exponent_le h1n hx1.le
  have hsplit : ∀ n : ℕ, residueClass a n / (n:ℝ)^x
      = (if n.Prime then residueClass a n else 0) / (n:ℝ)^x
        + (if n.Prime then 0 else residueClass a n) / (n:ℝ)^x := by
    intro n; by_cases hp : n.Prime <;> simp [hp]
  have hWs : Summable (fun n : ℕ => (if n.Prime then residueClass a n else 0) / (n:ℝ)^x) := by
    apply hRs.of_nonneg_of_le
      (fun n => div_nonneg (by split_ifs; exacts [residueClass_nonneg a n, le_refl 0]) (Real.rpow_nonneg (Nat.cast_nonneg n) x))
      (fun n => ?_)
    gcongr
    split_ifs
    · exact le_refl _
    · exact residueClass_nonneg a n
  have htle : ∀ n : ℕ, (if n.Prime then 0 else residueClass a n) / (n:ℝ)^x
      ≤ (if n.Prime then 0 else residueClass a n) / (n:ℝ) := by
    intro n
    rcases Nat.eq_zero_or_pos n with rfl | hn
    · simp
    · gcongr
      · split_ifs; exacts [le_refl 0, residueClass_nonneg a n]
      · exact hnp n hn
  have htails : Summable (fun n : ℕ => (if n.Prime then 0 else residueClass a n) / (n:ℝ)^x) := by
    apply hBsum.of_nonneg_of_le
      (fun n => div_nonneg (by split_ifs; exacts [le_refl 0, residueClass_nonneg a n]) (Real.rpow_nonneg (Nat.cast_nonneg n) x)) htle
  have hWval : Wf a x = ∑' n : ℕ, (if n.Prime then residueClass a n else 0) / (n:ℝ)^x := by
    unfold Wf; exact tsum_congr (fun n => Wf_summand x n)
  have hRsplit : (∑' n : ℕ, residueClass a n / (n:ℝ)^x)
      = Wf a x + ∑' n : ℕ, (if n.Prime then 0 else residueClass a n) / (n:ℝ)^x := by
    rw [hWval, ← Summable.tsum_add hWs htails]; exact tsum_congr hsplit
  have hpole := hC hx
  have htaille : (∑' n : ℕ, (if n.Prime then 0 else residueClass a n) / (n:ℝ)^x) ≤ B :=
    Summable.tsum_le_tsum htle htails hBsum
  linarith [hpole, htaille, hRsplit]

theorem hunb (ha : IsUnit a)
    (hVW : ∀ {x:ℝ}, x ∈ Set.Ioc 1 2 → Vf a x = Vf a 2 + ∫ t in x..2, Wf a t)
    (hWint : ∀ {x:ℝ}, x ∈ Set.Ioc 1 2 → IntervalIntegrable (Wf a) MeasureTheory.volume x 2)
    (C : ℝ) (hC : ∀ {x:ℝ}, x ∈ Set.Ioc 1 2 → (q.totient:ℝ)⁻¹/(x-1) - C ≤ Wf a x) :
    ∀ M : ℝ, ∃ x : ℝ, x ∈ Set.Ioc 1 2 ∧ M < Vf a x := by
  intro M
  have hcpos : (0:ℝ) < (q.totient:ℝ)⁻¹ := by
    have : 0 < q.totient := Nat.totient_pos.mpr (Nat.pos_of_ne_zero (NeZero.ne q)); positivity
  set c : ℝ := (q.totient:ℝ)⁻¹ with hc
  set K : ℝ := (Vf a 2 - |C| - M) / c with hKd
  set ε : ℝ := min 1 (Real.exp (K - 1)) with hε
  have hεpos : 0 < ε := lt_min one_pos (Real.exp_pos _)
  have hεle : ε ≤ 1 := min_le_left _ _
  set x : ℝ := 1 + ε with hxd
  have hxmem : x ∈ Set.Ioc 1 2 := ⟨by linarith, by linarith⟩
  have hxm1 : x - 1 = ε := by rw [hxd]; ring
  refine ⟨x, hxmem, ?_⟩
  have hmono : (∫ t in x..2, (c/(t-1) - C)) ≤ ∫ t in x..2, Wf a t := by
    apply intervalIntegral.integral_mono_on hxmem.2 (int_pole_intble c C x hxmem.1 hxmem.2) (hWint hxmem)
    intro t ht
    exact hC ⟨by simp only [Set.mem_Icc] at ht; linarith [ht.1, hxmem.1], by
      simp only [Set.mem_Icc] at ht; linarith [ht.2]⟩
  have heval := int_pole c C x hxmem.1 hxmem.2
  rw [hxm1] at heval
  have hlog : Real.log ε ≤ K - 1 := by
    calc Real.log ε ≤ Real.log (Real.exp (K-1)) := Real.log_le_log hεpos (min_le_right _ _)
    _ = K - 1 := Real.log_exp _
  have hcK : c * K = Vf a 2 - |C| - M := by rw [hKd]; field_simp
  have hCbound : -C * (2 - x) ≥ -|C| := by
    have h2x : (0:ℝ) ≤ 2 - x := by linarith [hxmem.2]
    have h2x1 : 2 - x ≤ 1 := by linarith [hxmem.1]
    nlinarith [abs_nonneg C, neg_abs_le C, le_abs_self C]
  rw [hVW hxmem]
  have h3 : Vf a 2 + (c * (-Real.log ε) - C * (2 - x)) ≤ Vf a 2 + ∫ t in x..2, Wf a t := by
    rw [← heval]; linarith [hmono]
  have h4 : M + c ≤ Vf a 2 + (c * (-Real.log ε) - C * (2 - x)) := by
    have hc2 : c * (-Real.log ε) ≥ -(c * (K-1)) := by nlinarith [hlog, hcpos]
    nlinarith [hc2, hCbound, hcK]
  linarith [h3, h4, hcpos]

theorem main (hq : 1 < q) :
    ¬ Summable (fun p : {p : Nat // p.Prime ∧ p % q = q - 1} => (1 / (p.1 : ℝ))) := by
  set a : ZMod q := ((q - 1 : ℕ) : ZMod q) with ha_def
  have ha : IsUnit a := by
    have h : a = -1 := by
      rw [ha_def]; push_cast [Nat.cast_sub (by omega : 1 ≤ q)]; simp [ZMod.natCast_self]
    rw [h]; exact isUnit_one.neg
  intro H
  have hsum : Summable (fun n : ℕ => prc a n / n) := bridge hq ha_def H
  obtain ⟨C, hC⟩ := Wpole ha
  have hunbd := hunb ha (fun {x} hx => VW ha hx) (fun {x} hx => Wint ha hx) C hC
  obtain ⟨x, hx, hM⟩ := hunbd (Vf a 1)
  exact absurd (Vmono ha hx.1.le hsum) (not_le.mpr hM)

end A1proof


namespace Erdos1054

noncomputable def sigma (n : Nat) : Nat := n.divisors.sum (fun d => d)


noncomputable def g (e n : Nat) : Rat :=
  (n.divisors.filter (fun r => e ≤ r)).sum (fun r => (1 : Rat) / r)





def ActiveSet (e a : Nat) : Finset Nat :=
  (Finset.range e).filter (fun r => 0 < r ∧ r ∣ e * a)

noncomputable def H (e a : Nat) : Nat := sigma (e * a) - F e a

theorem ed_pos (e d : Nat) (he : 0 < e) (hd : 0 < d) : 0 < e * d := by
  exact Nat.mul_pos he hd

theorem represented_of_F (e d : Nat) (he : 0 < e) (hd : 0 < d) :
    Represented (F e d) := by
  exact ⟨e, d, he, hd, rfl⟩

theorem one_mem_activeSet (e a : Nat) (he : 1 < e) :
    1 ∈ ActiveSet e a := by
  unfold ActiveSet
  simp [he]

theorem countUpTo_false (X : Nat) :
    countUpTo (fun _ : Nat => False) X = 0 := by
  unfold countUpTo
  simp

theorem densityZero_false : DensityZero (fun _ : Nat => False) := by
  intro ε hε
  refine ⟨0, ?_⟩
  intro X _hX
  rw [countUpTo_false]
  exact mul_nonneg hε.le (by exact_mod_cast Nat.zero_le X)

theorem countUpTo_true (X : Nat) :
    countUpTo (fun _ : Nat => True) X = X + 1 := by
  unfold countUpTo
  simp

theorem reflect_mem_right (e d q : Nat) (he : 0 < e) (hd : 0 < d)
    (hq : q ∈ (e * d).divisors.filter (fun q => q ≤ d)) :
    (e * d) / q ∈ (e * d).divisors.filter (fun r => e ≤ r) := by
  rw [Finset.mem_filter] at hq ⊢
  rcases hq with ⟨hqdivs, hqle⟩
  have hqdvd : q ∣ e * d := (Nat.mem_divisors.mp hqdivs).1
  have hned0 : e * d ≠ 0 := (Nat.mem_divisors.mp hqdivs).2
  have hqpos : 0 < q := Nat.pos_of_dvd_of_pos hqdvd (Nat.mul_pos he hd)
  constructor
  · exact Nat.mem_divisors.mpr ⟨Nat.div_dvd_of_dvd hqdvd, hned0⟩
  · exact (Nat.le_div_iff_mul_le hqpos).2 (by
      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
        using Nat.mul_le_mul_left e hqle)

theorem reflect_mem_left (e d r : Nat) (_he : 0 < e) (_hd : 0 < d)
    (hr : r ∈ (e * d).divisors.filter (fun r => e ≤ r)) :
    (e * d) / r ∈ (e * d).divisors.filter (fun q => q ≤ d) := by
  rw [Finset.mem_filter] at hr ⊢
  rcases hr with ⟨hrdivs, her⟩
  have hrdvd : r ∣ e * d := (Nat.mem_divisors.mp hrdivs).1
  have hned0 : e * d ≠ 0 := (Nat.mem_divisors.mp hrdivs).2
  constructor
  · exact Nat.mem_divisors.mpr ⟨Nat.div_dvd_of_dvd hrdvd, hned0⟩
  · exact Nat.div_le_of_le_mul (by
      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
        using Nat.mul_le_mul_right d her)

theorem countUpTo_mono (P Q : Nat → Prop)
    (h : ∀ n, P n → Q n) (X : Nat) : countUpTo P X ≤ countUpTo Q X := by
  classical
  unfold countUpTo
  exact Finset.card_le_card (by
    intro n hn
    simp only [Finset.mem_filter, Finset.mem_range] at hn ⊢
    exact ⟨hn.1, h n hn.2⟩)

theorem countUpTo_union_le (P Q : Nat → Prop)
    (X : Nat) : countUpTo (fun n => P n ∨ Q n) X ≤ countUpTo P X + countUpTo Q X := by
  classical
  unfold countUpTo
  refine le_trans (Finset.card_le_card ?_) (Finset.card_union_le
    ((Finset.range (X + 1)).filter P)
    ((Finset.range (X + 1)).filter Q))
  intro n hn
  simp only [Finset.mem_filter, Finset.mem_range, Finset.mem_union] at hn ⊢
  rcases hn with ⟨hr, hpq⟩
  rcases hpq with hp | hq
  · exact Or.inl ⟨hr, hp⟩
  · exact Or.inr ⟨hr, hq⟩

theorem densityZero_mono (P Q : Nat → Prop)
    (hPQ : ∀ n, P n → Q n) (hQ : DensityZero Q) : DensityZero P := by
  classical
  intro ε hε
  rcases hQ ε hε with ⟨X₀, hX₀⟩
  refine ⟨X₀, ?_⟩
  intro X hX
  have hnat : countUpTo P X ≤ countUpTo Q X := countUpTo_mono P Q hPQ X
  have hrat : (countUpTo P X : Rat) ≤ (countUpTo Q X : Rat) := by
    exact_mod_cast hnat
  exact le_trans hrat (hX₀ X hX)

theorem countUpTo_inter_le_left (P Q : Nat → Prop)
    (X : Nat) : countUpTo (fun n => P n ∧ Q n) X ≤ countUpTo P X := by
  classical
  exact countUpTo_mono (fun n => P n ∧ Q n) P (by intro n hn; exact hn.1) X

theorem countUpTo_inter_le_right (P Q : Nat → Prop)
    (X : Nat) : countUpTo (fun n => P n ∧ Q n) X ≤ countUpTo Q X := by
  classical
  exact countUpTo_mono (fun n => P n ∧ Q n) Q (by intro n hn; exact hn.2) X

theorem densityZero_union (P Q : Nat → Prop)
    (hP : DensityZero P) (hQ : DensityZero Q) : DensityZero (fun n => P n ∨ Q n) := by
  classical
  intro ε hε
  let δ : Rat := ε / 2
  have hδ : 0 < δ := by
    dsimp [δ]
    exact div_pos hε (by norm_num)
  rcases hP δ hδ with ⟨XP, hXP⟩
  rcases hQ δ hδ with ⟨XQ, hXQ⟩
  refine ⟨max XP XQ, ?_⟩
  intro X hX
  have hXPle : X ≥ XP := le_trans (Nat.le_max_left XP XQ) hX
  have hXQle : X ≥ XQ := le_trans (Nat.le_max_right XP XQ) hX
  calc
    (countUpTo (fun n => P n ∨ Q n) X : Rat)
        ≤ (countUpTo P X : Rat) + (countUpTo Q X : Rat) := by
          exact_mod_cast countUpTo_union_le P Q X
    _ ≤ δ * X + δ * X := by
          exact add_le_add (hXP X hXPle) (hXQ X hXQle)
    _ = ε * X := by
          dsimp [δ]
          ring

theorem densityZero_inter_left (P Q : Nat → Prop)
    (hP : DensityZero P) : DensityZero (fun n => P n ∧ Q n) := by
  classical
  exact densityZero_mono (fun n => P n ∧ Q n) P (by intro n hn; exact hn.1) hP

theorem densityZero_inter_right (P Q : Nat → Prop)
    (hQ : DensityZero Q) : DensityZero (fun n => P n ∧ Q n) := by
  classical
  exact densityZero_mono (fun n => P n ∧ Q n) Q (by intro n hn; exact hn.2) hQ

theorem densityZero_of_forall_not (P : Nat → Prop) (h : ∀ n, ¬ P n) :
    DensityZero P := by
  classical
  intro ε hε
  refine ⟨0, ?_⟩
  intro X _hX
  unfold countUpTo
  simp [h]
  exact mul_nonneg hε.le (by exact_mod_cast Nat.zero_le X)

theorem activeSet_subset_range (e a : Nat) : ActiveSet e a ⊆ Finset.range e := by
  intro r hr
  unfold ActiveSet at hr
  exact (Finset.mem_filter.mp hr).1

theorem activeSet_mem_lt (e a r : Nat) (hr : r ∈ ActiveSet e a) : r < e := by
  have hrange : r ∈ Finset.range e := activeSet_subset_range e a hr
  exact Finset.mem_range.mp hrange

theorem activeSet_mem_pos (e a r : Nat) (hr : r ∈ ActiveSet e a) : 0 < r := by
  unfold ActiveSet at hr
  exact (Finset.mem_filter.mp hr).2.1

theorem activeSet_mem_dvd (e a r : Nat) (hr : r ∈ ActiveSet e a) : r ∣ e * a := by
  unfold ActiveSet at hr
  exact (Finset.mem_filter.mp hr).2.2

theorem activeSet_nonempty_of_one_lt (e a : Nat) (he : 1 < e) : (ActiveSet e a).Nonempty := by
  exact ⟨1, one_mem_activeSet e a he⟩

theorem activeSet_card_pos_of_one_lt (e a : Nat) (he : 1 < e) :
    0 < (ActiveSet e a).card := by
  exact Finset.card_pos.mpr (activeSet_nonempty_of_one_lt e a he)

theorem activeSet_sum_pos_of_one_lt (e a : Nat) (he : 1 < e) :
    0 < (ActiveSet e a).sum (fun r => r) := by
  exact Finset.sum_pos (by intro x hx; exact activeSet_mem_pos e a x hx)
    (activeSet_nonempty_of_one_lt e a he)

theorem activeSet_sum_ne_zero_of_one_lt (e a : Nat) (he : 1 < e) :
    (ActiveSet e a).sum (fun r => r) ≠ 0 := by
  exact Nat.ne_of_gt (activeSet_sum_pos_of_one_lt e a he)

theorem activeSet_eq_divisors_filter_lt (e a : Nat) (he : 0 < e) (ha : 0 < a) :
    ActiveSet e a = (e * a).divisors.filter (fun r => r < e) := by
  ext r
  constructor
  · intro hr
    have hrdvd : r ∣ e * a := activeSet_mem_dvd e a r hr
    have hrlt : r < e := activeSet_mem_lt e a r hr
    rw [Finset.mem_filter]
    exact ⟨Nat.mem_divisors.mpr ⟨hrdvd, (Nat.mul_pos he ha).ne'⟩, hrlt⟩
  · intro hr
    rw [Finset.mem_filter] at hr
    unfold ActiveSet
    rw [Finset.mem_filter]
    constructor
    · exact Finset.mem_range.mpr hr.2
    · constructor
      · exact Nat.pos_of_mem_divisors hr.1
      · exact (Nat.mem_divisors.mp hr.1).1

theorem activeSet_sum_le_card_mul_e (e a : Nat) :
    (ActiveSet e a).sum (fun r => r) ≤ (ActiveSet e a).card * e := by
  calc
    (ActiveSet e a).sum (fun r => r) ≤ (ActiveSet e a).sum (fun _ => e) := by
      exact Finset.sum_le_sum (fun r hr => Nat.le_of_lt (activeSet_mem_lt e a r hr))
    _ = (ActiveSet e a).card * e := by
      rw [Finset.sum_const, smul_eq_mul]

theorem activeSet_card_le_e (e a : Nat) : (ActiveSet e a).card ≤ e := by
  calc
    (ActiveSet e a).card ≤ (Finset.range e).card := Finset.card_le_card (activeSet_subset_range e a)
    _ = e := by simp

theorem activeSet_sum_le_e_sq (e a : Nat) :
    (ActiveSet e a).sum (fun r => r) ≤ e * e := by
  exact le_trans (activeSet_sum_le_card_mul_e e a)
    (Nat.mul_le_mul_right e (activeSet_card_le_e e a))

theorem F_le_sigma (e a : Nat) : F e a ≤ sigma (e * a) := by
  unfold F sigma
  exact Finset.sum_le_sum_of_subset_of_nonneg
    (by intro x hx; exact (Finset.mem_filter.mp hx).1)
    (by intro x hxt hxnot; exact Nat.zero_le x)

theorem activeSet_subset_divisors (e a : Nat) (he : 0 < e) (ha : 0 < a) :
    ActiveSet e a ⊆ (e * a).divisors := by
  intro r hr
  have hmem : r ∈ (Finset.range e).filter (fun r => 0 < r ∧ r ∣ e * a) := by
    simpa [ActiveSet] using hr
  have hdvd : r ∣ e * a := (Finset.mem_filter.mp hmem).2.2
  exact Nat.mem_divisors.mpr ⟨hdvd, (Nat.mul_pos he ha).ne'⟩

theorem activeSet_sum_le_sigma (e a : Nat) (he : 0 < e) (ha : 0 < a) :
    (ActiveSet e a).sum (fun r => r) ≤ sigma (e * a) := by
  rw [activeSet_eq_divisors_filter_lt e a he ha]
  unfold sigma
  exact Finset.sum_le_sum_of_subset_of_nonneg
    (by intro x hx; exact (Finset.mem_filter.mp hx).1)
    (by intro x hxt hxnot; exact Nat.zero_le x)

theorem div_reflect_involutive (n q : Nat) (hn : 0 < n) (hq : q ∈ n.divisors) :
    n / (n / q) = q := by
  have hqd : q ∣ n := (Nat.mem_divisors.mp hq).1
  exact Nat.div_div_self hqd hn.ne'

theorem prefix_reflect_involutive (e a q : Nat) (he : 0 < e) (ha : 0 < a)
    (hq : q ∈ (e * a).divisors.filter (fun q => q ≤ a)) :
    (e * a) / ((e * a) / q) = q := by
  have hn : 0 < e * a := Nat.mul_pos he ha
  have hqdivs : q ∈ (e * a).divisors := (Finset.mem_filter.mp hq).1
  simpa using div_reflect_involutive (e * a) q hn hqdivs

theorem suffix_reflect_involutive (e a r : Nat) (he : 0 < e) (ha : 0 < a)
    (hr : r ∈ (e * a).divisors.filter (fun r => e ≤ r)) :
    (e * a) / ((e * a) / r) = r := by
  have hn : 0 < e * a := Nat.mul_pos he ha
  have hrdivs : r ∈ (e * a).divisors := (Finset.mem_filter.mp hr).1
  simpa using div_reflect_involutive (e * a) r hn hrdivs

theorem mul_g_le_sigma_rat (e a : Nat) (_he : 0 < e) (_ha : 0 < a)
    (hFg : (F e a : Rat) = (e * a : Rat) * g e (e * a)) :
    (e * a : Rat) * g e (e * a) ≤ (sigma (e * a) : Rat) := by
  have hnat : F e a ≤ sigma (e * a) := F_le_sigma e a
  have hrat : (F e a : Rat) ≤ (sigma (e * a) : Rat) := by
    exact_mod_cast hnat
  rw [hFg] at hrat
  exact hrat


